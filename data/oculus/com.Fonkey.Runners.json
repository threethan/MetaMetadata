5/38974513_862523441940798_5536174085458991433_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2oPuHJJayb0Q7kNvgG5rhVc&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDPIOBTvHFvAkdPK71Qryqg5LjwJ90tdH3wiYhRpu6mJQ&oe=670FB47E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cool image of foncre 2560 X 1440.png", "id": "818592230286497", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974494_818592233619830_5672033116955897345_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gaKNjfwAJoEQ7kNvgGu_Rhu&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCgDuBXNjOzArxM9YGqzQAg7__wE4KIHedcUKu0i-ssVg&oe=670FB842"}, "display_name": "Foncre", "keywords": [], "long_description": "Foncre is an exciting virtual reality (VR) game that takes the popular and fast-paced gameplay of the original Fonkey runners and adapts it to immersive VR environments. This game offers an entirely new way to experience the thrill of chasing and escaping in a three-dimensional space using the Gorilla Tag locomotion system.", "short_description": "The gameplay in Foncre is centered around a thrilling game of Horror. Players are divided into two teams, typically with one team taking on the role of \"fonke's\" and the other team as \"runners.\" The objective for the horror ai's is to chase down and eliminate the fonke's, while the runners must evade capture by using their speed, agility, and various tactics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fonktag-com2.webnode.page/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "fonkey", "support_website_url": null, "website_url": "https://fonktag-com2.webnode.page/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_