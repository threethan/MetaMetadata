=6e7a0a&_nc_ohc=kklUVoR36LQQ7kNvgEHZkDB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWK_mUq5vDPrWDa_jhVrANRd9-UlnWnwMlv7WXWPzDbw&oe=6714D6E2"}, {"file_name": "Screenshot_1.png", "id": "508666961166138", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031640_508666964499471_4830369738960598516_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vVp2LJczrVEQ7kNvgFo_8YG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFDfN5LU0Ljvjd9NZvyXpDyggUPtHBlAahIfYvILo0Rg&oe=6714F76D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_3.png", "id": "526530555909879", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031308_526530559243212_7804811575977836719_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zpy6Z_tegv8Q7kNvgHmO_jA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDml_3SE3oJwWrhgJWLhRo3xxc6c_Gbjf6gQOmMTPC95w&oe=6714EBD5"}, "display_name": "Bliss", "keywords": [], "long_description": "With Bliss, we guide you to breathe at your \"Resonant Frequency\" using beautiful visuals and relaxing audio. We call this Visual Breathing, and it's deeply relaxing.\n\nExtensive research has shown doing 12 minutes of resonant frequency breathing a day can transform your nervous system and has numerous benefits:\n-It helps improve symptoms of anxiety and depression\n-It lets your body fall asleep faster and sustain deeper sleep\n-It can immediately improve energy levels and prevent burnout\nTo learn more about the science of this technique, please visit our website at https://getbliss.app", "short_description": "With Bliss, we guide you to breathe at your \"Resonant Frequency\" using beautiful visuals and relaxing audio. We call this Visual Breathing, and it's deeply relaxing.\n\nExtensive research has shown doing 12 minutes of resonant frequency breathing a day can transform your nervous system and has numerous benefits.\n\nTo learn more about the science of this technique, please visit our website at https://getbliss.app"}]}, "developer_name": null, "developer_privacy_policy_url": "https://getbliss.app/terms", "developer_terms_of_service_url": "https://getbliss.app/terms", "publisher_name": "Rockwell Ventures", "support_website_url": null, "website_url": "https://getbliss.app/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1181174749156030"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_746514476318260_5110936428598265048_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q97nzvQVAc4Q7kNvgEpr9Ki&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKhjGas9OHNGsHy6fsIn6xgBqjqqdUAPaPr5TcjUjnkg&oe=6714F191"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bliss", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1653582600, "lastRevision": {"nodes": [{"id": "636603614157566", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4759867464060529", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "354491360022167"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"