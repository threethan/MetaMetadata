710E0C1"}, {"file_name": "Screenshot_4.png", "id": "326946172620699", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974853_326946175954032_4895921826098113970_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-zAxWVBmz4Q7kNvgE0aumo&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB6NPLSUNCGeCV7ChQ0WU1wfCnduDn2o89dWsiVmw5joQ&oe=67110188"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "667537957658372", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982512_667537960991705_1442117798375954928_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2akwiZKkxiMQ7kNvgHurLpl&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYARcyQE76PEYANH8CO5hfroCl5wP19C-eZtqK909F1hqg&oe=6710E6E8"}, "display_name": "Bliss - Visual Breathing", "keywords": [], "long_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nMost people don't realize, but there are simple breathing exercises that can significantly improve your health.\n\nBreathing at a particular rate for extended periods of time can be difficult and boring though. So to make it a more enjoyable experience, we've created beautiful visuals that help guide you through \"Resonant Frequency Breathing\" exercises. We call this Visual Breathing.", "short_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nVisual breathing guides you to breathe at your resonant frequency, which extensive research has shown impacts many areas of your wellbeing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://getbliss.app/terms", "developer_terms_of_service_url": "https://getbliss.app/terms", "publisher_name": "Rockwell Ventures", "support_website_url": null, "website_url": "https://g