i": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031618_2205259742957243_4814912224586648800_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0AZe19c9lA4Q7kNvgHOah4T&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYIZo66liEISZWotNtJIMKV_k6F10Fb_5G6KmF2Ya-jw&oe=672355C1"}, {"file_name": "Screenshot_4.png", "id": "326946172620699", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974853_326946175954032_4895921826098113970_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03jY-xgeitIQ7kNvgG0NBH2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnH-Q4J2m2w5Ky2J7LQhNm5YTlDhb68MXbOkNhpFo3Ng&oe=67237688"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "667537957658372", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982512_667537960991705_1442117798375954928_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z1vvi7N2LEkQ7kNvgE5WYFT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2Rtc4YdCIaNQH1L2Cg23IlyO04P6Byi6VxI9SAnyO0Q&oe=67235BE8"}, "display_name": "Bliss - Visual Breathing", "keywords": [], "long_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nMost people don't realize, but there are simple breathing exercises that can significantly improve your health.\n\nBreathing at a particular rate for extended periods of time can be difficult and boring though. So to make it a more enjoyable experience, we've created beautiful visuals that help guide you through \"Resonant Frequency Breathing\" exercises. We call this Visual Breathing.", "short_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nVisual breathing guides you to breathe at your resonant frequency, which extensive research has shown impacts many areas of your wellbeing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://getbliss.app/terms", "developer_terms_of_service_url": "https://getbliss.app/terms", "publisher_name": "Rockwell Ventures", "support_website_url": null, "website_url": "https://getbliss.app/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "440621284605192"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5615029358544331", "version": "1.0.0"}, "id": "2115006895331668", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4759867464060529", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5615029358544331"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2115006895331668"}]}, "change_log": "Putting bugs to sleep...\n\nIf you're loving the app, take some time to leave us a review. It really helps a lot. Thank you!", "created_date": 1666214700, "id": "5615029358544331", "version": 