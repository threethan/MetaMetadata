25/39031618_2205259742957243_4814912224586648800_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HuRrBZZxfEMQ7kNvgFBDtAn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDaYuBPv-yHhIvi1U2F8e9mizo7CY0Ci8Q4k5TmxBW0JA&oe=671CBE41"}, {"file_name": "Screenshot_4.png", "id": "326946172620699", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974853_326946175954032_4895921826098113970_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gb26KaE9AxIQ7kNvgHZKEPf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAo0XdMRlNS42K1XNVi96cPhv87L6VDbVluvoymFSLdpg&oe=671CDF08"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "667537957658372", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982512_667537960991705_1442117798375954928_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJi948lQGwEQ7kNvgHH4RqH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcAR0v7c43lb-p8TXLYKTv00XIYC_hca599gOtNTEw-A&oe=671CC468"}, "display_name": "Bliss - Visual Breathing", "keywords": [], "long_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nMost people don't realize, but there are simple breathing exercises that can significantly improve your health.\n\nBreathing at a particular rate for extended periods of time can be difficult and boring though. So to make it a more enjoyable experience, we've created beautiful visuals that help guide you through \"Resonant Frequency Breathing\" exercises. We call this Visual Breathing.", "short_description": "Bliss is a revolutionary new way to practice breathwork in virtual reality.\n\nOur body responds to our breathing. Bliss uses science-backed visual breathing aides to help you relax.\n\nVisual breathing guides you to breathe at your resonant frequency, which extensive research has shown impacts many areas of your wellbeing."}]}, 