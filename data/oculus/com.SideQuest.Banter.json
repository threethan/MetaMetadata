t-lga3-2.oculuscdn.com/v/t64.5771-25/39036620_942868613628807_6220741875054134395_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZdOO7cNgJ48Q7kNvgFxbXBf&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCNj2YTq6OhE9TV2LCMytPAxmhVO4Z1MB0-vPCU9Wcd6g&oe=675EDC7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled (15).png", "id": "1574809773041483", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75556790_1574809776374816_8807360985140779263_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mOjggEjoD-8Q7kNvgFAPQzf&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDJSI5nfMwaWr8buCPfhhW0LzVXd1ugBWfqoaienjWhzQ&oe=675EBA6D"}, "display_name": "Banter", "keywords": [], "long_description": "Banter is a Social VR experience that allows you to enjoy hanging out with friends whilst having fun. You can select from a huge number of custom avatars provided by Ready Player Me. Rather than appeal to younger players, we want Banter to be a place where adults can hang out and enjoy each other's company.\n\nBanter provides more presence than other social VR experiences because it provides full-body avatars with arms and legs, something we think is essential to feel present in your digital self. We look forward to supporting hi quality full-body tracking soon without the need for an expensive PC or equipment.\n\nEnjoy crystal clear spatial audio so you can hear your friends in VR, find your crew and enjoy casual mini-games that don't impose on the social experience too much. Run, jump, climb even zipline with a physics-enabled character allowing you to explore every part of Banter.\n\nBuild your own spaces and games with our Aframe integration!", "short_description": "The magnificent art of using word play, opinions, exaggeration, irony, sarcasm, and other comedic themes to have fun with your friends in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1StwiWB6pBf29XTZDxFR7zW-i-dTNUc6y0J83PK