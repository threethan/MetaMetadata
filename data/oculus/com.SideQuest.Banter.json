t-iad3-2.oculuscdn.com/v/t64.5771-25/39036620_942868613628807_6220741875054134395_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZdOO7cNgJ48Q7kNvgHIPKYQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2P9srJVTNs6-4HxyPPq0gQbjVk4xpsvVXrePYUR2fmw&oe=675C397C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled (15).png", "id": "1574809773041483", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75556790_1574809776374816_8807360985140779263_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KoGYyKxUIbQQ7kNvgE0z0zd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4brzVkkrA2PvwLpMl9f9Xql3btMIy-rvwIYOIjl4cbQ&oe=675C176D"}, "display_name": "Banter", "keywords": [], "long_description": "Banter is a Social VR experience that allows you to enjoy hanging out with friends whilst having fun. You can select from a huge number of custom avatars provided by Ready Player Me. Rather than appeal to younger players, we want Banter to be a place where adults can hang out and enjoy each other's company.\n\nBanter provides more presence than other social VR experiences because it provides full-body avatars with arms and legs, something we think is essential to feel present in your digital self. We look forward to supporting hi quality full-body tracking soon without the need for an expensive PC or equipment.\n\nEnjoy crystal clear spatial audio so you can hear your friends in VR, find your crew and enjoy casual mini-games that don't impose on the social experience too much. Run, jump, climb even zipline with a physics-enabled character allowing you to explore every part of Banter.\n\nBuild your own spaces and games with our Aframe integration!", "short_description": "The magnificent art of using word play, opinions, exaggeration, irony, sarcasm, and other comedic themes to have fun with your friends in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1StwiWB6pBf29XTZDxFR7zW-i-dTNUc6y0J83PK