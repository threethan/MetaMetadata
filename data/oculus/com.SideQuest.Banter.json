ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bj0_CBIe2v4Q7kNvgFvie50&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcykFGSHIuO4eUITNU2HbMR&oh=00_AYDBonyHA3_ZfUp0HalBEWRG6g0d9OFCqhOnWH6OtPTgsw&oe=66E02DB5"}, {"file_name": "b 13.png", "id": "833899171091185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031368_833899174424518_6410374894843913738_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=juD-UUvPEHEQ7kNvgHR4TFR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcykFGSHIuO4eUITNU2HbMR&oh=00_AYC8JqokYXY4yOGC4wTkudVkEGw2CWTHtSNiJC8-obQrMQ&oe=66E0142B"}, {"file_name": "b 12.png", "id": "500435064971379", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348041_500435068304712_1915409334878296060_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfugnkIP4nYQ7kNvgHJRxn8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcykFGSHIuO4eUITNU2HbMR&oh=00_AYC7J7LTJ4FCcsZhpzsrjn-GJTlIlU05KZdINfET2XdnbA&oe=66E01B6C"}, {"file_name": "b 11.png", "id": "407106681575207", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974825_407106684908540_7707055758076610265_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ODinjHBw_VwQ7kNvgEqelrt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcykFGSHIuO4eUITNU2HbMR&oh=00_AYDCvlr4PrYbXsG0zN6hOXQU0EYTM2fx2ka_lD2ylV_BIg&oe=66E014D4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Banter", "keywords": [], "long_description": "Banter is a Social VR experience that allows you to enjoy hanging out with friends whilst having fun. You can select from a huge number of custom avatars provided by Ready Player Me. Rather than appeal to younger players, we want Banter to be a place where adults can hang out and enjoy each other's company.\n\nBanter provides more presence than other social VR experiences because it provides full-body avatars with arms and legs, something we think is essential to feel present in your digital self. We look forward to supporting hi quality full-body tracking soon without the need for an expensive PC or equipment.\n\nEnjoy crystal clear spatial audio so you can hear your friends in VR, find your crew and enjoy casual mini-games that don't impose on the social experience too much. Run, jump, climb even zipline with a physics-enabled character allowing you to explore every part of Banter.\n\nBuild your own spaces and games with our Aframe integration!", "short_description": "The magnificent art of using word play, opinions, exaggeration, irony, sarcasm, and other comedic themes to have fun with your friends in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1StwiWB6pBf29XTZDxFR7zW-i-dTNUc6y0J83PKKdXgI/edit?usp=sharing", "developer_terms_of_service_url": "https://sidequestvr.com/terms", "publisher_name": "SideQuestVR", "support_website_url": "https://sdq.st/support", "website_url": "https://sidequestvr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "498872442181882"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1080858379272272"}]}, "baseline_offer": {"id": "1080858379272272"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1670859600, "status": "PUBLISHED", "id": "1080858379272272"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8115213605252591", "version": "0.0.612"}, "id":