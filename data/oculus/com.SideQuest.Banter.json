&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAywixutT7aoT1Q0dtyixkHD67sOsZDKus8rRN66ZbSUw&oe=6728B035"}, {"file_name": "b 13.png", "id": "833899171091185", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031368_833899174424518_6410374894843913738_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dz7ycOGj9DIQ7kNvgF6wDK2&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYChY4RuRzRka_z5vC6ZvlLIx6BDsoYlwQUqraKG1iVYBQ&oe=6728CEEB"}, {"file_name": "b 12.png", "id": "500435064971379", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75348041_500435068304712_1915409334878296060_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_2Yg3Fi8Q_UQ7kNvgFDmrFJ&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYC6DLASaOTLUAbT-bfFUHyomcoihRoClAYjOCKn3-vgRw&oe=67289DEC"}, {"file_name": "b 11.png", "id": "407106681575207", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974825_407106684908540_7707055758076610265_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ie3F2a3zqnMQ7kNvgFwyCIX&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDv9Fm1sthH_NNWYnc2i-3EiCbO-Z32JM5eY3XlRXoa6w&oe=6728CF94"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Banter", "keywords": [], "long_description": "Banter is a Social VR experience that allows you to enjoy hanging out with friends whilst having fun. You can select from a huge number of custom avatars provided by Ready Player Me. Rather than appeal to younger players, we want Banter to be a place where adults can hang out and enjoy each other's company.\n\nBanter provides more presence than other social VR experiences because it provides full-body avatars with arms and legs, something we think is essential to feel present in your digital self. We look forward to supporting hi quality full-body tracking soon without the need for an expensive PC or equipment.\n\nEnjoy crystal clear spatial audio so you can hear your friends in VR, find your crew and enjoy casual mini-games that don't impose on the social experience too much. Run, jump, climb even zipline with a physics-enabled character allowing you to explore every part of Banter.\n\nBuild your own spaces and games with our Aframe integration!", "short_description": "The magnificent art of using word play, opinions, exaggeration, irony, sarcasm, and other comedic themes to have fun with your friends in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1StwiWB6pBf29XTZDxFR7zW-i-dTNUc6y0J83PKKdXgI/edit?usp=sharing", "developer_terms_of_service_url": "https://sidequestvr.com/terms", "publisher_name": "SideQuestVR", "support_website_url": "https://sdq.st/support", "website_url": "https://sidequestvr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SOCIAL", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "498872442181882"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1080858379272272"}]}, "baseline_offer": {"id": "1080858379272272"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1670859600, "status": "PUBLISHED", "id": "1080858379272272"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8544377195669561", "version": "0.9"}, "id": "538244561634712", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nod