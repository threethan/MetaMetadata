0_AYAOPNawHI7BA86XYtkrnGmFiln6hQLUzB7ngjkPAKNBmg&oe=6705179F"}, {"file_name": "4_big.png", "id": "193667932815084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_193667939481750_4800023452492680439_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKh1_S88yfQQ7kNvgFnkcDl&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXYjIOhuhWtRTOiTJfR2pQMD4UsbheNX8cXVXkXBbDsg&oe=67050BA5"}, {"file_name": "3_big.png", "id": "522687855471572", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031312_522687858804905_8145332485232666619_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJ81QdA_BN4Q7kNvgHdYfU3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3JZz2IYGhdJ2GqLYWjTmQkOb0VjpfKhtRaL845W9cnQ&oe=670512E3"}, {"file_name": "1_big.png", "id": "199568998897145", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031400_199569002230478_2678784042357543218_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxOQQ4LegK0Q7kNvgGpHjmc&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJ2r3gWKGKa8KrI9aEbbkO6J8ua4wjvwT94Gs-D83sQA&oe=670509C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "247676503873355", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974632_247676507206688_6297495042000249873_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WQjMlk6EO-sQ7kNvgG3GBCL&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCG90vMLaSO7BU2UGt0FnD2oUOVQ4INeZI_rAz3L3dGBQ&oe=67050768"}, "display_name": "GRAB Demo", "keywords": [], "long_description": "This is the full early access version of GRAB, but will eventually become a more limited demo!\n\nGRAB is a VR multiplayer parkour game. Climb, jump, slide and swing through the levels to reach the end, but don't fall or touch the lava!\nA core component of GRAB is the level editor that lets you and your friends create your own levels together and upload them for everyone else to play.\n\nFeatures:\n- Active and fun physics based controls\n- Play with up to 16 players in cross platform multiplayer\n- Built-in tutorial levels to get you started as well as some more advanced bigger levels\n- Built-in level editor that lets you build levels together with your friends in multiplayer with quick switching between testing and editing\n- Download levels made by the community and upload your own", "short_description": "GRAB is a VR multiplayer parkour game. Climb, jump, slide and swing through the levels to reach the end, but don't fall or touch the lava!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://slindev.com/privacy", "developer_terms_of_service_url": "https://slindev.com/terms", "publisher_name": "SlinDev", "support_website_url": null, "website_url": "https://slindev.com/grab", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "EXPLORATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "630351748179695"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "473475945549280"}, {"status": "PUBLISHED", "id": "222566259952082"}]}, "baseline_offer": {"id": "473475945549280"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723136400, "status": "PUBLISHED", "id": "473475945549280"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8205070082924457", "version": "0.52.0"}, "id": "1974803902687197", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8205070082924457"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- New lobby!\n- New halloween items!\n- New tab in the level editor, listing all signs with the ability to jump to them.\n- Added support for portrait mode to the in-game camera.\n- The in-game camera now allows to directly send images to the GRAB discord (discord.gg/slindev).\n- Visor now lights up also for your own player in the camera, but only if not alone in a lobby.\n- Fixed a glitch that allowed placing checkpoints on lava in some situations.\n- Fixed button audio in the editor sometimes coming from the wrong position.\n- Camera snapping in the editor now enforces a minimum value to be less confusing.\n- New GAB - Join the GRAB discord for more information about the build competition!", "created_date": 1727865089, "id": "8205070082924457", "version": "0.52.0", "version_code": 1968, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8205070082924457"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- New lobby!\n- New cosmetics pack!\n- You can now use the in-game camera at any time to save pictures to your platforms camera roll!\n- The camera can now zoom, snap and stay in one spot.\n- Instead of 50 weekly coins, everyone now gets 10 daily coins.\n- The weekly rotation is now a daily rotation.\n- Player body rotations and positions relative to the head are now a bit more dynamic and look better overall.\n- Fixed sounds on menus in the level editor often being too quiet.", "created_date": 1725707163, "id": "7995119283919539", "version": "0.51.0", "version_code": 1918, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8205070082924457"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725705337, "id": "7994787030619431", "version": "0.51.0", "version_code": 1914, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8205070082924457"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- Added option to make colored lava transparent.\n- Specularity is now much stronger (using a darker color reduces it).\n- Fixed favorite colors not syncing correctly when adding new ones between lava and colored blocks.\n- Fixed gravity block particles turning black when effected by fog.\n- Fixed gravity block particles not immediately disappearing after deleting the block in the editor.\n- Fixed report player menu not working when opened from the Quest overlay.\n- Fixed animations for some older cosmetic items.", "created_date": 1723988987, "id": "7875610919203710", "version": "0.50.1", "version_code": 1902, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8205070082924457"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- New lobby with 5 hidden Coin stacks, each worth 20 Coins!\n- Added weekly changing items to the shop. These are randomly selected for every player and you can pay to reroll them.\n- Added support for transparent color blocks (limited to 20 per level).\n- Added a cone shape.\n- The color of lava blocks can now be changed.\n- Increased default maximum level complexity to 2000.\n- Added an \"advanced\" color picker to more freely select colors.\n- Restructured the player customization.\n- Added support for separate grapples.\n- Added support for left and right badges.\n- Added support for backpacks.\n- Added support for different bodies.\n- Updated logo and splash screen.\n- Added a setting to make the game remember your position and rotation snap setting between levels and sessions.\n- Added a setting to disable the new addition position snap steps.\n- Part picker in the editor now shows 4 items per row (was 3 before).\n- The currently active object on the part picker is now highlighted.\n- Several smaller performance improvements.", "created_date": 1720736457, "id": "7654682364629901", "version": "0.50.0", "version_code": 1882, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}