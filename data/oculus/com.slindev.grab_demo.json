 "0.52.1", "version_code": 1980, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8274074592690672"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728204375, "id": "8242899325808199", "version": "0.52.0", "version_code": 1976, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8274074592690672"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- New lobby!\n- New halloween items!\n- New tab in the level editor, listing all signs with the ability to jump to them.\n- Added support for portrait mode to the in-game camera.\n- The in-game camera now allows to directly send images to the GRAB discord (discord.gg/slindev).\n- Visor now lights up also for your own player in the camera, but only if not alone in a lobby.\n- Fixed a glitch that allowed placing checkpoints on lava in some situations.\n- Fixed button audio in the editor sometimes coming from the wrong position.\n- Camera snapping in the editor now enforces a minimum value to be less confusing.\n- New GAB - Join the GRAB discord for more information about the build competition!", "created_date": 1727865089, "id": "8205070082924457", "version": "0.52.0", "version_code": 1968, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4104088956355944", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8274074592690672"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1974803902687197"}]}, "change_log": "- New lobby!\n- New cosmetics pack!\n- You can now use the in-game camera at any time to save pictures to your platforms camera roll!\n- The camera can now zoom, snap and stay in one spot.\n- Instead of 50 weekly coins, everyone now gets 10 daily coins.\n- The weekly rotation is now a daily rotation.\n- Player body rotations and positions relative to the head are now a bit more dynamic and look better overall.\n- Fixed sounds on menus in the level editor often being too quiet.", "created_date": 1725707163, "id": "7995119283919539", "version": "0.51.0", "version_code": 1918, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}