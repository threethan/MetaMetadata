45_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFc6AhlmWM4Q7kNvgFwstEy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTRKCGa5gm0iuowfGusVkZtpnuvfqJUqTf-2hEy49c3Q&oe=67053233"}, {"file_name": "4.png", "id": "339393762340623", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982548_339393765673956_3885185240601273819_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1me9o2IFaKwQ7kNvgFMZbe2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBYsGphQBY1Ml_gaXNF0NUgYbr1Xk58KHHbf_w2TIg6Q&oe=67052856"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo_new.png", "id": "910181281142808", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982690_910181284476141_5255668048357376779_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Baljg6vn1-UQ7kNvgGN9SNd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAW32s9HBR3Ty2EJyPT2Rghg_BwZXrMeW9L6NzgxbZlyg&oe=67051D18"}, "display_name": "GRAB", "keywords": ["platform", "climbing", "grapple", "grappling", "creative"], "long_description": "Ready to become a parkour master with your friends? Dive into GRAB, the coolest multiplayer platforming game!\n\n\ud83d\ude80 **UNIQUE MOVEMENT MECHANICS**\nGrab the air to launch yourself in any direction. Swing with grappling hooks, climb impossible walls, and fling yourself through space. Master GRAB's innovative hand-based controls for the ultimate freedom of movement.\n\n\ud83c\udf0d **ENDLESS CHALLENGES**\nWith over 600,000 player-made levels, there's always a new parkour challenge waiting. Race against the clock, solve puzzles, or just enjoy the thrill of motion across a variety of creative courses.\n\n\ud83c\udfd7\ufe0f **CREATE & SHARE**\nUnleash your inner level design genius! Use the intuitive level editor to bring your wildest ideas to life. Team up with friends to build in real-time, then watch as players worldwide attempt to conquer your creation.\n\n\ud83e\udd1d **MULTIPLAYER MAYHEM**\n- Be part of an active community with thousands of players every day\n- Parkour through mind-bending levels with up to 12 players\n- Race against friends or work together to beat challenges\n- Build and test levels together in real-time\n\n\ud83c\udf08 **EXPRESS YOURSELF**\nCustomize your character and show off your unique style as you swing, climb, and fly through the GRAB universe.", "short_description": "Experience the thrill of VR platforming in GRAB, where you can parkour through user-created levels with friends and build your own."}]}, "developer_name": null, "developer_privacy_policy_url": "https://slindev.com/privacy", "developer_terms_of_service_url": "https://slindev.com/terms", "publisher_name": "SlinDev", "support_website_url": null, "website_url": "https://grabvr.quest/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2691890164460465"}, {"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "EXPLORATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "7934321493332652"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974579_337072909458686_8500276302092653312_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VPh_XooKJc0Q7kNvgGFOmJx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ9hE-LjvpmE1ZY9pIGt0zcU85Ndp31-XDCfBB-uZPKw&oe=67051FA4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "GRAB", "platform": "ANDROID_6DOF", "context_c