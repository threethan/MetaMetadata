C0DE"}]}, "id": "3664707217082333", "locale": "en_US", "screenshots": [{"file_name": "scShot_0.png", "id": "928247775970258", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031566_928247779303591_3211313496944776675_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w3tj9TRq7WkQ7kNvgGpYvtL&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAvuFr7JShdO-95_wsrknOUPF4cZku1s2SBjodg47km3Q&oe=675EDD73"}, {"file_name": "scShot_1.png", "id": "1136248807402966", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57575360_1136248810736299_6712741067953882829_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gchnKHFiDMQQ7kNvgFX_YPu&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDsS5CbdBOcVLLZQI8Bz9iwHmnsZYSsrkolqbngu2JYYg&oe=675ED780"}, {"file_name": "scShot_2.png", "id": "920896889775145", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57568678_920896893108478_405013918484303518_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JdZtWPWi68IQ7kNvgEvqxi2&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDOIyMD8BCDr4b0CtVm6fuqCy9r6LgOzkL7whEmF9dg4A&oe=675EC62D"}, {"file_name": "scShot_3.png", "id": "1072868457118337", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57569423_1072868460451670_4210713844247774611_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_wpHhdFJXhAQ7kNvgHEc-iC&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDv1ILbz0gPBuQm_Dd3yQgrHP_VxEZzC1Qn3Hg_2RovNw&oe=675EAF75"}, {"file_name": "scShot_4.png", "id": "2081005358961264", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57570294_2081005362294597_8056307412813670589_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dG2ItdjKTxUQ7kNvgGXVul2&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCs_wcuuRNQr1pG5MmRXxq1UQjYvUe-bg1uRz9HPhro0w&oe=675ED09D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "XRL\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_2560x1440px.png", "id": "2415607391972644", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75254874_2415607395305977_5123172794916816011_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5fZeFwQ5f6QQ7kNvgH9xSeI&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYA35a2KVjORy9gVTc55mATify_Dhr-BtsVO00buhVgwFA&oe=675EDD61"}, "display_name": "XR Layout", "keywords": [], "long_description": "\"XR Layout\" streamlines the process of redecorating a room.\n\nYou can easily rearrange a variety of 3D models and wallpapers provided, or upload your own custom items.\nAnd you have the option to borrow 3D models and wallpapers from friends.\n(Uploads can be made through the related service at https://xrsns.com.)\n\nThis tool is valuable for both personal and business use, such as moving or designing new home layouts.\nIt allows for testing various furniture placements in advance to reduce errors when purchasing actual pieces.\nExplore imaginative designs with \"XR Layout\".\n(Detailed operating instructions can be found at https://xrlayout.com.)\n\n\n\u25c6List of Functions\u25c6\nSummon models\nChange wallpapers\nChange background music\nCheck your own data\nVolume control\nSwitch language\n\n\u25c6Controls\u25c6\nThe upper trigger on the right controller operates the menu panel.\n\n\u25c6How to manipulate the 3D model\u25c6\nPlease do the below with the laser on the 3D model.\n\nMove: Move with the left controller stick.\nZoom in/out: Click the B button on the right controller.\nRotate: Click the A button on the right controller.\nReset rotation: Double-click the A button on the right controller.\nGravity: Click the X button on the left controller.\nDelete: Click the bottom trigger on the right controller.\n\n\u25c6Special thanks\u25c6\nBGM: (C)K.Y. (C)L-side (C)\u52b9\u679c\u97f3\u30e9\u30dc\nModel: (C)3D Shaker\nImage: (C)Pixabay", "short_description": "\"XR Layout\" streamlines the process of redecorating a room.\nYou can easily rearrange a variety of 3D models and wallpapers provided, or upload your own custom items.\nAnd you have the option to borrow 3D models and wallpapers from friends.\nThis tool is valuable for both personal and business use, such as moving or designing new home layouts.\nIt allows for testing various furniture placements in advance to reduce errors when purchasing actual pieces.\nExplore imaginative designs with \"XR Layout\"."}, {"images": {"nodes": [{"file_name": "XRL\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_1008x1440px.png", "id": "1700921013769246", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/57575360_1700921017102579_5965761788146700936_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gLgdHtAfCPMQ7kNvgErzLsu&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDZ6HQy_3-nVZPOSKuUtxlwwAFKrkD90r0mZG44MTZ43Q&oe=675EC86D"}, {"file_name": "XRL\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_3000x900px.png", "id": "1109468820180572", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031429_1109468823513905_91045592395151573_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gNrcyXWGXwAQ7kNvgEL-RRb&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBs0ncN9CnwIZyutFZDu805TJm9dAwOhFMctX04gyV7oA&oe=675ECAB1"}, {"file_name": "XRL\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_1080x360px.png", "id": "741753654793576", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75488373_741753658126909_1339597984623439031_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yEM5WrYLegAQ7kNvgF1F0ha&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDDSRHftza9kEkq_jhguUaJpCPc0ihqFnb4SPVSSRz95w&oe=675EA5FA"}, {"file_name": "XRL\u30ab\u30d0\u30fc\u30a2\u30fc\u30c8_1440x1440px.png", "id": "435753252347472", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75367598_435753255680805_454842784763093361_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fk9TtUjt9sEQ7kNvgEZMBDs&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYASBuqnOEqB_x-