458361616049_488781173470013071_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SyO_whiCqIAQ7kNvgHCN_82&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCxUyKg0rgVLePLBNHK6j3VwVKXLK9piAQb9Ip-7v8v2A&oe=6710E26C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage_2560x1440.png", "id": "450751302719230", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974875_450751306052563_4818029513373637982_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fsmwQwEXXsQ7kNvgEZjJZQ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAeDcCum6QBJ9XFkPCJfTurcUgAkqEI-_GZIAxAEmP2fQ&oe=67110E3F"}, "display_name": "Tennis Esports Demo", "keywords": [], "long_description": "Tennis Esports is an authentic VR tennis simulation and training ecosystem based on scientific research that helps you to improve your tennis skills. Play authentic tennis from home on a virtual court, with virtual balls, against real opponents at any time.\n\nAs long as Tennis Esports Demo is available you will have access to our full feature set.\n\n* Play training sessions at different levels of difficulty to increase your skills.\n* Mirrorplay will let you play against yourself on a full court in a new and innovative way. Experience your own playing style from the other court side!\n* Create real matches with opponents and challenge your friends online.", "short_description": "Tennis Esports is an authentic VR tennis simulation and training ecosystem based on scientific research that helps you to improve your tennis skills. Play authentic tennis from home on a virtual court, with virtual balls, against real opponents at any time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tennis-esports.com/privacy-policy", "developer_terms_of_service_url": "https://tennis-esports.com/legal", "publisher_name": "VR Motion Learning GmbH & Co KG", "support_website_url": "https://tennis-esports.com/contacts", "website_url": "https://www.tennis-esports.com/", "category": "GAME