458361616049_488781173470013071_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bLxpFtQYEDgQ7kNvgH_XlOV&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYDl6rR4X4A0GQ2k-eNWJTnedlBG50PK0G0W9zjE8r3AgA&oe=6716286C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage_2560x1440.png", "id": "450751302719230", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974875_450751306052563_4818029513373637982_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zcM36Fst0iYQ7kNvgFSgN7A&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYB8jw_sP1lN0UlPOPZ1lObtr5-vYAGWqyJLL-6iehudWQ&oe=6716543F"}, "display_name": "Tennis Esports Demo", "keywords": [], "long_description": "Tennis Esports is an authentic VR tennis simulation and training ecosystem based on scientific research that helps you to improve your tennis skills. Play authentic tennis from home on a virtual court, with virtual balls, against real opponents at any time.\n\nAs long as Tennis Esports Demo is available you will have access to our full feature set.\n\n* Play training sessions at different levels of difficulty to increase your skills.\n* Mirrorplay will let you play against yourself on a full court in a new and innovative way. Experience your own playing style from the other court side!\n* Create real matches with opponents and challenge your friends online.", "short_description": "Tennis Esports is an authentic VR tennis simulation and training ecosystem based on scientific research that helps you to improve your tennis skills. Play authentic tennis from home on a virtual court, with virtual balls, against real opponents at any time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tennis-esports.com/privacy-policy", "developer_terms_of_service_url": "https://tennis-esports.com/legal", "publisher_name": "VR Motion Learning GmbH & Co KG", "support_website_url": "https://tennis-esports.com/contacts", "website_url": "https://www.tennis-esports.com/", "category": "GAME