://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_764645390701539_7528127787900066877_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uzorOWysFw8Q7kNvgFK2zV0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsPgWLcqz1tNVTaNh_9qzYm8nsddy7jTjV1kmUvEQrmg&oe=6739CE9D"}, {"file_name": "Screenshot03.png", "id": "377396287024263", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036607_377396290357596_2887932211694389306_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsnlae8QmcYQ7kNvgHfSy0H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9Rc4dV3XWKAdOk25pWD_5xxaL_aflvIno1-LMUHzEWw&oe=6739D1B1"}, {"file_name": "Screenshot02.png", "id": "270291411264724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974702_270291414598057_7298090211289566202_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C9rBn_9YLZ8Q7kNvgFdSWlQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD40ZO3CgiuPxnd5FRpUCRiGttfPugfJ_DNgB_ZX6Vm3w&oe=6739D989"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PromoGrab.png", "id": "777827039511162", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569462_777827042844495_44153905854240214_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A27i0X-OBZQQ7kNvgE0_ecw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQEV9PLeWLkDS8gXPde3x7QOipLy0dny324oZ6T3I2EQ&oe=6739EF78"}, "display_name": "Crash Course Coordination", "keywords": [], "long_description": "Crash Course Coordination (C3) is the first VR Experience developed solely to affect abilities useful in just about any sport you enjoy.\nVision is a significant factor for optimal sports performance, and regular use of C3 may improve it through \u201cBrain Training.\u201d  From hand-eye coordination, awareness of the position of your limbs in space without looking at them, and the ability to see something \"out of the corner of your eye,\" visual prowess has ties to optimal athletic performance. \nC3 is a selection of Oculomotor Exercises, designed to help you concentrate on tracking, focusing and perception with your eyes.  It includes 6 distinct, entertaining techniques used to stimulate the Vestibular System. C3 does not guarantee enhanced performance or efficiency.  It is designed to allow you to utilize your vision and perception in fun and challenging ways. For entertainment purposes only.", "short_description": "a selection of fun Oculomotor Exercises, designed to help ya concentrate on tracking, focusing, and perception with your eyes.\nIt includes six distinct, entertaining techniques used to stimulate the Vestibular System.  Crash Course Coordination does not guarantee enhanced performance or efficiency.  It is designed to allow you to utilize your vision and perception in fun and challenging ways.  For entertainment purposes only."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lobaki.com/c3-privacy-policy", "developer_terms_of_service_url": "https://www.lobaki.com/c3", "publisher_name": "Lobaki, Inc", "support_website_url": "https://www.lobaki.com/contact", "website_url": "https://www.lobaki.com/c3", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1292003397942517"}, "review_messages": ["", "Hello!\n\nThank you for submitting your application to App Lab. Your application may pass Publishing review once the following issue has been resolved:\n\nThe pro