OtCmcV7A0lPP9Gp4TH4DX-lcfvpKTaLkgUg&oe=671390EE"}, {"file_name": "SampleScene_Custom..._09.05.2024_17-27-36.png", "id": "963294272251682", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223470_963294275585015_2575245773207504599_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ifANTHWFKoQ7kNvgFXc5Hs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxTFVD9GTX9EHSfoHzIR8NzrfSHe06yzU8XTif1RJJgQ&oe=671392C0"}, {"file_name": "SampleScene_Custom..._09.05.2024_17-26-42.png", "id": "450570240789747", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_450570244123080_4342758713980333731_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6FlM2FqNP5EQ7kNvgF7E0fQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyjGzUuQKpfcnHO0TXP7lLlbwGpvCQtiqQORAxRfVwAg&oe=671386FD"}, {"file_name": "SampleScene_Custom..._09.05.2024_17-24-47.png", "id": "962506482130803", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031624_962506485464136_8651979207373251041_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZdwNCLUyzFgQ7kNvgFRl4wN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1rowYcUo9OEd-yQWx7O0RusNetzErCz0Z03ZcRo7aOw&oe=6713B1E5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_2024-04-20_162603_1.png", "id": "458062533404629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75322602_458062540071295_8789285073392193674_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJ-01qxMNksQ7kNvgGsL7Px&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAU2t14SKBXGZhn5UMjQJGMBleoG6SjoNRrEpHAs3g1ig&oe=6713A8F7"}, "display_name": "Level scary!", "keywords": [], "long_description": "# Level Scary: A Gorilla Tag Fan Game\n\n**Level Scary** is an immersive VR horror game inspired by the popular **Gorilla Tag**. Currently in **beta**, this fan game takes the familiar mechanics of Gorilla Tag and adds a terrifying twist.\n\n## Features\n\n- **Playable Model**: Experience the game with a detailed and responsive play model.\n- **Working Mods**: Enhance your gameplay with various mods that introduce new elements of fear.\n- **Vent System**: Navigate through a network of vents, adding to the suspenseful atmosphere.\n- **Multiplayer Servers**: Join friends or face the horror alone in a thrilling multiplayer setting.\n\n## Gameplay\n\nPlayers navigate through dark, eerie environments filled with unexpected scares and challenging obstacles. The game features a detailed play model, working mods, and a network of vents that add to the suspenseful atmosphere.\n\n## Beta Phase\n\nAs **Level Scary** is currently in beta, players can experience the core gameplay while providing valuable feedback for future improvements.\n\n---\n\nDive into **Level Scary** and test your nerves in this spine-chilling VR experience that pushes the boundaries of traditional Gorilla Tag gameplay.\n{469350875616633}", "short_description": "\"Level Scary\" is a beta VR horror game inspired by Gorilla Tag. This fan game features a playable model, functional mods, vents, and servers for a thrilling multiplayer experience."}]}, "developer_name": "Aden Studios", "developer_privacy_policy_url": "https://prutuo.github.io/AdenPrivacyPolicy/", "developer_terms_of_service_url": null, "publisher_name": "Aden Studios", "support_website_url": null, "website_url": "https://levelscary.github.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE