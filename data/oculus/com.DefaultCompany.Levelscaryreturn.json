-7&_nc_sid=6e7a0a&_nc_ohc=AsO4lRjuUXQQ7kNvgEGKVM3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqMcPxqcfabBKIozZoymarFxTGhMB8TPM9ESC_V7xRrw&oe=670A7765"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_2024-04-20_162603_1.png", "id": "458062533404629", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75322602_458062540071295_8789285073392193674_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dI4qsxOCUk8Q7kNvgE_xGY3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9aL8AheDLyJMkozlvQSzktU91lqRZSIwl92ZJBWNXXg&oe=670A6E77"}, "display_name": "Level scary!", "keywords": [], "long_description": "# Level Scary: A Gorilla Tag Fan Game\n\n**Level Scary** is an immersive VR horror game inspired by the popular **Gorilla Tag**. Currently in **beta**, this fan game takes the familiar mechanics of Gorilla Tag and adds a terrifying twist.\n\n## Features\n\n- **Playable Model**: Experience the game with a detailed and responsive play model.\n- **Working Mods**: Enhance your gameplay with various mods that introduce new elements of fear.\n- **Vent System**: Navigate through a network of vents, adding to the suspenseful atmosphere.\n- **Multiplayer Servers**: Join friends or face the horror alone in a thrilling multiplayer setting.\n\n## Gameplay\n\nPlayers navigate through dark, eerie environments filled with unexpected scares and challenging obstacles. The game features a detailed play model, working mods, and a network of vents that add to the suspenseful atmosphere.\n\n## Beta Phase\n\nAs **Level Scary** is currently in beta, players can experience the core gameplay while providing valuable feedback for future improvements.\n\n---\n\nDive into **Level Scary** and test your nerves in this spine-chilling VR experience that pushes the boundaries of traditional Gorilla Tag gameplay.\n{469350875616633}", "short_description": "\"Level Scary\" is a beta VR horror game inspired by Gorilla Tag. This fan game features a playable model, functional mods, vents, and servers for a thrilling multiplayer experience."}]}, "developer_name": "Aden Studios", "developer_privacy_policy_url": "https://prutuo.github.io/AdenPrivacyPolicy/", "developer_terms_of_service_url": null, "publisher_name": "Aden Studios", "support_website_url": null, "website_url": "https://levelscary.github.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26027167736874646"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1140048853651242"}]}, "baseline_offer": {"id": "1140048853651242"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718923389, "status": "PUBLISHED", "id": "1140048853651242"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26262041500053934", "version": "0.52"}, "id": "308930508213447", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "24804484869142945", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26262041500053934"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "308930508213447"}]}, "change_log": null, "created_date": 1720582714, "id": "26262041500053934", "