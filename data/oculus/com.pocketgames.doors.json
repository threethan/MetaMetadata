7dfAlPb04Ptltb2psvyJsQXhQ&oe=66E80DD0"}, {"file_name": "Screenshot_ImpossibleDoors_04.png", "id": "3238854206376064", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974843_3238854209709397_1367487957624185294_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DHqMvhsToNQQ7kNvgE3cI5F&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVJ_OPZr6anxfnWjLcLeI7&oh=00_AYA5b-GRDK7BBKBADzpsMjWt3ClX31cXr2UAYSn6oDJM-Q&oe=66E81DBB"}, {"file_name": "Screenshot_ImpossibleDoors_05.png", "id": "560355399279056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031474_560355402612389_7593154677209284784_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wN7Zs2c8MhkQ7kNvgHXj0pt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVJ_OPZr6anxfnWjLcLeI7&oh=00_AYDB6XLiTVxABaLTIBSgNRiY5UHob0GzVf-heeJfI6C7CQ&oe=66E802C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_ImpossibleDoors_2560x1440.png", "id": "548223044031667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974830_548223047365000_5431885981916940141_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ln8X2mBicWMQ7kNvgHW3uGU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVJ_OPZr6anxfnWjLcLeI7&oh=00_AYDFNWPXA7E7xwfD46oTl925yP2iEA2Ry_RNO3xWuVVMIA&oe=66E82402"}, "display_name": "Impossible Doors: Can you open them?", "keywords": [], "long_description": "The most obvious solutions are not the way out.\n\nImpossible Doors was designed to get you thinking outside the box in the shortest possible time. Entertain your friends and family as they try to solve puzzles that might look easy at the start but are seemingly impossible to solve. If that doesn't get them, mini-games like basketball, Nerf guns, and paper toss will. If you're expecting a 2-hour solo game, this probably isn't for you. However, if you plan to entertain your friends and family or want to draw a crowd, this is the perfect title.\n\nKey Detective Features:\n\n10 levels of puzzles\nMini-games to earn coins for clues (basketball, paper toss, Nerf guns)\nMore levels coming...\nKevin MacLeod (incompetech.com)\nLicensed under Creative Commons: By Attribution 3.0\nhttp://creativecommons.org/licenses/by/3.0/", "short_description": "The most obvious solutions are not the way out. Impossible Doors is designed to get you thinking outside the box in the shortest possible time. Enjoy these tricky levels!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://orangenose.notion.site/Core-Loop-526683c3424d473e8981689fc63f2b9b", "developer_terms_of_service_url": "https://app.getterms.io/view/wAH42/tos/en-us", "publisher_name": "Core Loop", "support_website_url": null, "website_url": "http://www.coreloop.fun/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7911962568857851"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_566421732008754_3771726128600663963_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HYapSy6sEQEQ7kNvgGvybgK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkVJ_OPZr6anxfnWjLcLeI7&oh=00_AYD4XODkgqQk-IqoZMs9Xqxy42vngeyFHSA7gcvMyWCI1Q&oe=66E80587"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Impossible Doors: Can you open them?", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "contex