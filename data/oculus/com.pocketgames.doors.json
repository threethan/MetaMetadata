ose.notion.site/Core-Loop-526683c3424d473e8981689fc63f2b9b", "developer_terms_of_service_url": "https://app.getterms.io/view/wAH42/tos/en-us", "publisher_name": "Core Loop", "support_website_url": null, "website_url": "http://www.coreloop.fun/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7911962568857851"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_566421732008754_3771726128600663963_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NOE8w6X1NOIQ7kNvgE2uDMJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIe-mZpQsJ6tCa_4FnWUh9XtkyEXoLrIksKQiz7E3cGg&oe=66FE6F07"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Impossible Doors: Can you open them?", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1724756340, "lastRevision": {"nodes": [{"id": "5703497539704376", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5703497526371044", "is_first_party": false, "enables_in_app_ads": false, 