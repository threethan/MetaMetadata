t=scontent-iad3-2.oculuscdn.com&oh=00_AYDfrXggips69s5xZQc_7fgyB0FETm_ZmTHqCkebPsp9sQ&oe=673323ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u795e\u901f\u306e\u5927\u5263\u8853\u58eb\u7533\u8acb\u7528_\u52d5\u753b\u30ab\u30d0\u30fc.png", "id": "966067851820161", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974727_966067855153494_299069546356571393_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nDRHbvesz3QQ7kNvgGCBzpv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBj85CZKrDiwUTdsvhmiP0QJ7Mp6uCJoqbDHRodKiS6WA&oe=673328C3"}, "display_name": "The Shinsoku Grand Swordmaster", "keywords": [], "long_description": "There are no allies.\n\nThere is nowhere to return to.\n\nOnly countless enemies exist, along with a single invisible sword.\n\nTo accept is to die, the only way to live.\n\nReject everything.\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword.\nAs the \"Grand Swordmaster,\" your goal is to deflect all attacks with precise and swift swordplay, striving to survive without harming anyone!\n\nThe swords wielded by the \"Grand Swordmaster\" have varying power depending on factors such as the direction of the blade, the force of the swing, and the timing of the strike.\nIf the power of your sword doesn't surpass that of your enemy's attack, your sword will break.\nFurthermore, swords degrade over time and with missed swings, so precise swordsmanship without waste is essential.\n\nExperience authentic swordplay action beyond mere swinging!\n\n\u25a0 Avatar Customization Function\nIf you have an avatar in VRM format, you can change the player's appearance.\nUse your favorite avatar to enjoy the replay footage!\n\nTo change avatars, you need to connect your PC and VR device.\nPlace the VRM file into \"Android/data/jp.co.fox_hound.the_shinsoku_grand_swordmaster/avatar.vrm\" from your PC, and ensure that the avatar is added to the in-game settings screen.", "short_description": "There are no allies.\n\nThere is nowhere to return to.\n\nOnly countless enemies exist, along with a single invisible sword.\n\nTo accept is to die, the only way to live.\n\nReject everything.\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword."}]}, "developer_name": "FOX HOUND Ltd.", "developer_privacy_policy_url": "http://prod.shinsoku-gs.yuru-yuru.net.s3-website-ap-northeast-1.amazonaws.com/pdf/PrivacyPolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "FOX HOUND Ltd.", "support_website_url": null, "website_url": "http://prod.shinsoku-gs.yuru-yuru.net.s3-website-ap-northeast-1.amazonaws.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7649120425147240"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "8664520903558889"}, {"status": "PUBLISHED", "id": "364191522779501"}]}, "baseline_offer": {"id": "364191522779501"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "8664520903558889"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test