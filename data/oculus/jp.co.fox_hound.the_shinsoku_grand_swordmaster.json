7a0a&_nc_ohc=cvgmQTy3vD0Q7kNvgHWvSxx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwUD3EWeg5OKKO_jMKugODm4bUpPrs4SuiReknXqTiXg&oe=66D30532"}, {"file_name": "4.png", "id": "1151247966030653", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272211_1151247969363986_1397708518757056017_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pIyTEYg8O-8Q7kNvgH6eq-a&_nc_ht=scontent.oculuscdn.com&oh=00_AYALfXL5LTok0-gFPbDnBlxYy2ilmgL19D0gwbzK1U625A&oe=66D2F70A"}, {"file_name": "5.png", "id": "1437239023357074", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984452_1437239026690407_2912768361615302735_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3xWOUv33tJsQ7kNvgGQatiJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo5TDp4oJv2dm9zpuJ_H-ISyKpB5viJdgVBacFCJ-PHg&oe=66D2E66D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u795e\u901f\u306e\u5927\u5263\u8853\u58eb\u7533\u8acb\u7528_\u52d5\u753b\u30ab\u30d0\u30fc.png", "id": "966067851820161", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974727_966067855153494_299069546356571393_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QN55y6W6TbIQ7kNvgEjU3f9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnXdg5DI_rngEJ8qQVyVlRnaqBksppr_IhD5ZuUrDS7w&oe=66D2EB43"}, "display_name": "The Shinsoku Grand Swordmaster", "keywords": [], "long_description": "There are no allies.\n\nThere is nowhere to return to.\n\nOnly countless enemies exist, along with a single invisible sword.\n\nTo accept is to die, the only way to live.\n\nReject everything.\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword.\nAs the \"Grand Swordmaster,\" your goal is to deflect all attacks with precise and swift swordplay, striving to survive without harming anyone!\n\nThe swords wielded by the \"Grand Swordmaster\" have varying power depending on factors such as the direction of the blade, the force of the swing, and the timing of the strike.\nIf the power of your sword doesn't surpass that of your enemy's attack, your sword will break.\nFurthermore, swords degrade over time and with missed swings, so precise swordsmanship without waste is essential.\n\nExperience authentic swordplay action beyond mere swinging!\n\n\u25a0 Avatar Customization Function\nIf you have an avatar in VRM format, you can change the player's appearance.\nUse your favorite avatar to enjoy the replay footage!\n\nTo change avatars, you need to connect your PC and VR device.\nPlace the VRM file into \"Android/data/jp.co.fox_hound.the_shinsoku_grand_swordmaster/avatar.vrm\" from your PC, and ensure that the avatar is added to the in-game settings screen.", "short_description": "There are no allies.\n\nThere is nowhere to return to.\n\nOnly countless enemies exist, along with a single invisible sword.\n\nTo accept is to die, the only way to live.\n\nReject everything.\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword."}]}, "developer_name": "FOX HOUND Ltd.", "developer_privacy_policy_url": "http://prod.shinsoku-gs.yuru-yuru.net.s3-website-ap-northeast-1.amazonaws.com/pdf/PrivacyPolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "FOX HOUND Ltd.", "support_website_url": null, "website_url": "http://prod.shinsoku-gs.yuru-yuru.net.s3-website-ap-northeast-1.amazonaws.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": 