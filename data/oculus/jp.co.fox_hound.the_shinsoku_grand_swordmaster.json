6e7a0a&_nc_ohc=ps1pStj6JasQ7kNvgEeOrLp&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCU9Jnc7Xr4EpqceNvmosfUSjiXaM552dly5oeL72GQZw&oe=671A280A"}, {"file_name": "5.png", "id": "1437239023357074", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38984452_1437239026690407_2912768361615302735_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sTmdn-Dzk6MQ7kNvgFz4ts_&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCZag4xqqY4wbj2koOJinf7_FUfClf3j8DLJecE2eRa0A&oe=671A4FAD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u795e\u901f\u306e\u5927\u5263\u8853\u58eb\u7533\u8acb\u7528_\u52d5\u753b\u30ab\u30d0\u30fc.png", "id": "1108446413787595", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974675_1108446417120928_1736515545534287625_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pCmM4dCdxZ8Q7kNvgGWWoGI&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYATKZsmn-cPvXyZgFfS8d10D0s6hXniRbOSBsR3PSml4A&oe=671A32C3"}, "display_name": "The Shinsoku Grand Swordmaster", "keywords": ["sword", "katana", "saber", "blade", "action"], "long_description": "There are no allies.\n\nThere is no place to return to.\n\nAll that exists are countless enemies and a single invisible sword.\n\nIf acceptance means death, then there is only one way to survive.\n\n'Reject everything.'\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword.\nAs the \"Grand Swordmaster,\" your goal is to deflect all attacks with precise and swift swordplay, striving to survive without harming anyone!\n\nThe swords wielded by the \"Grand Swordmaster\" have varying power depending on factors such as the direction of the blade, the force of the swing, and the timing of the strike.\nIf the power of your sword doesn't surpass that of your enemy's attack, your sword will break.\nFurthermore, swords degrade over time and with missed swings, so precise swordsmanship without waste is essential.\n\nExperience authentic swordplay action beyond mere swinging!\n\n\u25a0 Avatar Customization Function\nIf you have an avatar in VRM format, you can change the player's appearance.\nUse your favorite avatar to enjoy the replay footage!\n\nTo change avatars, you need to connect your PC and VR device.\nPlace the VRM file into \"Android/data/jp.co.fox_hound.the_shinsoku_grand_swordmaster/avatar.vrm\" from your PC, and ensure that the avatar is added to the in-game settings screen.", "short_description": "There are no allies.\n\nThere is no place to return to.\n\nAll that exists are countless enemies and a single invisible sword.\n\nIf acceptance means death, then there is only one way to survive.\n\n'Reject everything.'\n\n\u25a0 Overview\n\"The Shinsoku Grand Swordmaster\" is a VR action game focused on swordsmanship and defense, where you confront long-range attacks from countless enemies using only your sword."}]}, "developer_name": "FOX HOUND Ltd.", "developer_privacy_policy_url": "https://shinsoku-gs.yuru-yuru.net/pdf/PrivacyPolicy.pdf?code=store", "developer_terms_of_service_url": null, "publisher_name": "FOX HOUND Ltd.", "support_website_url": null, "website_url": "https://shinsoku-gs.yuru-yuru.net/?code=store", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_int