-25/39031333_258258966859341_2025895060861390566_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SKc-jYxZyacQ7kNvgE9BMEJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-hd3o3Tjd-D9ZZP8aBnbJdTzdjp23rYLQBKMC5xGQYw&oe=6773C864"}, {"file_name": "Screenshot_1.png", "id": "1141186123465615", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031503_1141186126798948_2969020863239030497_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHgUwInpPL0Q7kNvgF_cey5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3a4FwovthXo_tniaq--vrzHFSlRh2CuNyPDFkuE_aOQ&oe=6773DB25"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MechanismCoverLandscape.png", "id": "764110168513308", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035448_764110171846641_6491232908856313930_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QFH8gSa0C4oQ7kNvgEVvc7H&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnm1Bv0YH17jPZxcXpCly7GJwmwp_tJoi01R4gsO3sHQ&oe=6773BDD5"}, "display_name": "Mechanisms", "keywords": [], "long_description": "Step into an immersive VR game where history and physics converge! Construct intricate devices using historic gear mechanisms created by real-life professors, in a stunning workshop environment. Players unlock the secrets of centuries-old inventions. With authentic puzzles, masterfully manipulate gears, levers, and pulleys.  With stunning visuals, become a true master of mechanisms. Get ready to tinker, experiment, and unravel the mysteries of the past. The workshop awaits your arrival\u2014let the journey begin!", "short_description": "Step into a captivating virtual reality experience where the laws of physics come alive! In this immersive game, players embark on a thrilling journey, utilizing their problem-solving skills to construct intricate devices using historic gear mechanisms. The meticulously designed workshop environment transports players to the golden age of invention, evoking a sense of wonder and excite