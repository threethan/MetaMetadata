-25/39031333_258258966859341_2025895060861390566_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SKc-jYxZyacQ7kNvgFV53t2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD9IIEGR6bp_eDFE7iXFR9R1PyFhL5poYAFj0BNc6e3PA&oe=677276E4"}, {"file_name": "Screenshot_1.png", "id": "1141186123465615", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031503_1141186126798948_2969020863239030497_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHgUwInpPL0Q7kNvgHp86TU&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC1yufKXN5H9fUikUbTBh2S7-T2icIUl9SF2CIvmoXF9w&oe=677289A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MechanismCoverLandscape.png", "id": "764110168513308", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035448_764110171846641_6491232908856313930_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QFH8gSa0C4oQ7kNvgHj6-wm&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAe6brUhXE29Nx9p_zl4j5imLQCr8sIJTc5tGHayibHZQ&oe=67726C55"}, "display_name": "Mechanisms", "keywords": [], "long_description": "Step into an immersive VR game where history and physics converge! Construct intricate devices using historic gear mechanisms created by real-life professors, in a stunning workshop environment. Players unlock the secrets of centuries-old inventions. With authentic puzzles, masterfully manipulate gears, levers, and pulleys.  With stunning visuals, become a true master of mechanisms. Get ready to tinker, experiment, and unravel the mysteries of the past. The workshop awaits your arrival\u2014let the journey begin!", "short_description": "Step into a captivating virtual reality experience where the laws of physics come alive! In this immersive game, players embark on a thrilling journey, utilizing their problem-solving skills to construct intricate devices using historic gear mechanisms. The meticulously designed workshop environment transports players to the golden age of invention, evoking a sense of wonder and excitement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.joygamemobile.com/privacy-policy-vr/", "developer_terms_of_service_url": "https://www.joygamemobile.com/tos/", "publisher_name": "Joygame Oyun ve Teknoloji", "support_website_url": null, "website_url": "https://www.joygamemobile.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1043107547362485"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "143187155300544"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "757216416173029"}, {"status": "PUBLISHED", "id": "1400748870757763"}]}, "baseline_offer": {"id": "757216416173029"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1694625749, "status": "PUBLISHED", "id": "757216416173029"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6224704544285841", "version": "1.0"}, "id": "1295270147761835", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6126753097414320", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6224704544285841"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1