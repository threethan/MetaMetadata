-25/39031333_258258966859341_2025895060861390566_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SlAEMuGCtQoQ7kNvgHMnwlJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVp24AIYWTDkO-oV8nMrxyb1TfddHzmO5MvnSiVZ2QcQ&oe=6767EAE4"}, {"file_name": "Screenshot_1.png", "id": "1141186123465615", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031503_1141186126798948_2969020863239030497_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KNa_xdrmohQQ7kNvgElQHOg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTHy6I2XMf5ShjeRaF3NCkxDEIyupAkGxQJvd99G90MA&oe=6767FDA5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MechanismCoverLandscape.png", "id": "764110168513308", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035448_764110171846641_6491232908856313930_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qNgpg_hCsboQ7kNvgF_XGEE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBR7LRv9t93oWtDm0h_c8K-TbYY6UFpmn-DK66SIBfDVg&oe=67681895"}, "display_name": "Mechanisms", "keywords": [], "long_description": "Step into an immersive VR game where history and physics converge! Construct intricate devices using historic gear mechanisms created by real-life professors, in a stunning workshop environment. Players unlock the secrets of centuries-old inventions. With authentic puzzles, masterfully manipulate gears, levers, and pulleys.  With stunning visuals, become a true master of mechanisms. Get ready to tinker, experiment, and unravel the mysteries of the past. The workshop awaits your arrival\u2014let the journey begin!", "short_description": "Step into a captivating virtual reality experience where the laws of physics come alive! In this immersive game, players embark on a thrilling journey, utilizing their problem-solving skills to construct intricate devices using historic gear mechanisms. The meticulously designed workshop environment transports players to the golden age of invention, evoking a sense of wonder and excite