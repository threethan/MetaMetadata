dIr61H&oh=00_AYD2bnQtD7X4s6DQCKuNtAXbFeP5rUgISMLO96m0Gpa7nA&oe=66E02064"}, {"file_name": "Screenshot_1.png", "id": "1141186123465615", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031503_1141186126798948_2969020863239030497_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YCinUuQxEj0Q7kNvgHGcHkX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6dSBDolk8kCluVT5dIr61H&oh=00_AYApleBzW_7peI1zwBQgolDUqKwZoj-0KuAUhLWtFv2-ug&oe=66E03325"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1450194279099949", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_1450194282433282_3022546673964820815_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SXmHM-qmoncQ7kNvgGSgQeC&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6dSBDolk8kCluVT5dIr61H&oh=00_AYD4q-kpuPxqO7K9R-3mZ2Ul-Jd0gj35TzYZrD1VhlVNZw&oe=66E019E7"}, "display_name": "Mechanisms", "keywords": [], "long_description": "Step into an immersive VR game where history and physics converge! Construct intricate devices using historic gear mechanisms created by real-life professors, in a stunning workshop environment. Players unlock the secrets of centuries-old inventions. With authentic puzzles, masterfully manipulate gears, levers, and pulleys.  With stunning visuals, become a true master of mechanisms. Get ready to tinker, experiment, and unravel the mysteries of the past. The workshop awaits your arrival\u2014let the journey begin!", "short_description": "Step into a captivating virtual reality experience where the laws of physics come alive! In this immersive game, players embark on a thrilling journey, utilizing their problem-solving skills to construct intricate devices using historic gear mechanisms. The meticulously designed workshop environment transports players to the golden age of invention, evoking a sense of wonder and excitement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.joygamemobile.com/privacy-policy-vr/", "developer_terms_of_service_url