, utilizing their problem-solving skills to construct intricate devices using historic gear mechanisms. The meticulously designed workshop environment transports players to the golden age of invention, evoking a sense of wonder and excitement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.joygamemobile.com/privacy-policy-vr/", "developer_terms_of_service_url": "https://www.joygamemobile.com/tos/", "publisher_name": "Joygame Oyun ve Teknoloji", "support_website_url": null, "website_url": "https://www.joygamemobile.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "143187155300544"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "757216416173029"}, {"status": "PUBLISHED", "id": "1400748870757763"}]}, "baseline_offer": {"id": "757216416173029"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1694625749, "status": "PUBLISHED", "id": "757216416173029"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6224704544285841", "version": "1.0"}, "id": "1295270147761835", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application