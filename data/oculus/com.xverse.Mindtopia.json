phere and freedom brought by different environments in Quest. You can overlook the snow-capped mountains with a warm campfire, swim in the depths of the ocean as a small fish, or enjoy the greenness and quietness in a Chinese garden. We support you to freely roam and explore in the scene, and also support you to accompany our carefully designed animation effects to better practice breathing and meditation.  We hope these experiences can help you stay away from the  pressures of life and enjoy a moment of pure happiness.", "short_description": "We hope to bring you a mind-journey through the exquisite scenes and music  we create.\nRelax, breathe, meditate. Feel peace, calm, freedom. Welcome to your utopian world."}]}, "developer_name": "Shenzhen XVerse Information Technology Co., Ltd.", "developer_privacy_policy_url": "https://appasset.xverse.cn/privacy/mindTopia/PrivacyPolicy.pdf", "developer_terms_of_service_url": "https://appasset.xverse.cn/privacy/quest/termService.pdf", "publisher_name": "\u53d1\u5e03", "support_website_url": null, "website_url": "http://www.xverse.cn/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6914983828624072"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "767963231933153"}]}, "baseline_offer": {"id": "767963231933153"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711137600, "status": 