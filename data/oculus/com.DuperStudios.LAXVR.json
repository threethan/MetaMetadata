me": "laxvr-ss4-2560x1440.png", "id": "470770281188878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982635_470770284522211_1664682070905352838_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9-oqN31ZyUQQ7kNvgEb0jA8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABWTOUYyuUXcMCEj_bJJKlx&oh=00_AYB9is0emXQSzVV9GnOGCNk3x8yP2D-NTxFBIZOiOpCrkg&oe=66EC0F1B"}, {"file_name": "laxvr-ss1-2560x1440.png", "id": "1705506343174635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974797_1705506346507968_8085597570849703522_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrwlbWBFP0cQ7kNvgGx2xmI&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABWTOUYyuUXcMCEj_bJJKlx&oh=00_AYAJAs75HVcEXUGluKi9mXOvJiZMb-NRU5lxY4_MaVTdvA&oe=66EC0AF8"}, {"file_name": "laxvr-ss2-2560x1440.png", "id": "671774420528304", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982635_671774423861637_180823103724781212_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ePjZPCONf_YQ7kNvgEjsIOP&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABWTOUYyuUXcMCEj_bJJKlx&oh=00_AYCJ8Aiy2vt3oa6kXZTD-Mc3UEpFqBWZQ4ETUsiu-cZtaw&oe=66EC1578"}, {"file_name": "laxvr-ss3-2560x1440.png", "id": "317993927035581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302221_317993930368914_2866513447516295560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XIcf7Dgyb6oQ7kNvgHfzD-E&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABWTOUYyuUXcMCEj_bJJKlx&oh=00_AYCECRyvFd-imfX7S15KzpmGY0IeshmvArDJ8xsQ58WayA&oe=66EBF766"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "LAX VR ", "keywords": [], "long_description": "LAX VR is a lacrosse based simulation game that lets you catch passes and shoot on our AI goalie to score points.\n\nLAX VR features realistic lacrosse catching and shooting in this VR simulation, leveraging the physics engine of our game platform which enables bounce shots. Leveraging the Oculus touch controllers, the speed of your shot is based on your real shooting motion.  Shoot from different spots on the field and feeds from our AI coach.\n\nFeatures include:\n   1) Wall Ball - Build lefty/righty fundamentals on our wall.\n   2) Game Mode - Receive passes from our coach and bury them against our AI driven goalie.\n  3) Compete against others with a global leaderboard or earn achievements for great performances.\n\nYou can't always go outside and shoot on a goalie, but with LAX VR, you can get your reps in the comfort of your own home.\n\nOculus touch controllers are required.", "short_description": "LAX VR is a lacrosse based simulation game that lets you catch passes and shoot on our AI goalie to score points.\n\nLAX VR features realistic lacrosse catching and shooting in this VR simulation, leveraging the physics engine of our game platform which enables bounce shots. Leveraging the Oculus touch controllers, the speed of your shot is based on your real shooting motion.  Shoot from different spots on the field and feeds from our AI coach.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "714775023019708"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "509512638343175"}, {"status": "PUBLISHED", "id": "743004701189069"}, {"status": "PUBLISHED", "id": "665557255427795