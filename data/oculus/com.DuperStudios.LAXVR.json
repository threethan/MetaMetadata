0a&_nc_ohc=3-TkyybmX-YQ7kNvgGcdJQV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALaYn6hChueBXzmNzwrlAbgbxT4f3kw8ssXljdsuA-Gw&oe=673C8849"}, {"file_name": "laxvr-ss4-2560x1440.png", "id": "470770281188878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982635_470770284522211_1664682070905352838_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ExSTlYh2UlkQ7kNvgHK5TRE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBz9zPQLCICdIQr36tEYwI2x_J5NoNVxfiz0YyDIWvX9g&oe=673C7A9B"}, {"file_name": "laxvr-ss1-2560x1440.png", "id": "1705506343174635", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974797_1705506346507968_8085597570849703522_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-vGkXUbUFywQ7kNvgEutxvP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-CoHyL91Ebsht4fJcJ7V9Nbgs9ro5s4kFztzM0fy3MQ&oe=673C7678"}, {"file_name": "laxvr-ss2-2560x1440.png", "id": "671774420528304", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982635_671774423861637_180823103724781212_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fKwXgy_Fz_YQ7kNvgGj4FDT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7ZTna_cI7aeAFtwWNiJSBhEdX2IUQdYfTKx30NI8qRQ&oe=673C80F8"}, {"file_name": "laxvr-ss3-2560x1440.png", "id": "317993927035581", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75302221_317993930368914_2866513447516295560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1W2lPHJpDcQ7kNvgHMvcP2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEBLAojajzIEWF3i_8zgWtKJj0NlbuSsYD53yLYvXH1A&oe=673C62E6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "LAX VR ", "keywords": [], "long_description": "LAX VR is a lacrosse based simulation game that lets you catch passes and shoot on our AI goalie to score points.\n\nLAX VR features realistic lacrosse catching and shooting in this VR simulation, leveraging the physics engine of our game platform which enables bounce shots. Leveraging the Oculus touch controllers, the speed of your shot is based on your real shooting motion.  Shoot from different spots on the field and feeds from our AI coach.\n\nFeatures include:\n   1) Wall Ball - Build lefty/righty fundamentals on our wall.\n   2) Game Mode - Receive passes from our coach and bury them against our AI driven goalie.\n  3) Compete against others with a global leaderboard or earn achievements for great performances.\n\nYou can't always go outside and shoot on a goalie, but with LAX VR, you can get your reps in the comfort of your own home.\n\nOculus touch controllers are required.", "short_description": "LAX VR is a lacrosse based simulation game that lets you catch passes and shoot on our AI goalie to score points.\n\nLAX VR features realistic lacrosse catching and shooting in this VR simulation, leveraging the physics engine of our game platform which enables bounce shots. Leveraging the Oculus touch controllers, the speed of your shot is based on your real shooting motion.  Shoot from different spots on the field and feeds from our AI coach.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "714775023019708"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "880712987521174"}, {"status": "PUBLISHED", "id": "509512638343175"}, {"status": "PUBLISHED", "id": "743004701189069"}, {"status": "PUBLISHED", "id": "665557255427795"}, {"status": "PUBLISHED", "id": "1081777955869957"}, {"status": "PUBLISHED", "id": "312480488122548"}, {"status": "PUBLISHED", "id": "3009451902699140"}]}, "baseline_offer": {"id": "880712987521174"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731360481, "status": "PUBLISHED", "id": "880712987521174"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8761610330570223", "version": "2.02"}, "id": "449429613552221", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4894698900594738", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8761610330570223"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "449429613552221"}]}, "change_log": "Version 2.02\n\nNew expansion:  10v10 & Coach's Mode.  An upgrade needs to be purchased to unlock 10v10. This is our first non-free update in over 2 years since the game started, as all new features have been free.  Our plan is to limit paid upgrades to once a year, and continue to push free updates every 1-2 months.\n\nShooting dynamics have been updated in all game modes to take into account the player's body movement towards the goal.  Moving towards the goal will result in harder shots, and moving away from goal will reduce shot power.  Controller speed is still a key ingredient to shot power.  We have added a power meter to most modes as well.\n\nOther small enhancements and fixes have been made.", "created_date": 1731338440, "id": "87