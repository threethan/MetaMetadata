75FB"}, {"file_name": "mainMenuSS.png", "id": "1497747114275031", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982658_1497747117608364_3174244154858717538_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5UcMMRLxVn8Q7kNvgF4Lllb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBp_2-fvO2bJIv3xJydYouAETDa3w9sGS4NHz05Pg-9mw&oe=673C89A6"}, {"file_name": "customizeUniforms.png", "id": "1918333101992104", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974646_1918333105325437_2135440247048955339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xvBBkPy8ZigQ7kNvgF-2Nl0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBMN5w6cJIgfe7eh4Elb6ERR5GBvjmB_29uKh7E4e6gEw&oe=673C6955"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "580650201075450", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/227909023_580650204408783_656727988578391655_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNTMiAVGnzIQ7kNvgECVWCa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCuI2tbDlpNYgCmOpEySBR7IiyPqTFAO59uHfZspWb9Ig&oe=673C83F2"}, "display_name": "LAX VR", "keywords": ["lacrosse", "laxvr", "lax", "game", "pll"], "long_description": "LAX VR is the ultimate first-person VR lacrosse experience, offering both Box and Field lacrosse modes, including an exhilarating 6v6 field game where you can play as a field player, long pole, or goalie. Game modes include: Field, Box, Braveheart, Shooting, Goalie, Longstick, Shoot Around, and Wall Ball. Our Medicine Game pays tribute to the Indigenous roots of lacrosse, set in a mythical historic environment. Hone your skills, customize your twig, and enjoy the immersive world of VR lacrosse. Start a box or field 6v6 tourney and aim for the Championship!\n\nThe latest release adds a new expansion (IAP) with 10v10 field play, featuring a Coaches Mode. Change middie lines, call timeouts, manage the tempo, and yell at refs in this added mode. Note: Expansion is a separate purchase from the base game.\n\nUnique touch controller physics replicate the feel of a real lacrosse stick, and as a family-friendly game with a one-time cost, there are no hidden fees. Compete globally on the leaderboards to compare skills and aim for the top.\n\nLAX VR delivers a fun, realistic lacrosse experience. Practice your skills in various modes, and customize your twig with colors for max style!", "short_description": "LAX VR is the ultimate first-person VR lacrosse experience, now with an  expansion that adds a thrilling 10v10 Field mode and new Coach's Mode! Play as a field player, long pole, or goalie in various modes: Field, Box, Braveheart, Shooting, Goalie, Longstick, Shoot Around, and Wall Ball. The Medicine Game mode pays tribute to the Indigenous People who created lacrosse. Customize your twig, hone your skills, and enjoy the immersive world of VR lacrosse."}]}, "developer_name": "Duper Studios", "developer_privacy_policy_url": "https://www.laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8761848987213024"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974463_1201846254227199_53691994609325662