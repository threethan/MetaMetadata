016392273160863298_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qzSGgE8bWV4Q7kNvgEGKyTy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChLCdiTkxYxLHReK4sNTpZbl4VLvrqs0wx5j6EhxWFWg&oe=6707D6F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "858127864920341", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035356_858127868253674_693678591875571551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UtoBxPrjYmUQ7kNvgEwcQ2S&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBEV6PQSNJu8IYbiEm0zSocW0wOn8MkEy83SgevG9uW1g&oe=6707DB2F"}, "display_name": "SimLab VR Viewer", "keywords": [], "long_description": "The free SimLab VR Viewer is the best tool to view and share your VR experiences, 3D models, multiple 360 images, and VR collaboration sessions. VR experiences can be created using the free SimLab VR Studio to enable architectural tours, mechanical training, preview sales options, and many other purposes. SimLab VR Studio supports creating VR experiences from a wide range of 3D formats and applications including (SketchUp, Revit, Rhino, SolidWorks, Inventor, AutoCAD, and more). Moreover, you can invite clients, colleagues, and other users into your VR experience to view and interact with the scene together using SimLab VR Collaboration.\n\nLearn more about SimLab Soft: https://simlab-soft.com/", "short_description": "A free, simple-to-learn, simple-to-use VR Viewer. View and share your 3D scenes on the go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.simlab-soft.com/SimlabArt/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "SimLab-Soft", "support_website_url": "https://www.simlab-soft.com/3d-products/help.aspx", "website_url": "https://www.simlab-soft.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "39322247