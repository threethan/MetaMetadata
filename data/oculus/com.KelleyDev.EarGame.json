zles to progress through each room. Using agility and clever interactions with the environment, the monkey climbs, swings, and collects items to unlock secrets and navigate toward escape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/eargame-privacy-and-policy/home", "developer_terms_of_service_url": null, "publisher_name": "SaucerTheDev", "support_website_url": null, "website_url": "https://sites.google.com/view/eargame-privacy-and-policy/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8544708162244198"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "964381462411279"}, {"status": "PUBLISHED", "id": "549462821172734"}]}, "baseline_offer": {"id": "964381462411279"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734816300, "status": "PUBLISHED", "id": "964381462411279"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8626896937358653", "version": "10"}, "id": "1506402720030793", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8518896698158678", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary"