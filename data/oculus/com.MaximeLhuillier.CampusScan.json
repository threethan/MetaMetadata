_nc_sid=6e7a0a&_nc_ohc=WKB0QuWp2QoQ7kNvgGtNu5h&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBaB1oHODv3Rph3xv34IRshffBCAG_MetlyDGXRKtKfow&oe=67164C3F"}, {"file_name": "Screenshot3.png", "id": "1458341788015477", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39036698_1458341791348810_6442662506578395404_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ON7oYWTaaiMQ7kNvgFogAo8&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD3K5N_Fwe6114mjacVH7gpENbiyKg24X5dvPo-ZfaMaA&oe=67163A25"}, {"file_name": "Screenshot4.png", "id": "749337256127474", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39031316_749337259460807_5096968805426332388_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VqFljZe6yqUQ7kNvgE_jv8J&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBJOo5oWzTYKK2WW89XyRtK8Ngu1OoQbw9eIJJVVfbflA&oe=671645F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "487236046744268", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75572754_487236050077601_8348865219296916010_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S35GWHQvAosQ7kNvgEv19ct&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAE_6mdgw7ozkmkksvn78OcsyigjqMelOYoE2C8HiXWmw&oe=67163D01"}, "display_name": "3D scan of a campus", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a pedestrian in a campus, reconstructed from videos taken by a helmet-held 360 camera (Garmin Virb), whose trajectory is about 5.2km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a campus, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held 360 camera (Garmin Virb) and by biking about 5.2km in the campus des C\u00e9zeaux (in Aubi\u00e8re, France)."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26725169960461721"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39001717_1636079193457061_1212892732761347295_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=abg4DEju2nsQ7kNvgGwIVOj&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYClw-JXMQwZSSPzLC_xYzv2E7oYfFguRbj7tn85RbVkYw&oe=671659A2"}, "is_concept"