ent-sin11-1.oculuscdn.com&oh=00_AYAEfxzcHGQlmHcDHz6w9zgfY7pif1NLl3XasugEas4esw&oe=677E7494"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape 2.png", "id": "624916828951306", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031653_624916832284639_5364896033089899053_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0AzvrvxFKncQ7kNvgGfPDVX&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDJYD3bcvdTEiiyZxZwA1VfqhIhrj_0XFRp2MHLAAzlJQ&oe=677E75E2"}, "display_name": "Mythic Mage", "keywords": [], "long_description": "Did you ever want to feel like a powerful mage as you explore dungeons, fighting scary monsters and discovering long lost treasure?\n\nMythic Mage is a dungeon crawler with procedurally generated levels. Fight monsters using melee or ranged attacks! Face giant bosses! Upgrade your stats between floors! But beware: if you die, you start again from the beginning!\n\nUnlock permanent upgrades and new enemies the further you get in the dungeon. How far can you get before you perish?\n\nFeatures:\n\u2605 Infinite procedurally generated dungeons!\n\u2605 Terrifying monsters to battle!\n\u2605 Environmental hazards!\n\u2605 Shop to upgrade abilities during a run!\n\u2605 Permanent upgrades and unlocks that stay between runs!", "short_description": "Did you ever want to feel like a powerful mage as you explore dungeons, fighting scary monsters and discovering long lost treasure?\n\nMythic Mage is a dungeon crawler with procedurally generated levels. Fight monsters using melee or ranged attacks! Face giant bosses! Upgrade your stats between floors! But beware: if you die, you start again from the beginning!\n\nUnlock permanent upgrades and new enemies the further you get in the dungeon. How far can you get before you perish?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/10aIJbCE7sSdmNKTR-5PfX8bTVjyPkZ6BY2cwRRS9wGQ/edit?usp=sharing", "developer_ter