knAyF2zci8hTBDjLtb6ehaeMZtxhI4i7dhJacX3TaA&oe=67519A93"}, {"file_name": "Modulia - Hero.png", "id": "514613756228672", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982495_514613759562005_2197118672975971266_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LpLp8fPPtq4Q7kNvgEyGfkG&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYADs9VK9R3OxExeyUonLxZrvZwrAA56niqaFonK9YmT9Q&oe=67519F50"}]}, "id": "194307269244447", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "449141153049904", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974745_449141156383237_2602725712318235799_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pk2EBUJ7v8YQ7kNvgEcKTUM&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDqy754BMm_VzKCXDxBliNCmmpESVnNBfUNioBa8c7CHQ&oe=67519CBA"}, {"file_name": "3.png", "id": "479342853409412", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75388621_479342856742745_8798487637681242118_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U1f4AGesIHsQ7kNvgF6ynTp&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYABj9N-I-0Oaay_V4KQtHMcNV2ELmUGWPoqDiR8GqW_Nw&oe=6751904B"}, {"file_name": "5.png", "id": "134778495298719", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982471_134778498632052_411711373724603695_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3JqBrtTbtg4Q7kNvgGa9buG&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBWan9yX1lXWYpDL84Ih0ocPYlIYo5V-jNPIhvqzdNSgg&oe=67519F24"}, {"file_name": "4.png", "id": "798605747754490", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982483_798605754421156_1986649763789961237_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wNx1DvUoc2AQ7kNvgEgYTeu&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCwTV-mCfvvrS6o-9qs_gD_2uGnYyQz_OJEhABaU7JKug&oe=675180A5"}, {"file_name": "2.png", "id": "263294812157372", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035358_263294815490705_4150129998500296228_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HAEJk6tZuu4Q7kNvgHZKYH0&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCP8MOJs2ZXscpCAD2AuwnuMunQM-78wapR346WIcknaQ&oe=67519367"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Modulia Quest - screenshot.png", "id": "522084335580003", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982449_522084338913336_7694930828877611739_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G9VajZRDglIQ7kNvgHxTIye&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYANDGS1Pm_i_9jiuouYtI278RHT1qPst7gS9Og3r8_O9A&oe=67518451"}, "display_name": "Modulia Studio", "keywords": [], "long_description": "Modulia Studio is a VR MIDI controller. \n\nIt allows you to wirelessly control any MIDI-compatible software and has an especially deep integration with Ableton Live\u2122 10 & 11. It also features a standalone mode with embedded sounds.\n\nBuild your custom studio using the 11 different modules:\n\n- Session (controls the session view of Live\u2122)\n- Circular Keyboard (a beautiful 360\u00b0 keyboard)\n- Scale Keyboard (a versatile scaled keyboard)\n- Expressive Keyboard (a MIDI-MPE keyboard for expressive performances)\n- Remote (remotely triggers multiple notes and visual effects at once)\n- Pads (a 4x4 pads grid)\n- Cube Mixer (a 3D mixing space)\n- Cylinder Mixer (a cylindrical 3D mixing space)\n- Knobs (4 configurable knobs)\n- Sliders (4 configurable sliders)\n- FX (visual effects)\n\nDownload Modulia Desktop for MacOS and Windows to connect Modulia Studio to your MIDI software: www.modulia-studio.com/get-modulia-studio/#desktop \n\n~~~~~~~~~~~~~~~~~~~~~~~~\n\nAbleton\u00ae and Live\u2122 are trademarks of Ableton AG.", "short_description": "Modulia Studio is a VR MIDI controller. \n\nIt lets you wirelessly control any MIDI-compatible software and has a deep integration with Ableton Live\u2122 10 & 11. It also features a standalone mode with embedded sounds.\n\nBuild your studio using the 11 different modules:\n\n- Session\n- Circular Keyboard\n- Scale Keyboard\n- Expressive Keyboard\n- Remote\n- Pads\n- Cube Mixer\n- Cylinder Mixer\n- Knobs\n- Sliders\n- FX\n\nGet Modulia Desktop to connect Modulia Studio to your MIDI software at www.modulia-studio.com "}]}, "developer_name": "Th\u00e9r\u00e9mix Tech", "developer_privacy_policy_url": "https://www.modulia-studio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Th\u00e9r\u00e9mix Tech", "support_website_url": "https://www.modulia-studio.com/documentation/", "website_url": "https://www.modulia-studio.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3072081379697941"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39036613_1091481498029473_7874334784127718790_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jj6fvPU-FkoQ7kNvgFxGgiu&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYA4UMukG3mfFR0kU15c_awE2m1t01JtAYbvRxGthT2i-Q&oe=67519F49"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Modulia Studio", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 