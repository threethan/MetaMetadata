NYNDy8ycgAMTIZY1UhQ32Gn2wKkUazA-H40OTDuTKQ&oe=6735EB13"}, {"file_name": "Modulia - Hero.png", "id": "514613756228672", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982495_514613759562005_2197118672975971266_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylUB4n-XsxAQ7kNvgHm10XZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDC_wTVpfPKvVelRTdISohQwcPynTI5gdKw_1xO-qp2HA&oe=6735EFD0"}]}, "id": "194307269244447", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "449141153049904", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974745_449141156383237_2602725712318235799_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPurJLhSlHUQ7kNvgFIZASU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmtdMl7n6kruh8EOgXQBqpSWE7RIVNhXIIZaN_VnBlHw&oe=6735ED3A"}, {"file_name": "3.png", "id": "479342853409412", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75388621_479342856742745_8798487637681242118_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ENlRfnDF6b0Q7kNvgFOrBm_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqtpCbbZLqx8CZHtuGHiF3fLU8-Z3CoYmh2JunHh_-Ww&oe=6735E0CB"}, {"file_name": "5.png", "id": "134778495298719", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982471_134778498632052_411711373724603695_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=phLarvYbQ90Q7kNvgEIG3_6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_YkPRtCx0hAQo-y6ZwMhxS29QsTRYGNVsj31jihI4Qg&oe=6735EFA4"}, {"file_name": "4.png", "id": "798605747754490", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982483_798605754421156_1986649763789961237_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xyHthub--VAQ7kNvgFewFID&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAgA-Zk2QgAgU7Xdkt7F2sMoyumj9xUl3utWWOqODtTZw&oe=6735D125"}, {"file_name": "2.png", "id": "263294812157372", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035358_263294815490705_4150129998500296228_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g0B4lE_U4jgQ7kNvgFHcs9b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8k6TuTXUaHRT8yQdD2OtKle0nUEkMjQ0lMscGO6e6zQ&oe=6735E3E7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Modulia Quest - screenshot.png", "id": "522084335580003", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982449_522084338913336_7694930828877611739_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yHmLMOtKcNQQ7kNvgFMS_Ci&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJe8r_CGRXRlXb_nEzW668nuZ72CSXkzaHsj4oEt6BRA&oe=6735D4D1"}, "display_name": "Modulia Studio", "keywords": [], "long_description": "Modulia Studio is a VR MIDI controller. \n\nIt allows you to wirelessly control any MIDI-compatible software and has an especially deep integration with Ableton Live\u2122 10 & 11. It also features a standalone mode with embedded sounds.\n\nBuild your custom studio using the 11 different modules:\n\n- Session (controls the session view of Live\u2122)\n- Circular Keyboard (a beautiful 360\u00b0 keyboard)\n- Scale Keyboard (a versatile scaled keyboard)\n- Expressive Keyboard (a MIDI-MPE keyboard for expressive performances)\n- Remote (remotely triggers multiple notes and visual effects at once)\n- Pads (a 4x4 pads grid)\n- Cube Mixer (a 3D mixing space)\n- Cylinder Mixer (a cylindrical 3D mixing space)\n- Knobs (4 configurable knobs)\n- Sliders (4 configurable sliders)\n- FX (visual effects)\n\nDownload Modulia Desktop for MacOS and Windows to connect Modulia Studio to your MIDI software: www.modulia-studio.com/get-modulia-studio/#desktop \n\n~~~~~~~~~~~~~~~~~~~~~~~~\n\nAbleton\u00ae and Live\u2122 are trademarks of Ableton AG.", "short_description": "Modulia Studio is a VR MIDI controller. \n\nIt lets you wirelessly control any MIDI-compatible software and has a deep integration with Ableton Live\u2122 10 & 11. It also features a standalone mode with embedded sounds.\n\nBuild your studio using the 11 different modules:\n\n- Session\n- Circular Keyboard\n- Scale Keyboard\n- Expressive Keyboard\n- Remote\n- Pads\n- Cube Mixer\n- Cylinder Mixer\n- Knobs\n- Sliders\n- FX\n\nGet Modulia Desktop to connect Modulia Studio to your MIDI software at www.modulia-studio.com "}]}, "developer_name": "Th\u00e9r\u00e9mix Tech", "developer_privacy_policy_url": "https://www.modulia-studio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Th\u00e9r\u00e9mix Tech", "support_website_url": "https://www.modulia-studio.com/documentation/", "website_url": "https://www.modulia-studio.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3072081379697941"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036613_1091481498029473_7874334784127718790_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z5TZ_Z63AvAQ7kNvgEySGw7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_Jd8gZ_SBV024ZthqFgLeRObic1cLeWYigXTKOwoUTw&oe=6735EFC9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Modulia Studio", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 