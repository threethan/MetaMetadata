6-4.oculuscdn.com/v/t64.5771-25/39031597_1363029397620328_2392232612287599288_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LU9FaIpnDCcQ7kNvgF62tga&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDkoI_PS7GilkwzjbUnrtazCjPOBAhVxen13uo7RL_n7A&oe=6728C01F"}, {"file_name": "migrated_image.png", "id": "674223363386825", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75334055_1108076909535517_7993917019646853120_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-c5dZjaTD4gQ7kNvgFWXUnH&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYBtubW3T-toOXCGH8NRctDKw6jeH6vhRlehHZMWhDkAjQ&oe=67289D1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "11landscape.png", "id": "1304342456802872", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982572_1304342460136205_3898911052984918261_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m1czvIQV1bgQ7kNvgEq0DGq&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDaLBfiyIJs3Zq9H9k9H3lOL9Inyai6Ay5cE2OwCyJT1A&oe=6728B3EB"}, "display_name": "Eleven Table Tennis", "keywords": ["ping", "pong", "eleven", "table", "tennis"], "long_description": "The ultimate Table Tennis simulator. Play opponents in online multiplayer or practice against the advanced AI. With physics designed to be as real as ever achieved in a Table Tennis simulator, you will forget you are in VR.\n\nPhysics Engine :\nFrom the very start, we have been obsessed with creating the most realistic table tennis simulation the World has ever seen. After countless hours of hard work and support from our amazing community, we believe that we accomplished that goal. \n\nWe hope that you enjoy playing Eleven as much as we enjoy working on it. If you run into any issues or if you're interested in joining our ever-growing community of table tennis fanatics, follow the link in the additional details section and join us on our discord.  ", "short_description": "The ultimate Table Tennis simulator. Play opponents in online multiplayer