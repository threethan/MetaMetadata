d": "151044183735004", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_151044187068337_2020309750771336295_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kYyXJh-iskAQ7kNvgHqq82T&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUANgilsq241rZxjFszDye&oh=00_AYBOqHaFjD2B62VYJJ7o_1E-6zxJLKe1xew3GtUmuPmHhQ&oe=66EEC38B"}, {"file_name": "Screenshot05.png", "id": "785575712127289", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974613_785575715460622_4214848590218218911_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=isqYXCAS-xEQ7kNvgFedQJ-&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUANgilsq241rZxjFszDye&oh=00_AYA33w3xj8R7zKvb7dfFJ0X59wwXUBpfvTLOyGla--5yjQ&oe=66EEC0D0"}, {"file_name": "Screenshot02.png", "id": "510393153539640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_510393156872973_4043877152986064557_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V0iu_Rhjbz8Q7kNvgEVm6ea&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUANgilsq241rZxjFszDye&oh=00_AYCWm9Sgzsu4JbSEveC9WTQN7dU3Kz_f14p3WCbRdVmo3Q&oe=66EEB69B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1113381322507169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_1113381329173835_4683781815905223101_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2CJMF52lpMkQ7kNvgF7iN8G&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUANgilsq241rZxjFszDye&oh=00_AYCdnm4Akm8kiQ_k6e6DBt9x6eD-ZuN4efqa-RLOdmYhDg&oe=66EE97E3"}, "display_name": "Sep's Diner (DEMO)", "keywords": [], "long_description": "THIS IS A DEMO VERSION OF SEP'S DINER. FULL GAME INCLUDES 54 LEVELS, MORE RECIPES AND CO-OP MULTIPLAYER!\n\nWelcome to Sep's Diner, the new restaurant of which YOU are the Chef! Will it really become the best burger in town? It's up to you!\nLevel after level, your experience will increase as well as the number of your gourmet customers. They are in a hurry, so make it quick to satisfy them before they leave!\nImpatient, they won't let you make a mistake... Be precise to make the best possible profit!\n\nIncluding a brand new Dessert restaurant: Sep's Donut!\n\nGame Features :\n\u00b7 2 restaurants\n\u00b7 3 game modes included: Timed, Relaxed, Multiplayer\n\u00b7 27 levels included per restaurant\n\u00b7 Co-op multiplayer up to 4 players\n\u00b7 Intense and thrilling levels!\n\u00b7 Immersive audio ambiance\n\u00b7 Impatient customers with fun voices\n\u00b7 Beautiful scenery and colored lights\n\u00b7 More than 30 different combinations for burgers recipes!\n\u00b7 Pancakes, donuts, waffles, cupcakes, ice-creams and milkshakes in the Dessert caf\u00e9!", "short_description": "(DEMO VERSION) Welcome to Sep\u2019s Diner, the new burger restaurant of which YOU are the Chef! Will it really become the best burger in town? It\u2019s up to you now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://voxel.scale1portal.com/privacy-policy", "developer_terms_of_service_url": "https://voxel.scale1portal.com/terms-and-conditions", "publisher_name": "SCALE-1 PORTAL", "support_website_url": "https://voxel.scale1portal.com/sepsdiner/#contact", "website_url": "https://voxel.scale1portal.com/sepsdiner", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FOOD", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "330463672326815"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/