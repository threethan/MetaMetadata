ackdrop_1800x700.png", "id": "521591527456037", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984458_521591530789370_8503274857588056658_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNjY5HoZaLAQ7kNvgE5HvVB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7VLVlBJc-HA6bn6rxSlNSDzutnoxxW5qopXOjthHS5A&oe=672370AA"}]}, "id": "552272570543390", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_01.png", "id": "1464988294173192", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75303840_1464988297506525_8991340839166974651_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GLQwVmUpDzAQ7kNvgG36CI-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC0zVsRK9tiX6LNcl6rmTvra48EO-J8Q1AEr6OHTRDiw&oe=672384C9"}, {"file_name": "Screenshot_02.png", "id": "998108822001177", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036669_998108825334510_8112152864798222185_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hyi5vpFnmcEQ7kNvgGVjjDH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCA6wDq_-bUF1nZB24loTcMCCgxUcCkjOHN4zhWVqgMdg&oe=67236380"}, {"file_name": "Screenshot_03.png", "id": "1074895857368260", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610711_1074895860701593_7275850341165404444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bdsAABwTiCEQ7kNvgGW6LYa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDfrGrd_5jH8Iw2wv2zzINRhCRco20ivJ8C2wHsmc2pw&oe=67235E17"}, {"file_name": "Screenshot_04.png", "id": "319481737914327", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240109_319481741247660_2311776443441155712_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MDoLf5WvyUwQ7kNvgFmixdx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCE7AQ5hkXHrKFQykhovNLxWCagnvwCXundWHnzQFmjqQ&oe=67236DFA"}, {"file_name": "Screenshot_05.png", "id": "1218222189322091", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974829_1218222192655424_6704110728869486582_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Je9BUb3XFqQQ7kNvgH2nA4_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCdsG9Sjcm0M17jKlLEOZr2DBwglD0_90ejXEMdqVxCg&oe=6723591C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JumpWorld_Cover_Landscape.png", "id": "1630745394490612", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203626_1630745397823945_773068501026464412_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pIWFyHLUIIwQ7kNvgGZXfGu&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoi_uSmTUYBpfPlVJx5fHUXmv-i3ssB9OddBJxlZLeEQ&oe=67236BE2"}, "display_name": "Jump World", "keywords": ["Platformer", "racing", "fantasy", "obstacle", "course"], "long_description": "# The Obstacle Course Game You\u2019ve Been Waiting For!\n\n**RUN, JUMP, PUNCH & SMASH** your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover.\n\n{465167516542056}\n\n# 7 Worlds To Discover\n\n- Honeywood Hills\n- Cookie Crumble\n- Sky Brick Road\n- Jump N' Jammy\n- Arctic Freeze\n- Dark Citadel \n- Cybertron\n\n{519192847571723}\n\n# Easy To Pickup And Play\n\n- Play Seated or Standing.\n- Movement - Left & Right Thumbsticks.\n- Jump - A Button or Click Right Thumbstick.\n- Dash - Click Left Thumbstick.\n- Ground Smash - While in Air, Press Trigger.\n\n{467766532286204}\n# Face the final challenge. Enter each of the 7 Dungeons and see if you have what it takes to unlock the next world.\n- Untimed so you can progress at your own pace.\n- Reach the gates to unlock checkpoints.\n- Dungeons designed with platforming in mind.\n\n{543457814936511}\n# Race To The Finish Line!\n- Race against your own time.\n- Compete to achieve Bronze, Silver or Gold Trophies!\n- You aren't penalized for a lack of skill.\n- As long as you can complete each course, you can progress!\n- Keep practicing and you'll do GREAT!", "short_description": "RUN, JUMP, PUNCH & SMASH your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ninjaplayground.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Ludus Vision", "support_website_url": null, "website_url": "https://www.ninjaplayground.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8678296775561748"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031622_1445926566095482_7961826354501749491_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DYTKeKUwquUQ7kNvgG4JTm0&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCseKgB-1lRL-odzBja3e47aZ5Xxeszj-Rq63n1xLmJFA&oe=672376E6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Jump World", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1728477720, "lastRevision": {"nodes": [{"id": "8601365819921511", "release_type": "SCHEDULED", "administration_s