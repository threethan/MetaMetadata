1E7A"}, {"file_name": "Screenshot_05.png", "id": "1218222189322091", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974829_1218222192655424_6704110728869486582_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YGX0_BBO99AQ7kNvgE9ku5H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADunIvWm7Q9up-FNEszwpzK0TSDOr56hi-cWtdEYO15w&oe=675C099C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JumpWorld_Cover_Landscape.png", "id": "1630745394490612", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203626_1630745397823945_773068501026464412_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=luaVqLesb20Q7kNvgF88xoT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZrBjUINdKghHFvPxVko4udIV7LWOH-6JfBIb07orWYQ&oe=675C1C62"}, "display_name": "Jump World", "keywords": ["Platformer", "racing", "fantasy", "obstacle", "course"], "long_description": "# The Obstacle Course Game You\u2019ve Been Waiting For!\n\n**RUN, JUMP, PUNCH & SMASH** your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover.\n\n{465167516542056}\n\n# 7 Worlds To Discover\n\n- Honeywood Hills\n- Cookie Crumble\n- Sky Brick Road\n- Jump N' Jammy\n- Arctic Freeze\n- Dark Citadel \n- Cybertron\n\n{519192847571723}\n\n# Easy To Pickup And Play\n\n- Play Seated or Standing.\n- Movement - Left & Right Thumbsticks.\n- Jump - A Button or Click Right Thumbstick.\n- Dash - Click Left Thumbstick.\n- Ground Smash - While in Air, Press Trigger.\n\n{467766532286204}\n# Face the final challenge. Enter each of the 7 Dungeons and see if you have what it takes to unlock the next world.\n- Untimed so you can progress at your own pace.\n- Reach the gates to unlock checkpoints.\n- Dungeons designed with platforming in mind.\n\n{543457814936511}\n# Race To The Finish Line!\n- Race against your own time.\n- Compete to achieve Bronze, Silver or Gold Trophies!\n- You aren't penalized for a lack of skill.\n- As long as you can complete each course, you can progress!\n- Keep practicing and you'll do GREAT!", "short_description": "RUN, JUMP, PUNCH & SMASH your way through 40+ levels and dungeons in this retro-themed VR platformer & obstacle course game. Filled with tough challenges, inventive obstacles, treasures to collect and secrets to discover."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ninjaplayground.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Ludus Vision", "support_website_url": null, "website_url": "https://www.ninjaplayground.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8678296775561748"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031622_1445926566095482_7961826354501749491_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aa3LlwJv1bkQ7kNvgHSGbp_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIybfC7g1ZlT5VyUNDZBC2DiVmrFrAXNeBKYJ-m0TIoQ&oe=675C2766"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Jump World", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "