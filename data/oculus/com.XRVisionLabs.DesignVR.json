F90"}, {"file_name": "9.png", "id": "8124162744290178", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75280981_8124162750956844_6947101117074463994_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sL2uH_RRdEEQ7kNvgHv9q-W&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzejRguoAE-X16GB4rAlb6B&oh=00_AYBDnzHm3awkLyzl6iGqnzYF0vuaPvP7NVgz5BYJ6I09PQ&oe=66EC1864"}, {"file_name": "10.png", "id": "1252587702700196", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031447_1252587706033529_6948644644306558618_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=43wl_Bo9dLUQ7kNvgEIyITD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzejRguoAE-X16GB4rAlb6B&oh=00_AYBaBUkLol0xvEzzj5kctNSX4PLVzZ8DD1CK2jRH2cWCYA&oe=66EC246B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Xrchitect-coverart.png", "id": "1124064952028034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974463_1124064955361367_7567437245873844734_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=81FfCHXl5AUQ7kNvgHfCYEY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzejRguoAE-X16GB4rAlb6B&oh=00_AYCm0r-AxmAkNNI0HSTnIbYu0kK4sz02cYCF-aWYdsjrTQ&oe=66EC222B"}, "display_name": "XRchitect", "keywords": ["interiordesign", "design", "homedesign", "decoration", "homedecoration"], "long_description": "XRchitect is a state-of-the-art design and collaboration platform for interior designers. It lets you plan, design, and present your ideas without needing to write any code.\n\nWith XRchitect, anyone can quickly and easily create 3D designs, even without prior experience. The platform's user-friendly interface makes it simple to configure spaces, whether you're working remotely or on-site.\n\nThere are two main modes to choose from. In Remote Mode, you can customize room dimensions and design unique spaces from a distance. Room Scan allows you to design your actual environment by scanning the real space around you.\n\nXRchitect also supports teamwork with its Co-op Mode, letting you collaborate and work together with your team no matter where you are. And when your design is ready, you can use the export feature to seamlessly save your work and download it from our web portal.\n\nThis versatile tool is perfect for planning, executing, and presenting designs. Whether you\u2019re giving clients a complete walkthrough of their space or renovating a room, XRchitect makes the process smooth and easy. The possibilities are endless.\n\n\nXRchitect allows interior designers, business leaders, and creative teams to start planning and designing spatially together, enabling a new era of collaborative and immersive interior design for the future of VR, AR, and MR.\n", "short_description": "XRchitect is a design and collaboration platform for interior designers where you can plan, design, and present your ideas without writing a single line of code."}]}, "developer_name": "XR Vision Labs", "developer_privacy_policy_url": "https://xrvisionlabs.com/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "XR Vision Labs", "support_website_url": null, "website_url": "https://xrvisionlabs.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8350716054984783"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363515_1937760010076344_58