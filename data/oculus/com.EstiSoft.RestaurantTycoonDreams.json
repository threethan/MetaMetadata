3SLkVxRrR2VRSVyoIdtaA&oe=67236C7D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss4.png", "id": "884438206451793", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974857_884438209785126_7854430393316971729_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8W8UolksCkkQ7kNvgGm8zQh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCS61ohq3ULN3aMNesdYZYRf4vMJyNUSJyXWS37MoT1Ow&oe=67237DCC"}, "display_name": "Restaurant Tycoon Dreams", "keywords": ["ArcadeIdle", "Idle", "fun", "comfort", "casual"], "long_description": "Welcome to \"Restaurant Tycoon Dream,\" the ultimate VR experience that combines the excitement of arcade gaming with the satisfaction of idle management. As the owner of a budding restaurant, your goal is to transform a humble eatery into a culinary empire. Start by designing the layout of your restaurant, selecting decor that appeals to your clientele. Dive into a detailed culinary world where you can craft a wide range of dishes from appetizers to exquisite main courses. Manage your resources wisely, upgrade your kitchen equipment, and train your staff to improve efficiency and service quality.\n\nAttract patrons with mouthwatering recipes and top-notch service. Respond to reviews, adapt your menu, and keep up with the latest food trends to stay competitive. As you accumulate profits, reinvest in expanding your restaurant chain across various exotic and bustling locations. Each new restaurant brings unique challenges and opportunities, keeping the gameplay engaging and rewarding.\n\n\"Restaurant Tycoon Dream\" offers an immersive VR interface where every decision impacts your success. With intuitive controls and realistic graphics, feel the thrill of slicing ingredients, saut\u00e9ing vegetables, and plating dishes\u2014all in VR. Are you ready to cook your way to success and become a true restaurant tycoon in this thrilling idle management adventure?", "short_description": "\"Restaurant Tycoon Dream\" is a VR arcade idle game that lets you build and manage your culinary empire! Design your dream restaurant, craft delicious dishes, and serve eager customers. Upgrade your kitchen, train staff, and expand to new locations. Experience the rush of restaurant management in immersive VR. Ready to become a culinary tycoon?"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/restaurant-tycoon-dreams", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6779192112205298"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974821_453611501040686_2266467352284701301_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dg8dgzfu4OwQ7kNvgEgCVAM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgWIHhJV6qI3vR7QlS2wl5J5LiPM4shrGZWDEi52OwJw&oe=672361F6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Restaurant Tycoon Dreams", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "rel