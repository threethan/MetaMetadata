g pass-through. \n\n* The app currently supports pdf, cbz, and zip files.", "short_description": "Livro is an XR reader app designed to bring the real-life physicality of interacting with books into the digital medium.\n\nImport your favorite novels, comic books, or manga and customize a digital replica that you can grab, manipulate, and flip through. \n\nRead in VR for maximum immersion or remain aware of your surroundings using pass-through. \n\n* The app currently supports pdf, cbz, and zip files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chronicbite.github.io/livro/privacy", "developer_terms_of_service_url": "https://chronicbite.github.io/livro/terms", "publisher_name": "ChronicBite", "support_website_url": null, "website_url": "https://chronicbite.github.io/livro/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "156495830716629"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "758678423027116"}, {"status": "PUBLISHED", "id": "201204446223385"}]}, "baseline_offer": {"id": "758678423027116"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712963880, "status": "PUBLISHED", "id": "758678423027116"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6668718089815270", "version": "0.1.2"}, "