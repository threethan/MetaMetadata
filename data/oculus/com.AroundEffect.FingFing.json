06235", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974853_1197874921339568_5440123697185013255_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hXJ_LLZgfoUQ7kNvgELI9YG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDDu5jUYUO8fMFu_8mzxLhXQsNjvIo2LvheyiZbi-WyEg&oe=6756DBFB"}, {"file_name": "ScreenShot_06.png", "id": "1652407508854509", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036625_1652407512187842_5805344665517755978_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Vwf2mwkqxAQ7kNvgE16qo0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAmP5Hjbjadlmzeu-_Sb5xjlODNVOKcQHa3ivElYzszXg&oe=6756C025"}, {"file_name": "ScreenShot_10.png", "id": "1126318891766450", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86601735_1126318895099783_2812360675534246664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7vrL1t3YKcsQ7kNvgHZ3_O-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCMDS9FBYE-WjJ3WUw62Axi49rRui-yriCl0Xim2DDJCg&oe=6756C309"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ScreenShot_10.png", "id": "981308963494230", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974685_981308966827563_5041963651491784421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UFis9R39nTIQ7kNvgE13Mq8&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB9cCttH_02SsSsrLmzeZ-4vPpyYqbZFbnvK1sO1ABKiA&oe=6756D656"}, "display_name": "FingFing", "keywords": [], "long_description": "When you press your finger on the ground, the character moves with a \"Fing\" sound. \nThis is the only control in this game, you don't need a controller, just \"Fing\" the ground with your index finger, and you can clear all the stages of the game. \n\n{469790078996779}\n\nYou can unlock 6 cute characters, and you can choose the main character for each stage. \nYou can play a total of 300 stages. when you clear the last stage, you can watch a concert of the 6 characters. \n\n\"FingFing\" is organized into four categories of games.\n Crossing the road, Find the maze, Block floor, Memorization\n\nImmerse yourself in a casual puzzle game filled with cute spaces and cute characters.  Master the art of finger movement and challenge yourself with increasingly complex levels. \n\n1. Crossing the road\n{468079492518832}\n\n2. Find the maze\n{1746179812456480}\n\n3. Block floor\n{1200729004441377}\n\n4. Memorization\n{1041506847592682}", "short_description": "\"FingFing\" a VR healing puzzle game played entirely with your fingers"}]}, "developer_name": "AroundEffect Inc.", "developer_privacy_policy_url": "https://aroundeffect.blogspot.com/2021/07/aroundeffect-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "AroundEffect Inc.", "support_website_url": null, "website_url": "http://aroundeffect.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "af", "ak", "sq", "arq", "ar", "am", "hy", "rup", "frp", "as", "az", "az_TR", "bcc", "ba", "eu", "bel", "bn", "bs", "br", "bg", "ca", "bal", "zh_CN", "zh_HK", "zh_TW", "co", "hr", "cs", "da", "dv", "nl", "nl_BE", "dzo", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "eo", "et", "fo", "fi", "fr_BE", "fr_CA", "fr", "fy", "fuc", "gl", "ka", "de", "de_CH", "el", "gn", "gu", "haw", "haz", "he", "hi", "hu", "is", "ido", "id", "ga", "it", "ja", "jv", "kab", "kn", "kk", "km", "kin", "ky", "ckb", "ko", "lo", "lv", "li", "lin", "lt", "lb", "mk", "mg", "ms", "ml", "mri", "mr", "xmf", "mn", "me", "mya", "ne", "nb", "nn", "oci", "ory", "os", "ps", "fa", "fa_AF", "pl", "pt_BR", "pt", "pa", "rhg", "ro", "roh", "ru", "ru_