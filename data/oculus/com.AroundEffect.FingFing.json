28", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75280981_1109196560172361_7445881001807314201_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jE7QBUMofiUQ7kNvgH9ERzG&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAnKpGOwFq_RWDhxQpXCyw10FulgfvNzT5pVee68R94JA&oe=67010CD1"}, {"file_name": "MiniLandscape.png", "id": "484583561194346", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974463_484583564527679_1843368915514574841_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0V9ZFRIXM8Q7kNvgG2svRx&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDSifGGEmmoGU22iNf8gcoDrmMPH3efgJ6GFHeDEMXw_w&oe=67013365"}, {"file_name": "01_main_01_big.png", "id": "469790078996779", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75404378_469790082330112_4642416773285806125_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4aQH9j4tZh8Q7kNvgFxrlgC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC7QmvLSrw2WK7D6RhIBjSQktMrAVTRV8ubxXNCZEiHSQ&oe=67013FC3"}]}, "id": "830526689071032", "locale": "en_US", "screenshots": [{"file_name": "ScreenShot_02.png", "id": "528579482849079", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86867710_528579486182412_9210849706424792127_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c5F3bdC7b-cQ7kNvgHwoXE4&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBs0dqyj8v46L1HgFeZz20kJRg50ZX6WWWFf0S9G9Dh1Q&oe=67013B11"}, {"file_name": "ScreenShot_09.png", "id": "367121736401235", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57570293_367121739734568_7672935860963024441_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NgEaErA-2-sQ7kNvgFBZ6Or&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBi4ynl4dHPFwVRvwhP2p7cYsOF7m0BmbjSEVoIB2YqHQ&oe=670126D1"}, {"file_name": "ScreenShot_05.png", "id": "1197874918006235", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974853_1197874921339568_5440123697185013255_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BS4W8Ggk5MYQ7kNvgErs14o&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC6b7peW4twF8PEMNw5-oOFbQCiog_chFcinyYwIB1KYg&oe=67012A7B"}, {"file_name": "ScreenShot_06.png", "id": "1652407508854509", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036625_1652407512187842_5805344665517755978_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Frak8re_C2kQ7kNvgG8612a&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDxT-tTF3lzoAlAw-o772MTrhBQKdd8I5vh0FjnqsTPzg&oe=67010EA5"}, {"file_name": "ScreenShot_10.png", "id": "1126318891766450", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86601735_1126318895099783_2812360675534246664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5VoNJLwZSK0Q7kNvgEZKw-Q&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBjamMP49-WSY36BrBTjZUGw7U-DlRWmWDk8TbhDtIXNQ&oe=67011189"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ScreenShot_10.png", "id": "981308963494230", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974685_981308966827563_5041963651491784421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mZTm3UkgFgoQ7kNvgHW50Ei&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDTpZNsbMenjtqTwvBhqJNFTflFGPIZfDF8PEbHgXERtQ&oe=670124D6"}, "display_name": "FingFing", "keywords": [], "long_description": "When you press your finger on the ground, the character moves with a \"Fing\" sound. \nThis is the only control in this game, you don't need a controller, just \"Fing\" the ground with your index finger, and you can clear all the stages of the game. \n\n{469790078996779}\n\nYou can unlock 6 cute characters, and you can choose the main character for each stage. \nYou can play a total of 300 stages. when you clear the last stage, you can watch a concert of the 6 characters. \n\n\"FingFing\" is organized into four categories of games.\n Crossing the road, Find the maze, Block floor, Memorization\n\nImmerse yourself in a casual puzzle game filled with cute spaces and cute characters.  Master the art of finger movement and challenge yourself with increasingly complex levels. \n\n1. Crossing the road\n{468079492518832}\n\n2. Find the maze\n{1746179812456480}\n\n3. Block floor\n{1200729004441377}\n\n4. Memorization\n{1041506847592682}", "short_description": "\"FingFing\" a VR healing puzzle game played entirely with your fingers"}]}, "developer_name": "AroundEffect Inc.", "developer_privacy_policy_url": "https://aroundeffect.blogspot.com/2021/07/aroundeffect-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "AroundEffect Inc.", "support_website_url": null, "website_url": "http://aroundeffect.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "af", "ak", "sq", "arq", "ar", "am", "hy", "rup", "frp", "as", "az", "az_TR", "bcc", "ba", "eu", "bel", "bn", "bs", "br", "bg", "ca", "bal", "zh_CN", "zh_HK", "zh_TW", "co", "hr", "cs", "da", "dv", "nl", "nl_BE", "dzo", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "eo", "et", "fo", "fi", "fr_BE", "fr_CA", "fr", "fy", "fuc", "gl", "ka", "de", "de_CH", "el", "gn", "gu", "haw", "haz", "he", "hi", "hu", "is", "ido", "id", "ga", "it", "ja", "jv", "kab", "kn", "kk", "km", "kin", "ky", "ckb", "ko", "lo", "lv", "li", "lin", "lt", "lb", "mk", "mg", "ms", "ml", "mri", "mr", "xmf", "mn", "me", "mya", "ne", "nb", "nn", "oci", "ory", "os", "ps", "fa", "fa_AF", "pl", "pt_BR", "pt", "pa", "rhg", "ro", "roh", "ru", "ru_UA", "rue", "sah", "sa_IN", "srd", "gd", "sr", "szl", "sd", "si", "sk", "sl", "s