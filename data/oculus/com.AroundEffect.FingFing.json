dzZVwT_1jFfPaSKDF6RsdTTtyCtyh5Vi0ndg&oe=66CB1951"}, {"file_name": "ScreenShot_05.png", "id": "1197874918006235", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_1197874921339568_5440123697185013255_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PV08ohAgZOoQ7kNvgFFgt5J&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACn009woDbySWV4yz1F2QCJ&oh=00_AYBoN3no4iONWKw4HamNInsbtTX0QDqfI8ntrvwFoorVmQ&oe=66CB1CFB"}, {"file_name": "ScreenShot_06.png", "id": "1652407508854509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036625_1652407512187842_5805344665517755978_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zjwp4AVphewQ7kNvgHGne_p&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACn009woDbySWV4yz1F2QCJ&oh=00_AYD6wl5oEJQCQ1Mr1iwxxC9iYjwbDmuIwObzfK5IbOZnTw&oe=66CB0125"}, {"file_name": "ScreenShot_10.png", "id": "1126318891766450", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86601735_1126318895099783_2812360675534246664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3Hxr-MksgsQ7kNvgFp5YUu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACn009woDbySWV4yz1F2QCJ&oh=00_AYClBSghhtfR_7-Zi6bPPJ0-XEudBpNrADo7eieSyDiotw&oe=66CB0409"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ScreenShot_10.png", "id": "981308963494230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_981308966827563_5041963651491784421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l18jX8e4sowQ7kNvgG-xQbK&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACn009woDbySWV4yz1F2QCJ&oh=00_AYBY2J4Idsyf70pDje2TZOmX5eV--X0g8d90zPuJYkWvdg&oe=66CB1756"}, "display_name": "FingFing", "keywords": [], "long_description": "When you press your finger on the ground, the character moves with a \"Fing\" sound. \nThis is the only control in this game, you don't need a controller, just \"Fing\" the ground with your index finger, and you can clear all the stages of the game. \n\n{469790078996779}\n\nYou can unlock 6 cute characters, and you can choose the main character for each stage. \nYou can play a total of 300 stages. when you clear the last stage, you can watch a concert of the 6 characters. \n\n\"FingFing\" is organized into four categories of games.\n Crossing the road, Find the maze, Block floor, Memorization\n\nImmerse yourself in a casual puzzle game filled with cute spaces and cute characters.  Master the art of finger movement and challenge yourself with increasingly complex levels. \n\n1. Crossing the road\n{468079492518832}\n\n2. Find the maze\n{1746179812456480}\n\n3. Block floor\n{1200729004441377}\n\n4. Memorization\n{1041506847592682}", "short_description": "\"FingFing\" a VR healing puzzle game played entirely with your fingers"}]}, "developer_name": "AroundEffect Inc.", "developer_privacy_policy_url": "https://aroundeffect.blogspot.com/2021/07/aroundeffect-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "AroundEffect Inc.", "support_website_url": null, "website_url": "http://aroundeffect.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "af", "ak", "sq", "arq", "ar", "am", "hy", "rup", "frp", "as", "az", "az_TR", "bcc", "ba", "eu", "bel", "bn", "bs", "br", "bg", "ca", "bal", "zh_CN", "zh_HK", "zh_TW", "co", "hr", "cs", "da", "dv", "nl", "nl_BE", "dzo", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "eo", "et", "fo", "fi", "fr_BE", "fr_CA", "fr", "fy", "fuc", "gl", "ka", "de", "de_CH", "el", "gn", "gu", "haw", "haz", "he", "hi", "hu", "is", "ido", "id", "ga", "it", "ja", "jv", "kab", "kn", "kk", "km", "kin", "ky", "ckb", "ko", "lo", "lv", "li", "l