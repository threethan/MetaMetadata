381"}, {"file_name": "ss_c6cdaeb0949a29ae1418e5a676ad14b901b3b38e.1920x1080.png", "id": "223024203931737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031446_223024207265070_5116694441189297930_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WTWNdvhJproQ7kNvgH71dI3&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zCdqgNjltzPmRPTor398p&oh=00_AYB463Umr-akxpsUtfYphDPCdWhOSjoU2FNcn3pkSlYX-Q&oe=66F694F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VY5T6okm4qgQ7kNvgHoyV2L&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zCdqgNjltzPmRPTor398p&oh=00_AYAbKMWPHwZiWzBOL-G99qV4azlWzTVOhSwgV_AIpFDMcA&oe=66F68BC0"}, "display_name": "The Obsessive Shadow", "keywords": [], "long_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you...\n\nWHAT'S THAT?\n\nYou're winding down at home for the night when suddenly you see a very strange emergency broadcast alert air on T.V. followed up with a knock at your window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nYour flashlight is your best friend...\n\nPOWER... OFF??\n\nit's so dark...\n\nSHOW YOURSELF!!!\n\nCatch him before he catches you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you..."}]}, "developer_name": "Sleepy Dog Studios", "developer_privacy_policy_url": "https://www.sleepydogstudios.net/privacy-policy", "developer_terms_of_service_url": null, "pub