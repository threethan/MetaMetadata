4441189297930_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mQgyjHsR798Q7kNvgFNTuLC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGf_kFmvwkdUAAMh_6c5u0jAbfJLry8LQYmss0peyG2w&oe=670CFE70"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SHU5bLpSyEcQ7kNvgHHC8xD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtSG_vNojP-2I9TB8tC6_iokefLQwJQIUXTj3DC9l9Kw&oe=670CF540"}, "display_name": "The Obsessive Shadow", "keywords": [], "long_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you...\n\nWHAT'S THAT?\n\nYou're winding down at home for the night when suddenly you see a very strange emergency broadcast alert air on T.V. followed up with a knock at your window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nYour flashlight is your best friend...\n\nPOWER... OFF??\n\nit's so dark...\n\nSHOW YOURSELF!!!\n\nCatch him before he catches you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you..."}]}, "developer_name": "Sleepy Dog Studios", "developer_privacy_policy_url": "https://www.sleepydogstudios.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Sleepy Dog Studios", "support_website_url": "https://www.sleepydogstudios.net/#contact", "website_url": "https://www.sleepydogstudios.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_