=66E2DD01"}, {"file_name": "ss_c6cdaeb0949a29ae1418e5a676ad14b901b3b38e.1920x1080.png", "id": "223024203931737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031446_223024207265070_5116694441189297930_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FS-Ay2o0yO0Q7kNvgG4CT_I&_nc_ht=scontent.oculuscdn.com&_nc_gid=A80flcpJy0nres8vDetvsDH&oh=00_AYDizHUj1SXLgolL6W7m0QZrtZhsEqxWMbctlDRHCQIidw&oe=66E2CE70"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ofh6x6FhcNYQ7kNvgGyoCQq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A80flcpJy0nres8vDetvsDH&oh=00_AYDoiqVJ3gFFlmo_-bVHy0t2yHguRxG6MDMfWv3pwR7P3w&oe=66E2C540"}, "display_name": "The Obsessive Shadow", "keywords": [], "long_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you...\n\nWHAT'S THAT?\n\nYou're winding down at home for the night when suddenly you see a very strange emergency broadcast alert air on T.V. followed up with a knock at your window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nYour flashlight is your best friend...\n\nPOWER... OFF??\n\nit's so dark...\n\nSHOW YOURSELF!!!\n\nCatch him before he catches you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival Indie Horror Game about a stalker you can't exactly Identify. With nothing but your eyes and a flashlight at your disposal, it's up to you to survive whatever horrific person or thing is out there watching you..."}]}, "developer_name": "Sleepy Dog Studios", "developer_privacy_policy_url": "https://www.sleepydogstudios.net/privacy-policy", "developer_terms_of_service_url": null