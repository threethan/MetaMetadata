_848170509737076_5910748200883144760_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aquSEsIcB_IQ7kNvgHbhABy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9RqKYpPfma1FfF0_aUunu1t-5wUCW_6RuH3B4bH4Q8Q&oe=6714F72E"}, {"file_name": "ss_d3e67170ba39ef9ca773d07e0b3dab65cb64404b.1920x1080.png", "id": "519501896634768", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003276_519501899968101_3666167532333045361_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EWx3Yyq5LjoQ7kNvgF6WBpJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYEg3Hcrr0y01HUFu95EMuDju943z5s0jFhkxVvpnPiw&oe=6714D95A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_qqrA5ZVer0Q7kNvgGp1M6r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDh8quDR8sF30RlVupX3VHRZreodYMouIMZNmMrRzEiYQ&oe=6714DE40"}, "display_name": "The Obsessive Shadow Demo", "keywords": [], "long_description": "The Obsessive Shadow is an Indie VR Survival horror game about fending off a home intruder that you can't exactly identify... Keep yourself safe with nothing but a flashlight and your own eyes...\n\nWHAT'S THAT?\n\nYou're going about your business winding down at home for the night when suddenly you see a very strange emergency broadcast come on the T.V. followed by a knock on the window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nyour flashlight is your best friend\n\nPOWER... OFF??\n\nKeep things quiet to avoid angering him...\n\nSHOW YOURSELF!!!\n\nCheck under the bed, something is reaching for you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival horror game about fending off a home intruder. Keep yourself safe with nothing but a flashlight and your eyes..."}]}, "developer_name": "Sleepy Dog Studios", "developer_priva