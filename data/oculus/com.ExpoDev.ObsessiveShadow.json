1w&oe=66F7D85A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hergNHg0iUQQ7kNvgHO0jRH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBurgq7ws7AUNVl5eR204HamzCR5N9N1KUtCfIv6h2JFg&oe=66F7DD40"}, "display_name": "The Obsessive Shadow Demo", "keywords": [], "long_description": "The Obsessive Shadow is an Indie VR Survival horror game about fending off a home intruder that you can't exactly identify... Keep yourself safe with nothing but a flashlight and your own eyes...\n\nWHAT'S THAT?\n\nYou're going about your business winding down at home for the night when suddenly you see a very strange emergency broadcast come on the T.V. followed by a knock on the window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nyour flashlight is your best friend\n\nPOWER... OFF??\n\nKeep things quiet to avoid angering him...\n\nSHOW YOURSELF!!!\n\nCheck under the bed, something is reaching for you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival horror game about fending off a home intruder. Keep yourself safe with nothing but a flashlight and your eyes..."}]}, "developer_name": "Sleepy Dog Studios", "developer_privacy_policy_url": "https://sleepy-dog-studios.github.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Sleepy Dog Studios, ExpoDev", "support_website_url": null, "website_url": "https://sleepydogstudios.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area":