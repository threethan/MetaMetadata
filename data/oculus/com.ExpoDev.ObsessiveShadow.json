_848170509737076_5910748200883144760_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=veU9Zx-YyOQQ7kNvgHWYa01&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCinhdfMRyxzSsqK0KfDC3nVfVzs1vsHaJ8NknE9NmrTw&oe=67179A2E"}, {"file_name": "ss_d3e67170ba39ef9ca773d07e0b3dab65cb64404b.1920x1080.png", "id": "519501896634768", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003276_519501899968101_3666167532333045361_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i02G5FGPd0oQ7kNvgFD7AO1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCd-I2X6NMaJy9EgDKzoKHB_0h2iWvHp4YGW176NbDTg&oe=67177C5A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimg.png", "id": "848855059562579", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_848855062895912_6314837845818043239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zQc6FFOnMVYQ7kNvgG1k86p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIbwVCaA1gx6ulVu6MJ-zitoxV-tpzOHCwW3-jepmc3w&oe=67178140"}, "display_name": "The Obsessive Shadow Demo", "keywords": [], "long_description": "The Obsessive Shadow is an Indie VR Survival horror game about fending off a home intruder that you can't exactly identify... Keep yourself safe with nothing but a flashlight and your own eyes...\n\nWHAT'S THAT?\n\nYou're going about your business winding down at home for the night when suddenly you see a very strange emergency broadcast come on the T.V. followed by a knock on the window...\n\nWHO'S THERE?\n\nWatch your windows, something is close by and watching you...\n\nGOTCHA!\n\nyour flashlight is your best friend\n\nPOWER... OFF??\n\nKeep things quiet to avoid angering him...\n\nSHOW YOURSELF!!!\n\nCheck under the bed, something is reaching for you!\n\n", "short_description": "The Obsessive Shadow is a VR Survival horror game about fending off a home intruder. Keep yourself safe with nothing but a flashlight and your eyes..."}]}, "developer_name": "Sleepy Dog Studios", "developer_priva