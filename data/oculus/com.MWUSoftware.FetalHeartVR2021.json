=o6zXHcjWX9QQ7kNvgE5sTBz&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8hiRQvaiHTc7F4dPc-8d-D59NwZv6w3DgQkq3qsU38w&oe=66D6EB0B"}, {"file_name": "cover_mini_13_.png", "id": "183396560281774", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_183396573615106_2241025425633465028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y2AHqoBOo4AQ7kNvgEP35B_&_nc_ht=scontent.oculuscdn.com&oh=00_AYB7L8Qzsn2pkg38wVP54cnMODc6eSIJQSCkrMx8XdLS8A&oe=66D6F66D"}]}, "id": "765595427477753", "locale": "en_US", "screenshots": [{"file_name": "scrshts_0001_Layer-4.png", "id": "927688834648355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982586_927688837981688_3492050327686788621_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bv2_clVsO7EQ7kNvgF9bUjo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCn8gpRJjrrcfKA45sAzIHZa-PLPMKMiqPlJW5-2mSYg&oe=66D6FEED"}, {"file_name": "scrshts_0000_Layer-5.png", "id": "922582825173596", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031567_922582828506929_5296870872997217138_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FhoRtgVrfccQ7kNvgEe5xWE&_nc_ht=scontent.oculuscdn.com&oh=00_AYDGhDJS0S0Lcza68_mHw6_csYl5IIBgG0eIBWjRrusIZQ&oe=66D6F6C5"}, {"file_name": "scrshts_0003_Layer-2.png", "id": "777617422887584", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_777617426220917_5046911845590742222_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=onjRUzss6CkQ7kNvgH8vzPg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtx2gU55X--9kHKx_fCrB-RpNsuxW3xR95zKZnvqumjw&oe=66D6FCC1"}, {"file_name": "scrshts_0004_Layer-1.png", "id": "522467975409751", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974909_522467978743084_3999197066674584349_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4GmXwArETjEQ7kNvgG9TqwM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBks4B33njtGu1xemHu9MSaf8GyOBWzh25fKf9Mu8qwCw&oe=66D6EE66"}, {"file_name": "scrshts_0002_Layer-3.png", "id": "299838361722592", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982602_299838365055925_766843420144144362_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vupUykgw7MYQ7kNvgG0qLTo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBcJvob6E6NE4ucZRJBRiiXbd2J9AC-G2MagSutgD9fyA&oe=66D70486"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fetal Heart VR", "keywords": [], "long_description": "Fetal Heart VR is a self-teaching tool to learn geometry, anatomy, and function of Congenital Heart Diseases.\n\nWith the app, you can make a virtual ultrasound scan of normal and abnormal heart models and learn specific anatomical and geometrical features typical for Congenital Heart Diseases. The controller simulates the ultrasound probe - by moving it like an ultrasound probe you can obtain all recommended fetal cardiac views for prenatal examination\n\nWith the Fetal Heart VR, we hope to enable a more personal, affordable opportunity to learn how to perform ultrasound scans, available for all professionals involved in prenatal sonography.\n\nThis version includes a healthy fetal heart as well as 14 Congenital Heart Defects: tetralogy of Fallot (TOF), Transposition of the Great Arteries (dTGA, lTGA),  hypoplastic left heart syndrome (HLHS MS-AA, HLHS MAAA), Critical Aortic Stenosis (CritAS), Atrio-Ventricular Septal Defect (AVSD, uAVSD) Double Outlet Right Ventricle (DORV) and more.", "short_description": "Fetal Heart VR is a self-teaching tool to learn geometry, anatomy, and function of Congenital Heart Diseases.\nWith the app, you can make a virtual ultrasound scan of normal and abnormal heart models and learn specific anatomical features typical for Congenital Heart Diseases. The controller simulates the ultrasound probe - by moving it like an ultrasound probe you can obtain all recommended fetal cardiac views for prenatal examination."}]}, "developer_name": "MWU Software", "developer_privacy_policy_url": "https://mwu.gridproducts.pl/privacy-policy/", "developer_terms_of_service_url": "https://mwu.gridproducts.pl/terms-and-conditions/", "publisher_name": "MWU 3D Models z.o.o.", "support_website_url": "http://mwusoftware.com/", "website_url": "https://mwu.gridproducts.pl/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDICINE", "SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "979002403045325"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3822305317879282", "version": "2.04"}, "id": "802061334078040", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3672461322863683", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3822305317879282"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "802061334078040"}]}, "change_log": "Fetal Heart VR version:2.0.4. \n------ \n\nThis is an initial release of our Fetal Heart VR app prepared for Oculus Quest and Quest 2, and a major upgrade from the Oculus Go version. \n\nWHAT'S NEW: \n- In the Quest version you are able to completely reproduce all the movements done with the echo probe during the examination, \n- The design of the Quest platform allowed us to improve the interface significantly. \n- This version covers a completely new model of the Normal Heart, that includes much more anatomical detail of the Heart and nearby cardiovascular structures. \n- In this version, we start to introduce Quizzes - a way to challenge yourself with recognizing different Congenital Heart Defects. \n- Freeze and CINE options are now available \n- for Normal Heart, recommended views from ISUOG, AIUM, and ASE guidelines can be detected \n- you can turn on the natural movements of the fetus that occur during any echo examination. \n\nSUPPORT & QUESTIONS\nAre you having problems? Do you have a suggestion for a new feature? Please, write to us: \ninfo@mwusoftware.com \n\nHave a great day! \nPiotr from MWU Software", "created_date": 1623096733, "id": "3822305317879282", "version": "2.04", "version_code": 15, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3672461322863683", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3822305317879282"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1623093053, "id": "3822180487891765", "version": "2.04", "version_code": 12, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3672461322863683", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3822305317879282"}, "release_status": "RELEASED"}, "b