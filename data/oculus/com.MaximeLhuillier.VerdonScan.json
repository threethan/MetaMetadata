97F"}, {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMyf6Ntac8cQ7kNvgE3dcPH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzBfPzDqAzZI8gXa-FH78Pn&oh=00_AYDOPfziUwf3JJL2Bi1WMdYTTaXpFoUz5WCLXodQSOSSwg&oe=66E6AD7C"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U5AWINM6iKgQ7kNvgE6qWP4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzBfPzDqAzZI8gXa-FH78Pn&oh=00_AYCXoC4XsknvN6phlz_E24uqAwLZWDuoV-DpekQe3uAtAw&oe=66E6ADEB"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0dcZH8WeIvkQ7kNvgGbDi3X&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzBfPzDqAzZI8gXa-FH78Pn&oh=00_AYChC6kTx0Z1Td6DovXMOJOAfk2Egf0Ljx6gMn2fBf4TRA&oe=66E6CB29"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-GDjmxrq-mIQ7kNvgHJnuk4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzBfPzDqAzZI8gXa-FH78Pn&oh=00_AYAbDpdOe_G5JvtNLp5yXIHssttEAE24PthE-6T8xzWe1A&oe=66E6D1A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lseeKklV20wQ7kNvgEDwGWy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzBfPzDqAzZI8gXa-FH78Pn&oh=00_AYDBFCguOq5HnAkc7Zt136Et51l5dJcvdRTUJWuBxkef8w&oe=66E6B117"}, "display_name": "3D scan of the Verdon's canyon", "keywords": [], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_t