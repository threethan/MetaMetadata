e": "Icon.png", "id": "1188191841742654", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001667_1188191845075987_1672082226289705403_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ozGRkt-EloYQ7kNvgF2Yh0-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDjzw7mPjP6mNBa1KYvpvKoTLtwch4gpwsuuvTUwEoU7g&oe=67864986"}, {"file_name": "CoverPortrait.png", "id": "634710061561605", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974457_634710064894938_32077390907761992_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10KwAYKo08cQ7kNvgEXMkll&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB6NgjBZbcMqazl-efEmYMwPgI31IyzBS2Xz21p_BF2uQ&oe=67864F53"}, {"file_name": "HeroCover.png", "id": "621733379666539", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982541_621733386333205_397279185868447146_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sd87M5UY-oEQ7kNvgFk8pdc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCoyU7hstlB_6Ur6shr9GaUwBwecpegY1_pedKn9-qYBQ&oe=678658EB"}]}, "id": "485497714323880", "locale": "en_US", "screenshots": [{"file_name": "Screenshot0.png", "id": "520742116522759", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974824_520742119856092_6530093332663618335_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=abXfYdpMnHIQ7kNvgF_-Nb7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDOvCFSL5VrvmHV3ThOU5YkARunu-cvrxUCS6fIWVWPTg&oe=67865EFF"}, {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jHL4rzUoehEQ7kNvgGklEHk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC1eWHlg9IJVkcaQDWmYi9ht-DE9O-ZJMaIHu1pDqYs4A&oe=678632FC"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fw0vJmwVCX0Q7kNvgEATffy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBL0gjkPgXxLxA_TY9mCxadp5DhEJ21yJjaMFuNP7al2g&oe=6786336B"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iF9omgbPodUQ7kNvgGZKnKc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDvXH7CuToN8Q-FuFM-h40DpwGV2418QBpV0r_hAT6_sA&oe=678650A9"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_x55-gUEeloQ7kNvgEOuKUy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCdnHVfYxqWd5sb7_ZI2o0kHFsS5zWUPeA8pgZ1p_pkig&oe=67865722"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tACuEX-fuksQ7kNvgGLh0iB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC7C_OVgG2IDTKg5vbl8n70wI_WLVT5EnxnCwzuYn4x7g&oe=67863697"}, "display_name": "3D scan of the Verdon's canyon", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26915388004771951"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Acn4Zs-fQikQ7kNvgFsWo76&_nc_zt=3&_nc_ht=sconte