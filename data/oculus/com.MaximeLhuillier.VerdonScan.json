e": "Icon.png", "id": "1188191841742654", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1188191845075987_1672082226289705403_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PdvQSvkuuW4Q7kNvgFqnXLC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkMZElagsgwTkHoiCE-690eXVdqbQtRKruHCJ8GRBQlg&oe=677D0F06"}, {"file_name": "CoverPortrait.png", "id": "634710061561605", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974457_634710064894938_32077390907761992_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MyOFVWWdwngQ7kNvgFnctA0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA56K5-z4bjY9MQ6o5pVj282IFIqbCKIGkjG8OwyCFQag&oe=677D14D3"}, {"file_name": "HeroCover.png", "id": "621733379666539", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982541_621733386333205_397279185868447146_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ArRtJKXx0WIQ7kNvgFRItE1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAG5bVL1_PxP_FTSzLt8MIpPqBt7HLb_rpXmjOqPKcsDg&oe=677D1E6B"}]}, "id": "485497714323880", "locale": "en_US", "screenshots": [{"file_name": "Screenshot0.png", "id": "520742116522759", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_520742119856092_6530093332663618335_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Bpc9dJ2iaYQ7kNvgE7_lmT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBElq_YbBeSr0Msugw-WyLz4M0hz77Q-SvkJbGRE7fiLw&oe=677D247F"}, {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gT5efpIhQOgQ7kNvgGX-H9s&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsApGMXoCdEeQA-qV6b2_2a2lZQjKc7kht6z2OHptx8A&oe=677CF87C"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ghtrEzSqb9QQ7kNvgGJHlum&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPfjDKz8p6ZmvXj8Q4s7_JPSk8LHEngccVPGNy3i-19g&oe=677CF8EB"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Doy5uc0Q87QQ7kNvgG2alQ4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTu2R6hRdcFr20QEhy836h5K-4PhppZpTeVvjNYomssA&oe=677D1629"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gf21scPf3sQ7kNvgFI9zlt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCi2ExlGQ4P_HowNO6uSt6A6BmDzYEuQQ4RJAiIt-jxMA&oe=677D1CA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AlA8ryKYcGcQ7kNvgHTFj_2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDiIBwo_86-89xxisYvMIhPF-QqEsJqW2sn8p3JHhE4g&oe=677CFC17"}, "display_name": "3D scan of the Verdon's canyon", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26915388004771951"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e7zXJlImH-AQ7kNvgGUtMwj&_nc_zt=3&_nc_ht=sconte