 {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Cr7-hsD6IQQ7kNvgFEiwkH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYDwVXo2-92RW-Se2y625mlJCELq1XO3jhozC3YJ2m5xXA&oe=66F28AFC"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=icJbJImeNfoQ7kNvgFh-jlT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYBekys9T1m5GbD3YK4sp1FMg0ZqyqO5PytWHtPdjD18VQ&oe=66F28B6B"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1Jw_-_kiRAQ7kNvgGbuPzM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYBC0ulC7q2TiWoldPxxfZ4wc-8FgV0EqVSQkzko6qNu1A&oe=66F2A8A9"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u7O1-MQt-b8Q7kNvgH2TTvI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYBLhwyK_o_v1RnpCF_GIfWZcVnmVYdIf0EjsCObY5IEJA&oe=66F2AF22"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GRF3ZzLIzAMQ7kNvgEgKAw2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYACf2WVOiRRCJJiKjsxKLbDkl5pd_zgGxRXtdUQkTQbIA&oe=66F28E97"}, "display_name": "3D scan of the Verdon's canyon", "keywords": [], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "842934970328926"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lITTjK2qpnUQ7kNvgH3bsh3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYA3yu5I5XjyOlTkMcTNjW1otkXP4wYODpnGAlGIjbwQzg&oe=66F2A9B5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "3D scan of the Verdon's canyon", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1662050229, "lastRevision": {"nodes": [{"id": "8038095429594493", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8038095376261165", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1226878741435860"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Logo2.png", "id": "1727928950896113", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86620695_1727928957562779_7090622951947483495_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bR00bhOqb38Q7kNvgEdALD2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYAFn_FdItByCfTIR0k63Y7LmjjihsxcewsgiYdWnmiJDQ&oe=66F2A96B"}, {"file_name": "CoverLandscape.png", "id": "1704462486593285", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_1704462496593284_3123954089663146348_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=je6Icl-WUNUQ7kNvgEimi6N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAyNgatWhBh-iwItoyIh1dS&oh=00_AYDpm9A0DUd2vFWw4GCbpf5qvLfm7Uauo90sPYGIVaok-g&oe=66F2A1E8"}, {"file_name": "CoverMiniLandscape.