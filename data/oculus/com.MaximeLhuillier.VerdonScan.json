uscdn.com&oh=00_AYDoD4mp6u5-IEM_WIYfSjNj4QiB-W1Aq1nlVCue0b38sQ&oe=66DD72FC"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R09oytFeyscQ7kNvgFyIeOD&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5w5snr8M3N5pZrHV4EBf5AJDhk5ZzRZv8Rm-wy10tCQ&oe=66DD736B"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6EIt8nq_nVcQ7kNvgEB6X_Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUnH_KU3wM2wQtsMq87_rxKb_TMedNDTsol6xspBvJAA&oe=66DD90A9"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GD2lvHtjX7UQ7kNvgG_ZJo_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZMMo1mx32WpXVjHsTQiJEvc2B5F3KSmqZiSPpIQbIgw&oe=66DD9722"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WHIqH3LPqAQ7kNvgEAqcAl&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3JdBhrPRduh2rJ7iX0rxAw6pZTnWZu1BxtUP89401Ng&oe=66DD7697"}, "display_name": "3D scan of the Verdon's canyon", "keywords": [], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "842934970328926"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nQeY6aH9uZgQ7kNvgFzE4RO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOi4FZyxELMzTgTWXL1piH5g8JjMw3an2eF_D0jydcQw&