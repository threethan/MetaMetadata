654", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1188191845075987_1672082226289705403_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sSbxjmDVCyEQ7kNvgHiWMPs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWUDwDs3h5Nn0NAQIOJ4tSe_b4bwMOgjC_Tt4tr80_6g&oe=67178B86"}, {"file_name": "CoverPortrait.png", "id": "634710061561605", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974457_634710064894938_32077390907761992_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iKg03JFIn_IQ7kNvgH5oFqj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsw77SttEl92p1vzxkmx-XW8CimaDFrG-bwgTRP4vwNg&oe=67179153"}, {"file_name": "HeroCover.png", "id": "621733379666539", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982541_621733386333205_397279185868447146_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rga8fdoAXowQ7kNvgEaBLx4&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAz1SCPZ8hBz4vWZbrOA89ARCduABnvh32Fvi3LfOK8oA&oe=67179AEB"}]}, "id": "485497714323880", "locale": "en_US", "screenshots": [{"file_name": "Screenshot0.png", "id": "520742116522759", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_520742119856092_6530093332663618335_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3yvnwk97bKYQ7kNvgHtArJ7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBii2_k9X4Z1nmAwrQtZLU9llMDO3fHu17ncAPaNPslA&oe=6717A0FF"}, {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KO-J3vQvK9sQ7kNvgF_90Lr&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMhCEy1DqA6nVrw1KsbRzM0cnBfiJuVyLFoOwDpaOK7w&oe=671774FC"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sJqVQ3ZyI2IQ7kNvgHqHb9V&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfQwvnV08reIC8G4FwSvSWFTcZV8ss3E8ccM1WoYKC7g&oe=6717756B"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q8xQrdCFrw0Q7kNvgGXxM-L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARNs_lx4mSUeHP3a1xF-Oh041ElyZpghzFRVChrHBNww&oe=671792A9"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qxOYCqovU3EQ7kNvgHjCGsg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_pyT8ASt39WR0rjQ9L-Qgx1L3abgsNbhKyFND94Fdrg&oe=67179922"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tHSx28TLWJ4Q7kNvgFeq3Zh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_hH-FTqrQLE1cNBX1pZSW3uSPFqNcT1PeQ4yGwgTb_A&oe=67177897"}, "display_name": "3D scan of the Verdon's canyon", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26915388004771951"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xvWvuD1AgIIQ7kNvgFs9Ra1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9wRkWjLRjzR79XtCEqTLySUXc7Dll9wM9bPbAqWJiKA&oe=671793B5"}, "is_concept": false, "is_test": f