e": "Icon.png", "id": "1188191841742654", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1188191845075987_1672082226289705403_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WlD55OsRnycQ7kNvgEi9yJa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWvqg__xoyRUz5EEttblf_OFumv_XsRYMwOlkpW_h6aw&oe=672CA386"}, {"file_name": "CoverPortrait.png", "id": "634710061561605", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974457_634710064894938_32077390907761992_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5wkkW438dMIQ7kNvgEAePqC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3rnc4AY-O_taR3DT9T3zB2ueBrUh72Hk5fO3SFH3F0A&oe=672CA953"}, {"file_name": "HeroCover.png", "id": "621733379666539", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982541_621733386333205_397279185868447146_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zox49DNXIDwQ7kNvgF8IXF8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAg0YkUw45LKiEggy2X5riS6ShsawArFSNGeIHL_ZCHVQ&oe=672CB2EB"}]}, "id": "485497714323880", "locale": "en_US", "screenshots": [{"file_name": "Screenshot0.png", "id": "520742116522759", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974824_520742119856092_6530093332663618335_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_UZNmXaS5z0Q7kNvgGCziXL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAel1jZjng_RuapQWrPkGW3URWM8OetBbR0aPOTpe1Qg&oe=672CB8FF"}, {"file_name": "Screenshot1.png", "id": "3001248820165356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035382_3001248823498689_57092404722974294_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GuE2nUtABM0Q7kNvgG_-m1f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBe7RvOAPsAiVp5lm_jIlnkPqsLr-ml66Kv_7zNLP7Oew&oe=672CC53C"}, {"file_name": "Screenshot2.png", "id": "1227522898033770", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982464_1227522901367103_7496718729731117090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=beVMwBOG2BQQ7kNvgH0ePA6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbmBG7HF1IuBp3AMutGWukyq4dFCeHJ5w8tBx5HbOq6Q&oe=672CC5AB"}, {"file_name": "Screenshot3.png", "id": "400523685352869", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_400523692019535_8401549706537711147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mKnZb9avKyEQ7kNvgF_Q_zD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCwCgJ8XygnmaiNm2Uw0UHPuzr8mupGiWxMwkubMB79Q&oe=672CAAA9"}, {"file_name": "Screenshot4.png", "id": "1301425357334121", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_1301425360667454_2162183305064303310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5-JwkVtCBjwQ7kNvgG1rdpf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCd3DKchpNCy4WVE7TCqIu_UUFDqT8F7rCLpOQv0OX8iQ&oe=672CB122"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "443437561075004", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580070_443437564408337_6207399824729004018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vlcrdpkDuYcQ7kNvgGGvAyc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwyy5BMXokH4jwd2_1yZNejYnSyYta8N9HGJShbEgjAA&oe=672C9097"}, "display_name": "3D scan of the Verdon's canyon", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a kayaker in the canyon of the Verdon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 2.5km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a kayaker in the canyon of the Verdon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by kayaking about 2.5km."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26915388004771951"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1213455862769266_6318729815187685553_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BkOm_pIBsEIQ7kNvgFXhfkD&_nc_zt=3&_nc_ht=scont