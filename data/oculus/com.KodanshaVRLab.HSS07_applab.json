0Q7kNvgGccrh3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-4MlyNT4UGChdUuN4tKYe649ScR7zpAyBuj94CuXkzQ&oe=6752ECD8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail\uff3fEN.png", "id": "1385848982285711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031529_1385848985619044_7932645804283440994_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L91g_g_zS3MQ7kNvgGcnYsw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBt9i--ux5-w4hExDN9SM5ok4c_Iup4KzykU6POHM4FQA&oe=6752E8FD"}, "display_name": "Hop Step Sing! By My Side", "keywords": [], "long_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\n\nJoin Shikiri for a romantic seaside date under the midsummer sun. Experience the joy of clasping your hands in hers, capturing picture-perfect moments, and crafting a mesmerizing VR music video that fans will find irresistible. Elevate your experience with a special bonus ending, unlocked by bringing joy to Shikiri, along with unique interactions that only VR can offer. Create unforgettable summer memories with Shikiri today!", "short_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\nUsing hand tracking, you can hold Shikiri's hand and take photos. The ending of the MV also changes depending on several interactive actions.\nThis heartwarming content is only possible in virtual reality!\nWhy not spend a memorable summer moment with Shikiri?\n"}, {"images": {"nodes": [{"file_name": "Logo TransparentJP 9000x1440px.png", "id": "7116072908484709", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974800_7116072915151375_8188742455952032553_n.png?_nc_cat=108&ccb=1-7&_nc_sid