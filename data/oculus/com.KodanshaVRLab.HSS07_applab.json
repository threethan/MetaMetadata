713_279198431500314_5126611026169557218_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OKsGotz-aswQ7kNvgFnI-3Z&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3pxh3G2yoMdKd8VIl5NNxkigxBqIxhTv1UBj2vWe26A&oe=66D5A89A"}]}, "id": "685403750468645", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "606301871412569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569422_606301874745902_5969691398966985340_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hOYTRMvFZRgQ7kNvgH2QvDV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBF1VQFw3Anw7ZYb9YHsO8k4yq8A9hu-Q5ezHl9IPQj2Q&oe=66D5AA38"}, {"file_name": "2.png", "id": "323821480173065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974458_323821483506398_1753346169402755972_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hoQd0yPbsTMQ7kNvgE_Ajmx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPszCtq4_ygT9BfZnKHmWcFGqOpK_ki4HOGCvevpWedA&oe=66D594B2"}, {"file_name": "4.png", "id": "311919491506832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250456_311919494840165_1584254742490173776_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=maAkwatCD-kQ7kNvgG2-Kf6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMuswj6n8iEMqoGCWbbVHesuMRRN2IPLZ6eb1ibHtCSw&oe=66D59DA7"}, {"file_name": "6.png", "id": "824719212431609", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429290_824719215764942_9145987177559641066_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=99sl-xe8Z_MQ7kNvgFJ3Iw1&_nc_ht=scontent.oculuscdn.com&oh=00_AYB6_9izw8N6pI-MnGRCqIAkqYF6sepIZas-WMPkk-9huQ&oe=66D5ACBA"}, {"file_name": "7.png", "id": "234717609071774", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222943_234717612405107_9009905920403019402_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6rt0l8QJRVgQ7kNvgE88HXl&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRmtCTU_GBmgZGgTPL356T_2qVboFMfyjaB7Opjjop6A&oe=66D5AE58"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail\uff3fEN.png", "id": "1385848982285711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031529_1385848985619044_7932645804283440994_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c5QHp-8hoekQ7kNvgGgy_fK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGlHUaJmjhKsTKdh303sbrVMdBQ3x_WeVzTr0XKEX9bg&oe=66D5AA7D"}, "display_name": "Hop Step Sing! By My Side", "keywords": [], "long_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\n\nJoin Shikiri for a romantic seaside date under the midsummer sun. Experience the joy of clasping your hands in hers, capturing picture-perfect moments, and crafting a mesmerizing VR music video that fans will find irresistible. Elevate your experience with a special bonus ending, unlocked by bringing joy to Shikiri, along with unique interactions that only VR can offer. Create unforgettable summer memories with Shikiri today!", "short_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\nUsing hand tracking, you can hold Shikiri's hand and take photos. The ending of the MV also changes depending on several interactive actions.\nThis heartwarming content is only possible in virtual reality!\nWhy not spend a memorable summer moment with Shikiri?\n"}, {"images": {"nodes": [{"file_name": "Logo TransparentJP 9000x1440px.png", "id": "7116072908484709", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_7116072915151375_8188742455952032553_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QSzDpI8OzbgQ7kNvgEOdc_7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDj447B2a4kpQlpnQTfVDZblNsa6eg_LdlOmShFrwKM_g&oe=66D5A72B"}, {"file_name": "Hero 3000x900px.png", "id": "2125333631133687", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75617315_2125333