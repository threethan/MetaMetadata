YQ7kNvgGjoEWM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDie693Obp6-oGVmkv8TsgJKPhcNdaLYl_XDPWV3u-Ybw&oe=67543E58"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail\uff3fEN.png", "id": "1385848982285711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031529_1385848985619044_7932645804283440994_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L91g_g_zS3MQ7kNvgEHirpU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANBA_0lHtOARulC8avtFVJyoZJpST-VJ8SCXfCuk3sWw&oe=67543A7D"}, "display_name": "Hop Step Sing! By My Side", "keywords": [], "long_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\n\nJoin Shikiri for a romantic seaside date under the midsummer sun. Experience the joy of clasping your hands in hers, capturing picture-perfect moments, and crafting a mesmerizing VR music video that fans will find irresistible. Elevate your experience with a special bonus ending, unlocked by bringing joy to Shikiri, along with unique interactions that only VR can offer. Create unforgettable summer memories with Shikiri today!", "short_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\nUsing hand tracking, you can hold Shikiri's hand and take photos. The ending of the MV also changes depending on several interactive actions.\nThis heartwarming content is only possible in virtual reality!\nWhy not spend a memorable summer moment with Shikiri?\n"}, {"images": {"nodes": [{"file_name": "Logo TransparentJP 9000x1440px.png", "id": "7116072908484709", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974800_7116072915151375_8188742455952032553_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ViRKtWT-SqoQ7kNvgHVj4jj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB6MyHArYINlnh2TncdzSL2iBxcagEngVSLbzVSVc3Y5Q&oe=6754372B"}, {"file_name": "Hero 3000x900px.png", "id": "2125333631133687", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75617315_2125333634467020_1924779169024147524_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1S0avp8XlIQ7kNvgGxl9-b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBMhQNyBGfUZZVsBiqRs-cv1P50C3nQBiqyZlw0IDNSdw&oe=67542118"}, {"file_name": "Cover Landscape 2560x1440.png", "id": "414602887664849", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269597_414602890998182_5527065958490967124_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s1zoTbOex14Q7kNvgGLdn6n&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAX7j5PjuxsErBZoI6fClKntXovJMSHpRCD60G5_70wRQ&oe=67542FF1"}]}, "id": "378138668249939", "locale": "ja_JP", "screenshots": [{"file_name": "1.png", "id": "1108496766974001", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031498_1108496770307334_4184770307113341496_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a8NADm81bzcQ7kNvgFjr0rn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCZWTwfq47s755q2xwijEZrK-qj14fNX7oGKYo_XtfpA&oe=675435C3"}, {"file_name": "3.png", "id": "3155467044597545", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86629764_3155467047930878_1135414980700668800_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ouQD8k4__k4Q7kNvgH4YPam&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv9KDuoaTglbpvBiYGW0lq6o_MvBUDjn0H6iehxCKWng&oe=67543079"}, {"file_name": "4.png", "id": "1533881560769174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035458_1533881564102507_1971429799922606995_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7K63Rf8q1Q0Q7kNvgH058be&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDL_fEEyAJMvNVBsrz5YTQpZwVqq