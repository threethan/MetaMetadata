0Q7kNvgGu8FCb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDY_FJYulSvex2444XDUoFeZL3BM-aGHAamtiJL0LUySQ&oe=67276B58"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail\uff3fEN.png", "id": "1385848982285711", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031529_1385848985619044_7932645804283440994_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YxCWUgzriaQQ7kNvgFxoNRs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABFFnPI1Rb5VgrSjeTfjFJNgO5bmxt1ZOqXFT8el-wUg&oe=6727677D"}, "display_name": "Hop Step Sing! By My Side", "keywords": [], "long_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\n\nJoin Shikiri for a romantic seaside date under the midsummer sun. Experience the joy of clasping your hands in hers, capturing picture-perfect moments, and crafting a mesmerizing VR music video that fans will find irresistible. Elevate your experience with a special bonus ending, unlocked by bringing joy to Shikiri, along with unique interactions that only VR can offer. Create unforgettable summer memories with Shikiri today!", "short_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\nUsing hand tracking, you can hold Shikiri's hand and take photos. The ending of the MV also changes depending on several interactive actions.\nThis heartwarming content is only possible in virtual reality!\nWhy not spend a memorable summer moment with Shikiri?\n"}, {"images": {"nodes": [{"file_name": "Logo TransparentJP 9000x1440px.png", "id": "7116072908484709", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974800_7116072915151375_8188742455952032553_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y1VLhke_eHcQ7kNvgHowXKC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAY-Qjyv05LrUvqnMXvYVCZZE6WCjR1URw_ykEsPbkZCg&oe=6727642B"}, {"file_name": "Hero 3000x900px.png", "id": "2125333631133687", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75617315_2125333634467020_1924779169024147524_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E5f79NbqSIMQ7kNvgES4G1N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpLsAc2ET9LoOEd1uA_ftMp4nGvPw1-bSBkCXHutTqpg&oe=67274E18"}, {"file_name": "Cover Landscape 2560x1440.png", "id": "414602887664849", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269597_414602890998182_5527065958490967124_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HUZawi9JvPkQ7kNvgGPrSx5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAI9C3ZX4VkKguOSbIBmx5alJULpW8-rSJiaxXU_ol0kg&oe=67275CF1"}]}, "id": "378138668249939", "locale": "ja_JP", "screenshots": [{"file_name": "1.png", "id": "1108496766974001", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031498_1108496770307334_4184770307113341496_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rkk_cunAFocQ7kNvgEgPDNj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzIIAldal7b1zKFW2Xi0tv-1EjmBe-xgXS53ykeczjgw&oe=672762C3"}, {"file_name": "3.png", "id": "3155467044597545", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86629764_3155467047930878_1135414980700668800_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=isWciUIdUs0Q7kNvgErd92v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPG8MBS1ihfpaEJu72PnL_uUDgzyqPT0MSZ73xkighag&oe=67275D79"}, {"file_name": "4.png", "id": "1533881560769174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035458_1533881564102507_1971429799922606995_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FBVoM6W0M2gQ7kNvgGMwXcj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3aMGm9RkOQxf1s3UzjbzTCAojm