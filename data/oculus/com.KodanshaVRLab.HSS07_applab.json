713_279198431500314_5126611026169557218_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ahAUfZOKouIQ7kNvgGV6OaK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDYAPJZMvp5aNCB9FdD3kXCJ23TVTCedkNeXqdW2TQ4EQ&oe=66D99D1A"}]}, "id": "685403750468645", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "606301871412569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569422_606301874745902_5969691398966985340_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yBtS2Ln7eNUQ7kNvgFahaWa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRNYylZWn7Z2aQqTvCh2h56TahKdRpFCe2efz-57LOXg&oe=66D99EB8"}, {"file_name": "2.png", "id": "323821480173065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974458_323821483506398_1753346169402755972_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=87O7uaHIAsIQ7kNvgHNkTt-&_nc_ht=scontent.oculuscdn.com&oh=00_AYArhXqkYiUCTuODIUmwfU11_woxhCNuE9RyxXMVWEHZWw&oe=66D98932"}, {"file_name": "4.png", "id": "311919491506832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250456_311919494840165_1584254742490173776_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZrQ05TvI2eMQ7kNvgFwcFLn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAk5xszN_kNZqZG7yySpbumZuVrxUMp5Qz-69rh7fvCRw&oe=66D99227"}, {"file_name": "6.png", "id": "824719212431609", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429290_824719215764942_9145987177559641066_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PeGy_9mb32MQ7kNvgF9HHR4&_nc_ht=scontent.oculuscdn.com&oh=00_AYC3S5LEbWHtOskzmswxQNX0gTE6Lk8D6yZ2omL7Tj-h8g&oe=66D9A13A"}, {"file_name": "7.png", "id": "234717609071774", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222943_234717612405107_9009905920403019402_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JjxtGuRkrAAQ7kNvgE3BzBW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUYNFV_7jCHgWUclCDHK5VLdh2oAn7kgbTn1yvY5Vl8Q&oe=66D9A2D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail\uff3fEN.png", "id": "1385848982285711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031529_1385848985619044_7932645804283440994_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vkyK9C_0708Q7kNvgEPRjGO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDR2bAE_0ZcwI7RKO-0BJ_Cmaz7ZasCwEx0P6cjrCbErQ&oe=66D99EFD"}, "display_name": "Hop Step Sing! By My Side", "keywords": [], "long_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\n\nJoin Shikiri for a romantic seaside date under the midsummer sun. Experience the joy of clasping your hands in hers, capturing picture-perfect moments, and crafting a mesmerizing VR music video that fans will find irresistible. Elevate your experience with a special bonus ending, unlocked by bringing joy to Shikiri, along with unique interactions that only VR can offer. Create unforgettable summer memories with Shikiri today!", "short_description": "The first solo VRMV by Shikiri Shiishiba.\nEmbark on an immersive journey in the first-ever solo VRMV featuring Shikiri Shiishiba. The theme this time around is \"Let\u2019s hold hands.\"\nUsing hand tracking, you can hold Shikiri's hand and take photos. The ending of the MV also changes depending on several interactive actions.\nThis heartwarming content is only possible in virtual reality!\nWhy not spend a memorable summer moment with Shikiri?\n"}, {"images": {"nodes": [{"file_name": "Logo TransparentJP 9000x1440px.png", "id": "7116072908484709", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_7116072915151375_8188742455952032553_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DIPQN0qMy1cQ7kNvgGatGBI&_nc_ht=scontent.oculuscdn.com&oh=00_AYC70Oalv5g5m5wXo1lEnesVm7jRJyCwcFwzI3a5obrYeA&oe=66D99BAB"}, {"file_name": "Hero 3000x900px.png", "id": "2125333631133687", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75617315_2125333