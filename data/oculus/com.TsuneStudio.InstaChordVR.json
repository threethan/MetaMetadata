NvgEzF9sn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_4MLugFbiR0aJWqoW6x0h9_3liai3gvyEqmSz-J10Gw&oe=673B22D2"}, {"file_name": "com.InstaChord.InstaChordVR-20220115-233158 (\u30ab\u30b9\u30bf\u30e0).png", "id": "1113721076112846", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422369_1113721079446179_5679668020330215549_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QURiVc2tHv0Q7kNvgFjQa6j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFdxC4xTMeULZ8y0PZACf9LYV1TI9JDXzyRCYa1-eRgg&oe=673B199E"}, {"file_name": "com.InstaChord.InstaChordVR-20220115-233138 (\u30ab\u30b9\u30bf\u30e0).png", "id": "276246021269365", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75305882_276246024602698_940034135407992554_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6z-Vu2rLEF8Q7kNvgFRCCJL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBi-rrmjJ7Bj63RMjEiOiiXj_XLRC4ybTwnHkpaezDWJA&oe=673B0FA6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30d7\u30ec\u30a4\u52d5\u753b\u30b5\u30e0\u30cd.png", "id": "1074551730010543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207241_1074551733343876_3758072879519379470_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DScZn5rwL_MQ7kNvgFnzn7C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACnZW6eFMm_-z_knkXQCIIUPsWkZqWYHOe3NqOARnGcw&oe=673B1E1D"}, "display_name": "InstaChordVR", "keywords": [], "long_description": "InstaChord VR is a music app.\nYou can play a song simply by selecting the key that matches the song and pressing the six buttons.\n\nFirst, search for the song you want to play.\nThen select the appropriate key for your music in the menu panel.\nFinally, touch the button with the numbers from 1 to 6 in front of you according to the number displayed on the web browser.\n\nThis app was developed under the supervision of Yuichi Nagata, the developer of \"Instachord\".", "short_description": "InstaChord VR is a music app.\nYou can play a song simply by selecting the key that matches the song and pressing the six buttons.\n\nFirst, search for the song you want to play.\nThen select the appropriate key for your music in the menu panel.\nFinally, touch the button with the numbers from 1 to 6 in front of you according to the number displayed on the web browser.\n\nThis app was developed under the supervision of Yuichi Nagata, the developer of \"Instachord\"."}, {"images": {"nodes": []}, "id": "227353216136428", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u30a4\u30f3\u30b9\u30bf\u30b3\u30fc\u30c9VR", "keywords": [], "long_description": "InstaChordVR\u306f\u97f3\u697d\u30a2\u30d7\u30ea\u3067\u3059\u3002\n\u697d\u66f2\u306b\u5408\u3063\u305f\u30ad\u30fc\u3092\u9078\u3073\u30016\u3064\u306e\u30dc\u30bf\u30f3\u3092\u62bc\u3059\u3060\u3051\u3067\u697d\u66f2\u3092\u6f14\u594f\u3067\u304d\u307e\u3059\u3002\nWeb\u30d6\u30e9\u30a6\u30b6\u3067\u697d\u8b5c\u3092\u78ba\u8a8d\u3057\u306a\u304c\u3089\u7c21\u5358\u306b\u30ae\u30bf\u30fc\u3084\u30d4\u30a2\u30ce\u306e\u97f3\u8272\u3092\u6f14\u594f\u3059\u308b\u4e8b\u304c\u3067\u304d\u307e\u3059\u3002\n\n\u307e\u305a\u3001\u6f14\u594f\u3057\u305f\u3044\u697d\u66f2\u3092\u691c\u7d22\u3057\u307e\u3059\u3002\n\u6b21\u306b\u3001\u30e1\u30cb\u30e5\u30fc\u30d1\u30cd\u30eb\u3067\u97f3\u697d\u306b\u9069\u3057\u305f\u30ad\u30fc\u3092\u9078\u629e\u3057\u307e\u3059\u3002 \u30ad\u30fc\u306fWeb\u30d6\u30e9\u30a6\u30b6\u306b\u8868\u793a\u3055\u308c\u3066\u3044\u307e\u3059\u3002\n\u6700\u5f8c\u306b\u3001Web\u30d6\u30e9\u30a6\u30b6\u306b\u8868\u793a\u3055\u308c\u3066\u3044\u308b\u756a\u53f7\u306b\u5f93\u3063\u3066\u76ee\u306e\u524d\u306e1~6\u307e\u3067\u306e\u6570\u5b57\u304c\u66f8\u304b\u308c\u305f\u30dc\u30bf\u30f3\u3092\u30bf\u30c3\u30c1\u3057\u307e\u3059\u3002\n\n\u672c\u30a2\u30d7\u30ea\u306f\u300c\u30a4\u30f3\u30b9\u30bf\u30b3\u30fc\u30c9\u300d\u306e\u958b\u767a\u8005\u3067\u3042\u308b\u6c38\u7530\u96c4\u4e00\u6c0f\u306e\