com/v/t64.5771-25/75356791_734477520765035_7817285667048774015_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xt82WU9SY_8Q7kNvgFnNjqg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBo6Dwqypzg0nXS_MeSN5y_w-rHwqhsP3OILkiNedQOTw&oe=670504B5"}, {"file_name": "Join.png", "id": "416966659369108", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542959_416966662702441_789052643303403720_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xG87JMzLLvsQ7kNvgHGHBLf&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC6X0A63lVnlWfD_1Zu2UGPPauKRL_2aGZYPL85gUEWQ&oe=670526E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "718683388821409", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86662329_718683395488075_416264793561488069_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VMPw0hbcc1wQ7kNvgFMHBlV&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcI7ehunCw80r8b1urcHo-EjeBoZy6WvozJ0FoZmcg8g&oe=67051B0D"}, "display_name": "Pub Darts", "keywords": [], "long_description": "Step up to the Oche with Pub Darts.  A detailed simulation of the game of darts that immerses you in the familiar environment of the Pub.  From the crackling fireplace to the hustle and bustle of the nearby bar you'll find yourself transported to your favorite local as you enjoy a few games of darts.\n\nPractice alone or invite a friend to join you for a match.  The dartboard and oche are precisely calibrated to BDO professional standards, and the automatically updating scoreboards will keep you well informed as to how your game is progressing.\n\nSupports both Left and Right handed playing, just grab the darts with the hand you do not intend to throw with, then take a dart into your other hand and throw.  Games are played from 501.", "short_description": "Fancy popping down the pub and playing a few games of darts?  Well now you can with On the Oche - Pub Darts!  Practice on your own, or invite a friend to join you for a match in this immersive recreation of this wonderful game.\n\nThe experience has been created to the exact specifications of BDO World Darts."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "323116656411049"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404385_774282233202633_4004269873526269044_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C50pcydd454Q7kNvgERW91U&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4odDEOOLHnylxOhIWaqU9YVVBd345Mowd9Y4vVOGzMA&oe=67050D6A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pub Darts", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1619199015, "lastRevision": {"nodes": [{"id": "199359671930444", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3621834484590501", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "482152046290064"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images"