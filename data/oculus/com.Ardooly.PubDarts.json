a&_nc_ohc=gIcvO22wp8YQ7kNvgH5jjVs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYAcg_JIkznlLLZFdRwYn6PVtrRV-7yag2CgpMyKZXLLJw&oe=66E2D69D"}, {"file_name": "Cover_Landscape.png", "id": "253569349827461", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974797_253569353160794_6058198078018813245_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCiC9Xr-qwMQ7kNvgGJbBSO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYB3otKMXa9k_gxHV7kasP92vc_qfMtqlLcw7qSqLlhzog&oe=66E2E7C6"}, {"file_name": "LogoT.png", "id": "139155111386722", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210399_139155114720055_500358394771758235_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vDD52VB8u8UQ7kNvgFlTT-h&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYBV-dYzEFZirrTxFY7mSRWGKdt3VqVcM2J-lePYdEkklw&oe=66E2C528"}]}, "id": "4350962978301166", "locale": "en_US", "screenshots": [{"file_name": "Pub.png", "id": "270236937870552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031395_270236941203885_8218912289734636564_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YzTz6ywPrKkQ7kNvgF36IUe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYDAPgNwOOqtMr6hY3npKEG--A-p2tKUD_OwmC3qU-Y20w&oe=66E2BBB2"}, {"file_name": "DartCabinet.png", "id": "764082710876929", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75314846_764082717543595_5827192745392422510_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LytFMBTJb3IQ7kNvgEBGz2c&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYC3Yvc9As_N5AfjIfP7YqDXYxhHwuJlQ2hxAy-sAaCkZQ&oe=66E2EC0E"}, {"file_name": "SelectDart.png", "id": "436170744482531", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251818_436170751149197_825983173380606270_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9PLK3QZtkzoQ7kNvgHtewUm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYA8diOLrgoOxjKW6MlAMf_FSFpVKlpMky4B9qUcqaFUtg&oe=66E2DB45"}, {"file_name": "Throw.png", "id": "734477514098369", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75356791_734477520765035_7817285667048774015_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TnPhbJy7noAQ7kNvgHIRtPi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYAto6iKlq792nUo9eyfhu0JoXs7A1lAfp7lrhjEYFZDcw&oe=66E2BDB5"}, {"file_name": "Join.png", "id": "416966659369108", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542959_416966662702441_789052643303403720_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d-ctQm2Gfl8Q7kNvgHs_xx7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYCdUfDs_Ma_aXfXmPJkafg7LbCvNogPjyKFDMOxRvVs5w&oe=66E2DFE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "718683388821409", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86662329_718683395488075_416264793561488069_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G0oAKxVINC4Q7kNvgGUcVAS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYCYgvEcgXKx_l0iiXPCoe0nOjws7XiVHHnI56J5yX0YTQ&oe=66E2D40D"}, "display_name": "Pub Darts", "keywords": [], "long_description": "Step up to the Oche with Pub Darts.  A detailed simulation of the game of darts that immerses you in the familiar environment of the Pub.  From the crackling fireplace to the hustle and bustle of the nearby bar you'll find yourself transported to your favorite local as you enjoy a few games of darts.\n\nPractice alone or invite a friend to join you for a match.  The dartboard and oche are precisely calibrated to BDO professional standards, and the automatically updating scoreboards will keep you well informed as to how your game is progressing.\n\nSupports both Left and Right handed playing, just grab the darts with the hand you do not intend to throw with, then take a dart into your other hand and throw.  Games are played from 501.", "short_description": "Fancy popping down the pub and playing a few games of darts?  Well now you can with On the Oche - Pub Darts!  Practice on your own, or invite a friend to join you for a match in this immersive recreation of this wonderful game.\n\nThe experience has been created to the exact specifications of BDO World Darts."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "323116656411049"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404385_774282233202633_4004269873526269044_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NvHm0kvfsjcQ7kNvgHjVJiN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoAxRw0-5srqQaL7kG6RArr&oh=00_AYBAGh01aEeXAnyR2EBUltu1hMsElNHA7Vljjg7PV7533g&oe=66E2C66A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pub Darts", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1619199015, "lastRevision": {"nodes": [{"id": "199359671930444", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3621834484590501", "is_fir