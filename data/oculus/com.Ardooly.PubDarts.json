a&_nc_ohc=NFoIq64UhgwQ7kNvgEGMSg_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMQ_dWuzv7C7VHZ15XwsVz&oh=00_AYALfKO6ygO3h9ymQRTPI4kCqh2TWL00ONOhcAeqAVxR4g&oe=66F55045"}, {"file_name": "Throw.png", "id": "734477514098369", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75356791_734477520765035_7817285667048774015_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zXHoAy8uvXsQ7kNvgEk00Nh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMQ_dWuzv7C7VHZ15XwsVz&oh=00_AYCaKVHdA5KYVIVfLQCNGKVmSiuODwAS-YW8KLt_jpt99w&oe=66F532B5"}, {"file_name": "Join.png", "id": "416966659369108", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542959_416966662702441_789052643303403720_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bJ6Zl8shW18Q7kNvgGS09SN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMQ_dWuzv7C7VHZ15XwsVz&oh=00_AYBRbfll72fjnDcGq3VBX31pY0KPWA2BuFB-9qcXESbqkw&oe=66F554E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "718683388821409", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86662329_718683395488075_416264793561488069_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WT4yB0SbH-YQ7kNvgF2yWda&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMQ_dWuzv7C7VHZ15XwsVz&oh=00_AYAeh0v7p1AYgejYfrH-67a1IYUeCy6CXVRwZFbv3UBrqA&oe=66F5490D"}, "display_name": "Pub Darts", "keywords": [], "long_description": "Step up to the Oche with Pub Darts.  A detailed simulation of the game of darts that immerses you in the familiar environment of the Pub.  From the crackling fireplace to the hustle and bustle of the nearby bar you'll find yourself transported to your favorite local as you enjoy a few games of darts.\n\nPractice alone or invite a friend to join you for a match.  The dartboard and oche are precisely calibrated to BDO professional standards, and the automatically updating scoreboards will keep you well informed as to how your game is progressing.\n\nSupports both Left and Right handed playing, just grab the darts with the hand you do not intend to throw with, then take a dart into your other hand and throw.  Games are played from 501.", "short_description": "Fancy popping down the pub and playing a few games of darts?  Well now you can with On the Oche - Pub Darts!  Practice on your own, or invite a friend to join you for a match in this immersive recreation of this wonderful game.\n\nThe experience has been created to the exact specifications of BDO World Darts."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "3008663349381811"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3924173311023282", "version": "1.1"}, "id": "465967684424134", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3621834484590501", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3924173311023282"}, "rel