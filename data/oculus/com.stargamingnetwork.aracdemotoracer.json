29_872104119875848_4970018889439117312_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nCJriJa64GAQ7kNvgEFRnoZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHDGAjCRGEi2jpt2DKWblN4&oh=00_AYBgsG0ugtz-9-45pJeLhccfcjkHxJH5EYxumjIer-VUxA&oe=66EEC076"}, {"file_name": "migrated_image.png", "id": "550452908909456", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572957_501710873650172_6271185579723980800_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oDMjjoHxIqAQ7kNvgFqBAsC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHDGAjCRGEi2jpt2DKWblN4&oh=00_AYDK9j66OLUwWzEAL8LhU76uRG-WiHRGFnSyF6fUcI7eyw&oe=66EEB52B"}, {"file_name": "migrated_image.png", "id": "507302683295536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572944_599628664203705_6528393424276553728_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nt3xTyCPiEQQ7kNvgGRYI_I&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHDGAjCRGEi2jpt2DKWblN4&oh=00_AYBCRlrO86tkQlWX46rYiDZXo_DqEsr-JEc85CVCou8veg&oe=66EEA9C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/oqHE3n", "id": "1511061745711431", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974447_1511061752378097_2771438612519059456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VULobSqrtsQQ7kNvgFktru3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHDGAjCRGEi2jpt2DKWblN4&oh=00_AYAGaL0aZ5NygSPhW77iQYHCRWIhbkTsNOgzWkdHXL5KEg&oe=66EE997E"}, "display_name": "Arcade Motobike Racer", "keywords": ["Motorcycle"], "long_description": "SGN brings the Arcade home with Arcade Series Motobike Racing.  Arcade style Motorbike racing on your VR Headset! \n\nTwo different modes to challenge you. Timed Mode has eight different locations to race. Make it to the end of each one with time remaining to unlock the next. Try to unlock all eight.\n\nArcade mode offers one endless track to compete for the highest school. Compete against your friends and the world with the highest score on the Leaderboard.\n\nArcade Series Motobike Racing has all the fun and excitement of an Arcade game on your console. Stack your quarters relive the classic game play.", "short_description": "SGN brings the Arcade home with Arcade Series Motobike Racing.  Arcade style Motorbike racing on your VR Headset! \n\nArcade Series Motobike Racing has all the fun and excitement of an Arcade game on your console. Stack your quarters relive the classic game play."}]}, "developer_name": "Star Gaming Network", "developer_privacy_policy_url": "https://sgngames.com/privacypolicy.php", "developer_terms_of_service_url": "https://sgngames.com/termsofservice.php", "publisher_name": "Star Gaming Network", "support_website_url": "http://sgngames.com/contactus.php", "website_url": "http://sgngames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "737606360547229"}, "review_messages": ["", "Changes are needed to the assets/metadata submitted.    \n      \n- Oculus Store cover art assets should not be \"self-badged\" Please remove the logo in the lower right corner of the cover art assets.  \n  \nPlease reference the information and templates found in:  \nocul.us/storeassetguidelines  \n\nThank you,  \n  \nThe Oculus Store Team", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196222_977764855954353_8919766197474426880_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=97Rnxa-4AYcQ7kNvgHjhKYI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHDGAjCRGEi2jpt2DKWblN4&oh=00_AYAUlXpigkQBUu6dZbFAywhZHqZxWDy