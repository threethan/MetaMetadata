5304", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036652_1016817310048637_6416072530128232494_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3f4nPV0vKv4Q7kNvgEO-yKY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNOtV38-c9GtNAwB-Jr-qJo3QJunfUGeg9lAOxZIMYPg&oe=66EAA2E6"}, {"file_name": "1440 (2).png", "id": "845937250420635", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375772_845937253753968_1683154871544542258_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A7mBu2XNgOMQ7kNvgGiHOXJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgjODRiK24Aa9K5kgkuE47Q8-hLO_ju1StpHujCm2M6g&oe=66EAA755"}, {"file_name": "2560x1440.png", "id": "764175079014926", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_764175082348259_5808662586191243543_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_xiIATHvZOMQ7kNvgGNJqbk&_nc_ht=scontent.oculuscdn.com&oh=00_AYD7po-6XzG1bsHu0Kbzr2K9h4pI4aB4iH1clEobs-xrPg&oe=66EAAF8E"}]}, "id": "390289470271306", "locale": "en_US", "screenshots": [{"file_name": "e.png", "id": "1133565321053240", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_1133565324386573_6238669882895587451_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IezkMa1JSDEQ7kNvgF9jdb-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCx9ObEeXTrj1cXwSSSn0jiH1xkcNs3NVC8a9SSpsQjzA&oe=66EAD481"}, {"file_name": "e.png", "id": "846797830212584", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_846797833545917_8011280191931882972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AZBt0bYJ66MQ7kNvgEcP9qg&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2-ngFpODnCRsY7QA2gBDFz6c7YSXZyjQcDIBRLvnvbA&oe=66EAA9EE"}, {"file_name": "e.png", "id": "1176367396967866", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984475_1176367416967864_6498282404026519499_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_9qR0OBT7NkQ7kNvgElchfg&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0czzlhunyvVH1ewM71cRHS5ANN5UhesnvzP7Qqzir4g&oe=66EACE85"}, {"file_name": "e.png", "id": "987591143138336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974757_987591146471669_5909785087520772796_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G1wAi_bAn7AQ7kNvgFAEtVr&_nc_ht=scontent.oculuscdn.com&oh=00_AYCimsr1r5akU82nUBgOUU_JK5-MvUhvsfFgo2WvvTdUtA&oe=66EAB4C1"}, {"file_name": "e.png", "id": "455430310805737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982557_455430317472403_7018293787988506357_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEB6xtcVopEQ7kNvgEusQif&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTzqeAn4uOI3lC469ALm-Irz4Z6O81kxBnhEaoL7xpiQ&oe=66EABE18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "e.png", "id": "2474202839635484", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566690_2474202842968817_8266260323957973746_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5Xds3Yx4dYQ7kNvgF81AI2&_nc_ht=scontent.oculuscdn.com&oh=00_AYB63Jnanukjy3IEIK7fSeY2b2fjCYvqB-boCRUjfDmx2A&oe=66EACB1B"}, "display_name": "Little_Tag", "keywords": [], "long_description": "\nDive into the heart-pounding excitement of *Little Tag*, the ultimate virtual reality experience that revolutionizes how you move in a game! In this fast-paced, immersive adventure, your arms are your ticket to speed and agility. Swing them to dash across expansive playgrounds, leap over obstacles, and outmaneuver opponents in an electrifying game of tag like no other.\n\n*Little Tag* isn't just about tagging and running; it's about mastering the art of movement. Feel the rush as you propel yourself forward, navigating through intricate environments designed to test your reflexes and strategy. Each arena is a vibrant, dynamic world filled with hidden shortcuts, thrilling jumps, and countless opportunities for epic tag moments.\n\nPlay solo to sharpen your skills or join friends in exhilarating multiplayer modes where every match is a test of wits and agility. With stunning graphics and responsive controls, *Little Tag* offers an unparalleled VR experience that keeps you on your toes, literally.\n\nPerfect for players of all ages, *Little Tag* combines the joy of classic playground games with cutting-edge VR technology. Get ready for a workout that doesn't feel like one, as you immerse yourself in a game that's as entertaining as it is physically engaging. \n\nAre you fast enough to be the ultimate tag champion? There's only one way to find out. Step into the world of *Little Tag* and let the games begin!", "short_description": "Step into the exhilarating world of Little Tag, the VR game that redefines movement! Swing your arms to dash, leap, and evade in this high-energy, immersive playground. Whether you're chasing friends or escaping foes, Little Tag promises endless fun and a full-body workout. Ready to tag in?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/littletagvr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Little_VR", "support_website_url": null, "website_url": "https://sites.google.com/view/littletagvr/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7612889512054318"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "364622756663211"}]}, "baseline_offer": null, "is_approved":