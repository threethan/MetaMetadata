gpmV41ubF9LOtoIZgrVIUewQjOKmuBpjRdg&oe=6720B76E"}, {"file_name": "e.png", "id": "1176367396967866", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984475_1176367416967864_6498282404026519499_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ngsVSXSxsfQQ7kNvgGX-SbC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAv1eep5st3OUoBhsdHxTDQ-CvIW_Jw011uPH4Zot9FoA&oe=6720DC05"}, {"file_name": "e.png", "id": "987591143138336", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974757_987591146471669_5909785087520772796_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GEeruaeKghkQ7kNvgEpanCn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAvAtyQPzWnc6_PaOlqmDy1rjsa7N5VeaR4NmcVuxedQ&oe=6720C241"}, {"file_name": "e.png", "id": "455430310805737", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982557_455430317472403_7018293787988506357_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=arPKcnq30LcQ7kNvgHVDj6m&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYLs0K-HAILlLLsgJZo2g1UzTc9LXL9cUIjo_3KGEYtw&oe=6720CB98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "e.png", "id": "2474202839635484", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566690_2474202842968817_8266260323957973746_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ey640ooV-0Q7kNvgEEZrSV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ9VsUHp9RLoTzLp-omeyqT2y14sfHkAG587hyWqVYzw&oe=6720D89B"}, "display_name": "Little_Tag", "keywords": [], "long_description": "\nDive into the heart-pounding excitement of *Little Tag*, the ultimate virtual reality experience that revolutionizes how you move in a game! In this fast-paced, immersive adventure, your arms are your ticket to speed and agility. Swing them to dash across expansive playgrounds, leap over obstacles, and outmaneuver opponents in an electrifying game of tag like no other.\n\n*Little Tag* isn't just about tagging and running; it's about mastering the art of movement. Feel the rush as you propel yourself forward, navigating through intricate environments designed to test your reflexes and strategy. Each arena is a vibrant, dynamic world filled with hidden shortcuts, thrilling jumps, and countless opportunities for epic tag moments.\n\nPlay solo to sharpen your skills or join friends in exhilarating multiplayer modes where every match is a test of wits and agility. With stunning graphics and responsive controls, *Little Tag* offers an unparalleled VR experience that keeps you on your toes, literally.\n\nPerfect for players of all ages, *Little Tag* combines the joy of classic playground games with cutting-edge VR technology. Get ready for a workout that doesn't feel like one, as you immerse yourself in a game that's as entertaining as it is physically engaging. \n\nAre you fast enough to be the ultimate tag champion? There's only one way to find out. Step into the world of *Little Tag* and let the games begin!", "short_description": "Step into the exhilarating world of Little Tag, the VR game that redefines movement! Swing your arms to dash, leap, and evade in this high-energy, immersive playground. Whether you're chasing friends or escaping foes, Little Tag promises endless fun and a full-body workout. Ready to tag in?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/littletagvr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Little_VR", "support_website_url": null, "website_url": "https://sites.google.com/view/littletagvr/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_ap