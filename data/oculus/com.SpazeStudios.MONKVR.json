2", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974814_830079985715585_7113404783654444010_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pyd9LqHJ5xgQ7kNvgFWeu-O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5WdwtL1g8a6exOa-SE8aKEVYqJrwcntegIxty0zZkRQ&oe=672762B3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MONK", "keywords": [], "long_description": "Become a Monk! Monk is a game where you are a monkey of no kind, with the freedom of exploring maps like the jungle, the beach, or the deep shining caves, or you can go to the shop and customize your monk with various amounts of cosmetics! In monk you can play with friends or other people around the world! If you have no friends too play with you always have your pets, pets in monk can be obtained in the shop. Monk with banana has great power!\n\nSpazeWorlds LLC note:\n\nWe hope everyone has a great experience!  Thanks too all the players for the support!", "short_description": "Become a Monk! Monk is a game where you are a monkey of no kind, with various maps to explore and various games to play. Long Description for more detail."}]}, "developer_name": "SpazeWorlds LLC", "developer_privacy_policy_url": "https://sites.google.com/view/monk-vr/home/information", "developer_terms_of_service_url": null, "publisher_name": "SpazeWorlds LLC", "support_website_url": null, "website_url": "https://sites.google.com/view/monk-vr/home/information", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_