XsCvbjotrch90X8r01Z0uzPLyEqv0tLbQIZBd9jWWpg&oe=670BC101"}, {"file_name": "Screenshot4.png.png", "id": "1055239098975559", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75339313_1055239102308892_2656465650491674012_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XPcJt8LvKjQQ7kNvgErboZV&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAxGRT0SClLv0O7OrLHAcgZ8PB-FZaeowWqc8FZzKGW_Q&oe=670BA409"}, {"file_name": "Screenshot5.png", "id": "1500973077326186", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974678_1500973080659519_7936052026139130471_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0vGYj2WOEX4Q7kNvgFfd0LW&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCeFTRLA6X5vj1VfkSE1I1JGg3Xrm_CH0pW897amsfJYw&oe=670BC5A9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "robmembor", "keywords": [], "long_description": "Navigate the labyrinthine corridors of an elderly woman's mind, whose memories have been broken by Alzheimer's. As the chosen mind-repairer, you will solve puzzles, guided by a witty robot, to piece together the tapestry of her life. Merge technology with empathy to revive beautiful memories from oblivion.\n\nPuzzle-Solving\nExplore various environments, each packed with unique challenges to solve. As you successfully untangle these puzzles, you'll gather precious memories that belong to an elderly woman. Engage your inner Sherlock Holmes, crack the puzzles, and share in the joy of rebuilding lost memories!\n\nUnleash the Potential of Brand New Powers!\nLevel up your puzzle-solving game: unleash unique powers to ghost your hands, clone objects and steal colors! \n", "short_description": "Unlock Memories, Solve Puzzles, Befriend Robots \u2013 Become a Mind-Repairer Now!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://palindromevr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Palindrome VR ", "support_website_url": null, "website_url": "https://palindromevr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "671829694919996"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1905452933220862"}, {"status": "PUBLISHED", "id": "248292324843339"}]}, "baseline_offer": {"id": "1905452933220862"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1714608900, "status": "PUBLISHED", "id": "1905452933220862"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7176536732462608", "version": "0.12"}, "id": "1968667173502857", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6587774418005512", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7176536732462608"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1968667173502857"}]}, "change_log": "Specific styles for every room\nMore interactable assets \nBetter art and lighting \nAble to see the sky through walls ", "created_date": 1706271153, "id": "7176536732462608", "version": "0.12", "version_code": 12, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_b