.5771-25/75210392_858563095631231_7526927227332047459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JANCUxPJEzUQ7kNvgHliVfk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXRzJYrWOkjhQlw5UwWrbm1&oh=00_AYC-mqugC3fFs-EqiAljyEfwIgMFsa3fRo64wD9bOwHQ3A&oe=66F40601"}, {"file_name": "Screenshot4.png.png", "id": "1055239098975559", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75339313_1055239102308892_2656465650491674012_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MY-fwoeLJ6EQ7kNvgHOt61X&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXRzJYrWOkjhQlw5UwWrbm1&oh=00_AYCZWW0QkGhrNyArpbDsai3irkdfB91XH_hK2zPTyPjdOg&oe=66F3E909"}, {"file_name": "Screenshot5.png", "id": "1500973077326186", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974678_1500973080659519_7936052026139130471_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bR5qZ2xE-e0Q7kNvgEdatCK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXRzJYrWOkjhQlw5UwWrbm1&oh=00_AYB7Mo1d2sXS0vMn61kg0Xe-GPamrfjhhOlMln_9H1XdrA&oe=66F40AA9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "robmembor", "keywords": [], "long_description": "Navigate the labyrinthine corridors of an elderly woman's mind, whose memories have been broken by Alzheimer's. As the chosen mind-repairer, you will solve puzzles, guided by a witty robot, to piece together the tapestry of her life. Merge technology with empathy to revive beautiful memories from oblivion.\n\nPuzzle-Solving\nExplore various environments, each packed with unique challenges to solve. As you successfully untangle these puzzles, you'll gather precious memories that belong to an elderly woman. Engage your inner Sherlock Holmes, crack the puzzles, and share in the joy of rebuilding lost memories!\n\nUnleash the Potential of Brand New Powers!\nLevel up your puzzle-solving game: unleash unique powers to ghost your hands, clone objects and steal colors! \n", "short_description": "Unlock Memories, Solve Puzzles, Befriend Robots \u2013 Become a Mind-Repairer Now!\n"}]}, "deve