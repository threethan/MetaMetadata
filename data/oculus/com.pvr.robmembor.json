_sid=6e7a0a&_nc_ohc=7gvWZpPhkioQ7kNvgFs6uf-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCW0w1Ehvg861YESR55wSELJEUwVe3b4lp9STMBgkUVmg&oe=6720D901"}, {"file_name": "Screenshot4.png.png", "id": "1055239098975559", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75339313_1055239102308892_2656465650491674012_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2EUhVRQDD1EQ7kNvgGfC1c1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpUbWfRFSgr60Wei9PplBfFPkIZyILGPsPyZE2dI4V5A&oe=6720BC09"}, {"file_name": "Screenshot5.png", "id": "1500973077326186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974678_1500973080659519_7936052026139130471_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xmwgoplf384Q7kNvgETOd-s&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGk1NZd7n3THkcQDUozofGvXP6BzL0WNEZsyaJwkGsBw&oe=6720DDA9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "robmembor", "keywords": [], "long_description": "Navigate the labyrinthine corridors of an elderly woman's mind, whose memories have been broken by Alzheimer's. As the chosen mind-repairer, you will solve puzzles, guided by a witty robot, to piece together the tapestry of her life. Merge technology with empathy to revive beautiful memories from oblivion.\n\nPuzzle-Solving\nExplore various environments, each packed with unique challenges to solve. As you successfully untangle these puzzles, you'll gather precious memories that belong to an elderly woman. Engage your inner Sherlock Holmes, crack the puzzles, and share in the joy of rebuilding lost memories!\n\nUnleash the Potential of Brand New Powers!\nLevel up your puzzle-solving game: unleash unique powers to ghost your hands, clone objects and steal colors! \n", "short_description": "Unlock Memories, Solve Puzzles, Befriend Robots \u2013 Become a Mind-Repairer Now!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://palindromevr.com/privacy-policy/", "developer_terms_of_se