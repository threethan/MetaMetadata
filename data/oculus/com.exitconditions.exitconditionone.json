7202828240377072_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cGQJEdsXheMQ7kNvgH1RVo2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYC4Rrg8UJR4yrl3ykwtV532RUpog_piPvieVb5jnQc2lw&oe=66E96069"}, {"file_name": "2560x1440virtual shot.png", "id": "841026373516293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_841026376849626_3803472195590454326_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-VgV3CylIcQ7kNvgHFBwrI&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYDApboTD-3bsD3xuzRIzg4TQmuW02ChugEDuRtRUpN0Lw&oe=66E9664F"}, {"file_name": "2560x1440 fireworks screenshot.png", "id": "275556064370648", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001654_275556067703981_4735310609106135896_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uraWHp7tF7AQ7kNvgEG5b6U&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYD4p9zDtrFk0gc0bHmtEUefkACJMP74DlXxoh3cKsJUzg&oe=66E9610B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 thumbnail.png", "id": "2605676156395631", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974608_2605676159728964_9206111280510424647_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QU5kNgcxdbkQ7kNvgGoyq0x&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYBgh4ICx4kbGS-UvXaleyQc4m7NmkOVV4k02NvOA-0R0A&oe=66E95C95"}, "display_name": "Exit Condition One", "keywords": [], "long_description": "This is a classic escape room game built exclusively for VR using roomscale to give you the experience of really being there. Walking is fully supported. Your hands and all objects act just like in the real world, no \"ghost objects.\" The puzzles are all tightly interwoven into the room and feel more like problems that need to be solved rather than puzzles that need to be figured out. There's about an hour of playtime.\n\nCool Features\n- Roomscale walking, locomotion, teleporting, stationary, crouch, stand\n- In-game visualization of the guardian to align physical and virtual spaces\n- Drone with unique 3D controller\n- Full use of physics\n- VR within VR\n- Fireworks display for finishing\n\nThere is a discord here: https://discord.gg/2NfBumhKQD .", "short_description": "Roomscale Escape Room"}]}, "developer_name": null, "developer_privacy_policy_url": "https://exitconditions.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Damon Poole", "support_website_url": null, "website_url": "https://exitconditions.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3391716047619440"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "546449526492636"}]}, "baseline_offer": {"id": "546449526492636"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1626983280, "status": "PUBLISHED", "id": "546449526492636"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6894765647276614", "version": ".999.26"}, "id": "309616357302408", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3909525809133961", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6894765647276614"}, "release_status": "RELEASED"}, "binary_release_c