oTD-3bsD3xuzRIzg4TQmuW02ChugEDuRtRUpN0Lw&oe=66E9664F"}, {"file_name": "2560x1440 fireworks screenshot.png", "id": "275556064370648", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001654_275556067703981_4735310609106135896_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uraWHp7tF7AQ7kNvgEG5b6U&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYD4p9zDtrFk0gc0bHmtEUefkACJMP74DlXxoh3cKsJUzg&oe=66E9610B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 thumbnail.png", "id": "2605676156395631", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974608_2605676159728964_9206111280510424647_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QU5kNgcxdbkQ7kNvgGoyq0x&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYBgh4ICx4kbGS-UvXaleyQc4m7NmkOVV4k02NvOA-0R0A&oe=66E95C95"}, "display_name": "Exit Condition One Escape Room Demo", "keywords": ["escape"], "long_description": "The full game, in early release, is available here: https://www.oculus.com/experiences/quest/4463936340397965/\n\nThis is a classic escape room game built exclusively for VR using roomscale to give you the experience of really being there. Walking is fully supported. Your hands and all objects act just like in the real world, no \"ghost objects.\" The puzzles are all tightly interwoven into the room and feel more like problems that need to be solved rather than puzzles that need to be figured out. This is the demo of the full game (coming soon). There's about an hour of playtime.\n\nCool Features\n- Roomscale ( walking, locomotion, teleporting, stationary, sitting all supported)\n- In-game visualization of the guardian to align physical and virtual spaces\n- Drone with unique 3D controller\n- Full use of physics\n- VR within VR\n- Fireworks display for finishing\n- Dynamic background music\n- In-game hint system\n- Distance grab assist\n\nThere is a discord here: https://discord.gg/2NfBumhKQD .", "short_description": "Roomscale Escape Room"}]}, "developer_name": null, "developer_privacy_policy_url": "https://exitconditions.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Damon Poole", "support_website_url": null, "website_url": "https://exitconditions.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7999316636821504"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974655_1229156364249992_344560652354746971_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XbNebgq0gUAQ7kNvgHd2pSp&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABF_J43gNSO8Sqn8bU9CZ2Z&oh=00_AYBYPvjDWQuXOuto24H_YthiWzxnowDnbz4HpkHm-9ZDoQ&oe=66E96445"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Exit Condition One Escape Room Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1626983299, "lastRevision": {"nodes": [{"id": "144113707696132", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3909525809133961", "is_first_party": false, "