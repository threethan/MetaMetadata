3-1.oculuscdn.com&oh=00_AYD_Gec4u1RiPZQ_rTcgGTmhbY-ojsZ8mRo4kbTU37aU_g&oe=673728E9"}, {"file_name": "2560x1440virtual shot.png", "id": "841026373516293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974517_841026376849626_3803472195590454326_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hFZCrs3JxAsQ7kNvgGmvxUW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCw9YSy3PLWK0GkfKj1b7ljZUORe0hoo0yZYBhwBf5qKA&oe=67372ECF"}, {"file_name": "2560x1440 fireworks screenshot.png", "id": "275556064370648", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001654_275556067703981_4735310609106135896_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DsZ050y-0LQQ7kNvgEwWiXS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsiusXBSVvrFstZIquUs6PCtH4uPjEtq6ynemihyYVSQ&oe=6737298B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 thumbnail.png", "id": "2605676156395631", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974608_2605676159728964_9206111280510424647_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nfk_ZqfSsu0Q7kNvgGyw0AX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQvnACm-WsapADq9yOQGLXii_wGrbndqJPigkKZtSp2Q&oe=67372515"}, "display_name": "Exit Condition One", "keywords": [], "long_description": "This is a classic escape room game built exclusively for VR using roomscale to give you the experience of really being there. Walking is fully supported. Your hands and all objects act just like in the real world, no \"ghost objects.\" The puzzles are all tightly interwoven into the room and feel more like problems that need to be solved rather than puzzles that need to be figured out. There's about an hour of playtime.\n\nCool Features\n- Roomscale walking, locomotion, teleporting, stationary, crouch, stand\n- In-game visualization of the guardian to align physical and virtual spaces\n- Drone with unique 3D controller\n- Full use of physics\n- VR within VR\n- Fireworks display for finishing\n\nThere is a discord here: https://discord.gg/2NfBumhKQD .", "short_description": "Roomscale Escape Room"}]}, "developer_name": null, "developer_privacy_policy_url": "https://exitconditions.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Damon Poole", "support_website_url": null, "website_url": "https://exitconditions.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "331529188132278"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3391716047619440"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "546449526492636"}]}, "baseline_offer": {"id": "546449526492636"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1626983280, "status": "PUBLISHED", "id": "546449526492636"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6894765647276614", "version": ".999.26"}, "id": "309616357302408", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3909525809133961", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6894765647276614"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel