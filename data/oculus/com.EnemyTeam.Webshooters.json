ile_name": "Webshooters Branding_Meta_Screenshot 002.png", "id": "3550545008602948", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031319_3550545015269614_2856941081991784961_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NBX3gHnOLKAQ7kNvgFpT97n&_nc_ht=scontent.oculuscdn.com&_nc_gid=AICqoRTcBR1Ki_aYM6_mPBk&oh=00_AYCNNx4DjM_HsAGazph99G8brbcJKTAmSFmDuKxFoVcpTQ&oe=66E81CE1"}, {"file_name": "Webshooters Branding_Meta_Screenshot 001.png", "id": "1280667939235659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1280667942568992_5502317974827324042_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NzIbcN1v1bIQ7kNvgGwFMaj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AICqoRTcBR1Ki_aYM6_mPBk&oh=00_AYCsVQiXbisGcQW_winWd9bn69FhrXSBRAK30XsczUX17Q&oe=66E814F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Webshooters Branding_Meta_Trailer Cover Image.png", "id": "315626984174012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_315626987507345_4967092722600282350_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RFvQL2Zj480Q7kNvgGnGH-a&_nc_ht=scontent.oculuscdn.com&_nc_gid=AICqoRTcBR1Ki_aYM6_mPBk&oh=00_AYDzKQiVnxdP0Ykh0_n6JuWlP0nLsazYMTnAmtMnejaWjQ&oe=66E82DF0"}, "display_name": "Webshooters", "keywords": [], "long_description": "Webshooters is a VR multiplayer game in which players swing around a massive metropolis, blasting each other with bullets and missles to become the champion. Play Free-For-All battles against other Webshooters, or try to take down thieving criminals flying around in helicopters! \n \nPROJECT STATUS\nOur game is currently in a prototype stage, despite that it's a blast and shaping up to be one of the most exciting VR mutliplayer games on the market. We'll be releasing a demo soon, so wishlist this page, so you don't miss it!", "short_description": "It started with a question, \"what if Spiderman had a gun?\". Now, Webshooters is an explosive multiplayer shooter that's pushing the limits of VR combat."}]