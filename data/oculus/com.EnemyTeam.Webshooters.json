ajeDg4cRMdK-1&oh=00_AYAh-yxqie5lB1nE2HBLOYkAagkThlWUc2TKvxhok7ULYg&oe=66E957C2"}, {"file_name": "Webshooters Meta Screenshot 05.png", "id": "1433101280923263", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974888_1433101284256596_6109247127387750469_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DdM9J8akhxgQ7kNvgFc6obU&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApXw0slkYtajeDg4cRMdK-1&oh=00_AYDlGSpuQR5W8ltMNuDi1-rjaQ2qYq9ioeItfoo7PtlqCA&oe=66E95A69"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Webshooters Branding_Meta_Trailer Cover Image.png", "id": "315626984174012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_315626987507345_4967092722600282350_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RFvQL2Zj480Q7kNvgECmO_G&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApXw0slkYtajeDg4cRMdK-1&oh=00_AYAGcBVeySvANe_h1wIy9_CzeTq9saIltDJnpgeuzDF2sA&oe=66E97F70"}, "display_name": "Webshooters", "keywords": [], "long_description": "Webshooters is a superhero themed battler which can be played in singleplayer or multiplayer, it's up to you!\n\nStep into the shoes of a hero and protect the city from a dangerous and powerful criminal group, or take care of yourself and work for the villains in their relentless crime spree. Swing between the skyscrapers, fly fast jets and powerful helicopters and race through the streets in on or offline game modes.", "short_description": "Midway City is in a chaos! A new type of criminal needs a new style of justice... Battle for the streets as a hero or villain, on or offline."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.enemyteam.games/webshooters-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Enemy Team", "support_website_url": null, "website_url": "https://www.enemyteam.games/webshooters", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topic