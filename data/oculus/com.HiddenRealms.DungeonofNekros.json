iOMJO-v_kV04slHYDxONPh0A&oe=66E6D77C"}, {"file_name": "UpscaledDungeonOfNekros6.png", "id": "1895786643957754", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_1895786647291087_2489373001132714866_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QB6mga2bXAgQ7kNvgHuWz6i&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am_ZXsyfAioVakW6jJEjrZZ&oh=00_AYDIP2ZgjddUtF9T3MBTlv640JrIYlWchdtJEKJIOtltQw&oe=66E6AB91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HeroHiddenRealmsTitleCoverArt.png", "id": "3763628287026264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974558_3763628290359597_6941369554397762485_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OxgUDdTfV7EQ7kNvgH_j-Sd&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am_ZXsyfAioVakW6jJEjrZZ&oh=00_AYB3kZOR7VPYG6kyNtJ234LryKLxsU1bDLtZcsG8fNN5tQ&oe=66E6DE8A"}, "display_name": "Dungeon of Nekros", "keywords": [], "long_description": "This is a one level demo for the upcoming full game. \n\nYou're alive again...but only for an hour! Temporarily resurrected from the dead, you find yourself in a musty old crypt, buried deep in the bowels of a dark & mysterious dungeon. Your only chance at becoming permanently alive again is to embark on a quest to retrieve the Necronomicon - a terrible & forbidden book desired by the one who resurrected you - Nekros the Necromancer. Discover treasure, fight monsters, & solve the mysteries of the Dungeon of Nekros in this amazing RPG by Hidden Realms.", "short_description": "You're alive again...but only for an hour! Temporarily resurrected from the dead, you find yourself in a musty old crypt, buried deep in the bowels of a dark & mysterious dungeon. Your only chance at becoming permanently alive again is to embark on a quest to retrieve the Necronomicon - a terrible & forbidden book desired by the one who resurrected you - Nekros the Necromancer. Discover treasure, fight monsters, & solve the mysteries of the Dungeon of Nekros in this amazing RPG by Hidden Realms.