Ius5LF0Cwh3WpvCtSQ&oe=66F6A97C"}, {"file_name": "UpscaledDungeonOfNekros6.png", "id": "1895786643957754", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_1895786647291087_2489373001132714866_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zZn2qwq9e0Q7kNvgGqMd1M&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsZ2EH1GCXOk9BNO11Wjd9d&oh=00_AYD4N8XjJYad45RDgubluYr3XK75k1ivdXW2DWx_BB6-HQ&oe=66F6B5D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HeroHiddenRealmsTitleCoverArt.png", "id": "3763628287026264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974558_3763628290359597_6941369554397762485_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MwHD4LfoVT4Q7kNvgFPWiYq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsZ2EH1GCXOk9BNO11Wjd9d&oh=00_AYBsohiVmsopYJ8Tu3NCl00OdRWt7Oj62XQxBtdqxBaGvw&oe=66F6B08A"}, "display_name": "Dungeon of Nekros", "keywords": [], "long_description": "This is a one level demo for the upcoming full game. \n\nYou're alive again...but only for an hour! Temporarily resurrected from the dead, you find yourself in a musty old crypt, buried deep in the bowels of a dark & mysterious dungeon. Your only chance at becoming permanently alive again is to embark on a quest to retrieve the Necronomicon - a terrible & forbidden book desired by the one who resurrected you - Nekros the Necromancer. Discover treasure, fight monsters, & solve the mysteries of the Dungeon of Nekros in this amazing RPG by Hidden Realms.", "short_description": "You're alive again...but only for an hour! Temporarily resurrected from the dead, you find yourself in a musty old crypt, buried deep in the bowels of a dark & mysterious dungeon. Your only chance at becoming permanently alive again is to embark on a quest to retrieve the Necronomicon - a terrible & forbidden book desired by the one who resurrected you - Nekros the Necromancer. Discover treasure, fight monsters, & solve the mysteries of the Dungeon of Nekros in this amazing RPG by Hidden Realms."}]}, 