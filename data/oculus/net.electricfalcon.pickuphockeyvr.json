65921427805_7380152483512844288_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2nsM19vHG94Q7kNvgENVdw0&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYACWjnckm0m2f3rQ0XlrdQH-wH1ut4wgs-Dn8RFv8kwOQ&oe=67010C5D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/DgL0O0", "id": "468620766999877", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974826_468620770333210_1992676753021075456_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gasis8fv5LEQ7kNvgHjk5MV&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBRRxXPeKetdLkw7hOgAlT-2yzHff0Y1ubIll0QJrL1Og&oe=6701127F"}, "display_name": "Pick-up League Hockey", "keywords": ["hockey", "sports", "coop", "multiplayer"], "long_description": "Pick-up League Hockey is a full-featured multiplayer hockey game using realistic physics and motion controls to create an immersive game that puts you right in the rink with up to 5 other friends! Created by a hockey enthusiast, PULH aims to be the most customizable multiplayer hockey game in VR with plans for player-selectable jerseys, stick skins, and more!\n\nCross-play between Rift and Go is possible!\nCross-region play is possible!\n\nDedicated server executables will be available for private clubs to host practices and tournament games. Please contact us for more info!\n\nPlease send feedback to contact@electricfalcon.net", "short_description": "Pick-up League Hockey is a full-featured multiplayer hockey game using realistic physics and motion controls to create an immersive game that puts you right in the rink with up to 5 other friends!"}]}, "developer_name": "Electric Falcon LLC", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Electric Falcon LLC", "support_website_url": null, "website_url": "http://www.electricfalcon.net/pickuphockey", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUI