izon-2560x1440.png", "id": "1596491024465918", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_1596491027799251_4652346712674817985_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=meBOxfCSWC0Q7kNvgH29tJu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXt7eNvFjGV4P-YgJUgyarHnPek9Llz8Ju9NlOcRe1iw&oe=67485B43"}, {"file_name": "cutie9-2560x1440.png", "id": "490153783378120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_490153786711453_7954615981815564690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t15MbnYY6r0Q7kNvgGlmKgU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiAfzzsi6GP52WUpMB5SR7MKm3jJyTc-0LYdffYPZYIw&oe=674874E1"}, {"file_name": "cola2-2560x1440.png", "id": "464324029534757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86684226_464324032868090_1299260451384064964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eX4Qzt_3SNwQ7kNvgHU4-g6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8Yr-ArB-scg3sgHvxoMvB0iDCR1P_44z-1vKbLvQUAA&oe=674860F7"}, {"file_name": "am_i_sigma-2560x1440 (1).png", "id": "825459519184960", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334058_825459525851626_8623430795344094344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D9erAylOH3kQ7kNvgHE1aT_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-dBcCThdRGs83FWnDn6B_oTldKIBLFROkfR9jgBmtJQ&oe=67483DD3"}, {"file_name": "swim-2560x1440.png", "id": "902061711729324", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031471_902061715062657_9218621828586492619_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IDU6c3gcx14Q7kNvgEOtAiH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVvJHbG-3ZLjRMzXKS9RNq3ODWncjnjh-G8fzMOu2Wsw&oe=6748621A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CHIMPANCOVER2.png", "id": "482571531497236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289915_482571534830569_3558417383934308094_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i3T2Cmbj-70Q7kNvgH4Yinf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvvL-Q0rpqtL7_UB_N5-VEMfbxT701aJetp2_q3Vg88A&oe=67486BF5"}, "display_name": "CHIMPAN'", "keywords": [], "long_description": "Introducing.. CHIMPAN'!\n\n\n\nCHIMPAN follows nimble monkeys exploring vast surroundings such as the Isles, a Shop, a s\u0336\u035b\u0323p\u0338\u0300\u0322o\u0338\u0309\u032eo\u0337\u0301\u034dk\u0337\u030e\u032cy\u0336\u0302\u0353 \u0337\u034b\u0339l\u0337\u031a\u0328a\u0334\u0346\u0349b\u0335\u030c\u0321o\u0334\u0352\u0328r\u0335\u0340\u0319a\u0337\u0352\u0339t\u0338\u0309\u0354o\u0334\u0351\u0353r\u0334\u030c\u033by\u0334\u035d\u0347  , a Player VS Player, and even more to come! CHIMPAN is not just another game. It\u2019s an adventure that you can enjoy alone or with friends. With its mix of action and story, CHIMPAN is perfect for anyone who loves Gorilla Tag and wants more adventure.\n\nWhat is there restricting you from being a CHIMPAN? Join CHIMPAN today!\n\n\n\n\n", "short_description": "This game follows acrobatic CHIMPANs embarking through the isles, buying items, and even exploring laboratories! What is there not to like of a CHIMPAN?"}]}, "developer_name": "DSVR LLC", "developer_privacy_policy_url": "https://sites.google.com/view/leapingforlife/home", "developer_terms_of_service_url": null, "publisher_name": "Solstice", "support_website_url": null, "website_url": "https://sites.google.com/view/leapingforlife/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_