izon-2560x1440.png", "id": "1596491024465918", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_1596491027799251_4652346712674817985_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CfJfrTpnJNwQ7kNvgE9gI3P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvKCMbbWYaWrVHmLgpQnzd1aP_82yRrFgPOboNQhjiFg&oe=676167C3"}, {"file_name": "cutie9-2560x1440.png", "id": "490153783378120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_490153786711453_7954615981815564690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jp588y2kyXEQ7kNvgHTUaGH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCj9UULGdbviuzEnFVkrzMMxpChiAILuXOifshHdqG3tQ&oe=67618161"}, {"file_name": "cola2-2560x1440.png", "id": "464324029534757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86684226_464324032868090_1299260451384064964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KpeFAk63Ms8Q7kNvgHkzSQw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuM7bRVHqLEqPxe0KLTXmlNxlbNviNiMn2HTw0QPIKHg&oe=67616D77"}, {"file_name": "am_i_sigma-2560x1440 (1).png", "id": "825459519184960", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334058_825459525851626_8623430795344094344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0XiiHTTitqAQ7kNvgHeMa5-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7wDLUzHGn41lH_hh0KjQCcPYuHJ7EPb0bVtA6dukk_Q&oe=67614A53"}, {"file_name": "swim-2560x1440.png", "id": "902061711729324", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031471_902061715062657_9218621828586492619_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2oYl4DlmkjcQ7kNvgEAW7jD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmrzWDE7pa1S6zXA1pnG7QeHbJpuOFzP3ifYrCjtlQZA&oe=67616E9A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CHIMPANCOVER2.png", "id": "482571531497236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289915_482571534830569_3558417383934308094_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lpx0ik_Inc4Q7kNvgEvis95&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4intmjGd17JNeF38GLSEZywX-e9Qigkebl_CgQzSlng&oe=67617875"}, "display_name": "CHIMPAN'", "keywords": [], "long_description": "Introducing.. CHIMPAN'!\n\n\n\nCHIMPAN follows nimble monkeys exploring vast surroundings such as the Isles, a Shop, a s\u0336\u035b\u0323p\u0338\u0300\u0322o\u0338\u0309\u032eo\u0337\u0301\u034dk\u0337\u030e\u032cy\u0336\u0302\u0353 \u0337\u034b\u0339l\u0337\u031a\u0328a\u0334\u0346\u0349b\u0335\u030c\u0321o\u0334\u0352\u0328r\u0335\u0340\u0319a\u0337\u0352\u0339t\u0338\u0309\u0354o\u0334\u0351\u0353r\u0334\u030c\u033by\u0334\u035d\u0347  , a Player VS Player, and even more to come! CHIMPAN is not just another game. It\u2019s an adventure that you can enjoy alone or with friends. With its mix of action and story, CHIMPAN is perfect for anyone who loves Gorilla Tag and wants more adventure.\n\nWhat is there restricting you from being a CHIMPAN? Join CHIMPAN today!\n\n\n\n\n", "short_description": "This game follows acrobatic CHIMPANs embarking through the isles, buying items, and even exploring laboratories! What is there not to like of a CHIMPAN?"}]}, "developer_name": "DSVR LLC", "developer_privacy_policy_url": "https://sites.google.com/view/leapingforlife/home", "developer_terms_of_service_url": null, "publisher_name": "Solstice", "support_website_url": null, "website_url": "https://sites.google.com/view/leapingforlife/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_i