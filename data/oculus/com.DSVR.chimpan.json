izon-2560x1440.png", "id": "1596491024465918", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_1596491027799251_4652346712674817985_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Aj-77Tuy1poQ7kNvgHY_Tj8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfhdtBVK4uaKopSuxhQB4BWRMmf6olFXXpAgetkH1XYw&oe=67655C43"}, {"file_name": "cutie9-2560x1440.png", "id": "490153783378120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_490153786711453_7954615981815564690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vIGA5xIWeW4Q7kNvgGPsSgQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKQsw3VRctm94lAUtuNFvHTduiLtVVZ8xk3S_1WrMZew&oe=676575E1"}, {"file_name": "cola2-2560x1440.png", "id": "464324029534757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86684226_464324032868090_1299260451384064964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Er8I6E9AwVIQ7kNvgHS95Vt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrI04Iy8y3mWh15U2yDyLu1xvAkthHI0tEQt1uxYH1_w&oe=676561F7"}, {"file_name": "am_i_sigma-2560x1440 (1).png", "id": "825459519184960", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334058_825459525851626_8623430795344094344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ktXQI7HWjvIQ7kNvgGjtUJO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJvJKy67YJ39MRE6VY1kOFQu2EZVTJD-0CsGaHI0XXHQ&oe=67653ED3"}, {"file_name": "swim-2560x1440.png", "id": "902061711729324", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031471_902061715062657_9218621828586492619_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wp3K4F5Q6kwQ7kNvgHRpTuL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnLxMvbtFlSDVhti6BQXZX5j3Q8xMoGfiYhCDCyWj2KA&oe=6765631A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CHIMPANCOVER2.png", "id": "482571531497236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289915_482571534830569_3558417383934308094_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qaa6l1MaZBEQ7kNvgG-t9La&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyh_XY-Xez7Xr9irOx3sDmHYqXKWn4jNt1kNDxOMHy7A&oe=67656CF5"}, "display_name": "CHIMPAN'", "keywords": [], "long_description": "Introducing.. CHIMPAN'!\n\n\n\nCHIMPAN follows nimble monkeys exploring vast surroundings such as the Isles, a Shop, a s\u0336\u035b\u0323p\u0338\u0300\u0322o\u0338\u0309\u032eo\u0337\u0301\u034dk\u0337\u030e\u032cy\u0336\u0302\u0353 \u0337\u034b\u0339l\u0337\u031a\u0328a\u0334\u0346\u0349b\u0335\u030c\u0321o\u0334\u0352\u0328r\u0335\u0340\u0319a\u0337\u0352\u0339t\u0338\u0309\u0354o\u0334\u0351\u0353r\u0334\u030c\u033by\u0334\u035d\u0347  , a Player VS Player, and even more to come! CHIMPAN is not just another game. It\u2019s an adventure that you can enjoy alone or with friends. With its mix of action and story, CHIMPAN is perfect for anyone who loves Gorilla Tag and wants more adventure.\n\nWhat is there restricting you from being a CHIMPAN? Join CHIMPAN today!\n\n\n\n\n", "short_description": "This game follows acrobatic CHIMPANs embarking through the isles, buying items, and even exploring laboratories! What is there not to like of a CHIMPAN?"}]}, "developer_name": "DSVR LLC", "developer_privacy_policy_url": "https://sites.google.com/view/leapingforlife/home", "developer_terms_of_service_url": null, "publisher_name": "Solstice", "support_website_url": null, "website_url": "https://sites.google.com/view/leapingforlife/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_i