izon-2560x1440.png", "id": "1596491024465918", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982685_1596491027799251_4652346712674817985_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Su7b7ZvRB30Q7kNvgEFxQtI&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYB8kDOJMrlRNkvXwJ11DIV0PBgO9iXahG8IExFnEndNzQ&oe=67582D43"}, {"file_name": "cutie9-2560x1440.png", "id": "490153783378120", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39036632_490153786711453_7954615981815564690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aGiouZO6tk8Q7kNvgFJphhb&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAY3_ZUhEJi5cEyYUKYp7bD9fdiHBhi6buz88VN0Yzr_w&oe=675846E1"}, {"file_name": "cola2-2560x1440.png", "id": "464324029534757", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/86684226_464324032868090_1299260451384064964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kYwDpEDPzasQ7kNvgHUBYLp&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDkBQAPz1pov8XCC28ypOxPt60rnl4MDKhGomGO9ST0qQ&oe=675832F7"}, {"file_name": "am_i_sigma-2560x1440 (1).png", "id": "825459519184960", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75334058_825459525851626_8623430795344094344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6HeoGiR-nokQ7kNvgEQx-R3&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBHHdFS77GCVtx11XbnZpzesf0atBPcUGA7whqEY2gjMg&oe=67580FD3"}, {"file_name": "swim-2560x1440.png", "id": "902061711729324", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031471_902061715062657_9218621828586492619_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y7xvCrm770UQ7kNvgGjc6a-&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCYEtTQPCUR5yFiQ0t7tybYSxqQ8Jl6Vee2MTEEzvhDvQ&oe=6758341A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CHIMPANCOVER2.png", "id": "482571531497236", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75289915_482571534830569_3558417383934308094_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G82bqhtz52cQ7kNvgFmEO71&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCgfGuecZzek8mz5G-Xp_UIjeARGCZk0W_3iSOnMnNVGQ&oe=67583DF5"}, "display_name": "CHIMPAN'", "keywords": [], "long_description": "Introducing.. CHIMPAN'!\n\n\n\nCHIMPAN follows nimble monkeys exploring vast surroundings such as the Isles, a Shop, a s\u0336\u035b\u0323p\u0338\u0300\u0322o\u0338\u0309\u032eo\u0337\u0301\u034dk\u0337\u030e\u032cy\u0336\u0302\u0353 \u0337\u034b\u0339l\u0337\u031a\u0328a\u0334\u0346\u0349b\u0335\u030c\u0321o\u0334\u0352\u0328r\u0335\u0340\u0319a\u0337\u0352\u0339t\u0338\u0309\u0354o\u0334\u0351\u0353r\u0334\u030c\u033by\u0334\u035d\u0347  , a Player VS Player, and even more to come! CHIMPAN is not just another game. It\u2019s an adventure that you can enjoy alone or with friends. With its mix of action and story, CHIMPAN is perfect for anyone who loves Gorilla Tag and wants more adventure.\n\nWhat is there restricting you from being a CHIMPAN? Join CHIMPAN today!\n\n\n\n\n", "short_description": "This game follows acrobatic CHIMPANs embarking through the isles, buying items, and even exploring laboratories! What is there not to like of a CHIMPAN?"}]}, "developer_name": "DSVR LLC", "developer_privacy_policy_url": "https://sites.google.com/view/leapingforlife/home", "developer_terms_of_service_url": null, "publisher_name": "Solstice", "support_website_url": null, "website_url": "https://sites.google.com/view/leapingforlife/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_