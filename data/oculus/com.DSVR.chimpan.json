86711453_7954615981815564690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RcovgV5MfJ8Q7kNvgHnO93X&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-WAmYlsaIt7UFjZDM-dSvMUjhwh0WUxnC0Cyn9e6Xug&oe=66CAFE21"}, {"file_name": "cola2-2560x1440.png", "id": "464324029534757", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86684226_464324032868090_1299260451384064964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KeBP2V65ZzsQ7kNvgGoGDLW&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-8vfatIgxK1A7hO504oQ1dV71pog9HeO4rrc-Mz3-pg&oe=66CB2277"}, {"file_name": "am_i_sigma-2560x1440 (1).png", "id": "825459519184960", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334058_825459525851626_8623430795344094344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DD2DZ6ud9BgQ7kNvgGgvVPX&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_0xZJ_GC3xVN9UaQPSwn0I4ueYlwuPNrFePOYup6U7A&oe=66CAFF53"}, {"file_name": "swim-2560x1440.png", "id": "902061711729324", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031471_902061715062657_9218621828586492619_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qJDEiAZ_hqIQ7kNvgFx_WUx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgVNcC8kAxEsdN8e0IIWCEhnBCwbcjujCXo7is3pt25g&oe=66CB239A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "chimpancover-2560x1440.png", "id": "3215758995221322", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974648_3215758998554655_3195878851293128268_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uTR5fjPQymcQ7kNvgE1VPyA&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-iqz27Wg3y5UVAlCS3ivxgscojQKlntjpps3bzXM43Q&oe=66CB1C5B"}, "display_name": "CHIMPAN'", "keywords": [], "long_description": "Introducing.. CHIMPAN'!\n\n\n\nCHIMPAN follows nimble monkeys exploring vast surroundings such as the Isles, a Shop, a s\u0336\u035b\u0323p\u0338\u0300\u0322o\u0338\u0309\u032eo\u0337\u0301\u034dk\u0337\u030e\u032cy\u0336\u0302\u0353 \u0337\u034b\u0339l\u0337\u031a\u0328a\u0334\u0346\u0349b\u0335\u030c\u0321o\u0334\u0352\u0328r\u0335\u0340\u0319a\u0337\u0352\u0339t\u0338\u0309\u0354o\u0334\u0351\u0353r\u0334\u030c\u033by\u0334\u035d\u0347  , a Player VS Player, and even more to come! CHIMPAN is not just another game. It\u2019s an adventure that you can enjoy alone or with friends. With its mix of action and story, CHIMPAN is perfect for anyone who loves Gorilla Tag and wants more adventure.\n\nWhat is there restricting you from being a CHIMPAN? Join CHIMPAN today!\n\n\n\n\n", "short_description": "This game follows acrobatic CHIMPANs embarking through the isles, buying items, and even exploring laboratories! What is there not to like of a CHIMPAN?"}]}, "developer_name": "DSVR LLC", "developer_privacy_policy_url": "https://sites.google.com/view/leapingforlife/home", "developer_terms_of_service_url": null, "publisher_name": "Solstice", "support_website_url": null, "website_url": "https://sites.google.com/view/leapingforlife/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8557658114278887"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1138607867338903"}]}, "baseline_offer": {"id": "1138607867338903"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722533179, "status": "PUBLISHED", "id": "1138607867338903"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary