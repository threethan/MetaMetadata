i": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974632_958500381511297_5538403479995970043_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4lRxtRqSbokQ7kNvgHTUCde&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7P_ZvMjeQAEb9HLTYBCKOeu1qNKORnfhP2XbbsGZ7NQ&oe=67669E3B"}, {"file_name": "BowlerProfile_In_Ground.png", "id": "684396066209758", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974570_684396069543091_7910715207076112134_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZmnFNdOBFiYQ7kNvgHKwMfZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhweAfBDrsgbYxGq5B1mhMt78Mm6adCQt2ZhNMBNkqyg&oe=6766AD20"}, {"file_name": "On_Hit_With_Bat_And_Fielding_In_Progress.png", "id": "541739497565882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974808_541739500899215_6587236729130995403_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=29LPUv_565UQ7kNvgHTi5QR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB88s2L7B49EpczLsFNDSKyDypWPmiQ6pPqwIkRjHeMJg&oe=67669C21"}, {"file_name": "On_Hitting_Four.png", "id": "3217682331845030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974459_3217682335178363_237033845748482834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pQ9rRiOkHQ8Q7kNvgGGG_VS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAk6ZCxwrlKGVwZmk7_3TAHSDhjfePZua4XmdLhX5XIAA&oe=6766B212"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Pic.png", "id": "287605153391285", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_287605156724618_5466474971579159763_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4NfJ1wP-GkQ7kNvgHmgBJP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxr4DjJCb0GsW5teDdX-T7X0AMgo9nvgf01LZ2GRS2uQ&oe=67669F9B"}, "display_name": "iB Cricket", "keywords": ["Cricket", "VRCricket", "iBCricket", "BestCricket", "Sport"], "long_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. \n\nTill date, over 60 million balls have been played by people from 40+ countries, including both cricketing & non-cricketing nations. 98% of them said that iB Cricket is amazing! iB Cricket has also received appreciation from 100+ world-class Cricketers.\n- Numerous Bowling Options: Right arm, left arm; Fast, medium pace, off spin, leg spin & more.\n- Intelligent fielding based on built-in AI\n- Multiple Stadiums\n- PvP:  Bowl to your friends & challenge them in a one-on-one match. \n- Leagues & Tournaments\n- Multiple Cricket Formats: 20, 50, unlimited overs \n- Coaching Module \n\nHone your skills, compete in global tournaments & become a vSport star.", "short_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. Thousands of people from all over the world including non-cricketing nations have enjoyed playing iB Cricket. Hone your skills, compete in global tournaments & become a vSport star."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ib.cricket/privacy-policy/", "developer_terms_of_service_url": "https://ib.cricket/EULA/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/iBCricket_Support", "website_url": "https://ib.cricket/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "5511384875557439"}}]}, "scheduled_offers": {"count": 25, "nodes": [{"status": "PUBLISHED", "id": "1184438745957705"}, {"status": "PUBLISHED", "id": "1206232440521635"}, {"status": "CANCELLED", "id": "3777840535869350"}, {"status": "PUBLISHED", "id": "470107835689122"}, {"status": "PUBLISHED", "id": "2022747094737234"}, {"status": "PENDING", "id": "812886280331150"}, {"status": "PENDING", "id": "316562727646724"}, {"status": "PENDING", "id": "9643425555699991"}, {"status": "PENDING", "id": "1164793740824378"}, {"status": "PENDING", "id": "889126112431342"}, {"status": "PUBLISHED", "id": "688688623011432"}, {"status": "PENDING", "id": "1426912481387925"}, {"status": "PUBLISHED", "id": "645664093767248"}, {"status": "PUBLISHED", "id": "802458077472127"}, {"status": "PENDING", "id": "581692683913814"}, {"status": "PUBLISHED", "id": "700617708246649"}, {"status": "PENDING", "id": "1117636242553563"}, {"status": "PENDING", "id": "1062701298038514"}, {"status": "PENDING", "id": "538497688391373"}, {"status": "PUBLISHED", "id": "613849070459380"}, {"status": "PUBLISHED", "id": "805238327829558"}, {"status": "PUBLISHED", "id": "742688097115441"}, {"status": "PENDING", "id": "1419430435461587"}, {"status": "PUBLISHED", "id": "519610810337507"}, {"status": "PENDING", "id": "1378989063021188"}]}, "baseline_offer": {"id": "742688097115441"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1184438745957705"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9402459903120937", "version": "7.2.0"}, "id": "1160049024747028", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5437449896288644", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9402459903120937"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1160049024747028"}]}, "change_log": "We are excited to announce the release of our new update - v7.2.0 \ud83d\ude80\n\n**Gameplay Improvements:**\n- Bat Physics: Adjusted bat powers based on user feedback for a balanced gameplay experience \ud83c\udfcf\n- Updated ball physics during bowling for more realistic ball speeds, both upon pitching and during the flight\n- Field positions in fieldsets are now more adaptable to batsman scoring regions\n- Bowlers now adjust the bowling guard(around the wicket) if too many runs are scored from over the wicket \ud83c\udfc3\n- Stadiums: The radius of all stadiums is now displayed in QuickStart and the Shop \ud83c\udfdf\ufe0f \n- Optimization: Extensive effort has been made to optimize battery performance, achieving a significant improvement. Players can now easily enjoy a full 50-over match without needing to recharge their headset, ensuring a seamless gaming experience\ud83d\udd0b\n- Wide Ball Detection: Enhanced accuracy in the wide ball detection algorithm\n\n**Bug Fixes**\n- Balls bowled outside the leg stump or too close to the wide line on the off stump have been significantly reduced\n- Spinners bowling lengths in Practice mode have been corrected.\n- Addressed excessive byes in Unlimited Overs mode\n- Fixed bowler hand release poses for a couple of special ball deliveries\n- Resolved an issue where matches could not be resumed after Save & Exit in specific scenarios\n- Corrected target-setting issues when clicking \"Play Again\" in Team Chasing Challenge \ud83c\udfaf\n- Fixed a network error affecting a few users with specific ISPs. Changes have been implemented to ensure such users can continue playing smoothly using their regular internet connection \ud83d\udedc\n\n**New Assets**\n- Stadiums: Two new stadiums have been added to the Shop \ud83c\udfdf\ufe0f\n- Dressing Room: Updated with a Holiday theme \ud83c\udf84\ud83c\udf85", "created_date": 1734361826, "id": "9402459903120937", "version": "7.2.0", "version_code": 221, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9402456129787981"}, "asset_files": {"count": 93}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5437449896288644", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9402459903120937"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734357706, "id": "9402140226486238", "version": "7.2.0", "version_code": 220, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9402137833153144"}, "asset_files": {"count": 93}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5437449896288644", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9402459903120937"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1160049024747028"}]}, "change_log": null, "created_date": 1730884791, "id": "9158615487505381", "version": "7.1.1", "version_code": 219, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9158611684172428"}, "asset_files": {"count": 89}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5437449896288644", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9402459903120937"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1160049024747028"}]}, "change_log": "We are excited to announce the **release of our new update** alongside with the start of a **new tournament season**.\nUsers in Early Access have shared positive feedback about this update, appreciating the enhanced realism of the gameplay.\n \n**Enhancements**\n\n**Realistic Bat Physics**\n- Updated bat powers to enhance the realism of bat physics\n- Ball movement when it takes an edge off the bat feels more natural\n\n**Bowling Enhancements**\n- Limited-over formats - Bowling strategies at higher difficulty levels now adapt based on user gameplay & More line and length variations from bowlers\n- In Unlimited over formats, bowling strategies including bowling spells and special deliveries, are updated according to user gameplay\n- Revised bowling regions for left-handed batsmen\n\n**Field Placement & Fielding Enhancements**\n- When the ball edges off the bat, the keeper and slips have an increased chance of taking a catch\n- Field placement adjusts based on your hitting regions as the match progresses and persists throughout the match\n- Updated ball deflection after misfields\n\n**Ball Physics**\n- Enhanced friction dynamics between the ball and grass\n- Increased ball bounce after pitching on all types of pitches\n- Reduced ball velocity upon pitching, with variations depending on the pitch type\n\n**Bug Fixes**\n- Reduced the gap between some of the commentary sentences\n- Resolved several disconnection issues in Co-Op to enhance multiplayer stability and performance\n\nThank you all for your continued support\n\n**To adapt to these enhancements, we recommend playing for 1-2 hours to adapt before jumping into competitive modes.**", "created_date": 1730702355, "id": "9144401815593415", "version": "7.1.0", "version_code": 218, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "9144399895593607"}, "asset_files": {"count": 89}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5437449896288644", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9402459903120937"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725449773, "id": "8673052632728338", "version": "7.0.2", "version_code": 217, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8673050679395200"}, "asset_files": {"count": 89}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}