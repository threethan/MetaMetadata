00_AYCjAIguniXqnz_J5yRTlJLQ8Fq64OKKZovxWi7MoGNhCg&oe=6766A111"}, {"file_name": "CampaignMode.png", "id": "621412579727793", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572758_621412583061126_6110164533952850496_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ilQ0lWk0o94Q7kNvgHh_0SP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBipSBgDi5YatncEQjNIuD4oW-xaFr2VZkGriAlXpj9wQ&oe=6766B85F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "iBC_Oculus Assets_Cover Landscape - 2560x1440_v3.png", "id": "1198775474454980", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610708_1198775477788313_4016531523126774863_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFNS_1y2YHsQ7kNvgG4lTrx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiHEMlxR86TDYAsuxrLMZfoznTqMCp_Z5khaOl9VcA0A&oe=67669263"}, "display_name": "iB Cricket", "keywords": ["Cricket", "VRCricket", "iBCricket", "VRBatting", "MetaverseCricket"], "long_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. \n\nTill date, over 500+ million balls have been played by people from 40+ countries, including both cricketing & non-cricketing nations. 98% of them said that iB Cricket is amazing! iB Cricket has also received appreciation from 100+ world-class Cricketers.\n- Numerous Bowling Options: Right arm, left arm; Fast, medium pace, off spin, leg spin & more.\n- Intelligent fielding based on built-in AI\n- Multiple Stadiums\n- PvP:  Bowl to your friends & challenge them in a one-on-one match. \n- Leagues & Tournaments\n- Multiple Cricket Formats: 20, 50, unlimited overs \n- Coaching Module \n- VR Bowling\n- Campaign Mode\n- CO-OP\n- Practice Nets\n- Fun MR Mode Games.\n\nHone your skills, compete in global tournaments & become a vSport star.", "short_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. Thousands of people from all over the world including non-cricketing nations have enjoyed playing iB Cricket. Hone your skills, compete in global tournaments & become a vSport star."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ib.cricket/game-privacy-policy/", "developer_terms_of_service_url": "https://ib.cricket/EULA/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/iBCricket_Support", "website_url": "https://ib.cricket/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8436453513054919"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75250460_450178807995120_1294512474726945696_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CenZ5uv2QxYQ7kNvgHqSCqq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0ZFBQpU49FIljJEvvpFtsAIv7wx6rdSVvCeP2GD_zTA&oe=6766AFE4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_nam