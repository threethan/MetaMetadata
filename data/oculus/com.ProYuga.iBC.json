i": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974632_958500381511297_5538403479995970043_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5YvyVIN1hA8Q7kNvgEmr8nq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIivWLqSCu-Vk8aLnsUnU63bKxTS_0QzbzzCHDpsUaUA&oe=6763FB3B"}, {"file_name": "BowlerProfile_In_Ground.png", "id": "684396066209758", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974570_684396069543091_7910715207076112134_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zrrAzTTzMIgQ7kNvgHGtP5i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhEV-LGVuhc7KZwkqFLdp1hZbAFrjjaPg1s-v5AU2gng&oe=67640A20"}, {"file_name": "On_Hit_With_Bat_And_Fielding_In_Progress.png", "id": "541739497565882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974808_541739500899215_6587236729130995403_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oUWMbsfhLogQ7kNvgE_uFYa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_vt6JZS3YafZwIjbfGpFSFBMqAePtyJgvEUAtkLvr6A&oe=6763F921"}, {"file_name": "On_Hitting_Four.png", "id": "3217682331845030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974459_3217682335178363_237033845748482834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pQ9rRiOkHQ8Q7kNvgF_OHbP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzuzBsGw8XInlLeH04sh6JODT5J1CKu6DI3idXycqUMw&oe=67640F12"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Pic.png", "id": "287605153391285", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_287605156724618_5466474971579159763_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WVff9F2WAaQQ7kNvgHx0ZNZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnAoGFpM7iwC_W58e9wajBubvjQrOeN8e1qwupcG-i2w&oe=6763FC9B"}, "display_name": "iB Cricket", "keywords": ["Cricket", "VRCricket", "iBCricket", "BestCricket", "Sport"], "long_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. \n\nTill date, over 60 million balls have been played by people from 40+ countries, including both cricketing & non-cricketing nations. 98% of them said that iB Cricket is amazing! iB Cricket has also received appreciation from 100+ world-class Cricketers.\n- Numerous Bowling Options: Right arm, left arm; Fast, medium pace, off spin, leg spin & more.\n- Intelligent fielding based on built-in AI\n- Multiple Stadiums\n- PvP:  Bowl to your friends & challenge them in a one-on-one match. \n- Leagues & Tournaments\n- Multiple Cricket Formats: 20, 50, unlimited overs \n- Coaching Module \n\nHone your skills, compete in global tournaments & become a vSport star.", "short_description": "A sport with 2.5 billion fans across the world is now in VR as iB Cricket (vSport). Step into immersive world-class stadiums with thousands cheering for you and hit the ball out of the park. Our realistic physics makes it intuitive to learn the sport within 10 mins. Thousands of people from all over the world including non-cricketing nations have enjoyed playing iB Cricket. Hone your skills, compete in global tournaments & become a vSport star."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ib.cricket/privacy-policy/", "developer_terms_of_service_url": "https://ib.cricket/EULA/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/iBCricket_Support", "website_url": "https://ib.cricket/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": null, "internet_