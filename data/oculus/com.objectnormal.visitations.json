state of the brain.\n\nUsers may customize experiences to their needs, which may include:\n\n\u00b7 Inner Journeys\n\u00b7 Relaxation/Focus\n\u00b7 Mood Modification\n\u00b7 Mini-Vacations\n\u00b7 Mindfulness\n\u00b7 Distraction Therapy\n\u00b7 Infusion Therapy\n\u00b7 Mental Reset\n\u00b7 Meditation Assistance", "short_description": "Visitations are experiments in therapeutic aesthetics which draw on lessons from neuroscience and psychology to induce relaxed and entranced mental states in the user."}]}, "developer_name": "Object Normal", "developer_privacy_policy_url": "http://visitationsvr.com/privacy.html", "developer_terms_of_service_url": "http://visitationsvr.com/eula.html", "publisher_name": "Light Clinic", "support_website_url": "http://visitationsvr.com/", "website_url": "http://visitationsvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2786641828305725"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4301426283217362", "version": "1"}, "id": "723145874949195", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4023694967