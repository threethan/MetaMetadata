332452961383780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236_332452964717113_3675266534000873610_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHogq7O2lfUQ7kNvgFw6vJP&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq6nfiUkvOj2XvR78gJiFf5&oh=00_AYBhVMmZpa2oJW_i_KBA614Kk3qF4ALPvIktoPTxLK-nQA&oe=66F68215"}, {"file_name": "screen_02.png", "id": "1045756535949780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485580_1045756539283113_4578636049130303649_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5yWn3QEPyDMQ7kNvgGASCem&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq6nfiUkvOj2XvR78gJiFf5&oh=00_AYBmO8M5ZgciU4RwBzD_HLc8GRtWrWGWB8aL0dAFgya-xA&oe=66F6853A"}, {"file_name": "screen_05.png", "id": "433227684778412", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254870_433227688111745_8945372473996700173_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cva318zlLvIQ7kNvgESVC6C&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq6nfiUkvOj2XvR78gJiFf5&oh=00_AYAlTBdFhWg1sY5x4CJlIjnsJVRLMjLYnEMCGuQf0Co2RQ&oe=66F6A330"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "729611147925759", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_729611151259092_1383265694339009972_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lHWyebJP0noQ7kNvgFAKLzg&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq6nfiUkvOj2XvR78gJiFf5&oh=00_AYAYWA3zqdwVBKO46kSn9AO7hycReuiVTc7shkkKTMmdcg&oe=66F69D1B"}, "display_name": "Visitations", "keywords": [], "long_description": "Aesthetic experiences are brought into the therapeutic realm using lessons from neuroscience and psychology. Visitations makes use of techniques such as binaural beats, subtle strobing, form constants, and includes a guided meditation, a dream induction, and a soundtrack developed by a healer with experience leading traditionally inspired ceremonies. Visitations creates a set & setting which allow users to turn inwards and explore their own stories and mental states.", "short_d