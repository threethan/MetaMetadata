332452961383780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236_332452964717113_3675266534000873610_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHogq7O2lfUQ7kNvgF0JB98&_nc_ht=scontent.oculuscdn.com&_nc_gid=AczjOM0A9l0nN4GIfqbCPIG&oh=00_AYB7xjpY9gHjNJXju67y1b7UWxSUG4yH-xCA61ZVyfBgOQ&oe=66F3DF15"}, {"file_name": "screen_02.png", "id": "1045756535949780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485580_1045756539283113_4578636049130303649_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5yWn3QEPyDMQ7kNvgH1hNDu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AczjOM0A9l0nN4GIfqbCPIG&oh=00_AYA9wq3pg1RWgi1C8F6Z0b2lv9c6wgjRwP3g0HC71HvMrQ&oe=66F3E23A"}, {"file_name": "screen_05.png", "id": "433227684778412", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254870_433227688111745_8945372473996700173_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=95qfO4FkDkUQ7kNvgG8Lv17&_nc_ht=scontent.oculuscdn.com&_nc_gid=AczjOM0A9l0nN4GIfqbCPIG&oh=00_AYCWMKc5IITxrwhdgusum6G-V8WZ41Dl5m0z_2jhq-W7Nw&oe=66F40030"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "729611147925759", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_729611151259092_1383265694339009972_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJ6o_TM2GgwQ7kNvgGPTsaD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AczjOM0A9l0nN4GIfqbCPIG&oh=00_AYAEhdY6oxOD7NAhVnROEywk0d7U2MRnAMprkTql6Fn12Q&oe=66F3FA1B"}, "display_name": "Visitations", "keywords": [], "long_description": "Aesthetic experiences are brought into the therapeutic realm using lessons from neuroscience and psychology. Visitations makes use of techniques such as binaural beats, subtle strobing, form constants, and includes a guided meditation, a dream induction, and a soundtrack developed by a healer with experience leading traditionally inspired ceremonies. Visitations creates a set & setting which allow users to turn inwards and explore their own stories and mental states.", "short_d