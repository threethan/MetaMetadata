3623123653905_1785160587917777408_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ksazEq9u3PsQ7kNvgHhuABQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaQE_L6E-gX83oW8XfYM77l&oh=00_AYBn_MPxZOy546180OShUWh0N3sT8TQ1fgry-fTpdXwbhA&oe=66F2B50F"}, {"file_name": "download (26).png", "id": "345687459964102", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003269_345687463297435_752144126112800743_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7YNkW-5xZbAQ7kNvgGD02Cv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaQE_L6E-gX83oW8XfYM77l&oh=00_AYAAf-GCa-wtHoneQtu3EYGcUCp4ghJw-bqV6ct5mmBC0g&oe=66F2B76E"}, {"file_name": "download (25).png", "id": "950220632166700", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_950220635500033_7792352926231781392_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7J5LeQZi49cQ7kNvgGYmv4p&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaQE_L6E-gX83oW8XfYM77l&oh=00_AYA2Jh0jiZ9gTH6DU3sk-z3BvmYjj-pKtJ_bTQTE5L5DxQ&oe=66F2BB6D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnail.png", "id": "779719429480823", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_779719432814156_6029904558920342406_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Wx_MV1RsPMQ7kNvgGm5UEv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaQE_L6E-gX83oW8XfYM77l&oh=00_AYC1mXDuYyDRyacBRtKjeCKULHWMLYYKOhYkbgpLTYMtAQ&oe=66F2BE85"}, "display_name": "Visitations", "keywords": ["meditation", "therapeutic", "mindful"], "long_description": "Ancient shamans intuitively understood the power of the mind and their performances would conjure  the body\u2019s innate ability to heal. Modern medicine accomplishes a similar performance with lab coats and pills. We are beginning to understand that technology can be employed to similar ends.\n\nVisitations makes use of techniques such as binaural beats, strobing, form constants, and includes body scan meditation, dream induction, and music developed by artists skilled in the healing arts.\n\nThese techniques have been shown to directly alter the physiological state of the brain.\n\nUsers may customize experiences to their needs, which may include:\n\n\u00b7 Inner Journeys\n\u00b7 Relaxation/Focus\n\u00b7 Mood Modification\n\u00b7 Mini-Vacations\n\u00b7 Mindfulness\n\u00b7 Distraction Therapy\n\u00b7 Infusion Therapy\n\u00b7 Mental Reset\n\u00b7 Meditation Assistance", "short_description": "Visitations are experiments in therapeutic aesthetics which draw on lessons from neuroscience and psychology to induce relaxed and entranced mental states in the user."}]}, "developer_name": "Object Normal", "developer_privacy_policy_url": "http://visitationsvr.com/privacy.html", "developer_terms_of_service_url": "http://visitationsvr.com/eula.html", "publisher_name": "Light Clinic", "support_website_url": "http://visitationsvr.com/", "website_url": "http://visitationsvr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1404800346651520"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031396_451897125757566_5508740563694341995_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cnkiKND2-MEQ7kNvgFNmoy7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaQE_L6E-gX83oW8XfYM77l&oh=00_AYBqZojnI_KUn2pBAZr29uAHSNgJQ9XHARoFgAV030EtUg&oe=66F28FD7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Visitations", "platform": "ANDROID", "cont