1-25/38974548_460035026911485_5406757983494996757_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9BejHnTvOUQ7kNvgFmgUgH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCS4xpF_u512uZYe4oe8bkTjjf5QgTEguCGZgbQj9ayHw&oe=6703B071"}, {"file_name": "5.png", "id": "803323975305349", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566690_803323978638682_6374794764864814850_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuHst4ilNIgQ7kNvgEo2U4a&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7Q0aeiaXEEx1Kfq2-80wSE5X8bl7jfbVJqhgFpPginw&oe=6703BEC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TRAILER-COVER.png", "id": "1218679169290308", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982480_1218679172623641_6223996276826998637_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IvKcArV1bXEQ7kNvgFh3A3g&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjA1SU1o8DpqObtBzZsQyu5Y7iIFXSP4Au8SOCFUQGZg&oe=6703B092"}, "display_name": "Hyperspace Music", "keywords": [], "long_description": "Discover a new world of music with HyperSpace Music, the ultimate VR app for Oculus headsets. HyperSpace Music revolutionizes your auditory experience by transforming your favorite MP3 tracks into breathtaking visual masterpieces.\n\nSimply load your MP3 files into the default \"music\" folder on your headset, and let HyperSpace Music do the rest. Each song is brought to life through stunning, real-time visualizers that respond dynamically to the beats, rhythms, and melodies of your music. Whether you're grooving to pop, rocking out to metal, or relaxing with classical tunes, HyperSpace Music creates an immersive visual landscape that complements every genre.\n\nDive into a vibrant universe where sound and sight merge, offering an unparalleled sensory adventure. Customize your experience with various visual themes and effects, ensuring that no two journeys are ever the same. HyperSpace Music is perfect for music lovers, VR enthusiasts, and anyone looking to elevate their listening experience.\n\nApp Created by Krish T & Vicente M - Future Productions Films\nVideo Backgrounds - Bj\u00f6rn Richter & TellSoto\nSpace Cover Art - Photo by Felix Mittermeier\n\nLINKS:\nhttp://www.future-productions.co.uk\nhttps://dietechrecruiter.de/author/bj%C3%B6rn-richter/ \nhttps://www.pexels.com/photo/blue-universe-956981/", "short_description": "HyperSpace Music is a VR app for Oculus headsets that lets you discover a new world of music through stunning visualizers. Load your favorite MP3 tracks into the music folder on your headset, and watch as HyperSpace Music transforms each song into an immersive visual experience, with vibrant, dynamic landscapes reacting in real-time to the beats and rhythms of your music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://future-productions.co.uk/privacy-policy-for-hyperspace-music-vr-application/", "developer_terms_of_service_url": null, "publisher_name": "Future Productions Films Ltd", "support_website_url": null, "website_url": "http://www.future-productions.co.uk/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "393222478507326"}, {"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8244448688912468"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974830_1075593470653594_4085963081586079827_n.png?stp=dst-png_s360x360&_nc_cat