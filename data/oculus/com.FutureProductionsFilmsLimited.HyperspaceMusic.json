=scontent.oculuscdn.com&oh=00_AYCMmEld_yPHM5lpiCCdT5ug--b9c-8TMf8dKH0uJyNeJg&oe=66D8422A"}, {"file_name": "3.png", "id": "864897658880084", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031570_864897665546750_7112887189832554735_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oSpJidzsf8QQ7kNvgH9FKqy&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0hUUi0ib1lN3MOO1CNteNIRafL_DdLq-SLUjkhgXeHw&oe=66D82D5B"}, {"file_name": "4.png", "id": "460035023578152", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_460035026911485_5406757983494996757_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oZkbS1q97M8Q7kNvgEgL-vM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRrrafeDJ62MaR3Up58oIiTXbMKSm9ZP-97oFaBEzQFQ&oe=66D82EF1"}, {"file_name": "5.png", "id": "803323975305349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566690_803323978638682_6374794764864814850_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xgw3ESVhwxwQ7kNvgG6DJew&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyx6UPuClFiHrRu6gTdQ_YG5sdhe_W5Y-WxNdPrMIbVA&oe=66D83D40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TRAILER-COVER.png", "id": "1218679169290308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982480_1218679172623641_6223996276826998637_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8RHdANHLCUUQ7kNvgHWs8Tr&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDQUqUyqNq398mpA7Y1kNXL94pRmv-xM2mOVYqPwE7nQ&oe=66D82F12"}, "display_name": "Hyperspace Music", "keywords": [], "long_description": "Discover a new world of music with HyperSpace Music, the ultimate VR app for Oculus headsets. HyperSpace Music revolutionizes your auditory experience by transforming your favorite MP3 tracks into breathtaking visual masterpieces.\n\nSimply load your MP3 files into the default \"music\" folder on your headset, and let HyperSpace Music do the rest. Each song is brought to life through stunning, real-time visualizers that respond dynamically to the beats, rhythms, and melodies of your music. Whether you're grooving to pop, rocking out to metal, or relaxing with classical tunes, HyperSpace Music creates an immersive visual landscape that complements every genre.\n\nDive into a vibrant universe where sound and sight merge, offering an unparalleled sensory adventure. Customize your experience with various visual themes and effects, ensuring that no two journeys are ever the same. HyperSpace Music is perfect for music lovers, VR enthusiasts, and anyone looking to elevate their listening experience.\n\nApp Created by Krish T & Vicente M - Future Productions Films\nVideo Backgrounds - Bj\u00f6rn Richter & TellSoto\nSpace Cover Art - Photo by Felix Mittermeier\n\nLINKS:\nhttp://www.future-productions.co.uk\nhttps://dietechrecruiter.de/author/bj%C3%B6rn-richter/ \nhttps://www.pexels.com/photo/blue-universe-956981/", "short_description": "HyperSpace Music is a VR app for Oculus headsets that lets you discover a new world of music through stunning visualizers. Load your favorite MP3 tracks into the music folder on your headset, and watch as HyperSpace Music transforms each song into an immersive visual experience, with vibrant, dynamic landscapes reacting in real-time to the beats and rhythms of your music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://future-productions.co.uk/privacy-policy-for-hyperspace-music-vr-application/", "developer_terms_of_service_url": null, "publisher_name": "Future Productions Films Ltd", "support_website_url": null, "website_url": "http://www.future-productions.co.uk/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "393222478507326"}, {"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8244448688912468"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1239348220764120"}]}, "baseline_offer": {"id": "1239348220764120"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722399746, "status": "PUBLISHED", "id": "1239348220764120"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8593609017329765", "version": "1.0.4"}, "id": "1845929692484603", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8593609017329765"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Space Travelers!\n\nI have been working constantly to make this app better and have some exciting new updates planned in the next few weeks.\n\nIn this Update:\n\n1) The SR8 SpaceFighters are now flying in battle formation in Visualizer 2.\n\n2) Jet engine effects have been added.\n\n3) Minor tweaks to the scene transitions.\n\nWe really have been working hard to make this app better and better. \n\nThanks for joining us on this journey through space and through sound.\n\nK", "created_date": 1724933079, "id": "8593609017329765", "version": "1.0.4", "version_code": 5, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8593608070663193"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8593609017329765"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Friends,\n\nI have been working endlessly to make this app better. Please bear with us as we make more updates to the app later this month.\n\nSo far:\n\n1) The Hyperspace Intro video is now in 360 format.\n\n2) An SR8 Spacefighter ship has been added to one of the scenes. (We will add in more ships and interior details in the next update)\n\n3) The visualizers now have a simple fade transition to smoothen scene changes.\n\nStay Tuned for a lot more exciting updates!\n\nK", "created_date": 1724706068, "id": "8575273972496603", "version": "1.0.3", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8575273192496681"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8593609017329765"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear All,\n\nThanks for joining us on the launch to Hyperspace!\n\nWe have a few exciting updates planned over the next few days, so please stay tuned.\n\nWe listened to some of your feedback and are currently relentlessly working on the rest of the changes.\n\nFor now this update brings:\n\n1) A brand new visualizer inspired by the popular \"Milkdrop\" visualizer. This visualizer is called \"Stardust\" and features some cool abstract effects. This will only get better with time!\n\n2) Web browsing and some Android 2D apps may work within app for Quest 2 and up.\n\nStay tuned, we will rollout more updates in a matter of days!\n\nK", "created_date": 1723147486, "id": "8466474513376550", "version": "1.0.2", "version_code": 3, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8466473700043298"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8593609017329765"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": null, "created_date": 1722859018, "id": "8444698865554115", "version": "1.0.1", "version_code": 2, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8444696522221016"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8593609017329765"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": null, "created_date": 1722264662, "id": "8403559513001384", "version": "1.0", "version_code": 1, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8403537809670221"}, "asset_files": {"count": 0}, "debug_symbols": 