dn.com&oh=00_AYBMvAHgIWBLBQmliLVP7FXL_CzJOrYJotUb2dD5ZIfRXg&oe=6703B007"}, {"file_name": "2.png", "id": "1181470809602019", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982480_1181470816268685_7901464159755747416_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KmNU8NStpecQ7kNvgEfWtkX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDN58pr6YuisS3E9fpHDWPlY0s5OgDAKiHllyuLuL3w7Q&oe=6703C3AA"}, {"file_name": "3.png", "id": "864897658880084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031570_864897665546750_7112887189832554735_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_JdvnPEqbEkQ7kNvgEOEgSj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAN7F0cyG62nSQw85o0G_bTZvEJ3EhyBU_atYH3O09Ryw&oe=6703AEDB"}, {"file_name": "4.png", "id": "460035023578152", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974548_460035026911485_5406757983494996757_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9BejHnTvOUQ7kNvgFmgUgH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCS4xpF_u512uZYe4oe8bkTjjf5QgTEguCGZgbQj9ayHw&oe=6703B071"}, {"file_name": "5.png", "id": "803323975305349", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566690_803323978638682_6374794764864814850_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuHst4ilNIgQ7kNvgEo2U4a&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7Q0aeiaXEEx1Kfq2-80wSE5X8bl7jfbVJqhgFpPginw&oe=6703BEC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TRAILER-COVER.png", "id": "1218679169290308", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982480_1218679172623641_6223996276826998637_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IvKcArV1bXEQ7kNvgFh3A3g&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjA1SU1o8DpqObtBzZsQyu5Y7iIFXSP4Au8SOCFUQGZg&oe=6703B092"}, "display_name": "Hyperspace Music", "keywords": [], "long_description": "Discover a new world of music with HyperSpace Music, the ultimate VR app for Oculus headsets. HyperSpace Music revolutionizes your auditory experience by transforming your favorite MP3 tracks into breathtaking visual masterpieces.\n\nSimply load your MP3 files into the default \"music\" folder on your headset, and let HyperSpace Music do the rest. Each song is brought to life through stunning, real-time visualizers that respond dynamically to the beats, rhythms, and melodies of your music. Whether you're grooving to pop, rocking out to metal, or relaxing with classical tunes, HyperSpace Music creates an immersive visual landscape that complements every genre.\n\nDive into a vibrant universe where sound and sight merge, offering an unparalleled sensory adventure. Customize your experience with various visual themes and effects, ensuring that no two journeys are ever the same. HyperSpace Music is perfect for music lovers, VR enthusiasts, and anyone looking to elevate their listening experience.\n\nApp Created by Krish T & Vicente M - Future Productions Films\nVideo Backgrounds - Bj\u00f6rn Richter & TellSoto\nSpace Cover Art - Photo by Felix Mittermeier\n\nLINKS:\nhttp://www.future-productions.co.uk\nhttps://dietechrecruiter.de/author/bj%C3%B6rn-richter/ \nhttps://www.pexels.com/photo/blue-universe-956981/", "short_description": "HyperSpace Music is a VR app for Oculus headsets that lets you discover a new world of music through stunning visualizers. Load your favorite MP3 tracks into the music folder on your headset, and watch as HyperSpace Music transforms each song into an immersive visual experience, with vibrant, dynamic landscapes reacting in real-time to the beats and rhythms of your music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://future-productions.co.uk/privacy-policy-for-hyperspace-music-vr-application/", "developer_terms_of_service_url": null, "publisher_name": "Future Productions Films Ltd", "support_website_url": null, "website_url": "http://www.future-productions.co.uk/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "393222478507326"}, {"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8244448688912468"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1239348220764120"}]}, "baseline_offer": {"id": "1239348220764120"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722399746, "status": "PUBLISHED", "id": "1239348220764120"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8869363689754295", "version": "1.0.9"}, "id": "1845929692484603", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8869363689754295"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Hyperspace Travelers,\n\nBuckle up, as we're taking another leap into the cosmos!\n\nWe're excited to announce that the visual experience in Hyperspace Music has improved and will improve further in the next update. \n\nHere's what's new:\n\nResolution Boost: We've started enhancing the overall visual quality! The cockpit resolution has received a notable upgrade, bringing sharper details to your journey through space.\n\nStarfighter Visuals: The starfighter visuals have also been enhanced, delivering even more clarity as you navigate the abstract universe.\n\nUpcoming Features: We're still hard at work on introducing a playlist feature, coming in the next update, so you can fully customize your musical journey!\n\nAs always, we remain dedicated to improving your experience with each update. Stay tuned for more exciting developments.\n\nSee you among the stars!\n\nK - Hyperspace Music", "created_date": 1727864808, "id": "8869363689754295", "version": "1.0.9", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8869362409754423"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8869363689754295"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Hyperspace Music VR - Update Changelog\n\nHey Hyperspace Pilots,\n\nWe\u2019re excited to share the latest update for Hyperspace Music VR! \ufffd \n\nWhile we\u2019re still fine-tuning the ships and working hard on a much-anticipated playlist feature for the next release, here\u2019s what\u2019s new in this version:\n\nAdjusted Lighting: We\u2019ve enhanced the in-game lighting for a more immersive experience.\n\nExterior Ship Details: New visual details have been added to the ships' exteriors to bring more depth and realism to your journey.\nBasic Heads-Up Display (HUD): We\u2019ve introduced a simple HUD behind the menu in the cockpit. It\u2019s a work in progress, and we\u2019ll be improving it over time!\n\nThank you for being a part of this journey. More exciting updates are on the horizon!\n\nHappy flying, The Hyperspace Music Team", "created_date": 1727550272, "id": "8835480006475997", "version": "1.0.8", "version_code": 9, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8835478213142843"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8869363689754295"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Hyperspace Travelers, \n\nVisualizer 2 and 9 now have a SR8 Fighter cockpit for you to ride in. This will get more detailed in time.\n\nWe are also currently working on playlist functionality, please expect that in the updates to come!\n\nStay Tuned!\n\nKrish - Hyperpace Music", "created_date": 1727378621, "id": "8816857305004934", "version": "1.0.7", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8816855628338435"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8869363689754295"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Hyperspace Travelers,\n\nWe've just made your journey through the music cosmos even more mesmerizing! \n\nIn this update, Visualizer 6 has undergone a complete transformation\u2014embrace the flow with the new Organic Green visualizer, designed to sync your music with nature's rhythm.\n\nWe've also made some under-the-hood tweaks to boost performance and ensure a smoother, more immersive experience. Keep exploring and enjoy the enhanced vibes!\n\nIn the next few weeks we have some really cool updates coming, so please stay tuned!\n\nSafe travels,\nK -The Hyperspace Music VR Team", "created_date": 1725481242, "id": "8632412443449422", "version": "1.0.6", "version_code": 7, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8632411206782879"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8244448648912472", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8869363689754295"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1845929692484603"}]}, "change_log": "Dear Hyperspace Travellers,\n\nToday we are proud to add a further 3 viualizers to Hyperspace Music!\n\nWe have been working non-stop to bring you a collection of truly unique and mesmerizing visuals. In the weeks to come we will add more visuals and are currently tweaking the ones we have for optimal performance and quality.\n\nstay tuned for some really cool stuff coming soon!\n\nK", "created_date": 1725397469, "id": "8625943034096363", "version": "1.0.5", "version_code": 6, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8625942120763121"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}