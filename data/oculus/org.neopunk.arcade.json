ry_application": {"__typename": "Application", "id": "5539797106068876", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8213926085322618"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1330071677791070"}]}, "change_log": "Why such a fast, unplanned version of arcade 7.7?}\nBecause an Arcade gamer (thanks Julie B.) reminded me that Jack game had certain weaknesses.\n\nWhat has changed?\n- Sounds and music. they coexist very well now.\n- I have added a neon-style effect when the serie is presented.\n\nDoes it really have an impact on the game?\nYes, definitely. I am getting higher scores but more importantly I am having a lot more fun playing!\n\nOther changes?\n- Some texts in the options screen.\n- Tab-style for games category (action/puzzle/demo).", "created_date": 1722746652, "id": "7708116362570262", "version": "7.7", "version_code": 21, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}