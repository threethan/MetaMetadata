scape.png", "id": "1597754543980218", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982481_1597754550646884_2352288393038998942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NhnCj7WmcD4Q7kNvgHOln7a&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2IOP9GbgvKu5n1NmHm_V1FBuiNQlg6AcZd2MsnTb6vA&oe=67371AB2"}, "display_name": "Arcade", "keywords": [], "long_description": "Welcome to Arcade!\n\nAfter developing Retro Bricks 1982, I decided to go further and propose a  collection of games inspired by the past...\n\nAt the moment, there are 3 old school ames: \n* Bricks, formelly Retro Bricks 1982, that I improved in several ways\n* Blocks, a funny game where you have to destroy shapes\n* Invasions, a classical invasion game\n\nI hope you will have a lot of fun playing Arcade ;-)\n\nNeoPunk", "short_description": "Welcome to Arcade!\nA collection of games inspired by the past...\nMeet Bricks, Blocks and Invasions!\nAnd above all, have fun!\nNeoPunk"}]}, "developer_name": "NeoPunk", "developer_privacy_policy_url": "https://www.neopunk.org/policy.php", "developer_terms_of_service_url": null, "publisher_name": "NeoPunk", "support_website_url": "https://www.neopunk.org/index.php?page=Feedback", "website_url": "https://www.neopunk.org/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "678828423727517"}}]}, "scheduled_offers": {"count": 4, "nodes": [{