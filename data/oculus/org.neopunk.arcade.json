cdn.com/v/t64.5771-25/75210898_269629522874889_1582705334465988593_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3HMW2qSzFL4Q7kNvgHulZsW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ-q4AzLor_-GHv_NMeNV5DkVBoDoU81WXHylM08abGg&oe=6718E51F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape-and-cover-2560-1440.png", "id": "3355850461382712", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75278189_3355850464716045_4287878642547994865_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GwGl_QE1lXkQ7kNvgGWyRZB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmgMN1C78SJ-c9Dd1HHCGKy2P9X3jRROUgpV7CLhJgJw&oe=6718CD01"}, "display_name": "Arcade", "keywords": [], "long_description": "Welcome to Arcade!\n\n* 13 retro style games & variation including Galactics, Bricks, Blocks, Invasions, Match, Rocs, Jack, Maze & Blocks 2!\n* Support all frame rate frequencies from 72.0 Hz to 120 Hz\n* Support all Quest (1, 2, 3 & Pro)\n* 4 levels of difficulty per game (easy, medium, hard & expert)\n* 20 to 75 waves per game (depending of the game)\n* Vector style graphics\n* Original soundtracks\n* And a leaderboard to share your score across players\n\nI hope you will have a lot of fun playing Arcade ;-)\n\nNeoPunk", "short_description": "Welcome to Arcade!\n\nArcade is a collection of 13 retro games & variations, almost free!\n\nHave fun!\nNeoPunk"}]}, "developer_name": "NeoPunk", "developer_privacy_policy_url": "https://www.neopunk.xyz/policy.php", "developer_terms_of_service_url": null, "publisher_name": "NeoPunk", "support_website_url": null, "website_url": "https://www.neopunk.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet