c_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCj2XEZuk-FFWNIkJrWpKnH61dHNgIu8G6Z458UJEDnNQ&oe=6775344B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Circumpaint", "keywords": ["paint", "animate", "images"], "long_description": "Do you like to draw? How about animate? Now you can do both while surrounded by a 360 degree view of your art. Circumpaint allows you to paint with pixels on a hemispherical canvas with you at the center. And when you're ready you can move beyond stills using page flip style animation. Uses the touchpad, or use a gamepad to access shortcuts.\n\n\"I ended up animating a pixel dragon breathing fire, it was silly but cute. It made me laugh and want to play a bit more. The developer clearly understand the limitations of trying to paint with your head, I appreciate the choices that they made to deliver a surprisingly satisfactory experience.\"\n-- Brad Herman, Head of DreamLab at DreamWorks Animation\n", "short_description": "Do you like to draw? How about animate? Circumpaint allows you to paint with pixels on a hemispherical canvas with you at the center. And when you're ready you can move beyond stills using page flip style animation. Uses the touchpad, or use a gamepad to access shortcuts.\n\n\"I ended up animating a pixel dragon breathing fire, it was silly but cute. It made me laugh and want to play a bit more.\"\n-- Brad Herman, Head of DreamLab at DreamWorks Animation\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.gnometech.com/circumpaint-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Gnometech Inc.", "support_website_url": null, "website_url": "http://www.gnometech.com/gearvr/circumpaint/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": null, "