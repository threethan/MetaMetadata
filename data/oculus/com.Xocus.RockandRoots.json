109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9HOvlfIWtrkQ7kNvgFoiyCo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsofQu1UROWKXtl2gthMyKuB_z-VAW0LybLj_2hb2HCg&oe=677FCCF1"}, "display_name": "Rock and Roots", "keywords": [], "long_description": "On a warm summer night, when the stars twinkle like fireflies and the rustling leaves whisper secrets in the deep woods, a captivating fairy tale weaves itself like magic around the flickering flames of a campfire. \nGuided by instinct and your own strategic acumen, you wield the power to dictate the ebb and flow of battle. Each encounter becomes a tactical dance, an intricate interplay of forces where you strategically choose and deploy your allies \u2013 the Springs \u2013 to conquer trials and adversaries that bar your path. The secret lies in the cards that adorn your left hand, each bearing the essence of a specific Spring. As you deftly select and unveil these cards, you set in motion a symphony of magic and nature, your chosen allies springing to life to face the challenges that await.", "short_description": "Rock and Roots is a captivating story-driven VR journey where you wield the power to dictate the ebb and flow of battle. Summon your enigmatic guardians of the woods with a magical hand to face the challenges. Conjure spells, dive into the magic world and reclaim your rightful place on the throne!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xocus.co/rockandrootsprivacy", "developer_terms_of_service_url": null, "publisher_name": "XOCUS", "support_website_url": null, "website_url": "https://xocus.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": 