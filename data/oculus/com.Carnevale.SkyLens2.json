771-25/38974721_1495159964699064_2176249693265729977_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_s60v9KzA4Q7kNvgGzyxrT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBOdwH4bHwp3dTILvynm4BWnHgYHYTryhTwckhYcCbUlQ&oe=66FFD501"}, {"file_name": "Flights.png", "id": "539005471912309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036667_539005478578975_8650327033978841105_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DYMrAMcNwcYQ7kNvgHnZyFZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQppv5-RcMzPNpZLm8HvnvKw5eeW7nyT1JeOYIyA-TLg&oe=66FFC0CB"}, {"file_name": "Sat.png", "id": "3597365077220262", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035364_3597365080553595_7738373876313878622_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LHN-hH1Qz6QQ7kNvgF5WML7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPS3t5gmDd7dSZRz-Jf78NoRQIXatDOAHuMK9ahAdQdA&oe=66FFD354"}, {"file_name": "Paris.png", "id": "420205420347672", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572663_420205423681005_1696009011502109278_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pwJfrRNlWw8Q7kNvgEUDxqp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzhQscrlT08FQXjlYR0p1p0n_Gc93op987hORFVCKQkA&oe=66FFE913"}, {"file_name": "Teleport.png", "id": "1218938712766523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982608_1218938716099856_607862685058392298_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rx6jgTjQCtwQ7kNvgHl_N2w&_nc_ht=scontent.oculuscdn.com&oh=00_AYCWQGBBLWryW4B2ALfRfnz31D4cKs6iqR4FYoh5yD7dhA&oe=66FFCE35"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SkyLens", "keywords": [], "long_description": "Introducing Skylens, your passport to a new dimension of weather and location-based data exploration! Immerse yourself in the world of mixed reality that seamlessly blends digital data with the physical world.\nPicture standing on the bustling streets of Tokyo while checking the current temperature, or virtually strolling along the serene beaches of Fiji as you g