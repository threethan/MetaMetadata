_thumbnail": null, "display_name": "SkyLens", "keywords": [], "long_description": "Introducing Skylens, your passport to a new dimension of weather and location-based data exploration! Immerse yourself in the world of mixed reality that seamlessly blends digital data with the physical world.\nPicture standing on the bustling streets of Tokyo while checking the current temperature, or virtually strolling along the serene beaches of Fiji as you gauge the real-time forecast \u2013 all inside the comfort of your own space. Witness dynamic weather patterns, explore temperature variations, and track precipitation levels across the globe. Whether you're an avid traveler, a weather enthusiast, or simply curious about the conditions in far-flung places, Skylens reveals a world of invisible and interesting data.", "short_description": "Introducing SkyLens, your passport to a new dimension of weather and location-based data exploration! Immerse yourself in the world of mixed reality that seamlessly blends digital data with the physical world.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.skylensapp.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "CARNEVALE", "support_website_url": null, "website_url": "https://www.skylensapp.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26687147287599531"}}]}, "schedu