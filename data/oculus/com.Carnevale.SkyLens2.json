2-1.oculuscdn.com&oh=00_AYAma_ZqX3WGGqDWsufFNvJhHX2X9lo5HYZbwxJxJ1i3IQ&oe=677E55DB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1183954759355001", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75612011_1183954762688334_7472894946712134861_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9L9agjUPVIwQ7kNvgF9VLmc&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYChl6_IJ-STTdoggOSxUH0M_QNWBjoBSfNQlJ8_TZD21w&oe=677E48D9"}, "display_name": "SkyLens", "keywords": [], "long_description": "Introducing SkyLens\u2014your gateway to a new world of weather, aerospace, and location-based real-time data. Explore the sky above with live updates on weather, aircraft, and satellite positions.\n\nWith our proprietary Dynamic Data Lens, SkyLens overlays a tremendous amount of data in AR mode and can transport you to any location in VR. Simply say \"Take me to Paris,\" and SkyLens will whisk you to the City of Light in VR mode, where you'll experience live weather, aircraft, and satellite data as if you were standing on the Champs-\u00c9lys\u00e9es. Use the innovative bubble control to fly above the cityscape.\n\nWhether you're a traveler, weather enthusiast, or just curious about distant places, SkyLens uncovers a fascinating world of invisible data.", "short_description": "Introducing SkyLens\u2014your gateway to a new world of weather, aerospace, and location-based real-time data. Explore the sky above with live updates on weather, aircraft, and satellite positions.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.skylensapp.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "CARNEVALE", "support_website_url": null, "website_url": "https://www.skylensapp.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external