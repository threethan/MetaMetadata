58392298_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u_MdKTThys8Q7kNvgEBvfm1&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBezoJPYgSIaa2usCKnmb8InQ1JW7A8xwPhVLFjtn6Ehg&oe=671637B5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SkyLens", "keywords": [], "long_description": "Introducing Skylens, your passport to a new dimension of weather and location-based data exploration! Immerse yourself in the world of mixed reality that seamlessly blends digital data with the physical world.\nPicture standing on the bustling streets of Tokyo while checking the current temperature, or virtually strolling along the serene beaches of Fiji as you gauge the real-time forecast \u2013 all inside the comfort of your own space. Witness dynamic weather patterns, explore temperature variations, and track precipitation levels across the globe. Whether you're an avid traveler, a weather enthusiast, or simply curious about the conditions in far-flung places, Skylens reveals a world of invisible and interesting data.", "short_description": "Introducing SkyLens, your passport to a new dimension of weather and location-based data exploration! Immerse yourself in the world of mixed reality that seamlessly blends digital data with the physical world.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.skylensapp.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "CARNEVALE", "support_website_url": null, "website_url": "https://www.skylensapp.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages"