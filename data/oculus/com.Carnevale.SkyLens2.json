ideo_trailer_thumbnail": {"file_name": "Cover.png", "id": "1183954759355001", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75612011_1183954762688334_7472894946712134861_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A5IW7jHpu9YQ7kNvgHs8sRn&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCrfmlx55_0Tadnu4TomyJr9Y2GaH3AHIOkDeQZBqT_Ng&oe=670F8AD9"}, "display_name": "SkyLens", "keywords": [], "long_description": "Introducing SkyLens\u2014your gateway to a new world of weather, aerospace, and location-based real-time data. Explore the sky above with live updates on weather, aircraft, and satellite positions.\n\nWith our proprietary Dynamic Data Lens, SkyLens overlays a tremendous amount of data in AR mode and can transport you to any location in VR. Simply say \"Take me to Paris,\" and SkyLens will whisk you to the City of Light in VR mode, where you'll experience live weather, aircraft, and satellite data as if you were standing on the Champs-\u00c9lys\u00e9es. Use the innovative bubble control to fly above the cityscape.\n\nWhether you're a traveler, weather enthusiast, or just curious about distant places, SkyLens uncovers a fascinating world of invisible data.", "short_description": "Introducing SkyLens\u2014your gateway to a new world of weather, aerospace, and location-based real-time data. Explore the sky above with live updates on weather, aircraft, and satellite positions.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.skylensapp.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "CARNEVALE", "support_website_url": null, "website_url": "https://www.skylensapp.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "393222478507326"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection":