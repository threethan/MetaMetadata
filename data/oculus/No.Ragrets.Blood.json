ontent-ams2-1.oculuscdn.com&oh=00_AYAkb2pdEmeRPZV407V-__HIU6A4VOOqbkEBfwHqVUl52w&oe=6756D4C6"}, {"file_name": "BLUD E.png", "id": "512750678316931", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974595_512750684983597_6316622060033192551_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSDVJdmg4vUQ7kNvgGUvM4O&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC8Vcl3WTaJX6yAM6m330FCLBFZ6MtLj6q0vmDcTm3I7w&oe=6756C821"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BLUD trailer cover.png", "id": "1257187508752269", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75230049_1257187512085602_1909194995855667713_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xNbRDLKzayAQ7kNvgGxYrdJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCPotZJL6TrtPG9TnnOF783p9O1Y8UIJsulMEUeIDGWAQ&oe=6756DDBB"}, "display_name": "BLUD", "keywords": ["gore", "violence", "guns", "sigma", "blood"], "long_description": "Unleash chaos and hilarity with BLUD, your very own mixed reality rage room! \nTurn your home into a battleground of absurd destruction, where colorful flying unicorns invade your space and only you can stop them.\n\n{1326912111658201}\n\n\"Bro woke up and chose violence\" \ud83e\udd84\n\n\n# Absurd Weapons\nGuns, chainsaws, crayons, and more \u2014 choose your tools of destruction and get creative with how you take down those pesky unicorns.\n\n{1140433681093627}\n\n\n\n# Multiple Game Modes\nWhether you're racing against time, pulling off trick shots, stopping a zombie outbreak, or focusing on one specific target (looking at you, Larry), there's a mode for every kind of chaos-lover.\n\n{544649441872261}\n\n# Endless Humor\nFeaturing Larry, a sarcastic talking unicorn with hundreds of hilarious lines, ready to taunt and entertain you throughout the madness.\n\n{1529351324437567}\n\n# 100% Mixed Reality\nExperience unicorn carnage in your own home as the game seamlessly blends your environment with a magical, blood-splattered battlefield.\n\n{1085416866703270}\n\n# Endless Fun\nEnjoy hours of replayable chaos that's perfect for showing off the power of mixed reality to friends and family.\n\nTransform your home into a wild, magical rage room and let the glitter, poop, and blood fly!\n\nAre you ready to paint your walls with unicorn blood?\n", "short_description": "Unleash chaos and hilarity with BLUD, your very own mixed reality rage room! \nTurn your home into a battleground of absurd destruction, where colorful flying unicorns invade your space and only you can stop them.\n\n\"Bro woke up and chose violence\" \ud83e\udd84"}]}, "developer_name": "No Ragrets Games", "developer_privacy_policy_url": "https://noragrets.wixsite.com/noragretsgames/privacy", "developer_terms_of_service_url": "https://noragrets.wixsite.com/noragretsgames/eula", "publisher_name": "No Ragrets Games", "support_website_url": null, "website_url": "https://noragrets.wixsite.com/noragretsgames/eula", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27701266322855529"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031341_1954962971653236_5637857974803045416_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WATQxAq0k78Q7kNvgEawhcq&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAQwo6qxSDXB4yWtw3nX0QeaQ5LbVIR6GMShstfB51zFg&oe=6756E370"}, "