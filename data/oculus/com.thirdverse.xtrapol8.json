21908", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031441_285638290455241_4106606953274371061_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wzf_5-CmEQQQ7kNvgHMWQZq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAI8F16blZH4imodpsXM2_HszXpN4JZIXqljbCX5mn9Rw&oe=670A549D"}, {"file_name": "X8_Screeshot_3.png", "id": "283437817362152", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974491_283437820695485_8757146730028716038_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CjZJvla72iEQ7kNvgGaVREm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARf9v5fuKqn99E2HVyu5Pg9OUJCDz6GD2BHsXpek2ZIg&oe=670A4A0E"}, {"file_name": "X8_Screeshot_4.png", "id": "1685131325648260", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443235_1685131328981593_7121581085702710915_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r8OAculgG_UQ7kNvgHpnoNE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmG-No-D01Hjp42xfFnaDWzc_xB4t4Af-T4hKO_HKaNQ&oe=670A63BD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1260149998007268", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974771_1260150001340601_5468830080405483778_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O12dicWWmYwQ7kNvgFTFfKj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZq2va_Ek5SsPRha4e4m4z_dz8ld9ZTIB-HZwtVwKvxA&oe=670A6A54"}, "display_name": "X8", "keywords": ["shooter", "pvp", "fps", "hero", "contra"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}]}, "developer_name": "Thirdverse, Co., Ltd.", "developer_privacy_policy_url": "https://thirdverse.io/en/privacy-policy.html", "developer_terms_of_service_url": "https://thirdverse.io/en/terms-of-service.html", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://playx8vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "zh_CN", "fr", "de", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "8493813437343911"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982643_894591262099858_2465524632437854400_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xK_IqQ6AJRUQ7kNvgHP0JkR&_nc_ht=scontent-iad3-2.oculus