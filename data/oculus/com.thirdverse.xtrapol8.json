eshot_1.png", "id": "1393643968243643", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75307246_1393643971576976_4032811018913052717_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mwgGKpfVjTUQ7kNvgHGX9Q-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhL_8XDY1R912W6LBANZICQXfjPokOQlHDegMN9n2LqA&oe=676C011C"}, {"file_name": "X8_Screeshot_2.png", "id": "285638287121908", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031441_285638290455241_4106606953274371061_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E6xVJLl7fn0Q7kNvgEqbjXr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAp13IoAnXiKeB2SdB_uvh_a7NlSGtPLpe_y3GzA0xedw&oe=676BE39D"}, {"file_name": "X8_Screeshot_3.png", "id": "283437817362152", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974491_283437820695485_8757146730028716038_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4afTJXGxocEQ7kNvgGow7CM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsAwHrH08DZXPVB8q5ySWE4PWiaLbY-782KMuEPqum9Q&oe=676BD90E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1260149998007268", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974771_1260150001340601_5468830080405483778_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PsWaV8aiUYEQ7kNvgEj6Qal&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXAaYrRXRmafNGfXq525nC2nbtVJ2tUb0FcVqA4Pqe-w&oe=676BF954"}, "display_name": "X8", "keywords": ["shooter", "pvp", "fps", "hero", "contra"], "long_description": "X8 is a **Free to Play** 5v5 VR multiplayer hero shooter where heroes from different shooting game worlds battle in order to stop an **omnipotent AI** and restore a path back to their worlds. Are you up to the challenge?\n\n{27839393689041821}\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities to gain the competitive edge.\n\n{1644548386470704}\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or