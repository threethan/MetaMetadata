102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_xwqJoqRJ-8Q7kNvgGMJ1Ti&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRoI7Wx1E7SR7-i59DTsLxhlKGqNVQc5j3vm3MvfOh0A&oe=66D8310E"}, {"file_name": "X8_Screeshot_4.png", "id": "1685131325648260", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443235_1685131328981593_7121581085702710915_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i0Ync-3wqhIQ7kNvgEoWmvG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwdemZOrLkJIekDEEfsNVVtFXvPpC3ChynyZX-k9qwKA&oe=66D84ABD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1260149998007268", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_1260150001340601_5468830080405483778_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zFBxluHbJ_8Q7kNvgFXzB_u&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMptiEZjPy3WNOellL5y0AZafrMeD0RIPnD7yTwMluSA&oe=66D85154"}, "display_name": "X8", "keywords": ["shooter", "action", "pvp", "fps", "hero"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchi