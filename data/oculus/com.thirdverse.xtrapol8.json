lTD97Vt36sQ7kNvgEDJ1_C&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDbyrylXNmv5D87DGZvZWKUlV854Fzy6bfFek1G7HTfcA&oe=67011A1D"}, {"file_name": "X8_Screeshot_3.png", "id": "283437817362152", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974491_283437820695485_8757146730028716038_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zsoL___Xns0Q7kNvgExaOYi&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA9pgli2HQdVyKoVH-LyppmtkAkxSYY-humCRC8qXBRUA&oe=67010F8E"}, {"file_name": "X8_Screeshot_4.png", "id": "1685131325648260", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75443235_1685131328981593_7121581085702710915_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrGI3lPojLAQ7kNvgGpYYx1&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAcRLJ3Flj8rz0Hj840jRQwkb_68XOFeOjWCXwxX0_hBA&oe=6701293D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1260149998007268", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974771_1260150001340601_5468830080405483778_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fmHNLT73TfQQ7kNvgEqK_z_&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA8JJX1PnwQ8lLOskgkOo1U5tMwgsVfjiFQOCjsC7qvYQ&oe=67012FD4"}, "display_name": "X8", "keywords": ["shooter", "action", "pvp", "fps", "hero"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "X8_LU7_Cover_Icon_512x512.png", "id": "1700672760771542", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982690_1700672764104875_1201346064423233571_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DnlIyAR2I2YQ7kNvgGATGzU&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDm7cSViBHtQvf-9KrmT48smJ6kno1atSuPM5EhIIo3FA&oe=67011D73"}, {"file_name": "pub_x8_Logo_556x164.png", "id": "1698286060574850", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031543_1698286063908183_7870509160302259884_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y135t1XfPVEQ7kNvgEsL0KF&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDWBQzmCEUIs8jZl39DCv72mzwnRzD9JZTkW7UXL8Pv-Q&oe=67010C48"}, {"file_name": "Logo.png", "id": "1601022513728602", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984463_1601022517061935_7590174127011369459_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9lQqmzaPGt0Q7kNvgHrXnn7&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCAtohjKSNPwVshFxlXX6vYDczLHHJIeHFob5OR_nBsTw&oe=67010F50"}, {"file_name": "X8_LU7_Square_1440x1440.png", "id": "1256150292055401", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035430_1256150295388734_6637746793680017730_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_LhZZ9Tm7g0Q7kNvgE7uWHA&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBCSRDdgIHR962xIpKx_SsYDa9Caa