tTDnBhJa0zNg&oe=6744741C"}, {"file_name": "X8_Screeshot_2.png", "id": "285638287121908", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031441_285638290455241_4106606953274371061_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Op9EvtWIk0Q7kNvgGfhYim&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiIj1epGYcWqJjVms75FHDfGx5Qlj8NrEpC_lX-SAVjg&oe=6744569D"}, {"file_name": "X8_Screeshot_3.png", "id": "283437817362152", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974491_283437820695485_8757146730028716038_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8_jUNkEcc4Q7kNvgG1Wtyg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEHiVbcQtx7VU5Q4xDeKOdHb8w0HZ6K3g21QZOUE8xbA&oe=67444C0E"}, {"file_name": "X8_Screeshot_4.png", "id": "1685131325648260", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443235_1685131328981593_7121581085702710915_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5sqAcFSlPNYQ7kNvgE0jWs2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPnKeOBJIqD6ykNHBvx1zjltyziqry1l-DoOLa5vJJMA&oe=674465BD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1260149998007268", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974771_1260150001340601_5468830080405483778_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EwgijnL2ElQQ7kNvgH4lOMK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmswpC3-e6F-AdHmNpvJYYBrjZZU1EhEhwHw5JD4U5Qw&oe=67446C54"}, "display_name": "X8", "keywords": ["shooter", "pvp", "fps", "hero", "contra"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "X8_LU7_Cover_Icon_512x512.png", "id": "1700672760771542", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982690_1700672764104875_1201346064423233571_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mpKI2JFk4UAQ7kNvgF09SVl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKLTJU3__UmkKCzhuaA3g6pxkmAdKiOMEtS5Cgdl5i8A&oe=674459F3"}, {"file_name": "pub_x8_Logo_556x164.png", "id": "1698286060574850", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031543_1698286063908183_7870509160302259884_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lK3IB9bTkTcQ7kNvgF634Kx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAbsqCiVUVL7xDVX7opJ3aHWLH9Vj-nI3wivytRW6XM_g&oe=674448C8"}, {"file_name": "Logo.png", "id": "1601022513728602", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984463_1601022517061935_7590174127011369459_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpnwvx8pRGwQ7kNvgHv3gOW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4eFTizQuxEvWlTV1OPhr0tuiWqGnPsQk9HaHenTjPAA&oe=67444BD0"}, {"file_name": "X8_LU7_Square_1440x1440.png", "id": "12