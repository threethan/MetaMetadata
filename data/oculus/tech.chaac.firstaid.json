ot.png", "id": "1134219074671891", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974521_1134219078005224_7179707438156380427_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Akt5g18MplcQ7kNvgETye2E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfNUuyF8-G5ashGBG4vGtFVFK_62vxoVxMLlAU1bN4Rw&oe=67221E84"}, {"file_name": "Lobbyscreenshot.png", "id": "1106361077362388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75305882_1106361080695721_2077980112903714015_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2sNP5niGOcQ7kNvgHvMO6e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAngwupneJCnjMggWN9zl8RL97VeI7nX3LDwmuejZcnlw&oe=672207FE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage.png", "id": "779497757477543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_779497760810876_157322345244620332_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rM9_Klp5GkgQ7kNvgF88dZE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQ6ITqerb-pXivdyJ-dhx2rdt_j9vI2K9eSZz1DnSScA&oe=6722209C"}, "display_name": "First Aid: Opioid Emergency", "keywords": [], "long_description": "Welcome to our VR First Aid app, a transformative learning tool. This application is meticulously designed to teach users essential emergency skills, including how to dial 911, administer Narcan, and respond to opioid overdoses. Through realistic, immersive virtual reality scenarios, users gain hands-on experience in managing these critical situations with precision and calm. The VR First Aid app guides you through each step, from recognizing signs of an overdose to performing necessary interventions, all within a safe, virtual space. Ideal for individuals, educators, and healthcare professionals, this app is your ultimate resource for becoming a proficient first responder in today\u2019s world.", "short_description": "Equip yourself with life-saving skills in VR! Learn to call 911, administer Narcan, and manage opioid overdoses effectively with our immersive first-aid training app."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1B3KNESmF2S8bFCdivo6S0UMBaS68peIqZfzvLoRR6-8/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Chaac Technologies", "support_website_url": null, "website_url": "https://chaac.tech/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6643572715745666"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451785_2217434231943695_7833519432859458808_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V1bCcYdTkOsQ7kNvgFgh2qQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHFGej4hUhjXg7ejcJD5n48r3a1NUXlC_OL4imZ6OmAg&oe=6722270D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "First Aid: Opioid Emergency", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Medical", "id": "478089301798119"}], "release_date": 1714417320, "lastRevision": {"nodes": [{"id": "6499778216791784", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id"