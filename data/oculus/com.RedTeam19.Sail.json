B40wIhlFZ6CgmY9Eg2W0cGm_JA98tVfhexzYwHqJDbzg&oe=6720E2DF"}, {"file_name": "3.png", "id": "1057687345176343", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984467_1057687348509676_2740683212959292314_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PGKVpJhcUWwQ7kNvgH_brH9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZQkoJLp57Rw2M3M7Bp7QCAvz1nmSrLiXiRX7hGhJw9A&oe=6720D9A0"}, {"file_name": "4.png", "id": "540091907573916", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031569_540091910907249_6947533925413752874_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KxjW597mV6QQ7kNvgGdIlLB&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaeJTwYZqmmOdHKxAhsOSIFETpYCUUSICrZQKWrntD4w&oe=6720D04A"}, {"file_name": "5.png", "id": "394781362603245", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974459_394781365936578_6792117721934853619_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xhCHL84ND2MQ7kNvgGZRuih&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWO6Lo6G5p9YADbDMBuCrUL8gi-SnMf_mSSa1ERPNpLg&oe=6720DF0D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VR PIRATE WEAPONS (2560 \u00d7 1440 px).png", "id": "702303140875337", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031381_702303144208670_9051229543365941497_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=891H1_2aG2cQ7kNvgEhN2aq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKI1o_ZKyI8bBxojRINAeGiFbvWQxyjMf6hiTwZBKu1A&oe=6720C032"}, "display_name": "Sail - Early Access", "keywords": [], "long_description": "UNLEASH your Inner Pirate in SAIL the Open World VR Pirate game!!!\n\nEarn your Pirate reputation through EPIC voyages where you'll test yourself by collecting as much treasure as possible and bringing it back safely to your Pirate hideout.\n\nBUT BE WARNED . . .\n\nYou're not the only Pirate seeking fortune on the seas.\n\nFight off Pirate enemies on land with your Pirate weapon of choice\n\n- OR -\n\nBattle them on the seas using your ship's cannons and VOICE COMMANDS!\n\nPut your plunder to good use and use your riches to equip yourself with the best weapons and ships a Pirate could ask for.\n\nWith an Open World filled with Treasure, Mysterious Islands and limitless possibilities there's only one question to ask . . .\n\nArrrrgh you ready to set SAIL ???\n\nPLEASE NOTE: This is game is Early Access so it is not perfect and still a work in progress. We appreciate any and all feedback so leave it in a review or JOIN THE DISCORD and let us know there!\n\nTHANK YOU FOR SUPPORTING SAIL!!!", "short_description": "Unleash your Inner Pirate!!!! - Open World VR Pirate Game"}]}, "developer_name": null, "developer_privacy_policy_url": "https://garett-cook.com/index.php/sail-early-access-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Red Team Nineteen", "support_website_url": null, "website_url": "https://www.garett-cook.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "325455299503411"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "788894073068383"}, {"status": "PUBLISHED", "id": "1269930520212990"}]}, "baseline_offer": {"id": "788894073068383"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1703368980, "status": "PUBLISHED", "id": "788894073068383"}]}, "liveChannel": 