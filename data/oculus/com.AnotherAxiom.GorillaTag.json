44666_2947562527679999063_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1iBocJRNPoQ7kNvgF4tyIw&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYA2Bhf91NTAFgEXIx4gQ0YAgXNB8_jwFieMqomw4oaF6A&oe=66E95141"}, {"file_name": "ss7.png", "id": "411114093337117", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572918_411114096670450_1003695786336535506_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2teA-dTEocQ7kNvgHmsnx9&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYAYVAV-OxmMdcPiRiIAg-LiOuq_8DwFLoQx0TDNdQxMMA&oe=66E97F68"}, {"file_name": "ss5.png", "id": "3027915770764804", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982607_3027915774098137_710589156999139948_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eFERpyCwXDcQ7kNvgHIV1oz&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYAqVt2i6H319NJyTSyQGKA4KP8t6F65Ok2918H_kyhhOw&oe=66E974F1"}, {"file_name": "ss2.png", "id": "728430948049312", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_728430951382645_7345579485767927470_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nZUtmmMr6a4Q7kNvgGXZ9YD&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYDqODv6ibvHTobtGWbAp_jjxuoDtk2ioeg_eLsnVtupsw&oe=66E958A5"}, {"file_name": "ss1.png", "id": "1181555035592658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974809_1181555038925991_8438735938502136521_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yf5tJF12ah8Q7kNvgFoil1U&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYDTBCK4w5SC6CV2TivC6be6xwl7GxZgzEG-GfURNbpkOg&oe=66E95107"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerss.png", "id": "269054794605241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982715_269054797938574_3340108240390532152_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S2Rj_c4iyEcQ7kNvgEgqX9_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auyi3Wd18gTnwqjKMfb3N7I&oh=00_AYAi-8RfntRbIyUBAAdfbIzZo_PIEVYtXsQcQ5iI-ciSzQ&oe=66E97B18"}, "display_name": "Gorilla Tag", "keywords": [], "long_description": "Reject humanity.\n\nRun, climb, and jump in VR using a unique locomotion method that only needs the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off of surfaces to jump and squeeze them with both hands to climb. The game mode is simple tag, for up to 3 players, or infection mode, with 4 or more. Run from the infected gorillas, or outmaneuver the survivors to catch them. Parkour up trees and cliff faces to evade and chase people down. Hang out in a virtual, low-fi jungle with randos or group up in a private room with friends to hang out and play. The stakes are low, so feel free to just chat or make up your own games. The movement is easy to learn, and hard to master. Crossplay with the PC versions of the game, so play with anyone on any platform.\n\nBecome gorilla.", "short_description": "Run, jump, and climb using only your hands. Run away from other infected players, or outmaneuver the survivors to catch them. Embrace your inner ape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinyurl.com/GorillaTagVRPrivacyPolicy", "developer_terms_of_service_url": "https://www.termsfeed.com/live/8ac81fdb-ebc2-4785-9fbf-1d338f93db4c", "publisher_name": "Another Axiom", "support_website_url": null, "website_url": "https://discord.gg/JkM7c9Nb6U", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_intera