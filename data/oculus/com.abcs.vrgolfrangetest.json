uscdn.com&_nc_gid=AF66rcf1zG2VxxsCcai0Sdq&oh=00_AYCffHM61SK-nCE-DIL5pea4c3EkUy74GrEwhHTO62D3Fg&oe=66E2E944"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u7121\u984c.png", "id": "502165951068157", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984473_502165957734823_1520286877948022907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_xCEcAvDUoQ7kNvgHl8n7-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF66rcf1zG2VxxsCcai0Sdq&oh=00_AYBg6ZEO1kBir8xBXBszIOW1ogEpLpf70ydLZ3SNu3MQYA&oe=66E2B8E6"}, "display_name": "VRGolfRange\u03b2", "keywords": [], "long_description": "It is a application that allows you to experience the driving range of golf at home. You can check your swing on VR by holding the controller instead of the golf club and swinging. You can also set the controller on a golf club for practice and swing. In that case, use the position adjustment function of the controller.", "short_description": "An application for golf practice that can be used at home. You can keep hitting golf in the VR space, and you can objectively check your swing. This will be a beta version for testing.\n\nPlease note that this application is a beta version, so adjustments for swing and ballistic behavior have not been completed."}, {"images": {"nodes": [{"file_name": "vrg_e003_tate.png", "id": "2730464913921008", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404390_2730464917254341_5136702418237828326_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I3UD7vfHQ6AQ7kNvgEskYho&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF66rcf1zG2VxxsCcai0Sdq&oh=00_AYCcCTJLagTN03bf-xpjEVx7X80dalyVFQ4ZyOLPRJs71g&oe=66E2C4D4"}, {"file_name": "vrg_e003_icon.png", "id": "554821149020375", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75292491_554821152353708_2328777657735194110_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5obeXHWpIMcQ7kNvgEZgNHY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF66rcf1zG2VxxsCca