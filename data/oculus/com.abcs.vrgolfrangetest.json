=00_AYA81SJge_2K1IzKRAwXLU8TPCYEKGFL4Gyk4y656BpXyA&oe=6775411F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Aset_yoko.png", "id": "271242931731013", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036675_271242935064346_1273099338209600938_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GEJVdnp8iqoQ7kNvgFuiP7o&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCkwgPVKAOM3xdJynRSKMgGrOTCHAqdBsHLje-qu2eoLQ&oe=67750D2E"}, "display_name": "VR\u30b4\u30eb\u30d5\u30ec\u30f3\u30b8\u03b2", "keywords": [], "long_description": "\u30b4\u30eb\u30d5\u306e\u30c9\u30e9\u30a4\u30d3\u30f3\u30b0\u30ec\u30f3\u30b8\u3092\u81ea\u5b85\u3067\u4f53\u9a13\u3067\u304d\u308b\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3067\u3059\u3002\n\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u3092\u30b4\u30eb\u30d5\u30af\u30e9\u30d6\u306e\u4ee3\u308f\u308a\u306b\u6301\u3061\u30b9\u30a4\u30f3\u30b0\u3059\u308b\u3053\u3068\u3067VR\u4e0a\u3067\u3054\u81ea\u8eab\u306e\u30b9\u30a4\u30f3\u30b0\u3092\u78ba\u8a8d\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u307e\u305f\u3001\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u3092\u7df4\u7fd2\u7528\u306e\u30b4\u30eb\u30d5\u30af\u30e9\u30d6\u306a\u3069\u306b\u30bb\u30c3\u30c8\u3057\u3066\u3001\u30b9\u30a4\u30f3\u30b0\u3092\u884c\u3046\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u305d\u306e\u5834\u5408\u306f\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u306e\u4f4d\u7f6e\u8abf\u6574\u6a5f\u80fd\u3092\u5229\u7528\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\n\u73fe\u5728\u642d\u8f09\u3057\u3066\u3044\u308b\u6a5f\u80fd\n\n1. \u30c1\u30e5\u30fc\u30c8\u30ea\u30a2\u30eb\n2. \u30ec\u30f3\u30b8\u30e2\u30fc\u30c9\n   \u30fb\u30b9\u30a4\u30f3\u30b0\u30c7\u30fc\u30bf\u8868\u793a\n        \u30d8\u30c3\u30c9\u30b9\u30d4\u30fc\u30c9\n        \u66f2\u304c\u308a\u5e45\n        \u5165\u5c04\u89d2\n        \u98db\u8ddd\u96e2\n   \u30fb\u30b9\u30a4\u30f3\u30b0\u306e\u8a18\u9332\n        \u904e\u53bb10\u56de\u5206\u306e\u30b9\u30a4\u30f3\u30b0\u30c7\u30fc\u30bf\u3092\u8a18\u9332\n   \u30fb\u30b9\u30a4\u30f3\u30b0\u306e\u518d\u751f\n        \u30b9\u30ed\u30fc\u518d\u751f\n        \u9006\u518d\u751f\n        \u4e00\u6642\u505c\u6b62\n        \u30b9\u30a4\u30f3\u30b0\u30e9\u30a4\u30f3\u8868\u793a\n        \u30d5\u30a7\u30fc\u30b9\u30e9\u30a4\u30f3\u8868\u793a\n   \u30fb\u8a2d\u5b9a\u5909\u66f4\n        \u904e\u53bb\u30b9\u30a4\u30f3\u30b0\u518d\u751f(\u904e\u53bb10\u56de\u5206)\n        \u80cc\u666f\u5909\u66f4(\u5b87\u5b99/\u5927\u7a7a/\u65e5\u66ae\u308c/\u6d77)\n        \u30d5\u30a7\u30fc\u30b9\u30e9\u30a4\u30f3\u9577\u3055\u5909\u66f4\n3. \u30b2\u30fc\u30e0\u30e2\u30fc\u30c9\n   \u30fb\u98a8\u8239\u5272\n   \u30fb\u30d3\u30eb\u30bf\u30fc\u30b2\u30c3\u30c8\n   \u30fb\u30c9\u30e9\u30b3\u30f3\n   \u30fb\u30cb\u30a2\u30d4\u30f3\n4. \u30ec\u30c3\u30b9\u30f3\u30e2\u30fc\u30c9\n   \u30fb\u30b9\u30e9\u30a4\u30b9\u77ef\u6b6301\n   \u30fb\u30b9\u30e9\u30a4\u30b9\u77ef\u6b6302\n   \u30fb\u624b\u5143\u306e\u6d6e\u304d\u77ef\u6b63\n5. \u30e9\u30a6\u30f3\u30c9\u30d7\u30ec\u30a4\u30e2\u30fc\u30c9\n   \u30fbGDO\u8305\u30f6\u5d0e\u30b4\u30eb\u30d5\u30ea\u30f3\u30af\u30b9(1\uff5e9h)\n6. \u30aa\u30d7\u30b7\u30e7\u30f3\n   \u30fb\u632f\u52d5\u8a2d\u5b9a\n   \u30fb\u30af\u30e9\u30d6\u4f4d\u7f6e\u8abf\u6574\n   \u30fb\u30dc\u30fc\u30eb\u304a\u3088\u3073\u5f3e\u9053\u306e\u8272\u5909\u66f4\n7.   \u8a00\u8a9e\u5909\u66f4\n   \u30fb\u82f1\u8a9e\n   \u30fb\u65e5\u672c\u8a9e\n \n\u73fe\u5728\u958b\u767a\u4e2d\u306e\u30d0\u30fc\u30b8\u30e7\u30f3\u306b\u306a\u308a\u307e\u3059\u306e\u3067\u6f5c\u5728\u7684\u306a\u30d0\u30b0\u306a\u3069\u306b\u3064\u3044\u3066\u306f\u3054\u4e86\u627f\u304f\u3060\u3055\u3044\u3002", "short_description": "\u81ea\u5b85\u3067\u30b4\u30eb\u30d5\u7df4\u7fd2\u5834\u304c\u4f53\u9a13\u3067\u304d\u308b\u30a2\u30d7\u30ea\u30b1\u30fc\u30b7\u30e7\u30f3\u3067\u3059\u3002\n\u30b2\u30fc\u30e0\u30e2\u30fc\u30c9\u3067\u306f\u30c9\u30e9\u30b3\u30f3\u3084\u30cb\u30a2\u30d4\u30f3\u306e\u307b\u304b\u306b\u65e5\u672c\u306b\