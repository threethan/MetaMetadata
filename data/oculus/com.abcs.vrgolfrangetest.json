=67389AC4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u7121\u984c.png", "id": "502165951068157", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984473_502165957734823_1520286877948022907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ah8wlmf-Q1oQ7kNvgHg4A5c&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC59q5lASDq4KridotX-63qXu6E21K5SoaovHgS36dBTA&oe=67386A66"}, "display_name": "VRGolfRange\u03b2", "keywords": [], "long_description": "It is a application that allows you to experience the driving range of golf at home. You can check your swing on VR by holding the controller instead of the golf club and swinging. You can also set the controller on a golf club for practice and swing. In that case, use the position adjustment function of the controller.", "short_description": "An application for golf practice that can be used at home. You can keep hitting golf in the VR space, and you can objectively check your swing. This will be a beta version for testing.\n\nPlease note that this application is a beta version, so adjustments for swing and ballistic behavior have not been completed."}, {"images": {"nodes": [{"file_name": "vrg_e003_tate.png", "id": "2730464913921008", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404390_2730464917254341_5136702418237828326_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gQauPZ-pHe8Q7kNvgF5NlLF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7MM0ZhSvyNQAV_mua_8ZZUyNCjPepYCJ8V3feB4eljw&oe=67387654"}, {"file_name": "vrg_e003_icon.png", "id": "554821149020375", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75292491_554821152353708_2328777657735194110_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1t5tEEhzZ7UQ7kNvgGOEUeG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwOrTH2txmOJeauRlw4XxydE9CmzdHZPKs03CaYzSEtw&oe=67389070"}, {"file_name": "vrg_e003_yoko.png", "id": "52220601