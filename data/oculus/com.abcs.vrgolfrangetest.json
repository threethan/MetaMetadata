=6756ED44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u7121\u984c.png", "id": "502165951068157", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984473_502165957734823_1520286877948022907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wk3nRVWQWqQQ7kNvgGrYLVP&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAc6WTdGuHlqjo4-bcTTQsGGEC42GmV2qhkxVTdoguZVQ&oe=6756F526"}, "display_name": "VRGolfRange\u03b2", "keywords": [], "long_description": "It is a application that allows you to experience the driving range of golf at home. You can check your swing on VR by holding the controller instead of the golf club and swinging. You can also set the controller on a golf club for practice and swing. In that case, use the position adjustment function of the controller.", "short_description": "An application for golf practice that can be used at home. You can keep hitting golf in the VR space, and you can objectively check your swing. This will be a beta version for testing.\n\nPlease note that this application is a beta version, so adjustments for swing and ballistic behavior have not been completed."}, {"images": {"nodes": [{"file_name": "vrg_e003_tate.png", "id": "2730464913921008", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75404390_2730464917254341_5136702418237828326_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIW6UzZhmzEQ7kNvgHe3xtX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBtPQ5TK59-Qk-X_6Q7SL1ID8XkHCU8k9il-OvDjRyfjA&oe=6756C8D4"}, {"file_name": "vrg_e003_icon.png", "id": "554821149020375", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75292491_554821152353708_2328777657735194110_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y2rkKB6mVE0Q7kNvgFRTN8w&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDKDHb73dGt2dR7N2Q_gBWRqMrdin_ITOIU1jBnJlhMxA&oe=6756E2F0"}, {"file_name": "vrg_e003_yoko.png", "id": "52220601