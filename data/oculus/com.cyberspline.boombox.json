Oculus_boombox_07.png", "id": "829233271002870", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031447_829233274336203_7324596943547983816_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kw6JWFvvfW4Q7kNvgHtZFmC&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBQsNd89j0VAMKgH0d51TyrvM4w39255pFXMuRPOwt__Q&oe=6787A7A3"}, {"file_name": "Screenshot_Oculus_boombox_01.png", "id": "297614208635347", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974453_297614211968680_7572329790472234101_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=96YW62flLbUQ7kNvgFa2AXA&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCZ7ZSn5S-_9HYvDzJT8QXe2Zpqi4mWj7e7bqdGJ7EjBA&oe=6787A794"}, {"file_name": "Screenshot_Oculus_boombox_03.png", "id": "130023162439690", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031588_130023165773023_1862225796012215510_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bpvRlRbnv4UQ7kNvgEubite&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCpLTR6z3XPlp_6greD1CUdo81Hq1YSCVeDVKUsL-ZZbw&oe=67878F86"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Boombox_LandscapeCover.png", "id": "1107005586451932", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031467_1107005589785265_4266724434786440435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V2ANyQiWLYsQ7kNvgFBU6mg&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDi4aQq0lyNydlUiMxNV31KkpQkJLyExkiEAVhg81GstA&oe=6787B156"}, "display_name": "BoomBox", "keywords": [], "long_description": "In BoomBox you can challenge yourself through sequences of interactable objects and obstacles, improving your skill as you conquer levels of varying difficulty. Customize the gameplay to your liking: it could be a fitness routine, a dance fest, or a method to improve your drumming skills. You don\u2019t just play within the confines of the game - you make the game! Use your creativity and think outside the box, designing new maps through the intuitive editor. Exercise, play, and compete on the global leaderboard to be the next champion!\n\nFeatures:\n1. Pre-cleared 150 Camellia songs and 100 FiXT songs for our community to create, share and stream their own maps officially\n2. 14 unique designed environments to adventure through\n3. Editor\n4. Local and Global Leaderboards: compete with players from all over the world\n5. Meet Pupa: our lovely kitty will be part of your amazing adventures, don't forget to pet her!", "short_description": "BoomBox is an intense VR Rhythm Game featuring a large catalogue of high-energy songs and a variety of colourful environments. Exercise, play and compete on the global leaderboard while beating drums and dodging obstacles. Feeling creative? You can design new maps through our intuitive editor which already offers more than 250 official songs! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.boomboxvr.com/wpautoterms/121-2/", "developer_terms_of_service_url": null, "publisher_name": "Cyberspline Games Inc", "support_website_url": null, "website_url": "https://www.boomboxvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ACTION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1013778196216460"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "510964756710684"}, {"status": "PENDING", "id": "274488031703262"}, {"status": "PUBLISHED", "id"