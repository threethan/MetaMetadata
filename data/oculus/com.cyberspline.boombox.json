4319"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "783574672552805"}]}, "change_log": "Fixed the issue with emotes only being visible in 1 eye during multiplayer.\nFixed emotes spawn in multiplayer during gameplay.\nNew feature: during multiplayer, players can now select the ready status only once and it will stay until they manually change.\nUpgrade the version of Unity to 2021.\nUpdated Bhaptics SDK.\nBug fixing for multiple minor issues.", "created_date": 1687882183, "id": "6458098310899808", "version": "3.1.8", "version_code": 318, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3983480868361577", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6606553186054319"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "783574672552805"}]}, "change_log": "- Fix pointer in multiplayer", "created_date": 1675932627, "id": "6002645856445058", "version": "3.1.1", "version_code": 311, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3983480868361577", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6606553186054319"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "783574672552805"}]}, "change_log": null, "created_date": 1670524792, "id": "5802567136452932", "vers