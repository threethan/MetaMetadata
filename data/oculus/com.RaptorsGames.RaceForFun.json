7", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031630_531887457829603_6118855794228179942_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ENIgjgjg1WgQ7kNvgFfnXJR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZfrlRAHZcWcHV1sisUu0hO9-a2dpzW4vKQFJ-oq67oQ&oe=6717A6D0"}, "display_name": "Race For Fun", "keywords": [], "long_description": "Race for fun is an arcade game in time attack mode. Enjoy the ride, upgrade your driving skills, fight with users for the best lap time. Each car has its own characteristics. Unique trails have different levels of difficulty.\n\nNot matter if you are a beginner or a pro. But if you like car racing, this game is for you.  Realistic driving and a first-person view will give you an unforgettable driving experience.\n\n- 10 tracks different levels of difficulty (5 for now)\n- 10 cars for any taste (5 for now)\n- Realistic car control \n- First and third person views\n\n- Free ride track (in future update)\n- Ghost racing mod  (in future update)\n- Leaderbord  (in future update)", "short_description": "Race for fun is an arcade game in time attack mode. Enjoy the ride, upgrade your driving skills, fight with users for the best lap time. Each car has its own characteristics. Unique trails have different levels of difficulty."}]}, "developer_name": "Kaplunov Yurii", "developer_privacy_policy_url": "http://raptorsgames.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Raptor`s Games", "support_website_url": null, "website_url": "http://raptorsgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": nu