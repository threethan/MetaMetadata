m/v/t64.5771-25/12410280_628999510783130_6008484673863286784_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZVvOpx4WApgQ7kNvgHqYLPi&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDYGdjZ1IC_i3Vt2fvN-AD42ltlAFlfQfDoStIgxmNgMA&oe=677E7A13"}, {"file_name": "migrated_image.png", "id": "498569274154329", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/12427628_627900814242763_130658591681019904_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Ru8w6avJrwQ7kNvgEVpvPQ&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAWbv7sKPsLp7JMzYUMczD8zlVtR5p2rzV3-Y7u0VrGCw&oe=677E55CE"}, {"file_name": "migrated_image.png", "id": "1634703596687374", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/12386401_1261150720683349_246784972537462784_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCZFqy5zwM4Q7kNvgG0BTlH&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBAGd_sAVJB8oD_hnDFxoNcc9rxGYSy7pU03qEdwKPX0A&oe=677E4E6F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NSAF_2560x1440.png", "id": "166618027353559", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/12504788_166618030686892_5236600667618934784_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3RAPk823uM0Q7kNvgHsE4cD&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAvhsU0D-CB5sklauzT_mehG50ojkjtm-3xiMwUWBwDsg&oe=677E58F0"}, "display_name": "NeuroSpeculative Afrofeminism", "keywords": ["scifi", "neuroscience", "future", "narrative", "hyphenlabs"], "long_description": "NeuroSpeculative AfroFeminism is a possible future told through speculative objects, virtual reality and cognitive investigation.  Experience the narrative that combines neuroscience and black hair rituals. Hyphen-Labs places you in a \u201cneurocosmetology lab\u201d where Brooks, the main character, CEO, Principal Investigator and pioneer of brain optimization technology (b.o.t.) is fitting her customers with transcranial electrodes. Brooks welcomes the viewer into her brain salon where she is testing this technology and helping her newest client experience an optimized future in virtual reality.", "short_description": "NeuroSpeculative AfroFeminism is a multi-layered possible future that transcends the constraints of the present told through speculative object design, virtual reality, and cognitive research. Join Brooks' movement as she challenges the boundaries of perception."}]}, "developer_name": "Hyphen-Labs", "developer_privacy_policy_url": "http://www.hyphen-labs.com/assets/-hyphen-labs--privacy-policy.pdf", "developer_terms_of_service_url": "http://www.hyphen-labs.com/assets/-hyphen-labs--terms-of-service.pdf", "publisher_name": "Hyphen-Labs", "support_website_url": null, "website_url": "http://www.hyphen-labs.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "361943225403178"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2029559837077490", "version": "0.8.1"}, "id": "300845793781942", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1934075829959225", "is_concept": false, "latest_released_binary":