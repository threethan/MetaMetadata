=6e7a0a&_nc_ohc=WxSUD-bWpqkQ7kNvgHssLLB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3-sL1KZtXdnQlcvzrMo0zTcHyg1hm9Ma23HpryKLkPQ&oe=6707D313"}, {"file_name": "migrated_image.png", "id": "498569274154329", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12427628_627900814242763_130658591681019904_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MmXujN4ggx0Q7kNvgGa0boD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSEQUNpNI0PHeWRfsHZd_QY-b6SoPk4f6-U3BP19KAwQ&oe=6707AECE"}, {"file_name": "migrated_image.png", "id": "1634703596687374", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12386401_1261150720683349_246784972537462784_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvIGbzaBU4wQ7kNvgEMXFzB&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpvuKRR5LXD7-I-JrlE3kt9IaoRij2bZn68lRhD1Y-EA&oe=6707A76F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NSAF_2560x1440.png", "id": "166618027353559", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12504788_166618030686892_5236600667618934784_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFqkudA5elMQ7kNvgHeOVix&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC21hPLe1a_X1Ys_pgW8xyKqQtyMdO3HBbr6HyPg3r34A&oe=6707B1F0"}, "display_name": "NeuroSpeculative Afrofeminism", "keywords": ["scifi", "neuroscience", "future", "narrative", "hyphenlabs"], "long_description": "NeuroSpeculative AfroFeminism is a possible future told through speculative objects, virtual reality and cognitive investigation.  Experience the narrative that combines neuroscience and black hair rituals. Hyphen-Labs places you in a \u201cneurocosmetology lab\u201d where Brooks, the main character, CEO, Principal Investigator and pioneer of brain optimization technology (b.o.t.) is fitting her customers with transcranial electrodes. Brooks welcomes the viewer into her brain salon where she is testing this technology and helping her newest client experience an optimized future in virtual reality.", "short_description": "NeuroSpeculative AfroFeminism is a multi-layered possible future that transcends the constraints of the present told through speculative object design, virtual reality, and cognitive research. Join Brooks' movement as she challenges the boundaries of perception."}]}, "developer_name": "Hyphen-Labs", "developer_privacy_policy_url": "http://www.hyphen-labs.com/assets/-hyphen-labs--privacy-policy.pdf", "developer_terms_of_service_url": "http://www.hyphen-labs.com/assets/-hyphen-labs--terms-of-service.pdf", "publisher_name": "Hyphen-Labs", "support_website_url": null, "website_url": "http://www.hyphen-labs.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "361943225403178"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2029559837077490", "version": "0.8.1"}, "id": "300845793781942", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1934075829959225", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "2029559837077490"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [