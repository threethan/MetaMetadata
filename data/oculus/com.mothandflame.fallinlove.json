6e7a0a&_nc_ohc=f6hDyaVwXYwQ7kNvgGGjf4R&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHnOKAIhqiInSIYy0A1XvRhtlcDwGE0DTkzgoVo5-wXw&oe=66D2F007"}, {"file_name": "migrated_image.png", "id": "600920153795567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162707_880211035466454_2379392434372083712_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-6lvQJQX_T0Q7kNvgFEtY9S&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEQb7-YDZ0F2Wqncnx6TU7jGXAErv_zxct_W7bneQjUg&oe=66D2FA3C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fall In Love", "keywords": [], "long_description": "EXPERIMENTAL BETA MODE\n\nHEADPHONES WITH MICROPHONE REQUIRED\n\nFalling in love is one of the most intoxicating human experiences. Inspired by \u201cThe 36 Questions that Lead to Love,\u201d the goal of Fall In Love is to foster authentic human conversation in VR and to inspire people to feel an emotional connection with others. People will put on a headset and be transported to a whimsical forest where they come face to face with a group of actors, who they can then have a conversation with through voice recognition software.", "short_description": "EXPERIMENTAL BETA MODE\n\nHEADPHONES WITH MICROPHONE REQUIRED\n\nThe goal of Fall In Love is to foster authentic human conversation in VR and to inspire people to feel an emotional connection with others. Through the power of technology, Fall in Love is a groundbreaking new format for storytelling and the next evolution of virtual reality filmmaking."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.trenchphysics.com/MothAndFlame/privacy_policy.html", "developer_terms_of_service_url": "http://www.trenchphysics.com/MothAndFlame/terms_and_conditions.html", "publisher_name": "Tool of North America", "support_website_url": null, "website_url": "http://www.toolofna.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_s