A0F1"}, {"file_name": "sgtgsg.png", "id": "1169207307494556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036668_1169207310827889_968131676387905948_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=acAlaxj8dacQ7kNvgFszYT7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeqRd7Z4qiAbeu6VcRQyl5wgtVkZWLCPLW1PMpqoLgNQ&oe=66D1A0A2"}, {"file_name": "rggdgsrsgsdrsgs.png", "id": "3671853096466030", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982683_3671853099799363_5682741748118183857_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EkdS1F-MH-IQ7kNvgE3xZHb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKdN4OkRe1b-Z54yUHCiYLMk5E4IJ6e7i5hUi5iBKY4w&oe=66D19C14"}, {"file_name": "dwaaddawd.png", "id": "999759545158832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75326677_999759548492165_8606905017932034748_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iZvzJNs4-rkQ7kNvgE2MoQ3&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2BtbJjEgOYoKjo55mvc6nQfINmJeBgLt5_x--3Porgw&oe=66D1A1CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Offical_Nurba_paper.png", "id": "1038429807999916", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982711_1038429811333249_717512346829026427_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BRj7B4drfWoQ7kNvgEXzO0W&_nc_ht=scontent.oculuscdn.com&oh=00_AYBoFc85hXizcYoAvO2w3wOj2OfIiZqBBa3irEXwksevPw&oe=66D1B30E"}, "display_name": "Nurba!", "keywords": [], "long_description": "Different Modes:\n\nNURBA, has different modes to play on, each of these modes have a unique goal.\nThese modes will have different outcomes, different playability. It all comes down to you to find a way to survive against the unknown.\nThese things will different, every mode will have a different goal. The goal is survival, but the way to survive is up to YOU!\n\nNew Updates:\n\nThese updates may change Nurba!, and make the game have a whole new perspective. Many of these update will bring new modes, items, and bring in new stuff for the community. These updates will change the game. We are still in development. You may see stuff that you don't expect to see.\n\nOne of a Kind Movement:\n\nIn Nurba! the movement isn't gorilla tag movement, it's a grip and pull movement to make running from monsters more fun!\n\nCommunity Member:\n\nJoin us today, become a member of the Nurba community or as we like to call it \"Project Nurba!\" See you soon, if you decide to join! It's up to YOU!", "short_description": "NURBA, has different modes to play on, each of these modes have a unique goal.\nThese modes will have different outcomes, different playability. It all comes down to you to find a way to survive against the unknown.\nThese things will different, every mode will have a different goal. The goal is survival, but the way to survive is up to YOU!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/b1edc116-dd05-4185-be29-2543cee9f92f", "developer_terms_of_service_url": null, "publisher_name": "Uwwomp", "support_website_url": null, "website_url": "https://sites.google.com/view/nurbastudios/home?authuser=2", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7580804078684482"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "334479142929876"}]}, "baseline_offer": {"id": "334479142929876"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722116785, "status": "PUBLISHED", "id":