cdn.com/v/t64.5771-25/39031449_447960566327550_2570250723340468387_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vkFKdRnSgIcQ7kNvgG9PlFW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQqNIYGB2NZ5bBqj-pvkGLu&oh=00_AYBsf_Z-3pVlNkoOBMLg9DO6hTU3PMkM0iIs6rK9bKO_dA&oe=66F00EFB"}, {"file_name": "Thunderbowl_mobile_a_graded.png", "id": "852519222146330", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982479_852519225479663_571832277572193096_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lnU5TCWIk8YQ7kNvgFSqz-g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQqNIYGB2NZ5bBqj-pvkGLu&oh=00_AYBgcoPLaVC1Fwm4u_d7HVUNS-AKM65eV3w9Ae5B2mHOMQ&oe=66EFFF29"}, {"file_name": "TankAimsMech_a.png", "id": "458075268675195", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_458075272008528_7089785448570377502_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mDg1HIxSKggQ7kNvgEQJuy_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQqNIYGB2NZ5bBqj-pvkGLu&oh=00_AYAa8GOCyYc00yMc48zomLhY3m6-iJzDMfibD_HEN-16Rg&oe=66F00805"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VZplay_trailer_a_thumb.png", "id": "356166702173989", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982715_356166705507322_1049771624748125068_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grHCRgw_ccYQ7kNvgHcKfJT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQqNIYGB2NZ5bBqj-pvkGLu&oh=00_AYATzS_UCDgFtHFwWW5wbQVvI3yx2NDJzZ7Mh-r2ibEOvA&oe=66EFF9AA"}, "display_name": "VZplay", "keywords": [], "long_description": "Say goodbye to your boring workout! VZplay is an add-on collection of arcade-style games for existing VZfit subscribers*.\n\nPedal faster to move faster in the game. Turn your head to aim your tank's cannon. Lean to weave between cyclists. Play with friends online, sync with Fitbit, and more.\n\nUse with a number of smart bikes, trainers, and cadence sensors, available from online retailers.\n\n*Requires a VZfit subscription.  Search for \u201cVZfit\u201d in the Oculus Store to get started.", "short_descr