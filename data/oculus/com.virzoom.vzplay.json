 subscribers*.\n\nPedal faster to move faster in the game. Turn your head to aim your tank's cannon. Lean to weave between cyclists. Play with friends online, sync with Fitbit, and more.\n\nUse with a number of smart bikes, trainers, and cadence sensors, available from online retailers.\n\n*Requires a VZfit subscription.  Search for \u201cVZfit\u201d in the Oculus Store to get started."}]}, "developer_name": null, "developer_privacy_policy_url": "https://virzoom.zendesk.com/hc/en-us/articles/360056428751", "developer_terms_of_service_url": "https://virzoom.zendesk.com/hc/en-us/articles/360056435331", "publisher_name": "VirZOOM, Inc.", "support_website_url": "https://vzfit.com/help", "website_url": "https://vzfit.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6345654662163311"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982456_787823741867013_7717071954952996218_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FrA5BAEkBkIQ7kNvgHhutg9&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDRSbFV8DFm7yCqKHlOMRkCdGFmMJonu6ps1JbntPOP7g&oe=6758263B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VZplay", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326