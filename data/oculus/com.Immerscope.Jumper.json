516_1623240171434662_2066721547793735535_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lf93qZkOctgQ7kNvgHJFO0f&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYC2IGqAy_xQ88AnmqC_yHpPK77q77NYz3kD0wAGBDxyxA&oe=6712336C"}, {"file_name": "Screenshot_Image4.png", "id": "735897284966798", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39031309_735897291633464_8248577039852668559_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MDkxhrAQ_ywQ7kNvgFJlghQ&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAXLLsii8Lwrh7yX_n1CeSqlqavszyplwXEamxreYTnsQ&oe=67125052"}, {"file_name": "Screenshot_Image5.png", "id": "306352228453101", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982575_306352235119767_1179650224465803718_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUl_MMfTwxoQ7kNvgHsl4qo&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAG0Y1Es5-t3QZxfV_RBfpGiMZeoaTmviJGzov0-RJFAg&oe=67126137"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "792514172662226", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974493_792514175995559_5929871910118818486_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zWFpuKqTX5EQ7kNvgGAbOkF&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCdb5mYnEnoTnYxrwcddJ63PpLreKOeX9Ag1m2E4TMabA&oe=67125DF6"}, "display_name": "Velocity Rush", "keywords": [], "long_description": "Velocity Rush is tailor-made for players seeking a seamless and user-friendly VR encounter with single input control that makes it effortless to jump right into the action. You'll find yourself swiftly maneuvering through high-speed scenarios, weaving through obstacles, and making split-second decisions that test your reflexes and wits.\n\nKey Features:\n- Simplicity in Action: Experience the thrill with just one input: jump, making the game easy to play for everyone.\n- Motion Sickness-Free: Ensuring a smooth and comfortable experience for all players.\n- Accessible Yet Challenging: Whether you're a casual player or a seasoned expert, Velocity Rush offers enjoyment for all while presenting a rewarding challenge for those seeking mastery.\n- Handcrafted Wonder: Each stage presents new hurdles and complexities, that immerse you in stunning virtual worlds.\n", "short_description": "Dive into the virtual realm of Velocity Rush, a VR platform game that delivers a thrilling experience that is both easy to pick up and intensely challenging. Unleash your inner speedster as you navigate through thrilling levels, all while enjoying a motion sickness-free adventure in the immersive world of Velocity Rush."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immerscope.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immerscope", "support_website_url": null, "website_url": "https://www.immerscope.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1462603794509558"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1517984932283970"}, {"status": "PUBLISHED", "id": "727301342601237"}]}, "baseline_offer": {"id": "727301342601237"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1691516438, "status": "PUBLISHED", "id": "1517984932283970"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test