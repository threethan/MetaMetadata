/t64.5771-25/11162741_1843988669247974_2229283872837730304_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iKG-cIjgl2QQ7kNvgF_hgYu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmaMk0MGnJrV03MNI5gzS-WBuTeOYEnQazoGPJSMt-ug&oe=67792FF4"}, {"file_name": "migrated_image.png", "id": "2509715422675297", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162679_270036033488815_1950632033965309952_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lLIAD2pEAKYQ7kNvgHAYusX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4NapqGjDufLle2TnZwakhnWI7Lb0HP2LdSJen5yIOjw&oe=677906D2"}, {"file_name": "migrated_image.png", "id": "837045673447443", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162717_1939496932991450_7612317885590929408_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2dY_ww-wjdMQ7kNvgFdHbwu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCA64ALJSctXbiaJYWvz_LU4qSu4uuMqNGHov8Lp4FIFg&oe=67792937"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_trailer_DoD.png", "id": "1815286671821896", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162732_1815286675155229_8777384002932703232_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i7DcWYPpcOQQ7kNvgGji5DU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA998kuKzAhGMRyTyibGo65BIfuxgw0zZTEIje15c46QQ&oe=67793670"}, "display_name": "Doors of Silence - the prologue", "keywords": ["horror", "exploration", "adventure", "survival", "escape"], "long_description": "From one of the best-known and more horrifying experiences for VR (best choice for Upload VR, GeorgeTown\u2019s Gelardin Media Center and TheRiftArcade) that has collected millions of views on youtube, The Prologue was born as the first episode of a new horror saga: Doors of Silence.\nDeveloped with Unreal Engine 4, DoS-The Prologue is an immersive survival horror for Gear VR, with stunning graphics and a long term gameplay featuring exploration, stealth, puzzles and interaction.\n\nYou wake up and find yourself in what looks like a nightmare. You have no recollection of where you are or who you are. Hide yourself from the evil entities and find out who you are and the secrets that lie in the underground bunkers and labs of this dark place.\n\nWARNING: this game use some JUMP SCARES", "short_description": "From one of the best-known and more horrifying experiences for VR (best choice for Upload VR, GeorgeTown\u2019s Gelardin Media Center and TheRiftArcade) that has collected millions views on youtube, The Prologue was born as the first episode of a new horror saga: Doors of Silence.\nDeveloped with Unreal Engine 4, DoS-The Prologue is an immersive survival horror for Gear VR, with stunning graphics and a long term gameplay featuring exploration, stealth, puzzles and interaction."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doorsofsilence.com/", "developer_terms_of_service_url": "https://doorsofsilence.com/", "publisher_name": "Blackbite Interactive", "support_website_url": null, "website_url": "https://doorsofsilence.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["HORROR", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "648144019559444"}}]}, "scheduled_offers": {"count": 59, "nodes": [{"status": "PUBLISHED", "id": "142240599731544"}, {"status": "PUBLISHED", "id": "215957802884820"}, {"status": "PUBLISHED", "id": "362531074184148"}, {"status": "PUBLISHED", "id": "1299226153614557"}, {"status": "PUBLISHED", "id": "1911670739153274"}, {"status": "PUBL