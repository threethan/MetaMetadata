WrG&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB_d1lKq-zKalqT4s08I-8H10BQ9YUAypx71PMMY6VgGg&oe=6710E75A"}, {"file_name": "screenshot_4.png", "id": "649156249920749", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974538_649156253254082_887860956994039358_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UljgLyz6bUIQ7kNvgFmmPDN&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC__c7y98hujvwrBXQx6TFUoSfAe8-1Wt4MJ230JALjbw&oe=6710E8E8"}, {"file_name": "screenshot_8.png", "id": "670213597500959", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75295751_670213600834292_2130503957943111885_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lEqIb_NxAMcQ7kNvgHoxn1f&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCRIJM-GFPo-GiHVNL4EXwlIm8-VGUTS-5YOf8Ug2nRNA&oe=671102C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QPP_CrisisBrigade2_Trailer_thumb.png", "id": "1532238350574399", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982564_1532238353907732_836246990000836504_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yu2-lzJE0lIQ7kNvgEL6TI6&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC8AjIn6ZNXIX7ybSVH8CNrO_5APH5b1VpUXM3yv29UBQ&oe=6710EEE4"}, "display_name": "Crisis Brigade 2 reloaded (AppLab)", "keywords": [], "long_description": "The streets are being overrun...\n\nYou have been handpicked as one of the elite few to go on high-risk missions and save the city. You're authorized to take down the enemy at any means possible.\n\nOn your six! Take cover!\n\nCrisis Brigade 2 reloaded is about covering, pointing and shooting, fast-paced pure action. Intense shootouts, powerful weapons, challenging levels, fierce enemies... Like the 90's classic arcade machines, but with the immersion that Virtual Reality is capable of.\n\n---> Co-op multiplayer mode available <---\n\n\u2022 Leaderboards\n\u2022 Intense physical gameplay.\n\u2022 Fight through a variety of realistic scenarios.\n\u2022 4 difficulty levels.\n\u2022 Awesome boss battles.\n\u2022 Lots of different weapons.\n\u2022 Collect and unlock upgrades to equip before the battle.\n\u2022 Choose your weapon and player skins.\n\nWe\u2019ll see you on the other side, soldier...", "short_description": "The streets are being overrun...\n\nYou have been handpicked as one of the elite few to go on high-risk missions and save the city. You're authorized to take down the enemy at any means possible.\n\nOn your six! Take cover!\n\nCrisis Brigade 2 reloaded is about covering, pointing and shooting, fast-paced pure action. Intense shootouts, powerful weapons, challenging levels, fierce enemies... Like the 90's classic arcade machines, but with the immersion that Virtual Reality is capable of."}]}, "developer_name": null, "developer_privacy_policy_url": "http://crisisbrigade.com/eula.html", "developer_terms_of_service_url": "http://sumalab.com/crisisvrigade/eula.html", "publisher_name": "Sumalab", "support_website_url": null, "website_url": "http://crisisbrigade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "649569173223325"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001661_3349525252039903_4213472784846807008_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4qp