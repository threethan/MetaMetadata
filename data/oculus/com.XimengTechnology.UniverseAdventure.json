//scontent.oculuscdn.com/v/t64.5771-25/75234368_393692699739385_7262805832621689913_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WA5M4LKcpqgQ7kNvgHboW6i&_nc_ht=scontent.oculuscdn.com&oh=00_AYASHEnx1DZsP0J2pSMgaeWRfKDBHft9FDGl5r4Li1KAkg&oe=66DAF403"}, {"file_name": "1.png", "id": "1107516557075533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_1107516560408866_873680861029651081_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UkI9CnK5ekAQ7kNvgFVI0U_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbu7dKIf631iYnSxx7aYioLtxAdf1d3eoqoLnid-LADg&oe=66DAF327"}, {"file_name": "3.png", "id": "915138216199286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_915138219532619_2286672816335369528_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aQFtmsASeIEQ7kNvgGHTOif&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcakjkDR4s_5yqMEyHu1dUrRGQmZfBQnI3QWOut_h5QA&oe=66DAD60F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "335199506136292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982723_335199509469625_7225261497215625725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABqyCFhxM8UQ7kNvgEZ88o2&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlq-lvkRvyj5UbsrEZzFFIOcYJN7VlkEkGkkrAJzM1VQ&oe=66DACC6D"}, "display_name": "BlastarVR(Hand Tracking)", "keywords": [], "long_description": "Welcome to the magnificent universe!  \n\nIn this game, you will confront various monsters in different vibrant cosmic settings!  The game creator, being a fan of Elon Musk, has incorporated elements related to the idol.  Welcome fellow Elon fans to appreciate together! \n\nIn the face of colossal creatures scattered throughout the vast universe, unleash your array of hand gesture-recognized weapons and engage in exhilarating battles!  Victory shall belong to the brave warriors!  \n\nIn the game, you have over forty weapons recognized through hand gestures at your disposal.  Each weapon possesses its own unique characteristics.  You can freely switch between various guns, knives, scepters, magic orbs, and more.  You can even pick up different planets as your new weapons.  Once you become familiar with them, you will experience the special excitement of gesture recognition games!  \n\nLet's embark on a thrilling adventure through the dreamlike cosmos together!", "short_description": "This is a gesture recognition game set in space where you fight against monsters. In the game, you can utilize over forty different hand gesture-recognized weapons! Each weapon has its own unique characteristics. You can freely switch between various guns, knives, scepters, magic orbs, and more. Once you become familiar with them, you will experience the novelty and fun of gesture recognition games!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://43.153.110.240:8888/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Sophia Song", "support_website_url": null, "website_url": "http://43.153.110.240:8888/home.html", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8138586182858866"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75411994_293164350392129_6311987748919434711_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JM