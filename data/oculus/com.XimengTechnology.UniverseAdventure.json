37_2497790981322490000_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPA0by7bjsAQ7kNvgFoDDm4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDKk65u4yTzyH_010wVUXp&oh=00_AYCwDxkKcDwN3v3DdfWQOI236BB7bZcoth7gtEqzNm8drw&oe=66D83139"}, {"file_name": "2.png", "id": "393692696406052", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234368_393692699739385_7262805832621689913_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xAbq2WzPpfwQ7kNvgH-eKyj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDKk65u4yTzyH_010wVUXp&oh=00_AYDdkuUhI6TOM6dNUZ5KKteniAP6rZz2vR_aD5q9uzT9rg&oe=66D85103"}, {"file_name": "1.png", "id": "1107516557075533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_1107516560408866_873680861029651081_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HpFNRcSanr0Q7kNvgEJaWoF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDKk65u4yTzyH_010wVUXp&oh=00_AYCrZ1VbYplphlFVC4OTGw3kOHqyuHskUolTu5qIuUc4dQ&oe=66D85027"}, {"file_name": "3.png", "id": "915138216199286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_915138219532619_2286672816335369528_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4m3QDIY9nd8Q7kNvgE_eWoJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDKk65u4yTzyH_010wVUXp&oh=00_AYC_WbCNFXInjf1AQZCnYynlc1ihaUgJZxmXu6YpQM8M6w&oe=66D8330F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560_1440.png", "id": "335199506136292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982723_335199509469625_7225261497215625725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABqyCFhxM8UQ7kNvgEzc0bR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDKk65u4yTzyH_010wVUXp&oh=00_AYA205wSARkAqyOrtN19_1-s1ek4thjeJLGGUxs-JyNtTg&oe=66D8296D"}, "display_name": "BlastarVR(Hand Tracking)", "keywords": [], "long_description": "Welcome to the magnificent universe!  \n\nIn this game, you will confront various monsters in different vibrant cosmic settings!  The game creator, being a fan of Elon Musk, has incorporated elements related to the idol.  Welcome fellow Elon fans to appreciate together! \n\nIn the face of colossal creatures scattered throughout the vast universe, unleash your array of hand gesture-recognized weapons and engage in exhilarating battles!  Victory shall belong to the brave warriors!  \n\nIn the game, you have over forty weapons recognized through hand gestures at your disposal.  Each weapon possesses its own unique characteristics.  You can freely switch between various guns, knives, scepters, magic orbs, and more.  You can even pick up different planets as your new weapons.  Once you become familiar with them, you will experience the special excitement of gesture recognition games!  \n\nLet's embark on a thrilling adventure through the dreamlike cosmos together!", "short_description": "This is a gesture recognition game set in space where you fight against monsters. In the game, you can utilize over forty different hand gesture-recognized weapons! Each weapon has its own unique characteristics. You can freely switch between various guns, knives, scepters, magic orbs, and more. Once you become familiar with them, you will experience the novelty and fun of gesture recognition games!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://43.153.110.240:8888/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Sophia Song", "support_website_url": null, "website_url": "http://43.153.110.240:8888/home.html", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKIN