dn.com/v/t64.5771-25/75500282_199687632888431_8812303436834920540_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VoxM8mXzJ6MQ7kNvgFuBqbW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCKo5LiXkxxvJOFXb_TWRyy1Nwj4aAOV5g5-bIi-qn58g&oe=67012353"}, {"file_name": "vlcsnap-2023-05-12-17h32m49s168.png", "id": "1302110007329863", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75367593_1302110010663196_8023239998264300795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6SBUzJqpyIYQ7kNvgGrAJdJ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCkmDMnmNKkRPNNckfYy_W384ULVNNxzGkcMj8kiOxwSw&oe=670122EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-2.png", "id": "184095404525465", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974552_184095407858798_2973736126209893403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B5tKhkA3q0sQ7kNvgFtZly0&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBHX-IuKAbxGtspU2dVeDgD-NNm42yF4tpBQn-JtHA-jg&oe=6701142E"}, "display_name": "Battle Talent", "keywords": ["physics", "mod", "sword", "rogue", "melee"], "long_description": "Tired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time.\n\nBattle Talent brings physics driven creatures come to life with advanced physics simulation. You'll get to epic boss battles like you've never experienced before.\n\nFeatures:\n- Thrill of the hack-and-slash\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Variety of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n- Boss melee fight in VR\n- Sandbox & parkour\n", "short_description": "Battle Talent is a physics-based sword fighting game with rich roguelite elements in a fantasy world. \nTired of fighting boring enemies? Battle Talent has created for 