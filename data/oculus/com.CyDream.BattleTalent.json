ow&oe=6762AEBE"}, {"file_name": "vlcsnap-2023-05-12-14h48m38s855.png", "id": "199687629555098", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75500282_199687632888431_8812303436834920540_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HImQA4ghtKYQ7kNvgGBWkxt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn1y-i8TAN7n_0xkOl4VEwqUOfgkzXXQ6TeNxoYWjlkw&oe=6762B253"}, {"file_name": "vlcsnap-2023-05-12-17h32m49s168.png", "id": "1302110007329863", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367593_1302110010663196_8023239998264300795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Em4ypLxVyeIQ7kNvgFXbHyU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAq5tvara4cVf4mI7fSWxAGxb78XWJKUfvfz3-ZH9OWw&oe=6762B1EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-2.png", "id": "184095404525465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_184095407858798_2973736126209893403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LDGKJsxXrCEQ7kNvgEh6vW_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8af_typIYIv8b3vW-lMJoUYxW9tU5ieDgsQI7GURmaA&oe=6762A32E"}, "display_name": "Battle Talent", "keywords": ["physics", "mod", "sword", "rogue", "melee"], "long_description": "Tired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time.\n\nBattle Talent brings physics driven creatures come to life with advanced physics simulation. You'll get to epic boss battles like you've never experienced before.\n\nFeatures:\n- Thrill of the hack-and-slash\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Variety of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n- Boss melee fight in VR\n- Sandbox & parkour\n", "short_description": "Battle Talent is a physics-based sword fighting game with rich roguelite elements in a fantasy world. \nTired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cydream.tech/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "CyDream", "support_website_url": null, "website_url": "https://cydream.tech/battletalent.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "211836104775365"}}]}, "scheduled_offers": {"count": 21, "nodes": [{"status": "PUBLISHED", "id": "907840370897977"}, {"status": "PUBLISHED", "id": "958848055914325"}, {"status": "PUBLISHED", "id": "1273120184094389"}, {"status": "PUBLISHED", "id": "1014148336678614"}, {"status": "PENDING", "id": "2290326101167864"}, {"status": "PUBLISHED", "id": "685223429698705"}, {"status": "PENDING", "id": "229536250057662"}, {"status": "PUBLISHED", "id": "755124776282709"}, {"status": "PUBLISHED", "id": "499084338992952"}, {"status": "PENDING", "id": "884491419918420"}, {"status": "PENDING", "id": "2370009909837702"}, {"status": "PENDING", "id": "974046320333824"}, {"status": "PENDING", "id": "851906726728953"}, {