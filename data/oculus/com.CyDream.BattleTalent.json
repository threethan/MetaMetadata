8U3A&oe=66FE8053"}, {"file_name": "vlcsnap-2023-05-12-17h32m49s168.png", "id": "1302110007329863", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367593_1302110010663196_8023239998264300795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=495MbmoA4DkQ7kNvgGjU7eC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAglqxxJqB5M-68Xgj-ddvkgnrOgGnEaZ5N3m2tSFTjfg&oe=66FE7FEF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-2.png", "id": "184095404525465", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974552_184095407858798_2973736126209893403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B5tKhkA3q0sQ7kNvgExlvVE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbAksVND-VohQfO199aNNaSxOLJQr0wI6KqP6NFqQG1A&oe=66FE712E"}, "display_name": "Battle Talent", "keywords": ["physics", "mod", "sword", "rogue", "melee"], "long_description": "Tired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time.\n\nBattle Talent brings physics driven creatures come to life with advanced physics simulation. You'll get to epic boss battles like you've never experienced before.\n\nFeatures:\n- Thrill of the hack-and-slash\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Variety of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n- Boss melee fight in VR\n- Sandbox & parkour\n", "short_description": "Battle Talent is a physics-based sword fighting game with rich roguelite elements in a fantasy world. \nTired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cydream.tech/privacy.html", "developer_terms