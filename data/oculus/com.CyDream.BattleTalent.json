6e7a0a&_nc_ohc=qZxYfHe1kwQQ7kNvgGbFk_U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCywpdIE9KzYgpHxEho5Ys_5KS46YhiYfzwewpoNc8NHg&oe=676EA6DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4Land.png", "id": "375444305590121", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974795_375444308923454_1152587668960523721_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9msVzZ0hzHQQ7kNvgHbQpmY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSzk91kzvO0KDSR10FyhvtuTZr8n_xZHGXAw4TS6mWuA&oe=676E9BCE"}, "display_name": "Battle Talent", "keywords": ["physics", "melee", "mod", "combat", "multiplayer"], "long_description": "Fight like a Warrior: Dive into a challenging physics-based roguelite action game set in a medieval fantasy world. Create your unique fighting style and embark on epic adventures!\n\n- Join forces with your friends to take down enemies! Experience rich **multiplayer** interactions and create powerful combos! (supports cross-play)\n\n{993508985736691}\n\n- Engage in realistic combat in **Mixed Reality Mode** (supports multiplayer) \n\n{862080482494054}\n\n- Experience thrilling physical combat with **spell, melee, and ranged attacks**. Beware, target the boss!\n\n{1153464909301423}\n\n- Customize your talent points in **Roguelike levels** and unlock unexpected treasure.\n\n{2455464587991559}\n\n- Explore **Sandbox Mode** to experiment with **2000+ mods** and Scene Editor feature.\n\n{1662858931145151}\n\n\n\n# Features:\n\n- 5 game modes: Adventure, Challenge, Sandbox, Mixed Reality mode (Quest 3), Multiplayer Mode\n- Supports multiplayer mode for 2-4 players and includes a built-in voice chat\n- Built-in scripted mod menu with 2000+ mods, enhance your gaming experience\n- Thrill of hack-and-slash with realistic physics interactions.\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Plenty of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n", "short_description": "Battle Talent is a challenging physics-based rogue-lite sword-fighting game, and now includes mixed reality and multiplayer mode, team up with friends to defeat enemies!\n\nIn this game, you can create your own fighting style and experience unparalleled gameplay in a mega seamless procedural dungeon. With over 80 enemy variants, 100 weapons, and 60 perks, the possibilities are endless. \n\nWhether you prefer medieval duels, magic or modern combat, melee or ranged attacks, this game has them all. "}]}, "developer_name": "Cydream", "developer_privacy_policy_url": "https://cydream.tech/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Cydream", "support_website_url": null, "website_url": "https://cydream.tech/battletalent.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "es", "sv", "fr", "ru"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27638193175824967"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86653844_578642535112710_4555535925000031525_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CY-cjs9rqLkQ7kNvgHUHZl_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwwoQuwl4c4TodziZIDmjGHeSYAjL1rVgi9EPGMnNj4g&oe=676E