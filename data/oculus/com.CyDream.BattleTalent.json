://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974635_805187057379504_8759899852072285381_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kczx54bbKvoQ7kNvgEwdodM&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCamaX6Jir717s8aKQ6s5JLpYiRb5bIhiABF5Gw0H4Dzg&oe=67518ED6"}, {"file_name": "vlcsnap-2023-05-23-14h37m48s082.png", "id": "5848051201991264", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57569428_5848051205324597_4678057873185456716_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uyXZtAzMp_0Q7kNvgFSI_z6&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBMKIpxw10kypK3V6qpjq5AbSJp_cPGUTJdAYtSKRyWPQ&oe=67518D40"}, {"file_name": "vlcsnap-2023-05-12-17h25m50s471.png", "id": "1296273721283473", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982665_1296273727950139_9036441277484988244_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mrmWkYxDE5gQ7kNvgH3vQTb&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCX8kSnvvFPEzKf4jg19YdvnHBOzG6R-VD5Gd0mZHpEvw&oe=6751A36A"}, {"file_name": "vlcsnap-2023-05-12-16h31m18s820.png", "id": "261292642951232", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/57572917_261292646284565_6552653360162497651_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T119yO_iWK4Q7kNvgFbjLT6&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDqb1MKjQg7F7f_gQebgt7IyhsHf3WcDlJJstQH_ZhrDw&oe=67518B3E"}, {"file_name": "vlcsnap-2023-05-15-14h44m51s169.png", "id": "1325202878429248", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75361360_1325202881762581_826073216865167659_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqebv3TuTHgQ7kNvgGHXCTZ&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDwJWvofDD2l1XCLrlVZPfHu0RVkZIrCbRJclHocy3MkQ&oe=6751A5DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-11.png", "id": "2673143799550395", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982629_2673143802883728_6915363993033614881_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ExNeb8MH1-kQ7kNvgFA4Q9O&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDQ_jMkdLulncRHjyH-9yyn9pnO9Tg2CP5jCwZ1eW-WCw&oe=6751A9FB"}, "display_name": "Battle Talent", "keywords": ["physics", "melee", "mod", "combat", "multiplayer"], "long_description": "Fight like a Warrior: Dive into a challenging physics-based roguelite action game set in a medieval fantasy world. Create your unique fighting style and embark on epic adventures!\n\n- Join forces with your friends to take down enemies! Experience rich **multiplayer** interactions and create powerful combos! (supports cross-play)\n\n{993508985736691}\n\n- Engage in realistic combat in **Mixed Reality Mode** (supports multiplayer) \n\n{862080482494054}\n\n- Experience thrilling physical combat with **spell, melee, and ranged attacks**. Beware, target the boss!\n\n{1153464909301423}\n\n- Customize your talent points in **Roguelike levels** and unlock unexpected treasure.\n\n{2455464587991559}\n\n- Explore **Sandbox Mode** to experiment with **2000+ mods** and Scene Editor feature.\n\n{1662858931145151}\n\n\n\n# Features:\n\n- 5 game modes: Adventure, Challenge, Sandbox, Mixed Reality mode (Quest 3), Multiplayer Mode\n- Supports multiplayer mode for 2-4 players and includes a built-in voice chat\n- Built-in scripted mod menu with 2000+ mods, enhance your gaming experience\n- Thrill of hack-and-slash with realistic physics interactions.\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Plenty of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n", "short_description": "Battle Talent is a challenging physics-based rogue-lite sword-fighting game, and now includes mixed reality and multiplayer mode, team up with friends to defeat enemies!\n\nIn this game, you can create your own fighting style and experience unparalleled gameplay in a mega seamless procedural dungeon. With over 80 enemy variants, 100 weapons, and 60 perks, the possibilities are endless. \n\nWhether you prefer medieval duels, magic or modern combat, melee or ranged attacks, this game has them all. "}]}, "developer_name": "Cydream", "developer_privacy_policy_url": "https://cydream.tech/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Cydream", "support_website_url": null, "website_url": "https://cydream.tech/battletalent.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "es", "sv", "fr", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27337166499260971"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75223483_1391980048854087_1314217745465057091_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rBZaRriVbq4Q7kNvgHPtr6o&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDTHZnLbyJLA9LQD6zPZ9G0T8KBT-N2IQ22Hx34Ktz0Rg&oe=6751928F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Battle Talent", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Action", "id": "4597815049