3436834920540_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vQ-OL1rNBtMQ7kNvgFPculZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-3RmQZc6GuGUq3FmlSi68HlZyql4J6jeMoUQy4UFmxA&oe=671CD2D3"}, {"file_name": "vlcsnap-2023-05-12-17h32m49s168.png", "id": "1302110007329863", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367593_1302110010663196_8023239998264300795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KjcY-gOC4g8Q7kNvgEZwXS3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnT7fgoZrLf_3x7PWrZpsbOoN9hJvM4fRxocbRVSo6lw&oe=671CD26F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-2.png", "id": "184095404525465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_184095407858798_2973736126209893403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1CxCdHr9BnEQ7kNvgEYtd7p&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5Ne4PM04yRb9wi4h2MXcWkIovyuzJpK6rWY47XH0hlA&oe=671CC3AE"}, "display_name": "Battle Talent", "keywords": ["physics", "mod", "sword", "rogue", "melee"], "long_description": "Tired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time.\n\nBattle Talent brings physics driven creatures come to life with advanced physics simulation. You'll get to epic boss battles like you've never experienced before.\n\nFeatures:\n- Thrill of the hack-and-slash\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Variety of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n- Boss melee fight in VR\n- Sandbox & parkour\n", "short_description": "Battle Talent is a physics-based sword fighting game with rich roguelite elements in a fantasy world. \nTired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 