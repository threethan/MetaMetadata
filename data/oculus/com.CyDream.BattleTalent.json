dSVvfIG38rSMLwjQ&oe=676E91A4"}, {"file_name": "vlcsnap-2023-05-12-16h31m18s820.png", "id": "261292642951232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572917_261292646284565_6552653360162497651_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lt3vcTYxVbIQ7kNvgH9fKuu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsBJ9xIY47amlVrnqD6N0sTgZ0rPaNqP27xkS-zhNEqw&oe=676E8C3E"}, {"file_name": "vlcsnap-2023-05-12-14h48m38s855.png", "id": "199687629555098", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75500282_199687632888431_8812303436834920540_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jvvVWsadNbUQ7kNvgFcN8Ek&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUvnrLqHrR5yUGroggW7xM5ZW0lquFrBegpIWbtKozoA&oe=676E8FD3"}, {"file_name": "vlcsnap-2023-05-12-17h32m49s168.png", "id": "1302110007329863", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367593_1302110010663196_8023239998264300795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0-6TlZ2cFcQQ7kNvgEg9K-I&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKGd9IqLubadjr6gY5RHnU0HcrtOf74MEw6kibvOYNmg&oe=676E8F6F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u672a\u6807\u9898-2.png", "id": "184095404525465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_184095407858798_2973736126209893403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TfarZVHks_QQ7kNvgGpurQS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB87-yZKWm4arNIL-uG0RNY6HnKau5G0JFdV-ArqZXvQg&oe=676E80AE"}, "display_name": "Battle Talent", "keywords": ["physics", "mod", "sword", "rogue", "melee"], "long_description": "Tired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time.\n\nBattle Talent brings physics driven creatures come to life with advanced physics simulation. You'll get to epic boss battles like you've never experienced before.\n\nFeatures:\n- Thrill of the hack-and-slash\n- Variety of enemies and bosses, over 80 enemy variants with different moveset\n- Variety of weapons and perks, over 100 weapons and over 60 perks\n- Seamless huge dungeons with multiple landscapes that regenerate each time\n- Boss melee fight in VR\n- Sandbox & parkour\n", "short_description": "Battle Talent is a physics-based sword fighting game with rich roguelite elements in a fantasy world. \nTired of fighting boring enemies? Battle Talent has created for you a mega seamless procedural dungeon with over 80 enemy variants, 100 weapons, 60 perks, and multiple landscapes that change each time."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cydream.tech/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "CyDream", "support_website_url": null, "website_url": "https://cydream.tech/battletalent.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "211836104775365"}}]}, "scheduled_offers": {"count": 21, "nodes": [{"status": "PUBLISHED", "id": "907840370897977"}, {"status": "PUBLISHED", "id": "958848055914325"}, {"status": "PUBLISHED", "id": "1273120184094389"}, {"status": "PUBLISHED", "id": "1014148336678614"}, {"status": "PENDING", "id": "2290326101167864"}, {"status": "PUBLISHED", "id": "685223429698705"}, {"status": "PENDING", "id": "229536250057662"}, {"status": "PUBLISHED", "id": "755124776282709"}, {"status": "PUBLISHED", "id": "499084338992952"}, {"status": "PENDING", "id": "884491419918420"}, {"status": "PENDING", "id": "2370009909837702"}, {"status": "PENDING", "id": "974046320333824"}, {"status": "PENDING", "id": "851906726728953"}, {"status": "PENDING", "id": "963879668133297"}, {"status": "PUBLISHED", "id": "697749585703447"}, {"status": "PUBLISHED", "id": "840988827291114"}, {"status": "PENDING", "id": "1342651670020833"}, {"status": "PUBLISHED", "id": "756264106547479"}, {"status": "PUBLISHED", "id": "851440896378516"}, {"status": "PUBLISHED", "id": "8178363545525461"}, {"status": "PENDING", "id": "842879350659158"}]}, "baseline_offer": {"id": "499084338992952"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "907840370897977"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27631961969781421", "version": "4"}, "id": "1430249234380634", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8752849024786000", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27631961969781421"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1430249234380634"}]}, "change_log": "Merry Christmas if you celebrate it, please check the official blog for more details\n\nNew Features / Improvements beyond the announcement\n- Players will now see newly designed blood-splatter effects when taking damage.\n- Players can now kick-jump off other players\u2019 heads.\n- Added an option to create local LAN-only rooms.\n- Improved smoothness for certain weapons and their behaviors during latency in multiplayer, such as shooting, bows, and projectile-based skills.\n- Challenge dungeon level 2 have been refined and enhanced.\n- Optimized the difficulty of MR combat levels.\n- Optimized the revolver to prevent jamming.\n- Optimized the mana cost for the Energy Transforming Bow.\n- Optimized the performance when multiple players use the lift together.\n- Optimized the experience of using the Scabbards in multiplayer.\n- Optimized flame effects.\n- Optimized the panel for selecting mods when creating multiplayer rooms.\n\nBug Fixes\n- Fixed the issue where elite and boss room doors would drag players when closed.\n- Fixed occasional crashes in multiplayer maps.\n- Fixed frame drops in certain scenes.\n- Fixed the issue where the boss room would suddenly disappear upon startup.\n- Fixed the issue where Earth Spell could not be used properly in MR mode.\n- Fixed the issue with the TwinBlade of Slash's enchantment status when separating or joining.\n- Fixed shadow effects on Quest.\n- Fixed the Spell status issue with the Spell Gun in multiplayer.\n- Fixed environment/building errors and movement blockages in some scenes.\n- Fixed the issue where the lever on the Demon Tablet occasionally gets stuck at the bottom\n- Fixed the erroneous pop-up of the MR battle report panel.\n- Fixed the stuttering issue when switching to ground-only mode in MR.\n- Fixed the issue where enemies would occasionally be pulled backward when attacked.\n- Fixed the issue where the Scabbards would disappear when on the sword, in the hand, during saves, or upon death and respawn.\n- Fixed the issue where weapons would easily slip out of hands.\n- Fixed the incorrect orientation of shields when stored in the backpack.\n\nKnown Issues\n- To optimize latency, there are some issues with using certain weapons (such as the Whip Sword) after joining multiplayer rooms. We will fix them soon.\n- Temporarily removed Sacrifice Spell. It will be reworked and added back later.", "created_date": 1734687693, "id": "27631961969781421", "version": "4", "version_code": 68, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27631952546449030"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8752849024786000", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27631961969781421"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733919368, "id": "27538406005803685", "version": "4", "version_code": 67, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27538398619137757"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8752849024786000", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27631961969781421"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1430249234380634"}]}, "change_log": "just a small patch for crash issue, the next update will be released early Dec", "created_date": 1732770437, "id": "27408136858830601", "version": "3.9", "version_code": 66, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27408132915497662"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8752849024786000", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27631961969781421"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1430249234380634"}]}, "change_log": "Small Patch\n>New content\n- The latency value of each room will be displayed on the multiplayer room list. Choose to join a low-latency room for a better multiplayer experience\n>Fixed bugs\n- Optimized performance to reduce lag.\n- Fixed multiplayer issue with the Index controller (Steam only).\n- Resolved issues with traps not triggering and stabbing actions not working.\n- Fixed problems with weapons being difficult to stab, occasionally disappearing, or not functioning properly, along with several other related issues.\n- Fixed issues that could occur when resurrecting from death.\n- Fixed the multiplayer NPC wound display issue.", "created_date": 1731137465, "id": "27219516911025931", "version": "3.9", "version_code": 65, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27219480157696273"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8752849024786000", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27631961969781421"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1430249234380634"}]}, "change_log": null, "created_date": 1729917095, "id": "27047936154850675", "version": "3.9", "version_code": 64, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27047895344854756"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}