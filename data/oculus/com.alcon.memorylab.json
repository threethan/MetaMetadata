9O&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Sor95I9OSHaq9ePdQf2tu&oh=00_AYD1DppMWK44Kg4pptyOoUm415Sguc84f-1Xcq93bFts6w&oe=66F6961C"}, {"file_name": "migrated_image.png", "id": "204834914179338", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162703_362498510870789_8981133922855288832_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uqyAWG5Cd8cQ7kNvgHfk8mJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Sor95I9OSHaq9ePdQf2tu&oh=00_AYDiz-4nXi1N_P0j4FXGPmHVNzOWEoy3TOet15KDStYZcA&oe=66F68081"}, {"file_name": "migrated_image.png", "id": "149082783038756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162682_2020521571551584_8432764477165797376_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vaIW7sjoyxMQ7kNvgFJZA-X&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Sor95I9OSHaq9ePdQf2tu&oh=00_AYAKc0WnuchtCSSghezpTRDdnjEZkmHO6qXL_rAu0UIIjQ&oe=66F6A695"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Blade Runner 2049: Memory Lab", "keywords": ["Bladerunner", "Blade", "Runner", "Memory", "Lab"], "long_description": "In this single-player adventure from the world of Blade Runner 2049, you've been transported to the Wallace Corporation's Memory Lab where an eager Joi-Tech model hologram is ready to scan your mind to reveal the circumstances behind your latest retirement.\nYou'll travel from the memory lab and into strange and thrilling recreations of the future, complete with fully volumetric characters and interactive elements. Within each scene you'll use futuristic tools to uncover clues to reveal and evidence to hide. Featuring Oculus Touch support and a sprawling, 360\u00ba world, Memory Lab brings the Blade Runner universe to you like never before.", "short_description": "After a frantic Replicant pursuit ends in violence, the LAPD sends you to the Wallace Corporation\u2019s Memory Lab for incident analysis. With the help of an holographic AI, you\u2019ll explore your memories of the event and interact with volumetric reconstructions to uncover a thrilling conspiracy."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "http://www.alconent.com/aig/privacy", "developer_terms_of_service_url": "http://www.alconent.com/aig/tos", "publisher_name": "Alcon", "support_website_url": null, "website_url": "http://alconent.com/aig/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "EXPLORATION", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "653671412437376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_191036994796892_7355663567833530368_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hzvKWHG22-IQ7kNvgGldj3B&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Sor95I9OSHaq9ePdQf2tu&oh=00_AYD7e5SageZm3d-w1W6CoBTYynDJtgeyaOAGnbhDh1q1YQ&oe=66F67EA9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Blade Runner 2049: Memory Lab", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1509037200, "lastRevision": {"nodes": [{"id": "531745407161668", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1666153080144269", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1488465531222966"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id"