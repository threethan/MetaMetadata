 a thrilling conspiracy."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "http://www.alconent.com/aig/privacy", "developer_terms_of_service_url": "http://www.alconent.com/aig/tos", "publisher_name": "Alcon", "support_website_url": null, "website_url": "http://alconent.com/aig/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "EXPLORATION", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "653671412437376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_191036994796892_7355663567833530368_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZNYxw6vCy8gQ7kNvgFrZFp-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4YGxiFxGwoI8n6aVI3edqy&oh=00_AYCbeBiKd26EsjWJ8MUyxgctW0eyisQmyicEcWMJNfqZZw&oe=66F52D29"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Blade Runner 2049: Memory Lab", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1509037200, "lastRevision": {"nodes": [{"id": "531745407161668", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1666153080144269", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1488465531222966"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id"