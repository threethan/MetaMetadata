lographic AI, you\u2019ll explore your memories of the event and interact with volumetric reconstructions to uncover a thrilling conspiracy."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "http://www.alconent.com/aig/privacy", "developer_terms_of_service_url": "http://www.alconent.com/aig/tos", "publisher_name": "Alcon", "support_website_url": null, "website_url": "http://alconent.com/aig/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "EXPLORATION", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "335898968436056"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "960042717468149"}]}, "baseline_offer": {"id": "960042717468149"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1509037200, "status": "PUBLISHED", "id": "960042717468149"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1679782865447957", "version": "0.1.6628"}, "id": "234401500424475", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1666153080144269", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1679782865447957"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "234401500424475"}]}, "change_log":