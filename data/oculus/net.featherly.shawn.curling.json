0011148288309843_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tMv9rhmzOOYQ7kNvgG64yBa&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAVsuk5-ess0aQe5MY6HiReUaxq3miX-QlJ_e9OnD3s6g&oe=670F8A80"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CurlingCoverArt2560.16by9.png", "id": "3078238962456385", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031518_3078238965789718_1994122252147675703_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Twg2n2n9wUQ7kNvgEg85ZP&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDSQSBAPIWl0W4zGSY1tx2maI7aNPKm3MOG34THbo4e1Q&oe=670FB4DE"}, "display_name": "Curling", "keywords": [], "long_description": "Play the sport of curling. After you slide across the ice to release the stone, hand your friend a touch controller and get them to \"SWEEP!\".\n\nCurling is fundamentally a social game. So is this VR game! The social aspect is similar to \"Keep Talking & Nobody Explodes\". Everyone needs to be in the same room. Sweepers for your team don't use the HMD, they use only the Touch controllers. Opposing teams play hot-seat style. Handing off a single Quest HMD to a member on the other team.\n\nComputer controlled AI curlers are not yet implemented.\n\nDemo is also available! https://www.oculus.com/experiences/quest/4387676764681800/", "short_description": "Play the sport of curling. A Winter Olympics party game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bouncylasers.com/curlingprivacy", "developer_terms_of_service_url": null, "publisher_name": "Shawn Featherly", "support_website_url": null, "website_url": "https://www.bouncylasers.com/curling", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", 