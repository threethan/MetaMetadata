iZfQ8Q7kNvgGHwLmJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8op2IaBz3Kl50u8ip5HTrR&oh=00_AYA8MUa9zHSgDOcFAwXe8e5NTRqg2r-qtzb4WZY9apq0zQ&oe=66EFE9E8"}, {"file_name": "pic1.png", "id": "1215126202972575", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982660_1215126206305908_7656455983350525662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PFMOED5Tl0sQ7kNvgFACA6W&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8op2IaBz3Kl50u8ip5HTrR&oh=00_AYCHuTZCS_cPWJn7ppdZUjbc1wDHndXzZvLf4Jc-0T3MLA&oe=66EFEB46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "8135831259803033", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_8135831263136366_2332711569767664856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8J3ysMW0JooQ7kNvgF4FRPX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8op2IaBz3Kl50u8ip5HTrR&oh=00_AYCcdGw7t5pMXprpoOLre53o5ifcOHSsDNmAShLWpOqu9g&oe=66F00943"}, "display_name": "synthesia", "keywords": [], "long_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a captivating musical puzzle game designed for VR, inspired by the fascinating phenomenon of \"synesthesia\" where senses blend and colors emerge from melodies.\nIn Synthesia, players hone their musical ear by solving a series of visually and aurally immersive puzzles. Listen to a captivating tune and then rearrange blocks representing sounds and shift notes up or down to match the melody.\nWhether you're a budding musician or simply enjoy a good brain-teaser, Synthesia provides a fun and educational experience for all.", "short_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a multisensory puzzle game that pairs colors and notes to train players' pitch recognition. Players solve fun puzzles while experiencing a VR simulation of the sensory phenomenon known as \"synesthesia\"."}]}, "developer_name": "Luxi Liu", "developer_privacy_policy_url": "https://luxi-liu97.github.io/