HNvJW3cSp4gQ7kNvgEYbS9T&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEObwK6cK6RDRxn6lHI2iWd&oh=00_AYCCkpJXnDI01Wkte1gMrriuYsez3UGlm4Rvku5QR1Ecgw&oe=66E55DE8"}, {"file_name": "pic1.png", "id": "1215126202972575", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982660_1215126206305908_7656455983350525662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J9NKKjzQx8sQ7kNvgElD-3Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEObwK6cK6RDRxn6lHI2iWd&oh=00_AYANzNvhmhRNlQOxDy4UGEfTEev_RU1Z4hdIQBFouoP1IA&oe=66E55F46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "8135831259803033", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_8135831263136366_2332711569767664856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bhL6ZA8wNhcQ7kNvgEGOeP4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEObwK6cK6RDRxn6lHI2iWd&oh=00_AYDT-oCInGdsPbGmHdBE64jlltZUEFnwWUcQgq4Amqi2Dw&oe=66E57D43"}, "display_name": "synthesia", "keywords": [], "long_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a captivating musical puzzle game designed for VR, inspired by the fascinating phenomenon of \"synesthesia\" where senses blend and colors emerge from melodies.\nIn Synthesia, players hone their musical ear by solving a series of visually and aurally immersive puzzles. Listen to a captivating tune and then rearrange blocks representing sounds and shift notes up or down to match the melody.\nWhether you're a budding musician or simply enjoy a good brain-teaser, Synthesia provides a fun and educational experience for all.", "short_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a multisensory puzzle game that pairs colors and notes to train players' pitch recognition. Players solve fun puzzles while experiencing a VR simulation of the sensory phenomenon known as \"synesthesia\"."}]}, "developer_name": "Luxi Liu", "developer_privacy_policy_url": "https://luxi-liu97.github.io/synthesia_pp.html", "developer_terms_of_service_url": null, "publisher_name": "Iota Co", "support_website_url": null, "website_url": "https://luxi-liu97.github.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "879473995923081"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8572254726119882"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75644991_478298924611798_3428034440511380311_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CaablD8W1VYQ7kNvgHi2n1e&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEObwK6cK6RDRxn6lHI2iWd&oh=00_AYBTqMKOy_9zKBmhmRuVQv2ulUKUesLWaBwPF7WeV5repw&oe=66E587D6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "synthesia", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1725033660, "lastRevision": {"nodes": [{"id": "8162465507098808", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8162465477098811", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "pl