B79M45Rqca1tnK2wKYeIgjnCLODCIb84g&oe=677905E8"}, {"file_name": "pic1.png", "id": "1215126202972575", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982660_1215126206305908_7656455983350525662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BWNZzUxZ7NEQ7kNvgHqyY_e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADwo95hMFifPuNHbSSdy7CIP__Zp2vDzcq6tNNBqHyeQ&oe=67790746"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "8135831259803033", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001727_8135831263136366_2332711569767664856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jdtAKHgfI-UQ7kNvgEKafNb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAI2s2e84Cg8k6UVICIHnX8_oMRYcfq1yzYrawCZM1Uqg&oe=67792543"}, "display_name": "synthesia", "keywords": [], "long_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a captivating musical puzzle game designed for VR, inspired by the fascinating phenomenon of \"synesthesia\" where senses blend and colors emerge from melodies.\nIn Synthesia, players hone their musical ear by solving a series of visually and aurally immersive puzzles. Listen to a captivating tune and then rearrange blocks representing sounds and shift notes up or down to match the melody.\nWhether you're a budding musician or simply enjoy a good brain-teaser, Synthesia provides a fun and educational experience for all.", "short_description": "Step into a world where you don\u2019t just hear the music\u2014you see it. Synthesia is a multisensory puzzle game that pairs colors and notes to train players' pitch recognition. Players solve fun puzzles while experiencing a VR simulation of the sensory phenomenon known as \"synesthesia\"."}]}, "developer_name": "Luxi Liu", "developer_privacy_policy_url": "https://luxi-liu97.github.io/synthesia_pp.html", "developer_terms_of_service_url": null, "publisher_name": "Iota Co", "support_website_url": null,