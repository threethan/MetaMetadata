nters and unravelling mysteries in the haunting forest.", "short_description": "VR shooting Game."}]}, "developer_name": "Mindpixels", "developer_privacy_policy_url": "https://www.mindpixels.io/privacy-policy/#developer", "developer_terms_of_service_url": null, "publisher_name": "Mindpixels", "support_website_url": null, "website_url": "https://www.mindpixels.io/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7589181044426265"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "7016429475143805"}]}, "baseline_offer": {"id": "7016429475143805"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720683332, "status": "PUBLISHED", "id": "7016429475143805"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8049328285078203", "version": "1.01"}, "id": "888333353297292", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7476442599033444", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8049328285078203"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "888333353297292"}]}, "