425010_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lRW9zxpC-4cQ7kNvgHO9j1h&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYANJqGzEmqO42tnklFpguatq1uGsO67In2RV6Ec3YFlCQ&oe=675187A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LOCI Trailer cover image 2560x1440px.png", "id": "1131325787505293", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031655_1131325790838626_8310563796273832673_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3g-Ao5RwaocQ7kNvgH2lCKs&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDVxbbBk4ZJQqp5myiaXBoPCX_Z6Ze9C-DCkfJZLreR-A&oe=6751A519"}, "display_name": "Shores of Loci", "keywords": [], "long_description": "The Shores of Loci is a single-player narrative puzzle game that can only be experienced in VR. With compelling characters, beautiful cinematic scenes, and surreal worlds, the Shores of Loci will transport you to other dimensions to create visions larger than life. \nIn this multidimensional story, Giants and Villagers alike need your help to reclaim their lands and rebuild their cities. Complete your journey creating a universe where puzzled pieces are assembled and transformed.\n\nFeatures\n\u2022 Intuitive gameplay creates an all-accessible inclusive experience while you travel through the Shores of Loci.\n\u2022 Adventure to fantastic places and find your place in a story larger than life.\n\u2022 Calming audio encourages a relaxed gameplay as you bring your environments to life and help your new friends in The Shores of Loci.\n\u2022 Cities and villages become populated with unique characters as you build out your creations along The Shores of Loci.", "short_description": "Escape the Ordinary, Create the Extraordinary. A Puzzling Adventure by MikeTeevee."}]}, "developer_name": "MikeTeevee", "developer_privacy_policy_url": "https://shoresofloci.com/lociprivacypolicy_feb2022/", "developer_terms_of_service_url": null, "publisher_name": "MikeTeevee", "support_website_url": null, "websi