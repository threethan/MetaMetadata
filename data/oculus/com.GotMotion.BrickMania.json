0mcQ7kNvgGe6Apk&_nc_ht=scontent.oculuscdn.com&oh=00_AYAPMklzt66bbD_-SEJmd0V3KICMno_UmWmFwd4QjBvKBg&oe=66DAF259"}, {"file_name": "2.png", "id": "800507275395357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_800507278728690_8370916924605575234_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PvXxnnRac-IQ7kNvgHnAib3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUNAyH2R_ID1dnUs4f96-N0EU6xFIePpwXnooRhxYSeg&oe=66DB0483"}, {"file_name": "Untitled.png", "id": "332917583088461", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035363_332917586421794_8831279654688852183_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y60vgrrHPCIQ7kNvgGRHYIT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJB8kT023tkj0MgeTNhfkPkeTGyTBpS6RDckhwWobL0w&oe=66DAD527"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 59.png", "id": "1524970634865802", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984452_1524970638199135_826433915348957463_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XZX1Dx5m5tEQ7kNvgF2LoTk&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLejCvc_hqkjAaafwPTEAPbD1CPHpipqpIlHyz724tjQ&oe=66DACF8C"}, "display_name": "Brick Mania", "keywords": [], "long_description": "\n\n\ud83e\udd8d **BRICK MANIA: UNLEASH YOUR INNER BRICK \ud83e\udd8d**\n\nShrink down to action figure size and explore an exciting room as a brick. With no legs and a lot of personality, you\u2019ll run on your hands through various fun-filled activities.  \n\n\ud83e\udda0 **BUILT IN MODS** \ud83e\udda0\n\nExplore the COOLEST mods that are easy to get. Rockets, Fly, No Clip, Speed Hacks, X Ray, Teleport, Laptop, and much more!\n\n\ud83d\udcf8 **FREE CAMERA MOD: MOST ADVANCED CAMERA \ud83d\udcf8**\n\nOur built-in camera mod lets you switch between first-person, third-person, and other exciting perspectives to enhance your gameplay experience.\n\n\ud83c\udfe0 **GAME MODES\ud83c\udfe0**\n\nHave fun and talk with other bricks in our casual mode or show your inner brick and jump into an infection lobby. More game modes soon to come..\n\n\u2757\ufe0f\u2757\ufe0f**BIG UPDATES CONSTANTLY\u2757\ufe0f\u2757\ufe0f**\n\nWe do our best to get out updates every week or every other week to best support our community. We built what the community wants!\n\n\n\ud83c\udfc0 **SHOOT HOOPS LIKE NEVER BEFORE** \ud83c\udfc0 \n\nHit the basketball court for some epic trick shots. Whether you\u2019re a baller or just want hit some jumpers, the court is yours.\n\n\n\n\n\ud83d\udecd\ufe0f **EXPLORE THE MALL AND GET COSMETICS \ud83d\udecd\ufe0f**\n\nVisit our in-game mall and deck out your brick with an array of cosmetics. From funky outfits to stylish accessories, there\u2019s something for everyone.\n\n\ud83e\udd73 **JOIN THE BRICK MANIA NOW \ud83e\udd73**\n\nReady to experience life as a brick? Join the Brick Mania now and embark on a tiny, yet massive adventure. Play for free and let the fun begin! Join our Discord to get support or find people to play with: https://discord.gg/brickmania", "short_description": "Step into the shoes of a miniature, brick in a room-sized adventure.Run, Jump, Tag, Shoot hoops, Explore mods, take videos using in game camera mod, and customize your look at the in-game mall."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.gotmotion.gg/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Got Motion", "support_website_url": null, "website_url": "https://gotmotion.gg/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices":