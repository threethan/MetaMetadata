771-25/75580066_338780088634012_7275390428483300799_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DzZHPCTaCU4Q7kNvgHZHP-R&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3fxgwebDgJMQKrg4YB8Y0A&oh=00_AYBz1pUadC-FCtrxlWbQC0Vwdfsf-sPcZHqQ575OQWADbQ&oe=66F539AB"}, {"file_name": "Screen-5.png", "id": "285204130993151", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566690_285204134326484_7225346090292018698_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H9-Bim-ztOQQ7kNvgE40GTW&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3fxgwebDgJMQKrg4YB8Y0A&oh=00_AYDlHxdNOQGikmnZLq9b0osDDzHVRWjX5lBWOgLDGcZg-w&oe=66F539E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screen-6.png", "id": "1416541045594302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974741_1416541048927635_167960599466487752_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5--9sfE07JcQ7kNvgEVLj4J&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3fxgwebDgJMQKrg4YB8Y0A&oh=00_AYAhaKebsRlP8iEEPWBHqrePSLR_BgUUmHaDJSt_Yxlylw&oe=66F53775"}, "display_name": "Red Antz", "keywords": [], "long_description": "Red Antz is an interactive music video for VR, created in collaboration with the experimental punk band Palberta.\n\nImmerse yourself in an alien world bounded by the confounding logic of Palberta\u2019s songwriting. Interact with objects to generate and recompose the band\u2019s song. Discover other sound-makers to perform your own noisy solos. Do a weird dance on the big screen. No one hears the song the same way.\n\n*** This is a short, open-ended experience, without defined goals or endpoint. ***\n\nPut the ants on your body.", "short_description": "Put the ants on your body."}]}, "developer_name": "Elf's End Interactive", "developer_privacy_policy_url": "https://www.elfs-end.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Elf's End Interactive", "support_website_url": null, "website_url": "https://www.elfs-end.com/red-antz", "category": null, "comfort_rating": "NOT_R