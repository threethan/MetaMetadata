uluscdn.com&oh=00_AYBtmPL58Qf7r-36UPfub6R7IpaHsPu7CdTt46EJubEQng&oe=67504089"}, {"file_name": "Appimg.png", "id": "1130037704921376", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031557_1130037708254709_112034632504369694_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fZZGLMM1wqQQ7kNvgGHOCdt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxF_0InOkaR7RaYdqFHcyEjEV3lb8FMU_TPLNgFxvouA&oe=67505937"}, {"file_name": "Appimg.png", "id": "1351355288889869", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974544_1351355292223202_3698011005419090752_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yljFC18J0zkQ7kNvgFFoIoN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHD2N6pyrWUjAXnWprjWmRy0nwQ9v6hWSEyv_5qKXdTQ&oe=675030C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Appimg.png", "id": "3013666645441634", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974712_3013666648774967_7147863938413542905_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrTSux6jch8Q7kNvgEqKYM9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvnJBCeEGCuP62wTvN8g8WW1EkuIxrjXeVa8Oq9q9OMA&oe=67505708"}, "display_name": "Monkey Company", "keywords": [], "long_description": "Monkey Company is a gripping horror game that thrusts players into the heart of a dark and enigmatic facility. Utilizing the popular Gorilla Tag locomotion system, players navigate the eerie corridors and rooms of Monkey Company, an abandoned research facility with a haunting past. As they delve deeper into the facility, players encounter nightmarish creatures and uncover chilling secrets that have long been buried.\n\nThe game's core mechanics revolve around exploration, puzzle-solving, and survival. Players must utilize elevators and manipulate door mechanisms to progress through the intricate levels while evading danger and piecing together the facility's grim history. Each room and corridor holds clues and challenges, pushing players to stay alert and think strategically to survive.\n\nMonkey Company's atmospheric design, coupled with its dynamic soundscapes and immersive storytelling, creates a truly terrifying experience. Players will find themselves on the edge of their seats as they unravel the mysteries of Monkey Company and confront their deepest fears in this adrenaline-fueled horror adventure.", "short_description": "Monkey Company is a spine-chilling horror game that combines the beloved Gorilla Tag locomotion with immersive exploration elements. Encounter terrifying creatures, solve puzzles using elevator and door mechanics, and unravel the mysteries of the eerie Monkey Company facility. Brace yourself for an adrenaline-pumping adventure like no other."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/d/1AJLwdPFcrJIfN60flat7dSReoN06T3gV/p/1fmq4srLe5F5T1bTFmlhv3tnUGS6zwU_y/edit", "developer_terms_of_service_url": null, "publisher_name": "BoxBotStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/robotmayhem/hub", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7195813343801159"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "449833064063945"}]}, "baseline_offer": {"id": "449833064063945"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712073840, "