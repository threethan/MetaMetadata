QQ7kNvgFTQs0W&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-ELesFU1-Iv-9jmB8dVcufXD3MFXwUpPrpAkXZ7a9Qg&oe=6750511D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Appimg.png", "id": "3013666645441634", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974712_3013666648774967_7147863938413542905_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrTSux6jch8Q7kNvgEqKYM9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvnJBCeEGCuP62wTvN8g8WW1EkuIxrjXeVa8Oq9q9OMA&oe=67505708"}, "display_name": "Monkey Company", "keywords": [], "long_description": "Monkey Company is a gripping horror game that thrusts players into the heart of a dark and enigmatic facility. Utilizing the popular Gorilla Tag locomotion system, players navigate the eerie corridors and rooms of Monkey Company, an abandoned research facility with a haunting past. As they delve deeper into the facility, players encounter nightmarish creatures and uncover chilling secrets that have long been buried.\n\nThe game's core mechanics revolve around exploration, puzzle-solving, and survival. Players must utilize elevators and manipulate door mechanisms to progress through the intricate levels while evading danger and piecing together the facility's grim history. Each room and corridor holds clues and challenges, pushing players to stay alert and think strategically to survive.\n\nMonkey Company's atmospheric design, coupled with its dynamic soundscapes and immersive storytelling, creates a truly terrifying experience. Players will find themselves on the edge of their seats as they unravel the mysteries of Monkey Company and confront their deepest fears in this adrenaline-fueled horror adventure.", "short_description": "Monkey Company is a spine-chilling horror game that combines the beloved Gorilla Tag locomotion with immersive exploration elements. Encounter terrifying creatures, solve puzzles using elevator and door mechanics, and unravel the mysteries of the eerie Monkey Company facility. Brace yourself for an adrenaline-pumping adventure like no other."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/crystalvoxstudios/crystalvoxgames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "BoxBotStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/crystalvoxstudios/crystalvoxgames", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8501588879890259"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974532_881049414129252_199950082950664860_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s17cc_Cp-osQ7kNvgFGrFCz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJQPFdm4gRlb48PH4SKbLaSmTec3laFF2JWoZM6ab0XQ&oe=675047FB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Monkey Company", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1712073840, "lastRevision": {"nodes": [{"id": "7195813363801157", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata"