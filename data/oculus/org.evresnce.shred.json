aryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7710802135672293", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8097635526988950"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1029625345559435"}]}, "change_log": null, "created_date": 1725825101, "id": "8067553163330520", "version": "1.2.1", "version_code": 121, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7710802135672293", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8097635526988950"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1029625345559435"}]}, "change_log": "Version 1.2.0 - September 2024 Early Access Release\n\nNew Features:\n\n- More Shreddable Objects: Introduced new shreddable objects, starting with a teddy bear, a game console controller, and the Stanley Cup.\n\n- Wacky Object Replacement for Hands: When users put their hands into the shredder, the hands are shredded and replaced with surprise objects. Additionally, the whole experience changes to revolve around those objects. Put your hand in the shredder and see for yourself!\n\n- Settings Menu: Added a menu that includes controls information.\n\nImprovements:\n\n- Shredding Physics Enhancement: Enhanced the overall shredding physics to make the experience more realistic and satisfying.\n\n- Improved Look: Changed the walls texture to a white finish with ambient occlusion, giving the environment a more polished look. We also made the paper shredder more eye-catching.\n\nBug Fixes:\n\n- File size optimisation: We reduced the game's overall size and decreased loading times, resulting in a smoother experience.\n\n- Annoying Phone Ringing Sound: Fixed the issue where phones would ring continuously. Phones now only ring when they are picked up, preventing them from annoying the player.\n\n- No More Object Teleportation to the Shredder: Removed the bug where objects were being teleported into the plastic shredder upon collision, ensuring objects behave as expected.\n\n", "created_date": 1725666180, "id": "8056036771148826", "version": "1.2.0", "version_code": 120, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7710802135672293", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8097635526988950"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1029625345559435"}]}, "change_log": null, "created_date": 1724879229, "id": "8003230986429405", "version": "1.10.3", "version_code": 13, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}