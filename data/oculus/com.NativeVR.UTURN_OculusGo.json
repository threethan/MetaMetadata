92234_459127621619330_7352765207449514032_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ayVn70Woum0Q7kNvgFOnTYS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr6zyagl0s77xi_bx8wuOhvhI2o_pBMZ2u7bqYGRH31w&oe=6767EB39"}]}, "id": "2699847657009771", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_01.png", "id": "2691395817816585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334067_2691395824483251_6519031322732069638_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A5m5CJkI2vQQ7kNvgFx6Qjs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTuFBz9-J9LRfT0DXUbonQHhN02d9ue7vwOOySfreyUQ&oe=6767FD57"}, {"file_name": "Screenshot_02.png", "id": "1719398694894630", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240107_1719398698227963_7911868471516927887_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b09KrHNVqToQ7kNvgG0auFL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUPRIA8ynin67cnQE85ZaqhYSKh_e8arc5H9FXlH5Omw&oe=6767FF48"}, {"file_name": "Screenshot_03.png", "id": "867819873628435", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340705_867819876961768_3198507502262905576_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AAgB7Jqa8EQ7kNvgFWsTzW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCV_zi--1rX3Z6AFkjDlyPpEg3GMd9oxOLvfjXEIdBIyg&oe=6767FC56"}, {"file_name": "Screenshot_04.png", "id": "340591443594238", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240094_340591446927571_5963273121078579791_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8uRPOkpgVFsQ7kNvgErJ3mP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9wOpmhrvCUIX3SUuIjqHokl68aqY35lfjZmDyCJyApw&oe=6768005E"}, {"file_name": "Screenshot_04B.png", "id": "3478983458792004", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395600_3478983462125337_720710518849186992_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvZc9fEbBfcQ7kNvgHPQQxY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASvIIqLON3hDFCbMEOGcfCEw1QHo6r0Iy8sGeWhIytYA&oe=6767F6AE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover.png", "id": "3212504765439624", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035422_3212504775439623_355045172815088181_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=exRkidDgd9IQ7kNvgF_ZXVU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWEexQNZcZKP4ko3N1MDx52sca_ZJDXCevzGmxaUwsFg&oe=67680E70"}, "display_name": "UTURN", "keywords": ["360", "narrative", "comedy", "gender", "unconsciousbias"], "long_description": "A dog-themed dating site goes down due to a data center server interruption that sweeps the nation. It is up to a female developer and her male teammates to get their site up and running again before their CTO, who\u2019s juggling his own problems, has to make a pivotal pitch to VCs the next day.\n\nUTURN innovates by placing the viewers in the middle of two intertwined stories, told from a female or a male character perspective. Viewers can choose what perspective to watch at any time. Only the scene being looked at can be heard through a unique spatial sound design. Whatever they miss changes their perspective on the overall story.\n\nAwards & Festivals:\n* Special Jury Prize Jump into VR Fest 2017\n* Nominated Best Interactive Experience FIVARS 2017 & Best Cinematic Narrative Experience Raindance 2017\n* 2019: Cannes XR, Women Deliver\n* 2018: SATIS, Nuit Blanche, Colcoa, Seattle, Cleveland, Nantucket \n* 2017: VR Days, UN Women, San Francisco, Mill Valley, Tacoma, Oculus Connect, Samsung DC", "short_description": "What happens when a young female coder joins a male-dominated floundering startup that\u2019s deep in an identity crisis?\n\nWith a comedic twist, UTURN is an interactive live-action VR film where you get to experience both sides of the gender divide."}]}, "developer_name": "NativeVR", "developer_privacy_policy_url": "http://www.uturnvr.com/wp-content/uploads/2020/UTURN-PrivacyPolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "NativeVR", "support_website_url": "http://www.uturnvr.com/", "website_url": "http://www.uturnvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "340781548056650"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75392234_459127621619330_7352765207449514032_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ayVn70Woum0Q7kNvgFOnTYS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArNpM_ib7CYfocTD66cOdd7t6u8BF7vpiGHqO0pgKKbQ&oe=6767EB39"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UTURN", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1600704005, "lastRevision": {"nodes": [{"id": "3388045607894634", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3089189254482303", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "687362745156425"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Mini.png", "id": "2580247455557354", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439595_2580247458890687_7625031953660946205_n.p