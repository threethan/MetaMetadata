_name": "2.png", "id": "1548017139081437", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974819_1548017142414770_7745637909361189185_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mhYrU6FJRIwQ7kNvgEZMbal&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIO0rHmtoCoLjVVVnSOtHaXvCEMKUVvx84iaM7d76ePA&oe=66DEC543"}, {"file_name": "4.png", "id": "2149338835436047", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031330_2149338838769380_1342380476848011217_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qNOcSVU-id8Q7kNvgGfLyvB&_nc_ht=scontent.oculuscdn.com&oh=00_AYASXI-Z74fwBTNq-GoCvAmyFHHLpwFOJT0Y6EIfFQny-g&oe=66DEC255"}, {"file_name": "3.png", "id": "425621870050920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984459_425621873384253_5444166115704050078_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qlLti4iMImIQ7kNvgF6CdeB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwUCK5RyCk9jRPf30uLteJpwho1ABptLWFan64lXLpcg&oe=66DEC9DD"}, {"file_name": "1.png", "id": "1135274944267833", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_1135274947601166_7513787693106153823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xWTHB1n1sAkQ7kNvgEWIX3u&_nc_ht=scontent.oculuscdn.com&oh=00_AYCuXZMtGGTHefc9tRhu1ZqYD5cBfXVmYqVPi5w2a7V-0A&oe=66DED85D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1087976862503576", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75588060_1087976869170242_8690834638362885484_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gJu8moNBnUkQ7kNvgHiabFf&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4n6OBIFvnLmwO2ymYImd15bubLQ_r16GIT9NDMmaANw&oe=66DECD80"}, "display_name": "VRzomOL", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Unity", "support_website_url": "https://www.bilibili.com/video/BV1JC4y1n7Uq/?spm_id_from=333.999.0.0&vd_source=f44d7fafb67bf1b4c28885f69f021585", "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "8149325901748851"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "973220864472036"}, {"status": "PUBLISHED", "id": "109726983157