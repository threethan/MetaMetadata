.oculuscdn.com&oh=00_AYDwtdz6ZQaK4kgezgl4RbppyfdggrXUM4rxfaKA_WbB9g&oe=6772A295"}, {"file_name": "3.png", "id": "425621870050920", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984459_425621873384253_5444166115704050078_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zz2iRSIuaNgQ7kNvgFKWfXH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAjE1m-mbU0DEtvVko-_n9zMajrfNf9tx2h5PAXztvOcw&oe=677271DD"}, {"file_name": "1.png", "id": "1135274944267833", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57572936_1135274947601166_7513787693106153823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uV1mW24LFKEQ7kNvgEUY3_O&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBgex8qquS34B1YimCrQ90WtxoJqluzIvGmJ-H6_EwlQ&oe=6772805D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1087976862503576", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75588060_1087976869170242_8690834638362885484_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HwOIluGaMh0Q7kNvgFo2iNL&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDOGYl6UKxQM0kVMDNOQ-anNEdzj5thsuIl-QWKNpqIyw&oe=67727580"}, "display_name": "VRzomOL", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Holoren", "support_website_url": null, "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "9653610137987079"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75395597_1141833577010956_6472850014483885218_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BWdZcBxoeiUQ7kNvgHcO2i1&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCCJ_rzFBzT7MeXTtbWgiz7KSeGqgjSg24q5zAT9vhCvw&oe=67727E4D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRzomOL", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1713479820, "lastRevision"