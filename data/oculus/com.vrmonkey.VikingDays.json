tual Reality! After the success of the game for old 3DOF platforms we bring a renew version for 6DOF exploring more of the freedom we have with 2 controllers and being able to move around the space.\n\nWith extra 7 days from the original game (total of 17), you will now be able to go down mountains skiing, enjoy the peace of fishing, compete in a target practice with arrow and bow and climb your way to obstacles and more!\n", "short_description": "How long can you survive the Viking Days?\nCompete in a series of minigames to see who is a true Viking!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrmonkey.com.br/tos.html", "developer_terms_of_service_url": null, "publisher_name": "VRMonkey", "support_website_url": null, "website_url": "http://vrmonkey.com.br/projects/vikingdays/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7950524284976589"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974875_963584180904144_545446777364198543_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yVNq3JT1BOAQ7kNvgF3s-3d&_nc_ht=scontent.oculuscdn.com&oh=00_AYBOcDKC0zgnC1wDyjXFTDWRQexFfBWczxks2PMKLM7-UQ&oe=66CDC86F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Viking Days R