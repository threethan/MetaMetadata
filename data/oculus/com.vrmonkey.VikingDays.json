 space.\n\nWith extra 6 days from the original game (total of 16), you will now be able to go down mountains skiing, enjoy the peace of fishing, compete in a target practice with arrow and bow and climb your way to obstacles and more!\n", "short_description": "How long can you survive the Viking Days?\nCompete in a series of minigames to see who is a true Viking!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrmonkey.com.br/tos.html", "developer_terms_of_service_url": null, "publisher_name": "VRMonkey", "support_website_url": null, "website_url": "http://vrmonkey.com.br/projects/vikingdays/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "312966214185523"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1064459874384549"}]}, "baseline_offer": {"id": "1064459874384549"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1637182080, "status": "PUBLISHED", "id": "1064459874384549"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5932709443424760", "version": "2.3"}, "id": "230633209052938", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5058206260875087", "is_concept": false, "latest_release