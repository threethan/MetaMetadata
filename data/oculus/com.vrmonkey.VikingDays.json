oAu1x8RqOmHFqOLroO7C5EYg&oe=67289BD3"}, "display_name": "Viking Days Remaster", "keywords": [], "long_description": "Face the domestic life of the fine upstanding viking in 17 mini challenges!\n\nInvite your newbie friends to compete with you in a EASY TO PLAY, HARD TO MASTER series of mini-games and show them who is the true Viking Master!\n\nViking Days is a game born to show the amazing and easy aspects of nowadays Virtual Reality! After the success of the game for old 3DOF platforms we bring a renew version for 6DOF exploring more of the freedom we have with 2 controllers and being able to move around the space.\n\nWith extra 7 days from the original game (total of 17), you will now be able to go down mountains skiing, enjoy the peace of fishing, compete in a target practice with arrow and bow and climb your way to obstacles and more!\n", "short_description": "How long can you survive the Viking Days?\nCompete in a series of minigames to see who is a true Viking!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrmonkey.com.br/tos.html", "developer_terms_of_service_url": null, "publisher_name": "VRMonkey", "support_website_url": null, "website_url": "http://vrmonkey.com.br/projects/vikingdays/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7950524284976589"}, "review_messages": [""]}]}, "cover_square_