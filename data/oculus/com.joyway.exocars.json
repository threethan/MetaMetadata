6658_8362404288766729595_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Phby9yr9uo0Q7kNvgHMbuwj&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwSaId3HnWxiNO0yW7fx2zesodAkQwD7-9RKyUFaHfXA&oe=67728068"}, "display_name": "EXOcars", "keywords": ["Racing", "Cars", "Multiplayer", "Drive", "Track"], "long_description": "**Dynamic Racing Experience** \n\nEXOcars delivers a thrilling VR racing experience grounded in real car physics, where every race is unique and unpredictable. The interaction between suspension dynamics and track surfaces ensures that each race feels fresh and challenging. \n\nWith carefully designed tracks featuring ramps, drifts, and real obstacles, players will face new challenges on every course. \n\n**Exciting Multiplayer Modes**\n\nCompete in asynchronous multiplayer to race against opponents matched to your skill level, making your journey to the top organic and rewarding. For those who crave live competition, real-time multiplayer lets you race against friends, proving who\u2019s the ultimate racer.\n\n**Tournaments**\n\nStep up your game with our thrilling tournament mode, where the stakes are higher and the rewards are real. Compete against the best in the world for cash prizes, VR accessories, and exclusive in-game rewards.\n\n**Customization**\n\nShow off your style by customizing your cars and earning rewards to unlock new designs and tracks. Aim to be at the top of the global leaderboard as you collect awards and achievements.\n\n**Are You In?**\n\nWhether you're navigating wild off-road courses or racing through city streets, EXOcars offers an unparalleled, adrenaline-fueled experience. \n\nIt\u2019s not just about racing\u2014it's about becoming a legend.", "short_description": "Experience the thrill of high-speed VR racing with EXOcars! Jump into the driver\u2019s seat and compete against real players in fast-paced multiplayer battles or tackle the challenge of asynchronous races. Test your skills, push the limits, and claim your title as the top VR racer!"}]}, "developer_name": "Xocus", "developer_privacy_policy_url": "https://joyway.games/privacy-policy", "developer_terms_of_service_url": "https://joyway.games/terms-of-service", "publisher_name": "Joy Way", "support_website_url": null, "website_url": "https://joyway.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8057795797629910"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1623892291498554"}, {"status": "PUBLISHED", "id": "1774150402989186"}]}, "baseline_offer": {"id": "1774150402989186"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1623892291498554"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8882186065190875", "version": "1.1.8"}, "id": "514754514282889", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8057795767629913", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8882186065190875"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "514754514282889