e_final.png", "id": "8529658553714773", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566695_8529658557048106_7419729879493828961_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UXwfggBt92kQ7kNvgEk_0Cj&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAs1F9AjMKP9A9rKp7UD9Ufux_rHivpXpD20FwaQqz6RQ&oe=67752969"}, {"file_name": "screenshot_terrain_final.png", "id": "1302744327198101", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569486_1302744330531434_4640078511257853477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_ndsBuCmyUQ7kNvgGMbuAl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBDZSAA3FdNk-Gz64iZ8rYw7b9u8Tp1j26WN_iGOzu4ww&oe=67753B46"}, {"file_name": "screenshot_passthrough_final.png", "id": "622384759404541", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974676_622384762737874_4507191442478279626_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Ff9j6itMk8Q7kNvgEcTt8g&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDhpwEy_oLHrDM7c47pUyM9FXT-3t9CVKaHfHIeeYw3rA&oe=67754213"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "765448778062707", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003257_765448781396040_4839994669853171722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xp89hp3N3QcQ7kNvgEeOu9l&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB7b_dHP5ojWxvpN__ZcxVpRYKPDVfdQSzMZqI19tAoxg&oe=67751EAF"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: 