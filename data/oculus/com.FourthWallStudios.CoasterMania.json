ad3-2.oculuscdn.com&oh=00_AYBslNOKuSl9SHA5OPPaOPWYjW1-Nbp78s6ZagHFXGBqLw&oe=6766A29E"}, {"file_name": "10.png", "id": "520020024364355", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974469_520020031031021_753106898793814438_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OkJ6oY1GwGIQ7kNvgFoeHZd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBK8C8Ug4kHyN8JLWZWPGN_aFsfoFmFcjPP_dlxEk9e_A&oe=6766AA07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1109115030654458", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031360_1109115037321124_1546349341370444684_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZzqsYlhK_cMQ7kNvgFZrEPf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYMJvnTv11sMXZA19uJlt3puxi0OJ_3jqG6sugzzrpIQ&oe=6766999D"}, "display_name": "CoasterMania", "keywords": ["Rollercoaster", "Sandbox", "Track", "Coaster", "Mania"], "long_description": "# Build, Ride, & Share Rollercoasters in Mixed Reality!\nCreate and ride thrilling rollercoasters in your own space with **CoasterMania**! Use physics-based tools to design jaw-dropping tracks that adapt to your room, then hop in the front seat for a first-person ride like no other.\n{2044160589411597}\n\n\n\n\n# Campaign Mode\nComplete over 50 puzzles across four themed worlds\u2014Medieval, Western, Atlantis, and Sci-Fi. Solve challenges, unlock cosmetics, and master the art of coaster-building!\n{1092357901949034}\n\n# Sandbox Mode\nTurn your room into a coaster playground! Build tracks through your space with gadgets like cannons, rocket propellers, and portals. Decorate with props, sculpt terrain, and experience your creations in VR, zipping around furniture and even your pets.\n{2874787972689001}\n\n# Showcase Mode\nShare your coasters and ride creations from players around the world!\n\nBring your imagination to life\u2014your living room is now a theme park!\n\n{1078555903573759}", "short_description": "Bring the thrill of rollercoasters into your world with CoasterMania! Use mixed reality to craft epic rides that twist and turn through your room, then jump in and experience your masterpiece from the best seat in the house!  "}]}, "developer_name": "4th Wall Breakers", "developer_privacy_policy_url": "https://stephenrogers6.wixsite.com/coastermania/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "4th Wall Breakers", "support_website_url": null, "website_url": "https://www.coastermaniavr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27639427149035894"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031370_402559002934880_5881930732539718093_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QGw8LpV47jAQ7kNvgEOvmRo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvK0uOdPFCQkLujwQ5-4G19hUdeHaPK_jWYH_7Zsmy5w&oe=67669BD7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CoasterMania", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sandbox", "id": "1990104051447093"}, {"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Simulation", "id": 