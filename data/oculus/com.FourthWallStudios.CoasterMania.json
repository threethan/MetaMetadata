hare_final.png", "id": "8529658553714773", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57566695_8529658557048106_7419729879493828961_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YL8lzxBVf1oQ7kNvgHszLYD&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDLVv5EJCntvnW3TeW_aMIH2Hm4TsSyD4HSHukIuQjpaQ&oe=67582869"}, {"file_name": "screenshot_terrain_final.png", "id": "1302744327198101", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57569486_1302744330531434_4640078511257853477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7MsJMEJ-IesQ7kNvgHD0VFf&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCQxjPormpQU7I5cJ5_Cw_9XwpcP7MZMw8enNwRxqFtag&oe=67583A46"}, {"file_name": "screenshot_passthrough_final.png", "id": "622384759404541", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974676_622384762737874_4507191442478279626_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xEFNZG3P9psQ7kNvgG-5fux&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYD8F15QedZqUtJON63NhPP8L748HzVbKBrestrj6eao0A&oe=67584113"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "765448778062707", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39003257_765448781396040_4839994669853171722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YdT52yI7lfgQ7kNvgG4JjvV&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDByIkYyU6zH3krgMowCsjBCVmOf2VDkhIjLdwT8biq8A&oe=67581DAF"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: Place your rollercoaster in the real world & build a track all around your house. \n\nPUZZLE MODE: Coming soon!\n\nONLINE SHARING: Infinite replayability with lots of depth. Access unlimited community-made rollercoasters in Online Sharing.   \n\nADDITIONAL FEATURES: \n- Terrain editor. \n- Decorate the environment with trees, rocks, and other props.", "short_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  "}]}, "developer_name": "Stephen Rogers", "developer_privacy_policy_url": "https://stephenrogers6.wixsite.com/coastermania/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "4th Wall Breakers", "support_website_url": null, "website_url": "https://www.coastermaniavr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1111892749745810"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "2509796049216408"}, {"status": "PUBLISHED", "id": "605134771413405"}, {"status": "PUBLISHED", "id": "522620866654128"}, {"status": "PENDING", "id": "1063548711290357"}]}, "baseline_offer": {"id": "2509796049216408"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733421600, "status": "PUBLIS