4_4640078511257853477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LGKe4taEyBwQ7kNvgHM48Uo&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYCF6qHb6N-_E6x4z-JVAf-woGvcVIq4-ssdorPHkJMOMQ&oe=6728C446"}, {"file_name": "screenshot_passthrough_final.png", "id": "622384759404541", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974676_622384762737874_4507191442478279626_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CyKhGaIsXN4Q7kNvgFdeNVl&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCGyqvLG7FdOCluV_CkxVt4D4-2j-Ti0YStvmh_W0AVGw&oe=6728CB13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "765448778062707", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39003257_765448781396040_4839994669853171722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l11RGrHSAK8Q7kNvgFySjNY&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDdAv4udIhwzcHta0PBavlWh-SIwWwu58TLaaCmbzGT0Q&oe=6728A7AF"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: Place your rollercoaster in the real world & build a track all around your house. \n\nPUZZLE MODE: Coming soon!\n\nONLINE SHARING: Infinite replayability with lots of depth. Access unlimited community-made rollercoasters in Online Sharing.   \n\nADDITIONAL FEATURES: \n- Terrain editor. \n- Decorate the environment with trees, rocks, and other props.", "short_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky cont