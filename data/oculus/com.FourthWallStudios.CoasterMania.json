dn.com/v/t64.5771-25/38982602_1116437456141414_8411135541442710440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xf7uIDLNi7UQ7kNvgG7-FNp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXKZzHuqUjxKPmS4-kP0xa&oh=00_AYAywE0NGEA_QNkvACNKVbCZzP0cZ3RZVCgaUPLXu_0hhg&oe=66EABC1D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoasterMania_pdp_landscape.png", "id": "297880253095280", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974753_297880256428613_1408391219714511861_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z-nhFjLuPBEQ7kNvgGKIeDE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXKZzHuqUjxKPmS4-kP0xa&oh=00_AYCMYvrR5rMlqn-ZsXatuArZKrzqQEsC95qiAnyuBae0Vw&oe=66EAADBF"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: Place your rollercoaster in the real world & build a track all around your house. \n\nPUZZLE MODE DEMO: Use physics and momentum to fly your cart through dangerous fiery rings procedurally placed around your room!\n\nONLINE SHARING: Infinite replayability with lots of depth. Access unlimited community-made rollercoasters in Online Sharing.   \n\nADDITIONAL FEATURES: \n- Terrain editor. \n- Decorate the environment with trees, rocks, and other props.", "short_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  "}]}, "developer_name": "4th Wall Breakers", "developer_privacy_policy_url": "