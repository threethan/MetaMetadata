57853477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BkjFsdK0mAMQ7kNvgHlUDg5&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBr-Jr8blrU7QpsAqtKjSYM2C97XmTeIJkHyCjR4htsxw&oe=6724CFC6"}, {"file_name": "screenshot_passthrough_final.png", "id": "622384759404541", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974676_622384762737874_4507191442478279626_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XHV7S7H8xi0Q7kNvgG9qYSK&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCmCShoJwWw-8ihWRz4vkzXzDn21T82na6I9h2dxCvnfQ&oe=6724D693"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "765448778062707", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003257_765448781396040_4839994669853171722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mQjYBYed0SgQ7kNvgGph0uM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCcyitrCTUkS7NKh5bgsHN__meQ0k83AHtYTZ88mjdWjQ&oe=6724B32F"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: Place your rollercoaster in the real world & build a track all around your house. \n\nPUZZLE MODE: Coming soon!\n\nONLINE SHARING: Infinite replayability with lots of depth. Access unlimited community-made rollercoasters in Online Sharing.   \n\nADDITIONAL FEATURES: \n- Terrain editor. \n- Decorate the environment with trees, rocks, and other props.", "short_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and eleme