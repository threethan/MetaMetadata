e_final.png", "id": "8529658553714773", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566695_8529658557048106_7419729879493828961_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ECCq5f4TSDEQ7kNvgHhcXyF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5mPoVsb_naUXItkyLpAKjVLucrbyqVKitUl5Lud7XFQ&oe=677A6F69"}, {"file_name": "screenshot_terrain_final.png", "id": "1302744327198101", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569486_1302744330531434_4640078511257853477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJYExckt6sAQ7kNvgExM0eU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARfPA5GoTBUH8PB031aUa-IN6sJkU3Gun0AlGbcbfjQg&oe=677A8146"}, {"file_name": "screenshot_passthrough_final.png", "id": "622384759404541", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974676_622384762737874_4507191442478279626_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elA0FdxVZI8Q7kNvgEAQo8h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCxTCyMNJKRFcxLqZACssa_9CmpwPvuqWGq49GDGf66g&oe=677A8813"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "765448778062707", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003257_765448781396040_4839994669853171722_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQfSEHH_YYkQ7kNvgEgrNsf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhdcRucotPKEkvuFgPckBjUAdFzbToa7AF8hczA96G0A&oe=677A64AF"}, "display_name": "CoasterMania", "keywords": [], "long_description": "CoasterMania is a physics-based VR rollercoaster game where you create the ride of your life! Use wacky contraptions and elements to fly through the sky, then experience your creation by jumping in the front seat. \n  \nSANDBOX MODE: Build your dream rollercoaster without any rules but the rules of physics. When you're done, share your coaster or experience the engineering marvels of others.  Design your own rides and upload them online\n\nPASSTHROUGH MODE: 