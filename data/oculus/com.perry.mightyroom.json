7a0a&_nc_ohc=-N745rZLEdgQ7kNvgHCMfqH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AApOUVobTlaldsPNeoLwdBg&oh=00_AYDnXlQkwwLw0mYrrpbZ6hUfzB1zRYe4kGJeTed2qSIlZw&oe=66F3E18A"}, {"file_name": "ss4.png", "id": "814218720822282", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86867711_814218724155615_47084801846210585_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6JaCVmucGOMQ7kNvgGNg0sH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AApOUVobTlaldsPNeoLwdBg&oh=00_AYB0Z3uJKLI3vOG7UsxhkmImLJ51QAivp67ksydpMQ1MfA&oe=66F3FC8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "3831938680360904", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031586_3831938683694237_9065793620056266647_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EoVDv4OIdOwQ7kNvgGPHPYJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AApOUVobTlaldsPNeoLwdBg&oh=00_AYB1XnfkmD5p4hmL4xAPBhcWUKLjSF_2ao0kyrR3TIdhrQ&oe=66F3EAC9"}, "display_name": "Mighty Room", "keywords": [], "long_description": "Description:\nEmbark on a thrilling adventure in \"Mighty Room,\" an immersive VR game where stealth, strategy, and cunning are your greatest allies. In this high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n\nGame Features:\n\n    Immersive VR Environment:\n        Dive into a meticulously designed world with cutting-edge VR graphics that make you feel like you're truly inside a colossal, high-tech room. Every corner, shadow, and detail is crafted to enhance your immersive experience.\n\n    Stealth and Strategy Gameplay:\n        Engage in heart-pounding stealth gameplay where every move matters. Use your intelligence and agility to stay hidden, create distractions, and outmaneuver the vigilant room owner.", "short_description": "Description:\nEmbark on a thrilling adv