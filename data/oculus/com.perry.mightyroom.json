087250351247_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uyleui8KFOcQ7kNvgFsPElb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAF7vfZw7I1581Bhpw0U0e4m0kkn24td5ylzKqyZW3dfA&oe=67826C75"}, {"file_name": "ss2.png", "id": "498593312566813", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974528_498593315900146_8922501169316056270_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n0rZjY-h2DUQ7kNvgGIcMz_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNd6F_wyFzkIfBmJaOCPje7fm6anQK0vbA-jxrj1RCng&oe=6782438A"}, {"file_name": "ss4.png", "id": "814218720822282", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86867711_814218724155615_47084801846210585_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RDs-V6q2aXEQ7kNvgGj9Rh-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBldkpxA8-iJg4ZgWN9z-LQsd6wtnhOut4SeMGSvgD_6Q&oe=67825E8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "3831938680360904", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031586_3831938683694237_9065793620056266647_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6NUbwPbqjo4Q7kNvgEAnRC6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCg9ad4jlWBG3whkZ0xYDZPPI8ASgauxHMzYXI1a3vJ0g&oe=67824CC9"}, "display_name": "Mighty Room", "keywords": [], "long_description": "Description:\nEmbark on a thrilling adventure in \"Mighty Room,\" an immersive VR game where stealth, strategy, and cunning are your greatest allies. In this high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n\nGame Features:\n\n    Immersive VR Environment:\n        Dive into a meticulously designed world with cutting-edge VR graphics that make you feel like you're truly inside a colossal, high-tech room. Every corner, shadow, and detail is crafted to enhance your immersive experience.\n\n    Stealth and Strategy Gameplay:\n        Engage in heart-pounding stealth gameplay where every move matters. Use your intelligence and agility to stay hidden, create distractions, and outmaneuver the vigilant room owner.", "short_description": "Description:\nEmbark on a thrilling adventure in \"Mighty Room,\" an immersive VR game where stealth, strategy, and cunning are your greatest allies. In this high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mighty-room/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Perry Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/mighty-room", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26002188332730172"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "4047701445461874"}, {"status": "PUBLISHED", "id": "1122820285477608"}]}, "baseline_offer": {"id": "1122820285477608"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "st