7a0a&_nc_ohc=-N745rZLEdgQ7kNvgGKJMIX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFh2iIpNppxUG5Tb7dVLEOh&oh=00_AYDLAQqing1ozcr9FILa3bPz-mI6aHd1LnZAt1I5yJfXBg&oe=66F5330A"}, {"file_name": "ss4.png", "id": "814218720822282", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86867711_814218724155615_47084801846210585_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6JaCVmucGOMQ7kNvgFgsIvu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFh2iIpNppxUG5Tb7dVLEOh&oh=00_AYDfIu45wM-M9hRaxd24f-2rZDDr6IRJ0-AzOzesnkKgag&oe=66F54E0D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "3831938680360904", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031586_3831938683694237_9065793620056266647_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EoVDv4OIdOwQ7kNvgHa6Wcg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFh2iIpNppxUG5Tb7dVLEOh&oh=00_AYDBMrnIuzM1OB1Br1Ex8WgoWmxueR_WitCRZOcHetDfHw&oe=66F53C49"}, "display_name": "Mighty Room", "keywords": [], "long_description": "Description:\nEmbark on a thrilling adventure in \"Mighty Room,\" an immersive VR game where stealth, strategy, and cunning are your greatest allies. In this high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n\nGame Features:\n\n    Immersive VR Environment:\n        Dive into a meticulously designed world with cutting-edge VR graphics that make you feel like you're truly inside a colossal, high-tech room. Every corner, shadow, and detail is crafted to enhance your immersive experience.\n\n    Stealth and Strategy Gameplay:\n        Engage in heart-pounding stealth gameplay where every move matters. Use your intelligence and agility to stay hidden, create distractions, and outmaneuver the vigilant room owner.", "short_description": "Description:\nEmbark on a thrilling adventure in \"Mighty Room,\" an immersive VR game where stealth, strategy, and cunning are your greatest allies. In this high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mighty-room/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Perry Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/mighty-room", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26002188332730172"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931336_462168589861003_8952256032087248072_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3oyZSDjyd7QQ7kNvgHz1TaA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFh2iIpNppxUG5Tb7dVLEOh&oh=00_AYCovjxtZrsVSCh0UKBzk5arUelHu1naVS3N_hmB9aw1eA&oe=66F543C3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mighty Room", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_t