s high-stakes game, your mission is to \"borrow\" valuable items from an enormous, high-tech space while avoiding detection by the colossal room owner. Experience a blend of suspense, excitement, and futuristic innovation as you navigate through a vast and intricate environment.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mighty-room/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Perry Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/mighty-room", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26002188332730172"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/43931336_462168589861003_8952256032087248072_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xrIyzgqefsoQ7kNvgHKad-u&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCD8KJGj1deSpYN5dQlMgPAogPu9vMRQ3kRSIt7YYwZcQ&oe=677BBCC3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mighty Room", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1721621846, "lastRevisi