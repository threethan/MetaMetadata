ZtQHTgQ7kNvgGrQzrP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzOiUSk2vtKbyhed1FC1q_wpUJQl80DK16_Fyoj4qsqQ&oe=6783A954"}, {"file_name": "StatueSS.png", "id": "409463572111823", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974889_409463578778489_2524195900194465476_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HdS_wr3S1kcQ7kNvgGK3xnZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM8RA3XGR9cnhAHxPZBR1rTe8maGRxYcLoc6TdSeVQCQ&oe=6783AEEA"}, {"file_name": "PbbvSS.png", "id": "436244476079297", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036662_436244479412630_5112527749587843215_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-HXB_DDyccQ7kNvgHJR4uB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmMHOLDdreTi1yEJy2mn-_3KGq6gkLtxg8DBG-bo81Vw&oe=67839EA5"}, {"file_name": "WardrobeSS.png", "id": "1727063364734812", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974856_1727063368068145_6092962011821609742_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9b476nEVFgcQ7kNvgEA2aff&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXFGe4ZGsew-piyus6STxiSsnt1ExPEPO93ad_wd4UEA&oe=6783B393"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpookiTagLogoNoText.png", "id": "1197538434610872", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001676_1197538437944205_3100403394699496241_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylCR2ThCJXEQ7kNvgFK-gyR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCED96MK5ANc1uuVQatOBhcK_1AWJI0ORvOk5SVCyG26w&oe=6783955E"}, "display_name": "Spooki Tag", "keywords": [], "long_description": "Spooki Tag is a thrilling fan-made homage to the popular game Gorilla Tag, reimagined with a chilling horror twist. Dive into an eerie environment where every shadow and sound keeps you on edge. In Spooki Tag, players must navigate haunted maps, using their wits and agility to avoid terrifying entities lurking in the darkness. With unique mechanics and original assets, Spooki Tag offers a spine-tingling multiplayer experience that pays tribute to the original game while delivering heart-pounding horror. Are you brave enough to join the chase?", "short_description": "Spooki Tag is a thrilling fan-made horror twist on the popular game Gorilla Tag. Navigate eerie maps and avoid terrifying entities lurking in the shadows. With unique mechanics and original assets, Spooki Tag offers a spine-tingling multiplayer experience that pays homage to the original while delivering heart-pounding horror. Are you brave enough to join the chase?"}]}, "developer_name": "Aero Monk Studios", "developer_privacy_policy_url": "https://sites.google.com/view/spooki-tag/privacy-policy?authuser=0", "developer_terms_of_service_url": null, "publisher_name": "GoodSoup", "support_website_url": null, "website_url": "https://sites.google.com/view/spooki-tag/home?authuser=0", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25995772826733410"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1965155747250132"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723258800, "status": "PUBLISHED", "id": "1965155747250132"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2637676688530066