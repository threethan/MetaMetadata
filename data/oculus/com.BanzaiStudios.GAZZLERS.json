5282158_520279389889027_325854125297509419_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rLmlLeGyXSkQ7kNvgG4ljxm&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZPOhsA0zyG2Jxdcsr4RqUrVA4q3cc9QVhwwF0ylVFuQ&oe=66DEF4E4"}, {"file_name": "screenshot_phil_choice_nl.png", "id": "739788560480758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375756_739788563814091_1481168140613050431_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p6SemSAhhZcQ7kNvgFFyw2G&_nc_ht=scontent.oculuscdn.com&oh=00_AYAohTqnMryv9xA0E_4plbdUAsH1hl4AmzZmyMGP4oC0Sg&oe=66DECCA3"}, {"file_name": "screenshot_lobby_nl.png", "id": "432293182238624", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031354_432293185571957_2087170394270923199_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BTsr3WLNTpoQ7kNvgHVWykF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBh_3NE1LdvjCuRFIaXbgYJtXn1enJawyEBtBFPUCtZA&oe=66DEE901"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-art_landscape.png", "id": "1450427208719079", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_1450427212052412_7567714177884696049_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oDL9by_qhCIQ7kNvgEUTjR4&_nc_ht=scontent.oculuscdn.com&oh=00_AYArCnEXotM9zB3Rdl1OFaiUfCabDG213mK6BgmQbc9AwQ&oe=66DED266"}, "display_name": "GAZZLERS", "keywords": [], "long_description": "Start je Pelgrimstocht aan boord van een aftandse locomotief op weg naar het Eindstation: de \u201cverloren Tempel van de Machine God\u201d.\n\nVecht met de Gazzlers! Ze besturen hun mechanische misbaksels met als enige doel om jouw tocht te dwarsbomen!\n\nVerzamel mysterieuze objecten die door de Apostelen achtergelaten werden. Combineer wapenonderdelen die zo knotsgek zijn dat ze misschien toch goed werken!\n\nVul de oude archieven aan en ontrafel de geheimen van een oude vergeten wereld vol surrealisme en mysterie. Puzzel het verhaal van Ginkgo bijeen en ontdek de waarheid achter de geheimzinnige Eeuwige Vlam!", "short_description": "GAZZLERS is 