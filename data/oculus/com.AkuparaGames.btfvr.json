5rd-rIQ7kNvgGTW3du&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHXatCOQRbd-u48QR43lJG8PK4GXBBTgUp9PnNSEHv6A&oe=676E91D6"}, {"file_name": "BTFVR_SS_4.png", "id": "168096126127236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974791_168096129460569_3374638376020859990_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eBZn-i1UNUsQ7kNvgFPiidx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCoCqaw9BAgEi-W883uox3w49P7k2Lj3P-l_xCeIYMpjQ&oe=676E9F58"}, {"file_name": "BTFVR_SS_5.png", "id": "789704402858787", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031603_789704406192120_2582869331303730724_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzrHDVdN2PAQ7kNvgFWXdyK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7eOJPPJ44W4zALfZ2oztXIdi-juTM54NCelHS68uALg&oe=676E81B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BTF_Graphic_Meta_TrailerThumbnail_2560x1440_V1.png", "id": "1004833247378719", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035416_1004833250712052_8179189765754741748_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iBttQMAE-OMQ7kNvgF1N1Lx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmjx8gj6q7CPKu6DfNfleAaK7mNdXD28KgvNE4pnb9NQ&oe=676E9B59"}, "display_name": "Behind The Frame: The Finest Scenery VR", "keywords": ["btf", "painting", "paint", "anime", "casual"], "long_description": "Behind the Frame is a vivid, interactive fiction about an aspiring artist on the cusp of finishing the final piece of her gallery submission.\n\nA relaxing, eloquent experience that can be played at any pace. Become immersed in a panoramic world filled with resplendent colors, beautiful hand-animated visuals, and a smooth, easy-listening soundtrack.\n\nAs a passionate artist, seek the missing colors that will bring your paintings to life - all while remembering to take the occasional coffee and breakfast breaks that keep you going. There is more than what meets the eye, for every painting has a story to tell.\n\nFeature List\n\u2022 Making Masterpieces: Paint, sketch, and retouch your artwork to complete your masterpiece and your memories\n\u2022 Intricate Immersion: Dive into and explore panoramic, VR worlds inspired by Miyazaki/Studio Ghibli visuals\n\u2022 Submerge in the Memory: Experience an evocative story, through the eyes of a passionate artist", "short_description": "Guide brush strokes and solve a variety of puzzles to help an aspiring artist complete her masterpiece amid her brusque neighbor\u2019s gaze and his pesky cat. As her painting starts to take shape, uncover an emotional tale of chance and artistry revealed behind unrelated yet familiar moments.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.akuparagames.com/privacy-policy-of-behind-the-frame-the-finest-scenery-vr", "developer_terms_of_service_url": null, "publisher_name": "Akupara Games", "support_website_url": null, "website_url": "https://www.akuparagames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "zh_TW", "zh_HK", "ru", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "820594612983858"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1099526981631743"}, {"status": "PUBLISHED", "id": "511787678265177"}, {"status": "PUBLISHED", "id": "7158425860923544"}, {"sta