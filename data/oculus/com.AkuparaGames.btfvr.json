], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BTF_Graphic_Meta_TrailerThumbnail_2560x1440_V1.png", "id": "1004833247378719", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035416_1004833250712052_8179189765754741748_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMrTdJidDhcQ7kNvgGJkhEP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCl45bR89g63ZrU42VGqVG5ZyvhyZUCA-IBm3Stx-U-8w&oe=6703D1D9"}, "display_name": "Behind The Frame: The Finest Scenery VR", "keywords": ["btf", "painting", "paint", "anime", "casual"], "long_description": "Behind the Frame is a vivid, interactive fiction about an aspiring artist on the cusp of finishing the final piece of her gallery submission.\n\nA relaxing, eloquent experience that can be played at any pace. Become immersed in a panoramic world filled with resplendent colors, beautiful hand-animated visuals, and a smooth, easy-listening soundtrack.\n\nAs a passionate artist, seek the missing colors that will bring your paintings to life - all while remembering to take the occasional coffee and breakfast breaks that keep you going. There is more than what meets the eye, for every painting has a story to tell.\n\nFeature List\n\u2022 Making Masterpieces: Paint, sketch, and retouch your artwork to complete your masterpiece and your memories\n\u2022 Intricate Immersion: Dive into and explore panoramic, VR worlds inspired by Miyazaki/Studio Ghibli visuals\n\u2022 Submerge in the Memory: Experience an evocative story, through the eyes of a passionate artist", "short_description": "Guide brush strokes and solve a variety of puzzles to help an aspiring artist complete her masterpiece amid her brusque neighbor\u2019s gaze and his pesky cat. As her painting starts to take shape, uncover an emotional tale of chance and artistry revealed behind unrelated yet familiar moments. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.akuparagames.com/privacy-policy-of-behind-the-frame-the-finest-scenery-vr", "developer_terms_of_service_url": null, "publisher_name": "Akupara Games", "support_website_url": null, "website_url": "https://www.akuparagames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "zh_TW", "zh_HK", "ru", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6986815911338594"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_287838193637432_1721950679602158742_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bkvmeQ5r2cgQ7kNvgHqAzvL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyDGL2sHJa_SnGhoAEOmqXcy9dZ62r857iCQcw5aoGrg&oe=6703C499"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Behind The Frame: The Finest Scenery VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "RPG (Role Playing Games)", "id": "961172191044986"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1694707200, "lastRevision": {"nodes": [{"id": "5751701041516760", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5751701001516764", "is_first_party": fals