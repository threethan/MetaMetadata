ntent.oculuscdn.com&oh=00_AYBCTN8yw7DqE55EK5f14iKRwKWqtlS1fzkoAh1dRvsuCA&oe=66ED6380"}]}, "id": "1481703302622494", "locale": "en_US", "screenshots": [{"file_name": "BTFVR_SS_1.png", "id": "163469943310824", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_163469946644157_3306966324160905_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v5GxcbwYfFgQ7kNvgFgcFce&_nc_ht=scontent.oculuscdn.com&oh=00_AYCqOV_Jq0GvWdZD1kPjAGypBvCfmODN3SgUbmsKUMil6Q&oe=66ED69C4"}, {"file_name": "BTFVR_SS_2.png", "id": "926833155042729", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974551_926833161709395_6381141322989834062_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AotcOTD8LU8Q7kNvgHTJ4zr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaNJrGE3RZoWKhigg3A_U8W6o5FjOz7lDw_GZgksYCnA&oe=66ED6B81"}, {"file_name": "BTFVR_SS_3.png", "id": "652769516358118", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031452_652769523024784_4349598323571350812_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=soEm8jsyLD0Q7kNvgGyyPeC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwV38qwr5uMTa6L9yf9-wcUtLkqtky2FLN4EU2PegnCw&oe=66ED5ED6"}, {"file_name": "BTFVR_SS_4.png", "id": "168096126127236", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974791_168096129460569_3374638376020859990_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=98U7IXN3PAIQ7kNvgGADS3C&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5A6RfPMMEpLkAJHRNFc6B3kGsBJO50QeCfX_XxyDaIA&oe=66ED6C58"}, {"file_name": "BTFVR_SS_5.png", "id": "789704402858787", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031603_789704406192120_2582869331303730724_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebS1dXI5LVUQ7kNvgHZkH2m&_nc_ht=scontent.oculuscdn.com&oh=00_AYC19AFukxN3mB_96qg7CwoC5M60_BQYXDj8HJriVdkEMQ&oe=66ED4EB8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BTF_Graphic_Meta_TrailerThumbnail_2560x1440_V1.png", "id": "1004833247378719", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035416_1004833250712052_8179189765754741748_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p-Q0_hDEE_QQ7kNvgHU2FvP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZGUPb-NwVU_2VoefHbMXD8HQqU3BFGQIJeFLX_vuDJw&oe=66ED6859"}, "display_name": "Behind The Frame: The Finest Scenery VR", "keywords": ["btf", "painting", "paint", "anime", "casual"], "long_description": "Behind the Frame is a vivid, interactive fiction about an aspiring artist on the cusp of finishing the final piece of her gallery submission.\n\nA relaxing, eloquent experience that can be played at any pace. Become immersed in a panoramic world filled with resplendent colors, beautiful hand-animated visuals, and a smooth, easy-listening soundtrack.\n\nAs a passionate artist, seek the missing colors that will bring your paintings to life - all while remembering to take the occasional coffee and breakfast breaks that keep you going. There is more than what meets the eye, for every painting has a story to tell.\n\nFeature List\n\u2022 Making Masterpieces: Paint, sketch, and retouch your artwork to complete your masterpiece and your memories\n\u2022 Intricate Immersion: Dive into and explore panoramic, VR worlds inspired by Miyazaki/Studio Ghibli visuals\n\u2022 Submerge in the Memory: Experience an evocative story, through the eyes of a passionate artist", "short_description": "Guide brush strokes and solve a variety of puzzles to help an aspiring artist complete her masterpiece amid her brusque neighbor\u2019s gaze and his pesky cat. As her painting starts to take shape, uncover an emotional tale of chance and artistry revealed behind unrelated yet familiar moments. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.akuparagames.com/privacy-policy-of-behind-the-frame-the-finest-scenery-vr", "developer_terms_of_service_url": null, "publisher_name": "Akupara Games", "support_website_url": null, "website_url": "https://www.akuparagames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags":