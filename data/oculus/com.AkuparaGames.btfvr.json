HrkPPsf&oh=00_AYBKuB4ATuPukZUY8jP-dK0SXnK1Nk6Jkbm42EXYP8h9wA&oe=66EEBD01"}, {"file_name": "BTFVR_SS_3.png", "id": "652769516358118", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031452_652769523024784_4349598323571350812_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=soEm8jsyLD0Q7kNvgEsbDuh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqJJBUSaU0S3yeWWHrkPPsf&oh=00_AYB3qMWKQA5KOprL0NAg1IwHT-zrqGuwnHgYSLDybbctzQ&oe=66EEB056"}, {"file_name": "BTFVR_SS_4.png", "id": "168096126127236", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974791_168096129460569_3374638376020859990_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=98U7IXN3PAIQ7kNvgFdVCST&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqJJBUSaU0S3yeWWHrkPPsf&oh=00_AYBhQKI7XlxatGaay6wqvzZxdXbhrHv2biPL1edomJB3pA&oe=66EEBDD8"}, {"file_name": "BTFVR_SS_5.png", "id": "789704402858787", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031603_789704406192120_2582869331303730724_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebS1dXI5LVUQ7kNvgFKEwFT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqJJBUSaU0S3yeWWHrkPPsf&oh=00_AYCJOQg-Eb93aA1GvBSlBr9Hfpkcmt3gXfN2s-yQOVBXug&oe=66EEA038"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BTF_Graphic_Meta_TrailerThumbnail_2560x1440_V1.png", "id": "1004833247378719", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035416_1004833250712052_8179189765754741748_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p-Q0_hDEE_QQ7kNvgFTYbbf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqJJBUSaU0S3yeWWHrkPPsf&oh=00_AYAZWA7RrQqtMICdMYA8k38AglAwQ5_3qWnZhlgRrsjTnA&oe=66EEB9D9"}, "display_name": "Behind The Frame: The Finest Scenery VR", "keywords": ["btf", "painting", "paint", "anime", "casual"], "long_description": "Behind the Frame is a vivid, interactive fiction about an aspiring artist on the cusp of finishing the final piece of her gallery submission.\n\nA relaxing, eloquent experience that can be played at any pace. Become immersed in a panoramic world filled with resplendent colors, beautiful hand-animated visuals, and a smooth, easy-listening soundtrack.\n\nAs a passionate artist, seek the missing colors that will bring your paintings to life - all while remembering to take the occasional coffee and breakfast breaks that keep you going. There is more than what meets the eye, for every painting has a story to tell.\n\nFeature List\n\u2022 Making Masterpieces: Paint, sketch, and retouch your artwork to complete your masterpiece and your memories\n\u2022 Intricate Immersion: Dive into and explore panoramic, VR worlds inspired by Miyazaki/Studio Ghibli visuals\n\u2022 Submerge in the Memory: Experience an evocative story, through the eyes of a passionate artist", "short_description": "Guide brush strokes and solve a variety of puzzles to help an aspiring artist complete her masterpiece amid her brusque neighbor\u2019s gaze and his pesky cat. As her painting starts to take shape, uncover an emotional tale of chance and artistry revealed behind unrelated yet familiar moments.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.akuparagames.com/privacy-policy-of-behind-the-frame-the-finest-scenery-vr", "developer_terms_of_service_url": null, "publisher_name": "Akupara Games", "support_website_url": null, "website_url": "https://www.akuparagames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "zh_TW", "zh_HK", "ru", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": 