MVxYdwvk_BTrQ&oe=677E7EB1"}, {"file_name": "2019-06-15_12-08-17.png", "id": "1128484751234151", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982512_1128484754567484_4383932164145087368_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DLb2tpmAGCEQ7kNvgEEbT-8&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAhsXH8ceJl_fdiTnqBoOn7ZDy4_eLnVTWPXlcx9MSyzg&oe=677E7214"}, {"file_name": "2019-06-15_11-51-39.png", "id": "936719776895822", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974526_936719780229155_2319144500103752663_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iIzXkB60oC0Q7kNvgGsTEyj&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYA0K_2PUleSdKDHT1v20IuNie28hD6BCMBWbyAwXWr1SA&oe=677E6C75"}, {"file_name": "2019-06-15_11-54-25.png", "id": "1445675765847474", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38982699_1445675769180807_1042152137665252181_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YI2bbKJegrUQ7kNvgHvpCe3&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYCe_w9MxdWW4CEJlhaAuUlqL7BtDZlthRsaSKDnAxdXyA&oe=677E5B97"}, {"file_name": "2019-06-15_11-58-13.png", "id": "450621576693685", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39036614_450621580027018_5690465298049970931_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MFgiZV1HGXAQ7kNvgGXH9Dd&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYA2Uo8Z7EnG6RlEJ1ozt_zd3i9XT1ALBBWsLnz7sXsilg&oe=677E6F3E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mobile VR Station", "keywords": [], "long_description": "This is the third re-write of Mobile VR Station and was based upon the successful iOS/Android versions, but re-imagined to work only in VR.  The player has been built from the ground up to display 2D & 3D content on various projections such as Plane, Spherical, Dome, Full Dome, Curved and EAC.\n\nThe player will continue in its freemium tradition and allows you to try all features before buying.  The only limitation of the free version is it will only play the first five minutes of any video, but you are free to make sure it works with your content and has all the needed features at your leisure.  We offer support on our Facebook page if you have any questions and links are available inside the app to our various pages, online tutorials and the extensive help guide.", "short_description": "A highly customizable VR media player that has support for many formats such as 360, 180, Full Dome, Over Under and Side by Side."}]}, "developer_name": "Michael Fuller", "developer_privacy_policy_url": "https://mgatelabs.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Michael G Fuller JR", "support_website_url": null, "website_url": "https://mgatelabs.com/mobile-vr-station/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MEDIA_PLAYER", "UTILITY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "702781544319936"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "538770481361242"}]}, "baseline_offer": {"id": "538770481361242"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1658778060, "status": "PUBLISHED", "id": "538770481361242"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9165091446863434", "version": "2024.12.11"}, "id": "13675