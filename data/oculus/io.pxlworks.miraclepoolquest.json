0_700958618154741_841056018972498732_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5wy-ahNvv1YQ7kNvgEtoAtP&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA0rEY4Cc_LlaA4m4ogOxlvvUMbJTl9u0d4Hc_xC1Zicw&oe=67766A3C"}, {"file_name": "MRPool_meta_screenshot_2560x1440_3.png", "id": "862915232024955", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982528_862915235358288_8848225477585209988_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_m5ej_iDAgQ7kNvgGGHLn9&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAuOstE0_JPVwfs5-dJxaW5_UCvI20mQG3Y41fQxK7cTw&oe=67766A05"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MiRacle Pool", "keywords": [], "long_description": "Have you ever dreamed about having a pool table in your home? Now you can!\n\nThanks to Mixed Reality and Miracle Pool, you can place a virtual Pool Table in your home, walk around, and shoot some balls. You can also play against friends or against other online players.\n\nThis is a room-scale-only experience and you must have plenty of space to use it. The minimum recommended play area is 3m x 4m (10 feet x 13 feet)\n\nFEATURES:\n- Practice alone (8Ball, 9Ball, 10Ball, practice drills)\n- Play against computer (8 Ball)\n- Play with friends (up to 4 players, no rules enforced)\n- Play ranked matches against random online opponents for ELO points (8 Ball)\n\nNOTE:\nThis is an early access version, and we reserve the rights to change pricing and feature sets.", "short_description": "Your own virtual Pool Table in Mixed Reality."}]}, "developer_name": "Pixel Works", "developer_privacy_policy_url": "https://www.pxlworks.io/mrpt_pp", "developer_terms_of_service_url": null, "publisher_name": "Pixel Works", "support_website_url": null, "website_url": "https://www.pxlworks.io/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603