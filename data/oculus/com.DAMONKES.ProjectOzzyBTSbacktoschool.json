, and let's make gorilla tag fun again in Project Ozzy! It\u2019s not just a game, it\u2019s a movement! Monke Luther King would be proud.\n\n--- ", "short_description": "\"Lets Make Gorilla Tag Great Again\" Monke Luther King"}]}, "developer_name": "Ozzy Da Shark", "developer_privacy_policy_url": "https://sites.google.com/view/projectozzy/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ozzy Da Shark", "support_website_url": null, "website_url": "https://sites.google.com/view/projectozzy/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7800484826687719"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375751_849380533783300_4992995279053541345_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uU0Y0FpN6j4Q7kNvgEgmqdy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A869UjjGBxAbMo6MlGhn7oz&oh=00_AYBkBSa_yijDIua_fDNY5I7fEbWPpv3MEBGzG9N_8B6d1g&oe=66E0153E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Project Ozzy", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1721763293, "lastRevision": {"nodes": [{"id": "780048483668