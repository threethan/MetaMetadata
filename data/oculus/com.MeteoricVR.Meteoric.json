490021434", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86609237_479730496688100_2081599567792533079_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ST5g5wWGkowQ7kNvgH-eVn7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYDSeYcYwC-x2kdfVwWC7IBqxSqSIKEb_GupBnNiUcfUXA&oe=66F13CEF"}, {"file_name": "Frame 3.png", "id": "465985551525811", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297578_465985554859144_1862944891551031006_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rY77n0xH5e4Q7kNvgEcRO6n&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYAzcWjdtvfRQY2yy_qfsVXr4QJ5C4XcdGk9ud5O_hQJIA&oe=66F14865"}, {"file_name": "Frame 5.png", "id": "919739868928769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230038_919739872262102_7284074616056328686_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u0rueR3LJlIQ7kNvgEHeAoG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYBGb6Jyc2y1vseMawpKZLRktImRxGMloUWiYv_rOoW7ow&oe=66F1530B"}, {"file_name": "Frame 7.png", "id": "442574743888500", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_442574747221833_5343900511564065734_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bPnNKj8xu84Q7kNvgEaAy0G&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYBYDWgiCQNP1vtBkxuJ_NhxvaO7U94Ry4SJWxgocY2AVQ&oe=66F15CEF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meteoric VR", "keywords": [], "long_description": "Destroy all the meteorites before they destroy you! You need good peripheral vision and perfect aim in order to succeed in this game. It\u2019s easy to play but hard to master.\n\nExplore 15 levels on three different planets and challenge yourself to get the perfect score. The more you play, the more fit you\u00b4ll physically get. Trust us, you will get pretty sweaty while shooting the meteorites and avoiding alien\u2019s attacks at the same time! Can you save Earth, Moon and Mars from destr