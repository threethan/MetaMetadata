1_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8qTTmlmuuMQ7kNvgF9u_1F&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYC92zRnK1qXry22j2s7xp5kmjvK2YQwuMXB2y7tFCarkw&oe=66F142E7"}, {"file_name": "Frame 4182 (2) 1.png", "id": "5430612333712027", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_5430612337045360_6891406736222939872_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cLIX1QL0RxMQ7kNvgHAzTgF&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYDnfxAEY4ikUvtN9xwM4XOS98fW7BJ4v42wbzgAIs6ypg&oe=66F16282"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.png", "id": "386456203273425", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240102_386456206606758_8958711361714300569_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SO63m4AcTwcQ7kNvgFghG_c&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYBeLCoClc5PjwG1PBvRdXOtTHAO1tmbeDiUY0B95Z-6KQ&oe=66F1631D"}, "display_name": "Meteoric VR - Demo", "keywords": [], "long_description": "Destroy all the meteorites before they destroy you! You need good peripheral vision and perfect aim to succeed in this game. It\u2019s easy to play but hard to master.\n\nMeteoric VR is a retro low poly first-person space shooter where mission is to protect the planet from incoming meteors. Try not to run out of lives! Our signature feature is a unique movement that you have to make with your hands to achieve successful shooting.\n\nFeatures:\n- 180 degrees gameplay\n- Zero motion sickness\n- Easy to play\n- Aim assist\n- Multiple power ups\n- Fitness element\n- Adaptive music\n- LIV and MRC support\n- Scoring system\n\nWe created Discord as the main platform to interact with the community and beta testers. We share sneak peeks, hottest news, behind the scenes content, and answer questions on a daily basis. If you are interested in the game or want to help us out by giving constructive feedback, please feel free to join the server.\n\nJoin the Meteoric VR Galaxy \u2192 https://discord.gg/VjgDjR5rkD\n\nCheck out the Demo on Steam: https://store.steampowered.com/app/1816770/Meteoric_VR/\nMeteoric VR - Early Access on Applab: https://www.oculus.com/experiences/quest/4128981423869367/", "short_description": "Meteoric VR is a first-person shooter where your mission is to defend the Earth from dangerous meteors in space! The fate of the planet is now in your hands. Will you live up to the task?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://meteoricvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Meteoric s.r.o.", "support_website_url": null, "website_url": "https://meteoricvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3563492813976027"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_851984106071679_3850455081484908977_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2SNxjAvzXNYQ7kNvgEWxJaS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A13wc2--4huAvBjDMBiw58W&oh=00_AYDqpA7DnP6YhqFj9Lefj5Vas1SCx5hGweUua0kfhR3Gyw&oe=66F162BC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meteoric VR - Demo", "platform": "ANDROID