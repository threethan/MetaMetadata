490021434", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86609237_479730496688100_2081599567792533079_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zaz8o5haq3gQ7kNvgGMFlJT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcATzForMH-X-EhlhUMbdsO&oh=00_AYBUF3E04oXaGU8PwRudpY9XCr9aCc207aGvEaIYqlndqw&oe=66ED486F"}, {"file_name": "Frame 3.png", "id": "465985551525811", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297578_465985554859144_1862944891551031006_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5JymLhBk7rcQ7kNvgHasy6j&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcATzForMH-X-EhlhUMbdsO&oh=00_AYDs8AOxbW6VWMV23-Hq4YZZFTizYNVgpgik0hkIT0rUgA&oe=66ED53E5"}, {"file_name": "Frame 5.png", "id": "919739868928769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230038_919739872262102_7284074616056328686_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8LsgJ6zaNF0Q7kNvgGO3Ijk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcATzForMH-X-EhlhUMbdsO&oh=00_AYAGuYYXYsG520x4qPDE8HorGfLfofJvByIt39N1vW6PXg&oe=66ED5E8B"}, {"file_name": "Frame 7.png", "id": "442574743888500", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_442574747221833_5343900511564065734_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v3Y-G89962YQ7kNvgGqdxHk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcATzForMH-X-EhlhUMbdsO&oh=00_AYAHLJzAo6TbJPJMbA2v9zcFVCvBzZuaKzaAYglzZZhI7w&oe=66ED686F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meteoric VR", "keywords": [], "long_description": "Destroy all the meteorites before they destroy you! You need good peripheral vision and perfect aim in order to succeed in this game. It\u2019s easy to play but hard to master.\n\nExplore 15 levels on three different planets and challenge yourself to get the perfect score. The more you play, the more fit you\u00b4ll physically get. Trust us, you will get pretty sweaty while shooting the meteorites and avoiding alien\u2019s attacks at the same time! Can you save Earth, Moon and Mars from destr