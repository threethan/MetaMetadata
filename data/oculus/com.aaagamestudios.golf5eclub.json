n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLnn1JBkuWkQ7kNvgEvjITb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChSsKrEPGJEIqNOWMYx7S0SvjdojTpJ9ivHv16YZnxrg&oe=6741CAAC"}, {"file_name": "Golf5_Screenshot_02.png", "id": "495543904955792", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_495543908289125_7127342155387579884_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BoOa3tNrIEsQ7kNvgG2gfjM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBouxco9_M8zDC3kxgcUH-ynWsPQEsV-Btbv6lRaBT_gA&oe=6741B335"}, {"file_name": "Golf5_Screenshot_04.png", "id": "1633029156906362", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974444_1633029160239695_7471909342320995584_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5hqWrf1r5qYQ7kNvgHhXHdM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBiNwKSGkkkFzKTp_gBA5kr7XN9eeWUqDqf-9vfVVf1dQ&oe=6741ABD3"}, {"file_name": "Golf5_Screenshot_07.png", "id": "257907399333065", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974844_257907402666398_3641523989344504766_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJseZK8yvVcQ7kNvgGEH2Qm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLOUm1lsbR49Qw2BHI3-yfILb9VJLE1F-y3bqOXD13JA&oe=6741D666"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560x1440.png", "id": "199590971613227", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974561_199590974946560_7095862371395979706_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hnY3IBcQAToQ7kNvgGjhEXD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKo2zL04eCIJtoEp2Aj3HdH9KR2lPPVXLU3ME4ewLAJQ&oe=6741B12F"}, "display_name": "Golf 5 eClub", "keywords": [], "long_description": "Do you want to have real fun playing and learning golf at the same time? Welcome to Golf5 eclub, a truly immersive genuine golf experience, that includes:\n\n* 18 hole \"The Dunes\" course, where you can practice or play tournaments\n* A driving range with all the clubs\n* An astounding and realistic putting Green with different levels of difficulty\n* When you don\u00b4t have much time, a WIPP version (Wood, Iron, Pitch & Putt)\n* And finally, a mini-golf for initiation to the game\n\nAll can be played online with your friends. Compete and talk with players around the world. Just enter the clubhouse and look for them. Incredibly realistic and multiplayer experiences. Different rewards as you improve your level and skills. Learn and have fun, while you improve your handicap with the International E-Golf Federation rules, participate in tournaments and become an egolf pro.", "short_description": "Golf 5 eClub is a new way to learn, play and practice Golf. You will belong to a virtual club where you can play 18 holes or practice like in a real club. You can also play or compete online. A new immersive way to learn and practice your favourite sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aaagamestudios.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "AAA Games Studios S.L.", "support_website_url": "https://www.aaagamestudios.com/client-support/", "website_url": "https://www.aaagamestudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "621687075796341"}}]}, "scheduled_offers": {"count": 52, "nodes": [{"status": "PENDING", "id"