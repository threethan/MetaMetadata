65071488", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75556803_833074571738154_1835005675269353545_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BjzcnRYn79wQ7kNvgEAEx8m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDC9SQdzDgp5Fgdoji1L4hEjhEGJO5gf0tHHCe9V84_7w&oe=672C90C5"}, {"file_name": "Temple.png", "id": "1000280781294795", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476756_1000280784628128_1559094590514075056_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r5uAApHo-i4Q7kNvgGbTTAq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIeRL71BDttx39opPWx4r9icYOKf4IW4R-ADUDE60l4Q&oe=672CB28E"}, {"file_name": "Leaderboard.png", "id": "1666964724052688", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031530_1666964727386021_6971077023420348181_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fl6CfsMuxnIQ7kNvgFj2R9i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBasF7VgxjJKXZVMSuUwehpYaE9AkYLJSK-ODi0YoikIQ&oe=672C97D1"}, {"file_name": "MedLevelSelect.png", "id": "486155310766917", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520122_486155314100250_6851802354829899748_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VsJrY257D5YQ7kNvgEBLcL4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8_Y5XyIkyQeJ-hdK6sqB04Ggmx_-wU_vZ9hIO5jWTaA&oe=672CC132"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ArcadeBG.png", "id": "3327318267576392", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75356794_3327318270909725_3314026119492980721_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qif5qBP1gCcQ7kNvgGLbgKX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgzFSAZLqbzVVKv92qwysCTiNH5t7Chlz7oTWecDX_ug&oe=672CA92C"}, "display_name": "On Point \ud83c\udf83", "keywords": ["shooter", "retro", "minigames"], "long_description": "**On Point** is a retro shooter, filled with Warioware-style arcade minigames. Think, aim, and blast your way to a high score through endless shooting minigames, but don't hit those bombs or you'll run out of lives!\n\n{1605443010366893}\n## ITS HALLOWEEN!\nThe spookiest update yet has arrived! Get ready to jump into our Halloween special, packed with three hauntingly fun minigames, eerie set dressing, and new challenges to keep you on your toes.\n\n\n## ABOUT\n- Compete in over 90 minigames.\n- Easy, medium, and hard mode.\n- Local, global, and friends leaderboards.\n- Tuned for all experience and comfort levels.\n\n## DESCRIPTION\n- Arcade-style target shooting minigames.\n- Hardcore mode, for experienced players to challenge themselves and the leaderboards.\n- Newcomer mode, low intensity to ease in new players.\n- Relive that retro arcade light-gun experience, in VR!\n\n{552621891048302}", "short_description": "On Point is a shooter, filled with Warioware-style arcade minigames. Think, aim, and blast your way to a high score through endless shooting minigames, but don't hit those bombs or you'll run out of lives!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://onpoint.game/privacy.html", "developer_terms_of_service_url": "https://onpoint.game/eula.html", "publisher_name": "Actuator Games", "support_website_url": null, "website_url": "https://onpoint.game/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8728374050542558"}, "review_messages"