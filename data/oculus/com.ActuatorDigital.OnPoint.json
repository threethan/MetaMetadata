-2R&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAihBTWoQEowYGLbIGUAliiFJsT5LjilpF0Fch1UVi-Zw&oe=677E7E32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ArcadeBG.png", "id": "3327318267576392", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75356794_3327318270909725_3314026119492980721_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zlADYLnuqbUQ7kNvgEGZbnw&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDD6HKXd9nWrNDMO6vCXFKTuA8MKERPP80sUHVVrX3Ufg&oe=677E662C"}, "display_name": "On Point \ud83c\udf84", "keywords": ["shooter", "retro", "minigames"], "long_description": "**On Point** is a retro shooter, filled with Warioware-style arcade minigames. Think, aim, and blast your way to a high score through endless shooting minigames, but don't hit those bombs or you'll run out of lives!\n\n## CHRISTMAS IS HERE\n{1528295191186128}\n- Christmas has come to On Point!\n- New Xmas Themed Minigames!\n\n## ABOUT\n- Compete in over 90 minigames.\n- Easy, medium, and hard mode.\n- Local, global, and friends leaderboards.\n- Tuned for all experience and comfort levels.\n\n## DESCRIPTION\n- Arcade-style target shooting minigames.\n- Hardcore mode, for experienced players to challenge themselves and the leaderboards.\n- Newcomer mode, low intensity to ease in new players.\n- Relive that retro arcade light-gun experience, in VR!\n", "short_description": "On Point is a shooter, filled with Warioware-style arcade minigames. Think, aim, and blast your way to a high score through endless shooting minigames, but don't hit those bombs or you'll run out of lives!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://onpoint.game/privacy.html", "developer_terms_of_service_url": "https://onpoint.game/eula.html", "publisher_name": "Actuator Games", "support_website_url": null, "website_url": "https://onpoint.game/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "274332