nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IR2DYBTGYH8Q7kNvgFb59Wl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgCLc7wQpaSqMYSgUlNWMnaJ92tHJ5-g2yUbcNHCfkWA&oe=6743218C"}, {"file_name": "cafeteria_post_02.png", "id": "670108341956450", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86636486_670108345289783_7821924724203181479_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i5Jf_Bo5j3kQ7kNvgEFKhuQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBy6aqwSx6920-dJZ8RxcyRtCUwgLjVUdFo6r3--hd-0w&oe=6742F772"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "stvrcaf.PNG", "id": "1347674722606091", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031356_1347674725939424_4814664499412655823_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P-7KUHU5U9EQ7kNvgE2iL_e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfXjmnnfJHTBVL_rY34m8J_8HLA-MC7S9w6rB1e2qLWQ&oe=6743205B"}, "display_name": "Smile Proud", "keywords": [], "long_description": "Smile Proud is a 2-player game aimed at providing psychosocial support to adolescents with cleft lip and/or palate. In the game, players work with their chosen Super Pet Pal, SuperCat or SuperPup, in going on missions to help others in difficult social situations. During these missions, players have the opportunity to practice addressing these situations with their psychologist, who plays with them. Players have the opportunity to learn more about how to address these situations and gain skill points along the way, while playing fun and engaging mini games. ", "short_description": "Join SuperCat or SuperPup on an adventure to help others in tricky social situations! You\u2019ll go on quests with your Super Pet Pal to help a student make friends, win a soccer trophy and help a social media star understand how to deal with cyberbullying. On your journey, you\u2019ll learn the skills necessary to address these challenging situations and gain skill points. "}]}, "developer_name": null, 