content.oculuscdn.com/v/t64.5771-25/75254875_1275095127214426_2608683143222814144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Xw_TGHaa4IQ7kNvgGfNMMw&_nc_ht=scontent.oculuscdn.com&_nc_gid=Agv6iw5r_QbM0tnPVTQBoBZ&oh=00_AYARNjrUKlz9TWRO5qwXBF25UwRD68PUCSjdU4-mov2-5g&oe=66D3120C"}, {"file_name": "cafeteria_post_02.png", "id": "670108341956450", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86636486_670108345289783_7821924724203181479_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=31dclxcSG_MQ7kNvgF8pft-&_nc_ht=scontent.oculuscdn.com&_nc_gid=Agv6iw5r_QbM0tnPVTQBoBZ&oh=00_AYDCqsQ_YPTbYyYx3-Kzi2Zoh7hDYqKui83-9B8464XzGg&oe=66D2E7F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "stvrcaf.PNG", "id": "1347674722606091", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031356_1347674725939424_4814664499412655823_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HxJvOr8dsucQ7kNvgFlSTdJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Agv6iw5r_QbM0tnPVTQBoBZ&oh=00_AYCcM01iseWOYDghTxdx3SusE-ZvwWO79yj67R4VgWOjsQ&oe=66D310DB"}, "display_name": "Smile Proud", "keywords": [], "long_description": "Smile Proud is a 2-player game aimed at providing psychosocial support to adolescents with cleft lip and/or palate. In the game, players work with their chosen Super Pet Pal, SuperCat or SuperPup, in going on missions to help others in difficult social situations. During these missions, players have the opportunity to practice addressing these situations with their psychologist, who plays with them. Players have the opportunity to learn more about how to address these situations and gain skill points along the way, while playing fun and engaging mini games. ", "short_description": "Join SuperCat or SuperPup on an adventure to help others in tricky social situations! You\u2019ll go on quests with your Super Pet Pal to help a student make friends, win a soccer trophy and help a social media star understand how to deal with cyberbullying. On your journey, you\u2019ll learn the skills necessary to address these challenging situations and gain skill points. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/13Qq1A5pVVwtP4qs9GiOn6irv1RvdzsUq/edit?usp=sharing&ouid=105529289327632046589&rtpof=true&sd=true", "developer_terms_of_service_url": "https://docs.google.com/document/d/1jArzbSbgeZEYzy4o2AC0yddLXhJywpFS/edit?usp=sharing&ouid=105529289327632046589&rtpof=true&sd=true", "publisher_name": "Smile Train", "support_website_url": null, "website_url": "https://smiletrain.org/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_CO", "pt_BR", "tl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8083734651646999"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974804_7443416602390036_9017832350779492661_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VK3YkAJestoQ7kNvgHTRGRT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Agv6iw5r_QbM0tnPVTQBoBZ&oh=00_AYB4JHazVx964ukxIPFBPZ4DQQMtuAwb5Kyh2JDqe6S24Q&oe=66D3038E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Smile Proud", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Simulation", "id": "331529188