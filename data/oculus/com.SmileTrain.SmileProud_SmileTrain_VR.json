nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sq8VyTu5NDwQ7kNvgGTm491&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDr72tjxr4c_r3Y1p2nA3O2Tb4-wPU0e8HxZ-k2np2JPA&oe=6762C58C"}, {"file_name": "cafeteria_post_02.png", "id": "670108341956450", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86636486_670108345289783_7821924724203181479_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nY2L6FG5zv0Q7kNvgFif_ZN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChQSK1YGWB7MfBXD5knMyDEnKKGMAaqTSMcmpPZ1vAiQ&oe=6762D3B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "stvrcaf.PNG", "id": "1347674722606091", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031356_1347674725939424_4814664499412655823_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JLr0sZLqeFEQ7kNvgGEHfSF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYUcUgx0yckxDA8fWRTMYgDnF0LHdQBjNoWyvY9S9oqA&oe=6762C45B"}, "display_name": "Smile Proud", "keywords": [], "long_description": "Smile Proud is a 2-player game aimed at providing psychosocial support to adolescents with cleft lip and/or palate. In the game, players work with their chosen Super Pet Pal, SuperCat or SuperPup, in going on missions to help others in difficult social situations. During these missions, players have the opportunity to practice addressing these situations with their psychologist, who plays with them. Players have the opportunity to learn more about how to address these situations and gain skill points along the way, while playing fun and engaging mini games. ", "short_description": "Join SuperCat or SuperPup on an adventure to help others in tricky social situations! You\u2019ll go on quests with your Super Pet Pal to help a student make friends, win a soccer trophy and help a social media star understand how to deal with cyberbullying. On your journey, you\u2019ll learn the skills necessary to address these challenging situations and gain skill points. "}]}, "developer_name": null, 