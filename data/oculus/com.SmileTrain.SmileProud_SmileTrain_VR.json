ill points along the way, while playing fun and engaging mini games. ", "short_description": "Join SuperCat or SuperPup on an adventure to help others in tricky social situations! You\u2019ll go on quests with your Super Pet Pal to help a student make friends, win a soccer trophy and help a social media star understand how to deal with cyberbullying. On your journey, you\u2019ll learn the skills necessary to address these challenging situations and gain skill points. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/13Qq1A5pVVwtP4qs9GiOn6irv1RvdzsUq/edit?usp=sharing&ouid=105529289327632046589&rtpof=true&sd=true", "developer_terms_of_service_url": "https://docs.google.com/document/d/1jArzbSbgeZEYzy4o2AC0yddLXhJywpFS/edit?usp=sharing&ouid=105529289327632046589&rtpof=true&sd=true", "publisher_name": "Smile Train", "support_website_url": null, "website_url": "https://smiletrain.org/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "821934236779161"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_CO", "pt_BR", "tl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8083734651646999"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "335340096065189"}]}, "baseline_offer": {"id": "335340096065189"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719358442, "status": "PUBLISHED", "id": "335340096065189"}]}, "liveChannel": {"nodes": [{"latest_supported_