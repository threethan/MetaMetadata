n.com/v/t64.5771-25/39035395_727579734703000_7865401773344897306_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2rE7EEFlWvoQ7kNvgG8emY5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCuR55V7FtAcbl0mL5c5-6jyP5s1f-q7A9M6b3dTmQewQ&oe=67824E0E"}, {"file_name": "2560x1440_HRDVR_Oculus_Screens_3DStrikeZone_01.png", "id": "366382784331706", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974747_366382787665039_6027343608069320544_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pnu6Nt14qVAQ7kNvgHWmoUF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOQUWxZW1p2lYNQkW_L2vAtRddIPk2pYPBaD6-cEh-ag&oe=678260BF"}, {"file_name": "2560x1440_HRDVR_Oculus_Screens_MLBHighlights_01.png", "id": "773748300034495", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982491_773748303367828_2005407520514929156_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qmdir-QkrToQ7kNvgEyboKQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDj8fCCNZLTbxsrns7fnvdFwuMpi_WOuJQ_utrul3QjoA&oe=67825B3E"}, {"file_name": "2560x1440_HRDVR_Oculus_Screens_immersive_01.png", "id": "1216334505369588", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974740_1216334512036254_9118089324280551962_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bPHPHdd9dH4Q7kNvgHWEN2d&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBVZrs_Gkjl5KLUI7vv8jfYNfYZPGQWfDbxae4p9BPRkA&oe=67825EAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_MLBVR_Oculus_Cover.png", "id": "678787249351857", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035408_678787252685190_2724231105057773603_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jrNgCFMZ8coQ7kNvgFILKFI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-C5vAe2a-c76YVl9LiEOLTAUGR60cfxm9viwiAMECMA&oe=678254D6"}, "display_name": "MLB VR", "keywords": ["Baseball", "Sports", "Streaming", "Entertainment", "Visualization"], "long_description": "The #1 source for LIVE BASEBALL comes to Oculus Quest! \n\nMLB VR empowers fans to dive into data and experience baseball in ways only possible in Virtual Reality. Analyze pitch locations in the 3D Strike Zone, track the players in the field and more. MLB VR brings live game streaming and real time data visualization to fans!\n\n**** FULL LIST OF FEATURES ****\n\u2022 Stream out-of-market games from your favorite team any time with this official Major League Baseball app*\n\u2022 The most live games of any VR Sports app*\n\u2022 Watch full games on demand going back to the start of the 2015 Regular Season\n\u2022 Groundbreaking Gameday Pitch-By-Pitch data visualization and 3D Strike Zone powered by Statcast allows you to analyze every pitch in VR\n\u2022 Interactive calendar, scores, stats and standings\n\u2022 Immersive 360 degree video highlights put you on the field, in the stands and in the clubhouse\n\u2022 Support for At Bat Lite, At Bat Premium, and MLB.TV \n\n*Requires At Bat Premium or MLB.TV Subscription", "short_description": "The #1 source for LIVE BASEBALL comes to Oculus Quest! \n\nMLB VR empowers fans to dive into data and experience baseball in ways only possible in Virtual Reality. Analyze pitch locations in the 3D Strike Zone, track the players in the field and more. MLB VR brings live game streaming and real time data visualization to fans!"}]}, "developer_name": "MLB", "developer_privacy_policy_url": "https://www.mlb.com/official-information/privacy-policy", "developer_terms_of_service_url": "https://mlb.com/tou", "publisher_name": "MLB", "support_website_url": "http://mlb.mlb.com/mobile/mobilecs.jsp", "website_url": "https://www.mlb.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection