ple to use controls paired with classic arcade challenge.\n\nPlay four incredible arcade classics completely hands free or with a controller.  Brought to you by acclaimed VR game developer Hidden Path Entertainment, Hypercade includes four arcade games, each with its own unique take on fan favorites of yesteryear.    "}]}, "developer_name": null, "developer_privacy_policy_url": "http://hiddenpath.com/privacy.php", "developer_terms_of_service_url": "http://hiddenpath.com/terms.php", "publisher_name": "Hidden Path Entertainment", "support_website_url": null, "website_url": "http://www.hiddenpath.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "623582758734853"}}]}, "scheduled_offers": {"count": 15, "nodes": [{"status": "PUBLISHED", "id": "466277434121364"}, {"status": "PUBLISHED", "id": "489137374989067"}, {"status": "PUBLISHED", "id": "1051862011600001"}, {"status": "PUBLISHED", "id": "868203236678041"}, {"status": "PUBLISHED", "id": "198791310718909"}, {"status": "PUBLISHED", "id": "1277446822287987"}, {"status": "PUBLISHED", "id": "613598245493089"}, {"status": "PUBLISHED", "id": "595527391015392"}, {"status": "PUBLISHED", "id": "202500247049044"}, {"status": "PUBLISHED", "id": "1420513178250041"}, {"status": "PUBLISHED", "id": "2952307388119329"}, {"status": "PUBLISHED", "id": "347291592632706"}, {"status": "PUBLISHED", "id": "1040466086296560"}, {"status": "PUBLISHED", "id": "385642635523992"}, {"status": "PUBLISHED", "id": "45240455179938