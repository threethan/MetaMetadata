b=1-7&_nc_sid=6e7a0a&_nc_ohc=fsuuMjL7XkgQ7kNvgGj0L1d&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCt9HtEb91zDVCed8PYRL5u--iZedy23qWYjpFn0kaDSA&oe=670D070E"}, {"file_name": "com.oculus.vrshell-20240617-154528 1 (1).png", "id": "381033334478454", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031392_381033337811787_5701494533830343396_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgjheJX_8TUQ7kNvgFxfw6b&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBdCc1SoBqffgQaoucvUycZ4iaHwBLG05HExaZWT3MwA&oe=670CEB4B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "24.png", "id": "479792944623870", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031358_479792947957203_7701327199303146140_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hn9mUK-Jdm0Q7kNvgEtSlAA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvMVNOFlKFH4xbCuauvdjgHyNJ19A9cvfmZYFGNmlZ-w&oe=670CF4EC"}, "display_name": "Gracia", "keywords": [], "long_description": "Gracia is a platform that redefines virtual reality, offering free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual.\n\nKey features:\n\n- Unmatched Photorealism: Gracia\u2019s advanced rendering technology blurs the line between virtual and reality and creates a feeling as if you are inside high-resolution photograph. \n- 6DOF Volumetric Scenes: Move and interact within our scenes with complete freedom as if you were really there.\n- Extremely High Fidelity: Up to 550 fps at native resolution.\n- Ever Expanding Store of Scenes: Regular updates keep the content fresh and exciting.", "short_description": "Gracia is a world's first platform with free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual."}]}, "developer_name"