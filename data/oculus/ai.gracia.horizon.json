64.5771-25/38974568_1114694220215365_8967788144077695009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OCnX_r09dBkQ7kNvgGeC3_l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDp7svkDMp54TXnCk-bqOeF6ZYAN6QjFLC1aYqWzSBjw&oe=6746E934"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "24.png", "id": "479792944623870", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031358_479792947957203_7701327199303146140_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xJmjP1BW-AIQ7kNvgHQCBhX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQ5wtU73QnNmoVyZ5eJ6oSpjpyZR6MUr1RD5Pr4Ypwfg&oe=6746F6EC"}, "display_name": "Gracia", "keywords": ["gracia", "6dof", "videos", "immersive"], "long_description": "Gracia is a platform that redefines virtual reality, offering free-viewpoint ultra-photorealistic videos in VR.\n\nKey features:\n\n- Feeling of Presence: Walk around the video and watch from any angle\n- Mixed Reality & Environmental Depth Support: Merge the scene into your environment for better immersion\n- Hands Tracking: Rotate the scene, pause and rewind without controllers\n- Ready-To-Go SDK: For self-distribution and streaming", "short_description": "Gracia is pioneering spatial computing with the first-ever Gaussian Splatting-based volumetric videos in VR"}]}, "developer_name": "Gracia", "developer_privacy_policy_url": "https://graciavr.notion.site/Privacy-Policy-ffd5b4acd3fd4ff2bccf5bf120192c29", "developer_terms_of_service_url": null, "publisher_name": "Gracia", "support_website_url": null, "website_url": "https://www.gracia.ai/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "rec