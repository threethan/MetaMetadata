_nc_sid=6e7a0a&_nc_ohc=ZsJVgWj_q0sQ7kNvgEM2rTP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBO_6BYIUiDzP4bf02QOfRdei3bXS2mwuCUbV2Jzng5aQ&oe=6749904B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "24.png", "id": "479792944623870", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031358_479792947957203_7701327199303146140_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7pWK_U3BDZoQ7kNvgE5ohtI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJsio6JoITN8HWFMoWjhzYWHb6SNUNY_CLGFfjyD6vvQ&oe=674999EC"}, "display_name": "Gracia", "keywords": [], "long_description": "Gracia is a platform that redefines virtual reality, offering free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual.\n\nKey features:\n\n- Unmatched Photorealism: Gracia\u2019s advanced rendering technology blurs the line between virtual and reality and creates a feeling as if you are inside high-resolution photograph. \n- 6DOF Volumetric Scenes: Move and interact within our scenes with complete freedom as if you were really there.\n- Extremely High Fidelity: Up to 550 fps at native resolution.\n- Ever Expanding Store of Scenes: Regular updates keep the content fresh and exciting.", "short_description": "Gracia is a world's first platform with free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual."}]}, "developer_name": "Gracia", "developer_privacy_policy_url": "https://graciavr.notion.site/Privacy-Policy-ffd5b4acd3fd4ff2bccf5bf120192c29", "developer_terms_of_service_url": null, "publisher_name": "Gracia", "support_website_url": null, "website_url": "https://www.gracia.ai/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692