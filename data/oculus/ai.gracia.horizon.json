scontent-lhr8-1.oculuscdn.com&oh=00_AYBFsmd5MxSJAQwHvykfBc0WotZV_6G5lQXvtJM3qDfDDQ&oe=67123566"}, {"file_name": "com.oculus.vrshell-20240617-153625 1.png", "id": "1912036715893591", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39036652_1912036719226924_6659661921984048353_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mlDUnkH-jXAQ7kNvgEH_ulM&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDaxrpmoX2cHBB2uY7KYFxwhq9OX6j-5SvpymYHjoZ9Pw&oe=67124D0E"}, {"file_name": "com.oculus.vrshell-20240617-154528 1 (1).png", "id": "381033334478454", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39031392_381033337811787_5701494533830343396_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vjogxPSJXiwQ7kNvgF_rI83&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDiJdDhxIAjolxtYoSeUKHl3zontdxhpFE1R8RdDs10Kg&oe=6712314B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "24.png", "id": "479792944623870", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031358_479792947957203_7701327199303146140_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GUX6C-GVdg0Q7kNvgHdCKdw&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBlVz96HTOWrdN86YBj5AP_AnxAX3MojEcFXCxOVnEL0w&oe=67123AEC"}, "display_name": "Gracia", "keywords": [], "long_description": "Gracia is a platform that redefines virtual reality, offering free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual.\n\nKey features:\n\n- Unmatched Photorealism: Gracia\u2019s advanced rendering technology blurs the line between virtual and reality and creates a feeling as if you are inside high-resolution photograph. \n- 6DOF Volumetric Scenes: Move and interact within our scenes with complete freedom as if you were really there.\n- Extremely High Fidelity: Up to 550 fps at native resolution.\n- Ever Expanding Store of Scenes: Regular updates keep the content fresh and exciting.", "short_description": "Gracia is a world's first platform with free-viewpoint ultra-photorealistic VR experiences. It's not just about seeing; it's about stepping inside a photo with freedom to walk around, where every detail is so vivid, you'll forget it's virtual."}]}, "developer_name": "Gracia", "developer_privacy_policy_url": "https://graciavr.notion.site/Privacy-Policy-ffd5b4acd3fd4ff2bccf5bf120192c29", "developer_terms_of_service_url": null, "publisher_name": "Gracia", "support_website_url": null, "website_url": "https://www.gracia.ai/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25784099061234159"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "888067786686421"}]}, "baseline_offer": {"id": "888067786686421"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723220178, "status": "PUBLISHED", "id": "888067786686421"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27182759224701462", "version": "1.0.0"}, "id": "977108810552108", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25784099001234165", "is_concept": false, "latest_r