4631_1832680312779386667_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SJU0LDXpnLwQ7kNvgFaWEPE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2OD6-_ipmuDNI2uZzj7Jer-Gt3brs-fpWGfsUoFK2TA&oe=675C1547"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER.png", "id": "357980773530423", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240105_357980776863756_8567502649601100453_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RLGValWH4BMQ7kNvgGVi0oh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpscan1QVI9zy0BrmiegpdV3boj_tj7znxqmmV4tnWJg&oe=675C09B3"}, "display_name": "Merlin's Chess", "keywords": [], "long_description": "\ud83e\uddd9\u200d\u2642\ufe0f\u265f\ufe0fIntroducing the greatest strategy game of all times reimagined by the hands of the most legendary sorcerer - Merlin himself. Here, every move is a spell, every piece a living entity, and every match a magical battle!\n\n\ud83c\udff0 Colosseum Setting: Step into a grand, magical colosseum where the halls echo with whispers of ancient spells and strategies.\n\n\ud83d\udde3\ufe0f Voice Command Your Army: Command your chess pieces by voice and watch them move across the board, animated with life and ready for epic battles.\n\n\u2694\ufe0f Challenge Real Players or AI: Test your skills against our cunning AI or real chess players from around the world.\n\n\ud83d\udc40 Spectator Mode - Esports Reimagined with Chess: Feel the adrenaline rush of esports as spectators watch and cheer for your strategic prowess. Or become a spectator to watch legendary matches and hang out with like-minded others.\n\n\ud83c\udf10 Inspired by Legends: Drawing on the art elements of the world's best MMORPGs, Merlin's Chess offers depth, community, and a lore-rich world in immersive and detailed environments.\n\n\ud83d\udd25 Social VR at Its Best: Immerse yourself in a fantastic community full of intelligent, fun, and like-minded folks where friendships are forged over shared battles.\n\n\ud83c\udf89 Regular Updates & Community Events: Join a game that grows with you. Regular updates and community events ensure an ever-evolving, fresh experience.\n\n\u2b07\ufe0f Unforgettable Chess Experience: Download for the most immersive and epic chess experience where strategy and community come together to create magic!", "short_description": "The greatest strategy game of all times awakens in the hands of the most legendary sorcerer, Merlin \ud83e\uddd9\u200d\u2642\ufe0f\u265f\ufe0fIn this grand colosseum setting, every piece resonates with magic! Command enchanted chess pieces by voice, watch them come alive in epic battles, challenge real players or AI while others watch your strategy come alive like an esports gladiator duel \ud83c\udff0  Inspired by the world's best MMORPGs, we invite you to join us in the most immersive and magical chess experience out there! \u2694\ufe0f \ud83d\udd25"}]}, "developer_name": "Teleporter Realities Inc.", "developer_privacy_policy_url": "https://teleporter.gg/merlins-chess/privacypolicy", "developer_terms_of_service_url": "https://teleporter.gg/merlins-chess/terms-of-service", "publisher_name": "Teleporter Realities Inc.", "support_website_url": "https://feedback.merlinschess.gg/", "website_url": "https://teleporter.gg/merlins-chess/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7146178408802154"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "9306115