CCD7"}, {"file_name": "migrated_image.png", "id": "685147152255764", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162686_153619565230181_561696037719244800_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1SkZ4v8c38Q7kNvgEHx8Uf&_nc_ht=scontent.oculuscdn.com&oh=00_AYAi-A35UWBMw1eqqdZFKEKEaKofudbe5kSz_wzFwwGEOw&oe=66FBF89C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "879261972236608", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162696_879261975569941_2394592379467202560_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9RBTMVGssMQQ7kNvgE3QSYb&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_9S_fE24Hw2AXIeSJtwQWgzMyacmIf2BNg784STgiPA&oe=66FBE4E8"}, "display_name": "VirtuGO", "keywords": ["Klax", "Tetris", "Puzzle", "Colors", "Fast"], "long_description": "VirtuGO is a classic puzzle game. Colored tiles come at you nonstop, and you must put them on your carrying platform and arrange them as best you can on a 5x5 grid.\n\nIf you match 3,4 or 5 tiles in the same color horizontally, vertically or diagonally, the blocks get destroyed, you score points and free up space for more tiles. \n\nThere are 100 levels in VirtuGO and as you level up, you\u2019ll encounter new color tiles, and they\u2019ll come at you faster and faster. For each 10,000 points you score, you\u2019ll get a WILD tile that you can substitute for any color. Visit the games community page to see the possible combinations and scoring details. \n\nVirtuGO will get addictive as you try to better your personal best. Have fun!", "short_description": "VirtuGO is a classic matching puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http://surrealvr.com/privacy.html", "developer_terms_of_service_url": "http://surrealvr.com/privacy.html", "publisher_name": "SurrealVR Inc", "support_website_url": null, "website_url": "http://surrealvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": nu