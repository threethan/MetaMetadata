.oculuscdn.com/v/t64.5771-25/11162701_141236729820889_5650786972680060928_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebKGqWC6gN4Q7kNvgG4LanJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbGZydXZrxjdNlCZCKJ4FA3L77Es6SDsiqW1fYoz0taA&oe=6742FDD7"}, {"file_name": "migrated_image.png", "id": "685147152255764", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162686_153619565230181_561696037719244800_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fe6nUIuqStMQ7kNvgHz-7U5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOg6W9WgyQLgTJr1zbLp_ys413O8Sol9drN6H3vkWtKg&oe=6743299C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "879261972236608", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162696_879261975569941_2394592379467202560_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V2gEXtGlCCgQ7kNvgEhfmOZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7xSrMPGRRbqlYrVLgAP8p7kQig_aCM2EbbwNgxVQjlA&oe=674315E8"}, "display_name": "VirtuGO", "keywords": ["Klax", "Tetris", "Puzzle", "Colors", "Fast"], "long_description": "VirtuGO is a classic puzzle game. Colored tiles come at you nonstop, and you must put them on your carrying platform and arrange them as best you can on a 5x5 grid.\n\nIf you match 3,4 or 5 tiles in the same color horizontally, vertically or diagonally, the blocks get destroyed, you score points and free up space for more tiles. \n\nThere are 100 levels in VirtuGO and as you level up, you\u2019ll encounter new color tiles, and they\u2019ll come at you faster and faster. For each 10,000 points you score, you\u2019ll get a WILD tile that you can substitute for any color. Visit the games community page to see the possible combinations and scoring details. \n\nVirtuGO will get addictive as you try to better your personal best. Have fun!", "short_description": "VirtuGO is a classic matching puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http:/