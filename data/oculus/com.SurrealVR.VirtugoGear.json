.oculuscdn.com/v/t64.5771-25/11162701_141236729820889_5650786972680060928_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ncKlqfMk0r4Q7kNvgGjNxUT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDszFodYYyjvYxeHfagBea6y1imNu_yWD3W7UofkNHuTw&oe=673088D7"}, {"file_name": "migrated_image.png", "id": "685147152255764", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/11162686_153619565230181_561696037719244800_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zF-KZ_mU_54Q7kNvgFgH_5a&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDYCMKLwHnvn-mq6IHKhUilRf-zHq4eVAjSrXRyZzmCDg&oe=6730B49C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "879261972236608", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/11162696_879261975569941_2394592379467202560_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vzV2LSLkhWUQ7kNvgFCpQLk&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYALiL2BrS5_kmuX2oNU2nRcTw16aFO7_U7MaLszCzsL2Q&oe=6730A0E8"}, "display_name": "VirtuGO", "keywords": ["Klax", "Tetris", "Puzzle", "Colors", "Fast"], "long_description": "VirtuGO is a classic puzzle game. Colored tiles come at you nonstop, and you must put them on your carrying platform and arrange them as best you can on a 5x5 grid.\n\nIf you match 3,4 or 5 tiles in the same color horizontally, vertically or diagonally, the blocks get destroyed, you score points and free up space for more tiles. \n\nThere are 100 levels in VirtuGO and as you level up, you\u2019ll encounter new color tiles, and they\u2019ll come at you faster and faster. For each 10,000 points you score, you\u2019ll get a WILD tile that you can substitute for any color. Visit the games community page to see the possible combinations and scoring details. \n\nVirtuGO will get addictive as you try to better your personal best. Have fun!", "short_description": "VirtuGO is a classic matching puzzle game."}]}, "developer_name": null, "developer_privacy_policy_url": "http:/