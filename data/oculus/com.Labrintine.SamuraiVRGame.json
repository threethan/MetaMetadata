me": "aaaaa.png", "id": "1025897278415453", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974534_1025897281748786_6004094132949088064_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aefvT2fT0f0Q7kNvgGyj3Ka&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUfwh40fxZOSe-VqlLFdSgdMKDPi_BMU2mz3XvX0C6aw&oe=67695223"}, {"file_name": "aaaa.png", "id": "1504060880426115", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974535_1504060883759448_3039452923271027083_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXlRZXHpTYIQ7kNvgFIQEnz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3zoT4Y_PdtSFq5FzAJMCjCB_qSMQfwEjcRkqTKZyunA&oe=676947A2"}, {"file_name": "aaa.png", "id": "290380220277183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031434_290380223610516_5553629018407681014_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4IQGXjz7zJcQ7kNvgHeEd-X&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxsS4QtfTe8Bire1coNqqBdRa4xN42W7bJM7QIsGT6XQ&oe=6769557D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerthumb.png", "id": "169206229537088", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422386_169206232870421_686099570980409076_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JmYbnCrSQsoQ7kNvgGa2Q1Y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_1EM7kc7cz1CSI0OIm2y8ApecKw2t4QBrPDVFg_iNqQ&oe=676946BF"}, "display_name": "Samurai VR", "keywords": [], "long_description": "\"A samurai has no goal, only path, and samurai's path is death\"\n\nSamurai VR allows you to become a samurai to stand as long as you can against different enemies.\n\nFrom the moment you'll grab a Katana, ninjas will summon a fog of war and will be continuously attacking you with shurikens. Use the Katana to defend from them, as you can survive only three hits.\n\nTime to time they can also throw a bomb towards you - don't try to block it with a Katana, just make a step to side or crouch to dodge it. Keep in mind - you can't move with a joystick in this game so you'll have to move yourself. Make sure you have enough space at least for one small step to the left and right to play this game.\n\nBesides, enemy shinobis can spawn nearby, trying to attack you directly. Your goal would be to hit them first. Most of them won't survive even one hit, but not enemy Samurais. When Samurai will spawn attack him three times as quickly as possible, and don't forget to watch for shurikens and bombs!\n\nIf at a certain point you'll feel that it's too easy - don't relax too quickly as the game may become faster over time! ", "short_description": "Grab a Katana and stand on your daimyo's castle defense, alone against an infinite horde of enemy shinobis. Kill the enemies, hit back shurikens, dodge bombs and beware of enemy Samurais! "}]}, "developer_name": "LABRINTINE LTD", "developer_privacy_policy_url": "http://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Boom", "support_website_url": null, "website_url": "https://www.labrintine.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "299000616046504"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1104408457193537"}]}, "baseline_offer": {"id": "1104408457193537"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697726460, "