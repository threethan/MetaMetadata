er the water after looking at the pagodas), the video stopped playing and brought the user to the main menu with a garbled/obscured error message.", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/12533755_143025222872064_2757650865555767296_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBR_53reDn4Q7kNvgGNoYh6&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAZw5D3nI6fgPwMdqj5uSVZxqn4N1HzQ-tGFIuwUTSeaQ&oe=675EDA01"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "GE: Dali Windfarm Experience", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1488960000, "lastRevision": {"nodes": [{"id": "1391642650894521", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1471354659542963", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "633317673536391"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "3121554321188303", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/12533755_143025222872064_2757650865555767296_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBR_53reDn4Q7kNvgGNoYh6&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAp4TLnntxkCtt1U8-gQG8Gh_NAwbQtj6HrvAE92seclA&oe=675EDA01"}, {"file_name": "migrated_image.png", "id": "1586816518143699", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/12680493_215194728944847_7553460340961312768_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0e3HmBqOwcQ7kNvgFf5_fv&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDkAAlEFZN7VxKn3NGplHM7nY5DhHypcHQbCUBSFLsYQA&oe=675EBB1E"}, {"file_name": "migrated_image.png", "id": "618184508739908", "image_type": "APP_IMG_SM