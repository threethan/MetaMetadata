76A908D"}, {"file_name": "Sin t\u00edtulo4.png", "id": "1316246445590523", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035464_1316246448923856_4685813099764993945_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QHR0sHb9GMYQ7kNvgHVUalj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClAmh9ICwaFCMBMd69u1_YpxJU9V6YHFxSg3a1iKPSdg&oe=676A9628"}, {"file_name": "Sin t\u00edtulo5.png", "id": "593371649331355", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974505_593371652664688_7933124050739087461_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgA2PrfGPYYQ7kNvgHg1DOn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1E7-Fh4rZGPBuHuOPQeAmnMD9mjAdlwJvTogPXY-_ig&oe=676A8556"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape2.png", "id": "746610606836421", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469632_746610610169754_4645638496184634992_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SDT2-GVRN18Q7kNvgHsHhMX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARSkRgK44p0P5Dc_v1_GJ3QFkVWtv6-QKz4RMvyQ7yQw&oe=676AB8CE"}, "display_name": "Multimusic Quest", "keywords": [], "long_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. \nYou  have to select the multiplication table that you want to practice/learn. You have to get less than 20s to obtain the degree in each multiplication table. If you get it, the table number in main menu will turn green. If not, it will turn red.\nFor musical notes and ear training, you have to get less than 30s and for memory levels you have to get more than 12 hits.\nThe 3 best times of each level can put their name in local and online leaderboards. To win the game, you have yo get all the degrees of each level. Good luck!", "short_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/ab850223-262b-4a78-a7e1-94c7416d1aff", "developer_terms_of_service_url": null, "publisher_name": "Rafael Gimeno", "support_website_url": null, "website_url": "https://www.rafaelgimeno.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "184509411014193"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441580_1374550056624990_7748148482118342745_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ikiVE_gCOrQQ7kNvgEgu062&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALyRTySPN2nJ_bAF87851aK3Jf1az3V64h2O3DxT-VlA&oe=676AA6F6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Multimusic Quest", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1680808451, "lastRevision": {"nodes": [{"id": "6393826987315473", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6393826977315474", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platf