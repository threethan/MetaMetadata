75EB30D"}, {"file_name": "Sin t\u00edtulo4.png", "id": "1316246445590523", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39035464_1316246448923856_4685813099764993945_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KAE0MU7dmwoQ7kNvgFUm26Z&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYC1uUcvS24oMrKOY3F0gJ4cngeOrSL-ysxhVXGaEMvYjA&oe=675EB8A8"}, {"file_name": "Sin t\u00edtulo5.png", "id": "593371649331355", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974505_593371652664688_7933124050739087461_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAHB6CfyNzMQ7kNvgHKezQX&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCDVUHy9RK6qc_UIOC--7prduZLPeuu3FMK55PElYjBbg&oe=675EA7D6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape2.png", "id": "746610606836421", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75469632_746610610169754_4645638496184634992_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fcjUZxRffp4Q7kNvgFP9kU3&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDYlfm8bfaPb1wfrsBWcSJ-m3dV2DISFQ5lOXFHZPvRgw&oe=675EDB4E"}, "display_name": "Multimusic Quest", "keywords": [], "long_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. \nYou  have to select the multiplication table that you want to practice/learn. You have to get less than 20s to obtain the degree in each multiplication table. If you get it, the table number in main menu will turn green. If not, it will turn red.\nFor musical notes and ear training, you have to get less than 30s and for memory levels you have to get more than 12 hits.\nThe 3 best times of each level can put their name in local and online leaderboards. To win the game, you have yo get all the degrees of each level. Good luck!", "short_description": "An educational app to learn multiplication tables and the name of notes on the staff. Also, there are extra levels for ear training and a musical memory game. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/ab850223-262b-4a78-a7e1-94c7416d1aff", "developer_terms_of_service_url": null, "publisher_name": "Rafael Gimeno", "support_website_url": null, "website_url": "https://www.rafaelgimeno.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "184509411014193"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75441580_1374550056624990_7748148482118342745_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gEOFks4kIb4Q7kNvgEL2ZZ9&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDc4AajWkGUE7F0RFsf2eQj4dnvU_hdefwXzXhNvZa3WQ&oe=675EC976"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Multimusic Quest", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1680808451, "lastRevision": {"nodes": [{"id": "6393826987315473", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6393826977315474", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platf