 training and a musical memory game. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/ab850223-262b-4a78-a7e1-94c7416d1aff", "developer_terms_of_service_url": null, "publisher_name": "Rafael Gimeno", "support_website_url": null, "website_url": "https://www.rafaelgimeno.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "184509411014193"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6393925397305632", "version": "4.5"}, "id": "754310422675817", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6393826977315474", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6393925397305632"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "754310422675817"}]}, "change_log": "- Added Hand Tracking.", "created_date": 1678655511, "id": "6393925397305632", "version": "4.5", "version_code": 28, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []