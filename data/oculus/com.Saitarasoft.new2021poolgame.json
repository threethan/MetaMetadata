: [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "- You can now choose between 8 types of table physics; some serious, some silly\n- Adjusted the CPU difficulty curve to help beginners\n- Various minor bugfixes", "created_date": 1649430801, "id": "7422605814476487", "version": "1.17", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1649424928, "id": "7422238051179930", "version": "1.15", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "The latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up, you can now choose to hold the Y button on the left controller to enable Autoplay. Releas