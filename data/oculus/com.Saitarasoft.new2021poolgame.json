565993245_3462149684479781488_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cNwEr28mcB8Q7kNvgGG59Oq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBPwxfMOVkpmsWHGwNxixIBI-raJHfjv_m46H5z60ipg&oe=672B3AEB"}, {"file_name": "screenshot2.png", "id": "285562633664373", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001671_285562636997706_4290177067957678845_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ax2vCzLJQ7AQ7kNvgE1Iw-P&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAo6b5IlzFBWFON8EBmDtQN2W9f9I6K0s30LV6f7Ota0w&oe=672B5B43"}, {"file_name": "screenshot3.png", "id": "1098264914349891", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974854_1098264917683224_4454014628276889452_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mFfD0UIkItAQ7kNvgEQpWCz&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAihNUYGkAF9ZOCTbG8Yv8S4u-Isdq9h4NxgHkn5Lfknw&oe=672B6623"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1292854621212403", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982512_1292854624545736_258234218258836525_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fk779I2QrycQ7kNvgGw4v2G&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAOQHhks_JAtpy45olNO_j8Uzv-RKejDCmRAI4UuzMWGw&oe=672B4055"}, "display_name": "Cueist 2", "keywords": [], "long_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxing environment to play pool and snooker against your friends or AI opponents of increasing skill. A natural cueing action provides realistic spin, jump and swerve shots. 9 Ball, 8 Ball, UK 8 Ball, and Snooker games are included as well as a choice of cues and a customizable table. \n\nOnline play against your friends requires an internet connection.\nVoice chat between players requires permission to use the device's microphone.", "short_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxi