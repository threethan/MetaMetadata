sid=6e7a0a&_nc_ohc=PT_IOuXjIRwQ7kNvgFvi4-V&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlVzSEl3t2K_HduHttPcJcl&oh=00_AYCJqc_71C6kvUjs0N5CdSVmTuf64lI4uH7F3UUZsHRAMg&oe=66EAA16B"}, {"file_name": "screenshot2.png", "id": "285562633664373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001671_285562636997706_4290177067957678845_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z9LD8J6tV3QQ7kNvgFBgwMM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlVzSEl3t2K_HduHttPcJcl&oh=00_AYC5_uBGNNAZ7ZLnTGRJxRnxVmgpIq8LSd4TgmJCvQbukg&oe=66EAC1C3"}, {"file_name": "screenshot3.png", "id": "1098264914349891", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_1098264917683224_4454014628276889452_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-neZ741q2IQ7kNvgHWiHIR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlVzSEl3t2K_HduHttPcJcl&oh=00_AYBixqHnDiwskoDaidZ4k2b3hPsz1U2sUNVmR5OCGc7acA&oe=66EACCA3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1292854621212403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_1292854624545736_258234218258836525_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jcGnGRU1KBcQ7kNvgGEgJ0N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlVzSEl3t2K_HduHttPcJcl&oh=00_AYBNEJkzXfzCrmA5MsRwNyuWwtf65_SchyTIzg3EcIngjA&oe=66EAA6D5"}, "display_name": "Cueist 2", "keywords": [], "long_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxing environment to play pool and snooker against your friends or AI opponents of increasing skill. A natural cueing action provides realistic spin, jump and swerve shots. 9 Ball, 8 Ball, UK 8 Ball, and Snooker games are included as well as a choice of cues and a customizable table. \n\nOnline play against your friends requires an internet connection.\nVoice chat between players requires permission to use the device's microphone.", "short_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxing environment to play pool and snooker against your friends or AI opponents of increasing skill. A natural cueing action provides realistic spin, jump and swerve shots. 9 Ball, 8 Ball, UK 8 Ball, and Snooker games are included as well as a choice of cues and a customizable table. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.saitarasoft.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Saitara Software", "support_website_url": null, "website_url": "https://www.saitarasoft.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "303736565051100"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7422605814476487", "version": "1.17"}, "id": "684780659564038", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "- You can now choose between 8 types of table physics; some serious, some silly\n- Adjusted the CPU difficulty curve to help beginners\n- Various minor bugfixes", "created_date": 1649430801, "id": "7422605814476487", "version": "1.17", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1649424928, "id": "7422238051179930", "version": "1.15", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "The latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up, you can now choose to hold the Y button on the left controller to enable Autoplay. Release the Y button to play the shot with the desired power (for those who are unable to use the standard cueing action effectively)\n - Now defaults to use the Novice Cue with minimal spin, to give beginners better shot accuracy.", "created_date": 1648679461, "id": "7383773305026405", "version": "1.09", "version_code": 5, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "The latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up and the laser pointer showing, you can now choose to hold the Y button on the left controller to enable Autoplay. Release the Y button to play the shot with the desired power (for those who are unable to use the standard cueing action effectively)\n - Now defaults to use the Novice Cue with minimal spin, to give beginners better shot accuracy.", "created_date": 1648602519, "id": "7379863325417403", "version": "1.08", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "Androi