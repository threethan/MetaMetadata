65993245_3462149684479781488_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eUbRCBQQUeoQ7kNvgGqOgP9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA-QBIWYLYTJjiaDY-RSNkeXgKhiOWfrL7P2oem8_J3iQ&oe=675D8C2B"}, {"file_name": "screenshot2.png", "id": "285562633664373", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001671_285562636997706_4290177067957678845_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wNCYHT_MCkQQ7kNvgHvADim&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBSyO8O1kiIhRF2tcPWAV0PXC-KVJBCBX6U8cKZb2L4sA&oe=675D7443"}, {"file_name": "screenshot3.png", "id": "1098264914349891", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974854_1098264917683224_4454014628276889452_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xzE26PCdefcQ7kNvgF-CBDz&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCCJhR_PN6Y9vl1f0ZsIxfZ0-zxJMEcFGjt0HYFgu5B5w&oe=675D7F23"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1292854621212403", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982512_1292854624545736_258234218258836525_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2CusS6CWqy8Q7kNvgF0cPtS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCvsKKhe07Ix7CrbFm6xcHO2plyk71cRbJK6hn-yQfyjg&oe=675D5955"}, "display_name": "Cueist 2", "keywords": [], "long_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxing environment to play pool and snooker against your friends or AI opponents of increasing skill. A natural cueing action provides realistic spin, jump and swerve shots. 9 Ball, 8 Ball, UK 8 Ball, and Snooker games are included as well as a choice of cues and a customizable table. \n\nOnline play against your friends requires an internet connection.\nVoice chat between players requires permission to use the device's microphone.", "short_description": "The sequel to the popular Cueist pool and snooker game, Cueist 2 gives a relaxin