/t64.5771-25/38974854_1098264917683224_4454014628276889452_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mFfD0UIkItAQ7kNvgEQpWCz&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAihNUYGkAF9ZOCTbG8Yv8S4u-Isdq9h4NxgHkn5Lfknw&oe=672B6623"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "1292854621212403", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982512_1292854624545736_258234218258836525_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fk779I2QrycQ7kNvgGw4v2G&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAOQHhks_JAtpy45olNO_j8Uzv-RKejDCmRAI4UuzMWGw&oe=672B4055"}, "display_name": "Cueist 2", "keywords": [], "long_description": "The sequel to the popular Cueist pool/snooker game, Cueist 2 brings unparalelled realism to online VR cue sports. This is not a casual point and click type game, but a deeper simulation which will reward real skill.\n\n - Play online against your friends with voice chat and Meta Avatars or get some practice in versus the CPU players.\n - Use a natural cueing action using the Touch Controllers, or attach a real cue for the ultimate in feel and accuracy.\n - A choice of specialist cues enables various spin, swerve, masse, and jump shots.\n - Choose between 9 Ball, 8 Ball, UK 8 Ball, and Snooker.\n\nThe latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up, you can nowhold the Y button on the left controller to enable Autoplay", "short_description": "The sequel to the popular Cueist pool/snooker game, Cueist 2 brings unparalelled realism to online VR cue sports. This is not a casual point and click type game, but a deeper simulation which will reward real skill.\n\n - Play online against your friends with voice chat and Meta Avatars or get some practice in versus the CPU players.\n - Use a natural cueing action using the Touch Controllers, or attach a real cue for the ultimate in feel and accuracy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.saitarasoft.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Saitara Software", "support_website_url": null, "website_url": "https://www.saitarasoft.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1316395305523232"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974523_287786286779951_2281181716083478951_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pRr_iGSZoewQ7kNvgE5HswI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwmX1mUyx_3NlhlfLZ0vFckxEC4JumjKxZVS1w0PDYng&oe=672B599C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Cueist 2", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1647889221, "lastRevision": {"nodes": [{"id": "3157926164528334", "release_type": "SCHEDULED", "administ