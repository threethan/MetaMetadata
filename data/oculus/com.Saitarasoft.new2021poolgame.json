ftware", "support_website_url": null, "website_url": "https://www.saitarasoft.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "303736565051100"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7422605814476487", "version": "1.17"}, "id": "684780659564038", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "- You can now choose between 8 types of table physics; some serious, some silly\n- Adjusted the CPU difficulty curve to help beginners\n- Various minor bugfixes", "created_date": 1649430801, "id": "7422605814476487", "version": "1.17", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1649424928, "id": "7422238051179930", "version": "1.15", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "The latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up, you can now choose to hold the Y button on the left controller to enable Autoplay. Release the Y button to play the shot with the desired power (for those who are unable to use the standard cueing action effectively)\n - Now defaults to use the Novice Cue with minimal spin, to give beginners better shot accuracy.", "created_date": 1648679461, "id": "7383773305026405", "version": "1.09", "version_code": 5, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "The latest update adds:\n - Click the left thumbstick to switch between smooth movement and stepped movement (for those who might find smooth movement unsettling)\n - Click the right thumbstick to switch between smooth rotation and snap turns.\n - A new laser aim pointer to aid lining up shots\n - When the shot is lined up and the laser pointer showing, you can now choose to hold the Y button on the left controller to enable Autoplay. Release the Y button to play the shot with the desired power (for those who are unable to use the standard cueing action effectively)\n - Now defaults to use the Novice Cue with minimal spin, to give beginners better shot accuracy.", "created_date": 1648602519, "id": "7379863325417403", "version": "1.08", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7050023918401347", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7422605814476487"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "684780659564038"}]}, "change_log": "- Enabled users to hit any ball at any time, not just when it's their turn. This will cause a foul of course, so be careful!\n- Automatically starts a new match with the same settings after a match is won.", "c