A&oe=6787AC29"}, {"file_name": "Screenshot-4.png", "id": "899462672290968", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982508_899462675624301_4670837775304231832_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50A3MDHHaQ0Q7kNvgFRRAqj&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDlQSWmStiwbYHL6b6JVTKePskQ1uTCn7Yv366MjuNagw&oe=67878938"}, {"file_name": "Screenshot-5.png", "id": "530505993208284", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982466_530505996541617_4010544249587798022_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PtKIgz9X39MQ7kNvgFdB0WU&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC7enRskSaRiNvF6TmqmKS_u8mIgfqXJdri2Z3M28oY1g&oe=6787A350"}, {"file_name": "Screenshot-6.png", "id": "1277355573394764", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38984442_1277355576728097_7814845927612364243_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XNxJ06UbkYgQ7kNvgExULve&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBjddL6uWz_5dHJVDmZrZbF2xeYMjevzvwf97gtYW2wyA&oe=6787B0CB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 X 1440.png", "id": "605867805097991", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57569483_605867808431324_1000610900874374725_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jrlOBOrOaKUQ7kNvgGYFTTa&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDZr0YU7y8MmihrnuKzyTaiTnODk3ZjIz3CPSLE-4PY8w&oe=6787B849"}, "display_name": "Premier League Player Football (Soccer)", "keywords": ["football", "soccer", "sports", "cleansheet", "VRFS"], "long_description": "Get closer to the **Premier League** like never before with Premier League Player, the first-ever officially licensed VR Football (Soccer) game.\n\n**Featuring all 20 Premier League teams**, authentic stadiums, and official kits.\n{1256086785642074}\n\n# Moments\nStep into the action with **Moments mode**, where you can replay highlights from the 2023/24 season. Become a hero for the club you support by scoring game-winning goals, delivering pinpoint assists, and feeling the intensity of every moment as if you were on the field.\n{496176953457265}\n\n# Shot Stopper\nAs the last line of defence, test your reflexes as a Premier League goalkeeper in our **Shot Stopper mode**.\n{1115537873623924}\n\n# Headers\nRise above the competition in our **Heading mode**, perfecting the art of accuracy and timing. Jump in solo or with friends in head-to-head or coop mode.\n{1149444206802903}\n\n# Free Play\nExperience **Freeplay mode**, solo or with friends in local party mode, and sharpen your abilities with tailored Training Drills.\n{1279307706541047}\n\n# The Sanctuary\nExplore the **Player Sanctuary** to unlock and organise players, make the space your own, and then show off with your friends. Collect achievements and celebrate your journey to becoming a **Premier League Player**.\n{1107258291029645}\n\n{1760176541401349}", "short_description": "Get closer to the Premier League with Premier League Player, the first officially licensed VR Football (Soccer) game. \n\nPlay for your favorite club, wearing official kits in iconic stadiums.\n\nReplay the 2023/24 season\u2019s top highlights in Moments mode, test your reflexes as a goalkeeper in Shotstopper, and perfect your timing in Heading Challenges.\n\nJoin friends in Multiplayer, sharpen your skills with Drills, and customize your experience.\n\nYour Premier League experience starts here."}]}, "developer_name": null, "developer_privacy_policy_url": "https://rezzil.com/plp-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Rezzil", "support_website_url": null, "website_url": "https://www.premierleague.com/pl-player", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "1700921480735423"}], "