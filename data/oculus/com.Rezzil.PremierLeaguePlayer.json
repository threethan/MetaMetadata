00_AYD5SKNXorlTRE6OKULk8XZv8phfEMhHgm3CRIIXOvI4DA&oe=678798F6"}, {"file_name": "Screenshot-4.png", "id": "899462672290968", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982508_899462675624301_4670837775304231832_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50A3MDHHaQ0Q7kNvgFRRAqj&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDlQSWmStiwbYHL6b6JVTKePskQ1uTCn7Yv366MjuNagw&oe=67878938"}, {"file_name": "Screenshot-5.png", "id": "530505993208284", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982466_530505996541617_4010544249587798022_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PtKIgz9X39MQ7kNvgFdB0WU&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC7enRskSaRiNvF6TmqmKS_u8mIgfqXJdri2Z3M28oY1g&oe=6787A350"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 X 1440.png", "id": "1206000437355507", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974900_1206000440688840_7316098603858564555_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q5UbKo3VVoIQ7kNvgGu7k4u&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDtrwLeRzM4ftrMWBE0rMaQzP2A1x2WqHuDc_w_KN5y8w&oe=6787A576"}, "display_name": "Premier League Player", "keywords": ["football", "soccer", "sports", "cleansheet", "VRFS"], "long_description": "Get closer to the **Premier League** like never before with Premier League Player, the first-ever officially licensed VR soccer game.\n\n**Featuring all 20 Premier League teams**, authentic stadiums, and official kits.\n{1256086785642074}\n\n# Moments\nStep into the action with **Moments mode**, where you can replay highlights from the 2023/24 season. Become a hero for the club you support by scoring game-winning goals, delivering pinpoint assists, and feeling the intensity of every moment as if you were on the field.\n{496176953457265}\n\n# Shot Stopper\nAs the last line of defence, test your reflexes as a Premier League goalkeeper in our **Shot Stopper mode**.\n{1115537873623924}\n\n# Headers\nRise above the competition in our **Heading mode**, perfecting the art of accuracy and timing. Jump in solo or with friends in head-to-head or coop mode.\n{1149444206802903}\n\n# Free Play\nExperience **Freeplay mode**, solo or with friends in local party mode, and sharpen your abilities with tailored Training Drills.\n{1279307706541047}\n\n# The Sanctuary\nExplore the **Player Sanctuary** to unlock and organise players, make the space your own, and then show off with your friends. Collect achievements and celebrate your journey to becoming a **Premier League Player**.\n{1107258291029645}\n\n{1760176541401349}", "short_description": "Get closer to the Premier League with Premier League Player, the first officially licensed VR soccer game.\n\nPlay for your favorite club, wearing official kits in iconic Premier League stadiums.\n\nReplay the 2023/24 season\u2019s top highlights in Moments mode, test your reflexes as a goalkeeper in Shotstopper, and perfect your timing in Heading Challenges.\n\nJoin friends in Multiplayer, sharpen your skills with Drills, and customize your experience.\n\nYour Premier League experience starts here."}]}, "developer_name": null, "developer_privacy_policy_url": "https://premierleagueplayer.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Rezzil", "support_website_url": null, "website_url": "https://premierleagueplayer.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en_US", "en_GB", "en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6442996295799470"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "612948424405973"}, {"status": "PUBLISHED", "id": "1287165075642079"}]}, "baseline_offer": {"id": "1287165075642079"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1737396000, "status": "PUBLISHED", "id": "612948424405973"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8700654633366947", "version": "0.4.300"}, "id": "3544744295790047", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6442996282466138", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8700654633366947"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3544744295790047"}]}, "change_log": "GAME MECHANIC UPDATE! \u2699\ufe0f\u26bd\n\nVersion: 0.4.300\n\nBOOTS! \nThanks to your valuable feedback, we've adjusted the collision volume on the boots. This change gives players more control and makes it easier to chip up and volley in Freeplay.\n\nOPEN FOOT / VOLLEY \nBased on user feedback, we\u2019ve also made the trigger for opening the foot straighter. This adjustment makes it easier to volley and execute open-foot strikes, with no changes to side-foot passes or other mechanics.\n\n***Pro Tip: Remember, we use real-world physics! If you lean back when shooting, the ball will naturally go higher. To keep your shots low, make sure to keep your head over the ball.\nHappy playing!", "created_date": 1736514556, "id": "8700654633366947", "version": "0.4.300", "version_code": 900, "release