b=1-7&_nc_sid=6e7a0a&_nc_ohc=GXvbPilkllwQ7kNvgES4mn_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA9YJ7eYXaA2AIcPO3_7Jg6128gDhXEmfukT5sdI9aDjg&oe=67348C9F"}, {"file_name": "2024_07_16_0n3_Kleki.png", "id": "853604533327814", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974785_853604536661147_8696033715543429473_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OrSYmu1XcyMQ7kNvgFZSPbL&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAo5dncfW-fMMJqJ_LUYXMeXVwTlcQ2fKF7csSzdj-qdw&oe=673474FA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "IMG_1723.png", "id": "375229432281887", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974819_375229435615220_2861483926012277246_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cm1029lSaBQQ7kNvgGgZGtB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAENwFIy6l8G2Lc36mWaYqd9lY-f1RtCxU93nSkR5owQg&oe=67347812"}, "display_name": "Sphere Guys", "keywords": [], "long_description": "Sphere Guys is a gorilla tag locomotion game based on the popular game \"Gorilla Tag.\" It features multiplayer functionality, allowing you to create private rooms and play with your friends! If you want to play with random people, we recommend joining codes 1, 2, or 3, as these are the most popular.\n\nThere are multiple fun game modes, such as Parkour, which has easy, medium, and hard levels. Another mode is Chase, where a scary ghost chases you! In the Space mode, you experience zero gravity, just like in actual space. You also get a rocket controlled by the player's hand and trigger button to move around easily.\n\nIn Dropper, you drop from a high place and try to land in a pool while avoiding obstacles. In Rising Lava, a volcano erupts, and you need to survive by navigating an obstacle course. The Hangout mode has three different islands, representing Autumn, Winter, Summer, and Spring.\n\nThe game also features a mall with plenty of cosmetics to choose from and bundles at great prices. Inside the mall, there is an entire pool map with multiple slides, an actual movie theater, and more content coming soon!", "short_description": "This is a Gorilla Tag Locomotion game with multiplayer. It has multiple gamemodes like for example Parkour, Rising Lava, Space/No Gravity, Dropper, Chase and Hangout. Even more gamemodes coming in the future!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/sphere-guys-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "PopTimeDev", "support_website_url": null, "website_url": "https://sites.google.com/view/sphereguys2024", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "9176912588988802"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395604_405802248874302_8752541268255953069_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cw19yQUWhooQ7kNvgF0syZU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBts5tyhk1P0y3oOG9FCSVqk1lg0bPR4Ol-nIoRUxfitw&oe=67348B6E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sphere Guys", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1704926710, "lastRevision": {"nodes":