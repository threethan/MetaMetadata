51_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WaYnKM7qbSQQ7kNvgFCCcvz&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCmXv576bvbwctFa8w79EGq_NV4S4kkGAtJUcN35_WvMg&oe=670FA4F6"}, {"file_name": "ss7.png", "id": "512472986379303", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031547_512472989712636_7638735751378089066_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1KPAbRC7z8Q7kNvgGlsVWi&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB6CquiW4-EH_w1PoB1Bc7TmHetILto786yQj63aAHJ6Q&oe=670F8C61"}, {"file_name": "ss2.png", "id": "421888538948247", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982542_421888542281580_7961047171456036679_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nF6JzpX62KMQ7kNvgEeU-oJ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDtNq7aFvidN2Ng_D5KdHcMKQA-GRbDj_ORhftHk2cQEA&oe=670FBDA2"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sH91Ib5Op7YQ7kNvgF8eskp&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDlOJbBh5Q5hrh1C8o5RV58eWCMtdfSh3oF216vHUFFtQ&oe=670F91D0"}, {"file_name": "ss5.png", "id": "215595850179052", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39036702_215595853512385_1516722769013058759_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5hmzgQNDWpAQ7kNvgH7ezc9&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDbQ9gtO47qvBXO8y_ttU3Q9LIEGLF7_bkkuI2q1B7Ung&oe=670FAC64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_Horizontal.png", "id": "375191540435674", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75375082_375191543769007_2543150386744462971_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MjpMD2ySj2MQ7kNvgHY4xD3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB0KGDgJaF5NpeAJ04ljZT3XX-v_0VcXBtFIu_3-1Y8RQ&oe=670FAA46"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIARN", "CounterFight", "JobSimurator", "Ramen", "cooking"], "long_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\nGame features\n\nBecome an employee of ICHIRAN and cook ramen!\n\nOptimized for VR games, the kitchen has intuitive gameplay that makes you feel like an ICHIRAN's employee.\n\nAim for a high score in response to customer orders!\n\nNot only cook ramen, also reproduce in-game the particulars of ICHIRAN, such as judging the beauty of presentation and the \"15 second standard\" to maintain the freshness of ramen.\n\nYou can enjoy the atmosphere of ICHIRAN anywhere!\n\nMany familiar items such as Kaedama plate and Order sheets that can only be seen at shops, Original spicy red sauce, and Arita porcelain original donburi bowls will appear.\n\nThe sound is faithfully reproduced!\n\nThe background music and sound effects of the Kaedama that flow in the store are faithfully ", "short_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\n*Game features*\nBecome an employee of ICHIRAN and cook ramen!\nAim for a high score in response to customer orders!\nYou can enjoy the atmosphere of ICHIRAN anywhere!\nThe sound is faithfully reproduced!"}, {"images": {"nodes": [{"file_name": "HeroCover.png", "id": "2929472120610209", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75210390_2929472123943542_324928563406628709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MTJj6XqqmtAQ7kNvgFYvGL8&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBxkuNTU1RFZIMpHBKBQZCqXnuwuJ039rjmHDbzq4gTJQ&oe=670F9800"}, {"file_name": "logo.png", "id": "93334195720009