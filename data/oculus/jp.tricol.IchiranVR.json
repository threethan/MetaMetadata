69013058759_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=siip7ju--b0Q7kNvgEZ1RXd&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYDr0mga4cJdm3pjo8p-ExEgWrRy7z8KHY4xFCwrIxNfpw&oe=66F3FCE4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_Horizontal.png", "id": "375191540435674", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375082_375191543769007_2543150386744462971_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zkRW2CrAXlYQ7kNvgHebm4a&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYBABH43uzVTANKD3BWJKLBFGSCLpcGwWiPH81ChkPozJQ&oe=66F3FAC6"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIARN", "CounterFight", "JobSimurator", "Ramen", "cooking"], "long_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\nGame features\n\nBecome an employee of ICHIRAN and cook ramen!\n\nOptimized for VR games, the kitchen has intuitive gameplay that makes you feel like an ICHIRAN's employee.\n\nAim for a high score in response to customer orders!\n\nNot only cook ramen, also reproduce in-game the particulars of ICHIRAN, such as judging the beauty of presentation and the \"15 second standard\" to maintain the freshness of ramen.\n\nYou can enjoy the atmosphere of ICHIRAN anywhere!\n\nMany familiar items such as Kaedama plate and Order sheets that can only be seen at shops, Original spicy red sauce, and Arita porcelain original donburi bowls will appear.\n\nThe sound is faithfully reproduced!\n\nThe background music and sound effects of the Kaedama that flow in the store are faithfully ", "short_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\n*Game features*\nBecome an employee of ICHIRAN and cook ramen!\nAim for a high score in response to customer orders!\nYou can enjoy the atmosphere of ICHIRAN anywhere!\nThe sound is faithfully reproduced!"}, {"images": {"nodes": [{"file_name": "HeroCover.png", "id": "2929472120610209", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210390_2929472123943542_324928563406628709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UaSTQr8QUm4Q7kNvgG77CBI&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYDP8aLK3yj9MlEq0B6ejv_k1K0Wl9_BG1HkNUe3RrlJ9Q&oe=66F3E880"}, {"file_name": "logo.png", "id": "933341957200091", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422372_933341960533424_4859949339304657620_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QCtgjAR9oPAQ7kNvgET9a4d&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYBzlOOMG-l_EJlpk7tBwFv9ga6kcYjagrvWgxRebs-87w&oe=66F40733"}, {"file_name": "MiniLandscape.png", "id": "805830126631709", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282165_805830129965042_8641739740128532803_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=faqUAhnOteMQ7kNvgE6ROZw&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYA1QAopG541OfwOUolIBkc-wqC2HVALGaZFRZ-az1qFTg&oe=66F3E855"}, {"file_name": "CoverPortrait.png", "id": "371006560865645", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974485_371006564198978_4464717763319316838_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xYYdFvhhcvkQ7kNvgHQS9b6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-eYFYggnOY5IAKHoOfyxMc&oh=00_AYD35NEf1ni_1wvWIe-7ry0vGPAK9nYUK56gsed-kB2-rQ&oe=66F40665"}, {"file_name": "CoverSquare.png", "id": "206631087618157", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://