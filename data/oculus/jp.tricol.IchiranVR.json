E257tPbVsQ7kNvgFcOqVH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVVsrGROS2YcFg3pqgpuZtYSonEXc5KN41nnBouIUoZQ&oe=67052064"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RIfXdwBE4fYQ7kNvgFTE4JS&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCw5IvPln7tFp_4t8Ndl8bzTt77JpW9HH_jTxDsJhNHng&oe=670505D0"}, {"file_name": "ss7.png", "id": "512472986379303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031547_512472989712636_7638735751378089066_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXXHQ7_p1IEQ7kNvgEZ68Fn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwBcevxmUSPGgm8T8FNK0mS_N2MH2dFtvmX7E6SUAlhA&oe=67050061"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "432285677886946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75458091_432285681220279_7535572255127238121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zgAF1MCjCVMQ7kNvgF90CgB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnmGFnMMFKLvM_L9qS1WCtz10YikrqcwTHOaTvoAP-gg&oe=67051937"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIRAN", "CounterFight", "JobSimulator", "Ramen", "cooking"], "long_description": "Make some mouth-watering ramen!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game created with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous tonkotsu ramen chain with 85 outlets in Japan. Established over 60 years ago, it's been perfecting its hit specialty tonkotsu ramen for a long time, which is why ICHIRAN's ramen is the best in the land. In fact, it's often touted in the media as a \"must-try cuisine\" for foreign visitors.\n\nGame Features:\n\u30fbFulfill orders to get a high score! \nImmersive kitchen-based gameplay lets you experience life as a real ICHIRAN employee, racking up points for your ramen preparation skills and speedy delivery.\n\n\u30fbClimb the ranks in store management mode! \nYour score in store management mode is entered into a world ranking. Boost your profits to employ more staff and increase seating capacity as you try to hit the high scores with your own unique store!\n\n*In-game kitchen layout may differ from actual restaurants.", "short_description": "Cook some knockout noodles!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game made with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous organic tonkotsu ramen chain with 85 outlets in Japan, often touted as a \"must-try cuisine\" for tourists. It has outlets in NY, Hong Kong, and Taiwan, too.\n\nFeatures:\n\u30fbFulfill orders to get a high score!\n\u30fbTake top place in store management mode!\n\u30fbBoost profits, employ more staff, up capacity, and hit the high scores with your own unique store!"}, {"images": {"nodes": [{"file_name": "MiniLandscape.png", "id": "3838591046231584", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984462_3838591052898250_5002299579482394963_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ttbwsLMgWvoQ7kNvgFeTY6u&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDooXV-iOnarNOYUYkL2n6TfOQlmXMcDHZNvYUZ1sGZhQ&oe=6705235E"}, {"file_name": "CoverSquare.png", "id": "2182671695203710", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75641339_2182671698537043_1819436220465957851_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61t9dFBfg9gQ7kNvgGbJrW6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACxMqYtGBDOWbD3akYa5SYmoE8m4HKVNfoh4SmMjCJ0g&oe=670500BB"}, {"file_name": "icon.png", "id": "446502446404480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476755_446502449737813_695504826495623275_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WAv6FIszn6UQ7kNvgHghdV6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnhhqqSt4AHmcE5Qcx9w7d8AtJ3FGkQ0y