mzgQNDWpAQ7kNvgH7ezc9&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDbQ9gtO47qvBXO8y_ttU3Q9LIEGLF7_bkkuI2q1B7Ung&oe=670FAC64"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sH91Ib5Op7YQ7kNvgF8eskp&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDlOJbBh5Q5hrh1C8o5RV58eWCMtdfSh3oF216vHUFFtQ&oe=670F91D0"}, {"file_name": "ss7.png", "id": "512472986379303", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031547_512472989712636_7638735751378089066_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1KPAbRC7z8Q7kNvgGlsVWi&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB6CquiW4-EH_w1PoB1Bc7TmHetILto786yQj63aAHJ6Q&oe=670F8C61"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "432285677886946", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75458091_432285681220279_7535572255127238121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OBaAG7W-6RoQ7kNvgH1MT2o&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBnQFuG-_JGxt2a_j-lM8-E5b7X9VVrcsvlUio_ZCLT8Q&oe=670FA537"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIRAN", "CounterFight", "JobSimulator", "Ramen", "cooking"], "long_description": "Make some mouth-watering ramen!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game created with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous tonkotsu ramen chain with 85 outlets in Japan. Established over 60 years ago, it's been perfecting its hit specialty tonkotsu ramen for a long time, which is why ICHIRAN's ramen is the best in the land. In fact, it's often touted in the media as a \"must-try cuisine\" for foreign visitors.\n\nGame Features:\n\u30fbFulfill orders to get a high score! \nImmersive kitchen-based gameplay lets you experience life as a real ICHIRAN employee, racking up points for your ramen preparation skills and speedy delivery.\n\n\u30fbClimb the ranks in store management mode! \nYour score in store management mode is entered into a world ranking. Boost your profits to employ more staff and increase seating capacity as you try to hit the high scores with your own unique store!\n\n*In-game kitchen layout may differ from actual restaurants.", "short_description": "Cook some knockout noodles!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game made with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous organic tonkotsu ramen chain with 85 outlets in Japan, often touted as a \"must-try cuisine\" for tourists. It has outlets in NY, Hong Kong, and Taiwan, too.\n\nFeatures:\n\u30fbFulfill orders to get a high score!\n\u30fbTake top place in store management mode!\n\u30fbBoost profits, employ more staff, up capacity, and hit the high scores with your own unique store!"}, {"images": {"nodes": [{"file_name": "MiniLandscape.png", "id": "3838591046231584", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38984462_3838591052898250_5002299579482394963_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A95hHJqpdxcQ7kNvgFrHF5X&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC_AxY1ZaQsib0bXKKh_IulltNhjrJTQLaKv4k8uxTjVg&oe=670FAF5E"}, {"file_name": "CoverSquare.png", "id": "2182671695203710", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75641339_2182671698537043_1819436220465957851_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YcdTe6Q6qLoQ7kNvgFaXA2d&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDt-2pexmuvgBZ4-jtEk6d3UBlXvBKSgmUAUc85Dm22UA&oe=670F8CBB"}, {"file_name": "icon.png", "id": "446502446404480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75476755_446502449737813_695504826495623275_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dz8uAgVfHoUQ7kNvgH6gw8C&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDi-C28CDuclwoh_qWkVyoE7n1RrhqaB4v