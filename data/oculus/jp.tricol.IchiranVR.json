51_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QaEYziT1x0EQ7kNvgFpc4bv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBViznemHWwOeYF5MeK30hj8SmfprkrZ-j9s1WppVa3AA&oe=670518F6"}, {"file_name": "ss7.png", "id": "512472986379303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031547_512472989712636_7638735751378089066_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXXHQ7_p1IEQ7kNvgEZ68Fn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwBcevxmUSPGgm8T8FNK0mS_N2MH2dFtvmX7E6SUAlhA&oe=67050061"}, {"file_name": "ss2.png", "id": "421888538948247", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982542_421888542281580_7961047171456036679_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2yekxL9uQLAQ7kNvgHIZuj8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ0r9H61FiFaKVuCL4w-wiufAjmAkfdvI1Pfd2nrwkwA&oe=670531A2"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RIfXdwBE4fYQ7kNvgFTE4JS&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCw5IvPln7tFp_4t8Ndl8bzTt77JpW9HH_jTxDsJhNHng&oe=670505D0"}, {"file_name": "ss5.png", "id": "215595850179052", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036702_215595853512385_1516722769013058759_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D-E257tPbVsQ7kNvgFcOqVH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVVsrGROS2YcFg3pqgpuZtYSonEXc5KN41nnBouIUoZQ&oe=67052064"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_Horizontal.png", "id": "375191540435674", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375082_375191543769007_2543150386744462971_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fXh06ISC5wQ7kNvgEk--Ln&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASsrmg9cr31Rb4gmtjap-WNmekqtZHC2c0ykhmbRLcFA&oe=67051E46"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIARN", "CounterFight", "JobSimurator", "Ramen", "cooking"], "long_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\nGame features\n\nBecome an employee of ICHIRAN and cook ramen!\n\nOptimized for VR games, the kitchen has intuitive gameplay that makes you feel like an ICHIRAN's employee.\n\nAim for a high score in response to customer orders!\n\nNot only cook ramen, also reproduce in-game the particulars of ICHIRAN, such as judging the beauty of presentation and the \"15 second standard\" to maintain the freshness of ramen.\n\nYou can enjoy the atmosphere of ICHIRAN anywhere!\n\nMany familiar items such as Kaedama plate and Order sheets that can only be seen at shops, Original spicy red sauce, and Arita porcelain original donburi bowls will appear.\n\nThe sound is faithfully reproduced!\n\nThe background music and sound effects of the Kaedama that flow in the store are faithfully ", "short_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\n*Game features*\nBecome an employee of ICHIRAN and cook ramen!\nAim for a high score in response to customer orders!\nYou can enjoy the atmosphere of ICHIRAN anywhere!\nThe sound is faithfully reproduced!"}, {"images": {"nodes": [{"file_name": "HeroCover.png", "id": "2929472120610209", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210390_2929472123943542_324928563406628709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JhOkhi3GmJEQ7kNvgFNquMw&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSghxk2aCsuu4xOKXgnnBwwfMG2P8cQ8L5l42NghNi4w&oe=67050C00"}, {"file_name": "logo.png", "id": "93334195720009