&oe=66CEF2E1"}, {"file_name": "ss2.png", "id": "421888538948247", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982542_421888542281580_7961047171456036679_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mcRf8O_75DsQ7kNvgEzH1Us&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpua-tZJJjTfrFdS1tO0_KaC7dwo7nW8PyIEJcSQl8oQ&oe=66CF2422"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KKot2nbSINoQ7kNvgEZljUr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtgcc0q5rN_3vL-UjvBjyB0d9RPsCdVJdEYIzVz9BkSg&oe=66CEF850"}, {"file_name": "ss5.png", "id": "215595850179052", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036702_215595853512385_1516722769013058759_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qzQiJ5j8w4MQ7kNvgEGqXnB&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXlytbXpLgP7ID5nzrykFx7PCVOsdJ1m06r438ZNCQ5g&oe=66CF12E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_Horizontal.png", "id": "375191540435674", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375082_375191543769007_2543150386744462971_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JGUG-5DSv5IQ7kNvgHdapWf&_nc_ht=scontent.oculuscdn.com&oh=00_AYACfK5E6hAjfbO12Xfbjfhw3Tr55NkYf5hYUciqsTQl5Q&oe=66CF10C6"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIARN", "CounterFight", "JobSimurator", "Ramen", "cooking"], "long_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\nGame features\n\nBecome an employee of ICHIRAN and cook ramen!\n\nOptimized for VR games, the kitchen has intuitive gameplay that makes you feel like an ICHIRAN's employee.\n\nAim for a high score in response to customer orders!\n\nNot only cook ramen, also reproduce in-game the particulars of ICHIRAN, such as judging the beauty of presentation and the \"15 second standard\" to maintain the freshness of ramen.\n\nYou can enjoy the atmosphere of ICHIRAN anywhere!\n\nMany familiar items such as Kaedama plate and Order sheets that can only be seen at shops, Original spicy red sauce, and Arita porcelain original donburi bowls will appear.\n\nThe sound is faithfully reproduced!\n\nThe background music and sound effects of the Kaedama that flow in the store are faithfully ", "short_description": "Let's make the best ramen for customers!\n\n\"Counter Fight ICHIRAN\" is a completely new cooking game that combines the experience of the VR work simulator game \"Counter Fight\" and the popular natural tonkotsu ramen specialty store \"ICHIRAN\".\n\n*Game features*\nBecome an employee of ICHIRAN and cook ramen!\nAim for a high score in response to customer orders!\nYou can enjoy the atmosphere of ICHIRAN anywhere!\nThe sound is faithfully reproduced!"}, {"images": {"nodes": [{"file_name": "HeroCover.png", "id": "2929472120610209", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210390_2929472123943542_324928563406628709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I293HEhJLfgQ7kNvgHBKveF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHFh5MmqkdR_4v_LTNkUPbuBzOfaNVgT7lptDRkg0JYA&oe=66CEFE80"}, {"file_name": "logo.png", "id": "933341957200091", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422372_933341960533424_4859949339304657620_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mej1KWjYeGUQ7kNvgHHoJlL&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_9S43KQGZHqpFryeC7DVYlH76gL6r1m-gXQ2kAJKBGw&oe=66CF1D33"}, {"file_name": "MiniLandscape.png", "id": "805830126631709", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282165_805830129965042_8641739740128532803_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jP2sr