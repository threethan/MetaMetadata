850179052", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036702_215595853512385_1516722769013058759_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l4PkVAsp6UwQ7kNvgFocdNF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYCptGhOHS23zSavMii9bRtVof_iAtZ2PSqulPkDl3Ilgw&oe=66E42AE4"}, {"file_name": "ss4.png", "id": "416146802772950", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982521_416146806106283_7161111592696257607_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=egmt823vqnoQ7kNvgF0gzeA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYDwJAXFavRw7ruSIjnchmziYP7awZ9GgJidtmxuYmXhSg&oe=66E41050"}, {"file_name": "ss7.png", "id": "512472986379303", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031547_512472989712636_7638735751378089066_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fJ6gwC7Be1gQ7kNvgGm7Rh5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYBHJZB2X8_-yja3Hh_IwyW7iIf8JjaJenQ89y0zCTOwyA&oe=66E40AE1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "432285677886946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75458091_432285681220279_7535572255127238121_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bA4eegq4trUQ7kNvgExyB2L&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYDrH3q5NeyCNiLyQJmDyFrtBqMvJAz-7GL58y_x8El6OQ&oe=66E423B7"}, "display_name": "Counter Fight ICHIRAN", "keywords": ["ICHIRAN", "CounterFight", "JobSimulator", "Ramen", "cooking"], "long_description": "Make some mouth-watering ramen!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game created with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous tonkotsu ramen chain with 85 outlets in Japan. Established over 60 years ago, it's been perfecting its hit specialty tonkotsu ramen for a long time, which is why ICHIRAN's ramen is the best in the land. In fact, it's often touted in the media as a \"must-try cuisine\" for foreign visitors.\n\nGame Features:\n\u30fbFulfill orders to get a high score! \nImmersive kitchen-based gameplay lets you experience life as a real ICHIRAN employee, racking up points for your ramen preparation skills and speedy delivery.\n\n\u30fbClimb the ranks in store management mode! \nYour score in store management mode is entered into a world ranking. Boost your profits to employ more staff and increase seating capacity as you try to hit the high scores with your own unique store!\n\n*In-game kitchen layout may differ from actual restaurants.", "short_description": "Cook some knockout noodles!\n\n\"Counter Fight ICHIRAN\" is an all-new cooking game made with input from popular ramen store, ICHIRAN.\n\nICHIRAN is a famous organic tonkotsu ramen chain with 85 outlets in Japan, often touted as a \"must-try cuisine\" for tourists. It has outlets in NY, Hong Kong, and Taiwan, too.\n\nFeatures:\n\u30fbFulfill orders to get a high score!\n\u30fbTake top place in store management mode!\n\u30fbBoost profits, employ more staff, up capacity, and hit the high scores with your own unique store!"}, {"images": {"nodes": [{"file_name": "MiniLandscape.png", "id": "3838591046231584", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984462_3838591052898250_5002299579482394963_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vf9B2hCkeaIQ7kNvgFhGKZw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYBBIs7GVDF5ltDZ2SoTDtqcPHDcHpYisBWq1R0S-uqhvg&oe=66E42DDE"}, {"file_name": "CoverSquare.png", "id": "2182671695203710", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641339_2182671698537043_1819436220465957851_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yRwIn689ooQQ7kNvgH3i1SZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGX9SABfi0DKVBSw59AuOqu&oh=00_AYCC0khQaxg3np1PoaZEKLMuWffgSfTQQhYSadHCRCGKBg&oe=66E40B3B"}, {"file_name": "icon.png", "id": "446502446404480", "image_ty