4575_817680602343393096_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n4ULOuNLJqYQ7kNvgGCR2Bo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAFot5YvQ0cfPGEu-ECcF_xo3tA6pGIfbDp4T2tQmaCYA&oe=6780EC80"}, {"file_name": "4.png", "id": "173073422495820", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982510_173073425829153_2299599481635269940_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=asqXnKtnsYcQ7kNvgEL258M&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDoOK2c_9AAvDyxcYSCfnHSl9wl-R7cRcX0cg13b-KDOQ&oe=67812175"}, {"file_name": "2.png", "id": "6842423902480754", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974729_6842423905814087_1714687859642765159_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jSrJ7SIBi70Q7kNvgElde_L&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB3i4pMQtmhbLrfu7Tgxpb_Fd1lTQKN5GoNLZ5vIzdYoQ&oe=678110D9"}, {"file_name": "7.png", "id": "688757976141154", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001729_688757979474487_372831043915449376_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vc4AfBXew_kQ7kNvgHr8qo0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAwKgNXPwPtRKb_cvsCU2Uku0sYiKup9WtxZw63_5UIuQ&oe=67811E30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "9.png", "id": "812515083888727", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974794_812515087222060_3028579936202036671_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I9o2FpQJjRQQ7kNvgGY5MEt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDT9Vif3X_hOpC2AZk_6oIUrlz9QXb6PTsD_6nIcbcjiA&oe=678101A6"}, "display_name": "Pickleball Pro - Early Access", "keywords": [], "long_description": "Early Access Alert: Unleash your inner Pickleball Pro!\n\nAvailable Now:\n\nDive into specialized mini-games designed to master the art of dinks, drops, and powerful slams.\n\nTest your skills against our 8.0 DUPR practice wall\u2014your ultimate sparring partner that never gets tired.\n\nHarness the power of a fully customizable ball machine. Engineer the perfect shot, set the spin, angle, and speed, then let it rip!\n\nComing Soon:\n\nGet ready to face off in high-stakes single-player and multiplayer matches. Scheduled for release in 2024. NOTE: These modes are under development and not included in the current Early Access package.\n\n\ud83d\udd25Pricing Alert: The value-packed Early Access price is a limited-time offer. Upon the release of more content including single-player and multi-player modes in 2024, the game's price will jump considerably. Get in now to enjoy future upgrades at no extra cost!", "short_description": "This is the EARLY ACCESS version of the worlds ultimate Pickleball simulator!\n\nAvailable Now:\n\nDive into training mini-games for dinks, drops, slams, and a practice wall. In addition to a fully configurable ball machine that can throw out any shot you can create.\n\nComing Soon:\n\nPickleball Pro will include single-player and multi-player matches but this is not currently part of the early access version.\n\nWhen single-player and multi-player modes are released the price of the app will increase."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.elevenvr.com/en/privacy/", "developer_terms_of_service_url": "https://www.elevenvr.com/en/tos/", "publisher_name": "For Fun Labs", "support_website_url": null, "website_url": "https://pball.pro/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": [