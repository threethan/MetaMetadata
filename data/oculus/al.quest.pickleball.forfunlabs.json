647141", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75534974_3772346832980474_8385164768429886058_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tSpdUq6DRr4Q7kNvgF_eCcQ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAWa4pl8tVpHwwhnCwzVr91Ixbl_PKUiNVRP13Ewt96Zg&oe=672B3B69"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-b-thumb-2.PNG", "id": "1659092211515154", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031354_1659092214848487_7808347538223477797_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPlvak3GRmwQ7kNvgGg8_Kb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAxJTfzbdY2ruEyeeZPmun3vlYhaextAICGPl1tm27QXA&oe=672B6EFD"}, "display_name": "Eleven Pickleball", "keywords": ["eleven", "pickleball", "pro", "simulator", "racket"], "long_description": "The worlds leading pickleball simulator from the developers of **Eleven Table Tennis**.\n\n# Online Multiplayer\nChallenge players worldwide in 1v1 and 2v2 **online matches**.\n\n# Real Life Physics with a Paddle Adapter\nGrab a paddle adapter to maximize physics realism \n\n{502403729250277}\n\n{1659537568170968}\n\n{2533271210193498}\n\n# Training\nMaster your game with our **hyper configurable & programmable ball machine**. Engineer the perfect shot, set the spin, angle, and speed, then let it rip. Dive into specialized training tools: Dink, Drop, Slam, Reaction, Wall\n\n# Singleplayer\nTest your skills against advanced AI opponents in 1v1 and 2v2 games.\n\n# Customization\n- Adjust ball visibility and color for precise tracking\n- Personalize court aesthetics to suit your style", "short_description": "The worlds leading realism pickleball simulator, from the developers of Eleven Table Tennis. Online 1v1 and 2v2 multiplayer, singleplayer against AI bots, and advanced training tools to level up your skill."}]}, "developer_name": null, "developer_privacy_policy_url": "https://11pball.com/privacy/", "developer_terms_of_service_url": "https://11pball.com/tos", "publisher_name": "For Fun Labs", "support_website_url": null, "website_url": "https://11pball.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "26666833462932322"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974866_1471441663491643_5519640092427098471_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GMKeydaKzVYQ7kNvgGa7ztp&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAa_gbDo2uqT39Eev0NjNVFasM4cJi6PHMk8qsUsX8WoQ&oe=672B3EFF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Eleven Pickleball", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1699455600, "lastRevision": {"nodes": [{"id": "9971213929587538", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "9971213886254209", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "875991693949671"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"