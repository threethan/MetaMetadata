CdFWeTMQ7kNvgHwyeh3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3KFX6mQdqm_vlP_q2wF7NRFrGi2hmFoTtDdPe9s5mKA&oe=671CCCBB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "272942851593434", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569423_272942854926767_8458628664151003811_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3FJsc9sFlNgQ7kNvgFVaGxP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCQe0rtsOXjZMuBGzamCUmQHxjn8WH_ADG20yS7usltQ&oe=671CD55F"}, "display_name": "Human Anatomy VR", "keywords": [], "long_description": "FREE TRIAL for 2 Hours for all content. After free trial, Guest mode is activated. Guest mode contains Skeletal system, Bronchial microanatomy model and movement preview. Subscription plan for unlock all available content after 2 hours is required. \n\nINTRODUCTORY PRICE for SUBSCRIBE PLAN! (Students ,Educators, Professional)\n\nHuman Anatomy delivers the most immersive and intuitive human anatomical experience available on market designed for students, medical and nursing schools, universities, healthcare systems, medical associations, and health practitioners. Feature rich content is delivered in a deeply engaging experience with excellent graphics, innovative presentation, and visual delivery.\n\nThe software provides 15 human body systems with more than 10 000 realistic anatomical structures designed by medical professionals. Bone mapping with 5000 bony features organized into Parts, Surfaces, Borders, and Landmarks. 21 Microanatomy models, over 500 movements animations and more!", "short_description": "The most advanced anatomical platform for virtual reality is finally here on Oculus Quest! \n\nNew Update! \nHANDTRACKING in now supported as experimental feature.\n\nVirtual Medicine has created the most advanced, multi-award-winning medical anatomy platform crossing Virtual Reality (VR), Mixed Reality (MR), and Augmented Reality (AR) for medical education. Human Anatomy VR is the only product on the market to provide an full VR anatomical atlas combined with advanced 3D VR DICOM viewer."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.medicinevirtual.com/data/Licence_VM.pdf", "developer_terms_of_service_url": null, "publisher_name": "Virtual Medicine s.r.o", "support_website_url": null, "website_url": "https://medicinevirtual.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["MEDICINE", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1069716047089480"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "551650669784639"}]}, "baseline_offer": {"id": "551650669784639"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1654552800, "status": "PUBLISHED", "id": "551650669784639"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7109469605844320", "version": "2024.41.1"}, "id": "922013611804643", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3662196457238336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7109469605844320"}, "release_status": "RELEASED"}, "binary_release_ch