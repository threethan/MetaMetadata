com/v/t64.5771-25/38974876_176724807272999_1907376285138155174_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xn6nKpLUg-oQ7kNvgGUC7_Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlTuUOohOebLXPlIIDk8nMtkijKfQp6M7Br6SJENoxZQ&oe=677D20D7"}, {"file_name": "07.png", "id": "707443609951539", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572918_707443613284872_3422591151930594066_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1gD1JPtSXcAQ7kNvgGf0N7o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBe-2CVIfOKJbWyPJI4nqy-ogZGUI6ENoaqrPYBOIfhog&oe=677D2528"}, {"file_name": "09.png", "id": "423296202083013", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_423296205416346_6572123320491667633_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IRB2xNEggxgQ7kNvgFKP2UH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEKWKJA97HoC81hstrcVGt1EPzgF5WflLcqx5qOxC4kQ&oe=677D1827"}, {"file_name": "15.png", "id": "709563269707982", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_709563273041315_5461420241404035025_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g5BPVXJDdt8Q7kNvgFjIRc8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3ecZ_fsMaiCV-3quUAhKGeOIoqHeu0o9_B7LY2GzWHA&oe=677D0392"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "466543267834311", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75195909_466543271167644_7584934116239430174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OMaiWQRSXxoQ7kNvgFqQD4Y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ3L5BIM7DZ8Yuk7rTqVjaAJmyUY0SIfWCKKqsko706g&oe=677CF7D0"}, "display_name": "VR New York Story", "keywords": [], "long_description": "As a total solution for English Speaking Education game, VR New York Story makes you have a conversation with Characters and develop your English speaking ability. With virtual reality technology, you feel as if there are truly in various places in New York. So you can move around everywhere we've implemented and do whatever you want in dynamic environment, not a static one.\n\nWe provide 3,800 sentences which include 240 key sentences and 720 core sentences, and Sound Recognition technology to evaluate English proficiency of users. This is our first series that include 60 units. We also plan to release a full range of 240 units in order so you can count on what's coming next!", "short_description": "As a total solution for English Speaking Education game, VR New York Story makes you have a conversation with Characters and develop your English speaking ability. People who want to develop their English ability are not required to spend time and money on overseas study anymore! This elaborately devised VR game enables you to visit everywhere in New York and feel the atmosphere of the place with your hands."}, {"images": {"nodes": []}, "id": "504845473867746", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR New York Story", "keywords": [], "long_description": "VR\u7ebd\u7ea6\u6545\u4e8b\u662f\u4ee5\u7ebd\u7ea6\u4e3a\u80cc\u666f\u7684\u865a\u62df\u7a7a\u95f4\u4e2d\uff0c\u5229\u7528\u82f1\u8bed\u53e3\u8bed\u5b66\u4e60\u89e3\u51b3\u65b9\u6848\uff0c\u4e0e\u89d2\u8272\u8fdb\u884c\u751f\u52a8\u7684\u5bf9\u8bdd\u4f53\u9a8c\u7684VR\u6e38\u620f\u3002\n\u5728\u865a\u62df\u73b0\u5b9e\u4e2d\uff0c\u53ef\u4ee5\u53bb\u6e38\u620f\u4e2d\u5185\u7f6e\u7684\u4efb\u4f55\u573a\u6240\uff0c\u5728\u52a8\u6001\u7684\u73af\u5883\u4e2d\uff0c\u53ef\u4ee5\u5b66\u4e60\u4efb\u4f55\u60f3\u5b66\u7684\u82f1\u8bed\u8868\u8fbe\u3002\n\u6211\u4eec\u4f1a\u63d0\u4f9b3800\u4e2a\u6587\u7ae0\uff0c\u5176\u4e2d\u5305\u62ec240\u4e2a\u548c720\u4e2a\u6838\u5fc3\u6587\u7ae0\uff0c\u9664\u6b64\u4e4b\u5916\u8fd8\u63d0\u4f9b\u53ef\u4ee5\u6d4b\u8bc4\u4f7f\u7528\u8005\u82f1\u8bed\u80fd\u529b\u7684\u8bed\u8a00\u8bc6\u522b\u6280\u672f\u3002\u7b2c\u4e00\u4e2a\u7cfb\u5217\u753160\u4e2a\u8bfe\u7a0b\u7ec4\u6210\uff0c\u5e76\u4f9d\u6b21\u63a8\u51fa\u5269\u4e0b\u7684240\u4e2a\u8bfe\u7a0b\uff0c\u656c\u8bf7\u671f\u5f85\u4ee5\u540e\u7684\u7cfb\u5217\uff01\n", "short_description": "VR\u7ebd\u7ea6\u6545\u4e8b\u662f\u4ee5\u7ebd\u7ea6\u4e3a\u80cc\u666f\u7684\u865a\u62df\u7a7a\u95f4\u4e2d\uff0c\u5229\u7528\u82f1\u8bed\u53e3\u8bed\u5b66\u4e60\u89e3\u51b3\u65b9\u6848\uff0c\u4e0e\u89d2\u8272\u8fdb\u884c\u751f\u52a8\u7684\u5bf9\u8bdd\u4f53\u9a8c\u7684VR\u6e38\u620f\u3002\n\u73b0\u5728\u4e0d\u8981\u518d\u4e3a\u4e86\u5b66\u4e60\u82f1\u8bed\u800c\u5728\u6d77\u5916\u7559\u5b66\u82b1\u8d39\u65f6\u95f4\u548c\u91d1\u94b1\u4e86\uff01\n\u901a\u8fc7\u7cbe\u81f4\u7684VR\u6e38\u620f\u8bbf\u95ee\u7ebd\u7ea6\u7684\u5404\u4e2a\u89d2\u843d\uff0c\u53ea\u9700\u7528\u624b\u548c\u9065\u63a7\u5c31\u53ef\u4ee5\u4f53\u9a8c\u7ebd\u7ea6\u3002\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.aiitone.com/aiPlatform/newYorkStoryPolicy", "developer_terms_of_service_url": null, "publisher_name": "AIIT ONE Co.,Ltd", "support_website_url": null, "website_url": "http://www.aiitone.com/aiPlatform/newYorkStory", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EDUCATIONAL", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "481660480285508"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"