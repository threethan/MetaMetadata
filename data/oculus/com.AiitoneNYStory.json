0_AYBk0zuQkVu_5yrzOC0Bvcht86k5abcbAyFkZKJt-pujbw&oe=677D0FB8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailor cover image.png", "id": "324142412858172", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031538_324142416191505_8010635114594294827_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C60Ek8Qg2-4Q7kNvgGbFl_K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNyOmDPwzzqq-2LthBJPxu23T5mFWyxTPRdQ9lXuO46A&oe=677CFE1E"}, "display_name": "VR New York Story", "keywords": [], "long_description": "\u5982\u679c\u60a8\u60f3\u51fa\u56fd\u5b66\u4e60\u82f1\u8bed\u5374\u53c8\u56e0\u4ef7\u683c\u592a\u9ad8\u800c\u62c5\u5fc3\u5462\uff1f\n\u2192\u60a8\u53ef\u4ee5\u82b160,000\u97e9\u5143\u51fa\u56fd\uff01\u5728\u7ebd\u7ea6\u66fc\u54c8\u987f\u768450\u4e2a\u771f\u5b9e\u5730\u70b9\u65c5\u884c\u65f6\uff0c\u6709\u673a\u4f1a\u4eb2\u81ea\u8bf4\u8bdd\u548c\u5b66\u4e603800\u79cd\u8868\u8fbe\u65b9\u5f0f\uff01\n\n\u4ec5\u82f1\u8bed\u5929\u624d\uff0c\u5982\u679c\u4ec5\u5728\u5916\u56fd\u4eba\u9762\u524d\uff0c\u60a8\u53ef\u80fd\u4f1a\u72af\u9519\u3002\n\u2192\u4e0d\u7528\u62c5\u5fc3\u72af\u9519\u8bef\uff01\u8ba9\u6211\u4eec\u81ea\u4fe1\u5730\u4e0e\u5404\u79cd\u89d2\u8272\u4ea4\u8c08\uff01\n\n\u5982\u679c\u60a8\u771f\u7684\u60f3\u53bb\u7ebd\u7ea6\uff0c\u4f46\u662f\u56e0\u4e3aCovid 19\u800c\u88ab\u56f0\u5728\u5bb6\u91cc\uff1f\n\u2192\u8ba9\u6211\u4eec\u5f00\u59cbVR\u7ebd\u7ea6\u6545\u4e8b\uff0c\u9a6c\u4e0a\u53bb\u7ebd\u7ea6\uff01\u60a8\u53ea\u9700\u8981\u66f4\u957f\u7684Quest 2\uff01\n\n\u5982\u679c\u60a8\u6b63\u5728\u4e3a\u51fa\u56fd\u5de5\u4f5c\u505a\u51c6\u5907\uff0c\u90a3\u4e48\u5728\u5b9e\u9645\u7684\u4e1a\u52a1\u60c5\u51b5\u4e2d\u5c06\u4f7f\u7528\u4ec0\u4e48\u8868\u8fbe\u65b9\u5f0f\uff1f\n\u2192\u522b\u611f\u5230\u56f0\u96be\uff01\u4f7f\u7528VR\u5e76\u50cf\u5728\u771f\u5b9e\u60c5\u51b5\u4e0b\u73a9\u6e38\u620f\u4e00\u6837\u8f7b\u677e\u5b66\u4e60\uff01\n\n\n\u8fd9\u4e00\u90e8\u5206\u5305\u542b120\u5802\u8bfe\u7684\u5176\u4ed6\u6709\u8da3\u7247\u6bb5\uff0c\u60a8\u53ef\u4ee5\u5728\u5176\u4e2d\u8868\u8fbe\u65c5\u884c\uff0c\u65e5\u5e38\u751f\u6d3b\uff0c\u5de5\u4f5c\u751f\u6d3b\uff0c\u6d6a\u6f2b\u53f2\u548c\u9ad8\u96be\u5ea6\u77e5\u8bc6\uff01\n\n\u4e3b\u8981\u7279\u70b9\n\n\u2299\u4f7f\u7528\u8bed\u97f3\u8bc6\u522b\u6280\u672f\u4e0e32\u4e2a\u4e0d\u540c\u76843D\u89d2\u8272\u8fdb\u884c\u82f1\u8bed\u5bf9\u8bdd\uff01\n\u2299\u501f\u52a9\u9ad8VR\u6280\u672f\u5b9e\u73b0\u7684\u751f\u52a8\u7ebd\u7ea6\u573a\u666f\uff01\n\u2299\u6839\u636e\u7528\u6237\u5728\u6bcf\u79cd\u60c5\u51b5\u4e0b\u7684\u54cd\u5e94\uff0c\u4eba\u7269\u7684\u60c5\u7eea\uff0c\u4f7f\u7528\u60c5\u7eea\u6d4b\u91cf\u4eea\uff0c\u4eba\u7269\u7684\u60c5\u7eea\u4f1a\u66f4\u52a0\u751f\u52a8\uff01\n\u2299\u901a\u8fc7\u53ef\u4ee5\u68c0\u67e5\u53d1\u97f3\uff0c\u8bed\u6cd5\uff0c\u8bed\u8c03\u7b49\u7684\u8bc4\u4f30\u7cfb\u7edf\uff0c\u60a8\u53ef\u4ee5\u8bf4\u6b63\u786e\u7684\u82f1\u8bed\u5e76\u4e14\u8bf4\u4e00\u4e2a\u5355\u8bcd\uff01\n\u2299\u8ba9\u6211\u4eec\u4e0d\u4ec5\u5b66\u4e60\u82f1\u8bed\u4f1a\u8bdd\uff0c\u8fd8\u5b66\u4e60\u5177\u6709\u7cfb\u7edf\u6027\u6311\u6218\u7cfb\u7edf\u7684\u80cc\u666f\u77e5\u8bc6\uff01", "short_description": "VR\u7ebd\u7ea6\u6545\u4e8b\u662f\u4ee5\u7ebd\u7ea6\u4e3a\u80cc\u666f\u7684\u865a\u62df\u7a7a\u95f4\u4e2d\uff0c\u5229\u7528\u82f1\u8bed\u53e3\u8bed\u5b66\u4e60\u89e3\u51b3\u65b9\u6848\uff0c\u4e0e\u89d2\u8272\u8fdb\u884c\u751f\u52a8\u7684\u5bf9\u8bdd\u4f53\u9a8c\u7684VR\u6e38\u620f\u3002\n\u73b0\u5728\u4e0d\u8981\u518d\u4e3a\u4e86\u5b66\u4e60\u82f1\u8bed\u800c\u5728\u6d77\u5916\u7559\u5b66\u82b1\u8d39\u65f6\u95f4\u548c\u91d1\u94b1\u4e86\uff01\n\u7531\u6700\u4f73VR\u6280\u672f\u548cOculus Quest2\u652f\u6301\u7684VR New York Story\uff0c\u60a8\u53ef\u4ee5\u5728\u7ebd\u7ea6\u7684\u4efb\u4f55\u5730\u65b9\uff01\n"}, {"images": {"nodes": [{"file_name": "Square.png", "id": "1050794265409135", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035428_1050794268742468_3680544553532420616_n.