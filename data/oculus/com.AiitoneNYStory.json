tent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_709563273041315_5461420241404035025_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g5BPVXJDdt8Q7kNvgFjIRc8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3ecZ_fsMaiCV-3quUAhKGeOIoqHeu0o9_B7LY2GzWHA&oe=677D0392"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "466543267834311", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75195909_466543271167644_7584934116239430174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OMaiWQRSXxoQ7kNvgFqQD4Y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ3L5BIM7DZ8Yuk7rTqVjaAJmyUY0SIfWCKKqsko706g&oe=677CF7D0"}, "display_name": "VR New York Story", "keywords": [], "long_description": "Are you hesitating to go study abroad because you have a tight budget?\n\u2192Experience studying in America virtually only for $49.99! You will learn how to speak 3800 different expressions in English as well as enjoying on-the-spot experiences i \n\nAre you still hanging out with friends who speak the same language, while studying overseas?\n\u2192Communicate with 32 different foreign 3D characters like Sam and Barbara and become real friends!\n\nAre you too nervous to speak when you bump into foreigners, worrying that you will make a mistake?\n\u2192Don\u2019t be afraid! Practice and enjoy daily life conversations with various characters and gain confidence!\n\nAre you stuck at home wanting to travel to New York? (I do!)\n\u2192You only need a VR headset and once you make a one-time purchase of VR New York Story, we're all set. Off to New York!\n\nDive right into VR New York Story to check-out more episodes including traveling, daily life, life at work, having a relationship and more!", "short_description": "As a total solution for English Speaking Education Application, VR New York Story makes you have a conversation with Characters and develop your English speaking ability. People who want to develop their English ability are not required to spend time and money on overseas study anymore! This elaborately devised VR New York Story enables you to visit everywhere in New York and feel the atmosphere of the place with your hands and Oculus Quest2."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.aiitone.com/aiPlatform/newYorkStoryPolicy", "developer_terms_of_service_url": null, "publisher_name": "AIIT ONE Co.,Ltd", "support_website_url": null, "website_url": "http://www.aiitone.com/aiPlatform/newYorkStory", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EDUCATIONAL", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5420691651283640"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035428_1050794268742468_3680544553532420616_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ci_CE7CfehgQ7kNvgE7uRsH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKNdLhpCu-d7ca1M1faM9quVX6eOVUiEXHARhIvBOWAA&oe=677D09CE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR New York Story", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1619070671, "lastRevision": {"nodes": [{"id": "114887390595164", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4379500475397647", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "908449326638438"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "5281335118574093", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR New York Story", "keywords": [], "long_description": "VR \ub274\uc695\uc2a4\ud1a0\ub9ac\ub294 \ub274\uc695\uc744 \ubc30\uacbd\uc73c\ub85c \ud55c \uac00\uc0c1 \uacf5\uac04\uc5d0\uc11c \uc601\uc5b4 \ub9d0\ud558\uae30 \ud559\uc2b5 \uc194\ub8e8\uc158\uc744 \uc774\uc6a9\ud574 \uce90\ub9ad\ud130\ub4e4\uacfc \uc0dd\ub3d9\uac10 \ub118\uce58\ub294 \ub300\ud654 \uccb4\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \n\n\uac00\uc0c1 \ud604\uc2e4 \uc18d\uc5d0\uc11c \ub274\uc695\uc758 \uacf3\uacf3\uc744 \ubc29\ubb38\ud558\uba70, \ub3d9\uc801\uc778 \ud658\uacbd \uc18d\uc5d0\uc11c \uc6d0\ud558\ub294 \uc0c1\ud669\uc5d0\uc11c\uc758 \ubaa8\ub4e0 \ud45c\ud604\uc744 \ud559\uc2b5\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \n\n\uc6b0\ub9ac\ub294 240 \uac1c\uc758 \ud575\uc2ec \ubb38\uc7a5\uacfc 720 \uac1c\uc758 \ud575\uc2ec \ubb38\uc7a5\uc744 \ud3ec\ud568\ud55c 3,800 \uac1c\uc758 \ubb38\uc7a5\uacfc \uc0ac\uc6a9\uc790\uc758 \uc601\uc5b4 \ub2a5\ub825\uc744 \ud3c9\uac00\ud560 \uc218 \uc788\ub294 \uc74c\uc131 \uc778\uc2dd \uae30\uc220\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \uccab \ubc88\uc9f8 \uc2dc\ub9ac\uc988\ub294 60\uac1c \uac15\uc758\ub85c \uc774\ub8e8\uc5b4\uc838 \uc788\uace0, \uc21c\ucc28\uc801\uc73c\ub85c \ub098\uba38\uc9c0 240 \uac15\uc758\ub97c \ucd9c\uc2dc \ud560 \uacc4\ud68d\uc774\ub2c8, \uc55e\uc73c\ub85c \ub098\uc62c \uc2dc\ub9ac\uc988\ub3c4 \ub193\uce58\uc9c0 \ub9c8\uc138\uc694!\n", "short_description": "VR \ub274\uc695\uc2a4\ud1a0\ub9ac\ub294 \ub274\uc695\uc744 \ubc30\uacbd\uc73c\ub85c \ud55c \uac00\uc0c1 \uacf5\uac04\uc5d0\uc11c \uc601\uc5b4 \ub9d0\ud558\uae30 \ud559\uc2b5 \uc194\ub8e8\uc158\uc744 \uc774\uc6a9\ud574 \uce90\ub9ad\ud130\ub4e4\uacfc \uc0dd\ub3d9\uac10 \ub118\uce58\ub294 \ub300\ud654 \uccb4\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \uc774\uc81c \ub354 \uc774\uc0c1 \uc601\uc5b4 \uacf5\ubd80\ub97c \uc704\ud574 \ud574\uc678 \uc720\ud559\uc5d0 \uc2dc\uac04\uacfc \ub3c8\uc744 \ub4e4\uc774\uc9c0 \ub9c8\uc138\uc694! \uc815\uad50\ud558\uac8c \uace0\uc548\ub41c VR \uac8c\uc784\uc744 \ud1b5\ud574 \ub274\uc695\uc758 \uacf3\uacf3\uc744 \ubc29\ubb38\ud558\uace0 \ub2f9\uc2e0\uc758 \uc190\uacfc \ucee8\ud2b8\ub864\ub7ec\ub9cc\uc73c\ub85c \ub274\uc695\uc744 \uccb4\ud5d8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n"}, {"images": {"nodes": [{"file_name": "Square.png", "id": "1050794265409135", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035428_1050794268742468_3680544553532420616_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ci_CE7CfehgQ7kNvgE7uRsH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDswfFPAt8iCrPIjUYR3XQerjTuoe_qlELW0VxPpFahbg&oe=677D09CE"}, {"file_name": "Portrait.png", "id": "476756833501511", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982622_476756836834844_2861411570546577743_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CKjM33bjwWMQ7kNvgFBHK-y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0EgFEtYr-mAyx3jBlLtq_QwKgq-gRV4PgRk8Fe-RRRw&oe=677CFB5C"}, {"file_name": "Mini Landscape.png", "id": "452754142581166", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036605_452754145914499_3196844746571875619_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6akFy6brDHoQ7kNvgGWY2nx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD94rNJ5jOOk3CJJWHRKg7DgGR5pElqW58YForj1EGP6w&oe=677D0ADC"}, {"file_name": "Mobile_Icon.png", "