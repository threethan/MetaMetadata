"Portrait.png", "id": "227372566184625", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974638_227372569517958_5031428201847665160_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8MYbYkLEMo8Q7kNvgHj6nWn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXP9rCA3Pvaz6wW2IF0LFIiyRCW1M7gPDYQL575DtKgg&oe=677D1878"}]}, "id": "524738838963133", "locale": "ko_KR", "screenshots": [{"file_name": "\uc2a4\ud06c\ub9b0\uc0f7 (4).png", "id": "3112470322413126", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974849_3112470325746459_8212762868385227522_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=26umA0XbrB4Q7kNvgHBaKmF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDoFiYYe5zv3CaFcG1xIFr-ed-cyTCwS8DL4ssBpruTmg&oe=677D0E67"}, {"file_name": "\uc2a4\ud06c\ub9b0\uc0f7 (2).png", "id": "611121750076818", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974644_611121753410151_3114577759999104114_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zfy1YwK2pqYQ7kNvgG18hxZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCe2H5gb6Luq_Sv_34vbGmnM7NCWAd2pVCz5lXp6NohA&oe=677D09FB"}, {"file_name": "\uc2a4\ud06c\ub9b0\uc0f7 (1).png", "id": "487954732593232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035355_487954735926565_3352121502077569904_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c1fE4K8UKMYQ7kNvgFHjp4N&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrks53dCvbq0TbbEO2QGXcSkSkMJ8ES9eoc6B05umfxQ&oe=677D0B86"}, {"file_name": "\uc2a4\ud06c\ub9b0\uc0f7 (3).png", "id": "2130505190436967", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974644_2130505193770300_7420884189501479304_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LnToL8OI0WcQ7kNvgHmlzaO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKAKD35h5NJyshxKDwaEmfwq1hKNcjxVCGzi3fJvv9VA&oe=677D0361"}, {"file_name": "\uc2a4\ud06c\ub9b0\uc0f7 (5).png", "id": "432768858341205", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974696_432768861674538_4066107163896917381_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qBLa0D5StMMQ7kNvgEdnFJD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfKQ-9o2q1hF303Tc0rP16kjvF2JJM6Iw2xZFAgEKP3A&oe=677D2282"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailor cover image.png", "id": "1135802447206831", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982450_1135802450540164_8243461477477475291_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CqY0iYguWKkQ7kNvgGo1HVT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAPeDM5lO4TzJkxO4awe8m7henTe7mKMJWvxo6DQETsA&oe=677D01BB"}, "display_name": "VR \ub274\uc695\uc2a4\ud1a0\ub9ac", "keywords": [], "long_description": "\uc601\uc5b4 \ubc30\uc6b0\ub7ec \ud574\uc678\uc5f0\uc218 \uac00\uace0 \uc2f6\uc740\ub370 \ub108\ubb34 \ube44\uc2f8\uc11c \uace0\ubbfc \uc911\uc774\ub77c\uba74? \n\u2192$59.99\ub85c \ud574\uc678\uc5f0\uc218 \uac08 \uc218 \uc788\ub2e4! \ub274\uc695 \ub9e8\ud558\ud0c4\uc758 50\uac1c \uc2e4\uc81c \uc7a5\uc18c\ub97c \ub204\ube44\uba70, 3800\uac1c \ud45c\ud604\uc744 \uc9c1\uc811 \ub9d0\ud558\uace0 \ubc30\uc6b8 \uc218 \uc788\ub294 \ucc2c\uc2a4! \n\n\ube44\uc2fc \ub3c8 \uc8fc\uace0 \ud574\uc678\uc5f0\uc218 \uac14\ub294\ub370, \uc5b8\uc81c\uae4c\uc9c0 \ubbfc\uc218\u2026\uc601\ud76c\u2026\ub791\ub9cc \ub180\uac70\ub2c8..? \n\u2192Vanessa, Peter \uac19\uc740 32\uac1c\uc758 3D \uc678\uad6d\uc778 \uce90\ub9ad\ud130\ub4e4\uacfc \uc601\uc5b4\ub85c \ub300\ud654\ud558\uba70 \uc9c4\uc9dc \uce5c\uad6c\uac00 \ub418\uc790! \n\n\ud63c\uc790\uc11c\ub294 \uc601\uc5b4\ucc9c\uc7ac, \uc815\uc791 \uc678\uad6d\uc778 \uc55e\uc5d0\ub9cc \uc11c\uba74 \uc2e4\uc218\ud560 \uae4c\ubd10 \uc9c4\ub540\ub9cc \ubed8\ubed8, \ud55c\ub9c8\ub514\ub3c4 \ubabb\ud55c\ub2e4\uba74? \n\u2192\uc2e4\uc218\uc5d0 \ub300\ud55c \ub450\ub824\uc6c0\uc740 No! \ub2e4\uc591\ud55c \uce90\ub9ad\ud130\ub4e4\uacfc \ud568\uaed8 \uc790\uc2e0\uac10 \uc788\uac8c \ub300\ud654 \ub098\ub204\uc790! \n\n\ucf54\ub85c\ub098 \ub54c\ubb38\uc5d0 \uaf3c\uc9dd \ubabb\ud558\ub294 \ub2f9\uc2e0, \ub274\uc695\uc5ec\ud589 \uac00\uace0 \uc2f6\ub2e4\uba74? \n\u2192VR \ub274\uc695\uc2a4\ud1a0\ub9ac & Oculus Quest 2 \ub9cc \uc788\ub2e4\uba74 \uc9c0\uae08 \ub2f9\uc7a5 OK! \n\n\ud574\uc678 \ucde8\uc5c5\uc744 \uc900\ube44\ud558\ub294 \ub2f9\uc2e0, \uc2e4\uc81c \ube44\uc988\ub2c8\uc2a4 \uc0c1\ud669\uc5d0\uc11c \uc5b4\ub5a4 \ud45c\ud604\uc774 \uc4f0\uc77c\uae4c \uace0\ubbfc\uc774\ub77c\uba74? \n\u2192\uc5b4\ub835\uac8c \uc0dd\uac01\ud558\uc9c0 \ub9d0\uc790! VR \uc4f0\uace0 \uc2e4\uc81c \uc0c1\ud669\uc5d0\uc11c \uac8c\uc784\ud558\ub4ef \uc27d\uac8c \ubc30\uc6b0\uc790! \n\n Main Episode \n\n\u2299\uc2ec\uc0ac\uad00 Sean\ud55c\ud14c \uc785\uad6d \uc2ec\uc0ac \ud1b5\uacfc\ud558\uae30 \n\u2299\uce5c\uad6c Mark\ub791 \uc2dd\ub2f9\uc5d0\uc11c \uc2a4\ud14c\uc774\ud06c \uc8fc\ubb38\ud558\uae30 \n\u2299\uc740\ud589\uc6d0 Anthony\ud55c\ud14c \uc740\ud589\uacc4\uc88c \uc2e0\uccad\ud558\uae30 \n\u2299\ub8f8\uba54\uc774\ud2b8 Jimmy\uc640 \ud074\ub7fd \uac00\uae30 \n\u2299Wolfgang\uacfc \uc2a4\ud130\ub514 \uc77c\uc815 \uc870\uc815\ud558\uae30 \n\u2299\ub3c4\uc11c\uad00\uc5d0\uc11c \uc0ac\uc11c Bill\ud55c\ud14c \ucc45 \ub300\ucd9c\ud558\uae30 \n\u2299\uc9c1\uc7a5\uc0c1\uc0ac Jenifer\uc640 \uc5c5\ubb34 \uc791\uc5c5\uae30\ud55c \uc560\uae30\ud558\uae30 \n\n\uadf8 \ubc16\uc5d0 \uc5ec\ud589, \uc77c\uc0c1, \uc9c1\uc7a5\uc0dd\ud65c, \uc5f0\uc560, \uace0\ub09c\uc774\ub3c4 \ud45c\ud604\uc744 \ud560 \uc218 \uc788\ub294 120\uac15\uc758 \uc7ac\ubc0c\ub294 \uc5d0\ud53c\uc18c\ub4dc\ub294 \ubcf8 \ud3b8\uc5d0\uc11c \ud655\uc778\ud558\uc138\uc694!! \n\n Key Features \n\n\u2299\uc74c\uc131\uc778\uc2dd \uae30\uc220\uc744 \uc0ac\uc6a9\ud558\uc5ec 32 \uac1c\uc758 \uc11c\ub85c \ub2e4\ub978 3D \uce90\ub9ad\ud130\uc640 \uc601\uc5b4\ub85c \ub300\ud654\ud558\uae30! \n\u2299\ub192\uc740 VR \uae30\uc220\ub85c \uad6c\ud604\ub41c \uc0dd\uc0dd\ud55c \ub274\uc695\uc758 \ud604\uc7a5! \n\u2299\uc0c1\ud669 \ubcc4 \uc0ac\uc6a9\uc790\uc758 \ub300\ub2f5\uc5d0 \ub530\ub978 \uce90\ub9ad\ud130\uc758 \uac10\uc815\uc744 Emotion meter\ub85c \ub098\ud0c0\ub0b4 \ub354\uc6b1 \ub354 \uc0dd\ub3d9\uac10 \uc788\uac8c! \n\u2299\ubc1c\uc74c, \ubb38\ubc95, \uc5b5\uc591 \ub4f1 \uccb4\ud06c\ud560 \uc218 \uc788\ub294 \ud3c9\uac00\uc2dc\uc2a4\ud15c\uc744 \ud1b5\ud574 \uc815\ud655\ud55c \uc601\uc5b4\ub97c \uad6c\uc0ac\ud558\uc790! \n\u2299\uccb4\uacc4\uc801\uc778 \ucc4c\ub9b0\uc9c0 \uc2dc\uc2a4\ud15c\uc73c\ub85c \uc601\uc5b4\ud68c\ud654\ubfd0\ub9cc \uc544\ub2c8\ub77c, \ubc30\uacbd\uc9c0\uc2dd\uae4c\uc9c0 \uacf5\ubd80\ud558\uc790!  ", "short_description": "VR \ub274\uc695\uc2a4\ud1a0\ub9ac\ub294 \ub274\uc695\uc744 \ubc30\uacbd\uc73c\ub85c \ud55c \uac00\uc0c1 \uacf5\uac04\uc5d0\uc11c \uc601\uc5b4 \ub9d0\ud558\uae30 \ud559\uc2b5 \uc194\ub8e8\uc158\uc744 \uc774\uc6a9\ud574 \uce90\ub9ad\ud130\ub4e4\uacfc \uc0dd\ub3d9\uac10 \ub118\uce58\ub294 \ub300\ud654 \uccb4\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 VR \uc571\uc785\ub2c8\ub2e4. \uc774\uc81c \ub354 \uc774\uc0c1 \uc601\uc5b4 \uacf5\ubd80\ub97c \uc704\ud574 \ud574\uc678 \uc720\ud559\uc5d0 \uc2dc\uac04\uacfc \ub3c8\uc744 \ub4e4\uc774\uc9c0 \ub9c8\uc138\uc694! \ucd5c\uace0\uc758 VR \uae30\uc220\ub85c \uad6c\ud604\ub41c VR \ub274\uc695\uc2a4\ud1a0\ub9ac,\uadf8\ub9ac\uace0 Oculus Quest2\uc640 \ud568\uaed8 \ub77c\uba74 \ub274\uc695\uc758 \uc5b4\ub514\ub4e0 \uac08 \uc218 \uc788\uc2b5\ub2c8\ub2e4!\n"}, {"images": {"nodes": [{"file_name": "Portrait.png", "id": "1288183764979753", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974696_1288183768313086_6311173737458031570_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FxndhGKM8bgQ7kNvgGhdVq7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDylUtI2WfTGJLvx9xKXeYfAD3JCchEqiNSRD7p7qMi0w&oe=677D03D6"}, {"file_name": "Landscape.png", "id": "1223288898162147", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-2