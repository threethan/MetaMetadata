ng level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nivision.org/x-booster-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": "https://www.nivision.org/x-booster-eula?lang=pl", "website_url": "https://www.nivision.org/x-booster?lang=pl", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "915122435859818"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1517479568859688"}, {"status": "PUBLISHED", "id": "1709167246494746"}, {"status": "PUBLISHED", "id": "6440456442662044"}, {"status": "PUBLISHED", "id": "2652689221694735"}, {"status": "PUBLISHED", "id": "2532733260369391"}]}, "baseline_offer": {"id": "1709167246494746"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1517479568859688"}]}, "liveChannel": {"nodes": [{"latest_supported_