_name": "new_portrait.png", "id": "733412800948928", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_733412810948927_6998670201117516268_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cXv6iVXgYlkQ7kNvgFpMAp6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeLU70STITvul7pwnQQnBKxVHRzVzeZdbzlX6zW0RuEA&oe=66FE7A19"}, {"file_name": "new_square.png", "id": "604863244128137", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_604863250794803_3845454927555917912_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OBqI9zcbNgcQ7kNvgGc9kX0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHMsgJ70rHHV2Ay4oJZVcqrODZNYcGvhF0MRpeDnuCbg&oe=66FE7DCF"}, {"file_name": "fitness_logo_2.png", "id": "434201601621089", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_434201604954422_4478548741147130320_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQATag-W_7AQ7kNvgH3WMnF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEV19C9VeVF3EiB0DeUhCMGMyI2ihNWJ8M1Iqdbp4lUA&oe=66FE6E75"}, {"file_name": "hero_cover.png", "id": "406461097613203", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974745_406461100946536_8230944501691580488_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U4HnewHmgBEQ7kNvgHcIaSB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrY28HphRQejVbgHVH-hXRPKy_S0jQdRXkO4DAiv0jSQ&oe=66FE774B"}]}, "id": "26709061345351927", "locale": "en_US", "screenshots": [{"file_name": "x-booster_002.png", "id": "6376184232406966", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974705_6376184235740299_3653200258853421552_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_LVFYt_oXFkQ7kNvgFBaF3V&_nc_ht=scontent.oculuscdn.com&oh=00_AYDefY8AAJmP8BwyDLX35l81kfipyVARgNwcE-z5PF37aw&oe=66FE76BE"}, {"file_name": "x-booster_001.png", "id": "500691601160723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_500691604494056_4523823600094580026_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxAGJYR1VsMQ7kNvgGGyXUu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvKfiQ4PPgJ4PJO5WByCt2DozCyYvyNGwTEm3JQCruyA&oe=66FE8BED"}, {"file_name": "scr_16.png", "id": "437744274315635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036613_437744277648968_5520262405081187381_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mrQmmBhg0WwQ7kNvgG33x90&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFf9G3tS57gVcYul3K0IxhBCN4RQfxluk-6AXZx0NmKg&oe=66FE9462"}, {"file_name": "new_arena_2.png", "id": "292676427146092", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982448_292676430479425_2235918166081777569_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RmIyICQYkHsQ7kNvgGKIXXK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBH2YywWcZk0i6O2982IasHqkrV9-FHB-PwGvubuFjTgg&oe=66FE8A1F"}, {"file_name": "scr_2.png", "id": "256137685871429", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_256137689204762_140882877740874286_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=scToIsgr_E0Q7kNvgH4IjCj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQTMTbsaDlRSHM35hVRb-ml0uJ2rOw0Nb0fsrmeZ6Fpw&oe=66FE9823"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "splash.png", "id": "234827682049961", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_234827685383294_2291046045821978373_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CX2NcY4GchQQ7kNvgErEFQg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAipx95bl9QQI2tMrNIFcOYzE4BiqK2lU8mPCUAHPOQyQ&oe=66FE8980"}, "display_name": "X-Fitness", "keywords": ["fitness", "music", "workout", "mp3", "fun"], "long_description": "Level up your fitness game with **X-Fitness**, the ultimate VR full-body workout that makes getting in shape an exhilarating adventure!\n# Why Choose X-Fitness?\n- **Burn Calories in a Fun Way:** Turn your workouts into a calorie-burning experience that feels more like a game.\n- **Hit the Beat:** Punch targets in time with the music! Choose from our original tracks or add your own MP3s and train to your favorite tunes.\n- **Dynamic and Varied Moves:** Keep things fresh and exciting with a variety of moves such as striking, punching, cutting, blocking, avoiding, and dodging.\n- **Full-Body Engagement:** Engage your entire body in the virtual arena for a comprehensive workout.\n- **Precision and Timing:** Improve your precision and timing to achieve higher scores and climb the leaderboards.\n- **Customizable Experience:** Adjust the intensity to match your fitness level, from warm-ups to intense challenges, or create your own workout routine.\n# Features:\n- **Music Integration:** Enjoy your workout with our handcrafted tracks or your own music.\n- **Virtual Arena:** Step into the arena and perform a wide range of movements to stay fit.\n- **Fun and Engaging:** Stay motivated with varied moves and exciting challenges.\n- **Track Your Progress:** Monitor your performance with detailed stats and compete on the leaderboards for the top spot.\n# Get Started Today!\nMake your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with **X-Fitness!**", "short_description": "Make your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with X-Fitness!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/x-fitness-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://www.facebook.com/groups/xboostercommunity", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "MUSIC", "SPORTS"], "