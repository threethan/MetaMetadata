scdn.com&oh=00_AYAyRAjaqqjrELy50O0kI4fGHqQ-ZSevf0dS0Gb-answdA&oe=674C60A3"}, {"file_name": "scr_7.png", "id": "3216811178420389", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001675_3216811188420388_8925977417708828380_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wFo6jhmV5tgQ7kNvgEO4OIK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATdR68cTDj0Ho2b5BaIRdqXSl7fRYgCPBH_NnEHJoQJw&oe=674C4AC3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus_2560_1440.png", "id": "759002318358787", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974503_759002321692120_5431871159328002558_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mh7isy7i6f8Q7kNvgGJjugQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5FvVYa_AMXWbbpSLH_DB5_eDMu4Cjqt6Wx6AfhTgKnQ&oe=674C67AF"}, "display_name": "X-BOOSTER", "keywords": [], "long_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-BOOSTER supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and 