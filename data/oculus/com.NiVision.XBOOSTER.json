=6e7a0a&_nc_ohc=H7QtWq8Wki4Q7kNvgEJyCZL&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDxjRrYPaCzS9arMcckbDFF5KVWaKEyZco4M3kUVuirxQ&oe=677BB53E"}, {"file_name": "x-booster_001.png", "id": "500691601160723", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982471_500691604494056_4523823600094580026_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r3dkAn8nbqEQ7kNvgFPfilm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDJQn9L5pr7YajyG90g1W_QgSfbmPk3eUqvFncsrAB_4g&oe=677BCA6D"}, {"file_name": "scr_16.png", "id": "437744274315635", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036613_437744277648968_5520262405081187381_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJCWMPHIoWcQ7kNvgEZEadB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYARKY3cI_rnWt9qoT6-U4L10-IhG1ZDsSVTEzhPC3tvGQ&oe=677BD2E2"}, {"file_name": "new_arena_2.png", "id": "292676427146092", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982448_292676430479425_2235918166081777569_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HNR_gXlZfCYQ7kNvgFmjbE4&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDmWgK3KUVen9TgoUCn0TjhJ0vD53dfbmoAI2aADVJ8wg&oe=677BC89F"}, {"file_name": "scr_2.png", "id": "256137685871429", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003274_256137689204762_140882877740874286_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CsnECGDTqCQQ7kNvgHJ0vng&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDYMvEnfYJfeA0wrKYuE4WzRAE_zm4M-bojfgKWsFUU1A&oe=677BD6A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "splash.png", "id": "234827682049961", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031400_234827685383294_2291046045821978373_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elAUhFf8PSsQ7kNvgG2oh75&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC74xfXIoHWHXZTD1LoSxp3J9UTx0NW97p-mfGk_UPc7w&oe=677BC800"}, "display_name": "X-Fitness", "keywords": ["fitness", "music", "workout", "mp3", "fun"], "long_description": "Level up your fitness game with **X-Fitness**, the ultimate VR full-body workout that makes getting in shape an exhilarating adventure!\n# Why Choose X-Fitness?\n- **Burn Calories in a Fun Way:** Turn your workouts into a calorie-burning experience that feels more like a game.\n- **Hit the Beat:** Punch targets in time with the music! Choose from our original tracks or add your own MP3s and train to your favorite tunes.\n- **Dynamic and Varied Moves:** Keep things fresh and exciting with a variety of moves such as striking, punching, cutting, blocking, avoiding, and dodging.\n- **Full-Body Engagement:** Engage your entire body in the virtual arena for a comprehensive workout.\n- **Precision and Timing:** Improve your precision and timing to achieve higher scores and climb the leaderboards.\n- **Customizable Experience:** Adjust the intensity to match your fitness level, from warm-ups to intense challenges, or create your own workout routine.\n# Features:\n- **Music Integration:** Enjoy your workout with our handcrafted tracks or your own music.\n- **Virtual Arena:** Step into the arena and perform a wide range of movements to stay fit.\n- **Fun and Engaging:** Stay motivated with varied moves and exciting challenges.\n- **Track Your Progress:** Monitor your performance with detailed stats and compete on the leaderboards for the top spot.\n# Get Started Today!\nMake your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with **X-Fitness!**", "short_description": "Make your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with X-Fitness!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/x-fitness-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null,