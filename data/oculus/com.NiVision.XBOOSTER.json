=6e7a0a&_nc_ohc=b9HHtgx46xwQ7kNvgGGarh-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmjUX0OlmdzTTRDN3bgvBFDtqMnlbL4FHahSIT6XX_og&oe=674EE23E"}, {"file_name": "x-booster_001.png", "id": "500691601160723", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982471_500691604494056_4523823600094580026_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbzuVGYzYOgQ7kNvgHR3b6J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwsu3wMPSUlrxcSy5rVlbidTU3zdQ_-nD6kXm9duOwOg&oe=674EF76D"}, {"file_name": "scr_16.png", "id": "437744274315635", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036613_437744277648968_5520262405081187381_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LG5EKN31PSAQ7kNvgHxyZQs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdaIhIs-kmYPRUrCMwOxvmX9_Xpqa8VpREvEJ6TxfdEg&oe=674EFFE2"}, {"file_name": "new_arena_2.png", "id": "292676427146092", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982448_292676430479425_2235918166081777569_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hO2d3m-bFkcQ7kNvgGhdemM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRbly0Z8N4x8iwPwW4UDwIG-NSSncAde8nrQMn-xAmUg&oe=674EF59F"}, {"file_name": "scr_2.png", "id": "256137685871429", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003274_256137689204762_140882877740874286_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I2oT3GSwFioQ7kNvgHnw6MU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBVndHIo8u98WbshWImozTJgo4vOhuWmDgsYk4-9s0u5w&oe=674F03A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "splash.png", "id": "234827682049961", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031400_234827685383294_2291046045821978373_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A1adh0rzLm8Q7kNvgEbRaDv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADGlPEtGUzfb_FFPCVtuKKrH23PlSQbbe4NNumRni3IQ&oe=674EF500"}, "display_name": "X-Fitness", "keywords": ["fitness", "music", "workout", "mp3", "fun"], "long_description": "Level up your fitness game with **X-Fitness**, the ultimate VR full-body workout that makes getting in shape an exhilarating adventure!\n# Why Choose X-Fitness?\n- **Burn Calories in a Fun Way:** Turn your workouts into a calorie-burning experience that feels more like a game.\n- **Hit the Beat:** Punch targets in time with the music! Choose from our original tracks or add your own MP3s and train to your favorite tunes.\n- **Dynamic and Varied Moves:** Keep things fresh and exciting with a variety of moves such as striking, punching, cutting, blocking, avoiding, and dodging.\n- **Full-Body Engagement:** Engage your entire body in the virtual arena for a comprehensive workout.\n- **Precision and Timing:** Improve your precision and timing to achieve higher scores and climb the leaderboards.\n- **Customizable Experience:** Adjust the intensity to match your fitness level, from warm-ups to intense challenges, or create your own workout routine.\n# Features:\n- **Music Integration:** Enjoy your workout with our handcrafted tracks or your own music.\n- **Virtual Arena:** Step into the arena and perform a wide range of movements to stay fit.\n- **Fun and Engaging:** Stay motivated with varied moves and exciting challenges.\n- **Track Your Progress:** Monitor your performance with detailed stats and compete on the leaderboards for the top spot.\n# Get Started Today!\nMake your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with **X-Fitness!**", "short_description": "Make your workouts more enjoyable and effective than ever before. Put on your VR headset, start moving to the beat, and get fit while having fun with X-Fitness!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/x-fitness-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null,