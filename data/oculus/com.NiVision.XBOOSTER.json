&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CsnECGDTqCQQ7kNvgHJ0vng&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDYMvEnfYJfeA0wrKYuE4WzRAE_zm4M-bojfgKWsFUU1A&oe=677BD6A3"}, {"file_name": "scr_7.png", "id": "3216811178420389", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001675_3216811188420388_8925977417708828380_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WZoALB6UE74Q7kNvgEz7J_x&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDUXeIgQ6DCsZJCSS4WyRra6joqyu9D68X7HY5XhGt4sA&oe=677BC0C3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus_2560_1440.png", "id": "759002318358787", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974503_759002321692120_5431871159328002558_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UglqGCmFiGUQ7kNvgGzILoR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBApOhx5CY795nzA85Tqh57IHgB1Buo6MdoNVtJQ8RqYQ&oe=677BA56F"}, "display_name": "X-BOOSTER", "keywords": [], "long_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-BOOSTER supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nivision.org/x-booster-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": "https://www.nivision.org/x-booster-eula?lang=pl", "website_url": "https://www.nivision.org/x-booster?lang=pl", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "MUSIC", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "915122435859818"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "546282028008838"}, {"status": "PUBLISHED", "id": "1021325216406735"}, {"status": "PUBLISHED", "id": "1517479568859688"}, {"status": "PUBLISHED", "id": "1709167246494746"}, {"status": "PUBLISHED", "id": "6440456442662044"}, {"status": "PUBLISHED", "id": "2652689221694735"}, {"status": "PUBLISHED", "id": "2532733260369391"}]}, "baseline_offer": {"id": "1021325216406735"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "546282028008838"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8631704636939144", "version": "4.51"}, "id": "163756812218079", "channel_