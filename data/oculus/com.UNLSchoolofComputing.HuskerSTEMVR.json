1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cC8IVqrIWNAQ7kNvgEILYKl&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCJQRudyY1u-utmnGJl5aKI-lvC_oMypYVEQtSNpEGwCA&oe=675ECF49"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_first_frame.png", "id": "682082493293051", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39035301_682082496626384_1269824762140296970_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WQS6Iyvmr4kQ7kNvgFDSzV2&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDQmJps3wG0ZHbwqVYucnz4wrR-gV13bEVADt9hmvMzkw&oe=675ECE4F"}, "display_name": "Husker STEM VR", "keywords": [], "long_description": "The Husker STEM VR project is an outreach/recruitment app being built for the Oculus Quest, iOS, Android, and Web App to creating a fun and engaging learning environment. Students are building a virtual reality Oculus Quest app for UNL's School of Computing and College of Engineering to encourage STEM outreach. This app will help to make learning fun by creating a virtual reality app designed to create an engaging learning environment. Additionally, we can promote more diversity in STEM by creating an educational environment that promotes inclusiveness.\nSTEM Activities:\n- Computer Science\n- Computer Engineering\n- Software Engineering\n- Electrical Engineering\n- Chemical Engineering\n- Mechanical Engineering \n- Civil Engineering\n- Biological Systems Engineering\nFor more information:\nhttps:// www.huskerstemvr.com ", "short_description": "Learn about STEM majors at the University of Nebraska - Lincoln through a fun, interactive experience! The Husker STEM VR project is an outreach/recruitment app built for the Oculus Quest, iOS, Android, and Web App to creating a fun and engaging learning environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.huskerstemvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "University of Nebraska - Lincoln School of Computing", "support_