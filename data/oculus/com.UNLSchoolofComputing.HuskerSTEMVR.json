t.oculuscdn.com/v/t64.5771-25/38974762_1148450535787050_2741192875807970363_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3KATUAWPSnIQ7kNvgG0byB-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAJfVV-bjfxr5oDDSv95Uu7&oh=00_AYBMXPYO8Tsos5dk5TIgC6PH86eUf8aQTv4SiMVulaVqFg&oe=66F405C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_first_frame.png", "id": "682082493293051", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035301_682082496626384_1269824762140296970_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D8qUFmlgPPcQ7kNvgEOVksd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAJfVV-bjfxr5oDDSv95Uu7&oh=00_AYB8EcfG24nLQc4CkhMD1zhg6htODxjaf7sddeE_MA1kAA&oe=66F404CF"}, "display_name": "Husker STEM VR", "keywords": [], "long_description": "The Husker STEM VR project is an outreach/recruitment app being built for the Oculus Quest, iOS, Android, and Web App to creating a fun and engaging learning environment. Students are building a virtual reality Oculus Quest app for UNL's School of Computing and College of Engineering to encourage STEM outreach. This app will help to make learning fun by creating a virtual reality app designed to create an engaging learning environment. Additionally, we can promote more diversity in STEM by creating an educational environment that promotes inclusiveness.\nSTEM Activities:\n- Computer Science\n- Computer Engineering\n- Software Engineering\n- Electrical Engineering\n- Chemical Engineering\n- Mechanical Engineering \n- Civil Engineering\n- Biological Systems Engineering\nFor more information:\nhttps:// www.huskerstemvr.com ", "short_description": "Learn about STEM majors at the University of Nebraska - Lincoln through a fun, interactive experience! The Husker STEM VR project is an outreach/recruitment app built for the Oculus Quest, iOS, Android, and Web App to creating a fun and engaging learning environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.huskerstemvr.com/privacy", "devel