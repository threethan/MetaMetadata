w&oe=66F29E36"}, {"file_name": "VRChemLabScreenshot4.png", "id": "338842120931038", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569453_338842124264371_1271572442538917737_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6F13CPJjYeEQ7kNvgHwXBbY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJ1PfyTlGcxYuMYWEhhqkD&oh=00_AYBk06PA3nHgGaU810-48MCjxc-y8HC_rW9DUlmmDX3c7g&oe=66F288A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videoThumb1.png", "id": "4602314206561808", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340712_4602314209895141_4225900787876836247_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mzQfzkbSp74Q7kNvgHm8sJA&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJ1PfyTlGcxYuMYWEhhqkD&oh=00_AYBqNrpj-W0c9e2cownEge1F_X9tH05lhWJsSTV1CQpaiw&oe=66F2A0E5"}, "display_name": "The VR Chemistry Lab", "keywords": [], "long_description": "The VR Chemistry Lab was originally designed to be a research tool where studies of VR learning environments could be explored. Currently, it is still being used in research but has potential for student use as a hands-on science lab experience at home or at school. It also contains experiences where players can explore molecule creation in an immersive environment as well as play a game of catalyzing a chemical reaction. \n\nThis is still a work in progress and there are many possibilities with its potential for education. Any encouragement, advice, and support is much appreciated. For more details, pictures, etc. please go to https://virtualrealityforeducation.com/the-vr-chemistry-lab-is-now-on-the-oculus-app-lab/\n\nCreator: Elliot Hu-Au", "short_description": "The VR Chemistry Lab is a simulation of a typical school chemistry laboratory and an immersive experience where players can zoom down to the size of molecules."}]}, "developer_name": null, "developer_privacy_policy_url": "http://virtualrealityforeducation.com/the-vr-chemistry-lab-privacy-policy/", "developer_terms_of_service_url": null, "publisher_n