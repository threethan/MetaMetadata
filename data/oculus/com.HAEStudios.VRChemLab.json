1.oculuscdn.com&oh=00_AYC0Q9LW75Tt7uOlQgnPeh1O4SvTQuz6wjfgUuZQHR7rnQ&oe=675D661F"}, {"file_name": "VRChemLabScreenshot5.png", "id": "4063439060362216", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974693_4063439067028882_1925107953584439780_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Q08OYXvvZQQ7kNvgGh_dJV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBm9uGsMk0ZURd-3JyKZwlAd6lfyIWZk8lKfsslbiepJQ&oe=675D81F8"}, {"file_name": "VRChemLabScreenshot3.png", "id": "920482272127955", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036661_920482278794621_1432969144147325397_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fMwCaCfTFAwQ7kNvgHGYDzC&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC8K8Ch3yK_IbGUz8SPLsRAk3lffnVSziaYrb1ZjDXG5Q&oe=675D67B6"}, {"file_name": "VRChemLabScreenshot4.png", "id": "338842120931038", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57569453_338842124264371_1271572442538917737_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_LEjRJZmPZEQ7kNvgE_OkYu&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC5rQPThe4Viber4-bGSMi2UQ721JmotFKXXlbe1DbCNQ&oe=675D8A67"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The VR Chemistry Lab", "keywords": [], "long_description": "The VR Chemistry Lab was originally designed to be a research tool where studies of VR learning environments could be explored. Currently, it is still being used in research but has potential for student use as a hands-on science lab experience at home or at school. It also contains experiences where players can explore molecule creation in an immersive environment as well as play a game of catalyzing a chemical reaction. \n\nThis is still a work in progress and there are many possibilities with its potential for education. Any encouragement, advice, and support is much appreciated.\n\nCreator: Elliot Hu-Au", "short_description": "The VR Chemistry Lab is designed to be a VR simulation of a typical school chemistry laboratory and an immersive experience where players can zoom down to the size of molecules."}]}, "developer_name": null, "developer_privacy_policy_url": "http://virtualrealityforeducation.com/the-vr-chemistry-lab-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HAE Studios", "support_website_url": null, "website_url": "https://virtualrealityforeducation.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "973046940257784"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1786222811730218"}, {"status": "PUBLISHED", "id": "615995253191797"}]}, "baseline_offer": {"id": "615995253191797"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1637120340, "status": "PUBLISHED", "id": "1786222811730218"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6205514552829190", "version": "0.9.8"}, "id": "1512432792443944", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3919613214752680", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6205514552829190"}, "re