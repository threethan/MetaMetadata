/scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569453_338842124264371_1271572442538917737_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Faxoufmvh5AQ7kNvgGDT6Iu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSZ1IXlIv_Xu_fcihOUKIeESriN1aEbfezC97HBAnAVw&oe=67386827"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videoThumb1.png", "id": "4602314206561808", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340712_4602314209895141_4225900787876836247_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jUCkee-k7LgQ7kNvgHy1WB8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJbcvcXzw7Zg9nMHXcvDOLSlQLaWEooS9aE9jjWYtbRg&oe=67388065"}, "display_name": "The VR Chemistry Lab", "keywords": [], "long_description": "The VR Chemistry Lab was originally designed to be a research tool where studies of VR learning environments could be explored. Currently, it is still being used in research but has potential for student use as a hands-on science lab experience at home or at school. It also contains experiences where players can explore molecule creation in an immersive environment as well as play a game of catalyzing a chemical reaction. \n\nThis is still a work in progress and there are many possibilities with its potential for education. Any encouragement, advice, and support is much appreciated. For more details, pictures, etc. please go to https://virtualrealityforeducation.com/the-vr-chemistry-lab-is-now-on-the-oculus-app-lab/\n\nCreator: Elliot Hu-Au", "short_description": "The VR Chemistry Lab is a simulation of a typical school chemistry laboratory and an immersive experience where players can zoom down to the size of molecules."}]}, "developer_name": null, "developer_privacy_policy_url": "http://virtualrealityforeducation.com/the-vr-chemistry-lab-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HAE Studios", "support_website_url": null, "website_url": "https://virtualrealityforeducation.com/", "category