SALgKolkvcB4-C-WlTbQ&oe=670FB4E2"}, {"file_name": "migrated_image.png", "id": "2757225490998906", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982590_1941034845996440_4239233077357838336_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nF_6McdKxTAQ7kNvgEe27X-&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAPy2pj1AZ1HQsYC8yaDR7foYbpnC4fyJPJoK8ZL0BnqQ&oe=670FAD74"}, {"file_name": "migrated_image.png", "id": "567623190770588", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982659_358060028207091_2785657015853121536_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K2WQNBfjy4QQ7kNvgG8iYHA&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBsHgzTZe9Eo8rjrDW9kAEoGUUBWSobnAG_uHJmszl76g&oe=670FBF7A"}, {"file_name": "migrated_image.png", "id": "2890215867668600", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38984463_490191335086749_8979207973620416512_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LgUKEjXK7N0Q7kNvgHWX2eE&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCU0c3GNMn5rqqfCTdCn2ay98slAr9EXp1x57uhAjNZ0w&oe=670F9A28"}, {"file_name": "migrated_image.png", "id": "349538672607763", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974536_348167052800524_459072406976200704_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iQEgSxTBuuwQ7kNvgG84_ve&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCK7pwPfeISghqwDJK55wB75p1TX07OVETdXMEUB4YJMw&oe=670FAF9B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/xONCUJ", "id": "423633068234723", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974902_423633071568056_1349753795583672320_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nt__-TUzSooQ7kNvgHCnvyV&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCLSy5vn1MnL1i5_59cMQr1qGQNJKkKkTGra9cQnn1Gmw&oe=670FB431"}, "display_name": "Red Matter", "keywords": ["Adventure", "Puzzle", "Exploration", "Narrative", "Mystery"], "long_description": "Red Matter is a story-driven VR puzzle adventure game set during a dystopian Sci-Fi Cold War. Take on the role of Agent Epsilon, an astronaut of the Atlantic Union dispatched to an abandoned Volgravian base on Rhea, one of Saturn\u2019s moons. Your mission: to investigate a shady top secret research project. \n\nSolve puzzles in a beautiful, high-detail brutalist environment which only becomes more and more surreal as the story progresses. Use an array of hi-tech tools to decipher hidden messages and mechanisms and uncover ever deeper and darker secrets of the facility. But beware of what you may find... Once you discover the truth, will you be able to stomach it?", "short_description": "Red Matter is a VR puzzle adventure set during a dystopian Sci-Fi Cold War. Take on the role of Agent Epsilon, an astronaut dispatched to an abandoned Volgravian base on one of Saturn\u2019s moons. Your mission: to investigate a shady top secret research project. Use an array of hi-tech tools to decipher hidden messages and mechanisms, and uncover ever deeper and darker secrets of the facility. But beware of what you may find... Once you discover the truth, will you be able to stomach it?"}, {"images": {"nodes": []}, "id": "577769626418056", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Red Matter", "keywords": ["Aventura", "Puzle", "Exploraci\u00f3n", "Narrativa", "Misterio"], "long_description": "Red Matter es una aventura narrativa de puzles que tiene lugar en una Guerra Fr\u00eda dist\u00f3pica. Tomar\u00e1s el papel del Agente \u00c9psilon, un astronauta de la Uni\u00f3n Atl\u00e1ntica que ser\u00e1 enviado a una base abandonada en Rhea, luna de Saturno. Tu misi\u00f3n: recuperar informaci\u00f3n sobre las investigaciones que llevaba a cabo Volgravia en aquel oscuro lugar. Pero a medida que la aventura avanza, el jugador se enfrentar\u00e1 al dif\u00edcil reto de discernir qu\u00e9 es lo que realmente se esconde en la base y deber\u00e1 descubrir hasta d\u00f3nde se extienden sus misterios\n\nResuelve puzzles en unos impresionantes entornos brutalistas, que van volvi\u00e9ndose m\u00e1s y m\u00e1s surrealistas a medida que la historia avanza. Usa un set de herramientas para descifrar mensajes ocultos, mecanismos e ir desvelando los oscuros secretos que oculta la base. Pero ten cuidado con lo que puedas encontrar\u2026 Una vez sepas la verdad \u00bfser\u00e1s capaz de soportarla?", "short_description": "Red Matter es una aventura de puzles que tiene lugar en una Guerra Fr\u00eda dist\u00f3pica. Tomar\u00e1s el papel del Agente \u00c9psilon, un astronauta de la Uni\u00f3n Atl\u00e1ntica que ser\u00e1 enviado a una base abandonada en Rhea, luna de Saturno. Tu misi\u00f3n: recuperar informaci\u00f3n sobre las oscuras investigaciones que llevaba a cabo Volgravia en aquel lugar. Pero ten cuidado con lo que te puedas encontrar. Una vez sepas la verdad \u00bfser\u00e1s capaz de soportarla?"}, {"images": {"nodes": []}, "id": "144277000245215", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Red Matter", "keywords": ["Aventure", "Puzzle", "Exploration", "Narration", "Myst\u00e8re"], "long_description": "Red Matter est une aventure narrative qui se d\u00e9roule dans une Guerre Froide dystopique. Vous jouerez le r\u00f4le de l'agent Epsilon, un astronaute de l'Union Atlantique qui sera envoy\u00e9 dans une base abandonn\u00e9e sur Rh\u00e9a, une lune de Saturne. Votre mission: r\u00e9cup\u00e9rer des informations sur les enqu\u00eates que la Volgravie menait dans ce sombre endroit. Mais au fur et \u00e0 mesure que l'aventure progresse, le joueur devra relever le d\u00e9fi compliqu\u00e9 de discerner ce qui est r\u00e9ellement cach\u00e9 dans la base et d\u00e9couvrir l\u2019ampleur de ses myst\u00e8res.\n\nR\u00e9solvez des \u00e9nigmes dans des environnements \u00e9tonnants et brutaux qui deviennent de plus en plus surr\u00e9alistes au fur et \u00e0 mesure que l'histoire se d\u00e9roule. Utilisez un ensemble d'outils pour d\u00e9chiffrer les messages cach\u00e9s, les m\u00e9canismes et d\u00e9couvrir les obscurs secrets cach\u00e9s dans la base. Mais attention \u00e0 ce que vous trouvez..... Une fois que vous aurez connu la v\u00e9rit\u00e9, serez-vous capable de la supporter?", "short_description": "Red Matter est une aventure puzzle qui se d\u00e9roule dans une Guerre Froide dystopique. Vous jouerez le r\u00f4le de l'agent Epsilon, un astronaute de l'Union Atlantique qui sera envoy\u00e9 dans une base abandonn\u00e9e sur Rh\u00e9a, une lune de Saturne. Votre mission: r\u00e9cup\u00e9rer des informations sur les enqu\u00eates obscures que la Volgravie menait \u00e0 cet endroit. Mais attention \u00e0 ce que vous pouvez trouver. Une fois que vous aurez connu la v\u00e9rit\u00e9, serez-vous capable de la supporter?"}]}, "developer_name": "Vertical Robot", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "http://www.verticalrobot.com/tos.html", "publisher_name": "Vertical Robot", "support_website_url": "http://redmattergame.com/contact-us/", "website_url": "http://www.redmattergame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "PUZZLE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "493015472251458"}}]}, "scheduled_offers": {"count": 38, "nodes": [{"status": "PUBLISHED", "id": "1648901962566904"}, {"status": "PUBLISHED", "id": "964320065135000"},