cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RKKUMlnrxRgQ7kNvgEnPUTF&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8SJdRit3zAFD1n0u5FnepZ&oh=00_AYAHMPLxdkWs-hc_Y_pukW1cffIqX99VQcMIRzXWYyHwQw&oe=66F00192"}, {"file_name": "inGame2.png", "id": "313720009870365", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575352_313720013203698_4468974874963137331_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gQW3XZERdU4Q7kNvgFpSO_6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8SJdRit3zAFD1n0u5FnepZ&oh=00_AYBTLTBKMS8hM0oHimrs-gnzwU2GJhWxwt4sJF-eFpOb1g&oe=66EFF80D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover_2560x1440.png", "id": "777653299736360", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367588_777653303069693_993849786349685831_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JK-WZp2PcCUQ7kNvgH1mMwV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8SJdRit3zAFD1n0u5FnepZ&oh=00_AYDN-IFzy83_BhzNZM0PvodLhiIWTI5g4xgGcR6RjHhAuA&oe=66EFF6D2"}, "display_name": "BangSquash", "keywords": ["breakout", "pong", "ball", "arcade", "squash"], "long_description": "BangSquash is a block breaker-style for Oculus virtual reality (VR) platform which could be attractive for people of all ages. We believe Bang Squash to be an ideal game to show off the basic operation of the Oculus platform to novice players, or to get in a mini workout session in a couple of minutes.\n\nIt is an arcade game, so each level could be repeatable many times and there aren\u2019t two similar scenarios regarding the playing of levels, everything happens differently each time because of the realistic physics.\nThe game launch with a whole set of fun achievements and a global ranking system to increase replayability.\n\n!!!Orientation-tracked controller is required to paly this game.", "short_description": "BangSquash is a block breaker-style for Oculus virtual reality (VR) platform which could be attractive for people of all ages. We believe Bang Squash to be an ideal game to show off the basic operation of the Oculus platform to novice players, or to get in a mini workout session in a couple of minutes.\n\n!!!Orientation-tracked controller is required to paly this game."}]}, "developer_name": "Leber Software", "developer_privacy_policy_url": "https://lebersoftware.hu/bangsquash-privacy-policy/", "developer_terms_of_service_url": "http://www.lebersoftware.hu/", "publisher_name": "Leber Software", "support_website_url": "http://www.lebersoftware.hu/", "website_url": "https://lebersoftware.hu/bang-squash/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "461319502302523"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375752_1155259998192815_3334834765477641943_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UA5m1gxVcEoQ7kNvgGzOpPm&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8SJdRit3zAFD1n0u5FnepZ&oh=00_AYDpk1HeGEVsVwv5ECQ5kWG8h8A_ZlXRvNC2Fabqr1U9Tg&oe=66EFEA13"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BangSquash", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1601571669, "lastRevision": {"nodes": [{"id": "3259552984139744", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2990946714347209", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "pl