eration of the Oculus platform to novice players, or to get in a mini workout session in a couple of minutes.\n\n!!!Orientation-tracked controller is required to paly this game."}]}, "developer_name": "Leber Software", "developer_privacy_policy_url": "https://lebersoftware.hu/bangsquash-privacy-policy/", "developer_terms_of_service_url": "http://www.lebersoftware.hu/", "publisher_name": "Leber Software", "support_website_url": "http://www.lebersoftware.hu/", "website_url": "https://lebersoftware.hu/bang-squash/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "446228797176476"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "334029501137882"}]}, "baseline_offer": {"id": "334029501137882"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1601571660, "status": "PUBLISHED", "id": "334029501137882"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3197736737001538", "version": "1.7"}, "id": "685475692182263", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2990946714347209", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3197736737001538"}, "release_status": "RELEASED"}, "binary_release_channels":