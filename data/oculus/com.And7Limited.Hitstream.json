2571733_972184139648437816_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JIzp1uBfTbYQ7kNvgE8RSa_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArBZphUyXIZUIapOvYC4Fq5TbGyuiQJe25dziL2XAHKg&oe=677D0628"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "465800033225103", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974841_465800036558436_7943392708707471915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NE2ZpRCViEAQ7kNvgHetekg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCG0gAADZk9q7t2eoYxXWFILpMKQ-tRg9A_7IBE2-mXgQ&oe=677D2ED7"}, "display_name": "Hitstream", "keywords": ["fitness", "movement", "rhythm", "music", "wellbeing"], "long_description": "Fitness made fun!\n\nThe challenge surrounds you in this 360\u2019 game that takes you on a cardio-boosting trip around the world. So good you won\u2019t even realise you\u2019re exercising!\n\n\ud83c\udfae Over 12 hours of gameplay\n\n\ud83e\udd4a Punch, stretch, squat & dodge moves\n\n\ud83d\udd25 Lite, standard & intense modes\n\n\ud83c\udfdd\ufe0f Stunning scenery \n\n\ud83d\udcaa Full-body movement\n\n\ud83c\udfb5 Awesome tunes\n\n\ud83d\udd7a Intuitive choreography\n\n\ud83d\udc6bMultiplayer\n\n\ud83e\ude9fMixed reality\n\nDesigned with positive energy and physical/mental wellbeing in mind, this immersive game will take you on a range of journeys, from uplifting adventures that work on agility to power-focused routines that build strength and stamina. \n\nThe perfect non-subscription addition to your VR fitness library. \n\nHitstream: where will you exercise today?", "short_description": "Fitness made fun! \nThe challenge surrounds you in this 360\u2019 game that takes you on a cardio-boosting trip around the world. So good you won\u2019t even realise you\u2019re exercising!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://hitstream.games/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "And 7 Limited", "support_website_url": "https://hitstream.games/support", "website_url": "https://hitstream.games/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8800095603358865"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984444_931767488896253_2250571641091412824_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUb8u-SRwU4Q7kNvgEX63-2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCe8nLwljA_gk8HYmv9jOrRA53ZuB4h8SyiibrXw7FXOQ&oe=677D025E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hitstream", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "release_date": 1696957200, "lastRevision": {"nodes": [{"id": "444152016768751", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3645916778776799", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "533996014170348"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Hitstream-Square copy.pn