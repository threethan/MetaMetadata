imited.HitstreamDemo-20210205-203123.png", "id": "912205122855825", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974493_912205126189158_6317210425263435394_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xUU32X1X8kUQ7kNvgHrXoIQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA36Vrfb4U_Sb9PxZcclywmMWNZC7hGvFj32S88TQQ4FQ&oe=6745B0DF"}, {"file_name": "com.And7Limited.HitstreamDemo-20210205-202950.png", "id": "421161975617954", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003273_421161978951287_654754052404880732_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DWvvGEfhPZQQ7kNvgFWQr3Q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDsr3J0T217wSgvElTYjod8McMY3w4CDk_s4zekbHeKEQ&oe=6745C1C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Hitstream-Landscape.png", "id": "3253388198096282", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974450_3253388201429615_5315758588012683243_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_zKonxGY7IYQ7kNvgEQTp8x&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBM4l9nkpE_WikVY_sA07-U8DIBHPbgtB0SIpCQPMClAA&oe=6745CA3F"}, "display_name": "Hitstream", "keywords": [], "long_description": "Want to make exercise fun? Punch, stretch, squat and step your way to fitness in this 360\u00b0 game that will get you working up a sweat in no time.\n \nDesigned with positive energy and mental wellbeing in mind, Hitstream takes you to stunning locations across the globe, bringing the outdoor world to you at a time when so much of it is off limits.\n  \nPunch up, down, forward, to the side \u2026 catch the orbs, dodge the walls and, if you\u2019re feeling really energetic, turn squats on. Just make sure you keep an eye out for where they\u2019re coming from next!\n \nEvery action is perfectly timed to the beat of the music, with soundtracks that have been specially selected to take you on a range of journeys, from uplifting adventures that work on agility to hard-hitting routines that build strength and stamina.\n \nAdditional challenges await those who achieve a score of 90% or more -- can you make the grade?", "short_description": "Want to make exercise fun? Punch, stretch, squat and step your way to fitness in this 360\u00b0 game that takes you to stunning locations across the globe.\n   \nHit the objects, catch the orbs, dodge the walls and, if you\u2019re feeling really energetic, turn squats on. Just make sure you keep an eye out for where they\u2019re coming from next!\n  \nAdditional challenges await those who achieve a score of 90% or more -- can you make the grade?\n \nFull release with even more uplifting soundtracks coming soon."}]}, "developer_name": null, "developer_privacy_policy_url": "https://hitstream.games/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "And 7 Limited", "support_website_url": "https://hitstream.games/support", "website_url": "https://hitstream.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "909316856283378"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PUBLISHED", "id": "1695051574586607"}, {"status": "PUBLISHED", "id": "829018305788800"}, {"status": "PUBLISHED", "id": "6917495605008383"}, {"status": "PUBLISHED", "id": "622893020039006"}, {"status": "PENDING", "id": "325104127044986"}, {"status": "PUBLISHED", "id": 