ent-iad3-2.oculuscdn.com&oh=00_AYC99ithLKeuok4GmLj3GVH1fRIKDC78Jj3viQ5qQuWnNg&oe=671B7F9F"}, {"file_name": "Screenshot-Ice.png", "id": "1018062432708421", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031529_1018062436041754_1577944608711742886_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=csIlVODrzJAQ7kNvgH172dV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGcfZGkhjWakCjzELv61kEwuV_NSevKk9f2pn17aj12A&oe=671B9FCE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HITSTREAM_Cover_FINAL_PASSOFF.png", "id": "876481967757738", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_876481977757737_2671632885756691458_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pe9U6VhE52kQ7kNvgFejCfE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6-w40ORDmPa5Vz2xEGt04MwCTpiG-TnBFXOicac47ZQ&oe=671B810F"}, "display_name": "Hitstream", "keywords": ["fitness", "movement", "rhythm", "music", "wellbeing"], "long_description": "Fitness made fun!\n\nThe challenge surrounds you in this 360\u2019 game that takes you on a cardio-boosting trip around the world. So good you won\u2019t even realise you\u2019re exercising!\n\n\ud83c\udfae Over 12 hours of gameplay\n\n\ud83e\udd4a Punch, stretch, squat & dodge moves\n\n\ud83d\udd25 Lite, standard & intense modes\n\n\ud83c\udfdd\ufe0f Stunning scenery \n\n\ud83d\udcaa Full-body movement\n\n\ud83c\udfb5 Awesome tunes\n\n\ud83d\udd7a Intuitive choreography\n\n\ud83d\udc6bMultiplayer\n\n\ud83e\ude9fMixed reality\n\nDesigned with positive energy and physical/mental wellbeing in mind, this immersive game will take you on a range of journeys, from uplifting adventures that work on agility to power-focused routines that build strength and stamina. \n\nThe perfect non-subscription addition to your VR fitness library. \n\nHitstream: where will you exercise today?", "short_description": "Fitness made fun! \nThe challenge surrounds you in this 360\u2019 game that takes you on a cardio-boosting trip around the world. So good you won\u2019t even realise you\u2019re exercising!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://hitstream.games/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "And 7 Limited", "support_website_url": "https://hitstream.games/support", "website_url": "https://hitstream.games/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "2776542286000603"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8334468153254948"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210885_521166520634320_1350461756746285275_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vByqYeRn7BoQ7kNvgFTT-Uf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjS4HkNe14HKB-lpN6Ny9PvnCH24BWVCBqz8MfsjTY8w&oe=671B95A7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hitstream", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Lifestyle", "id": "3362542290449643"}, {"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Health & Fitness", "id": "619566195371476"}], "release_date": 1696957200, "lastRevision": {"nodes": [{"id": "444152