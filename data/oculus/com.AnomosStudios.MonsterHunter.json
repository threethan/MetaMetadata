/v/t64.5771-25/38974819_633247994283735_3680501467410535799_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4dFG05-5-QQ7kNvgGU1sB6&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATDtWiHYzNsc4UT3HZcQmtB&oh=00_AYCkPEyOJENvBl_wzgPtF5q6bmOlE723giguWF1qw4qF6Q&oe=66E978DA"}, {"file_name": "New_Foto_go_2.png", "id": "330063921377364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031486_330063928044030_1246687379521254996_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kdj3zBBr6zEQ7kNvgHJIOiD&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATDtWiHYzNsc4UT3HZcQmtB&oh=00_AYBTHj7dpoyz000X4or9mzZjfRM0W-GFJfdgnhafjKEZjA&oe=66E97DB2"}, {"file_name": "new_foto_go_1.png", "id": "307553537184269", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035402_307553540517602_8350025863300208031_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6FoOep341lkQ7kNvgH9CjB0&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATDtWiHYzNsc4UT3HZcQmtB&oh=00_AYBspGcLjGlRgxLzpNWj4gHgFTWMYM2vr_VUkmZ8UTDKvg&oe=66E94D6E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "STORE_COVER_LANDSCAPE.png", "id": "3831950493487932", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035403_3831950506821264_7913869629720238260_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qjwAFSc6vf4Q7kNvgFizuCE&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATDtWiHYzNsc4UT3HZcQmtB&oh=00_AYD8N4Dz3Q4xF7kbwzh0bU64481WRizAH2ecs7sfvqCKbw&oe=66E958E3"}, "display_name": "BIONIC HUNTER", "keywords": ["SCIFI", "SHOOTER", "HORROR", "ZOMBIE", "FPS"], "long_description": "NOTE: For Gear VR Users!We Support Samsung S7 Edge and Newer \n         Devices ONLY With SNAPDRAGON Chipset!\n\nYear 2236... vicious creatures destroyed our home planet. The few of us that survived, sworn to take revenge and make them pay. You are one of us... let none alive.. avenge humanity so we can thrive once again!\n\n-Full locomotion\n-Snap turning\n- 12 Sci-Fi Weapons to choose from the Battlefield :\n(Handguns,Shotguns,Rifles,Snipers,RocketsLaunchers, etc.)\n- Gigantic Monsters and parasites :\n(over 15 different enemy types with special abilities)\n- 4 Levels from Medium to Planet size!\n(maps take place on different planets)\n- Latest Gen Graphics and FX \n- Special PickUps to choose\n- Unlimited Survival mode play as long as you can survive!\n- Outstanding Sound FX and Music Tracks!\n- Leaderboards to track your ranking among other players worldwide\n- Open world Maps\n\nTake them down Hunter\nUPDATE 7/7/2020  New Level Map!", "short_description": "Hunt down Monsters in a Sci-Fi Horror Survival Shooter and test your Skills among other other player!\nLive a immersive experience with latest generation graphics for Go and GearVR!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.anomos-studios.com/terms-of-service-copy", "developer_terms_of_service_url": "https://www.anomos-studios.com/about", "publisher_name": "Anomos Studios", "support_website_url": "https://www.anomos-studios.com/", "website_url": "https://www.anomos-studios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "678168966655110"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035317_258435552165009_1898191441058856960_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nADBHLziGDMQ7kNvgGZcUbf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATDtWiHYzNsc4UT3HZcQmtB&oh=00_AYBIGlTppR8_IvnctIidsMvAA6r1XarNgZMKO9kP_Oafeg&oe=66E97D53"}, 