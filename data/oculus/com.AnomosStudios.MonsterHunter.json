 Maps\n\nTake them down Hunter\nUPDATE 7/7/2020  New Level Map!", "short_description": "Hunt down Monsters in a Sci-Fi Horror Survival Shooter and test your Skills among other other player!\nLive a immersive experience with latest generation graphics for Go and GearVR!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.anomos-studios.com/terms-of-service-copy", "developer_terms_of_service_url": "https://www.anomos-studios.com/about", "publisher_name": "Anomos Studios", "support_website_url": "https://www.anomos-studios.com/", "website_url": "https://www.anomos-studios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "678168966655110"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035317_258435552165009_1898191441058856960_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MIjF8gkvm64Q7kNvgHLm9qu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBcB8Wu26bIgLWmB28vI-aWHR5tHLEuZoCrJa9xGzDN-Q&oe=66DEF153"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BIONIC HUNTER", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1576864779, "lastRevision": {"nodes": [{"id": "221694965493104", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3165818406825516", "is_first_party": false, "enables_i