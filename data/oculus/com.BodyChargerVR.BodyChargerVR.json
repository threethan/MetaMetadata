, Please don't hesitate to contact us immediately via E-Mail: 408077086@qq.com\n", "short_description": "Body Charger VR  is an zumba VR app on Oculus Quest. Also friendly to beginners. We can see clearly virtual characters do by your side with pop songs.  "}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Body_charger_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.023d.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "702579937565199"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_535343271162433_7066741113254913407_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tVleYxOXBAQ7kNvgEdnHX4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3X9PrQdqJ_BRI0eSw31kZearBh3AZB4fRlXGv-X6cJQ&oe=66FBC8E3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Body Charger VR", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1637609703, "lastRevision": {"nodes": [{"id": "340409561197639", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4711482972209957", "is_first_party": false, "enables_in_app_ads": false, "i