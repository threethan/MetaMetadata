ns when first open app,there won't be reaction with rhythm. Never mind App still can work,.\n4. Make sure to review your surroundings and clear any obstacles in your play area before starting this game.\n5. You 'd better have sweat proof sleeve on your Quest headset, you will sweat a lot happily when playing this.\n6. Will update new songs every month,  If there are songs you wonder which are not in the list, Please don't hesitate to contact us immediately via E-Mail: \n408077086@qq.com", "short_description": "By using Body Charger VR will make us energetic. We enjoy life, we love music,so we love zumba.\nSong list:\nhttp://www.cqplanb.com/ccc/Bodycharger-songlist.html"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Body_charger_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.023d.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "471146947739763"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5110616792296571", "version": "8"}, "id": "278947967404591", "channel_name": "LIVE"}]}, "is_for_oculus_keys_onl