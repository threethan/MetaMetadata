68_540251457093263_596185216737678114_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DIxpW_Iy15MQ7kNvgFPbwjp&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Oaa1ZO9sB3isG2pTI8-lW&oh=00_AYAxzs249K4U08Q2cn8ikkQ40k3G2uqLSrOYrPFU8OGwUQ&oe=66EC1FE5"}, {"file_name": "Untitled-4.png", "id": "345017844023739", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974589_345017847357072_5205306834273048416_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fXMPmwKdzY4Q7kNvgHHqd6r&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Oaa1ZO9sB3isG2pTI8-lW&oh=00_AYA6XgfM6vcksgBIyYYMVXrdFGRA_bDP07XD41e27fOgfg&oe=66EC06DD"}, {"file_name": "CTH-Screenshot-10.png", "id": "210466391035364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031450_210466394368697_3171406121056240819_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pEIVyBLL-D8Q7kNvgFK9lSS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Oaa1ZO9sB3isG2pTI8-lW&oh=00_AYBVXevg89uXciUhZj2O9h6w4LsbxMvtJ5oyFTMkSkcONw&oe=66EC05C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeCTH.png", "id": "363675381967905", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_363675385301238_5052437303050576733_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P05q53bhhZEQ7kNvgGp7jHw&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1Oaa1ZO9sB3isG2pTI8-lW&oh=00_AYDx3X6TmpVaiK_G7LMOAJkDR7S64OdDdrOpOEZj9tPl-g&oe=66EC26CA"}, "display_name": "Captain ToonHead vs The Punks from Outer Space", "keywords": ["towerdefense", "rts"], "long_description": "A true first-person tower defense, designed for VR. \nThis is not your diorama-style VR tower defense. In Captain ToonHead you'll move all over the map, hammering away to upgrade your towers, while throwing over-powered chanclas recklessly. You'll take manual control of your towers to unleash streams of heavy-metal powered hot sauce and shoot electric beams from weaponized pizza at your enemies. \n\nAfter the squad sent by the World Treaty for Freedom (WTF) got fried in the \"burrito incident\", it falls to Elliott Salazar, the cartoon-obsessed facility technician and only survivor, to save Earth. There\u2019s a new captain onboard: Captain ToonHead! The hero we got stuck with.\n\nBalance action and strategy:\nYou're going to do a lot of shooting, but shooting alone will not defeat the waves of Cyber-C.H.I.C.K.E.N.s and Terra-S.H.A.R.K.s. Combine those PIG\u00f1ata tower bombs with your chancla throws in a very strategic way if you want to save the EnerCubes and defeat Nicholas Voorhees' P.U.N.K. army!", "short_description": "Ever wanted to beat a T-Rex up with a chancla, while building powerful towers that shoot pi\u00f1atas, hot sauce and heat-seeking fireworks? Captain ToonHead is the VR tower defense game of your cartooniest dreams."}]}, "developer_name": null, "developer_privacy_policy_url": "https://teravisiongames.com/site/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Teravision Games", "support_website_url": null, "website_url": "http://captaintoonhead.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "454522316314008"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "1501422157435158"}, {"status": "PUBLISHED", "id": "366463219254505"}, {"status": "CANCELLED", "id": "385423926330315"}, {"status": "PUBLISHED", "id": "266153856580289"}, {"status": "PUBLISHED", "id": "520166669540340"}, {"status": "PUBLISHED", "i