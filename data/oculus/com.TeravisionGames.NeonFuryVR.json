9144_3327136659855934361_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nuJS9hIkBtAQ7kNvgFUDVyN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDm7j5Rx392v13GO0IV54WQrG7VnhnerDegHKwkV-aGgQ&oe=66CB0B09"}, {"file_name": "CTH-Screenshot-2.png", "id": "865151511043206", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035389_865151514376539_175007382094924936_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g-EJKAkyrw0Q7kNvgEqyKFv&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1FiIC1llinya1-dQNiO2aRN7Q0atYX4BX2botNPf_Bw&oe=66CB0846"}, {"file_name": "Untitled-4.png", "id": "540251453759930", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974568_540251457093263_596185216737678114_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gWY0DPW45ZwQ7kNvgEqQqNF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgoezzTDjUQ9fZBM2riZs3UTBX1tBlS4to3BA6uYqiGg&oe=66CB2A65"}, {"file_name": "CTH-Screenshot-10.png", "id": "210466391035364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031450_210466394368697_3171406121056240819_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-kuYKqE5C-UQ7kNvgFrKsN6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTgMZMBB1dNDPPdhp6JR7cNcJKb6bgDJxd-dKPMFACrA&oe=66CB1045"}, {"file_name": "Captain ToonHead Screenshot.png", "id": "426672885500768", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_426672888834101_6085981131912280130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hC4-MVK-EXoQ7kNvgGafJPA&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6wholewjyMvk-Wkl-d_4lrK9URBl2WBsW159TLdJzQQ&oe=66CB22A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Oculus-Thumbnail.png", "id": "760441625080166", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974883_760441628413499_3472724892994893008_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XCR1BMnBM4IQ7kNvgFWudmy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkhYGMd8MXIALKYKAZH48jnwwGmouEH0Eznt_KMzdyhQ&oe=66CB13F3"}, "display_name": "Captain ToonHead vs The Punks from Outer Space", "keywords": ["towerdefense", "rts", "narrative", "cartoon", "humor"], "long_description": "\"\u2018Captain Toonhead Might Be The Most Over-The-Top VR Game Ever\"\n- VRScout\n\n\"One of the best tower defense games I have played in VR.\"\n- VRGameFaqs\n\n*An ACTION TOWER DEFENSE*\nYou'll move all over the map, hammering away to upgrade towers, throwing over-powered chanclas recklessly and taking control of your towers to unleash streams of heavy-metal powered hot sauce and shoot electric beams from weaponized pizza at your enemies. \n\n*The hero we got stuck with*\nAfter the squad sent by the World Treaty for Freedom (WTF) got fried in the \"burrito incident\", it falls to Elliott Salazar, the cartoon-obsessed space janitor and only survivor, to save Earth. There\u2019s a new captain onboard: Captain ToonHead! \n\n*Balance action and strategy*\nShooting alone will not defeat the waves of Cyber-C.H.I.C.K.E.N.s and Terra-S.H.A.R.K.s. Combine those PIG\u00f1ata tower bombs with your chancla throws in a very strategic way if you want to save the EnerCubes and defeat Nicholas Voorhees' P.U.N.K. army!", "short_description": "Ever wanted to beat a T-Rex up with a chancla, while building powerful towers that shoot pi\u00f1atas, hot sauce and heat-seeking fireworks? Captain ToonHead is the ACTION TOWER DEFENSE of your cartooniest dreams."}]}, "developer_name": null, "developer_privacy_policy_url": "https://teravisiongames.com/site/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Teravision Games", "support_website_url": null, "website_url": "http://captaintoonhead.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "ADVENTURE"], "has_in_app_ads": false, "internet_connection