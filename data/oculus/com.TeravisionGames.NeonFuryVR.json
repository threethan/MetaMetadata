PoL-Rm9ok21bm18iW9b7MzgiJI-XDw&oe=674DAD61"}]}, "id": "1315872672615554", "locale": "en_US", "screenshots": [{"file_name": "CHT-Screenshot-1.png", "id": "1551410408545811", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931338_1551410411879144_3327136659855934361_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ew9QflhvO_QQ7kNvgGp_fT6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAM3Qoid9ImKJxt8K_tPSPb7KpLDKpszJuZTfKlZJLfnw&oe=674D8F89"}, {"file_name": "CTH-Screenshot-2.png", "id": "865151511043206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035389_865151514376539_175007382094924936_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F0wTwdZWfTYQ7kNvgE9vfd8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmE7pN_2pXFCHxL-a9xY0xRERtla2ad0IZ2WoiEQJaPg&oe=674D8CC6"}, {"file_name": "Untitled-4.png", "id": "540251453759930", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974568_540251457093263_596185216737678114_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bVdDklJAMb8Q7kNvgGn-BCs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLW4jv4P2SGthnz-R08yy403UctwDXl7WCIB4_rO9ZDQ&oe=674DAEE5"}, {"file_name": "CTH-Screenshot-10.png", "id": "210466391035364", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031450_210466394368697_3171406121056240819_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bAHORuvwTDMQ7kNvgG-Nhk8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBeHAIyKWuqs-cxj_LRkkgKjMQzz-SWc3ke6CO3kGzKeA&oe=674D94C5"}, {"file_name": "Captain ToonHead Screenshot.png", "id": "426672885500768", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982658_426672888834101_6085981131912280130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=clETuhcpOIkQ7kNvgEsTxQS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCLu2GHBRvHQEJzDKLKuu8ay22sQm0rDy1MsSvs6dgCg&oe=674DA724"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Oculus-Thumbnail.png", "id": "760441625080166", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974883_760441628413499_3472724892994893008_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KMGS9PTabnMQ7kNvgH5fycI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDhQwhmAHrW72LauLmYai3KMw-nhwT1h33iYeohcAuTiA&oe=674D9873"}, "display_name": "Captain ToonHead vs The Punks from Outer Space", "keywords": ["towerdefense", "rts", "narrative", "cartoon", "humor"], "long_description": "\"\u2018Captain Toonhead Might Be The Most Over-The-Top VR Game Ever\"\n- VRScout\n\n\"One of the best tower defense games I have played in VR.\"\n- VRGameFaqs\n\n*An ACTION TOWER DEFENSE*\nYou'll move all over the map, hammering away to upgrade towers, throwing over-powered chanclas recklessly and taking control of your towers to unleash streams of heavy-metal powered hot sauce and shoot electric beams from weaponized pizza at your enemies. \n\n*The hero we got stuck with*\nAfter the squad sent by the World Treaty for Freedom (WTF) got fried in the \"burrito incident\", it falls to Elliott Salazar, the cartoon-obsessed space janitor and only survivor, to save Earth. There\u2019s a new captain onboard: Captain ToonHead! \n\n*Balance action and strategy*\nShooting alone will not defeat the waves of Cyber-C.H.I.C.K.E.N.s and Terra-S.H.A.R.K.s. Combine those PIG\u00f1ata tower bombs with your chancla throws in a very strategic way if you want to save the EnerCubes and defeat Nicholas Voorhees' P.U.N.K. army!", "short_description": "Ever wanted to beat a T-Rex up with a chancla, while building powerful towers that shoot pi\u00f1atas, hot sauce and heat-seeking fireworks? Captain ToonHead is the ACTION TOWER DEFENSE of your cartooniest dreams."}]}, "developer_name": null, "developer_privacy_policy_url": "https://teravisiongames.com/site/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Teravision Games", "support_website_url": null, "website_url": "http://captaintoonhead.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1388421651996214"}, "review_messages": ["Approving your metadata update for release!"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997708_209448355239747_3531361018383596726_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0qE4_CCn0UQ7kNvgExtlFe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3MoBAZygLTzznf6hcbw8XC6-QGv8hFoI1R98gTiTyvg&oe=674D9AEF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Captain ToonHead vs The Punks from Outer Space", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1636653631, "lastRevision": {"nodes": [{"id": "2825729510973619", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3697657733661230", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "187830250079142"}, "iarc_email": null, "msrp"