ailer": null, "video_trailer_thumbnail": null, "display_name": "Deadhead VR", "keywords": ["FPS", "Texas", "Zombie", "Arcade", "Steampunk"], "long_description": "Welcome to the Battle of the Alamo, but in this fantasy world, it's the apocalypse. You are Monsignor Saintiago, best shot in the wild west, you wake up from the rubble only to find the rotten corpses have come back to life to hunt down the rest of existence. Skulls rise from the ash and come to your aid. Destroy the rotten.\n\n-Unique companions, unlock all six of them.\n-Five weapon drops with expendable ammo.\n-Level up your soul types for unique strategies.\n-Killer music tracks inspired by old console classics.\n-Procedural generation creates a unique level every playthrough.\n-Voice narrated backstory in English and Spanish.", "short_description": "It\u2019s safe to say that no living soul can click fast enough to blast away all of the enemies in this throwback arcade shooter. You will inevitably die, but how long can you survive? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.facebook.com/LV2VR/", "developer_terms_of_service_url": "https://www.facebook.com/LV2VR/", "publisher_name": "Level 2 VR", "support_website_url": null, "website_url": "https://www.facebook.com/LV2VR/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "HORROR", "SHOOTER", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "455965746011061"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com