683873737_532297538_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j7lAcFS-UfQQ7kNvgEubV4d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDMbBc5TGG20wSWUg91SGfcLm56L9HTxatEvQ6-0B2GMQ&oe=67274876"}]}, "id": "1156978797982329", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "525031131752395", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138908_1536317813325897_537984264_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZsysrTsLLcsQ7kNvgFSrXhU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnBPaoAa77agIC-3b9J2PrMn4AuE8QcJrb4KBjtSkMvg&oe=67274BA3"}, {"file_name": "migrated_image.png", "id": "549292258897057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162739_965793660148431_1038942214_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Unu0iIx7yGMQ7kNvgFvXY22&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfMr1fGGwgzB-mKtsaqJWDdXL64NOx6ewMEQqZ4T8qnQ&oe=67275C63"}, {"file_name": "migrated_image.png", "id": "532568754306702", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138945_438806592985304_767396154_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=droTlFHVS8UQ7kNvgFbYrvX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBrBLD5LHjt6PwXtztVtqDzyMCEQcB7pdxFHzl273n3yw&oe=67277C45"}, {"file_name": "migrated_image.png", "id": "830146164121878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138853_1482349018762448_1360026320_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ruepHa-2RSUQ7kNvgH91ZW8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUf4Q0GgGjKBrOYkThME8zSNgRfVOMJc0tr8ovFKYXxA&oe=67275D9F"}, {"file_name": "migrated_image.png", "id": "544983129465947", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12138853_1479861728986817_626868105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuoQJSY_qcQQ7kNvgHU2RTx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2WMwRhhHGxhgUeQYkcpaqQ5oum-nDWp1asLPKVK7LSQ&oe=67274ADB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Deadhead VR", "keywords": ["FPS", "Texas", "Zombie", "Arcade", "Steampunk"], "long_description": "Welcome to the Battle of the Alamo, but in this fantasy world, it's the apocalypse. You are Monsignor Saintiago, best shot in the wild west, you wake up from the rubble only to find the rotten corpses have come back to life to hunt down the rest of existence. Skulls rise from the ash and come to your aid. Destroy the rotten.\n\n-Unique companions, unlock all six of them.\n-Five weapon drops with expendable ammo.\n-Level up your soul types for unique strategies.\n-Killer music tracks inspired by old console classics.\n-Procedural generation creates a unique level every playthrough.\n-Voice narrated backstory in English and Spanish.", "short_description": "It\u2019s safe to say that no living soul can click fast enough to blast away all of the enemies in this throwback arcade shooter. You will inevitably die, but how long can you survive? "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.facebook.com/LV2VR/", "developer_terms_of_service_url": "https://www.facebook.com/LV2VR/", "publisher_name": "Level 2 VR", "support_website_url": null, "website_url": "https://www.facebook.com/LV2VR/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "HORROR", "SHOOTER", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "455965746011061"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.co