49018762448_1360026320_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ehjqU6dHlK0Q7kNvgFXoAXN&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD-OGcwzyUbVqRx5EmVK2_ezTdgDAmA4Gyo45e49F9SNA&oe=6776779F"}, {"file_name": "migrated_image.png", "id": "592005134717751", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12138853_1479861728986817_626868105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4_EtxgN4S58Q7kNvgGvfRXP&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC-Vmv2vv8GfRvprcxGc-w8OpPYcMDg-CzNoMSFlIP-1A&oe=677664DB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Deadhead VR", "keywords": [], "long_description": "It\u2019s probably safe to say that no living soul can click fast enough to blast away all of the enemies in this first-person arcade shooter. We even attached a bayonette to the end of your multipurpose gun for melee attacks and added a soul vial that can upgrade your attributes overtime. Choose your companion wisely - every death is a new beginning.", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Level 2 VR", "support_website_url": null, "website_url": "http://www.level2vr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "HORROR", "SHOOTER", "STRATEGY", "CASUAL"], "has_in_app_ads": null, "internet_connection": null, "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": ["TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "364104581819512"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "132454880765482"}, {"status": "