g?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nycw2MqxdxwQ7kNvgEovlGm&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYCJM8D-PHsD3yBsfnp1Ke3eAz9pqWHmGx6O1m8ZRXhOQw&oe=66E6AD60"}, {"file_name": "screenshot5.png", "id": "553874096635567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974780_553874099968900_7378651240689708759_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b5qv_N5zCO4Q7kNvgGHMnUj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYDWkP9gch-15Oj5AlqlZuy5bF69P4SwFoQe_E6UDokpyw&oe=66E6C544"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "md_cover_yoko.png", "id": "177397054888391", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001715_177397058221724_4824817095391091493_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFGOGS2pXs0Q7kNvgG71vAQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYAyl5jfydEVn-mUhXnRP-ErgTYhjCw8h0UiuYXWGXQ2mg&oe=66E6C763"}, "display_name": "Holoeyes MD", "keywords": [], "long_description": "Holoeyes MD\" is a program that computer processes image information obtained by diagnostic imaging equipment and provides it for medical treatment. It does not perform automatic diagnosis. In addition to the standard function that displays images, there is an optional function that performs three-dimensional image processing.\n\nIt is to be installed and used on general-purpose IT equipment, etc. that meets the specifications specified by Holoeyes Corporation (hereinafter referred to as \"the Company\") in the manner specified by the Company and provided as a download. For details, please refer to the attached document.\n\nThe latest version of the attached document (electronic attachment) https://holoeyes.jp/pmda/", "short_description": "The medical imaging software \"Holoeyes MD\" is a controlled medical device (generic name: program for general-purpose diagnostic imaging workstations, certification number: 302ADBZX00011000) under the \"Act on Quality, Efficacy and Safety Assurance of Pharmaceuticals, Medical Devices, etc.\" (Pharmaceuticals and Medical Devices Act)."}, {"images": {"nodes": [{"file_name": "md_logo.png", "id": "5998065973633964", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003260_5998065976967297_260827317627691552_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d3W9PUuQFSsQ7kNvgF7Jfuu&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYAtRYh-5CxBCJbz5BQBMUZWGIaB-pVNLrcU1YC4FmmV9g&oe=66E6D24D"}, {"file_name": "md_cover_tate.png", "id": "2303415159832893", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974904_2303415163166226_7688600240374808365_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CW8S5hEEVKwQ7kNvgFqZ47q&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYCGF7VZ-jpdD2ODZDqwGl3V-xwfdZLfDRxIbo9koXTATA&oe=66E6C4AC"}, {"file_name": "md_cover_miniyoko.png", "id": "950325029433473", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_950325032766806_6345836855774372629_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KbyEPP7V6LsQ7kNvgHiBDs8&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYDfdY4iPPtZaa5AmAwPXVFQFtaUBM5XDUmwWLJXz3twkg&oe=66E6ADFD"}, {"file_name": "md_cover_yoko.png", "id": "773168277532939", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223486_773168280866272_6988374572968566012_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3NdzTtABjtEQ7kNvgEfFadO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4zVfM6Wp5U7rEOrwZFU6zJ&oh=00_AYBRvyleg8O-b0aylYCzrhtfTFHoqsRLICVsy4hk1dv1Vg&oe=66E6B8CC"}, {"file_name": "md_cover_sei.png", "id": "720321789843117", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974637_720321793176450_8923266462407111499_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_o