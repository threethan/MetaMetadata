59_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lO9eeExGeC8Q7kNvgEWSQ29&_nc_ht=scontent.oculuscdn.com&oh=00_AYDitfC4wQ4hWOywG6vzE16qtpnCiBgiGcA_nISyRQ8o_w&oe=66DD8AC4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "md_cover_yoko.png", "id": "177397054888391", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001715_177397058221724_4824817095391091493_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b1t7R32X7uUQ7kNvgEFhOZ-&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0EadSUYCKuS2dtxaE1ZZhsOlq8Hui0_lgkV-zXBjcSg&oe=66DD8CE3"}, "display_name": "Holoeyes MD", "keywords": [], "long_description": "Holoeyes MD\" is a program that computer processes image information obtained by diagnostic imaging equipment and provides it for medical treatment. It does not perform automatic diagnosis. In addition to the standard function that displays images, there is an optional function that performs three-dimensional image processing.\n\nIt is to be installed and used on general-purpose IT equipment, etc. that meets the specifications specified by Holoeyes Corporation (hereinafter referred to as \"the Company\") in the manner specified by the Company and provided as a download. For details, please refer to the attached document.\n\nThe latest version of the attached document (electronic attachment) https://holoeyes.jp/pmda/", "short_description": "The medical imaging software \"Holoeyes MD\" is a controlled medical device (generic name: program for general-purpose diagnostic imaging workstations, certification number: 302ADBZX00011000) under the \"Act on Quality, Efficacy and Safety Assurance of Pharmaceuticals, Medical Devices, etc.\" (Pharmaceuticals and Medical Devices Act)."}, {"images": {"nodes": [{"file_name": "md_logo.png", "id": "5998065973633964", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003260_5998065976967297_260827317627691552_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ep_HmF2D1VIQ7kNvgGDZ3F