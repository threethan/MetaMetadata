il has 5 unique levels.\n\nHotel Arena, Apartments Arena, Boxing Ring, Sandbox.\n\nThe game is in early access for now, stay tuned for new updates.", "short_description": "Bullet Trail is a brutal free-play shooter whose main feature is gore."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/13UAcp26fVNVxGUlmnTxDvOEqaTMNDc7XXYcB62H4ouU/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Zero Level", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCAKPvpAYvXDRVGPnVQzsdaQ", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25352448881013052"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "7719096411550339"}, {"status": "PUBLISHED", "id": "25224059320518766"}]}, "baseline_offer": {"id": "7719096411550339"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723443672, "status": "PUBLISHED", "id": "7719096411550339"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26822529274004998", "version": "0.51"}, "id": "1595060531315472", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_appl