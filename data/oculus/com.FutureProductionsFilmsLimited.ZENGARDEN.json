digital oasis. \ud83c\udf38\u2728 #ZenGardenVR #VirtualRelaxation #JapaneseSerenity \ud83c\udf8b\ud83c\udfef"}]}, "developer_name": null, "developer_privacy_policy_url": "https://future-productions.co.uk/zen-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Future Productions Films Limited", "support_website_url": null, "website_url": "http://future-productions.co.uk/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6070055033119248"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1367680463934766"}]}, "baseline_offer": {"id": "1367680463934766"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712608320, "status": "PUBLISHED", "id": "1367680463934766"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7459721160819288", "version": "1.0.7"}, "id": "421680427177678", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6020869228037829", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7459721160819288"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "421680427177678"}]}, "change_log": "Dear friends,\n\nI\u2019m thrilled to share the latest updates for Zen Garden VR! \n\nHere\u2019s what\u2019s new and what\u2019s coming:\n\nIt\u2019s snowing!\n\nFor the festive season, I\u2019ve added a beautiful snowfall effect to the garden. Wander through the tranquil paths as snowflakes gently fall around you.\n\nWarm by the fire:\n\nHead to the pagoda and enjoy the cozy fire\u2014a perfect spot to relax and unwind during this chilly season.\n\nSnow as an optional feature:\n\nAfter the festive period, the snow effect will remain available as an option, so you can enjoy a wintry garden whenever you\u2019d like.\n\nThird Party App Support:\n\nYou can now multitask in the app and play music and other meditations from third party sideloaded apps. (Just be sure to mute the in game audio and that you have developer mode enabled. Tested on Quest 2 and up)\n\n\nFuture plans:\n\nI\u2019m already working on adding new places and maps for you to explore. \n\nLush forests of bamboo to other hidden gems, there\u2019s much more to look forward to in Zen Garden VR!\n\nThank you for your continued support and feedback\u2014it means the world to me. I can\u2019t wait to share even more updates with you in the coming months.\n\nWishing you a peaceful and joyful festive season! \n\n\u2013 Krish", "created_date": 1734246043, "id": "7459721160819288", "version": "1.0.7", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6020869228037829", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7459721160819288"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "421680427177678"}]}, "change_log": null, "created_date": 1724270858, "id": "6736263639831714", "version": "1.0.6", "version_code": 7, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6020869228037829", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7459721160819288"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "421680427177678"}]}, "change_log": "Zen Garden VR - Update 2024\n\nThank you all for enjoying Zen Garden so far!\n\nIt has been a tricky time for me but I have finally managed a new update for you to enjoy.\n\n1) The pagoda is now open, feel free to warm yourself by the fire.\n2) Textures on the Tori Gates have been improved.\n3) Web browsing and some 2D Android apps will work from within this app on Quest 2 and up!\n\nThanks for your support on this journey. I am very proud to help you all relax with this app.\n\nStay tuned for more updates out soon!\n\nK", "created_date": 1722939288, "id": "6651074388350640", "version": "1.0.5", "version_code": 6, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6020869228037829", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7459721160819288"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "421680427177678"}]}, "change_log": "A guided meditation has now been added. The vocals have been enhanced to bring about a deeper sense of relaxation. The Zen garden will be getting new updates again soon with a new meditation each month and other new features.", "created_date": 1714559024, "id": "6176681949123222", "version": "1.0.4", "version_code": 5, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6020869228037829", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7459721160819288"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "421680427177678"}]}, "change_log": null, "created_date": 1714297217, "id": "6163676073757143", "version": "1.0.3", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}