MIUGAR1G1&oh=00_AYAJdtMuckwgOIsq93srGkdD60oNGeXEu-E9HImWSd77lw&oe=66EABD81"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AppLab\u7533\u8acb\u7528_\u6a2a\u9577\u30ab\u30d0\u30fc_2560x1440.png", "id": "1033889684028928", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031504_1033889687362261_6037341758526645169_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Q4ISFIuiWMQ7kNvgFPLQl3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYDOX3acvFMlwEMIUGAR1G1&oh=00_AYCDiNNF5VjLme7QqbZKk7zphiMQOQaI1j4CyjbpbSazlA&oe=66EAD32A"}, "display_name": "TOKYO GAME SHOW VR 2021 ", "keywords": [], "long_description": "This is the official VR application of TOKYO GAME SHOW VR 2021.\n\nCelebrating the 25th anniversary of TOKYO GAME SHOW (TGS), the first virtual exhibition site in the history of TGS is now open!\nSet in \u201cGAME FLOAT\u201d floating in the distant ocean somewhere in the real world, enjoy 20 exhibitors spaces, 2 official stores, 3 special video contents, and a theater where you can watch the official TGS2021 ONLINE program on a large screen!\n\nIn the unique virtual venue where famous characters welcome you, you\u2019ll find a wealth of information about games, from the latest news to the history of TGS.\nMoreover, visitors can enjoy communicating with each other through voice chat, text message display, replaceable avatar T-shirt, and a channel function that allows you to go around with your friends.\n\nIn addition, if everyone collects the \u201cFragments of Crystal\u201d hidden in the venue, the power of connection among game fans will be united...!\n\nEvent dates: September 30th (Thur.) - October 3rd (Sun.), 2021", "short_description": "This is the official VR application of TOKYO GAME SHOW VR 2021.\n\nCelebrating the 25th anniversary of TOKYO GAME SHOW (TGS), the first virtual exhibition site in the history of TGS is now open!\nSet in \u201cGAME FLOAT\u201d floating in the distant ocean somewhere in the real world, enjoy 20 exhibitors spaces, 2 official stores, 3 special video contents, and a theater where you can watch the official TGS2021 ONLINE program on a large screen!\n\nEvent dates: September 30th (Thur.) - October 3rd (Sun.), 2021"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tgsvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "TOKYO GAME SHOW Studios", "support_website_url": null, "website_url": "https://tgsvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "SOCIAL", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2043580522482932"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031347_3002694320056989_7188271754724957916_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-DmvpbAvVCkQ7kNvgEW5TAO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYDOX3acvFMlwEMIUGAR1G1&oh=00_AYDED9M8EcStGnM1ZJkL77jwgYDdrNwiNklty9LWj9wWHg&oe=66EAB9F1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TOKYO GAME SHOW VR 2021 ", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1631904255, "lastRevision": {"nodes": [{"id": "592358358396106", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4228801603820680", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {