nSRLwMvoL9tCk-g&oe=66D9A757"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "lobby_screenshot_2_2560x1440.png", "id": "1727220680906804", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162686_1727220684240137_926651241495265280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l77vT31iaqMQ7kNvgGuJGzx&_nc_ht=scontent.oculuscdn.com&oh=00_AYDGYGw51gNtylrAcVYhA-BaJX8uIkYd2G4NY5TS--1YpA&oe=66D99594"}, "display_name": "PROSENSE", "keywords": ["prosense", "stream", "event", "sport", "live"], "long_description": "View broadcasts through the PROSENSE is a new level of immersion to the game for true fans - a VIP area with the best views in VR and the original UI.\nPROSENSE has already aired such major Sports as the All Stars Week of the Continental Hockey League , Fights ACB etc. \nWe are constantly expanding the themes of the broadcasts and a list of additional materials - interview, backstage shots.\nWith PROSENSE - you will move immediately to an event that you are interested in, wherever it took place - just be where you want to be! \n\nContact us through facebook (https://www.facebook.com/prosense.tv ) \nor email hello@prosense.tv", "short_description": "PROSENSE is your exclusive access to the most spectacular events in Virtual Reality. Setting app provides you with the best views in 360\u2019 and 180\u2019 during the broadcast and the complete library of the greatest moments in Sports, Music, Cultural and Business events!"}, {"images": {"nodes": []}, "id": "515571682477032", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PROSENSE", "keywords": ["\u043f\u0440\u043e\u0441\u0435\u043d\u0441", "\u0441\u0442\u0440\u0438\u043c", "\u0441\u043e\u0431\u044b\u0442\u0438\u0435", "\u0441\u043f\u043e\u0440\u0442", "\u0432\u0438\u0434\u0435\u043e"], "long_description": "\u041f\u0440\u043e\u0441\u043c\u043e\u0442\u0440 \u0442\u0440\u0430\u043d\u0441\u043b\u044f\u0446\u0438\u0439 \u0447\u0435\u0440\u0435\u0437 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 PROSENSE - \u044d\u0442\u043e \u043d\u043e\u0432\u044b\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u043f\u043e\u0433\u0440\u0443\u0436\u0435\u043d\u0438\u044f \u0432  \u0446\u0435\u043d\u0442\u0440 \u0441\u043e\u0431\u044b\u0442\u0438\u0439 \u0434\u043b\u044f \u0438\u0441\u0442\u0438\u043d\u043d\u044b\u0445 \u0431\u043e\u043b\u0435\u043b\u044c\u0449\u0438\u043a\u043e\u0432 - Vip \u041b\u043e\u0436\u0430 \u0441 \u043b\u0443\u0447\u0448\u0438\u043c\u0438 \u0440\u0430\u043a\u0443\u0440\u0441\u0430\u043c\u0438 \u0441\u044a\u0435\u043c\u043e\u043a \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 \u0412\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 360\u2019 \u0438 180\u2019 \u0438 \u043e\u0440\u0438\u0433\u0438\u043d\u0430\u043b\u044c\u043d\u044b\u043c \u0438\u043d\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u043e\u043c.\nPROSENSE \u0443\u0436\u0435 \u0442\u0440\u0430\u043d\u0441\u043b\u0438\u0440\u043e\u0432\u0430\u043b \u0442\u0430\u043a\u0438\u0435 \u043a\u0440\u0443\u043f\u043d\u044b\u0435 \u0441\u043f\u043e\u0440\u0442\u0438\u0432\u043d\u044b\u0435 \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044f \u043a\u0430\u043a \u041d\u0435\u0434\u0435\u043b\u044f \u0417\u0432\u0435\u0437\u0434 \u041a\u043e\u043d\u0442\u0438\u043d\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u043e\u0439 \u0425\u043e\u043a\u043a\u0435\u0439\u043d\u043e\u0439 \u041b\u0438\u0433\u0438, \u0411\u043e\u0438 ACB \u0438 \u0434\u0440. \n\u041c\u044b \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e \u0440\u0430\u0441\u0448\u0438\u0440\u044f\u0435\u043c \u0442\u0435\u043c\u0430\u0442\u0438\u043a\u0443 \u0442\u0440\u0430\u043d\u0441\u043b\u044f\u0446\u0438\u0439 \u0438 \u043f\u0435\u0440\u0435\u0447\u0435\u043d\u044c \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u043e\u0432 - \u0438\u043d\u0442\u0435\u0440\u0432\u044c\u044e, \u0431\u044d\u043a\u0441\u0442\u0435\u0439\u0434\u0436\u0438 \u0441\u044a\u0435\u043c\u043e\u043a. \u0412\u043f\u0435\u0440\u0435\u0434\u0438 \u0441\u0435\u0437\u043e\u043d, \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u043d\u044b\u0439 \u043d\u043e\u0432\u044b\u043c\u0438 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044f\u043c\u0438 \u0438 \u044f\u0440\u0447\u0430\u0439\u0448\u0438\u043c\u0438 \u044d\u043c\u043e\u0446\u0438\u044f\u043c\u0438!!!!\n\u0412\u043c\u0435\u0441\u0442\u0435 \u0441 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435\u043c PROSENSE -  \u0432\u044b \u043f\u0435\u0440\u0435\u043d\u0435\u0441\u0435\u0442\u0435\u0441\u044c \u043d\u0430 \u0441\u043e\u0431\u044b\u0442\u0438\u0435, \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0432\u0430\u043c \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u043e, \u0433\u0434\u0435 \u0431\u044b \u043e\u043d\u043e \u043d\u0435 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u043b\u043e - be where you want to be!  \n\n\u0421\u0432\u044f\u0436\u0438\u0442\u0435\u0441\u044c \u0441 \u043d\u0430\u043c\u0438 \u0447\u0435\u0440\u0435\u0437 facebook(https://www.facebook.com/Prosense.tv ) \n\u0438\u043b\u0438 email hello@prosense.tv", "short_description": "\u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 PROSENSE - \u0442\u0432\u043e\u0439 \u044d\u043a\u0441\u043a\u043b\u044e\u0437\u0438\u0432\u043d\u044b\u0439 \u0434\u043e\u0441\u0442\u0443\u043f \u043a \u043d\u0430\u0438\u0431\u043e\u043b\u0435\u0435 \u0437\u0440\u0435\u043b\u0438\u0449\u043d\u044b\u043c \u0441\u043e\u0431\u044b\u0442\u0438\u044f\u043c \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 \u0412\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0420\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438. \u0423\u0441\u0442\u0430\u043d\u0430\u0432\u043b\u0438\u0432\u0430\u044f \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0