enshot-4_v2.png", "id": "927824121486073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_927824124819406_2964890372995800077_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V4dBOGmhij0Q7kNvgGlUoll&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvdQYaq2Ue2Ujn4r2kV1I3WiCXNsEgIweO_Kmf9n-TKw&oe=66D835DB"}, {"file_name": "screenshot-3.png", "id": "370773844371958", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974824_370773851038624_5748969745682492719_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hs3PJWD-htwQ7kNvgGctVRn&_nc_ht=scontent.oculuscdn.com&oh=00_AYC83FSoBr8JE-04pDsLFZ1Zfc-nMwAcUflsjVK9GGZSTA&oe=66D829AD"}, {"file_name": "screenshot-5.png", "id": "443029733325686", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210398_443029736659019_6449814880897090248_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-DW1coX6D2cQ7kNvgGS_8zN&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-pbb7G7gr_cTC8UIlivAUJsGNPhJ8BZ66sHjczurfWA&oe=66D85A0B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus-Thumbnail.png", "id": "3009970792661767", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036632_3009970795995100_8495805163915112358_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=usdmPmeKsfcQ7kNvgFYgi5z&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxQa1zbfBoeaRV2seT858Z0RAYoS8XOQucwIWv_egXDA&oe=66D83AF2"}, "display_name": "Shotwood", "keywords": [], "long_description": "Shotwood is a single player shooting game, with realistic guns and full reload mechanics. Duck and dodge between cover in full roomscale VR!\n\nWelcome to the facility. Here you'll complete combat assessments - killhouse scenarios - clearing floors of deadly wooden targets.\n\nBeat challenges to earn credits. Spend them on different firearms, attachments, and ammo. You'll need to buy LOTS of bullets!\n\nUse the gun range to toy with each weapon simulation, or dive into a shoothouse floor and blast away. Tactical shooter or action hero, it's up to you.\n\nNasty case of shell-shock coming on? Take a break and enjoy the minigames! Balloon Stabber and Brick Shield. Or gamble away your earnings playing cards, with the Simple Jack arcade game.\n\nAce every challenge in an intense action-packed weekend, or duck in for 10 minutes to smash an assessment, and bail back out with time left for lunch.\n\nShotwood VR is the casual, offline, FPS game that you can play your own way.", "short_description": "Welcome volunteer! Prepare for your new life at 'the facility'. A life of assessments, challenges, and of course; shooting wood!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.concretebox.net/privacy.html", "developer_terms_of_service_url": "https://www.concretebox.net/terms.html", "publisher_name": "Concrete Box", "support_website_url": null, "website_url": "https://www.concretebox.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "CASUAL", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1256803971477952"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1543460822922085"}, {"status": "PUBLISHED", "id": "198226459088016"}]}, "baseline_offer": {"id": "198226459088016"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1543460822922085"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8417449231603638", "version": "1047"}, "id": "3666359086773967", "channel_name"