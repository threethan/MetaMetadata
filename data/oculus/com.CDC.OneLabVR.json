 "Core_Lab.png", "id": "965824571045485", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/57575356_965824574378818_5408282902568678505_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=415mBSSkaQEQ7kNvgEoa9hD&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYB9u5NAlhhQDLobLDnrxxdBRNV7PUFmWgBYvD2Sf58PnA&oe=672A12D4"}, {"file_name": "BSC.png", "id": "454363530193551", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974580_454363533526884_4384150340550210189_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZmJfLwhStZsQ7kNvgFjB4pF&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDOHizvfvS61u6-ThgiSjvGoibJluIHzZV5ojXqAxyzeQ&oe=6729EC68"}, {"file_name": "Equip_1.png", "id": "653529576459894", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974826_653529579793227_8275410732036232651_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MyVgAFi8Jb0Q7kNvgGDH11n&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBxl-x3Egi29HojdjAq1txvwWOBG8JvcHf9KScHJhUBjA&oe=6729FF51"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage.png", "id": "231913949546850", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39036614_231913952880183_1828654917417058474_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U0oxq2bl7PIQ7kNvgFNz1CZ&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDQf9DWhpKOwPEQjprZm_UBabHXO5BEe24eaqd9qgX-xA&oe=672A0C0C"}, "display_name": "OneLabVR", "keywords": [], "long_description": "Situated on the 4th floor of a fictitious building, OneLabVR encompasses a 50,000 square foot facility that is focused on clinical and public health laboratory training. OneLabVR includes 12 different laboratories, and over 100 (and counting) laboratory-specific pieces of hardware and equipment. \n\nWorking extensively with laboratory architects, designers, safety experts, and members of the laboratory community, we created this virtual training space for your training needs. Everything from the physical size and placement of laboratory environments to simple things like placement of fire alarms and sprinkler systems has been rigorously researched, tested, and reviewed for users like you. \n\nCDC will be releasing quarterly updates to OneLabVR featuring tutorials, additional standalone training, multiplayer scenarios, and accessibility tools. As the need grows and new training programs are developed, CDC will provide training materials and guidance that will allow individuals to create their own training in the OneLabVR environment.", "short_description": "Situated on the 4th floor of a fictitious building, OneLabVR encompasses a 50,000 square foot facility that is focused on clinical and public health laboratory training. OneLabVR includes 12 different laboratories, and over 100 (and counting) laboratory-specific pieces of hardware and equipment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cdc.gov/labtraining/training-courses/VR_Training_Privacy_Policy_Page.html", "developer_terms_of_service_url": null, "publisher_name": "Centers for Disease Control and Prevention", "support_website_url": "https://www.cdc.gov/labtraining/onelab/onelabvr.html", "website_url": "https://www.cdc.gov/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "794607812260786"}}]}, "scheduled_offers": {"count