4844_521486569742765_7179524105465731980_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6fyuoft0sJsQ7kNvgG25Vb7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmgOa7vxdb5MUzQeJR1cb0zyWgYwiRWhFCi8gXfwTSHg&oe=6763F35C"}, {"file_name": "20220829-235223.png", "id": "349174444000845", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035421_349174447334178_5455449181583213884_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0OWSeeZHx18Q7kNvgEuxnW3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5FPG1BguwOuY7vvNck501n6YvUmxxeHQtAZ9QUe4W-g&oe=6763FC99"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "20220817-124152.png", "id": "477277443868888", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974721_477277447202221_2566098246160369602_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03mMx0W_kvQQ7kNvgHtJoiq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACI6iaSul7do5DYtO5LgyYPoEofOTe5qzDBC4YdEz3og&oe=6763FFA5"}, "display_name": "TOKYO GAME SHOW VR 2022", "keywords": [], "long_description": "This is the official VR application of TOKYO GAME SHOW VR 2022.\n\nAn evolved Tokyo Game Show's virtual site is returning this fall!\nYou will be an explorer searching \u201cGAME STOPE\u201d - the dungeon spreads in the underground of Makuhari Messe Event Hall.\nLet\u2019s enjoy visiting booths of various game companies, a special exhibition where you can look back at the history of games, and more!\n\nOnce you enter the venue, you will be greeted by famous characters and will immediately feel the drastic changes from last year.\nAdding to existing functions such as Voice Chat, HELLO, and Stamps, there will be new features that make the Game Show more enjoyable and playable.\n\u00b7 Avatar Customization: Freely customize your avatar body parts and outfits!\n\u00b7 Quest System: Advance the story and earn items by completing quests!\n\nEarn Three Sacred Treasures and check out what's at the bottom of the strata with your own eyes!\n\nEvent Period: September 15th (Thur.) 10:00 JST - September 18th (Sun.) 24:00 JST, 2022", "short_description": "This is the official VR application of TOKYO GAME SHOW VR 2022.\n\nAn evolved Tokyo Game Show's virtual site is returning this fall!\nLet\u2019s enjoy visiting various game companies' booths and a special exhibition at \u201cGAME STOPE\u201d in the underground of Makuhari Messe.\n\nOnce you enter the venue, you will be greeted by famous characters and find more enjoyable and playable elements.\nWith new features such as Avatar Customization and Quest System, the Game Show itself will be a gaming experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ambr.co.jp/privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "TOKYO GAME SHOW Studios", "support_website_url": null, "website_url": "https://tgsvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL", "TRAVEL", "ADVENTURE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5174300682695996"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210391_405669291682641_508344702576618105_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uvJ2z3_29fkQ7kNvgEDGYLq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfyGGCtoPqhbqxdR213x8c2ZAiL5TfsurT889izp0NqA&oe=67641B