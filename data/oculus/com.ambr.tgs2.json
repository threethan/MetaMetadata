l1lKX&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADE7yz4SOgq7AeVfhxkQ9V9-IW197vmZuj_12bVFOxUg&oe=6707AA5C"}, {"file_name": "20220829-235223.png", "id": "349174444000845", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035421_349174447334178_5455449181583213884_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GfDPfGIYM1oQ7kNvgH8VfAR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBq_v1DR8LCoArcGVGBvMxTkD-4fJYlyPU7itP0roWP7Q&oe=6707B399"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "20220817-124152.png", "id": "477277443868888", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974721_477277447202221_2566098246160369602_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0czAniuBwP8Q7kNvgE0hEUa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_04uhwWO7jTRXBIw5Qeb_uTwhOGIO_v6MjBmjZZRIyA&oe=6707B6A5"}, "display_name": "TOKYO GAME SHOW VR 2022", "keywords": [], "long_description": "This is the official VR application of TOKYO GAME SHOW VR 2022.\n\nAn evolved Tokyo Game Show's virtual site is returning this fall!\nYou will be an explorer searching \u201cGAME STOPE\u201d - the dungeon spreads in the underground of Makuhari Messe Event Hall.\nLet\u2019s enjoy visiting booths of various game companies, a special exhibition where you can look back at the history of games, and more!\n\nOnce you enter the venue, you will be greeted by famous characters and will immediately feel the drastic changes from last year.\nAdding to existing functions such as Voice Chat, HELLO, and Stamps, there will be new features that make the Game Show more enjoyable and playable.\n\u00b7 Avatar Customization: Freely customize your avatar body parts and outfits!\n\u00b7 Quest System: Advance the story and earn items by completing quests!\n\nEarn Three Sacred Treasures and check out what's at the bottom of the strata with your own eyes!\n\nEvent Period: September 15th (Thur.) 10:00 JST - September 18th (Sun.) 24:00 JST, 2022", "short_description": "This is the official VR application of TOKYO GAME SHOW VR 2022.\n\nAn evolved Tokyo Game Show's virtual site is returning this fall!\nLet\u2019s enjoy visiting various game companies' booths and a special exhibition at \u201cGAME STOPE\u201d in the underground of Makuhari Messe.\n\nOnce you enter the venue, you will be greeted by famous characters and find more enjoyable and playable elements.\nWith new features such as Avatar Customization and Quest System, the Game Show itself will be a gaming experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ambr.co.jp/privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "TOKYO GAME SHOW Studios", "support_website_url": null, "website_url": "https://tgsvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL", "TRAVEL", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5174300682695996"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210391_405669291682641_508344702576618105_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sE8zZATcyyIQ7kNvgFFFn6j&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIEkdKJktesI6x9OF1uwrM7mlrVL9V_zp_P67mmEeJvw&oe=6707D2EF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TOKYO GAME SHOW VR 2022", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "