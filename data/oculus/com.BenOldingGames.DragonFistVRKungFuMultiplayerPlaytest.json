-7&_nc_sid=6e7a0a&_nc_ohc=q1-YOV6yfjIQ7kNvgFRXYkp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU6NyvlJimnIJRyP5gib741&oh=00_AYC8ct6F5-jzEDahr3bVpvmwdyrjZPSdwHgt6oEh4fbfFg&oe=66D98B4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "playtest main capsule oc.png", "id": "219723111022984", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031446_219723114356317_5827204287518780281_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iOOiGdgX978Q7kNvgEdXkWS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU6NyvlJimnIJRyP5gib741&oh=00_AYBMw6NqQeQHzNm78z9zxawvPIDQiu_ISlLfN5HJFk0dBw&oe=66D98D90"}, "display_name": "Dragon Fist: VR Kung Fu [Multiplayer Play Test]", "keywords": [], "long_description": "Be a part of the next evolution of Dragon Fist: VR Kung Fu with our Multiplayer Playtest! Help us test, expand, and break new features while getting an early look at what is to come. \n\nStep into your own kung fu movie with legendary characters inspired by martial arts movies across the decades. Whether you fancy playing as an old wise master, or a young gifted female kung fu student, or a shaolin monk, Bruce Lee inspired character, samurai or a ninja there's bound to be someone for you...\n\nHow you fight is up to you. But your opponents might use different strategies also, so you must learn how to foresee their attacks and how best to attack them.\n\nYou opponents all have the same controls as you, no advantage, no disadvantage. Except on easier levels they will have less strength - they will also have their speed and intelligence reduced.", "short_description": "Playtest all upcoming Dragon Fist: VR Kung Fu features such as Multiplayer, Co-op, new interactions, and more! This playtest is available for everyone and will feature experimental features. Have fun! "}]}, "developer_name": "Ben Olding Games", "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "w