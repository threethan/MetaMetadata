1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1H8_dgArYjUQ7kNvgHqPkAo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXxS33g9kVR-vFpfCW4RrKPqc6fOxT8G_z_qZgdlHlaA&oe=66E6BC90"}, "display_name": "Dragon Fist: VR Kung Fu [Multiplayer Play Test]", "keywords": [], "long_description": "Be a part of the next evolution of Dragon Fist: VR Kung Fu with our Multiplayer Playtest! Help us test, expand, and break new features while getting an early look at what is to come. \n\nStep into your own kung fu movie with legendary characters inspired by martial arts movies across the decades. Whether you fancy playing as an old wise master, or a young gifted female kung fu student, or a shaolin monk, Bruce Lee inspired character, samurai or a ninja there's bound to be someone for you...\n\nHow you fight is up to you. But your opponents might use different strategies also, so you must learn how to foresee their attacks and how best to attack them.\n\nYou opponents all have the same controls as you, no advantage, no disadvantage. Except on easier levels they will have less strength - they will also have their speed and intelligence reduced.", "short_description": "Playtest all upcoming Dragon Fist: VR Kung Fu features such as Multiplayer, Co-op, new interactions, and more! This playtest is available for everyone and will feature experimental features. Have fun! "}]}, "developer_name": "Ben Olding Games", "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://dragonfistvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommend