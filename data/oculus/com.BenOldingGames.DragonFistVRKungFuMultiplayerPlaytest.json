=scontent-ams2-1.oculuscdn.com&oh=00_AYA2KmuI3aYd59HpTL8a7q4abqoevszuMKnob61miGy72A&oe=678105B6"}]}, "id": "1024576342289382", "locale": "en_US", "screenshots": [{"file_name": "aplb - ss1.png", "id": "628481575762177", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001664_628481579095510_2571194579478916259_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oO_Dz24EhFIQ7kNvgFBG8K5&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC4oHsVjMaIcOPV6sRzP7wU1VLGHwq-0NcWmVYtW0P0iQ&oe=678109F6"}, {"file_name": "aplb - ss5.png", "id": "189158564047762", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974885_189158567381095_2590099101629890264_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CBUM3HuHnb0Q7kNvgHN_ovm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBIgSQIjE2wIWe9ssWU_JLpgSMjMEVO5ycOqs_ff0FUNA&oe=67812240"}, {"file_name": "aplb - ss4.png", "id": "978800080023439", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982619_978800083356772_4918853589962715064_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NlAuBLHSGHwQ7kNvgFobRUR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDPCoiT0xf9GVYA4A1qRk0cGDM399iOjam7t4jFIIJ7Jg&oe=6780EC2D"}, {"file_name": "aplb - ss2.png", "id": "3805304573031216", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57566686_3805304576364549_4697030718551306604_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CxhD_EGWkT8Q7kNvgG45iSf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCuf9A6SmYAFwq6eK0RX6kt2tVY67u88zrw2sWDbD0ZSQ&oe=67811EFE"}, {"file_name": "aplb - ss3.png", "id": "823840649246178", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974645_823840655912844_5288026250863127288_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YxzbLR5K8QAQ7kNvgHwLUjQ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBHsPKRcTkql7Ms-udNl435dOUXDFO5WDn77etl99SKaw&oe=6780F9CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "playtest main capsule oc.png", "id": "219723111022984", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031446_219723114356317_5827204287518780281_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n9C8TgaXKRsQ7kNvgFd3chA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAu2VHijcl2BoXU3IJjbqzvLD_lNuSvi41W4fuo90s68Q&oe=6780FC10"}, "display_name": "Dragon Fist: VR Kung Fu [Multiplayer Play Test]", "keywords": [], "long_description": "Be a part of the next evolution of Dragon Fist: VR Kung Fu with our Multiplayer Playtest! Help us test, expand, and break new features while getting an early look at what is to come. \n\nStep into your own kung fu movie with legendary characters inspired by martial arts movies across the decades. Whether you fancy playing as an old wise master, or a young gifted female kung fu student, or a shaolin monk, Bruce Lee inspired character, samurai or a ninja there's bound to be someone for you...\n\nHow you fight is up to you. But your opponents might use different strategies also, so you must learn how to foresee their attacks and how best to attack them.\n\nYou opponents all have the same controls as you, no advantage, no disadvantage. Except on easier levels they will have less strength - they will also have their speed and intelligence reduced.", "short_description": "Playtest all upcoming Dragon Fist: VR Kung Fu features such as Multiplayer, Co-op, new interactions, and more! This playtest is available for everyone and will feature experimental features. Have fun! "}]}, "developer_name": "Ben Olding Games", "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://dragonfistvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "p