/v/t64.5771-25/38974593_636036640827386_5574898335345545828_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tedoggqjokEQ7kNvgFUNGi0&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAVnXKTjke9dDVHfQ7PiiTmBB8ws_EqFA0zu9ue2Tk-Qg&oe=67010CE7"}, {"file_name": "Screenshot_com.VRFactory.VRBartenderSymulator_2022.03.23-07.33.16.781_056.png", "id": "1131739147592444", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031427_1131739150925777_6967941911669488657_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aetSiZ8aO6kQ7kNvgH7uSn9&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYACzKa_w2mfGZmEwzAocltGxMbGJTz2z_wcVgf--4LQLg&oe=67010E39"}, {"file_name": "Screenshot_com.VRFactory.VRBartenderSymulator_2022.03.23-07.34.06.936_774.png", "id": "674566467023618", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569445_674566470356951_7066716002191437089_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9rkbLns5fnQQ7kNvgEpNaAu&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDYBUHSugp-pIP5Ga3L7HySTtDXgR_EjRGnYWroJ9lrjw&oe=67011C8D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Bartender_2560x1440_betaversion_001.png", "id": "174009265468444", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974515_174009268801777_927155774712427092_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hS6r9j0P1s4Q7kNvgEyImI0&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAXiVBzosA2llIe469OfR-r2fAj6SVE4aIloU4oalmF9A&oe=67012FD8"}, "display_name": "BARTENDER VR SIMULATOR beta version", "keywords": [], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. Begin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. Master more and more demanding drinks as you progress to new, unique bars.\n\nA range of drinking glasses to chose from, different liquors, beverages and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Real-life liquid physics and item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\nWho will earn most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? ", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. Developed in cooperation with a six-time Bartending World Champion, Tomek Malek"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory Games S.A.", "support_website_url": "http://www.bartendervrsimulator.com/", "website_url": "http://www.bartendervrsimulator.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7177393659048305"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031612_951691626122015_6533183965367935382_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XwN0ieV