566470356951_7066716002191437089_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_guL3MIdoRAQ7kNvgEwEdHu&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB_Gn6tt2NprFAQ-HF2GiG2c-zdb3ycIUcMWAwych7OSA&oe=6756CE0D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "db1c4c5d53e8430f200cfb9e298a0d37.png", "id": "359125009450435", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031379_359125016117101_6015394047178847806_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bb9JOVFsInkQ7kNvgFzPbJ2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCZovvf-0ateSPmXdX-xgFADEAZuEeCXnKndwzB9JinXw&oe=6756C18B"}, "display_name": "Bartender VR Simulator", "keywords": [], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. Begin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. Master more and more demanding drinks as you progress to new, unique bars.\n\nA range of drinking glasses to chose from, different liquors, beverages and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Real-life liquid physics and item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\nWho will earn most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? ", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. Developed in cooperation with a six-time Bartending World Champion, Tomek Malek"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory", "support_website_url": null, "website_url": "http://www.bartendervrsimulator.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "683736672958581"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1474364606362225"}, {"status": "PUBLISHED", "id": "672700367134970"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1654095600, "status": "PUBLISHED", "id": "1474364606362225"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8613285818792408", "version": "1.9.2.4"}, "id": "529160918436459", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4790705267717168", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8613285818792408"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732811229, "id": "8652903108164012", "version": "xmass", "version_code": 1275, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "86529019548