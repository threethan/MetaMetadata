A1ADjRTpZaRNr5Z6cK5odtng&oe=67332586"}, {"file_name": "Screenshot_com.VRFactory.VRBartenderSymulator_2022.03.23-07.34.53.746_672.png", "id": "636036637494053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974593_636036640827386_5574898335345545828_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ObDxNDOvb4Q7kNvgE2CqO8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmHn1zDK1j5liPfFbJVPGtpCMfOS3b7OOsku97p--aMA&oe=673325E7"}, {"file_name": "Screenshot_com.VRFactory.VRBartenderSymulator_2022.03.23-07.33.16.781_056.png", "id": "1131739147592444", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031427_1131739150925777_6967941911669488657_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZcucnnFTkX0Q7kNvgFrRnd4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABulAhSpCzCXkYRW7n3ydy4yS086fdpmasZlQnb1Zaww&oe=67332739"}, {"file_name": "Screenshot_com.VRFactory.VRBartenderSymulator_2022.03.23-07.34.06.936_774.png", "id": "674566467023618", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569445_674566470356951_7066716002191437089_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f1F5C9mt9ikQ7kNvgFv2QlW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIQvnXO2-puTgMYlEj_DutqEIosvFp0iFqJCusbJv4qg&oe=6733358D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Bartender_2560x1440_betaversion_001.png", "id": "174009265468444", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974515_174009268801777_927155774712427092_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hdlUJsVES_gQ7kNvgFPjUjN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxa9C5_ALYsD_8UUvdGN1gDQBUpIOsbBTN7_UgqSDwhw&oe=673348D8"}, "display_name": "BARTENDER VR SIMULATOR beta version", "keywords": [], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. Begin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. Master more and more demanding drinks as you progress to new, unique bars.\n\nA range of drinking glasses to chose from, different liquors, beverages and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Real-life liquid physics and item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\nWho will earn most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? ", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. Developed in cooperation with a six-time Bartending World Champion, Tomek Malek"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory Games S.A.", "support_website_url": "http://www.bartendervrsimulator.com/", "website_url": "http://www.bartendervrsimulator.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7177393659048305"}, "review_messages": [