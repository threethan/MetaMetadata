aoz8z3sOE9JME8iV3NxgdU0islG26JjCrqTv7zFi9Aw&oe=673C8B73"}, {"file_name": "Master-4.png", "id": "557489166409298", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540503_557489169742631_6163921996793232814_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fy-2jf_lCKMQ7kNvgEVTv0s&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCftMsUOoAvPe8QdSl216BHfjEJxhsFAcx78PmkX_2s9g&oe=673C8425"}, {"file_name": "Master-5.png", "id": "6776745459089236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568722_6776745462422569_646325243917089556_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gwk--Hun7HwQ7kNvgGjVab5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkkdOLEWSp7HT_uGyQ_l22KVwqd1oB8l4FrOikhsBYqw&oe=673C6340"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Master-3.png", "id": "740231434164987", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75241700_740231437498320_1452555169856770047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJ7s8gfKBpEQ7kNvgHZk7qd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC03827TsdDJpT4VfCSG5w3depES66WgvCDXgfMZru6zQ&oe=673C8922"}, "display_name": "Spear Master", "keywords": [], "long_description": "Spear-throwing Challenge is a fast-paced and addictive game that tests your aim and dexterity. In this game, you'll take turns throwing a spear at a target, with the goal of hitting the bullseye or a designated area on the target to progress to the next section. \nYou'll be racing against an AI opponent, so you'll need to be quick and accurate if you want to come out on top.\nThe difficulty increases as you progress through the sections, with longer distances, more challenging targets, and obstacles to avoid.\n\nSo what are you waiting for? Download Spear-Master today and see if you have what it takes to become the ultimate champion!", "short_description": "Put your skills to the test with Spear-throwing Challenge! \nRace against an opponent to see who can hit the target and progress through the sections the fastest. \nChoose your preferred spear and adjust your aim to become the ultimate champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.am-apps.at/wordpress/?page_id=81", "developer_terms_of_service_url": null, "publisher_name": "AM Apps", "support_website_url": null, "website_url": "http://www.am-apps.at/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "726745482258899"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974593_889422209058677_3452463327476988892_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d_3fc5x23vIQ7kNvgEjUel1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA87eyjnP4ARXcTD5Qbg-svz0ftadWpi8Yy0IrTtxly0Q&oe=673C64E3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spear Master", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1677535007, "lastRevision": {"nodes": [{"id": "5693862134045677", "release_type": "SCHEDULED", "administration_