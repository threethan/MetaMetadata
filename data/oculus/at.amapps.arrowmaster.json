cles to avoid.\n\nSo what are you waiting for? Download Spear-Master today and see if you have what it takes to become the ultimate champion!", "short_description": "Put your skills to the test with Spear-throwing Challenge! \nRace against an opponent to see who can hit the target and progress through the sections the fastest. \nChoose your preferred spear and adjust your aim to become the ultimate champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.am-apps.at/wordpress/?page_id=81", "developer_terms_of_service_url": null, "publisher_name": "AM Apps", "support_website_url": null, "website_url": "http://www.am-apps.at/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "726745482258899"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "207262081961707"}]}, "baseline_offer": {"id": "207262081961707"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677534960, "status": "PUBLISHED", "id": "207262081961707"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5815629148535641", "version": "0.4"}, "id": "585651030075886", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary