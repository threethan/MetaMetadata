kAyrcjZNFoUqMAaIjcCTZfqcc6Y-NaFyRElbKwk4QNA&oe=673896F3"}, {"file_name": "Master-4.png", "id": "557489166409298", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540503_557489169742631_6163921996793232814_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uX8RRuDnq8sQ7kNvgF7s4Kw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvTsdLN3Zc9xjGf13J_w91ebiCOsMtMcz9CccfN5hQAw&oe=67388FA5"}, {"file_name": "Master-5.png", "id": "6776745459089236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568722_6776745462422569_646325243917089556_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fky3HwfPiJkQ7kNvgFqsJFN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAF8xVCbAs4oueDvQKBTHIBI3l5FRJvwemNKyT9AUcaMQ&oe=67386EC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Master-3.png", "id": "740231434164987", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75241700_740231437498320_1452555169856770047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yji3P6NULT0Q7kNvgFxDRbS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCP3NZn-NDmTQsXLM62A_XGkgfkV8hWs91Js8xnn-jppw&oe=673894A2"}, "display_name": "Spear Master", "keywords": [], "long_description": "Spear-throwing Challenge is a fast-paced and addictive game that tests your aim and dexterity. In this game, you'll take turns throwing a spear at a target, with the goal of hitting the bullseye or a designated area on the target to progress to the next section. \nYou'll be racing against an AI opponent, so you'll need to be quick and accurate if you want to come out on top.\nThe difficulty increases as you progress through the sections, with longer distances, more challenging targets, and obstacles to avoid.\n\nSo what are you waiting for? Download Spear-Master today and see if you have what it takes to become the ultimate champion!", "short_description": "Put your skills to the test with Spear-throwing Challenge! \nRace against an opponent to see who can hit the target and progress through the sections the fastest. \nChoose your preferred spear and adjust your aim to become the ultimate champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.am-apps.at/wordpress/?page_id=81", "developer_terms_of_service_url": null, "publisher_name": "AM Apps", "support_website_url": null, "website_url": "http://www.am-apps.at/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "726745482258899"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974593_889422209058677_3452463327476988892_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e2AkIsNz_tMQ7kNvgGRfQYA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ1JMMO_1xPkmbDdMvPgpYwSS06y1mwu3cn3IRKFBkdQ&oe=67387063"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spear Master", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1677535007, "lastRevision": {"nodes": [{"id": "5693862134045677", "release_type": "SCHEDULED", "administration_