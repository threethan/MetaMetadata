e": "Master-3.png", "id": "771643413817570", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210896_771643417150903_4303972191552407160_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=27684iBac6UQ7kNvgFYJvw_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDzSTDgILqBg7vw3dt9CZJor4LMD0ZeFdfJzd9ofPOIRw&oe=677A81F3"}, {"file_name": "Master-4.png", "id": "557489166409298", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540503_557489169742631_6163921996793232814_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hKdSj3v4ytQQ7kNvgHJgY0Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnLpzoN7T8YoEQxti7j_p07iegHGJdVLJrzmqgxRzH4g&oe=677A7AA5"}, {"file_name": "Master-5.png", "id": "6776745459089236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568722_6776745462422569_646325243917089556_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HaBk70PSniMQ7kNvgEea5qq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2IWKu3diwlgm3OCs3rDMgy9Ft3fBazYvUv9FPmD_D1g&oe=677A59C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Master-3.png", "id": "740231434164987", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75241700_740231437498320_1452555169856770047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rVSfI21q-2cQ7kNvgE_ZL9c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkQ-OWzi6upW3ylBdDun-xTXW__-M5uMnCkfj9xUk0fg&oe=677A7FA2"}, "display_name": "Spear Master", "keywords": [], "long_description": "Spear-throwing Challenge is a fast-paced and addictive game that tests your aim and dexterity. In this game, you'll take turns throwing a spear at a target, with the goal of hitting the bullseye or a designated area on the target to progress to the next section. \nYou'll be racing against an AI opponent, so you'll need to be quick and accurate if you want to come out on top.\nThe difficulty increases as you progress through the sections, with longer distances, more challenging targets, and obstacles to avoid.\n\nSo what are you waiting for? Download Spear-Master today and see if you have what it takes to become the ultimate champion!", "short_description": "Put your skills to the test with Spear-throwing Challenge! \nRace against an opponent to see who can hit the target and progress through the sections the fastest. \nChoose your preferred spear and adjust your aim to become the ultimate champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.am-apps.at/wordpress/?page_id=81", "developer_terms_of_service_url": null, "publisher_name": "AM Apps", "support_website_url": null, "website_url": "http://www.am-apps.at/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "726745482258899"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5815629148535641", "version": "0.4"}, "id": "585651030075886", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5693862130712344", "is_concept": false, "latest_released_binary": 