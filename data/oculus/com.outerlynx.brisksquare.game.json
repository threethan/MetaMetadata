-22 17-52-35 (0-00-06-47).png", "id": "297589002391485", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572948_297589012391484_3787102876524498545_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kv-uNngMqpEQ7kNvgE7UnCb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC70jAu3lr_iJ5XbCrUhLAXIO4i9RgYAM-8F9r_VvATEw&oe=673DC7FD"}, {"file_name": "2022-01-22 17-52-35 (0-00-05-11).png", "id": "1084353699016907", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984447_1084353702350240_2933415590870248678_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-m5_naJYpfsQ7kNvgERnZ1p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBxDOW-Cz6c2jU8LGhxYILFg-2PCCsc3xpvcZlSvrxYVQ&oe=673DCC72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape_2560x1440 new.png", "id": "445289890711681", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031629_445289894045014_2099929920867611179_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=26icH9g5Pp0Q7kNvgHlxPvF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAq8NV-e7JMX7pd36BxXnqadfb7JnptJVv2DYGENBLj7g&oe=673DB291"}, "display_name": "Brisk Square", "keywords": [], "long_description": "The only Infinite Run game in VR!\nChallenge your friends in an infinite run gameplay and see who emerges victorious. Enter a cyberpunk world and enjoy multiple game modes:\n\nMultiplayer Mode\nCampaign Mode\nDual Wield Mode\nBrisk Mode\n\nFuture! In the wake of a cataclysm! You are the prey in a world full of hunters. Run, overpower them and free the violent streets in this intensively fast-paced cyber adventure. Be the decisive last stand in an infinite run gameplay by starting with a simple blade and evolve step by step to unlock more advanced weapons. Make your way ahead in the game by sword-slashing with your one hand and use superior powers to push/pull/crash objects with your other one and collect enough points to reach the top of a worldwide leaderboard.", "short_description": "The only Infinite Run game in VR!\n\nChallenge your friends in an infinite run gameplay and see who emerges victorious. Enter a cyberpunk world and enjoy multiple game modes:\n\nMultiplayer Mode\nCampaign Mode\nDual Wield Mode\nBrisk Mode\n\nFuture! In the wake of a cataclysm! You are the prey in a world full of hunters. Be the last stand in an infinite run gameplay by starting with a simple blade and evolve to unlock more advanced weapons."}]}, "developer_name": "Outerlynx", "developer_privacy_policy_url": "https://outerlynx.com/brisk-square/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Outerlynx", "support_website_url": null, "website_url": "https://outerlynx.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8025128574236246"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572948_513498760027349_4846152387108758934_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZTOmGvQdeOgQ7kNvgEhmxpk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDf8OsisxqrMs4mtY0IHL1Fkw6NGV4Akvuiu-EigseNHA&oe=673DBA35"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Brisk Square", "platform": "ANDROID_6DOF", "conte