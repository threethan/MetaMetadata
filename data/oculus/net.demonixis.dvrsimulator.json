tO6g6RfWpXetNjKavRRVnAQ9raWQuXt5cWV14GXw&oe=67431AF6"}, {"file_name": "Screen4.png", "id": "539088520607883", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75617327_539088523941216_1542448400021589127_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ICZQMz7a3mgQ7kNvgH3iLfd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUIbCH_8cvfEJRWqBZtRzY92umHCEopmtm37CMWEfNEg&oe=67430C51"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DVR Simulator_2021-04-08_21-48-53.png", "id": "806780961421519", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422394_806780964754852_8255125831375478688_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nFXWAYvs8QoQ7kNvgEDS6FA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXYWqw_Qu6hWyNk8JQ7XtPm1aVGy604FBQdxyL5PTT2w&oe=67430790"}, "display_name": "DVR Simulator", "keywords": [], "long_description": "DVR Simulator is a Drone Racing FPV Simulator. It features two flight modes, Freestyle and Racing. Simulates FPV Goggles using your VR headset. Many modes are available. With Mixed Reality you can control your drone and learn how to pilot without breaking anything. You can also create your own race!\n\nAn in-game editor allows you to tweak the drone's physics. You can also save your profiles and use them later. The profile format is open so you can share it with your friends.\n\nGamepads are supported and enabled by default. Radio transmitters are currently partially supported. You can play with VR controllers but it is recommanded to enable some confort options : Throttle Lag or Sticky Throttle.\n\n- 8 levels\n- Many drones\n- 2 game modes: Freestyle and Racing\n- A tons of options", "short_description": "DVR Simulator is a Drone Racing FPV Simulator. It features two flight modes, Freestyle and Racing. Simulates FPV Goggles using your VR headset. Many modes are available."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.demonixis.net/privacy-policy/", "developer_