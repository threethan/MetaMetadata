6555_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0rOfL_9Ikw4Q7kNvgEq0vQV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1EArPG06vTzi5OF0I2U_6fmVlAm18_gtKzLtKMopZ8Q&oe=6703B88F"}, {"file_name": "Untitled design (40).png", "id": "484591624282968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982555_484591630949634_4303247271567844434_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZnkTkHxiPW4Q7kNvgHueP1q&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDe94uSLn_WbmIs9Y03t0DVBl9i-L90LrtqDjLS_Ok-Fw&oe=6703E135"}, {"file_name": "Untitled design (41).png", "id": "868217155221901", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974450_868217158555234_4833863825953062561_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=euppy6sjceEQ7kNvgGA21Zp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdtNmjsmOKo9RyiSn0ZV2zpRZpW5g5oM8n6awbGvHchA&oe=6703C7A3"}, {"file_name": "Untitled design (42).png", "id": "473639632245009", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974468_473639635578342_1855917357853873321_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JI65WoMSsa0Q7kNvgHPuMyF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6pofmzItbnBnAZ8kpEE7Si-c183o_2QAv2yhVF7lRZw&oe=6703E229"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (50).png", "id": "1847952789060587", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974704_1847952792393920_573495990117697004_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LkX417hcWwcQ7kNvgHkG7br&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXHUtAeFb-27JdieCd51DoNhzVfCIQu8MMPcHQNMnmqg&oe=6703C6CD"}, "display_name": "Creepy Apes.", "keywords": [], "long_description": "dark, intricate mazes inhabited by terrifying, mutated apes. Each level presents a new labyrinth filled with unsettling twists, dead ends, and lurking dangers. Use your arms to crawl, climb, and maneuver through tight spaces as you search for an escape, all while avoiding the monstrous apes that hunt you down. Customize your character with eerie cosmetics, unlocking new looks as you progress. Join forces with friends in multiplayer mode, where communication is key to survival. Work together to solve puzzles, share strategies, and escape the deadly mazes. Can you survive the endless corridors and unravel the mystery within Creepy Apes? Or will you become their next victim?", "short_description": "Creepy Apes is a terrifying VR horror game set within a labyrinth of dark, twisted mazes inhabited by horrifying, mutated apes. Navigate through a series of increasingly complex mazes, from eerie industrial settings to shadowy underground tunnels, using intuitive arm movements to climb, push, and escape the lurking danger. Collect cosmetics to customize your character and join friends in multiplayer mode, where you can talk, strategize, and survive together. Each maze is packed with scary AI's"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1XLKOKPFbOgT3aZvCLbQy_wqzyS-iHznuBQOqUN49A74/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Snowzy VR", "support_website_url": null, "website_url": "https://matthewcrandon023.wixsite.com/creepy-apes", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7329545707148787"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1044708573902873"}]},