0yUMNC1vdXySPMKA0NKRLsU3jQ&oe=66FE728F"}, {"file_name": "Untitled design (40).png", "id": "484591624282968", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982555_484591630949634_4303247271567844434_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ibEjWylbGUAQ7kNvgGJCbfF&_nc_ht=scontent.oculuscdn.com&oh=00_AYC40kuIie2jsaB41Nq-RgJ6Ijc0gT1rTPM6iq4B7Ey5kQ&oe=66FE9B35"}, {"file_name": "Untitled design (41).png", "id": "868217155221901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_868217158555234_4833863825953062561_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OywwsAMega4Q7kNvgF_Y-3I&_nc_ht=scontent.oculuscdn.com&oh=00_AYAK5Nr0uayCZddjku5mnLaRt5qbLNGxxhO16MLpJbn0zw&oe=66FE81A3"}, {"file_name": "Untitled design (42).png", "id": "473639632245009", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974468_473639635578342_1855917357853873321_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FgqrHgPNj_kQ7kNvgF8X2uy&_nc_ht=scontent.oculuscdn.com&oh=00_AYAi8w47I5CNuzxu0Y5cOWfI_yi755LMiTTX2jI7-ScqzA&oe=66FE9C29"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (50).png", "id": "1847952789060587", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974704_1847952792393920_573495990117697004_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SnOxnCspdDMQ7kNvgFvW7CG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuuUlhA9DGrA0IyAwrGiUqm3vuGx5F2SvcbTjJM_md7A&oe=66FE80CD"}, "display_name": "Creepy Apes.", "keywords": [], "long_description": "dark, intricate mazes inhabited by terrifying, mutated apes. Each level presents a new labyrinth filled with unsettling twists, dead ends, and lurking dangers. Use your arms to crawl, climb, and maneuver through tight spaces as you search for an escape, all while avoiding the monstrous apes that hunt you down. Customize your character with eerie cosmetics, unlocking new looks as you progress. Join forces with friends in multiplayer mode, where communication is key to survival. Work together to solve puzzles, share strategies, and escape the deadly mazes. Can you survive the endless corridors and unravel the mystery within Creepy Apes? Or will you become their next victim?", "short_description": "Creepy Apes is a terrifying VR horror game set within a labyrinth of dark, twisted mazes inhabited by horrifying, mutated apes. Navigate through a series of increasingly complex mazes, from eerie industrial settings to shadowy underground tunnels, using intuitive arm movements to climb, push, and escape the lurking danger. Collect cosmetics to customize your character and join friends in multiplayer mode, where you can talk, strategize, and survive together. Each maze is packed with scary AI's"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1XLKOKPFbOgT3aZvCLbQy_wqzyS-iHznuBQOqUN49A74/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Snowzy VR", "support_website_url": null, "website_url": "https://matthewcrandon023.wixsite.com/creepy-apes", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7329545707148787"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1044708573902873"}]}, "baseline_offer": {"id": "1044708573902873"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726066260, "status": "PUBLISHED", "id": "1044708573902873"}]}, "liveChannel": {"nodes": 