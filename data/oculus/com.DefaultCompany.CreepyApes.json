6555_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=24Ar1X2EF2MQ7kNvgGp1S8I&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCSvEtkG8Oo5MoRKMqlnDJgGFXx1vOvlrTMfNUT6TXaXA&oe=6701158F"}, {"file_name": "Untitled design (40).png", "id": "484591624282968", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982555_484591630949634_4303247271567844434_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ibEjWylbGUAQ7kNvgFwmvL5&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA8hveuPck3dQCKdmYfzABgZy-HfXoZ4i39U8j3zzYP1g&oe=67013E35"}, {"file_name": "Untitled design (41).png", "id": "868217155221901", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974450_868217158555234_4833863825953062561_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5zsxNkalUrsQ7kNvgGg0qjf&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBKRQm_f5j1yeA1M1XRPlRmDsoc52Ho7HBHFV5aZo3HsQ&oe=670124A3"}, {"file_name": "Untitled design (42).png", "id": "473639632245009", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974468_473639635578342_1855917357853873321_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxJTdZhQhKgQ7kNvgGxFhiW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDknshbtgLkNwJQGehBg5HkX12TA7UIPyZAXi8_To5mMg&oe=67013F29"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (50).png", "id": "1847952789060587", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974704_1847952792393920_573495990117697004_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SnOxnCspdDMQ7kNvgFk9HDK&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA9ad_l7lbQmfRfuErGFDWZjcTR3RqlipPdv_aSewE7Kw&oe=670123CD"}, "display_name": "Creepy Apes.", "keywords": [], "long_description": "dark, intricate mazes inhabited by terrifying, mutated apes. Each level presents a new labyrinth filled with unsettling twists, dead ends, and lurking dangers. Use your arms to crawl, climb, and maneuver through tight spaces as you search for an escape, all while avoiding the monstrous apes that hunt you down. Customize your character with eerie cosmetics, unlocking new looks as you progress. Join forces with friends in multiplayer mode, where communication is key to survival. Work together to solve puzzles, share strategies, and escape the deadly mazes. Can you survive the endless corridors and unravel the mystery within Creepy Apes? Or will you become their next victim?", "short_description": "Creepy Apes is a terrifying VR horror game set within a labyrinth of dark, twisted mazes inhabited by horrifying, mutated apes. Navigate through a series of increasingly complex mazes, from eerie industrial settings to shadowy underground tunnels, using intuitive arm movements to climb, push, and escape the lurking danger. Collect cosmetics to customize your character and join friends in multiplayer mode, where you can talk, strategize, and survive together. Each maze is packed with scary AI's"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1XLKOKPFbOgT3aZvCLbQy_wqzyS-iHznuBQOqUN49A74/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Snowzy VR", "support_website_url": null, "website_url": "https://matthewcrandon023.wixsite.com/creepy-apes", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7329545707148787"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1044708573902873"}]},