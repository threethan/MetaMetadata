h our highly skilled team of specialists who provide application and service support on a global scale. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.phenom-world.com/", "developer_terms_of_service_url": "https://www.phenom-world.com/", "publisher_name": "Phenom World", "support_website_url": null, "website_url": "https://www.phenom-world.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "904649030225682"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331199_1441284982579531_2100555181761495040_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6fRkWsFMUsQ7kNvgGhLpla&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4vEBnufsuBZX8J4fIcOuAo&oh=00_AYDgFi-Eh2KHY_CajZgccU8VPboQBst7L2pA-CU4d_exew&oe=66F53F49"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PhenomVR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1489561200, "lastRevision": {"nodes": [{"id": "182585278906533", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1406387342739529", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1523272127713569"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "38811