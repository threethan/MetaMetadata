rs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKqn-cNbU-VnO3GTLievhJFZAWJvXTzHlwoWAfqcNEhQ&oe=6762AD57"}, {"file_name": "Screenshot Pitching Focus_2560x1440.png", "id": "574645060927542", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982497_574645064260875_2276229677728320493_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ae4t5B3ocuwQ7kNvgH0shW4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUAllNRHPZUJjWdown_qkfxI2z3C9Uokmu2QsAzgPEZg&oe=6762B6F0"}, {"file_name": "Screenshot Fielding_2560x1440.png", "id": "1488034254944276", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404383_1488034258277609_7410707247810562726_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V8LrU0p-6JkQ7kNvgEPKfsO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUNi_O19_CtbeMZKqz3hGEppqpWvDr7jKXWzyQNohYMw&oe=67629D06"}, {"file_name": "Screenshot Reaction_2560x1440.png", "id": "1145515816017245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031339_1145515819350578_8502800640176104500_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OcnHREzf84kQ7kNvgHrYwZh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCI7OWHgwnmPXZr5F7C53Hh2FjhkVRM6OYG2PQlFI8hQ&oe=6762C4C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover AppLab Trailer.png", "id": "1070433643593417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610704_1070433650260083_9089712345028087544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cv9rNBtYo6QQ7kNvgFwKjnP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDuwa8EXa33CJTNZRh3aysfq0PvkCvhWaTmQejy2hUKEg&oe=6762CF00"}, "display_name": "Baseball Softball Training", "keywords": [], "long_description": "This training covers all aspects of the baseball and softball game: hitting, fielding, pitching, focus and reaction speed.\nWork on your hitting skills in the Batting Practice drill where you can set the speed, location and spin of the pitch. And to force a late swing or no-swing decision you can make the ball invisible. Or practice directional hitting with our multi-functional tee that you can adjust for position, height and launch angle.\nWant to practice groundballs or flyballs? The fielding drill allows you to play any position on the field, set the speed and range of the balls that are hit towards you.\nOr work on your pitching focus or technique, that's also possible. Just as improving your reaction skills.", "short_description": "Improve your baseball and softball skills using groundbreaking Virtual Reality drills that go beyond the limits of the real world."}]}, "developer_name": null, "developer_privacy_policy_url": "http://license.sportsimprovr.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "SportsImproVR", "support_website_url": null, "website_url": "https://www.sportsimprovr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "237565695121838"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "601642544684109"}]}, "baseline_offer": {"id": "601642544684109"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1659132360, "status": "PUBLISHED", "id": "601642544684109"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5808985602491580", "version": "0.9"}