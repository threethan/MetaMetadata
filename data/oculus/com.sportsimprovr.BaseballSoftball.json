er&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAycQNaF7saRsetRIa8tRX8S79wwaI-zDfJQtsc6Sojjg&oe=6763FED7"}, {"file_name": "Screenshot Pitching Focus_2560x1440.png", "id": "574645060927542", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982497_574645064260875_2276229677728320493_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QkiaV6K07CoQ7kNvgFC1rbJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLg3EZ37KUn037b3VcxATm94UuNh6QWM0QTyCaIR6OKg&oe=67640870"}, {"file_name": "Screenshot Fielding_2560x1440.png", "id": "1488034254944276", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404383_1488034258277609_7410707247810562726_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V8LrU0p-6JkQ7kNvgEtft-m&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7c61krPaYlm5RNW9wXPiAhy7tvnis5TQPPxvFaLo9bg&oe=6763EE86"}, {"file_name": "Screenshot Reaction_2560x1440.png", "id": "1145515816017245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031339_1145515819350578_8502800640176104500_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OcnHREzf84kQ7kNvgFOeM91&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBF4nncQalYkMxEHOKwM-FQCfqINiu-EjXAZc2b07h2xA&oe=67641649"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover AppLab Trailer.png", "id": "1070433643593417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610704_1070433650260083_9089712345028087544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nT7wL6-btUoQ7kNvgH-P-pz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQz-b_F0iYfsO_Dvc9punwyIQkgx-8aLgYv2vvED4_Jw&oe=67642080"}, "display_name": "Baseball Softball Training", "keywords": [], "long_description": "This training covers all aspects of the baseball and softball game: hitting, fielding, pitching, focus and reaction speed.\nWork on your hitting skills in the Batting Practice drill where you can set the speed, location and spin of the pitch. And to force a late swing or no-swing decision you can make the ball invisible. Or practice directional hitting with our multi-functional tee that you can adjust for position, height and launch angle.\nWant to practice groundballs or flyballs? The fielding drill allows you to play any position on the field, set the speed and range of the balls that are hit towards you.\nOr work on your pitching focus or technique, that's also possible. Just as improving your reaction skills.", "short_description": "Improve your baseball and softball skills using groundbreaking Virtual Reality drills that go beyond the limits of the real world."}]}, "developer_name": null, "developer_privacy_policy_url": "http://license.sportsimprovr.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "SportsImproVR", "support_website_url": null, "website_url": "https://www.sportsimprovr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "237565695121838"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "601642544684109"}]}, "baseline_offer": {"id": "601642544684109"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1659132360, "status": "PUBLISHED", "id": "601642544684109"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5808985602491580", "version": "0.9"}