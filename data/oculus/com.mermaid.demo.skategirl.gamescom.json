375_4687916655952102229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dZ5Lk6ZSS2oQ7kNvgHTmXPo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVBBkMwkuVaQ6MmbANRWXBpiDNJ8gYUQA3wjbLzfB30Q&oe=66DEC910"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-thumb.png", "id": "421382299121723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982557_421382302455056_1973832185226838256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-bA3owO523QQ7kNvgEbgDBv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlXL9ZOIm7_OyMsilbkYEO1q9lalflA_i3rI-5bosEqQ&oe=66DEE264"}, "display_name": "Skategirl Destroys the Universe (timed demo)", "keywords": [], "long_description": "SKATEGIRL DESTROYS THE UNIVERSE is a game played on TV screens floating in a surreal 3D VR space. On the screens the player controls Skategirl, who just destroyed the universe. The player in VR must grab, move and fit together the TV screens like jigsaw pieces to create a path Skategirl can move through to escape the horrible consequences of her own actions.\n\nSKATEGIRL will be available for sale in 2022. In the meantime, this time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).", "short_description": "SKATEGIRL DESTROYS THE UNIVERSE is an upcoming VR game where the player can grab and rearrange the game world with their hands in VR. This time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://mermaid.industries/page/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mermaid Heavy Industries, Ltd", "support_website_url": "https://mermaid.industries/", "website_url": "https://mermaid.industries/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED"