775331342_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rThFBwZQrV8Q7kNvgF-NFWu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXXKYY04qHn9UC_bZ3zGDyv&oh=00_AYCBj9RPEtH8Qn_crubKU_h_SOggszX4mAPdFhXPP543iw&oe=66F2BC27"}, {"file_name": "screenshot-5.png", "id": "971359553716042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031466_971359557049375_4687916655952102229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kMUsSe3tCQsQ7kNvgFMkEW5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXXKYY04qHn9UC_bZ3zGDyv&oh=00_AYDXKQ2nKF7X4awWDbbKD_Lmtf9DFEZU9_c9jTMaENj18w&oe=66F28F90"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-thumb.png", "id": "421382299121723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982557_421382302455056_1973832185226838256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k4T8nCaHz1oQ7kNvgHu5Px9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXXKYY04qHn9UC_bZ3zGDyv&oh=00_AYCu5iXXN7dX3eov5Zc3lx1lRpYGWTQdkUfugf3Alo2skw&oe=66F2A8E4"}, "display_name": "Skategirl Destroys the Universe (timed demo)", "keywords": [], "long_description": "SKATEGIRL DESTROYS THE UNIVERSE is a game played on TV screens floating in a surreal 3D VR space. On the screens the player controls Skategirl, who just destroyed the universe. The player in VR must grab, move and fit together the TV screens like jigsaw pieces to create a path Skategirl can move through to escape the horrible consequences of her own actions.\n\nSKATEGIRL will be available for sale in 2022. In the meantime, this time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).", "short_description": "SKATEGIRL DESTROYS THE UNIVERSE is an upcoming VR game where the player can grab and rearrange the game world with their hands in VR. This time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://mermaid.industries/page/privacy-policy/", "developer_terms_of_service_url": null, "publisher_