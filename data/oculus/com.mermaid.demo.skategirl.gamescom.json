357280775331342_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o-BmcE-OtYgQ7kNvgFNzZxA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfVqMjoZgE1PydEqIT651dw&oh=00_AYCT7kJjn71iulnCc3tGFCWx9nMhZtB3sc7CawTOxbL8-w&oe=66E6DEA7"}, {"file_name": "screenshot-5.png", "id": "971359553716042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031466_971359557049375_4687916655952102229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IpmQofHJ_3YQ7kNvgHhPZ9l&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfVqMjoZgE1PydEqIT651dw&oh=00_AYA40MPuJqkHtO-9eChNLbbXVkuOcF8WB3XZNXQnSYFoZA&oe=66E6B210"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer-thumb.png", "id": "421382299121723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982557_421382302455056_1973832185226838256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=skmejcc9HCUQ7kNvgGBdV4u&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfVqMjoZgE1PydEqIT651dw&oh=00_AYCT8Dv1uJKDBNjMdJATQNV2RCOy46Wyi3erDwTkjgJ-Mw&oe=66E6CB64"}, "display_name": "Skategirl Destroys the Universe (timed demo)", "keywords": [], "long_description": "SKATEGIRL DESTROYS THE UNIVERSE is a game played on TV screens floating in a surreal 3D VR space. On the screens the player controls Skategirl, who just destroyed the universe. The player in VR must grab, move and fit together the TV screens like jigsaw pieces to create a path Skategirl can move through to escape the horrible consequences of her own actions.\n\nSKATEGIRL will be available for sale in 2022. In the meantime, this time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).", "short_description": "SKATEGIRL DESTROYS THE UNIVERSE is an upcoming VR game where the player can grab and rearrange the game world with their hands in VR. This time-limited demo will be available during Gamescom (Aug 23 - Aug 29, 2021).\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://mermaid.industries/page/privacy-policy/", "developer_terms_of_service_url": null, "publ