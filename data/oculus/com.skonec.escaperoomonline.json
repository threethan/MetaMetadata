{"data": {"node": {"__typename": "Application", "id": "7941437402579936", "organization": {"id": "778834515548544", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7941437402579936"}]}, "id": "990853559156007"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7224231090949496"}]}, "id": "702228988686262"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1270657409683040"}]}, "id": "1202980389822910"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1000027913449340"}]}, "id": "951066165027081"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "894630640574434"}]}, "id": "1186255254718557"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "848002675255993"}]}, "id": "1116690968383377"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "765949116854401"}]}, "id": "552560721587740"}]}}, "firstRevision": {"nodes": [{"application": {"id": "7941437402579936", "release_date": 1728579600, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 5}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8656466714410331"}, "id": "1176507303802348"}]}}, "binary": null, "live_binary": null, "created_date": 1730258125, "id": "8733862056670796", "is_initial_release": false, "name_with_fallback": "v12", "pdp_metadata_with_fallback": {"version": 10, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8733925343331134"}, "release_status": "RELEASED", "id": "7941437402579936"}, "id": "8733925343331134", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7941437402579936", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1186989522424434"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "1110953463723766", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Another Door: Escape Room", "keywords": ["EscapeRoom", "Puzzle", "Horror", "Coop", "Halloween"], "long_description": "# \uc9c0\ud61c\ub97c \ubc1c\ud718\ud574 \ud0c8\ucd9c\ud558\uc138\uc694!\n\nAnother Door\ub294 \uace0\uc720\ud55c \uc2a4\ud1a0\ub9ac\uc640 \uc18c\ub984\ub07c\uce58\ub294 \ub3c4\uc804\uc774 \uc788\ub294 \ubab0\uc785\uac10 \uc788\ub294 \ud658\uacbd\uc73c\ub85c \uc5ec\ub7ec\ubd84\uc744 \uc548\ub0b4\ud558\ub294 VR \ubc29 \ud0c8\ucd9c \uac8c\uc784\uc785\ub2c8\ub2e4. \uad34\uc9dc \uacfc\ud559\uc790\uac00 \ub9cc\ub4e0 \ud568\uc815\uc73c\ub85c \uac00\ub4dd \ucc2c \uc740\uc2e0\ucc98\ubd80\ud130 \uc8fd\uc740 \uc544\uc774\uc758 \uc601\ud63c\uc5d0 \uc800\uc8fc\ubc1b\uc740 \uc720\ub839\uc774 \ub098\uc624\ub294 \uc778\ud615\uc758 \ubc29, \ud658\uac01\uc774 \ud604\uc2e4\uc744 \ud750\ub9ac\uac8c \ud558\ub294 \ube44\ubc00 \uc2e4\ud5d8\uc2e4\uae4c\uc9c0 \ub9e4 \uc5d0\ud53c\uc18c\ub4dc\ub9c8\ub2e4 \uc2e0\uc120\ud558\uace0 \uc2a4\ub9b4 \ub118\uce58\ub294 \ubbf8\uc2a4\ud130\ub9ac\uac00 \uc804\ub2ec\ub429\ub2c8\ub2e4!\n{1478867432833048}\n# \uc5b4\ub098\ub354 \ub3c4\uc5b4(Another Door)\ub294 \uc9c4\uc815\ud55c \uac00\uc0c1\ud604\uc2e4 \ubab0\uc785\uac10\uc744 \ud1b5\ud574 \uc2e4\uc81c \ubc29\ud0c8\ucd9c\uc758 \uc2a4\ub9b4\uc744 \uc7ac\ud604\ud569\ub2c8\ub2e4.\n{331491059959479}\n# \uc8fc\uc694 \ud2b9\uc9d5:\n   - \uacf3\uacf3\uc5d0 \uc228\uaca8\uc9c4 \uc218\uc9d1\ud488\uc744 \ucc3e\uc544\ubcf4\uc138\uc694\n   - 5\uac00\uc9c0 \ub3c5\ud2b9\ud55c \ud14c\ub9c8\ub97c \ub098\ub9cc\uc758 \ud37c\uc990\ub85c \uacbd\ud5d8\ud574\ubcf4\uc138\uc694\n   - \ubab0\uc785\ud615 \uc624\ub514\uc624 \ub514\uc790\uc778\n   - \uc628\ub77c\uc778 \uba40\ud2f0\ud50c\ub808\uc774\n\n# \ub208\uc5d0 \ubcf4\uc774\ub294 \uac83 \uadf8 \uc774\uc0c1\nAnother Door\ub294 \uac01\uac01 \uc0c8\ub85c\uc6b4 \ud14c\ub9c8, \uc2a4\ud1a0\ub9ac, \ud37c\uc990 \uba54\ucee4\ub2c8\uc998\uc744 \uac16\ucd98 5\uac1c\uc758 \ub3c5\ud2b9\ud55c \uc5d0\ud53c\uc18c\ub4dc\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ud50c\ub808\uc774\uc5b4\ub294 \ub3c4\uc11c\uad00\uc5d0\uc11c \ucc45\uc744 \uc120\ud0dd\ud558\ub294 \uac83\ucc98\ub7fc \uc5d0\ud53c\uc18c\ub4dc\ub97c \uc120\ud0dd\ud560 \uc218 \uc788\uc73c\ubbc0\ub85c \ub450 \ubaa8\ud5d8\uc774 \ub3d9\uc77c\ud558\uac8c \ub290\uaef4\uc9c0\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.\n{1484294608875128}\n# \ud63c\uc790 \ub610\ub294 \uce5c\uad6c\uc640 \ud568\uaed8 \ud50c\ub808\uc774\ud558\uc138\uc694!\n\ub4f1\uace8\uc774 \uc624\uc2f9\ud574\uc9c0\ub294 \uacbd\ud5d8\uc744 \uc704\ud574 \ud63c\uc790 \ud50c\ub808\uc774\ud558\uac70\ub098 \ucd5c\ub300 3\uba85\uc758 \uce5c\uad6c\uc640 \ud300\uc744 \uc774\ub8e8\uc5b4 \uac00\uc7a5 \uc5b4\ub824\uc6b4 \uacfc\uc81c\ub97c \ud568\uaed8 \ud574\uacb0\ud558\uc138\uc694. \ud0d0\uc0c9\ud558\uace0 \ud0c8\ucd9c\ud558\ub294 \ub3d9\uc548 \uc74c\uc131 \ucc44\ud305\uc744 \uc0ac\uc6a9\ud558\uc5ec \ub2e8\uc11c\ub97c \uacf5\uc720\ud558\uace0 \uc2e4\uc2dc\uac04\uc73c\ub85c \ud611\ub825\ud558\uc138\uc694.\n\n# \ud37c\uc990 \ud14c\uc2a4\ud2b8\n\ud63c\uc790\ub4e0 \uce5c\uad6c\uc640 \ud568\uaed8\ub4e0 \ubbf8\uc9c0\uc758 \uc138\uacc4\uc5d0 \ub9de\uc11c\ub294 Another Door\ub294 \uc11c\uc2a4\ud39c\uc2a4, \ud300\uc6cc\ud06c, \uc815\uc2e0\uc744 \ud55c\uacc4\uae4c\uc9c0 \ubc00\uc5b4\ubd99\uc774\ub294 \ubcf5\uc7a1\ud55c \ud37c\uc990\ub85c \uac00\ub4dd\ud55c \uc78a\uc744 \uc218 \uc5c6\ub294 VR \ubaa8\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.", "short_description": "\ubaa9\ud45c\ub294 \uac04\ub2e8\ud569\ub2c8\ub2e4. \n\ubb38\uc744 \uc5f4\uace0 \ud0c8\ucd9c\ud558\uc138\uc694!\n\n\ub17c\ub9ac\uc5d0 \ub3c4\uc804\ud558\uace0 \uc7ac\uce58\ub97c \uc2dc\ud5d8\ud558\ub294 \ubc29\ud0c8\ucd9c \uac8c\uc784 '\uc5b4\ub098\ub354\ub3c4\uc5b4'\ub85c \ucd08\ub300\ud569\ub2c8\ub2e4. \uc785\uc7a5\ud558\ub294 \uc21c\uac04\ubd80\ud130 \uc194\ub85c \ub610\ub294 \uce5c\uad6c\ub4e4\uacfc \ud611\ub825 \ud50c\ub808\uc774\ub97c \ud558\uae30\uc5d0 \uc644\ubcbd\ud55c \uad6c\uc131\uc73c\ub85c \uc5ec\ub7ec\ubd84\uc740 \ub2e4\uc591\ud558\uace0 \uae30\ubc1c\ud55c \ud37c\uc990\uacfc \ub9c8\uc8fc\ud558\uac8c \ub429\ub2c8\ub2e4. \ubab0\uc785\ud615 VR\uc744 \uc704\ud574 \uc12c\uc138\ud558\uac8c \uc124\uacc4\ub41c \ub2e4\uc591\ud55c \uc5d0\ud53c\uc18c\ub4dc\uc758 \ubaa8\ud5d8\ub4e4\uacfc \uc2e4\uc81c\uc640 \uac19\uc740 \ud0c8\ucd9c\uc758 \uc2a4\ub9b4\uc744 \uac00\uc0c1 \ud604\uc2e4\uc744 \ud1b5\ud574 \uacbd\ud5d8\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc608\uce21\ud560 \uc218 \uc5c6\ub294 \uc2dc\ub098\ub9ac\uc624\uc5d0 \ube60\uc838 \ub2e8\uc11c\ub97c \ud30c\ud5e4\uce58\uace0 \uc9c4\uc2e4\uc5d0 \uc811\uadfc\ud558\uc5ec \ud765\ubbf8\uc9c4\uc9c4\ud55c '\uc5b4\ub098\ub354\ub3c4\uc5b4'\uc758 \uc138\uacc4\uc5d0 \ube60\uc838 \ubcf4\uc138\uc694!"}, {"images": {"nodes": [{"file_name": "Logo(Transparent).png", "id": "7762231480498497", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/54770913_7762231483831830_3691965120608535737_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=apbzSVLNSBQQ7kNvgH9WyE0&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDwuT7CMhcqMKgRcUs7jHp4u8EpOHEWrbsqNP_Ie1mZhw&oe=672A16A1"}, {"file_name": "AE_img_Immersive_Logo.png", "id": "3902567900018959", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031634_3902567903352292_2734493492234583304_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vgPMx18SZPEQ7kNvgF26p9m&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYA8u19WNU-bTYYwCZOZ3JFXv2F8LgSr0SvLj5Kvfjx_5g&oe=672A0303"}, {"file_name": "AE_img_Immersive_Object_Left.png", "id": "3865287877125526", "image