_nc_sid=6e7a0a&_nc_ohc=b6WYW_rhIKAQ7kNvgFJke5O&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDiMaQ1ElpYt7bBsWhucpF6gkvgGkvdZnfoXMCwyzELig&oe=675EC084"}, {"file_name": "Screenshot_AR_01.png", "id": "307362578653070", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75269589_307362581986403_5514138600774088351_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ndb0mmW1yW4Q7kNvgFvSoh_&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYA6bJxEcHIBr-rdeZdaZj9gXwnR4xqpGObQqebm5dD3NA&oe=675EBCD1"}, {"file_name": "Screenshot_AR_02.png", "id": "1525826631293830", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75608439_1525826637960496_5600121410335262776_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylD5BUDEjLkQ7kNvgELABBe&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAiea3mXNdY9Asg1UrxdkYCEYDGZvUYX2Ik9OTkidLRfg&oe=675EB75C"}, {"file_name": "Screenshot_AR_04.png", "id": "768495041846123", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982441_768495045179456_7364421852535849747_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9zcDi8VOc7EQ7kNvgGo4R57&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBTNyWTDbA_y5Z_TPXE8jmqb-gTUjJZaOnT3bkT5zK9Jw&oe=675ECB89"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ProteusLabs_CoverImage.png", "id": "720561586563712", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974695_720561589897045_1601795383552454132_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ERaMhLsdm-AQ7kNvgGBNh6l&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBpANa7AY8ce_WctYqLxYvitzTUQqrvnyLiRgmBBfMukA&oe=675EC760"}, "display_name": "Proteus Labs", "keywords": [], "long_description": "Proteus Labs permite a los estudiantes acceder a un laboratorio o taller de \u00faltima generaci\u00f3n. Tambi\u00e9n permite concretar situaciones de aprendizaje al ofrecer un entorno inmersivo, interactivo y realista. Se puede acceder a Proteus Labs desde cualquier lugar, lo que lo hace perfecto para la ense\u00f1anza en l\u00ednea o para estudiantes aislados. La opci\u00f3n multipersona hace posible y f\u00e1cil el coaching de profesores.\n \nNuestras actividades promueven el desarrollo de las destrezas a las que apunta el plan de estudios de diversas disciplinas. Algunos elementos del contenido pueden modificarse a elecci\u00f3n del profesor. Los resultados obtenidos son tan v\u00e1lidos y variados como en la realidad.", "short_description": "\u00a1Simule clases de qu\u00edmica, electricidad y descubrimiento a trav\u00e9s de Proteus Labs! \u00a1Avalado y validado por profesores y utilizado en escuelas de todo el mundo!"}, {"images": {"nodes": []}, "id": "418814627967663", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Proteus Labs", "keywords": [], "long_description": "Proteus Labs\ub294 \ud559\uc0dd\ub4e4\uc5d0\uac8c \ucd5c\ucca8\ub2e8 \uc2e4\ud5d8\uc2e4\uc774\ub098 \uc791\uc5c5\uc7a5\uc5d0 \uc811\uadfc\ud560 \uc218 \uc788\ub294 \uae30\ud68c\ub97c \uc81c\uacf5\ud569\ub2c8\ub2e4. \ub610\ud55c \ubab0\uc785\uac10 \uc788\uace0, \uc0c1\ud638\uc791\uc6a9\ud558\uba70, \ud604\uc2e4\uac10 \uc788\ub294 \ud658\uacbd\uc744 \ud1b5\ud574 \uad6c\uccb4\uc801\uc778 \ud559\uc2b5 \uc0c1\ud669\uc744 \uac00\ub2a5\ud558\uac8c \ud569\ub2c8\ub2e4. Proteus Labs\ub294 \uc5b4\ub514\uc11c\ub098 \uc811\uadfc\ud560 \uc218 \uc788\uc5b4 \uc628\ub77c\uc778 \uc218\uc5c5\uc774\ub098 \uc678\ub534 \uc9c0\uc5ed \ud559\uc0dd\ub4e4\uc5d0\uac8c \uc644\ubcbd\ud55c \uc194\ub8e8\uc158\uc785\ub2c8\ub2e4. \ub2e4\uc911 \uc0ac\uc6a9\uc790 \uc635\uc158\uc740 \uad50\uc0ac\uc758 \ucf54\uce6d\uc744 \ub354\uc6b1 \uc27d\uac8c \ub9cc\ub4e4\uc5b4 \uc90d\ub2c8\ub2e4.\n\n\uc6b0\ub9ac\uc758 \ud65c\ub3d9\uc740 \ub2e4\uc591\ud55c \ud559\ubb38 \ubd84\uc57c\uc758 \uad50\uc721\uacfc\uc815\uc5d0\uc11c \ubaa9\ud45c\ub85c \ud558\ub294 \uc5ed\ub7c9 \uac1c\ubc1c\uc744 \ucd09\uc9c4\ud569\ub2c8\ub2e4. \uc77c\ubd80 \ucf58\ud150\uce20 \uc694\uc18c\ub294 \uad50\uc0ac\uc758 \uc120\ud0dd\uc5d0 \ub530\ub77c \uc870\uc815\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc2e4\ud5d8 \uacb0\uacfc\ub294 \ud604\uc2e4\uacfc \ub9c8\ucc2c\uac00\uc9c0\ub85c \uc720\ud6a8\ud558\uace0 \ub2e4\uc591\ud569\ub2c8\ub2e4.", "short_description": "Proteus Labs\uc640 \ud568\uaed8 \ud654\ud559, \uc804\uae30 \ubc0f \ud0d0\uad6c \uc218\uc5c5\uc744 \uc2dc\ubbac\ub808\uc774\uc158\ud558\uc138\uc694! \uad50\uc0ac\ub4e4\uc774 \uc2b9\uc778\ud558\uace0 \uac80\uc99d\ud588\uc73c\uba70 \uc804 \uc138\uacc4 \ud559\uad50\uc5d0\uc11c \uc0ac\uc6a9\ub418\uace0 \uc788\uc2b5\ub2c8\ub2e4!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://proteus-vr.com/wp-content/uploads/2024/03/apps-privacy-policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Proteus", "support_website_url": null, "website_url": "https://proteus-vr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr_BE", "fr_CA", "fr", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE", "ko", "it"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8764510420328816"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031436_1254625122481651_4078790714543439764_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Dpk90tR1usQ7kNvgFOvcdy&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBMW1_9TM8TxSr7npJ841zemqV_aifQO1_o4ua_Uyp5jg&oe=675ED731"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Proteus Labs", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1628547955, "lastRevision": {"nodes": [{"id": "4239692762748777", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4083148155131756", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "335169871381883"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "1000359420709594", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Proteus Labs", "keywords": [], "long_description": "Proteus Labs permet aux \u00e9tudiants d\u2019avoir acc\u00e8s \u00e0 un laboratoire ou un atelier \u00e0 la fine pointe de la technologie. Il permet aussi de rendre les situations d\u2019apprentissage concr\u00e8tes en offrant un environnement immersif, interactif et r\u00e9aliste. Proteus Labs peut \u00eatre accessible de partout ce qui le rend parfait pour l\u2019enseignement \u00e0 distance ou pour les \u00e9tudiants isol\u00e9s. L\u2019option multi-personnes rend l\u2019accompagnement par l\u2019enseignant possible et facile.\n\nNos activit\u00e9s favorisent le d\u00e9veloppement des comp\u00e9tences vis\u00e9es par les curriculums des diff\u00e9rentes disciplines. Certains \u00e9l\u00e9ments du contenu peuvent \u00eatre modifi\u00e9s en fonction du choix de l\u2019enseignant. Les r\u00e9sultats obtenus sont valides et vari\u00e9s comme dans la r\u00e9alit\u00e9.", "short_description": "Simulez la chimie, la physique et la biologie avec les Proteus Labs! Endoss\u00e9 et valid\u00e9 par des professeurs dans des \u00e9coles \u00e0 travers le monde!"}, {"images": {"nodes": [{"file_name": "ProteusLabs_Icon.png", "id": "4381960035161134", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75429295_4381960038494467_1732173401242729257_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3_vwFG7JLS0Q7kNvgFPQ3PW&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYARvnuqbXpM9m0pjQSPgBdqhUzSRGQ85PwpLGp73svGvA&oe=675EAE86"}, {"file_name": "ProteusLabs_1080x360.png", "id": "3006749922878727", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75203619_3006749926212060_8851401734746462968_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6YDxyFg-AgQ7kNvgErqTCo&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDreUJvjmtq4jnRh8hSOkW9cv7Pb2D74n1lzIevWa2FmA&oe=675EABBC"}, {"file_name": "ProteusLabs_Logo_2560x1440.png", "id": "1467295343624364", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75203625_1467295346957697_7388907762043359903_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ifl-wmo90_4Q7kNvgE5hFL9&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBC56Wq0vYmvB7Rfn38Vo7M2NTAkDJsVEQzITJHZjOH4Q&oe=675EBA96"}, {"file_name": "ProteusLabs_1440x1440.png", "id": "493816628618311", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982450_493816631951644_2621195822375107062_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8UqsCwjqlysQ7kNvgH5OLER&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDCT-zThMAj0TOI9qE8xAHFJuPqDxOU8KIbzmd6ulhS3A&oe=675ED19C"}, {"file_name": "ProteusLabs_2560x1440.png", "id": "315206370189891", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974650_315206373523224_7939487214243035339_n.png?_nc_cat=104