------------------------------------------------------------------\n\n\u2728 Mejoras en el Modo MR\nAhora, en dispositivos Meta Quest 3, Meta Quest 3S y Meta Quest Pro, el rendimiento en el modo MR es tan fluido como en VR. \u00a1Adi\u00f3s a los tirones y bajones de frames!\nHemos a\u00f1adido nuevos efectos visuales al activar el modo MR para que la experiencia sea m\u00e1s inmersiva y espectacular.\n\n\ud83d\udd27 Mejoras Generales\nCorrecci\u00f3n de varios errores para una experiencia de juego m\u00e1s estable. \u00a1Seguimos trabajando para que puedas disfrutar de la mejor experiencia de baile!", "created_date": 1730882511, "id": "8599868843474187", "version": "1.3.5", "version_code": 103050005, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 14}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6212696172191478", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8599868843474187"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730816801, "id": "8595742920553446", "version": "1.3.5", "version_code": 103050004, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 14}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6212696172191478", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8599868843474187"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730798721, "id": "8594487644012307", "version":