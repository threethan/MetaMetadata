888_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wt86LgwCqcwQ7kNvgGGSLm_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBS2sQ_Egj90W3eK0WN7Ulgs8REgQYbGyR1lgIVHvA6eA&oe=674C5F5D"}, "display_name": "LES MILLS XR DANCE", "keywords": ["music", "rhythm", "fitness", "move", "bodycombat"], "long_description": "Get moving with the new dance fitness program by LES MILLS. Join their official presenters in more than 45 songs by Monstercat! \n\nChoose your favorite genre and groove on to different music styles from hip-hop, to urban latin rhythms, techno and pop!\n\nLearn and master dancing in the most fun way!\n\n\ud83d\udd7a\ud83c\udffe +25 Dance routines and over 45 music tracks from Monstercat\n\ud83c\udfb6 Enjoy Pop, Techno, Vibe and Hip Hop choreos\n\ud83d\udc69\u200d\ud83c\udfeb 5 official presenters to guide you on your dance journey\n\ud83e\udd47 3 difficulty levels for both beginners and masters of dance!", "short_description": "Get moving with the new dance fitness program by LES MILLS. Join their official presenters in more than 45 songs by Monstercat! \n\nChoose your favorite genre and groove on to different music styles from hip-hop, to urban latin rhythms, techno and pop!\n\nLearn and master dancing in the most fun way!\n\n\ud83d\udd7a\ud83c\udffe +25 Dance routines and over 45 songs from Monstercat\n\ud83c\udfb6 Enjoy Pop, Techno, Vibe and Hip Hop choreos\n\ud83d\udc69\u200d\ud83c\udfeb 5 official presenters to guide you\n\ud83e\udd47 3 difficulty levels for both beginners and masters"}]}, "developer_name": null, "developer_privacy_policy_url": "https://odderslab.com/les-mills-xr-dance-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Odders", "support_website_url": null, "website_url": "https://odderslab.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_su