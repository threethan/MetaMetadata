38974714_881861406488965_7761861626454403146_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bEjMBZ0xjnAQ7kNvgEwT3Qn&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCtong2rFf2AOzr5d9YSdSiHakdL_pMn3eJ98cED2Dfxw&oe=6707A5DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "876725454402101", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974456_876725457735434_6317396692062889187_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tppRN1rchaYQ7kNvgGxhq5A&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhg-W5Nu-rLlxIIU8Wm3epSFvk_FvYj9MHPVItsqU7uA&oe=6707D1D1"}, "display_name": "VENTA X", "keywords": ["VR", "3D", "\ucf00\uc774\ud31d", "\ucf58\uc11c\ud2b8", "\uc544\uc774\ub3cc"], "long_description": "VENTA X\ub294 \uc804 \uc138\uacc4 \ucd5c\ub2e4 K-POP 3D VR \uc601\uc0c1\uc744 \ubcf4\uc720\ud55c \uc571\uc73c\ub85c \uc74c\uc545\ubc29\uc1a1, \ucf58\uc11c\ud2b8 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ucd08\uace0\ud654\uc9c8 3D VR \uc601\uc0c1\uc744 \uac00\uc7a5 \uc27d\uace0 \ub2e4\uc591\ud558\uac8c \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc804 \uc138\uacc4 60\uac1c\uad6d K-POP \ud32c\ub4e4\uc774 \ub9c8\uce58 \ub0b4 \ub208 \uc55e\uc5d0 \uc788\ub294 \uac83\ucc98\ub7fc, \uc815\ub9d0 \uc2e4\uac10\ub098\ub294 VENTA X\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ud1b5\ud574 K-POP \uc544\ud2f0\uc2a4\ud2b8\ub97c \ub9cc\ub098\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub9e4\uc8fc \uc0c8\ub86d\uac8c \uc5c5\ub370\uc774\ud2b8 \ub418\ub294 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ub9cc\ub098\ubcf4\uc138\uc694!\n\n[VENTA X Original content : 8K 3D VR MUSIC CINEMA]\n\u00b7 \uc544\ud2f0\uc2a4\ud2b8\uc758 \uace1\uc744 \uc601\ud654\uac19\uc740 \uc2a4\ud1a0\ub9ac\ub85c \ud3bc\uccd0\ub0b4\ub294 \uacf5\uc5f0\n\u00b7 VR\ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4\uc640 \uc785\uccb4 CG\n\n[VENTA X K-POP Series content : 8K 3D VR performance VOD]\n\u00b7 \uacf5\uc5f0, \uc608\ub2a5 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ub2e4\uc591\ud55c \ubaa8\uc2b5\uc744 \uc785\uccb4\uc801\uc73c\ub85c \ubcfc \uc218 \uc788\ub294 3D VR \ucf58\ud150\uce20", "short_description": "8K 3D VR\ub85c \uc81c\uc791\ub41c K-POP \ucf58\ud150\uce20\ub97c \ubab0\uc785\uac10 \uc788\uac8c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uad00\ub78c\uc5d0\ub3c4 \uba40\ubbf8\uac00 \uc5c6\uace0 \uc544\uc774\ub808\ubca8\ubdf0\ub85c \ucd2c\uc601\ub418\uc5b4 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc640 \ub208\uc744 \ub9de\ucd94\ub294 \uacbd\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 \ucf58\ud150\uce20\uac00 \uac00\ub4dd\ud569\ub2c8\ub2e4."}]}, "developer_name": null, "developer_privacy_policy_url": "https://venta-x.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8138455792901552"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974755_1172204187192076_462646316343839108_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z2YLcFZO8JcQ7kNvgEdYr0m&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJchwrIvU6jswdnhGyum-otUJDwzMAd-85xmYjsdMtdg&oe=