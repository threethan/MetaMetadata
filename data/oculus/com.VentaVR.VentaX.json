0124"}, {"topic_name": "Dance", "id": "548013192910304"}, {"topic_name": "TV Shows", "id": "337573230800174"}], "release_date": 1670519358, "lastRevision": {"nodes": [{"id": "5370589016354924", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5370588983021594", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "766834831187859"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "820358052662466", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ubca4\ud0c0\uc5d1\uc2a4", "keywords": [], "long_description": "\uc624\uc9c1, \ubca4\ud0c0X\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 '3D VR \uc2dc\ub124\ub9c8\ud2f1 \ucf58\uc11c\ud2b8'\n- \uc544\ud2f0\uc2a4\ud2b8\uc758 \uc138\uacc4\uad00\uc744 \ud55c \ud3b8\uc758 \uc601\ud654\ucc98\ub7fc \ud480\uc5b4\ub0b8 \uc2a4\ud1a0\ub9ac\uac00 \uc788\ub294 \ud504\ub9ac\ubbf8\uc5c4 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4. \n- VR \ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4 \uc5f0\ucd9c\uacfc \uc785\uccb4 CG\uac00 \ub354\ud574\uc838 VR\uc5d0\uc11c\ub9cc \uac00\ub2a5\ud55c \ucf58\uc11c\ud2b8 \uadf8 \uc774\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc2e4\uc81c \uc624\ud504\ub77c\uc778 \ucf58\uc11c\ud2b8\ub97c \ubc14\ub85c \ub0b4 \ub208 \uc55e\uc5d0\uc11c \uc990\uae30\ub294 '3D VR LIVE \ucf58\uc11c\ud2b8'\n- \uc6d4\ub4dc\ud22c\uc5b4 \ucf58\uc11c\ud2b8\ub97c 8K 3D VR LIVE\ub85c \uc5b4\ub514\uc11c\ub4e0\uc9c0 \uc990\uae38 \uc218 \uc788\ub294 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4.\n- \uace0\ud654\uc9c8/\uace0\ud574\uc0c1\ub3c4\uc758 \uacf5\uc5f0\uc744 VR \uae30\uae30\ub9cc \uc788\ub2e4\uba74 \uadf8\uacf3\uc774 \uacf5\uc5f0\uc7a5\uc73c\ub85c \ubcc0\ud558\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc544\ud2f0\uc2a4\ud2b8 Showroom\n- \uc544\ud2f0\uc2a4\ud2b8\uc640 \uacf5\uc5f0 \uad00\ub828 \ucf58\ud150\uce20\ub85c \uac00\ub4dd \ucc44\uc6cc\uc9c4 6dof \uba54\ud0c0\ubc84\uc2a4 \uacf5\uac04\uc5d0\uc11c \uc9c1\uc811 \ub3cc\uc544\ub2e4\ub2c8\uba70 \uad00\ub78c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "8K 3D VR\uc758 \uace0\ud654\uc9c8 \uc601\uc0c1\uc73c\ub85c \uc544\ud2f0\uc2a4\ud2b8\uc758 \uacf5\uc5f0\uc744 \ub354 \uc120\uba85\ud55c \ubab0\uc785\uac10\uc73c\ub85c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uacf5\uc5f0 \uc2dc\uccad\uc5d0\ub3c4 \uba40\ubbf8\uac10 \uc5c6\uc774 \uad00\ub78c \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc544\ud2f0\uc2a4\ud2b8\ub97c Eye Level\ub85c \ub208 \uc55e\uc5d0\uc11c \ubcf4\ub294 \ub4ef\ud55c \ubab0\uc785\uac10\uc744 \uad6c\ud604\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "03_\uc601\uc6c5\ud45c\uc9c0_3000x900.png", "id": "1233375317579645", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1233375320912978_2312981716732830757_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8-QK6_AFPOoQ7kNvgFcpPtq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBptEMpjs_XT4_MwyIV_Ds8ZOu1rnoSrnL3IGotTUB_kg&oe=66DEC898"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1440x1440.png", "id": "1171750103750394", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1171750107083727_407813169638949737_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2KMIJPyUYd4Q7kNvgHzo_s5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIZrWL4ZRTdmbez1f0ctoQunDaLI2gvceMczoKfG06CA&oe=66DEDDCA"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1008x1440.png", "id": "816809249690649", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001703_816809253023982_5697252018931420675_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jn0EO-DngR8Q7kNvgH2gvpm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAh7cDjm7M94YcZa3VvVlOkbsvNrv9nn_6OB8LiCjNmZQ&oe=66DEC82A"}, {"file