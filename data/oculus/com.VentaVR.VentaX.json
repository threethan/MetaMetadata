ttps://scontent.oculuscdn.com/v/t64.5771-25/38974456_876725457735434_6317396692062889187_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vm_yXTcrAY8Q7kNvgF7yFrj&_nc_ht=scontent.oculuscdn.com&oh=00_AYD19R1EZpyhRw9Otvr7iiTUZAK8n4aAYM8MHeOdHs06YQ&oe=66F7FFD1"}, "display_name": "VENTA X", "keywords": ["VR", "3D", "\ucf00\uc774\ud31d", "\ucf58\uc11c\ud2b8", "\uc544\uc774\ub3cc"], "long_description": "VENTA X\ub294 \uc804 \uc138\uacc4 \ucd5c\ub2e4 K-POP 3D VR \uc601\uc0c1\uc744 \ubcf4\uc720\ud55c \uc571\uc73c\ub85c \uc74c\uc545\ubc29\uc1a1, \ucf58\uc11c\ud2b8 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ucd08\uace0\ud654\uc9c8 3D VR \uc601\uc0c1\uc744 \uac00\uc7a5 \uc27d\uace0 \ub2e4\uc591\ud558\uac8c \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc804 \uc138\uacc4 60\uac1c\uad6d K-POP \ud32c\ub4e4\uc774 \ub9c8\uce58 \ub0b4 \ub208 \uc55e\uc5d0 \uc788\ub294 \uac83\ucc98\ub7fc, \uc815\ub9d0 \uc2e4\uac10\ub098\ub294 VENTA X\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ud1b5\ud574 K-POP \uc544\ud2f0\uc2a4\ud2b8\ub97c \ub9cc\ub098\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub9e4\uc8fc \uc0c8\ub86d\uac8c \uc5c5\ub370\uc774\ud2b8 \ub418\ub294 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ub9cc\ub098\ubcf4\uc138\uc694!\n\n[VENTA X Original content : 8K 3D VR MUSIC CINEMA]\n\u00b7 \uc544\ud2f0\uc2a4\ud2b8\uc758 \uace1\uc744 \uc601\ud654\uac19\uc740 \uc2a4\ud1a0\ub9ac\ub85c \ud3bc\uccd0\ub0b4\ub294 \uacf5\uc5f0\n\u00b7 VR\ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4\uc640 \uc785\uccb4 CG\n\n[VENTA X K-POP Series content : 8K 3D VR performance VOD]\n\u00b7 \uacf5\uc5f0, \uc608\ub2a5 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ub2e4\uc591\ud55c \ubaa8\uc2b5\uc744 \uc785\uccb4\uc801\uc73c\ub85c \ubcfc \uc218 \uc788\ub294 3D VR \ucf58\ud150\uce20", "short_description": "8K 3D VR\ub85c \uc81c\uc791\ub41c K-POP \ucf58\ud150\uce20\ub97c \ubab0\uc785\uac10 \uc788\uac8c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uad00\ub78c\uc5d0\ub3c4 \uba40\ubbf8\uac00 \uc5c6\uace0 \uc544\uc774\ub808\ubca8\ubdf0\ub85c \ucd2c\uc601\ub418\uc5b4 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc640 \ub208\uc744 \ub9de\ucd94\ub294 \uacbd\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 \ucf58\ud150\uce20\uac00 \uac00\ub4dd\ud569\ub2c8\ub2e4."}]}, "developer_name": null, "developer_privacy_policy_url": "https://venta-x.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8138455792901552"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974755_1172204187192076_462646316343839108_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r4bEbtPNNbIQ7kNvgH_qXCd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCptPVrwObG8nXCq7IrdFMrkPuKgQpA6Ka6iKVJFjSODA&oe=66F7FA93"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VENTA X", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Music", "id": "668538087410124"}, {"topic_name": "Dance", "id": "548013192910304"}, {"topic_name": "TV Shows", "id": "337573230800174"}], "release_date": 1670519358, "lastRevision": {"nodes": [{"id": "5370589016354924", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5370588983021594", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "766834831187859"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "820358052662466", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ubca4\ud0c0\uc5d1\uc2a4", "keywords": [], "long_description": "\uc624\uc9c1, \ubca4\ud0c0X\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 '3D VR \uc2dc\ub124\ub9c8\ud2f1 \ucf58\uc11c\ud2b8'\n- \uc544\ud2f0\uc2a4\ud2b8\uc758 \uc138\uacc4\uad00\uc744 \ud55c \ud3b8\uc758 \uc601\ud654\ucc98\ub7fc \ud480\uc5b4\ub0b8 \uc2a4\ud1a0\ub9ac\uac00 \uc788\ub294 \ud504\ub9ac\ubbf8\uc5c4 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4. \n- VR \ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4 \uc5f0\ucd9c\uacfc \uc785\uccb4 CG\uac00 \ub354\ud574\uc838 VR\uc5d0\uc11c\ub9cc \uac00\ub2a5\ud55c \ucf58\uc11c\ud2b8 \uadf8 \uc774\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc2e4\uc81c \uc624\ud504\ub77c\uc778 \ucf58\uc11c\ud2b8\ub97c \ubc14\ub85c \ub0b4 \ub208 \uc55e\uc5d0\uc11c \uc990\uae30\ub294 '3D VR LIVE \ucf58\uc11c\ud2b8'\n- \uc6d4\ub4dc\ud22c\uc5b4 \ucf58\uc11c\ud2b8\ub97c 8K 3D VR LIVE\ub85c \uc5b4\ub514\uc11c\ub4e0\uc9c0 \uc990\uae38 \uc218 \uc788\ub294 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4.\n- \uace0\ud654\uc9c8/\uace0\ud574\uc0c1\ub3c4\uc758 \uacf5\uc5f0\uc744 VR \uae30\uae30\ub9cc \uc788\ub2e4\uba74 \uadf8\uacf3\uc774 \uacf5\uc5f0\uc7a5\uc73c\ub85c \ubcc0\ud558\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc544\ud2f0\uc2a4\ud2b8 Showroom\n- \uc544\ud2f0\uc2a4\ud2b8\uc640 \uacf5\uc5f0 \uad00\ub828 \ucf58\ud150\uce20\ub85c \uac00\ub4dd \ucc44\uc6cc\uc9c4 6dof \uba54\ud0c0\ubc84\uc2a4 \uacf5\uac04\uc5d0\uc11c \uc9c1\uc811 \ub3cc\uc544\ub2e4\ub2c8\uba70 \uad00\ub78c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "8K 3D VR\uc758 \uace0\ud654\uc9c8 \uc601\uc0c1\uc73c\ub85c \uc544\ud2f0\uc2a4\ud2b8\uc758 \uacf5\uc5f0\uc744 \ub354 \uc120\uba85\ud55c \ubab0\uc785\uac10\uc73c\ub85c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uacf5\uc5f0 \uc2dc\uccad\uc5d0\ub3c4 \uba40\ubbf8\uac10 \uc5c6\uc774 \uad00\ub78c \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc544\ud2f0\uc2a4\ud2b8\ub97c Eye Level\ub85c \ub208 \uc55e\uc5d0\uc11c \ubcf4\ub294 \ub4ef\ud55c \ubab0\uc785\uac10\uc744 \uad6c\ud604\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "03_\uc601\uc6c5\ud45c\uc9c0_3000x900.png", "id": "1233375317579645", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1233375320912978_2312981716732830757_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uI61Lli7aeUQ7kNvgFtYLyC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaFTIwmi9JpvDRYvhqtMz2giHs57LBgnvY5sGyzUgv3Q&oe=66F7D518"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1440x1440.png", "id": "1171750103750394", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1171750107083727_407813169638949737_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7CtjwJFaHYQ7kNvgEi6Si4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYeR-HK6cz4v59TMpkeaqA3b35qh9j3qQHzE2tXvz7Vg&oe=66F7EA4A"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1008x1440.png", "id": "816809249690649", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001703_816809253023982_5697252018931420675_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=le6vTJKrYpoQ7kNvgGJhG1q&_nc_ht=scontent.oculuscdn.com&oh=00_AYDc7KN2KP7VPVglvhDQDhMGsz2WixNnsvYfok4tS1bwiw&oe=66F7D4AA"}, {"file_name": "05_\uc571\uc544\uc774\ucf58_512x512.png", "id": "812578290033043", "image_type": "APP_