=1-7&_nc_sid=6e7a0a&_nc_ohc=NUiPjDjyHewQ7kNvgHcZron&_nc_ht=scontent.oculuscdn.com&oh=00_AYAd79x3021TLp_pIxTifpnJ3RdOE-sxS65R51d-zZgYhg&oe=66D06A12"}, {"file_name": "screen_shot_05.png", "id": "562269192374886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031396_562269195708219_747858643925041939_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jzY4pniQIsUQ7kNvgGm6wgy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDb3J5T0AIZeF_0GdYB5Abcdg8ussy28bHvPa_jdtBbZg&oe=66D0748B"}, {"file_name": "screen_shot_03.png", "id": "1188126361799241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575348_1188126365132574_7210804357987216834_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pvY8PGjYcIIQ7kNvgHNkWd4&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5XQEO-B0fhjdPDZNicpKCj2sQ1Z9QsM9O5Dbp98YBkQ&oe=66D05533"}, {"file_name": "screen_shot_04.png", "id": "1325732064889578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031417_1325732068222911_2838978085344824011_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcvbYWY-ZLwQ7kNvgFe9lW8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDq3vuG-4jXm9g2S-xo1KU5SIPxTMd4q-IMhVPNgrCsOg&oe=66D04AD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "04_\ud45c\uc9c0\uc774\ubbf8\uc9c0_2560x1440.png", "id": "1933609343697147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1933609347030480_6829772173375124862_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qbw6Fcv7iMsQ7kNvgFvLyf1&_nc_ht=scontent.oculuscdn.com&oh=00_AYCajbIWqeqYeGIQC3FPB2kDAZnqcyFmsedaqK3rwS-qeA&oe=66D04111"}, "display_name": "VENTA X", "keywords": [], "long_description": "''3D VR Cinematic Concert' exclusively brought to you by Venta X \n - A premium concert with a story that unfolds the artist's universe like a movie. \n - Our performance directing optimized for the VR environment and stereoscopic CG \nare offered to provide an extra special experience that is only achievable at VR concerts which is going beyond a normal offline concert. \n\nEnjoy a real offline concert with our '3D VR LIVE Concert' feature to experience the sense of presence at your house. \n- You will be able to enjoy your favorite artist\u2019s World Tour Concerts at your house with our 8K 3D VR LIVE Concert feature. \n- Wherever you are, all you need is your VR device to transform your surroundings into a concert hall. \n\nArtist Showroom \n- You can walk around and check out the 6dof metaverse space filled with your favorite artist and the performance-related content. ", "short_description": "Enjoy your favorite artist's performance with an immersive feeling from our 8K 3D VR high-definition videos. \nYou will be able to enjoy the performance without motion sickness even after watching it for a long time. \nExperience the immersive feeling as if you are looking at your favorite artist right in front of you making eye contacts.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ventavr.com/doc/private", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "747034206589337"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "457991779810698"}]}, "baseline_offer": {"id": "457991779810698"}, "is_app