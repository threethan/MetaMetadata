5497246859265", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_1635497250192598_4885713622178140194_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g1i0-6QY3e8Q7kNvgE6gmdZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDe53v130uZOQmaaFmYOCdttkDesXgYLuk8ZJ7sJt-Hag&oe=66D2F84B"}, {"file_name": "06_TEMPEST.png", "id": "1555218178586201", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334053_1555218181919534_3389336785450721409_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yGmOaa_IaXMQ7kNvgHnQ5_q&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfwyZVKB8ExfD2T_E1YrarfSQlbGlUBj-Hoi2Iwx1gCw&oe=66D2F093"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "309991668500167", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_309991671833500_7423572892990786868_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pZmXhibjgiQQ7kNvgFka_xm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMKMhGeth1WYf65L8BKLSRrpP1hGT448Owlc8C-iiesw&oe=66D30440"}, "display_name": "VENTA X", "keywords": [], "long_description": "VENTA X is an app that boasts the largest collection of K-POP 3D VR videos worldwide, allowing you to easily and diversely enjoy high-quality 3D VR videos of K-POP artists, including music broadcasts and concerts.\n\nFans from 60 countries around the globe are meeting K-POP artists through VENTA X's immersive 8K 3D VR content, as if they are right in front of their eyes.\n\nDiscover the latest 8K 3D VR content of K-POP artists, updated weekly!\n\n[VENTA X Original content: 8K 3D VR MUSIC CINEMA]\n\u00b7 A performance that unfolds the artist's songs with movie-like stories.\n\u00b7 VR-optimized performances and immersive CG.\n\n[VENTA X K-POP Series content: 8K 3D VR performance VOD]\n\u00b7 Experience the diverse aspects of K-POP artists, including performances and variety shows, in a three-dimensional VR content.", "short_description": "Enjoy K-POP content produced in immersive 8K 3D VR! You can watch for extended periods without experiencing motion sickness, and the content is shot from an eye-level perspective, allowing you to have an experience of making eye contact with K-POP artists. There's a plethora of content available for you to enjoy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://venta-x.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}, {"id": "337573230800174"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6825731684173976"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75584096_334757179247071_7111872606072916876_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UvCPPTwzNjgQ7kNvgEJu3gY&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3uZUn9CXoIXJJ1zvN63lt4IBLmvd9B5WPTMLA2G2gvA&oe=66D2F684"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VENTA X", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Music", "id": "668538087410124"}, {"topic_name": "Dance", "id": "548013192910304"}, {"topic_name": "TV Shows", "id": "337573230800174"}], "release_date": 1670519358, "lastRevision": {"nodes": [{"id": "5370589016354924", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5370588983021594", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "766834831187859"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "820358052662466", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ubca4\ud0c0\uc5d1\uc2a4", "keywords": [], "long_description": "\uc624\uc9c1, \ubca4\ud0c0X\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 '3D VR \uc2dc\ub124\ub9c8\ud2f1 \ucf58\uc11c\ud2b8'\n- \uc544\ud2f0\uc2a4\ud2b8\uc758 \uc138\uacc4\uad00\uc744 \ud55c \ud3b8\uc758 \uc601\ud654\ucc98\ub7fc \ud480\uc5b4\ub0b8 \uc2a4\ud1a0\ub9ac\uac00 \uc788\ub294 \ud504\ub9ac\ubbf8\uc5c4 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4. \n- VR \ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4 \uc5f0\ucd9c\uacfc \uc785\uccb4 CG\uac00 \ub354\ud574\uc838 VR\uc5d0\uc11c\ub9cc \uac00\ub2a5\ud55c \ucf58\uc11c\ud2b8 \uadf8 \uc774\uc0c1\uc758 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc2e4\uc81c \uc624\ud504\ub77c\uc778 \ucf58\uc11c\ud2b8\ub97c \ubc14\ub85c \ub0b4 \ub208 \uc55e\uc5d0\uc11c \uc990\uae30\ub294 '3D VR LIVE \ucf58\uc11c\ud2b8'\n- \uc6d4\ub4dc\ud22c\uc5b4 \ucf58\uc11c\ud2b8\ub97c 8K 3D VR LIVE\ub85c \uc5b4\ub514\uc11c\ub4e0\uc9c0 \uc990\uae38 \uc218 \uc788\ub294 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4.\n- \uace0\ud654\uc9c8/\uace0\ud574\uc0c1\ub3c4\uc758 \uacf5\uc5f0\uc744 VR \uae30\uae30\ub9cc \uc788\ub2e4\uba74 \uadf8\uacf3\uc774 \uacf5\uc5f0\uc7a5\uc73c\ub85c \ubcc0\ud558\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc544\ud2f0\uc2a4\ud2b8 Showroom\n- \uc544\ud2f0\uc2a4\ud2b8\uc640 \uacf5\uc5f0 \uad00\ub828 \ucf58\ud150\uce20\ub85c \uac00\ub4dd \ucc44\uc6cc\uc9c4 6dof \uba54\ud0c0\ubc84\uc2a4 \uacf5\uac04\uc5d0\uc11c \uc9c1\uc811 \ub3cc\uc544\ub2e4\ub2c8\uba70 \uad00\ub78c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "8K 3D VR\uc758 \uace0\ud654\uc9c8 \uc601\uc0c1\uc73c\ub85c \uc544\ud2f0\uc2a4\ud2b8\uc758 \uacf5\uc5f0\uc744 \ub354 \uc120\uba85\ud55c \ubab0\uc785\uac10\uc73c\ub85c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uacf5\uc5f0 \uc2dc\uccad\uc5d0\ub3c4 \uba40\ubbf8\uac10 \uc5c6\uc774 \uad00\ub78c \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc544\ud2f0\uc2a4\ud2b8\ub97c Eye Level\ub85c \ub208 \uc55e\uc5d0\uc11c \ubcf4\ub294 \ub4ef\ud55c \ubab0\uc785\uac10\uc744 \uad6c\ud604\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "03_\uc601\uc6c5\ud45c\uc9c0_3000x900.png", "id": "1233375317579645", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1233375320912978_2312981716732830757_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kyLbroE_rQQQ7kNvgF5EwUM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWNC0-YbJPhL4UD5lBwIVeIBrs9W-wY-wJ62BLVC-8eg&oe=66D2EB18"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1440x1440.png", "id": "1171750103750394", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1171750107083727_407813169638949737_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULwaWmvLlHQQ7kNvgHMH58B&_nc_ht=scontent.oculuscdn.com&oh=00_AYBK5qC2KGbd9J8Sh6SoYg52ePQZH9sM0IXijmjLOgCjNg&oe=66D3004A"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1008x1440.png", "id": "816809249690649", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001703_816809253023982_5697252018931420675_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XlFW9N-M8AAQ7kNvgF6D3E6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnGidsmGZnF1_QYBW4s_EjTXGchejYSzD4ONqkTbWlYw&oe=66D2EAAA"}, {"file_name": "05_\uc571\uc544\uc774\ucf58_512x512.png", "id": "812578290033043", "image_type": "APP_IMG_ICON", "uri": "https://sconten