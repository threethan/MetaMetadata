3389336785450721409_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wTRUGsHGgMMQ7kNvgEuk-l2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAc7vk1XtWMilkvF7oBa3hcvTlnjIb68G8e0q1bFGLWEg&oe=675C0C93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "886684883332180", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422392_886684886665513_3928802769089218270_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=19v58GEoHv0Q7kNvgEz7wb4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3y6CSm68O3XCgAcx43nKttVkiFhy1tZUUsa0f217w4g&oe=675C35CF"}, "display_name": "VENTA X", "keywords": ["VR", "POP", "3D", "Concert", "Music"], "long_description": "VENTA X is an app that boasts the largest collection of K-POP 3D VR videos worldwide, allowing you to easily and diversely enjoy high-quality 3D VR videos of K-POP artists, including music broadcasts and concerts.\n\nFans from 60 countries around the globe are meeting K-POP artists through VENTA X's immersive 8K 3D VR content, as if they are right in front of their eyes.\n\nDiscover the latest 8K 3D VR content of K-POP artists, updated weekly!\n\n[VENTA X Original content: 8K 3D VR MUSIC CINEMA]\n\u00b7 A performance that unfolds the artist's songs with movie-like stories.\n\u00b7 VR-optimized performances and immersive CG.\n\n[VENTA X K-POP Series content: 8K 3D VR performance VOD]\n\u00b7 Experience the diverse aspects of K-POP artists, including performances and variety shows, in a three-dimensional VR content.", "short_description": "Enjoy K-POP content produced in immersive 8K 3D VR! You can watch for extended periods without experiencing motion sickness, and the content is shot from an eye-level perspective, allowing you to have an experience of making eye contact with K-POP artists. There's a plethora of content available for you to enjoy!"}, {"images": {"nodes": [{"file_name": "00_Logo(Transparent).png", "id": "1444402182919663", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003255_1444402186252996_7014711383928885591_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FkgxsheuZDUQ7kNvgEhokYb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFdFf1a0BAk3btLmZm79fCxGLpeGuEbWiFZvPtwc-sXQ&oe=675C129D"}, {"file_name": "03_portrait.png", "id": "1171362250588035", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031467_1171362257254701_2035722783743461690_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bBsociO81asQ7kNvgGtfkwK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjsh3kBYBegi84RTgTjY4h5nSHS76IEcFPnsEeUhEc1A&oe=675C16A0"}, {"file_name": "01_Hero.png", "id": "1082791666697111", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556807_1082791670030444_157587303266942099_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6mjFbe-OnXsQ7kNvgHLgI5I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlEzXnQsMSd2lRrYcgdbijaDtejLenYE_qgGuGa1XPdg&oe=675C3BC3"}, {"file_name": "02_Landscape_OMGxLCY.png", "id": "1036921594358498", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974803_1036921601025164_7466508655244176603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WrLoYCuX5DEQ7kNvgHTuiIY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6WeANY8sPV_5Do2Nkg_rQRTEIAmAHaj4GBOek-uJNxQ&oe=675C1D89"}, {"file_name": "05_mini_Landscape_1080x360.png", "id": "827352726115382", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982659_827352729448715_3251657501699630758_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XYxOKvX4pz4Q7kNvgEpXECd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJCJfgm3cfFSsNU2ay7rvIAtHj7f56tZU1AossqJdLKg&oe=675C1F45"}, {"file_name": "01_Icon.png", "id": "769375391889552", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad