=scontent-iad3-2.oculuscdn.com&oh=00_AYB5_Ai8sPLwsGlWDWWaWBpkj_fedJnptH1JYTF7f_vJUw&oe=6707AC93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "886684883332180", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422392_886684886665513_3928802769089218270_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hf4qIVAv-J0Q7kNvgE7HfA3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAm626BDUu00KP_fAdcrJzD9c5u1oQPE03xni1OQFLOAw&oe=6707D5CF"}, "display_name": "VENTA X", "keywords": ["VR", "POP", "3D", "Concert", "Music"], "long_description": "VENTA X is an app that boasts the largest collection of K-POP 3D VR videos worldwide, allowing you to easily and diversely enjoy high-quality 3D VR videos of K-POP artists, including music broadcasts and concerts.\n\nFans from 60 countries around the globe are meeting K-POP artists through VENTA X's immersive 8K 3D VR content, as if they are right in front of their eyes.\n\nDiscover the latest 8K 3D VR content of K-POP artists, updated weekly!\n\n[VENTA X Original content: 8K 3D VR MUSIC CINEMA]\n\u00b7 A performance that unfolds the artist's songs with movie-like stories.\n\u00b7 VR-optimized performances and immersive CG.\n\n[VENTA X K-POP Series content: 8K 3D VR performance VOD]\n\u00b7 Experience the diverse aspects of K-POP artists, including performances and variety shows, in a three-dimensional VR content.", "short_description": "Enjoy K-POP content produced in immersive 8K 3D VR! You can watch for extended periods without experiencing motion sickness, and the content is shot from an eye-level perspective, allowing you to have an experience of making eye contact with K-POP artists. There's a plethora of content available for you to enjoy!"}, {"images": {"nodes": [{"file_name": "00_Logo(Transparent).png", "id": "1444402182919663", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003255_1444402186252996_7014711383928885591_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iVuT4_g1D-YQ7kNvgG494Zh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdnMb-uYs4hEJMQAydWxSj9juLuNtgJyUXMa3J4RhF6g&oe=6707B29D"}, {"file_name": "03_portrait.png", "id": "1171362250588035", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031467_1171362257254701_2035722783743461690_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2w1HITcWI5kQ7kNvgG-8H_v&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgrTCFI43qpXv8gyiwTkwmbO4_iTzx9SIxlXDoaa9r5g&oe=6707B6A0"}, {"file_name": "01_Hero.png", "id": "1082791666697111", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556807_1082791670030444_157587303266942099_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nbiyPxPiqlsQ7kNvgGHCo6s&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDT0MMZMTgQpY78xs2LBXOOIconYR1zNSZzE1kGR1uGTQ&oe=6707A383"}, {"file_name": "02_Landscape_OMGxLCY.png", "id": "1036921594358498", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974803_1036921601025164_7466508655244176603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TEnwjrHzHFcQ7kNvgHLYmkd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4S-PxsbkkaGfp5qlsADxq6vpTM42l1YstXCSmSZsSBw&oe=6707BD89"}, {"file_name": "05_mini_Landscape_1080x360.png", "id": "827352726115382", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982659_827352729448715_3251657501699630758_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v6GlbGrIDlEQ7kNvgG3SV-B&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9RVTufN2G2q9CVAn6kuiQxj50TA9UGG1XcfZtimPYIw&oe=6707BF45"}, {"file_name": "01_Icon.png", "id": "769375391889552", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031607_769375395222885_7144280537148493577_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a9e0Fu_07LgQ7kNvgEMve6b&_nc_ht=scont