GPc1EWUq&oh=00_AYCxpj1BFWUSE6RkG-QIVx6NswXMGPZfO3zUZlrYtpzA6Q&oe=66E81033"}, {"file_name": "screen_shot_04.png", "id": "1325732064889578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031417_1325732068222911_2838978085344824011_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UE6oF2NMIhAQ7kNvgGWvRRw&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYCp1NYPXNS5cPxZK7RwqtbOEbSXkNxK9EdIxNVL4NrEPA&oe=66E805D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "04_\ud45c\uc9c0\uc774\ubbf8\uc9c0_2560x1440.png", "id": "1933609343697147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1933609347030480_6829772173375124862_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4X5aFEr3mOMQ7kNvgGdpl5Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYCwdGxOeGG-1DXl4y7NOwLs3jUqevc6-t9LAdqG2I13tw&oe=66E7FC11"}, "display_name": "VENTA X", "keywords": [], "long_description": "''3D VR Cinematic Concert' exclusively brought to you by Venta X \n - A premium concert with a story that unfolds the artist's universe like a movie. \n - Our performance directing optimized for the VR environment and stereoscopic CG \nare offered to provide an extra special experience that is only achievable at VR concerts which is going beyond a normal offline concert. \n\nEnjoy a real offline concert with our '3D VR LIVE Concert' feature to experience the sense of presence at your house. \n- You will be able to enjoy your favorite artist\u2019s World Tour Concerts at your house with our 8K 3D VR LIVE Concert feature. \n- Wherever you are, all you need is your VR device to transform your surroundings into a concert hall. \n\nArtist Showroom \n- You can walk around and check out the 6dof metaverse space filled with your favorite artist and the performance-related content. ", "short_description": "Enjoy your favorite artist's performance with an immersive feeling from our 8K 3D VR high-definition videos. \nYou will be able to enjoy the performance without motion sickness even after watching it for a long time. \nExperience the immersive feeling as if you are looking at your favorite artist right in front of you making eye contacts.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ventavr.com/doc/private", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "747034206589337"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "457991779810698"}]}, "baseline_offer": {"id": "457991779810698"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1670519340, "status": "PUBLISHED", "id": "457991779810698"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8107534519327013", "version": "0.7.287"}, "id": "1233280367215178", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5370588983021594", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8107534519327013"}, "release_sta