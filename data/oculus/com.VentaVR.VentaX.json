P_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974774_255847844155207_8500068428010316949_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uuyGm4qklHQQ7kNvgHQ_vvZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYABQxq3fBhsmRQQvIXUQNCI-mnurqRZ0yq9EkaVS-36Pg&oe=66DD900F"}]}, "id": "711644797512782", "locale": "ko_KR", "screenshots": [{"file_name": "01_main.png", "id": "3622401108047796", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003286_3622401111381129_7349772023362246850_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4I0HanjP_2MQ7kNvgEnGmSf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqE16rYnkXGuvR6nXesp4owc5tPupqBXrB_Uv9Wgiwgw&oe=66DD8B80"}, {"file_name": "02_OMG.png", "id": "714517440735737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974494_714517444069070_8902172206727480207_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hds_Tan33TgQ7kNvgHIHgux&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8YAtIsb2HeEic9CFRUY58KYH7Rz-RQ9dnAOjX7s6Q6A&oe=66DD7581"}, {"file_name": "03_LCY.png", "id": "1616521142213837", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_1616521145547170_4433812390319894113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ydGiY90lFfYQ7kNvgHTD8tD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKcJeuv4Ciso0mHttqbSexOb6RvxozP2vXxxETrREWBA&oe=66DD7E78"}, {"file_name": "04_IZONE.png", "id": "874388643973433", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974774_874388647306766_6514325373967558355_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dRsRNNU7v7wQ7kNvgER0aNd&_nc_ht=scontent.oculuscdn.com&oh=00_AYABdPB2orieBEL7npR9Gv6MiJJWvKtFqVh09lXzfJuHXQ&oe=66DD9217"}, {"file_name": "06_TEMPEST.png", "id": "881861403155632", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_881861406488965_7761861626454403146_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=etKMqPvrYtQQ7kNvgG3Xnm_&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_hJgwHTCj8v1S6Zund5EyfmbAQ0Hd8wbaCbuEtNj6yg&oe=66DD75DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "1084277152504107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570306_1084277155837440_3151073603281609672_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zx6zZpAEBC4Q7kNvgFSZ-fC&_nc_ht=scontent.oculuscdn.com&oh=00_AYChZhJ-hAz9A5OqSPtXt5lMGsAnHfxKKr2kcOvpIl6GRw&oe=66DDA1EC"}, "display_name": "VENTA X", "keywords": [], "long_description": "VENTA X\ub294 \uc804 \uc138\uacc4 \ucd5c\ub2e4 K-POP 3D VR \uc601\uc0c1\uc744 \ubcf4\uc720\ud55c \uc571\uc73c\ub85c \uc74c\uc545\ubc29\uc1a1, \ucf58\uc11c\ud2b8 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ucd08\uace0\ud654\uc9c8 3D VR \uc601\uc0c1\uc744 \uac00\uc7a5 \uc27d\uace0 \ub2e4\uc591\ud558\uac8c \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc804 \uc138\uacc4 60\uac1c\uad6d K-POP \ud32c\ub4e4\uc774 \ub9c8\uce58 \ub0b4 \ub208 \uc55e\uc5d0 \uc788\ub294 \uac83\ucc98\ub7fc, \uc815\ub9d0 \uc2e4\uac10\ub098\ub294 VENTA X\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ud1b5\ud574 K-POP \uc544\ud2f0\uc2a4\ud2b8\ub97c \ub9cc\ub098\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub9e4\uc8fc \uc0c8\ub86d\uac8c \uc5c5\ub370\uc774\ud2b8 \ub418\ub294 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ub9cc\ub098\ubcf4\uc138\uc694!\n\n[VENTA X Original content : 8K 3D VR MUSIC CINEMA]\n\u00b7 \uc544\ud2f0\uc2a4\ud2b8\uc758 \uace1\uc744 \uc601\ud654\uac19\uc740 \uc2a4\ud1a0\ub9ac\ub85c \ud3bc\uccd0\ub0b4\ub294 \uacf5\uc5f0\n\u00b7 VR\ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4\uc640 \uc785\uccb4 CG\n\n[VENTA X K-POP Series content : 8K 3D VR performance VOD]\n\u00b7 \uacf5\uc5f0, \uc608\ub2a5 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ub2e4\uc591\ud55c \ubaa8\uc2b5\uc744 \uc785\uccb4\uc801\uc73c\ub85c \ubcfc \uc218 \uc788\ub294 3D VR \ucf58\ud150\uce20", "short_description": "8K 3D VR\ub85c \uc81c\uc791\ub41c K-POP \ucf58\ud150\uce20\ub97c \ubab0\uc785\uac10 \uc788\uac8c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uad00\ub78c\uc5d0\ub3c4 \uba40\ubbf8\uac00 \uc5c6\uace0 \uc544\uc774\ub808\ubca8\ubdf0\ub85c \ucd2c\uc601\ub418\uc5b4 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc640 \ub208\uc744 \ub9de\ucd94\ub294 \uacbd\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 \ucf58\ud150\uce20\uac00 \uac00\ub4dd\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "02_Landscape_OMGxLCY.png", "id": "1981310828929556", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254876_1981310835596222_667783510401865147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EyaHP1vxzDsQ7kNvgFWDSx8&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4Tl0yIDTjGxoY_CFDBGaze0rE-3MUxipySC3kuSglaQ&oe=66DD8C6B"}, {"file_name": "01_Hero.png", "id": "1437583666800708", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982575_1437583670134041_7743040293531665854_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fCT___6-V0UQ7kNvgElPdON&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBGn6j2jxo1niPxnv3QYGXjb0wNZFNKXMfF_wZrPEK4g&oe=66DD85BB"}, {"file_name": "03_portrait.png", "id": "1021482895734406", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_1021482899067739_7301234032120213073_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93C_-x4WzskQ7kNvgHWGu2N&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjoBmUwNsjSE5a-uITOHQlYJa6heI00iEQead6zXKz4A&oe=66DD8AC6"}, {"file_name": "00_icon_512.png", "id": "1018117859448568", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_1018117862781901_5027150983061586467_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDDJsGLZ9C0Q7kNvgHThIPL&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuLhlBmhez71DNTnfteJvZ3pVbF7VszMvTRD-bilk9kw&oe=66DD711E"}, {"file_name": "04_Square.png", "id": "334757175913738", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75584096_334757179247071_7111872606072916876_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6