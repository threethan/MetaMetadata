=1-7&_nc_sid=6e7a0a&_nc_ohc=GzpjcRRHVZUQ7kNvgENcQ6Y&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlalqxpM83cZKJIXzaSi102shaJBgnpeTaDHbeG2NAeA&oe=66D30D12"}, {"file_name": "screen_shot_05.png", "id": "562269192374886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031396_562269195708219_747858643925041939_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oyIhnsHVY-YQ7kNvgHYfSTC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsyqiYrxnm1jeN5SEEbj-5lJ3U-bMIxUAuw_frwD7kdA&oe=66D3178B"}, {"file_name": "screen_shot_03.png", "id": "1188126361799241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575348_1188126365132574_7210804357987216834_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u8-tRx7abUUQ7kNvgH0zFXE&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_QueFSGnM8azZJ-btAC179s5USwkSxAY4WjnJLi2jvQ&oe=66D2F833"}, {"file_name": "screen_shot_04.png", "id": "1325732064889578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031417_1325732068222911_2838978085344824011_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcvbYWY-ZLwQ7kNvgEQdPpT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBikYujNU8ZvsAzGCzUYp2mujmqjb-_y7BvoqtVNWhmzQ&oe=66D2EDD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "04_\ud45c\uc9c0\uc774\ubbf8\uc9c0_2560x1440.png", "id": "1933609343697147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1933609347030480_6829772173375124862_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-xbZSctmSNsQ7kNvgEqUvl6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPd__1lkrbWoGS7SkZfz8afBB_cZETFm8-5wjAgfKm7w&oe=66D2E411"}, "display_name": "VENTA X", "keywords": [], "long_description": "''3D VR Cinematic Concert' exclusively brought to you by Venta X \n - A premium concert with a story that unfolds the artist's universe like a movie. \n - Our performance directing optimized for the VR environment and stereoscopic CG \nare offered to provide an extra special experience that is only achievable at VR concerts which is going beyond a normal offline concert. \n\nEnjoy a real offline concert with our '3D VR LIVE Concert' feature to experience the sense of presence at your house. \n- You will be able to enjoy your favorite artist\u2019s World Tour Concerts at your house with our 8K 3D VR LIVE Concert feature. \n- Wherever you are, all you need is your VR device to transform your surroundings into a concert hall. \n\nArtist Showroom \n- You can walk around and check out the 6dof metaverse space filled with your favorite artist and the performance-related content. ", "short_description": "Enjoy your favorite artist's performance with an immersive feeling from our 8K 3D VR high-definition videos. \nYou will be able to enjoy the performance without motion sickness even after watching it for a long time. \nExperience the immersive feeling as if you are looking at your favorite artist right in front of you making eye contacts.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ventavr.com/doc/private", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "747034206589337"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "457991779810698"}]}, "baseline_offer": {"id": "457991779810698"}, "is_app