4771211", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001681_534718488104544_8015496589210106655_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rj1DSY-5mIsQ7kNvgH5ZdAQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIPU4HKq2b_oRsJ0pHoeAd7kspKB_trXXOoOL-iGKLiw&oe=66DEEA92"}, {"file_name": "screen_shot_05.png", "id": "562269192374886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031396_562269195708219_747858643925041939_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_UGWYC33wtkQ7kNvgHYsr8z&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQz_hToXQpIWdHbR4ZpM_nlvjgixWCEJhhv2svVSSe6w&oe=66DEF50B"}, {"file_name": "screen_shot_03.png", "id": "1188126361799241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575348_1188126365132574_7210804357987216834_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4-xYhdd5wxIQ7kNvgFsNN5K&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6xGvegfAHdPF9Daz9zMfLK51yll5joJU-6rjCG-KPog&oe=66DED5B3"}, {"file_name": "screen_shot_04.png", "id": "1325732064889578", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031417_1325732068222911_2838978085344824011_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uj76pnzBoWwQ7kNvgFg8yAT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCGhZQrZv-M4LIyjJcNKx0qXyPiw-qoQ2-sifQi5iSBGQ&oe=66DECB55"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "04_\ud45c\uc9c0\uc774\ubbf8\uc9c0_2560x1440.png", "id": "1933609343697147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982657_1933609347030480_6829772173375124862_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7Pe0b0XOX0Q7kNvgHYwiID&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-NsheGiEtQRroperzJhPn9AugT9kUibkjGx-U8_bvrA&oe=66DEC191"}, "display_name": "VENTA X", "keywords": [], "long_description": "''3D VR Cinematic Concert' exclusively brought to you by Venta X \n - A premium concert with a story that unfolds the artist's universe like a movie. \n - Our performance directing optimized for the VR environment and stereoscopic CG \nare offered to provide an extra special experience that is only achievable at VR concerts which is going beyond a normal offline concert. \n\nEnjoy a real offline concert with our '3D VR LIVE Concert' feature to experience the sense of presence at your house. \n- You will be able to enjoy your favorite artist\u2019s World Tour Concerts at your house with our 8K 3D VR LIVE Concert feature. \n- Wherever you are, all you need is your VR device to transform your surroundings into a concert hall. \n\nArtist Showroom \n- You can walk around and check out the 6dof metaverse space filled with your favorite artist and the performance-related content. ", "short_description": "Enjoy your favorite artist's performance with an immersive feeling from our 8K 3D VR high-definition videos. \nYou will be able to enjoy the performance without motion sickness even after watching it for a long time. \nExperience the immersive feeling as if you are looking at your favorite artist right in front of you making eye contacts.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ventavr.com/doc/private", "developer_terms_of_service_url": null, "publisher_name": "VENTA VR", "support_website_url": null, "website_url": "https://venta-x.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "747034206589337"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "457991779810698"}]}, "baseline_offer": {"id": "457991779810698"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1670519340, "status": "PUBLISHED", "id": "457991779810698"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8107534519327013", "version": "0.7.287"}, "id": "1233280367215178", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5370588983021594", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8107534519327013"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1233280367215178"}]}, "change_log": "Hello!\nThis is VENTA X.\n\nHere are the new features and changes coming in the update.\n\n[NEW FEATURES]\nSign-Up Feature :\n - The app has been updated to allow automatic login after signing up.\n\nThank you.\nVENTA X\n\n\u25cf VENTA X Official Homepage - https://www.venta-x.com/\n\n\n\n\uc548\ub155\ud558\uc138\uc694!\nVENTA X\uc785\ub2c8\ub2e4.\n\n\uc774\ubc88 \uc5c5\ub370\uc774\ud2b8\uc5d0\uc11c \ucd94\uac00\ub418\ub294 \uae30\ub2a5 \ubc0f \ubcc0\uacbd \uc0ac\ud56d\uc740 \uc544\ub798\uc640 \uac19\uc2b5\ub2c8\ub2e4.\n\n[\uae30\ub2a5 \ucd94\uac00]\n\uc571 \ub0b4 \ud68c\uc6d0\uac00\uc785 \uae30\ub2a5 :\n - \uc571\uc5d0\uc11c \ud68c\uc6d0\uac00\uc785 \ud6c4 \uc790\ub3d9 \ub85c\uadf8\uc778\uc774 \uac00\ub2a5\ud558\ub3c4\ub85d \uc5c5\ub370\uc774\ud2b8 \ub418\uc5c8\uc2b5\ub2c8\ub2e4.\n\n\uac10\uc0ac\ud569\ub2c8\ub2e4.\nVENTA X\n\n\u25cf VENTA X Official Homepage - https://www.venta-x.com/", "created_date": 1724826661, "id": "8107534519327013", "version": "0.7.287", "version_code": 56, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"n