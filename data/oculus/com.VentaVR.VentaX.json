video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "1084277152504107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570306_1084277155837440_3151073603281609672_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KeUtPJR-6RsQ7kNvgE1af-x&_nc_ht=scontent.oculuscdn.com&oh=00_AYApqxianV-vNlj59A4E19lOBRzpq3XghJdumx3jq8kKIw&oe=66CC7E6C"}, "display_name": "VENTA X", "keywords": [], "long_description": "VENTA X\ub294 \uc804 \uc138\uacc4 \ucd5c\ub2e4 K-POP 3D VR \uc601\uc0c1\uc744 \ubcf4\uc720\ud55c \uc571\uc73c\ub85c \uc74c\uc545\ubc29\uc1a1, \ucf58\uc11c\ud2b8 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ucd08\uace0\ud654\uc9c8 3D VR \uc601\uc0c1\uc744 \uac00\uc7a5 \uc27d\uace0 \ub2e4\uc591\ud558\uac8c \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc804 \uc138\uacc4 60\uac1c\uad6d K-POP \ud32c\ub4e4\uc774 \ub9c8\uce58 \ub0b4 \ub208 \uc55e\uc5d0 \uc788\ub294 \uac83\ucc98\ub7fc, \uc815\ub9d0 \uc2e4\uac10\ub098\ub294 VENTA X\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ud1b5\ud574 K-POP \uc544\ud2f0\uc2a4\ud2b8\ub97c \ub9cc\ub098\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ub9e4\uc8fc \uc0c8\ub86d\uac8c \uc5c5\ub370\uc774\ud2b8 \ub418\ub294 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 8K 3D VR \ucf58\ud150\uce20\ub97c \ub9cc\ub098\ubcf4\uc138\uc694!\n\n[VENTA X Original content : 8K 3D VR MUSIC CINEMA]\n\u00b7 \uc544\ud2f0\uc2a4\ud2b8\uc758 \uace1\uc744 \uc601\ud654\uac19\uc740 \uc2a4\ud1a0\ub9ac\ub85c \ud3bc\uccd0\ub0b4\ub294 \uacf5\uc5f0\n\u00b7 VR\ud658\uacbd\uc5d0 \ucd5c\uc801\ud654\ub41c \ud37c\ud3ec\uba3c\uc2a4\uc640 \uc785\uccb4 CG\n\n[VENTA X K-POP Series content : 8K 3D VR performance VOD]\n\u00b7 \uacf5\uc5f0, \uc608\ub2a5 \ub4f1 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc758 \ub2e4\uc591\ud55c \ubaa8\uc2b5\uc744 \uc785\uccb4\uc801\uc73c\ub85c \ubcfc \uc218 \uc788\ub294 3D VR \ucf58\ud150\uce20", "short_description": "8K 3D VR\ub85c \uc81c\uc791\ub41c K-POP \ucf58\ud150\uce20\ub97c \ubab0\uc785\uac10 \uc788\uac8c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uad00\ub78c\uc5d0\ub3c4 \uba40\ubbf8\uac00 \uc5c6\uace0 \uc544\uc774\ub808\ubca8\ubdf0\ub85c \ucd2c\uc601\ub418\uc5b4 K-POP \uc544\ud2f0\uc2a4\ud2b8\uc640 \ub208\uc744 \ub9de\ucd94\ub294 \uacbd\ud5d8\uc744 \ud560 \uc218 \uc788\ub294 \ucf58\ud150\uce20\uac00 \uac00\ub4dd\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "02_Landscape_OMGxLCY.png", "id": "1981310828929556", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254876_1981310835596222_667783510401865147_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hi20nc0rCS8Q7kNvgFSgbb7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBiByyLEaTEuKFihK4-_IAAlabGLKUIFuTI05P3lXhRZQ&oe=66CC68EB"}, {"file_name": "01_Hero.png", "id": "1437583666800708", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982575_1437583670134041_7743040293531665854_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AhT-t3cC88MQ7kNvgFLyEFo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMQLucQLcRvllqRTQmAqFmj1DpBP4EDebRPbNLa0JRuQ&oe=66CC623B"}, {"file_name": "03_portrait.png", "id": "1021482895734406", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_1021482899067739_7301234032120213073_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdboJbt0-U0Q7kNvgFuwwal&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8u0jiyjCR7esHuhTnDC6D1ESBaWK9q4r0ygUl4uWStg&oe=66CC6746"}, {"file_name": "00_icon_512.png", "id": "1018117859448568", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_1018117862781901_5027150983061586467_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fTLAKbtkDBEQ7kNvgHfnJp8&_nc_ht=scontent.oculuscdn.com&oh=00_AYAy6xKoUPHLFKuoi-o8BHSFmBvfrvK_19H6X_Kj351Uag&oe=66CC4D9E"}, {"file_name": "04_Square.png", "id": "334757175913738", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75584096_334757179247071_7111872606072916876_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6