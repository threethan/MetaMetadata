3389336785450721409_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QK8pLqx5CQoQ7kNvgE7PAa1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC14fF3zd5Rjl4joLOeIaP-H92CsozB7B5dwNyVrF9mkg&oe=6735D113"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "886684883332180", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422392_886684886665513_3928802769089218270_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xFozLtOF32MQ7kNvgGC2KWT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGXLvv3U0yYo8fejTeXNLlXY2n9vjZ0TilKpWSHzMTRQ&oe=6735FA4F"}, "display_name": "VENTA X", "keywords": ["VR", "POP", "3D", "Concert", "Music"], "long_description": "VENTA X is an app that boasts the largest collection of K-POP 3D VR videos worldwide, allowing you to easily and diversely enjoy high-quality 3D VR videos of K-POP artists, including music broadcasts and concerts.\n\nFans from 60 countries around the globe are meeting K-POP artists through VENTA X's immersive 8K 3D VR content, as if they are right in front of their eyes.\n\nDiscover the latest 8K 3D VR content of K-POP artists, updated weekly!\n\n[VENTA X Original content: 8K 3D VR MUSIC CINEMA]\n\u00b7 A performance that unfolds the artist's songs with movie-like stories.\n\u00b7 VR-optimized performances and immersive CG.\n\n[VENTA X K-POP Series content: 8K 3D VR performance VOD]\n\u00b7 Experience the diverse aspects of K-POP artists, including performances and variety shows, in a three-dimensional VR content.", "short_description": "Enjoy K-POP content produced in immersive 8K 3D VR! You can watch for extended periods without experiencing motion sickness, and the content is shot from an eye-level perspective, allowing you to have an experience of making eye contact with K-POP artists. There's a plethora of content available for you to enjoy!"}, {"images": {"nodes": [{"file_name": "00_Logo(Transparent).png", "id": "1444402182919663", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003255_1444402186252996_7014711383928885591_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=prIDIrhxQt0Q7kNvgGQepmY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAp-tQcrL5MVoEkqAjGaasUbm2lNBJRjKRpGjVT-qFyjA&oe=6735D71D"}, {"file_name": "03_portrait.png", "id": "1171362250588035", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031467_1171362257254701_2035722783743461690_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OPzA5DHb1O0Q7kNvgHrRG7L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3Z_j1360XQxW1xw_J9UxALl73SKlzPyGTke7Go3qsaQ&oe=6735DB20"}, {"file_name": "01_Hero.png", "id": "1082791666697111", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556807_1082791670030444_157587303266942099_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BZXxqhCAJxYQ7kNvgE6opkj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6Y-cgLqLrx1gdeBldu748stz-zZrHTsmE--q8Qpasrg&oe=6735C803"}, {"file_name": "02_Landscape_OMGxLCY.png", "id": "1036921594358498", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974803_1036921601025164_7466508655244176603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eTj-aqX8upYQ7kNvgFMg9eL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqRa_4cbs7QVKwqsdJ67gM6Gp6sB6HsUl33w5WJN7bCg&oe=6735E209"}, {"file_name": "05_mini_Landscape_1080x360.png", "id": "827352726115382", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982659_827352729448715_3251657501699630758_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iWlxrKD5DXMQ7kNvgFgHLC4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDso9ahf0pxXS9Dqnc324UhDCq2kqQxsLJUhikC-eY_6g&oe=6735E3C5"}, {"file_name": "01_Icon.png", "id": "769375391889552", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad