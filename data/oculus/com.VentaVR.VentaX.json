85c \uc5b4\ub514\uc11c\ub4e0\uc9c0 \uc990\uae38 \uc218 \uc788\ub294 \ucf58\uc11c\ud2b8\uc785\ub2c8\ub2e4.\n- \uace0\ud654\uc9c8/\uace0\ud574\uc0c1\ub3c4\uc758 \uacf5\uc5f0\uc744 VR \uae30\uae30\ub9cc \uc788\ub2e4\uba74 \uadf8\uacf3\uc774 \uacf5\uc5f0\uc7a5\uc73c\ub85c \ubcc0\ud558\ub294 \uacbd\ud5d8\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n\uc544\ud2f0\uc2a4\ud2b8 Showroom\n- \uc544\ud2f0\uc2a4\ud2b8\uc640 \uacf5\uc5f0 \uad00\ub828 \ucf58\ud150\uce20\ub85c \uac00\ub4dd \ucc44\uc6cc\uc9c4 6dof \uba54\ud0c0\ubc84\uc2a4 \uacf5\uac04\uc5d0\uc11c \uc9c1\uc811 \ub3cc\uc544\ub2e4\ub2c8\uba70 \uad00\ub78c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.", "short_description": "8K 3D VR\uc758 \uace0\ud654\uc9c8 \uc601\uc0c1\uc73c\ub85c \uc544\ud2f0\uc2a4\ud2b8\uc758 \uacf5\uc5f0\uc744 \ub354 \uc120\uba85\ud55c \ubab0\uc785\uac10\uc73c\ub85c \uc990\uaca8\ubcf4\uc138\uc694.\n\uc7a5\uc2dc\uac04 \uacf5\uc5f0 \uc2dc\uccad\uc5d0\ub3c4 \uba40\ubbf8\uac10 \uc5c6\uc774 \uad00\ub78c \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc544\ud2f0\uc2a4\ud2b8\ub97c Eye Level\ub85c \ub208 \uc55e\uc5d0\uc11c \ubcf4\ub294 \ub4ef\ud55c \ubab0\uc785\uac10\uc744 \uad6c\ud604\ud569\ub2c8\ub2e4."}, {"images": {"nodes": [{"file_name": "03_\uc601\uc6c5\ud45c\uc9c0_3000x900.png", "id": "1233375317579645", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031355_1233375320912978_2312981716732830757_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BMY8KjR5lbYQ7kNvgERwr_O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0Na4rbXi8EWlnRVOhEz6c8jTvKBr10QgTTSeW3w5cTA&oe=676BD918"}, {"file_name": "02_\ucee4\ubc84\uc544\ud2b8_1440x1440.png", "id": "1171750103750394", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982657_1171750107083727_407813169638949737_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Og2-k17sPb4Q7kNvgELgYzd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDU5PFsXXAD5RbpBV0p72nEh3ghxXgm_MTU1BkXLTSYjQ&oe=676BEE4