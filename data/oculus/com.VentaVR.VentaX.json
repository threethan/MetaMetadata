1555218178586201", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334053_1555218181919534_3389336785450721409_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NCi6_gOLY7cQ7kNvgGiCwvb&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYBqbaKfCZh1FSs18YLke04LNaBBdd-YzKs_BidprWHd4g&oe=66E80893"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02_Landscape_OMGxLCY.png", "id": "886684883332180", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422392_886684886665513_3928802769089218270_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WGfZimroERkQ7kNvgHppwae&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYAXi8ZRM-ERR8ZLpq9hZ01d8RNcmWL-3QqeyFy8vgsfwA&oe=66E831CF"}, "display_name": "VENTA X", "keywords": ["VR", "POP", "3D", "Concert", "Music"], "long_description": "VENTA X is an app that boasts the largest collection of K-POP 3D VR videos worldwide, allowing you to easily and diversely enjoy high-quality 3D VR videos of K-POP artists, including music broadcasts and concerts.\n\nFans from 60 countries around the globe are meeting K-POP artists through VENTA X's immersive 8K 3D VR content, as if they are right in front of their eyes.\n\nDiscover the latest 8K 3D VR content of K-POP artists, updated weekly!\n\n[VENTA X Original content: 8K 3D VR MUSIC CINEMA]\n\u00b7 A performance that unfolds the artist's songs with movie-like stories.\n\u00b7 VR-optimized performances and immersive CG.\n\n[VENTA X K-POP Series content: 8K 3D VR performance VOD]\n\u00b7 Experience the diverse aspects of K-POP artists, including performances and variety shows, in a three-dimensional VR content.", "short_description": "Enjoy K-POP content produced in immersive 8K 3D VR! You can watch for extended periods without experiencing motion sickness, and the content is shot from an eye-level perspective, allowing you to have an experience of making eye contact with K-POP artists. There's a plethora of content available for you to enjoy!"}, {"images": {"nodes": [{"file_name": "00_Logo(Transparent).png", "id": "1444402182919663", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003255_1444402186252996_7014711383928885591_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3IiXuw0zx5YQ7kNvgHNWWLF&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYB5Ss6Jhu6-mYNUIhOM7Q4jlxNkj1G5kSa_i8QOssknCQ&oe=66E80E9D"}, {"file_name": "03_portrait.png", "id": "1171362250588035", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031467_1171362257254701_2035722783743461690_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ehD9u7DadNwQ7kNvgEWkSjk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYCghl2HMvqDx7k_0wFqaKU_BRIQiRwX-_1OyjfShcDu6Q&oe=66E812A0"}, {"file_name": "01_Hero.png", "id": "1082791666697111", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556807_1082791670030444_157587303266942099_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gVa2Hbig440Q7kNvgEZHaET&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYDQ3IeDrnG5QCubi5B2oP-BkePXeOkC8_H-r1noQV8lpQ&oe=66E7FF83"}, {"file_name": "02_Landscape_OMGxLCY.png", "id": "1036921594358498", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974803_1036921601025164_7466508655244176603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eS-5jJStO4EQ7kNvgFvdMq5&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYAlWwSqOmk0j3thTSskMYG3eprnXx69ivZm9QHwHZbKag&oe=66E81989"}, {"file_name": "05_mini_Landscape_1080x360.png", "id": "827352726115382", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_827352729448715_3251657501699630758_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZEVEWunIKzEQ7kNvgHPG9cR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApKcZjvYoAwnx23GPc1EWUq&oh=00_AYBj3u