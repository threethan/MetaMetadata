ourism", "keywords": [], "long_description": "With this app you will be able to explore wonderful destinations and landmarks of Georgia, the country, where you will find experiences totally worth exploring. You can experience destination listed in this app at your own pace. Just gaze over the waypoints in front of you and start exploring. \n\"Explore Georgia\" app was created and published by VRex Immersive. Our mission is to help travelers worldwide explore destinations and tourist activities in VR.\n", "short_description": "Explore diverse and exciting Georgia, the country where winemaking was born!\nExperience Georgian travel destinations, cultural heritage and theaters with this interactive VR app. \nYou will be able to navigate through the app by simply aiming at the menu items and waypoints you see.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.vrexbox.com/", "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": null, "website_url": "https://vrexbox.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5329456090419996"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "4721352517906391"}]}, "baseline_offer": {"id": "4721352517906391"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1608228027, "status": "PUBLISHED", "id": "4721352517906391"}]}, "liveChannel": {"nodes": [{"latest