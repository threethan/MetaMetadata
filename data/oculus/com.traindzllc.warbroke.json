E4A15"}, {"file_name": "Screen2.png", "id": "3860919684134995", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974887_3860919687468328_847966470490229895_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jtQbTd5xRwgQ7kNvgFfsDN3&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBfsrtq53HhVU4HqFs4sqPCOFZ9aGOhZjNmipqWOj-lgw&oe=677E7A3C"}, {"file_name": "Screen3.png", "id": "1380340509424621", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38982656_1380340512757954_6078701553812775564_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LUSzHs7h4HQQ7kNvgGK0n53&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYBRpbfGMThucQCJ9yIZgjX0fICp5DCi_xO8KOFlL37H9A&oe=677E5846"}, {"file_name": "Screen1.png", "id": "948802223107406", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974813_948802226440739_1355161462311305423_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EqWSwUDBOBYQ7kNvgGCn8Nq&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCWsImF7fmXt7HxpG5yKMsjbbembhS25412xF8-QCngpw&oe=677E73C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE.png", "id": "181187054873902", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38984448_181187058207235_6817043556417277513_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=byFXuMReT9QQ7kNvgGVnQrT&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYB_yTSrldSmFaErXqrwyoii3inH2kNGnvFkJ3fwCQdU8A&oe=677E5C83"}, "display_name": "War Broke in Heaven", "keywords": [], "long_description": "Based on the events of the beginning and the end, this VR experience may cause motion sickness, user discretion is advised.\n\nWar Broke in Heaven is a VR experience that puts you in the air while you fight enemies and a dragon to stop the ultimate rebellion. Use controlled moving and tactics to destroy the enemy and not get engulfed by their attacks. You will have a variety of weapons at your disposal each with a unique attribute to destroy your enemy. \n\nUse your head to look at the directions you want to fly to and slash, or fire spirit bombs at the enemy. War broke in heaven has beautiful graphics that will keep you in awe and that will leave you having fun and wanting to come back to play more. ", "short_description": "An epic battle and the fall of a rebellion, this VR experience will keep you engaged and entertained "}]}, "developer_name": "Traindz LLC", "developer_privacy_policy_url": "https://www.traindz.com/warbrokeinheaven", "developer_terms_of_service_url": null, "publisher_name": "Traindz LLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1196559731056726"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974843_232458709386805_3077251822818418283_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RIXiHQZpXecQ7kNvgEdn5yq&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYATSXI1zK27rGUCJ9MUN3g4FjficLbCbvaoS-6CHW4kVg&oe=677E720F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "War Broke in Heaven", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1683647096, "lastRevisio