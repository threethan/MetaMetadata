 have a variety of weapons at your disposal each with a unique attribute to destroy your enemy. \n\nUse your head to look at the directions you want to fly to and slash, or fire spirit bombs at the enemy. War broke in heaven has beautiful graphics that will keep you in awe and that will leave you having fun and wanting to come back to play more. ", "short_description": "An epic battle and the fall of a rebellion, this VR experience will keep you engaged and entertained "}]}, "developer_name": "Traindz LLC", "developer_privacy_policy_url": "https://www.traindz.com/warbrokeinheaven", "developer_terms_of_service_url": null, "publisher_name": "Traindz LLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1196559731056726"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974843_232458709386805_3077251822818418283_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xn7U9Cpp3PEQ7kNvgF9M98C&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJE-7oXxaWNKxRPbh5Q5AQ8&oh=00_AYAmcYVyTVtCRe2Iaq-XHl_IORxhzCdH-ZIisPftKtQk3A&oe=66EC1B8F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "War Broke in Heaven", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "27433260