4442_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T487-yv0dtUQ7kNvgEe9GT2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZEOQeosBUru6o3gYNufL9XwlIYXaaFE6OXp1YJpTrYQ&oe=670A53D2"}, {"file_name": "migrated_image.png", "id": "206944537066579", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12138900_970218879705301_1750044479_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E80OG8u_DDcQ7kNvgH-dK76&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhMzhtsfTRNep69d6aEHRZttLuOQFIYPoOxIL_Rnm93A&oe=670A54B1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Dead Secret", "keywords": ["adventure", "dead", "game", "games", "mystery", "paranormal", "puzzle", "scary", "zombie"], "long_description": "Who killed Harris Bullard?\n\nA reclusive man with a mysterious past is dead, and it's up to you to crack the case. Investigate the crime scene, uncover secret documents and piece together the puzzle to name the killer. But keep your wits about you: nothing is as it seems and you are not alone. Bullard took his secrets to the grave. Somebody wants them to stay there. \n\nDead Secret is an original mystery thriller designed exclusively for Gear VR.", "short_description": "A reclusive man with a mysterious past is dead, and it's up to you to crack the case. Investigate the crime scene, uncover secret documents and piece together the puzzle to name the killer. But keep your wits about you: nothing is as it seems and you are not alone. Bullard took his secrets to the grave. Somebody wants them to stay there. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://deadsecret.com/", "developer_terms_of_service_url": "http://deadsecret.com/", "publisher_name": "Robot Invader", "support_website_url": null, "website_url": "http://deadsecret.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "HORROR