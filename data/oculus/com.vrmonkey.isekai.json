deo_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover1.png", "id": "1063769158796579", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036603_1063769162129912_8410577913387167135_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y70t9jhy9cQQ7kNvgGSmBIU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAuFTUzoc00Eig25okPC7j54iWuKZYQzTjDvNPZjXrHPg&oe=6780F050"}, "display_name": "Anime School - Fight Club Simulator (Early Access)", "keywords": ["anime", "fight", "school", "boxing", "sorcery"], "long_description": "Strange changes are sweeping through your high school as some students start exhibiting unusual powers. You\u2019re thrust into a dangerous mystery that links your world to bizarre, anime-inspired dimensions. As you battle your way through various parody worlds, your ultimate goal is to solve the mystery and stop the growing threat that endangers both realities.\n\n{1552556698687179}\n\n# Key Features:\n- **Physically Simulated Combat**: Engage in fluid, realistic battles where every punch, kick, and move is fully physically simulated. Use the environment, dodge attacks, and throw enemies with a visceral, grounded feel.\n{491015480393946}\n\n\n- **Explore Anime Parody Worlds**: Travel through unique anime-inspired dimensions, each parodying popular shows and genres. Encounter diverse styles, characters, and challenging environments.\n{745705460994153}\n\n- **Learn Special Moves**: Unlock powerful techniques as you advance, enhancing your combat skills and adding strategic depth to your fights.\n{549704514383368}\n\n\n- **Deep Story-Driven Mystery**: Uncover the truth behind strange transformations at your school and solve the mystery linking to a parallel anime world. Your choices will influence the story's outcome.\n{373424095824237}\n\n\n\n# The World of Isekai:\nExplore beautifully crafted anime worlds beyond the school, from ninja villages to futuristic cities. Use your skills and uncover the mystery threatening both realities.\n\n\nCan you master the art of combat, solve the mystery, and save both worlds?\n\n\n============\n\n\n**Trailer Music Credits**: Souichi Sakagami \n\n(https://www.tandess.com/en/music/free-material/data/pride.html)\n", "short_description": "Isekai: Anime School Fight Club Simulator is a VR action-adventure where the boundaries between reality and a fantastical anime world blur. Dive into a school setting turned battleground, where a mysterious force is altering your classmates, and it's up to you to uncover the truth. With fully physically simulated combat, every fight feels intense and lifelike."}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrmonkey.com.br/tos.html", "developer_terms_of_service_url": null, "publisher_name": "VRMonkey", "support_website_url": null, "website_url": "http://vrmonkey.com.br/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8327331694021860"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86610708_1513530802636458_3438562828806279001_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77356yzY0LMQ7kNvgEJfQWx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDBq9-n6036Ksksa0iGxHd9_-ejc91VKe1YWz6GvOy_Xg&oe=6780FB04"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": fals