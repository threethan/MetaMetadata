scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982659_455555057439072_6665585091696755703_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vqjK_mzJWj8Q7kNvgH43nr1&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBuM09FKN9tF_2QGISr-eNlgcu7Q-bpc8UkotLwmqndxg&oe=67811CBE"}, {"file_name": "HighresScreenshot00002.png", "id": "1350474255667761", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75254872_1350474262334427_1451215857295809152_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pAr01aJGyqMQ7kNvgEhzy4g&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBrcBrEs_vC0kx3HTFz5lakvQvk5sez4-JdtUGJyfemgw&oe=67812060"}, {"file_name": "HighresScreenshot00003.png", "id": "8437471896316114", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75318184_8437471899649447_213814366610928578_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17b3EHBrq7kQ7kNvgGOYTwZ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBwT5atHRjWMHQ8beYMH_l3W9zZYS7VduCPWHprM0z3Jw&oe=6780F03F"}, {"file_name": "HighresScreenshot00004.png", "id": "463530573342259", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57572928_463530576675592_730866115576838150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPhn6qu5jG0Q7kNvgHjNvMf&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBO2wrLsMFlC9-J5MN5TRUeYnbJAE6FsebwGKO9bpzRLA&oe=6780F8F2"}, {"file_name": "HighresScreenshot00005.png", "id": "1014398490436839", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974882_1014398493770172_4461870131617680196_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lmXjdaZLPxEQ7kNvgEBYaoF&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBywevfvLp5M3bbgg1Okc2eU-Tfx6mJ4A9f7BlXLdvMYg&oe=67811213"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover1.png", "id": "1063769158796579", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036603_1063769162129912_8410577913387167135_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y70t9jhy9cQQ7kNvgGSmBIU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAuFTUzoc00Eig25okPC7j54iWuKZYQzTjDvNPZjXrHPg&oe=6780F050"}, "display_name": "Anime School - Fight Club Simulator (Early Access)", "keywords": ["anime", "fight", "school", "boxing", "sorcery"], "long_description": "Strange changes are sweeping through your high school as some students start exhibiting unusual powers. You\u2019re thrust into a dangerous mystery that links your world to bizarre, anime-inspired dimensions. As you battle your way through various parody worlds, your ultimate goal is to solve the mystery and stop the growing threat that endangers both realities.\n\n{1552556698687179}\n\n# Key Features:\n- **Physically Simulated Combat**: Engage in fluid, realistic battles where every punch, kick, and move is fully physically simulated. Use the environment, dodge attacks, and throw enemies with a visceral, grounded feel.\n{491015480393946}\n\n\n- **Explore Anime Parody Worlds**: Travel through unique anime-inspired dimensions, each parodying popular shows and genres. Encounter diverse styles, characters, and challenging environments.\n{745705460994153}\n\n- **Learn Special Moves**: Unlock powerful techniques as you advance, enhancing your combat skills and adding strategic depth to your fights.\n{549704514383368}\n\n\n- **Deep Story-Driven Mystery**: Uncover the truth behind strange transformations at your school and solve the mystery linking to a parallel anime world. Your choices will influence the story's outcome.\n{373424095824237}\n\n\n\n# The World of Isekai:\nExplore beautifully crafted anime worlds beyond the school, from ninja villages to futuristic cities. Each dimension offers intense battles and narrative twists. Use your skills and wits to survive and uncover the mystery threatening both realities.\n\n\nCan you master the art of combat, solve the mystery, and save both worlds?\n", "short_description": "Isekai: Anime School Fight Club Simulator is a VR action-adventure where the boundaries between reality and a fantastical anime world blur. Dive into a school setting turned battleground, where a mysterious force is altering your classmates, and it's up to you to uncover the truth. With fully physically simulated combat, every fight feels intense and lifelike."}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrmonkey.com.br/tos.html", "developer_terms_of_service_url": null, "publisher_name": "VRMonkey", "support_website_url": null, "website_url": "http://vrmonkey.com.br/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8020514344703598"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "949817950239873"}]}, "baseline_offer": {"id": "949817950239873"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726681501, "status": "PUBLISHED", "id": "949817950239873"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8020633091358390", "version": "1.0"}, "id": "876655051150966", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8020514338036932", "is_concept": false, "latest_released_binary": {"__typename": "