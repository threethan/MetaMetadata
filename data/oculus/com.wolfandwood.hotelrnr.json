495033706510338", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974693_495033709843671_5264723085240222381_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yro16AG3QZsQ7kNvgFkt-IW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIqBYRuvYaUM0_kKXjnMJMp9N162wRckgymzlYiZf49Q&oe=66F2BE25"}]}, "id": "853981083335618", "locale": "en_US", "screenshots": [{"file_name": "Boxing-Manager.png", "id": "826050019642794", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982687_826050026309460_4877167111948523043_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=40YPTLH6siIQ7kNvgHdJfEf&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEXmrgLYVRNHG6W-W51ZhVam83wv3i2trt7ppPi0QCkQ&oe=66F29FFA"}, {"file_name": "Explosion-Kitchen-Squid.png", "id": "1570533410161863", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982484_1570533416828529_7622160026863989059_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NGIY9En8Kr0Q7kNvgHyiK09&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWDtSQmlZqwi-zYKKa0qp0kOUrMU4p0mSxq_1ZFgkTQw&oe=66F2BD90"}, {"file_name": "Fire-Starter.png", "id": "1001209668687396", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_1001209675354062_9096103961925402093_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=88271nkcgc0Q7kNvgGjwlag&_nc_ht=scontent.oculuscdn.com&oh=00_AYAiylP7qhr1HuAzbyyZKoclGaxRqSvsIvIhLIaCFAYz8Q&oe=66F28B22"}, {"file_name": "Fish-Cop.png", "id": "1201329671213488", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_1201329674546821_4409942110368326809_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qHd1NA_LSYoQ7kNvgFLjQJx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMAvFMo5ga5ivjgTRQDpbHLbtIvElERr0HK2DClM4mXw&oe=66F28AAF"}, {"file_name": "Tac-10-Office.png", "id": "1488399318704747", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_1488399322038080_884019094700045570_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTyVlWEZBJgQ7kNvgEb6fxY&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5cRHFvTbAIZSui3Hae90msNvklNA7k8pUuyABdvkOMw&oe=66F29BC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HotelRnR_CoverLandscape_2560x1440.png", "id": "1079008000317618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974683_1079008003650951_7654025850976196770_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0hQLcpdwNoQ7kNvgFNFgmK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPE-naoi3EPglpNu_eax3rPxsAEMPbxITrURVH88aXEg&oe=66F2A005"}, "display_name": "Hotel R'n'R - Rockstar Simulator", "keywords": ["Rockstar", "Smash", "RnR", "Simulator", "Sandbox"], "long_description": "Live the rockstar lifestyle. Sell your soul for fame, smash up hotels and become Infamous. Pressure from hotel staff and your own limp wrists are against you, but with over 40 weapons, there is a World Tour ahead of you, it\u2019s time to get creative.\n\nEach hotel is a playground of physics-based demolition, with time to explore and plan your strategy before lighting the fireworks and trying to keep the Manager out. With a hellish pawn shop of weirdly satisfying weapons \u2013 including Wet Fish, an electric baton, C4 and Guns \u2013 and a stack of Challenges to appease The Devil, becoming the most Infamous takes brains as well as looks.\n\nHit up the varied 'Challenge mode' or try out ideas at your own pace in 'Sandbox mode'. Hotel R\u2019n\u2019R is a satirical journey of selling your soul and then trying to take it back along the way there\u2019s no shortage of luxury hotels, sarcastic maids and ragdoll physics mayhem. Are you up to it? Just sign here.", "short_description": "Sell your soul and become Infamous for smashing stuff up! Each hotel is a playground of physics-based demolition, take time to explore, plan and setup before going to work at taking it down! With over 40 weapons - including a bowling ball, C4, guns, glue and a fish - the aim is simple, cause mayhem, how you do it is up to you. Just remember to keep the security out!"}]}, "developer_name": null, "developer_privacy_policy_url