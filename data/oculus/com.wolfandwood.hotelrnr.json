.com&oh=00_AYApq02VfdqlWP5GKIOB4sqEaLO_JHKlCBwiC8Xu_p03iQ&oe=672B6E10"}, {"file_name": "Fire-Starter.png", "id": "1001209668687396", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031400_1001209675354062_9096103961925402093_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbNfeF_K2T4Q7kNvgGjhFqT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA9hVwxr6O9Y39oUE59F4PgYPG6HxYNAymdw3ExQGXrqg&oe=672B3BA2"}, {"file_name": "Fish-Cop.png", "id": "1201329671213488", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568680_1201329674546821_4409942110368326809_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KRuRGvv9TTMQ7kNvgFqt-h5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVzocONZDBt7EVUZAhJ3c7igdUUG9KzZ_f9fKALcGseg&oe=672B3B2F"}, {"file_name": "Tac-10-Office.png", "id": "1488399318704747", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974719_1488399322038080_884019094700045570_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8F_mHuj6AlIQ7kNvgEOIIXh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSXQDxnREgyOEUyXNfx8aRzCJxhXWQPpBTZZTnnynCAg&oe=672B4C40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HotelRnR_CoverLandscape_2560x1440.png", "id": "1079008000317618", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974683_1079008003650951_7654025850976196770_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TDkXTEXfxpcQ7kNvgE16UXm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFLMe-ZSXKnuuD0qlTsrA-5D9De3DMzJO6AxTxF7xH7g&oe=672B5085"}, "display_name": "Hotel R'n'R - Rockstar Simulator", "keywords": ["Rockstar", "Smash", "RnR", "Simulator", "Sandbox"], "long_description": "Live the rockstar lifestyle. Sell your soul for fame, smash up hotels and become Infamous. Pressure from hotel staff and your own limp wrists are against you, but with over 40 weapons, there is a World Tour ahead of you, it\u2019s time to get creative.\n\nEach hotel is a playground of physics-based demolition, with time to explore and plan your strategy before lighting the fireworks and trying to keep the Manager out. With a hellish pawn shop of weirdly satisfying weapons \u2013 including Wet Fish, an electric baton, C4 and Guns \u2013 and a stack of Challenges to appease The Devil, becoming the most Infamous takes brains as well as looks.\n\nHit up the varied 'Challenge mode' or try out ideas at your own pace in 'Sandbox mode'. Hotel R\u2019n\u2019R is a satirical journey of selling your soul and then trying to take it back along the way there\u2019s no shortage of luxury hotels, sarcastic maids and ragdoll physics mayhem. Are you up to it? Just sign here.", "short_description": "Sell your soul and become Infamous for smashing stuff up! Each hotel is a playground of physics-based demolition, take time to explore, plan and setup before going to work at taking it down! With over 40 weapons - including a bowling ball, C4, guns, glue and a fish - the aim is simple, cause mayhem, how you do it is up to you. Just remember to keep the security out!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.hotel-rnr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Wolf & Wood Interactive Ltd.", "support_website_url": "http://www.hotel-rnr.com/", "website_url": "http://www.hotel-rnr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "