399322038080_884019094700045570_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JEPIMYBke00Q7kNvgEg5eSk&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBIPPVeM_yNxn45zPZpwC3bhzVK8PNEDc1E2sG8WGZzAA&oe=677671C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HotelRnR_CoverLandscape_2560x1440.png", "id": "1079008000317618", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974683_1079008003650951_7654025850976196770_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NeIFBQDTFbUQ7kNvgE5wzkI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCkVd7ShmFXSBO8cwTrIa99bcEA3PPuWAXl433LflVWuw&oe=67767605"}, "display_name": "Hotel R'n'R - Rockstar Simulator", "keywords": ["Rockstar", "Smash", "RnR", "Simulator", "Sandbox"], "long_description": "Live the rockstar lifestyle. Sell your soul for fame, smash up hotels and become Infamous. Pressure from hotel staff and your own limp wrists are against you, but with over 40 weapons, there is a World Tour ahead of you, it\u2019s time to get creative.\n\nEach hotel is a playground of physics-based demolition, with time to explore and plan your strategy before lighting the fireworks and trying to keep the Manager out. With a hellish pawn shop of weirdly satisfying weapons \u2013 including Wet Fish, an electric baton, C4 and Guns \u2013 and a stack of Challenges to appease The Devil, becoming the most Infamous takes brains as well as looks.\n\nHit up the varied 'Challenge mode' or try out ideas at your own pace in 'Sandbox mode'. Hotel R\u2019n\u2019R is a satirical journey of selling your soul and then trying to take it back along the way there\u2019s no shortage of luxury hotels, sarcastic maids and ragdoll physics mayhem. Are you up to it? Just sign here.", "short_description": "Sell your soul and become Infamous for smashing stuff up! Each hotel is a playground of physics-based demolition, take time to explore, plan and setup before going to work at taking it down! With over 40 weapons - including a bowling ball, C4, guns, glue and a fish - the aim is simple, cause mayhem, how you do it is up to you. Just remember to keep the security out!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.hotel-rnr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Wolf & Wood Interactive Ltd.", "support_website_url": "http://www.hotel-rnr.com/", "website_url": "http://www.hotel-rnr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7937172229709358"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1716041882570660"}, {"status": "PUBLISHED", "id": "383230991486706"}, {"status": "PUBLISHED", "id": "3731875220461434"}, {"status": "PUBLISHED", "id": "1200563621073905"}]}, "baseline_offer": {"id": "383230991486706"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1716041882570660"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8540108719415703", "version": "1.2.1.0"}, "id": "1001222631182360", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6684