5/38974719_1488399322038080_884019094700045570_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6EDd4Qsx9g0Q7kNvgGyx1Cl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDXzpysfC9JxlA-agK4vjotH8rj4liKPkO1NPSoW5E6KA&oe=67727D40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HotelRnR_CoverLandscape_2560x1440.png", "id": "1079008000317618", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974683_1079008003650951_7654025850976196770_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y3IV-GuQ6qcQ7kNvgGjymKY&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAYsYHbPe_D0gosDoWHtqhUgMjjVC9cnGqrxcTTxW0ZAQ&oe=67728185"}, "display_name": "Hotel R'n'R - Rockstar Simulator", "keywords": ["Rockstar", "RnR", "Simulator", "Wizard", "Cat"], "long_description": "\ud83c\udfb8 **Live the rockstar lifestyle** \n\nIn a **sandbox of physics-based demolition**, with time to explore and plan your strategy before lighting the fireworks and doing your best to keep the Hotel Manager out!\n{1979515509218852}\n\n\ud83e\udd4a **40+ Weapons**\n\nPressure from hotel staff and your own limp wrists are against you, but with over 40 weapons and 20+ upgrades, there is a World Tour ahead of you, it\u2019s time to get creative.\n{1101858231351938}\n\n\ud83d\uddfa **6 Luxury hotels to explore**\n\nEach with:\n- Challenges\n- Leaderboards\n- Unique interactions (find the wrecking ball!)\n- Hidden secrets\n\n\n{1137607227798372}\n\n\ud83d\udece  **...AND...**\n- Character Skins\n- Mini-games\n- Sandbox mode\n\n\n\n", "short_description": "Become Infamous for smashing up Hotels! Each hotel is a playground of physics-based demolition, take time to explore, plan and setup before going to work at taking it down! With over 40 weapons - including a bowling ball, C4, guns, glue and a fish - the aim is simple, cause mayhem, how you do it is up to you. Just remember to keep the security out!\n\nThe new \"Magic, Maces and Mange\" free-update adds 5 brand-new weapons, upgrades and 12 new challenges!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.hotel-rnr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Wolf & Wood Interactive Ltd.", "support_website_url": "http://www.hotel-rnr.com/", "website_url": "http://www.hotel-rnr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "3744040075834813"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8616184081808166"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569427_909119921179352_8708485245637680829_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJh0UWGlESkQ7kNvgG8XVQR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAKcyX68eTig0t-AmtEnOw8RhtTEE0ne-GDrszNwWse8w&oe=67729DB4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hotel R'n'R - Rockstar Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Sandbox", "id": "1990104051447093"}], "release_date": 1726160400, "lastRevision": {"nodes": [{"id": "6684805758279351", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata"