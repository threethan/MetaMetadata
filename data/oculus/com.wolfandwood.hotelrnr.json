": "1488399318704747", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_1488399322038080_884019094700045570_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTyVlWEZBJgQ7kNvgEb6fxY&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5cRHFvTbAIZSui3Hae90msNvklNA7k8pUuyABdvkOMw&oe=66F29BC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HotelRnR_CoverLandscape_2560x1440.png", "id": "1079008000317618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974683_1079008003650951_7654025850976196770_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0hQLcpdwNoQ7kNvgFNFgmK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPE-naoi3EPglpNu_eax3rPxsAEMPbxITrURVH88aXEg&oe=66F2A005"}, "display_name": "Hotel R'n'R - Rockstar Simulator", "keywords": ["Rockstar", "Smash", "RnR", "Simulator", "Sandbox"], "long_description": "Live the rockstar lifestyle. Sell your soul for fame, smash up hotels and become Infamous. Pressure from hotel staff and your own limp wrists are against you, but with over 40 weapons and 20+ upgrades, there is a World Tour ahead of you, it\u2019s time to get creative.\n\nEach hotel is a playground of physics-based demolition, with time to explore and plan your strategy before lighting the fireworks and trying to keep the Manager out. With a hellish pawn shop of weirdly satisfying weapons \u2013 including Wet Fish, an electric baton, C4 and Guns \u2013 and a stack of Challenges to appease The Devil, becoming the most Infamous takes brains as well as looks.\n\nHit up the varied 'Challenge mode' or try out ideas at your own pace in 'Sandbox mode'. Hotel R\u2019n\u2019R is a satirical journey of selling your soul and then trying to take it back along the way there\u2019s no shortage of luxury hotels, sarcastic maids and ragdoll physics mayhem. Are you up to it? Just sign here.", "short_description": "Sell your soul and become Infamous for smashing stuff up! Each hotel is a playground of physics-based demolition, take time to explore, plan and setup before going to work at taking it down! With over 40 weapons - including a bowling ball, C4, guns, glue and a fish - the aim is simple, cause mayhem, how you do it is up to you. Just remember to keep the security out!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.hotel-rnr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Wolf & Wood Interactive Ltd.", "support_website_url": "http://www.hotel-rnr.com/", "website_url": "http://www.hotel-rnr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8137397229686856"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974764_8184133281648833_1931058976764472663_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7E94zczGw7wQ7kNvgEkk-EX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQwlHGn4jH5AaDk1QsZmGE91uOb_tLUUFMSY8E5ma8Zg&oe=66F29CD1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hotel R'n'R - Rockstar Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Simulation", "id": "331529188132278"}]