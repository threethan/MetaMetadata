=scontent-iad3-1.oculuscdn.com&oh=00_AYCDiddeBjeCMQVag4cNUf3KfyYQNClgz9bz4Qp3hYckmQ&oe=6707B84A"}, {"file_name": "5.png", "id": "718060913735361", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035406_718060917068694_1271612091639701484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TDNyg0gdNs4Q7kNvgHOsRpD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDS6_zWFb-n-lkI1CwEuMhkPQfq7Sv8b6tHe-hMjLWEzw&oe=6707AA5B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "340969025645211", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569475_340969028978544_321298285756797051_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QLblK97yX3gQ7kNvgHtTRhR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUAzdhy2VJHlLj4AcpLwypWbjWG0QSYsuyZtlA0I6pfQ&oe=6707CFE6"}, "display_name": "Giant Animals", "keywords": [], "long_description": "Explore their natural environments in stunning detail, from the ocean's depths to the vast savannahs and dense forests. Witness these animals' sheer scale and grace up close as you interact with them in their virtual habitats.\nWith immersive visuals and realistic sound effects, our app provides a one-of-a-kind experience that educates and inspires users about the beauty and importance of these incredible creatures. Get ready for a virtual adventure and get close to these giant animals in stunning VR.", "short_description": " Immerse yourself in the awe-inspiring world of the largest animals to ever roam the Earth. From the gentle giants like the majestic elephant and the colossal whale to the agile kangaroo and the towering ostrich, this VR app takes you on a journey through the habitats of these magnificent creatures."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "