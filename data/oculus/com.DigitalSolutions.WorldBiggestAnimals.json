, "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031340_790211635820398_6437391553166419644_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jbVb94YRzTsQ7kNvgHPhsZT&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7pHXSCYXYB6T3rjrFgtlGs&oh=00_AYDN6MT8bGUbXV3MIEWe98oxMmC0Riz2enxWolhJv2PVzA&oe=66E41FCA"}, {"file_name": "5.png", "id": "718060913735361", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035406_718060917068694_1271612091639701484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PN6_iZ2PqhsQ7kNvgGoy0Xt&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7pHXSCYXYB6T3rjrFgtlGs&oh=00_AYCEVQa2o8v4Ww8UQInEVOBybfVymU2l22Xqy-oB1gUT8Q&oe=66E411DB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "340969025645211", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569475_340969028978544_321298285756797051_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sa2ur6SZhy8Q7kNvgF-IHyy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7pHXSCYXYB6T3rjrFgtlGs&oh=00_AYDHBFwszKEmCg8BSMorsoWigi6PZKMtkyT-u3EuDIkZHA&oe=66E43766"}, "display_name": "Giant Animals", "keywords": [], "long_description": "Explore their natural environments in stunning detail, from the ocean's depths to the vast savannahs and dense forests. Witness these animals' sheer scale and grace up close as you interact with them in their virtual habitats.\nWith immersive visuals and realistic sound effects, our app provides a one-of-a-kind experience that educates and inspires users about the beauty and importance of these incredible creatures. Get ready for a virtual adventure and get close to these giant animals in stunning VR.", "short_description": " Immerse yourself in the awe-inspiring world of the largest animals to ever roam the Earth. From the gentle giants like the majestic elephant and the colossal whale to the agile kangaroo and the towering ostrich, this VR app takes you on a journey through the habitats of these magnificent creatures."}]}, "developer_name": null, "developer