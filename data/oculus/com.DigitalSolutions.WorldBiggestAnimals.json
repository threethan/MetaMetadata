.com&oh=00_AYA-fHm4zVMoBYbXO37l2jUyRxFsoo_xKpGWBJAPmp7hgg&oe=673C6490"}, {"file_name": "2.png", "id": "1778717605946299", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036648_1778717609279632_18769772185672315_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tP7fjw4cyK8Q7kNvgHPr5yE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDysUZu3O75bhm4AXqNMcxZnCJlnW3XUaokvyBf7lED6w&oe=673C7EEC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "376633455206850", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982443_376633458540183_8306788755237107195_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=feupf9RXsgIQ7kNvgFyz4x5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZ-UHUoA7d-MbDIxO85qeRXGg-fFa7S32dWTIBhig1Vw&oe=673C7C13"}, "display_name": "The World's biggest animals", "keywords": [], "long_description": "Explore their natural environments in stunning detail, from the depths of the ocean to the vast savannahs and dense forests. Witness the sheer scale and grace of these animals up close as you interact with them in their virtual habitats.\n\nWith immersive visuals and realistic sound effects our app provides a one-of-a-kind experience that educates and inspires users about the beauty and importance of these incredible creatures. Get ready to embark on a virtual adventure like no other and witness the wonders of the world's biggest animals in breathtaking VR.", "short_description": " Immerse yourself in the awe-inspiring world of the largest animals to ever roam the Earth. From the gentle giants like the majestic elephant and the colossal whale to the agile kangaroo and the towering ostrich, this VR app takes you on a journey through the habitats of these magnificent creatures."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "w