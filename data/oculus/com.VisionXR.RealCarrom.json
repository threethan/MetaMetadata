om/v/t64.5771-25/75330714_375029434864504_3438469359134721684_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cbiipZS1ejYQ7kNvgFGWeTt&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAbDFSWbHWTGcLj8AP-T7EttAWkJQ7Hfyurni_1bDo17Q&oe=675EC95C"}, {"file_name": "Shot2.png", "id": "854075359784046", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982722_854075363117379_8890355021061860199_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CPtDQF237VkQ7kNvgGBOMDr&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDd9KE8sJjUhbLWUe6WzLoHNlTSUXKTnZbRzJO6S0vIRg&oe=675ED6C5"}, {"file_name": "Shot3.png", "id": "172564552513109", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031369_172564555846442_535019711188672072_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z5I00buenXgQ7kNvgFLaIIB&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDLq5y5x0nIOSzlPJc_Spxv9T2pFLbM9daWWjZMWcX9og&oe=675EC6ED"}, {"file_name": "Shot4.png", "id": "7320494554645928", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39036694_7320494561312594_2506563998898253588_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yC_4zldlh4YQ7kNvgGEqrPQ&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDu2nCqDaISAWmwPryMyxYY-FniOCdBvE3vgokC6KDRsA&oe=675ECB27"}, {"file_name": "Shot5.png", "id": "338132915371122", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75404380_338132918704455_6259576606063557941_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KVtSzIclMjMQ7kNvgFRAQgs&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBUvhSgFzY0-ArZbcJZ8AWnc0Wa2V-Y2ULip5XUAF2EFA&oe=675EB730"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440.png", "id": "857828942470516", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974800_857828945803849_726516360446674022_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MaS4MYJ2iO4Q7kNvgHEZ19o&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBqdmDIa1smz0zZqVwuwKCu7rC7dd4G7U9rs14kR2tGZA&oe=675EA65C"}, "display_name": "RealCarrom", "keywords": [], "long_description": "\"Welcome to 'Real Carrom', where tradition meets modern gaming. Engage in one of the most beloved board games with a virtual reality enhancement.\n\n\ud83d\udd33 Game Modes:\n\nBlack and White: Stay true to the classic Carrom game, where you're assigned either black or white coins and must pocket them before your opponent.\nFreestyle: Flexibility is key. Pocket any coin and rack up those points against your competition.\n\ud83d\udd33 Single Player:\nTest your skills against our AI opponents. Whether you're playing solo, partnering with an AI, or challenging multiple AIs, there's a level for everyone.\n\n\ud83d\udd33 Multiplayer Magic:\nExperience multiplayer like never before. Play one-on-one, team up with a friend against two AIs, or embrace the challenge of player + AI versus player + AI matches.\n\n\ud83d\udd33 Immersive Features:\n\nVoice Chat: Communicate with your opponents in real-time.\nOculus Avatars: Customize and flaunt your unique avatar.\nLip-Sync: Experience enhanced realism with lip-sync features.\nRediscover the joy of Carrom, whether you're a seasoned player or a newcomer. With intuitive controls, lifelike interactions, and multiple game modes, 'Real Carrom' promises endless fun and challenges. Ready to strike?\"", "short_description": "Experience authentic Carrom with a digital twist! Dive into single or multiplayer modes, challenge AI, or team up with friends, all while enjoying voice chat, Oculus avatars, and lip-sync. Choose from 'Black and White' or 'Freestyle' modes and showcase your Carrom mastery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.visionxr.co.in/realcarromprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VisionXR", "support_website_url": null, "website_url": "https://www.visionxr.co.in/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {