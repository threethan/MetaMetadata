vgEdSLRU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA3e7vGHI4UgMd_Bcgfx-rXNllFWqQ_DjWlLgS1pLcmtQ&oe=6780EEB5"}, {"file_name": "Shot2.png", "id": "575805858245874", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974871_575805861579207_1400221684779084674_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n84sr34AM6MQ7kNvgGQEbFs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC2iCcGA0aHwwtTsxuFIoxlC33BGK3mx-tPSAsdw-4m7A&oe=6780F818"}, {"file_name": "Shot4.png", "id": "4056638544583206", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003276_4056638547916539_5316383743700282922_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CGa0djo2DKAQ7kNvgFP3M2e&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBEgl3opDyUtruuuthqaEtBWl4uTmG55zAMLSPBWXHlWA&oe=67811D32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440.png", "id": "857828942470516", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974800_857828945803849_726516360446674022_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cgNX7nC2PVoQ7kNvgFJwO_D&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBUEXkwMubD9asuyH7UeZuzGv1NNXCP394xZK6seSXhnQ&oe=6780ED5C"}, "display_name": "RealCarrom", "keywords": ["Carrom", "Board", "Multiplayer", "TabeTop", "DiscPool"], "long_description": "\"Welcome to 'Real Carrom', where tradition meets modern gaming. Engage in one of the most beloved board games with a virtual reality enhancement.\n\n\ud83d\udd33 Game Modes:\n\nBlack and White: Stay true to the classic Carrom game, where you're assigned either black or white coins and must pocket them before your opponent.\nFreestyle: Flexibility is key. Pocket any coin and rack up those points against your competition.\n\ud83d\udd33 Single Player:\nTest your skills against our AI opponents. Whether you're playing solo, partnering with an AI, or challenging multiple AIs, there's a level for everyone.\n\n\ud83d\udd33 Multiplayer Magic:\nExperience multiplayer like never before. Play one-on-one, team up with a friend against two AIs, or embrace the challenge of player + AI versus player + AI matches.\n\n\ud83d\udd33 Immersive Features:\n\nVoice Chat: Communicate with your opponents in real-time.\nOculus Avatars: Customize and flaunt your unique avatar.\nLip-Sync: Experience enhanced realism with lip-sync features.\nRediscover the joy of Carrom, whether you're a seasoned player or a newcomer. With intuitive controls, lifelike interactions, and multiple game modes, 'Real Carrom' promises endless fun and challenges. Ready to strike?\"", "short_description": "Experience authentic Carrom with a digital twist! Dive into single or multiplayer modes, challenge AI, or team up with friends, all while enjoying voice chat, Oculus avatars, and lip-sync. Choose from 'Black and White' or 'Freestyle' modes and showcase your Carrom mastery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.visionxr.co.in/realcarromprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VisionXR", "support_website_url": null, "website_url": "https://www.visionxr.co.in/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "275629210202852"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "9006183802746456"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t