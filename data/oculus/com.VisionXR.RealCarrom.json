om/v/t64.5771-25/75330714_375029434864504_3438469359134721684_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EHs34ZJ-TY0Q7kNvgG9ihGp&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBOzg8IBMQYZQOuBi-DumAVHKMFnLcPKOlwX6m4HlQHfg&oe=6781105C"}, {"file_name": "Shot2.png", "id": "854075359784046", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982722_854075363117379_8890355021061860199_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rnol8i619UsQ7kNvgHbmTBX&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCH2wmLKV9Ln1UVI0PVlnYIBYZG4WoeLACClqHlZ9KV9A&oe=67811DC5"}, {"file_name": "Shot3.png", "id": "172564552513109", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031369_172564555846442_535019711188672072_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R4QMwtF3seAQ7kNvgHy7S4q&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDECsRsnOY33e8sIlhsNx6SNWrl4nBxZzq0R-a9vVW3JA&oe=67810DED"}, {"file_name": "Shot4.png", "id": "7320494554645928", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036694_7320494561312594_2506563998898253588_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-N9WVPNCxj0Q7kNvgGZ-N0W&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCoZMNM1EdL4tSv_OH1egTkCkY7PY2ExYiDpHFnYEUnbg&oe=67811227"}, {"file_name": "Shot5.png", "id": "338132915371122", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75404380_338132918704455_6259576606063557941_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bwpc8aEaDDUQ7kNvgGLpJLA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDlVGM81-fC772t892gWNII7QB2sFxib4yc2ZTUdoxTig&oe=6780FE30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440.png", "id": "857828942470516", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974800_857828945803849_726516360446674022_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cgNX7nC2PVoQ7kNvgFJwO_D&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBUEXkwMubD9asuyH7UeZuzGv1NNXCP394xZK6seSXhnQ&oe=6780ED5C"}, "display_name": "RealCarrom", "keywords": [], "long_description": "\"Welcome to 'Real Carrom', where tradition meets modern gaming. Engage in one of the most beloved board games with a virtual reality enhancement.\n\n\ud83d\udd33 Game Modes:\n\nBlack and White: Stay true to the classic Carrom game, where you're assigned either black or white coins and must pocket them before your opponent.\nFreestyle: Flexibility is key. Pocket any coin and rack up those points against your competition.\n\ud83d\udd33 Single Player:\nTest your skills against our AI opponents. Whether you're playing solo, partnering with an AI, or challenging multiple AIs, there's a level for everyone.\n\n\ud83d\udd33 Multiplayer Magic:\nExperience multiplayer like never before. Play one-on-one, team up with a friend against two AIs, or embrace the challenge of player + AI versus player + AI matches.\n\n\ud83d\udd33 Immersive Features:\n\nVoice Chat: Communicate with your opponents in real-time.\nOculus Avatars: Customize and flaunt your unique avatar.\nLip-Sync: Experience enhanced realism with lip-sync features.\nRediscover the joy of Carrom, whether you're a seasoned player or a newcomer. With intuitive controls, lifelike interactions, and multiple game modes, 'Real Carrom' promises endless fun and challenges. Ready to strike?\"", "short_description": "Experience authentic Carrom with a digital twist! Dive into single or multiplayer modes, challenge AI, or team up with friends, all while enjoying voice chat, Oculus avatars, and lip-sync. Choose from 'Black and White' or 'Freestyle' modes and showcase your Carrom mastery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.visionxr.co.in/realcarromprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VisionXR", "support_website_url": null, "website_url": "https://www.visionxr.co.in/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {