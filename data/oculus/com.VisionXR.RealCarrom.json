2_535019711188672072_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wlbedZEOwyQQ7kNvgHUsMmL&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUnBOliO43SHNK7iNYEALn&oh=00_AYB5dETrEoyDCDPxJq4OxirkGy5BS_0NioNO8Z-BM8cE7Q&oe=66EAC2ED"}, {"file_name": "Shot4.png", "id": "7320494554645928", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036694_7320494561312594_2506563998898253588_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u35AF20ykrkQ7kNvgHesgxv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUnBOliO43SHNK7iNYEALn&oh=00_AYD-J1SAITb-H85YHPsU8B_RJ7hhrmERXStvUdghGBa9-A&oe=66EAC727"}, {"file_name": "Shot5.png", "id": "338132915371122", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404380_338132918704455_6259576606063557941_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zB4eIsfkMUQ7kNvgHfwCUs&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUnBOliO43SHNK7iNYEALn&oh=00_AYDUZ0_ZZEf4ZKhZH-5Ieg_17A9S_jaUo47RFP6b4W1nFg&oe=66EAB330"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560_1440.png", "id": "857828942470516", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_857828945803849_726516360446674022_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NGYcWFOreIcQ7kNvgECWOav&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANUnBOliO43SHNK7iNYEALn&oh=00_AYDL0FIth8wURngGtjF8bInmX6yMV-aPmESyjgIXJF6YIg&oe=66EAA25C"}, "display_name": "RealCarrom", "keywords": [], "long_description": "\"Welcome to 'Real Carrom', where tradition meets modern gaming. Engage in one of the most beloved board games with a virtual reality enhancement.\n\n\ud83d\udd33 Game Modes:\n\nBlack and White: Stay true to the classic Carrom game, where you're assigned either black or white coins and must pocket them before your opponent.\nFreestyle: Flexibility is key. Pocket any coin and rack up those points against your competition.\n\ud83d\udd33 Single Player:\nTest your skills against our AI opponents. Whether you're playing solo, partnering with an AI, or challenging multiple AIs, there's a level for everyone.\n\n\ud83d\udd33 Multiplayer Magic:\nExperience multiplayer like never before. Play one-on-one, team up with a friend against two AIs, or embrace the challenge of player + AI versus player + AI matches.\n\n\ud83d\udd33 Immersive Features:\n\nVoice Chat: Communicate with your opponents in real-time.\nOculus Avatars: Customize and flaunt your unique avatar.\nLip-Sync: Experience enhanced realism with lip-sync features.\nRediscover the joy of Carrom, whether you're a seasoned player or a newcomer. With intuitive controls, lifelike interactions, and multiple game modes, 'Real Carrom' promises endless fun and challenges. Ready to strike?\"", "short_description": "Experience authentic Carrom with a digital twist! Dive into single or multiplayer modes, challenge AI, or team up with friends, all while enjoying voice chat, Oculus avatars, and lip-sync. Choose from 'Black and White' or 'Freestyle' modes and showcase your Carrom mastery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.visionxr.co.in/realcarromprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VisionXR", "support_website_url": null, "website_url": "https://www.visionxr.co.in/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8335472679817575"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scon