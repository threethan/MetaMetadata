_3.png", "id": "3051080451772344", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974671_3051080455105677_4603791397004981886_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lLCMs5RfLxAQ7kNvgG0fzJg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7cZq1DupY6Tt1DC0BBWBEXRVg6iSi7n6yHbqFcr03tA&oe=6754425D"}, {"file_name": "SSD_4.png", "id": "409010397620138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974874_409010400953471_6320605527484466823_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ib0j91tcrNIQ7kNvgElFwAs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbLqmzjwE94MwvH2g7pfKJJoEqNbpgkv6Wi0Elrjam-g&oe=67543216"}, {"file_name": "SSD_5.png", "id": "250381913858534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_250381917191867_4031333320144728339_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i0Ee1GkFjQEQ7kNvgEd3fGF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHlHG3dzpL7OyXcjWUCMuM6tx6l8FDFbewsPiuhcYINQ&oe=675430A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SuckerPunchDemo_TrailerCover.png", "id": "1303058460211254", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974497_1303058463544587_31116198519094646_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pRte9ei8IOYQ7kNvgGMA7uF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJVyHyxj0f6SdcBkbo44bHcjwA9EX3yLD6ICeN5FIdTQ&oe=67545024"}, "display_name": "Sucker Punch VR - Demo", "keywords": [], "long_description": "Sucker Punch VR - Demo is a taste of the full game Sunker Punch VR, which is a heart-pounding single and multiplayer experience!\n\nFull game available here: https://www.oculus.com/experiences/quest/4283216598381414/\n\nBattle your opponents in a variety of diverse arenas using an arsenal of power-ups! Punch point cubes as they come at you to send them flying back at your opponent. Unleash power-ups to overwhelm your opposition and defend your goal!\n\nUNLEASH YOUR POWERS - YOUR WAY\nGain access to an arsenal of gloves and equipment, each with their own powers. Mix and match to find your perfect playing style.\n\nSINGLE AND MULTIPLAYER\nPlay a single match versus AI, or grab a friend and go head-to-head via multiplayer. Need a bigger challenge? Play a season and climb the league tables for trophies and ultimate glory!", "short_description": "Like Pong, in VR, on Steroids, with Superpowers! Sucker Punch VR is a fast-paced arcade punch-fest! Go head-to-head wielding a variety of powers, to punch, parry, and strike your way to victory! Score cubes past your opponent while preventing cubes from getting past you. Easy.....right?\n\nSucker Punch VR: Demo gives you free access to experience a taste of the action you can expect in the full Sucker Punch VR game.\nAvailable here: https://www.oculus.com/experiences/quest/4283216598381414/"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.suckerpunchvr.com/eula", "developer_terms_of_service_url": "https://www.suckerpunchvr.com/eula", "publisher_name": "AR Glimpse, LLC", "support_website_url": null, "website_url": "https://www.suckerpunchvr.com/eula", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1216715385525433"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "495350395350398"}]}, "baseline_offer": {"id": "495350395