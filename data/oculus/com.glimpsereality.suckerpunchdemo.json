8534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_250381917191867_4031333320144728339_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWpstxPw7N4Q7kNvgHd4Jkz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDjLxpwgRfns06QAEJHSMyWl4BkC1Mpl_HDzBbMTZQfwA&oe=670A5CA5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SuckerPunchDemo_TrailerCover.png", "id": "1303058460211254", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974497_1303058463544587_31116198519094646_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_pcUlNQ4e_8Q7kNvgGgm-9A&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9oh2eYklZFBdEn76mXCu1YxJFIJdQHPg5QYAuYCzLNA&oe=670A7C24"}, "display_name": "Sucker Punch VR Demo", "keywords": [], "long_description": "Sucker Punch VR - Demo is a taste of the full game Sucker Punch VR, which is a heart-pounding single and multiplayer experience!\n\nFull game available here: https://www.oculus.com/experiences/quest/4283216598381414/\n\nBattle your opponents in a variety of diverse arenas using an arsenal of power-ups! Punch point cubes as they come at you to send them flying back at your opponent. Unleash power-ups to overwhelm your opposition and defend your goal!\n\nUNLEASH YOUR POWERS - YOUR WAY\nGain access to an arsenal of gloves and equipment, each with their own powers. Mix and match to find your perfect playing style.\n\nSINGLE AND MULTIPLAYER\nPlay a single match versus AI, or grab a friend and go head-to-head via multiplayer. Need a bigger challenge? Play a season and climb the league tables for trophies and ultimate glory!", "short_description": "Like Pong, in VR, on Steroids, with Superpowers! Sucker Punch VR is a fast-paced arcade punch-fest! Go head-to-head wielding a variety of powers, to punch, parry, and strike your way to victory! Score cubes past your opponent while preventing cubes from getting past you. Easy.....right?\n\nSucker Punch VR: Demo gives you free access to experience a taste of the action you can expect in the full Sucker Punch VR game.\nAvailable here: https://www.oculus.com/experiences/quest/4283216598381414/"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.suckerpunchvr.com/eula", "developer_terms_of_service_url": "https://www.suckerpunchvr.com/eula", "publisher_name": "AR Glimpse, LLC", "support_website_url": null, "website_url": "https://www.suckerpunchvr.com/eula", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "635797457682321"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974862_610474116840168_6924433269621199470_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UqTu2b-xjpYQ7kNvgHjH4ng&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGp1zvGWgvnwGAOqIA6IMCZtuxLW0RVG4_YQvxDPW3aQ&oe=670A70DB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sucker Punch VR Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1645074000, "lastRevision": {"nodes": [{"id": "2096703060492950", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4355680247888573", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "592334781873997"}, "iarc