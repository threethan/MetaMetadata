in6-3.oculuscdn.com&oh=00_AYDRHkfAb-rLeQnJF6aTRsn4Pp4wl8rhn7S_WX4urK5yCQ&oe=677E7F4A"}, {"file_name": "Untitled design (12).png", "id": "874807593803858", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39036608_874807597137191_4777149021059031506_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KsZ7YP4EIsUQ7kNvgFa9vqI&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAL8II1ZlvPehhW7zBuCsxOcDUR8fnjQUoNuO3ervjrfQ&oe=677E7FA0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (9).png", "id": "957857345197920", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75340707_957857348531253_8268323953929920624_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMFbKt91YocQ7kNvgG0h1ak&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYBhT4jaodCwm2DwBQltA0obcyyR_wiux0FtQ3aPWDk7fg&oe=677E6A13"}, "display_name": "Chimp Kingdom", "keywords": [], "long_description": "Chimp Kingdom is a virtual reality game that puts you in the role of a chimpanzee. The game is designed to be immersive and interactive, allowing you to use your VR headset and controllers to move around in a virtual world!\n\nAs a chimpanzee, you will explore and navigate through the game, using your hands to climb trees, interact with the world around you. Along the way, you will encounter a variety of obstacles & challenges.\n\nWith its rich and detailed world, engaging gameplay, and intuitive controls, Chimp Kingdom offers a truly unique and immersive VR experience that is sure to be a hit with fans of both animal games and virtual reality. So why wait? Put on your VR headset and get ready to explore the exciting and wild world of the Chimp Kingdom!", "short_description": "In this game, you play as a chimpanzee, exploring and navigating a virtual world filled with obstacles and challenges, and you can connect with friends"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1DeW2F0us_czTdavKwHj1-u_F72ZXHwMS