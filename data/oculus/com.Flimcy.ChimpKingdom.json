TgQ7kNvgHSw2l9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYUWjIMTs_0NmwL7I1RQp7DG6Lbe8JuM7N_C2uJ4XSVQ&oe=6731DCD2"}, {"file_name": "Untitled design (7).png", "id": "877825833471264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86661268_877825836804597_5883543275937235476_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pTjKUqEFFZkQ7kNvgGRl47P&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCo1FtvvYFxjKXGu1hD0nTbEksUZ3v2TFypOKcDwYmEBg&oe=673205AB"}, {"file_name": "Untitled design (8).png", "id": "2676714449137209", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974702_2676714455803875_934717980046163925_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=snkyir7ZDrwQ7kNvgGvzUuB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAs_QnYI2uo1heV8vKToWrXgQh6ddSvMUKJfqOvQ9q2jA&oe=6731E812"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (9).png", "id": "957857345197920", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340707_957857348531253_8268323953929920624_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vBy87dn0JHkQ7kNvgHF-Lle&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8fIm4gBktzo25QX8FdjxlY_5twF93vp7OhryuSfouqg&oe=6731F313"}, "display_name": "Chimp Kingdom", "keywords": [], "long_description": "Chimp Kingdom is a virtual reality game that puts you in the role of a chimpanzee. The game is designed to be immersive and interactive, allowing you to use your VR headset and controllers to move around in a virtual world!\n\nAs a chimpanzee, you will explore and navigate through the game, using your hands to climb trees, interact with the world around you. Along the way, you will encounter a variety of obstacles & challenges.\n\nWith its rich and detailed world, engaging gameplay, and intuitive controls, Chimp Kingdom offers a truly unique and immersive VR experience that is sure to be a hit with fans of both animal games and virtual reality. So why wait? Put on your VR headset and get ready to explore the exciting and wild world of the Chimp Kingdom!", "short_description": "In this game, you play as a chimpanzee, exploring and navigating a virtual world filled with obstacles and challenges, and you can connect with friends"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1DeW2F0us_czTdavKwHj1-u_F72ZXHwMSsBisdVzpP_s/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1fjRpMKaAXzt8kTH1CqX1oEWelcLiEjWaD_XUZf_6AoM/edit?usp=sharing", "publisher_name": "Flimcy", "support_website_url": null, "website_url": "https://chimp-kingdom-official.carrd.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1023770785722696"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1559620981205022"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6172207069544202", "version": "1.1.7.2"}, "id": "464135699124633", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5746295508802029", "is_concept": false, "latest_released_binary": {"__type