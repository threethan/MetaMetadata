2.oculuscdn.com&oh=00_AYAMrryVGiss3G6rRkWVMoQd7i1TDF9FEqPl1nYI7-chtA&oe=672A1F4A"}, {"file_name": "Untitled design (12).png", "id": "874807593803858", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39036608_874807597137191_4777149021059031506_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JXMik5qV7NUQ7kNvgFV3iYZ&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAl1h0-n6mDEn2b80v5zp5C-1IG186IlgmOI0ThmaUQkQ&oe=672A1FA0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (9).png", "id": "957857345197920", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75340707_957857348531253_8268323953929920624_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bvmlu-fFxwwQ7kNvgFd9fS2&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAM69YvYV0ub4lamGjFzo_IxQl94h0qQ6rVF34eO_Uf3w&oe=672A0A13"}, "display_name": "Chimp Kingdom", "keywords": [], "long_description": "Chimp Kingdom is a virtual reality game that puts you in the role of a chimpanzee. The game is designed to be immersive and interactive, allowing you to use your VR headset and controllers to move around in a virtual world!\n\nAs a chimpanzee, you will explore and navigate through the game, using your hands to climb trees, interact with the world around you. Along the way, you will encounter a variety of obstacles & challenges.\n\nWith its rich and detailed world, engaging gameplay, and intuitive controls, Chimp Kingdom offers a truly unique and immersive VR experience that is sure to be a hit with fans of both animal games and virtual reality. So why wait? Put on your VR headset and get ready to explore the exciting and wild world of the Chimp Kingdom!", "short_description": "In this game, you play as a chimpanzee, exploring and navigating a virtual world filled with obstacles and challenges, and you can connect with friends"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1DeW2F0us_czTdavKwHj1-u_F72ZXHwMSsBisdVzp