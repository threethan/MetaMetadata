dset and get ready to explore the exciting and wild world of the Chimp Kingdom!", "short_description": "In this game, you play as a chimpanzee, exploring and navigating a virtual world filled with obstacles and challenges, and you can connect with friends"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1DeW2F0us_czTdavKwHj1-u_F72ZXHwMSsBisdVzpP_s/edit?usp=sharing", "developer_terms_of_service_url": "https://docs.google.com/document/d/1fjRpMKaAXzt8kTH1CqX1oEWelcLiEjWaD_XUZf_6AoM/edit?usp=sharing", "publisher_name": "Flimcy", "support_website_url": null, "website_url": "https://chimp-kingdom-official.carrd.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1559620981205022"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6172207069544202", "version": "1.1.7.2"}, "id": "464135699124633", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5746295508802029", "is_concept": false, "latest_released_binary": {"__typename": "And