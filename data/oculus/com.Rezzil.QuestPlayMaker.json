&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWPfS7yhUcraQLFxQBMiS-Cz8_fX30RyshTLmfo8VsHw&oe=672752FB"}, {"file_name": "screenshot5.png", "id": "1535088327286928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984462_1535088330620261_2696574789503898695_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azKFvbZE--QQ7kNvgEiua--&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZG0ZzmdBqryi8m3zJLWKMp5CC4Jd6mPFidnKMNlauCQ&oe=6727499E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "7050636325025275", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031462_7050636331691941_4735315412487883710_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U4ADfN90roEQ7kNvgGynT2b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJbJWFQvLHWET7eqZ23onq72aNLTZr3RcrKBG34Rj-GA&oe=67276097"}, "display_name": "PlayMaker", "keywords": [], "long_description": "PlayMaker is an innovative VR sports app dedicated to soccer, transforming how teams strategize and collaborate. As a multiplayer platform, it allows users to create, visualize, and share tactical plays in a dynamic mixed-reality environment.\n\nKey Features:\n\nInteractive Strategy Creation: Design and manipulate soccer plays in 3D, offering in-depth tactical understanding.\n\nMixed Reality Meetups: Connect with friends or teammates in a virtual setting, ideal for discussing strategies or socializing.\n\nYouTube Integration: Analyze weekend matches in-app, facilitating group discussions and breakdowns of key game moments.\n\nMeta Avatar Customization: Personalize your meta avatar with team jerseys and accessories, enhancing engagement.\n\nReal-Time Collaboration: Work together in real-time, share ideas, and adjust tactics with teammates or coaches, irrespective of physical location.\n\nEnhanced Communication Tools: Utilize integrated voice chat and gesture recognition for natural, effortless team discussions.\n\nPlayMaker is more than just a tactical tool; it's a bridge between virtual and physical sports training, perfect for soccer teams and enthusiasts eager to leverage technology for an edge in their game.", "short_description": "PlayMaker is an innovative VR sports app dedicated to soccer, transforming how teams strategize and collaborate. As a multiplayer platform, it allows users to create, visualize, and share tactical plays in a dynamic mixed-reality environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://rezzil.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Rezzil", "support_website_url": null, "website_url": "http://rezzil.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "26140850858895986"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_3607866372766571_6362993371785017846_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U3giIzUi12UQ7kNvgGCRLqM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMHrUI2h-lJuo07NoIJWVS20G5n4c6s7-VJPYFc9PEwA&oe=67275300"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PlayMaker", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 17084