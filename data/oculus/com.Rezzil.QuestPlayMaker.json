25/39031510_1095471495241126_7904825382140520563_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ctYKwp1aYwQ7kNvgHPVlGq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAkmAz9mk2KOO297P3KWiO-ddoEqwUCscHbSsBilX4mhA&oe=670E50BB"}, {"file_name": "screenshot3.png", "id": "1049137639698936", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982554_1049137646365602_1414254081213079555_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7dQbzlEt61oQ7kNvgF-1bPp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDEarqGFXSrmwKXX6LPv_2kmhknSKyArd9R-3DpGxilg&oe=670E467B"}, {"file_name": "screenshot5.png", "id": "1535088327286928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984462_1535088330620261_2696574789503898695_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R1LuZChTX4YQ7kNvgFeJ_DO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChM3b87IbyOZTAxFHplR3zTV3YOxQao4zB_e7fEe9GUw&oe=670E3D1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "7050636325025275", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031462_7050636331691941_4735315412487883710_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VSUbE9S7fuMQ7kNvgEBS8dB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByHgMqlqj8BU8qF2OgQv5gQCyR31KFZerLMsYM0GrhBA&oe=670E5417"}, "display_name": "PlayMaker", "keywords": [], "long_description": "PlayMaker is an innovative VR sports app dedicated to soccer, transforming how teams strategize and collaborate. As a multiplayer platform, it allows users to create, visualize, and share tactical plays in a dynamic mixed-reality environment.\n\nKey Features:\n\nInteractive Strategy Creation: Design and manipulate soccer plays in 3D, offering in-depth tactical understanding.\n\nMixed Reality Meetups: Connect with friends or teammates in a virtual setting, ideal for discussing strategies or socializing.\n\nYouTube Integration: Analyze weekend matches in-app, facilitating group discussions and breakdowns of key game moments.\n\nMeta Avatar Customization: Personalize your meta avatar with team jerseys and accessories, enhancing engagement.\n\nReal-Time Collaboration: Work together in real-time, share ideas, and adjust tactics with teammates or coaches, irrespective of physical location.\n\nEnhanced Communication Tools: Utilize integrated voice chat and gesture recognition for natural, effortless team discussions.\n\nPlayMaker is more than just a tactical tool; it's a bridge between virtual and physical sports training, perfect for soccer teams and enthusiasts eager to leverage technology for an edge in their game.", "short_description": "PlayMaker is an innovative VR sports app dedicated to soccer, transforming how teams strategize and collaborate. As a multiplayer platform, it allows users to create, visualize, and share tactical plays in a dynamic mixed-reality environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://rezzil.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Rezzil", "support_website_url": null, "website_url": "http://rezzil.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "421923165850360"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1062203387954661"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "762069362638274"}]}, "baseline_offer": {"id": "762069362638274"}, "is_approved": true,