/t64.5771-25/39031490_1163128708251605_4492358988846339906_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cmeLlrLxHswQ7kNvgGIieVS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPtzyR57dMYOHfx6doDhwJdxI2f7UE0jliZI6Z-PcF3g&oe=671CC77F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss5.png", "id": "505736522179444", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462955_505736525512777_6892212070865107814_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Liif-dAq74cQ7kNvgHz1hVO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_oel1CsdGTyd68DgP99uOep1RDisjQ73hmdSCHVzvRQ&oe=671CCB47"}, "display_name": "Dragon Breakout", "keywords": ["HyperCasual", "Comfort", "Dragon", "Escape"], "long_description": "Dragon Breakout is a thrilling maze escape game that puts players in control of a powerful dragon trying to break free from intricate labyrinths. Your mission is to navigate through the winding paths, avoid deadly traps, and uncover secret routes that lead to freedom. As you guide your dragon through each maze, the challenges become more difficult, requiring fast thinking and strategic planning.\n\nThe game offers a variety of labyrinths, each designed with unique obstacles and puzzles that keep the gameplay fresh and exciting. With smooth controls and dynamic visuals, Dragon Breakout immerses players in a world of adventure and danger, where every move counts. Will you be able to guide your dragon out of the maze, or will the labyrinth keep you trapped forever?\n\nDragon Breakout appeals to both casual gamers and those seeking a challenge, offering a mix of action, puzzle-solving, and strategy. As you progress through the game, you'll encounter new mazes with increasing difficulty, keeping you engaged and pushing your skills to the limit. It's a perfect game for anyone looking for a fun, dragon-filled escape adventure!", "short_description": "Dragon Breakout is an exciting maze escape game where you guide your dragon through complex labyrinths to freedom. Avoid traps, find hidden paths, and use quick thinking to lead your dragon to safety. Each maze offers new challenges, requiring skill and strategy to overcome. Can you help your dragon break free and escape the maze?"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/dragon-breakout", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "10023185894365067"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982466_1228632968561595_8431387604103643234_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qalGUvD2vMMQ7kNvgGDJ_iB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpIX7v16ah7uglvXwSg6oD8eLdi_Bwk32LnJZSniGhDQ&oe=671CDE18"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dragon Breakout", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id"