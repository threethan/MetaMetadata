xperiences using 360\u00b0 images and videos."}]}, "developer_name": "eLearning Brothers", "developer_privacy_policy_url": "https://www.trivantis.com/privacy-policy/", "developer_terms_of_service_url": "https://trivantis.com/saas-agreement/", "publisher_name": "eLearning Brothers", "support_website_url": null, "website_url": "https://cenariovr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "654119819073487"}, "review_messages": ["", "Thank you for submitting an update to your application. Your metadata requires some changes before it can go live on the Oculus store. As per VRC.Mobile.Asset.6, the trailer may not contain any non-Oculus VR hardware. Additionally, your trailer may not contain the Oculus Quest unless the application has been approved to launch on the Oculus Quest.\n\nPlease resubmit once you have made changes to your trailer."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974542_752699692232648_2640267871047107314_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ee-8AWFd0IMQ7kNvgEiIlcT&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALMMZ3uC9kmVnQ7b1NwTGzO&oh=00_AYDObYYGV-fuPH4yWxqsTsmA0veXcgC6MNXb7chzQtKmaA&oe=66F14119"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CenarioVR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1543424400, "lastRevision": {"nodes": [{"