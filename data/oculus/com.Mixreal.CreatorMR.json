l es una App que te permite crear espacios inmersivos sin necesidad de tener conocimientos de programaci\u00f3n y en cuesti\u00f3n de minutos."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mixreal.com/politica-de-privacidad", "developer_terms_of_service_url": "https://mixreal.com/aviso-legal", "publisher_name": "Meta Global Creator S.L", "support_website_url": "https://mixreal.com/contacto", "website_url": "https://www.mixreal.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24892022263779957"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982463_1267572287500846_9127939760090505487_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jWBETiEqTiIQ7kNvgGC_-eb&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ag2CPzYAkYlufqIps4ZWF93&oh=00_AYA9v6BTJnrhnmFgwfNrQCg0SrYpYo6iuxN2HkXHhBrbbA&oe=66ED5137"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mixreal (BETA)", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 1708108680, "lastRevision": {"nodes": [{"id": "24791160913866093", "release_type": "SCHEDULED", "administration_statu