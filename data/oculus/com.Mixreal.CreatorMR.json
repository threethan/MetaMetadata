 de contenido en VR y MR.", "short_description": "Mixreal es una App que te permite crear espacios inmersivos sin necesidad de tener conocimientos de programaci\u00f3n y en cuesti\u00f3n de minutos."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mixreal.com/politica-de-privacidad", "developer_terms_of_service_url": "https://mixreal.com/aviso-legal", "publisher_name": "Meta Global Creator S.L", "support_website_url": "https://mixreal.com/contacto", "website_url": "https://www.mixreal.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24892022263779957"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "407190091835051"}]}, "baseline_offer": {"id": "407190091835051"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1708108680, "status": "PUBLISHED", "id": "407190091835051"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24892258507089666", "version": "2.1.0"}, "id": "1095413035218987", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "24791160847199433", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "24892258507089666"}, "release_status"