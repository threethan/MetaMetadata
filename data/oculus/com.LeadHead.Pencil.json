sid=6e7a0a&_nc_ohc=DWiNP97Ikb0Q7kNvgHnh1df&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae85UEHnVaJuZrUhIVGQxip&oh=00_AYBbsF1lf9ICedgY1G_ymG1ULsZYFcDrv52qDD453zsujw&oe=66ED4549"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "991099852280025", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974552_991099855613358_2102416442689796815_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MaVznpBc-_YQ7kNvgEPTCZd&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae85UEHnVaJuZrUhIVGQxip&oh=00_AYBwE55Dnj9ywCX4KV4L-nW7A2pAHfravjtkeuOD69BZOQ&oe=66ED7301"}, "display_name": "Pencil", "keywords": [], "long_description": "# Learn how to draw with Pencil!\nPencil! is a fun new way to learn how to draw! Overlay drawing guides on your physical paper to help you trace and follow along. By combining mixed-reality with a sheet of paper & a pencil, grow your art skills from complete beginner to master artist! \n\n{796057042654180}\nBe sure to join our **Discord** to share your art with the community and give us feedback: https://discord.gg/GpabPFTzDy\n{464353963003063}\n{926346675848213}\nPencil! teaches you how to draw by overlaying step-by-step guides on your piece of paper.\nLearn fundamental concepts such as:\n- Shape & Form\n- Perspective\n- Texture\n- Anatomy\n- & More!\n\n{870538865095490}\nCreate your own still-life composition with Free-draw mode. Drag and drop 3d and 2d models onto a stage that get projected onto your paper.\n", "short_description": "Pencil! - Learn how to draw with real paper and pencil! \n\nUsing mixed-reality, overlay step-by-step guides to trace and learn the fundamentals of drawing. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://pencil-xr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "4th Wall Breakers", "support_website_url": "https://www.pencilxr.com/discord", "website_url": "https://www.pencilxr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags"