-1.oculuscdn.com/v/t64.5771-25/38974874_484299887415919_4293237671533096211_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p82a9d4q4lYQ7kNvgFo7aLZ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAcDBCZS8PvqdXLLQNjqrv8VeK-WFeBn44aLcYrk5oqQA&oe=6710FC4B"}, {"file_name": "Screenshot3.png", "id": "902745538562836", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974907_902745541896169_74786021923903026_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PdXURi8WdsQQ7kNvgHWWt3G&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBKiLXfAr6zR5EUoGTMz1dihoi1WZg1cKwJHjhFlYNT3Q&oe=6710DD2B"}, {"file_name": "Screenshot4.png", "id": "1912725752573319", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974794_1912725755906652_356529078635386275_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PqqDQo7krRsQ7kNvgGaIenw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBDBMDJ8L0fcpTysxodHB3ULZCgAC1hjZsvIJTVh0oy3A&oe=6710F681"}, {"file_name": "Screenshot5.png", "id": "1023797202465128", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031314_1023797205798461_6097934466934139325_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mEOnUKPdwrAQ7kNvgHy7uRK&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCLNpfVbYjSk0mH2PuEwVPQMRWy5mamCXaPRdwtQ_P3Uw&oe=6710EB26"}, {"file_name": "Screenshot2.png", "id": "2174437169601806", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035461_2174437172935139_1902765828656607617_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93_QfXPA5jwQ7kNvgF2o6AQ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA2Y1NnhtcTOd5yyM1RKQ1NpBWkCdfnqsnhTCAnz4uhGw&oe=6710DDC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "991099852280025", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974552_991099855613358_2102416442689796815_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LN4nL6ZY-i4Q7kNvgHw_diH&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB8wvhXplvNA2tvQmDCwJGJru-hP6jI7JgUYgw_ohTy4g&oe=67110B81"}, "display_name": "Pencil", "keywords": ["Draw", "Trace", "Sketch", "Art", "Creative"], "long_description": "# Learn how to draw with Pencil!\nPencil! is a fun new way to learn how to draw! Overlay drawing guides on your physical paper to help you trace and follow along. By combining mixed-reality with a sheet of paper & a pencil, grow your art skills from complete beginner to master artist! \n\n{796057042654180}\nBe sure to join our **Discord** to share your art with the community and give us feedback: https://discord.gg/GpabPFTzDy\n{464353963003063}\n{926346675848213}\nPencil! teaches you how to draw by overlaying step-by-step guides on your piece of paper.\nLearn fundamental concepts such as:\n- Shape & Form\n- Perspective\n- Texture\n- Anatomy\n- & More!\n\n{870538865095490}\nCreate your own still-life composition with Free-draw mode. Drag and drop 3d and 2d models onto a stage that get projected onto your paper.\n", "short_description": "Pencil! - Learn how to draw with real paper and pencil! \n\nUsing mixed-reality, overlay step-by-step guides to trace and learn the fundamentals of drawing. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://pencil-xr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "4th Wall Breakers", "support_website_url": "https://www.pencilxr.com/discord", "website_url": "https://www.pencilxr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}, {"id": "393222478507326"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRA