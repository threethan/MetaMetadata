i": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974907_902745541896169_74786021923903026_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oDq6IQ7sGuMQ7kNvgHL2ptD&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAbG3LzdMO01OperagWPbCIdtJj9-o1V4tbK3HL58r4mQ&oe=6720AF2B"}, {"file_name": "Screenshot4.png", "id": "1912725752573319", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974794_1912725755906652_356529078635386275_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZXGuN8B9twQ7kNvgFHwUSg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAms-VVwSCqG0eo9effF3CsfH1EC2V3JjiAvcC1rItMrA&oe=6720C881"}, {"file_name": "Screenshot5.png", "id": "1023797202465128", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031314_1023797205798461_6097934466934139325_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AaOOuahU4JsQ7kNvgE4AEg7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAK7tUIyfZPBsgF-NLi6skOiw7oJrAutqNiK-8NScUFkA&oe=6720BD26"}, {"file_name": "Screenshot2.png", "id": "2174437169601806", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035461_2174437172935139_1902765828656607617_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RE1ljXg2Zw0Q7kNvgHgVzxu&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBfujmDMe9W3shfHzVlQE8dKhgSxjGqEXcjDx-BQ4adw&oe=6720AFC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "991099852280025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_991099855613358_2102416442689796815_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UDXrr00B8wgQ7kNvgFXwcPu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtCKyFFK7f624PGOmpIAqqxvYfIk6-5BO7A-1JJXXKjQ&oe=6720DD81"}, "display_name": "Pencil", "keywords": [], "long_description": "# Learn how to draw with Pencil!\nPencil! is a fun new way to learn how to draw! Overlay drawing guides on your physical paper to help you trace and follow along. By combining mixed-reality with a sheet of paper & a pencil, grow your art skills from complete beginner to master artist! \n\n{796057042654180}\nBe sure to join our **Discord** to share your art with the community and give us feedback: https://discord.gg/GpabPFTzDy\n{464353963003063}\n{926346675848213}\nPencil! teaches you how to draw by overlaying step-by-step guides on your piece of paper.\nLearn fundamental concepts such as:\n- Shape & Form\n- Perspective\n- Texture\n- Anatomy\n- & More!\n\n{870538865095490}\nCreate your own still-life composition with Free-draw mode. Drag and drop 3d and 2d models onto a stage that get projected onto your paper.\n", "short_description": "Pencil! - Learn how to draw with real paper and pencil! \n\nUsing mixed-reality, overlay step-by-step guides to trace and learn the fundamentals of drawing. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://pencil-xr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "4th Wall Breakers", "support_website_url": "https://www.pencilxr.com/discord", "website_url": "https://www.pencilxr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1043107547362485"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8358998234135234"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1117205959385750"}]}, "baseline_offer": {"id": "1117205959385750"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1