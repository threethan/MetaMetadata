culuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYDowi4SYr2vYt5arSRCJkF35Jv-uJvbu_A_b3IVlwmDxA&oe=66EBF409"}, {"file_name": "wada_oculus_screenshot_3.png", "id": "488392406346969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974447_488392409680302_3155418975303320174_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSRG4yvrQ7sQ7kNvgGPliMl&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYBNW3iLXQrZkLfCuAYG8_ZFcDilNa1IXq-nUAXN75tRLA&oe=66EC1578"}, {"file_name": "wada_oculus_screenshot_2.png", "id": "1039815123611270", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_1039815126944603_9177373266834432759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPqAv6QM050Q7kNvgGXVWlm&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYB8GYuT10bBXjj5smWaD-uXQpQ8zPO_vSFtfjaHtQbmvg&oe=66EC209C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wada_oculus_tumbnail.png", "id": "1219257588605169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_1219257591938502_8118811099117830679_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grv4QvOMbPAQ7kNvgHi72Ug&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYAYYamkxSrzVqQhsCQXOE6ixMEQ8Lta_sC3LHYkwoLRgA&oe=66EC1313"}, "display_name": "Wadality VR Arena", "keywords": [], "long_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That \"flappy\" locomotion system gives a fresh flying experience during the game.\n\nThe game features the movement technique unique for VR that allows players freely move around game level in all directions. Using hands swing locomotion drastically reduces motion sickness symptoms.\n\nGame supports up to 8 players per server with different game mode and configurations. Game is crossplatform and currently works on main VR platforms. Become part of growing wadality e-league community