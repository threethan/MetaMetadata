LBv49aeJ-o1TbGJNx_8DdmYhA&oe=66F54FF8"}, {"file_name": "wada_oculus_screenshot_2.png", "id": "1039815123611270", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_1039815126944603_9177373266834432759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dffePmv7WXkQ7kNvgGnSY6h&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6c7QAMGVKJAvuVHmnw032O&oh=00_AYCp4OJPCtaki776oQa7XwXZUGpfn02Fc_gIxf5gB8Iohg&oe=66F55B1C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wada_oculus_tumbnail.png", "id": "1219257588605169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_1219257591938502_8118811099117830679_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VfK2D7hZYAwQ7kNvgEuZwy0&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6c7QAMGVKJAvuVHmnw032O&oh=00_AYA2oav5RiQiq1DWmrELMWPDuLsGAzzrmv274lsEwB6WlA&oe=66F54D93"}, "display_name": "Wadality", "keywords": [], "long_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That flying locomotion system gives a fresh experience of 100% motion freedom during the game.\n\nThe game features the movement technique unique for VR that allows players freely move around game level in all directions. Using hands swing locomotion drastically reduces motion sickness symptoms.\n\nGame supports up to 12 players per server with different game mode and configurations. Game is crossplatform and currently works on main VR platforms. Become part of growing wadality e-league community <3", "short_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That \"flappy\" locomotion system gives a fresh flying experience during the game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wadality.manerai.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Man