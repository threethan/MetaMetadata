_9177373266834432759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NuHFvP5CB74Q7kNvgEurAUz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBleVXgG8KCIqa_vq789MAAJvFRwLGmNNscquWO4wkJpg&oe=6709219C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wada_oculus_tumbnail.png", "id": "1219257588605169", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982721_1219257591938502_8118811099117830679_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1XosEwnWWo0Q7kNvgEx4Mad&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCu0lFFiKlmo4uWzJCAkts5KxDVtkYJQPUKje8oCuyLIA&oe=67091413"}, "display_name": "Wadality", "keywords": [], "long_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That flying locomotion system gives a fresh experience of 100% motion freedom during the game.\n\nThe game features the movement technique unique for VR that allows players freely move around game level in all directions. Using hands swing locomotion drastically reduces motion sickness symptoms.\n\nGame supports up to 12 players per server with different game mode and configurations. Game is crossplatform and currently works on main VR platforms. Become part of growing wadality e-league community <3", "short_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That \"flappy\" locomotion system gives a fresh flying experience during the game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wadality.manerai.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Manerai", "support_website_url": null, "website_url": "https://wadality.manerai.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "