_ZFcDilNa1IXq-nUAXN75tRLA&oe=66EC1578"}, {"file_name": "wada_oculus_screenshot_2.png", "id": "1039815123611270", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_1039815126944603_9177373266834432759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPqAv6QM050Q7kNvgGXVWlm&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYB8GYuT10bBXjj5smWaD-uXQpQ8zPO_vSFtfjaHtQbmvg&oe=66EC209C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wada_oculus_tumbnail.png", "id": "1219257588605169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_1219257591938502_8118811099117830679_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grv4QvOMbPAQ7kNvgHi72Ug&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYAYYamkxSrzVqQhsCQXOE6ixMEQ8Lta_sC3LHYkwoLRgA&oe=66EC1313"}, "display_name": "Wadality", "keywords": [], "long_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That flying locomotion system gives a fresh experience of 100% motion freedom during the game.\n\nThe game features the movement technique unique for VR that allows players freely move around game level in all directions. Using hands swing locomotion drastically reduces motion sickness symptoms.\n\nGame supports up to 12 players per server with different game mode and configurations. Game is crossplatform and currently works on main VR platforms. Become part of growing wadality e-league community <3", "short_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That \"flappy\" locomotion system gives a fresh flying experience during the game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wadality.manerai.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Manerai", "support_website_url": null, "website_url": "https://wadality.manerai.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "FLYING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "6993874694013390"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984469_722657422272757_9151180453971855544_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6rauRWUVSpIQ7kNvgHrLQ-0&_nc_ht=scontent.oculuscdn.com&_nc_gid=APcg6kE7x4gQtkWKuGoo6Ep&oh=00_AYB8MxFG6_MsPys7xJScNqm0-fqG0WatcNwX_9xqMbCXvA&oe=66EBFAD7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wadality", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Shooting", "id": "1436351953220286"}], "release_date": 1652628600, "lastRevision": {"nodes": [{"id": "102114098992049", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4640272592706957", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "730989747921059