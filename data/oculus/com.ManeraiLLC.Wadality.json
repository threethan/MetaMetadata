iZKFXBLYzQHPj7DagoWSB-q9w&oe=66EEB878"}, {"file_name": "wada_oculus_screenshot_2.png", "id": "1039815123611270", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974610_1039815126944603_9177373266834432759_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPqAv6QM050Q7kNvgHRoKuk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACYH_Ug2CNT0Qbh1KbPH_6I&oh=00_AYCkJ3bCufiYiviEuakP8-0j6SMmh6zMrnMqIHK1MqYTeg&oe=66EEC39C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "wada_oculus_tumbnail.png", "id": "1219257588605169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_1219257591938502_8118811099117830679_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grv4QvOMbPAQ7kNvgFkFkoj&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACYH_Ug2CNT0Qbh1KbPH_6I&oh=00_AYB94NoAFjV1wFmmeFFOA72ShQRExchrMHtI9Uy93lebrA&oe=66EEB613"}, "display_name": "Wadality", "keywords": [], "long_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That flying locomotion system gives a fresh experience of 100% motion freedom during the game.\n\nThe game features the movement technique unique for VR that allows players freely move around game level in all directions. Using hands swing locomotion drastically reduces motion sickness symptoms.\n\nGame supports up to 12 players per server with different game mode and configurations. Game is crossplatform and currently works on main VR platforms. Become part of growing wadality e-league community <3", "short_description": "This is a multiplayer VR Shooter platform with unique vertical gameplay! Take your friends and fight for the title of being called the toughest on the block. That \"flappy\" locomotion system gives a fresh flying experience during the game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wadality.manerai.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Man