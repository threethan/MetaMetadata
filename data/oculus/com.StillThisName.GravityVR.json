vity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-PrivacyPolicy-Sep-2021.pdf", "developer_terms_of_service_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-TandC-26-Sep-2021.pdf", "publisher_name": "StillThisName", "support_website_url": null, "website_url": "https://www.whataboutgravity.com/oculus", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ART_CREATIVITY", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1293529914494481"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "604414987495400"}]}, "baseline_offer": {"id": "604414987495400"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1640280960, "status": "PUBLISHED", "id": "604414987495400"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4747832701981747", "version": "1.0"}, "id": "372150371281986", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "A