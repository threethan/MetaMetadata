&_nc_ohc=flE3IgDmTrAQ7kNvgHTdSwb&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_VQaquuapUNmRSSQdianx-&oh=00_AYBwCJPLiSdlQo37fNkf18akWzlt0jJosIvHh9VnakKIKg&oe=66F54A98"}, {"file_name": "cover2560x1440.png", "id": "243973341055980", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75289719_243973347722646_7552601174685460740_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AFBX092FqIUQ7kNvgHuraNz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_VQaquuapUNmRSSQdianx-&oh=00_AYCcfY0CpJzBUh7wMAHxwQMhv9L-qA441ndimJts7tPNLg&oe=66F55A3E"}, {"file_name": "shot9.png", "id": "231133592364622", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_231133595697955_508502976939701772_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b9sETOsaHSQQ7kNvgHkV3HM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_VQaquuapUNmRSSQdianx-&oh=00_AYC1V4veOPtQmT4gtCAdY7g5fLyvDizmRY9UDot9Ju8uCw&oe=66F55425"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "shot11.png", "id": "2993083937593903", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_2993083940927236_4822662181164399403_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OcYUwPUDwXcQ7kNvgGnbZZT&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_VQaquuapUNmRSSQdianx-&oh=00_AYDOF8gfbhgym2-Z8L9tvbqjB-hD4zkV0TvyBG4l4fFOkw&oe=66F5472B"}, "display_name": "Gravity", "keywords": [], "long_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops.\nOculus version looks like a cube, the same as the Gravity concept. You are standing inside. You can switch between different minimalistic sound-reactive themes surrounding you.\nAnother thing you have control of is an audio-reactive geometric form in the middle. Press triggers on both hand controllers to switch between different types of inner and outer things. Press both triggers quickly to get the metamorphosis effect.", "short_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-PrivacyPolicy-Sep-2021.pdf", "developer_terms_of_service_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-TandC-26-Sep-2021.pdf", "publisher_name": "StillThisName", "support_website_url": null, "website_url": "https://www.whataboutgravity.com/oculus", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ART_CREATIVITY", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1293529914494481"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "604414987495400"}]}, "baseline_offer": {"id": "604414987495400"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1640280960, "status": "PUBLISHED", "id": "604414987495400"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4747832701981747", "version": "1.0"}, "id": "372150371281986", "channel_name": "LIVE"}]}