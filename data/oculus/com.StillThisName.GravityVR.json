dn.com/v/t64.5771-25/75289719_243973347722646_7552601174685460740_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H066FeoOxLIQ7kNvgFJkimU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRPjmly-4if93bQgwooyL-zpjeApgOTJv5sPAto7r9-g&oe=67850DBE"}, {"file_name": "shot9.png", "id": "231133592364622", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974444_231133595697955_508502976939701772_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Otfg9Rz3bTgQ7kNvgEbsXTo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-deKinhO23nJByYF8VDY1c1J2lQbwZwr0xrNo26KDgw&oe=678507A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "shot11.png", "id": "2993083937593903", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572935_2993083940927236_4822662181164399403_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZImQkMX2slkQ7kNvgG2Ocy6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD67Utq7AMNfS7SaTNHscSy_2zlicnb4AOJ4_87pYXZMw&oe=6784FAAB"}, "display_name": "Gravity", "keywords": [], "long_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops.\nOculus version looks like a cube, the same as the Gravity concept. You are standing inside. You can switch between different minimalistic sound-reactive themes surrounding you.\nAnother thing you have control of is an audio-reactive geometric form in the middle. Press triggers on both hand controllers to switch between different types of inner and outer things. Press both triggers quickly to get the metamorphosis effect.", "short_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-PrivacyPolicy-Sep-2021.pdf", "developer_terms_of_service_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-TandC-26-Sep-2021.pdf", "publisher_name": "StillThisName", "support_website_url": null, "website_url": "https://www.whataboutgravity.com/oculus", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ART_CREATIVITY", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1293529914494481"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031482_831217234211391_2025683571966640736_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tiDS1v4_RPkQ7kNvgGRR1Fx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6v7NA9yMIguvxUIHOsDE595C-PoNSdyMgCWFTjIwulw&oe=67851709"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gravity", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Creativity", "id": "1819021644882647"}], "release_date": 1640280998, "lastRevision": {"nodes": [{"id": "115984877484301", "release_type": "SCHED