347722646_7552601174685460740_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QWpM9nzalb4Q7kNvgECJ6HM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4fXFfc32Bh6A-qDaXXP6Hu&oh=00_AYBYO9NqzGgeUNbRaRoCXoYHbKdsRH2VqjKYFR-lSFogYQ&oe=66D707BE"}, {"file_name": "shot9.png", "id": "231133592364622", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_231133595697955_508502976939701772_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xV7GO9elUvoQ7kNvgFnWy34&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4fXFfc32Bh6A-qDaXXP6Hu&oh=00_AYDJiK1QqNOd_s1Wz0Gi7YLrWLKcpeyoO_rILKE1e0qRDQ&oe=66D701A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "shot11.png", "id": "2993083937593903", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_2993083940927236_4822662181164399403_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wLeg6DAJedcQ7kNvgHzr91V&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4fXFfc32Bh6A-qDaXXP6Hu&oh=00_AYAvqRISonUcMjVSnMzt4jB9jLKN8t1aD8GKSYhMHrwYDA&oe=66D6F4AB"}, "display_name": "Gravity", "keywords": [], "long_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops.\nOculus version looks like a cube, the same as the Gravity concept. You are standing inside. You can switch between different minimalistic sound-reactive themes surrounding you.\nAnother thing you have control of is an audio-reactive geometric form in the middle. Press triggers on both hand controllers to switch between different types of inner and outer things. Press both triggers quickly to get the metamorphosis effect.", "short_description": "Gravity is a virtual reality music visualizer. As soon as you start, you will find yourself in the middle of an audio-reactive environment where you can switch visual themes and backgrounds, walk around and jump with the teleport. It is a VR version of the same-named audio-reactive app for Windows and Mac desktops."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-PrivacyPolicy-Sep-2021.pdf", "developer_terms_of_service_url": "https://www.whataboutgravity.com/GRAVITY-Oculus-TandC-26-Sep-2021.pdf", "publisher_name": "StillThisName", "support_website_url": null, "website_url": "https://www.whataboutgravity.com/oculus", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "ART_CREATIVITY", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1293529914494481"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031482_831217234211391_2025683571966640736_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QBtvVUSa8_kQ7kNvgGB7j_P&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4fXFfc32Bh6A-qDaXXP6Hu&oh=00_AYAmF9V0v2o9IWfKIHvkWRztpJFAfNWnTDQvfTWkR71fzw&oe=66D6D8C9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gravity", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1640280998, "lastRevision": {"nodes": [{"id": "115984877484301", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4226971757401180", "is_first_party": false, "enables_in_app