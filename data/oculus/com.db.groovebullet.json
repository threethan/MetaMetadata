mes: Tech City, Japanese Garden, Galaxy Zone, and Holiday Forest! Fifth theme coming soon!", "short_description": "An arcade SHMUP where the music is part of the action.\n\nTravel across the virtual zone and defend the core by guiding a pair of starfighters through the shoot 'em up action of Rhythm 'n Bullets. Enemies fly in from all sides, diving towards the core in time with the soundtrack. Time your shots to the beat for maximum effect, and grab awesome power-ups to clear the stage.\n"}]}, "developer_name": "DB Creations", "developer_privacy_policy_url": "https://www.dbcreations.studio/rhythm-n-bullets/privacy_policy.html", "developer_terms_of_service_url": "https://www.dbcreations.studio/rhythm-n-bullets/terms_and_conditions.html", "publisher_name": "DB Creations", "support_website_url": "https://dbcreations.studio/", "website_url": "http://rhythmnbullets.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_HK", "zh_TW", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1024092198509446"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_3637217329729017_1684752136176544847_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ok9X0DF3cwQ7kNvgHMgixJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auqv5JIPLZq6JBWmiJX3ptg&oh=00_AYB9PVnVDrULtU09SYMHuZIM9Zaw-AZrEA6uoteDlf4lPQ&oe=66F14883"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_nam