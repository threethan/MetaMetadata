RenAQ7kNvgFuv4hw&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAPADGnvoJGAkoybQ0Pb37D-TRnaqZ0tpahUdGSOgh0uQ&oe=670110B0"}, "display_name": "Rhythm 'n Bullets", "keywords": [], "long_description": "An arcade SHMUP where the music is part of the action.\n\nTravel across the virtual zone and defend the core by guiding a pair of starfighters through the shoot 'em up action of Rhythm 'n Bullets. Enemies fly in from all sides, diving towards the core in time with the soundtrack. Time your shots to the beat for maximum effect, and grab awesome power-ups to clear the stage.\n\nKeep the core safe from danger in the multi-level campaign, and then try to top the leaderboards in endless mode, where the enemies never stop! Take a break with our relax mode where you can practice your shooting and experience remixes of the games score!\n\nFeatures four themes: Tech City, Japanese Garden, Galaxy Zone, and Holiday Forest! Fifth theme coming soon!", "short_description": "An arcade SHMUP where the music is part of the action.\n\nTravel across the virtual zone and defend the core by guiding a pair of starfighters through the shoot 'em up action of Rhythm 'n Bullets. Enemies fly in from all sides, diving towards the core in time with the soundtrack. Time your shots to the beat for maximum effect, and grab awesome power-ups to clear the stage.\n"}]}, "developer_name": "DB Creations", "developer_privacy_policy_url": "https://www.dbcreations.studio/rhythm-n-bullets/privacy_policy.html", "developer_terms_of_service_url": "https://www.dbcreations.studio/rhythm-n-bullets/terms_and_conditions.html", "publisher_name": "DB Creations", "support_website_url": "https://dbcreations.studio/", "website_url": "http://rhythmnbullets.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRE