691_364218904427978_9131951884137922560_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2HpOLC4v354Q7kNvgHwvwu2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8uY5Iov_7QcGHzQ2zwxRmO&oh=00_AYACmZ9a3n8SIaNMcCjyrhqog2FqDtzCXw_0iDqcttpVsw&oe=66EE926F"}, {"file_name": "migrated_image.png", "id": "218373562608627", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001722_386935278552194_88665407937839104_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXjBMfl8oisQ7kNvgFqrE6C&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8uY5Iov_7QcGHzQ2zwxRmO&oh=00_AYC3GLtM40lLgOJrX7UkUjGeCq4SddXQDR87QlF2g1GpIg&oe=66EEA04E"}, {"file_name": "migrated_image.png", "id": "158529695311092", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974664_291927611485707_8703178087728152576_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-ivWifyzQMQ7kNvgG9xKrY&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8uY5Iov_7QcGHzQ2zwxRmO&oh=00_AYB5VR364PUlMylyGBJqmV6muDk71l6U3wjfpOkes51epQ&oe=66EEC4B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/n8EZl3", "id": "261451988136010", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974798_261451991469343_7252665102409662464_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GgUZxxClbJAQ7kNvgGB_-GT&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8uY5Iov_7QcGHzQ2zwxRmO&oh=00_AYCm0cktgg5xDSXY2w30CQptC5EImdqw_I6SbDubb97vYQ&oe=66EEC0FE"}, "display_name": "Pirate Monkey Run!", "keywords": ["runner", "infinite", "monkeys", "bananas"], "long_description": "Help Jake and Jade, everyone's favorite Pirate Monkeys, collect Bananas and Coconuts. Race along the path grabbing valuable bananas while avoiding obstacles. Jump over flower pots and skulls. Roll under flower stands and boat stands. Avoid charging pigs and bouncing beach balls. Watch out for crate stacks, rocks, and more.\n\nFind power-ups along the way. Grab a tasty pineapple for invincibility! A Banana Magnet attracts Bananas from any lane. Score multipliers increase your score quickly for a high score.\n\n* Go nuts with Missions to collect extra Coconuts.\n\n* Jake and Jade for the first time in 3D!\n\n* Use Bananas and Coconuts to unlock the Beach and Jungle areas.\n\n* Get a High Score in each area.\n\n* Stand or Sit to play. No walking or turning required.", "short_description": "Help Jake and Jade to collect bananas and coconuts."}]}, "developer_name": "Star Gaming Network", "developer_privacy_policy_url": "http://sgngames.com/privacypolicy.php", "developer_terms_of_service_url": "http://sgngames.com/termsofservice.php", "publisher_name": "Star Gaming Network", "support_website_url": "https://sgngames.com/contactus.php", "website_url": "http://vr.sgngames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1064943334067462"}, "review_messages": ["Hello,\n \nCongratulations! Your submission is ready to publish in the Oculus Store.\n \nYour app will be released on 3/26/2019 @10AM PST for $1.99 under the Games section of the mobile store. Let us know if you would like a different date otherwise we will proceed with launch. Please review all binaries in the STORE channel to make sure the proper supported devices are listed.  Please do not update your online services (such as your back-end servers) during your launch week.\n \nOnce your submission is published, you can access analytics here: (https://developer.oculus.com/apps/).\n \nThanks,\n \nThe Oculus Store Team\n", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.