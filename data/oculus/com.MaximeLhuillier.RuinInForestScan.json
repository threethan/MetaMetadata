=66E6AEF2"}, {"file_name": "Screenshot1.png", "id": "790462812150344", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031458_790462815483677_5380930595172148371_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rzzGupyShQAQ7kNvgGmf54_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiKlG8LHwO4L78W-gIBvcJK&oh=00_AYA9WEukHqi8Q_IAz8AP-X3U8OtkcZ2Qxyq5qAsaFX_Kng&oe=66E6CF51"}, {"file_name": "Screenshot2.png", "id": "850077762573200", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031634_850077769239866_7313417490599216593_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s1Xb6s9zrs8Q7kNvgGq3bej&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiKlG8LHwO4L78W-gIBvcJK&oh=00_AYCC3ZkXCxfpSypl-oOUHsk7x9smJFDkLapKX2DfnBNzOw&oe=66E6C82B"}, {"file_name": "Screenshot3.png", "id": "1514223109014213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_1514223119014212_7927654477935769634_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nsf9idQHAYwQ7kNvgGk1Qk3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiKlG8LHwO4L78W-gIBvcJK&oh=00_AYBkYA8peYiXfs6qT3PN_-CEcUB4v1Ri5y-lNKu9wGWFcg&oe=66E6DAE7"}, {"file_name": "Screenshot4.png", "id": "1118439258797246", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_1118439262130579_1516651612606432838_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nyOnHhkadAcQ7kNvgF3CFbQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiKlG8LHwO4L78W-gIBvcJK&oh=00_AYDvy_Vi-Jb6auHahQlb1MISXSUSrRfeXkDVxOTTIxFgeA&oe=66E6C66A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "3147257625535224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_3147257628868557_5914689202831265680_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JsbMmsfvrxEQ7kNvgFxSWZ1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiKlG8LHwO4L78W-gIBvcJK&oh=00_AYBmWwYt4vqcvC-dZsTIypoz9MXM4to-5DhQVhZSOXY3vw&oe=66E6D721"}, "display_name": "3D scan of a ruin in a forest", "keywords": [], "long_description": "Move like a pedestrian in a ruin surrounded by a forest, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 400m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a ruin surrounded by a forest, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by walking about 400 meters."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_m