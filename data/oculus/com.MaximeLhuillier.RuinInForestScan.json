=1-7&_nc_sid=6e7a0a&_nc_ohc=lQSodR0I5pQQ7kNvgE2tHhv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBzMU3sDdxBiAj579FIpHRYfR4XURulWJl2j0TmxYn0yA&oe=67139B2B"}, {"file_name": "Screenshot3.png", "id": "1514223109014213", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001667_1514223119014212_7927654477935769634_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZv8-H6x2t0Q7kNvgEf01xa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgcT-IbKTSL47r5wOkhASkxkA86wLwvyORlrhQ5sFv0w&oe=6713ADE7"}, {"file_name": "Screenshot4.png", "id": "1118439258797246", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1118439262130579_1516651612606432838_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W1gSrMO6cRsQ7kNvgEAnkRR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBGFv_EzSpTMjdHp6PttaoQb-EJlR6mGSBI_IGIkFoH7g&oe=6713996A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "3147257625535224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_3147257628868557_5914689202831265680_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-9X7SjYtZcsQ7kNvgHf2zRb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDzRtwfuHtvUZJsHp_HmvB_YQep4sHczNRZt0QtqijwBw&oe=6713AA21"}, "display_name": "3D scan of a ruin in a forest", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a pedestrian in a ruin surrounded by a forest, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 400m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a ruin surrounded by a forest, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by walking about 400 meters."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8320772584709919"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_5316589385128348_5266922226042114803_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rkRxId8iyHgQ7kNvgGniMYQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBeKitFDXbs9fCt1ocumo_2keIMiSXMQKZn9FMeWcZtIw&oe=67139