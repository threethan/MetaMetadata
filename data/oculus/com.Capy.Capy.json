dn.com/v/t64.5771-25/57570291_495533996379453_3498398816927922099_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=etyqZTrE29kQ7kNvgGDvKWO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbdY47rio59zdvV3e3gK8gEsesrXGaxVhfoagoXWlIpw&oe=66D6E6CE"}, {"file_name": "ss4.png", "id": "2167793816917307", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75530717_2167793820250640_7955545426742716187_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zPaiHNm-GjoQ7kNvgEwW-Fo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhgRUxMPAvvkRSRvJEYfEuS2J9SjIpwJ2Sy3VoYENo4w&oe=66D70D7F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "capyherolandscape.png", "id": "1104667157499303", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542958_1104667160832636_8737034789958696015_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2dQ9HzJIc8Q7kNvgEbdKFs&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_u9zn1LvKDBfTmsQb_mtRKTEyCyIE316htVN_ueGQ7g&oe=66D6F04E"}, "display_name": "Capy Oasis", "keywords": [], "long_description": "Welcome to the Capy Oasis! Here you'll find yourself shipwrecked in a paradise filled with some of the cutest, curious creatures in the world - Capybaras! You'll learn educational facts about these critters while you interact with them in a rich, immersive environment. \n\nIn the Capy Oasis you can : \n- Pet a Capybara with your own hands! The creatures react to your touch, the objects you play with, and more. \n- Learn about Capybaras! There's plenty to learn about these friendly animals, and Capy Oasis aims to educate as much as entertain.\n- Unlock the mysteries of the Oasis! This mysterious oasis isn't just a Capybara ecosystem, it's a living world with puzzles and intrigue. \n\nCapybara Capybara Capybara Capybara, Ca-py-bara! ", "short_description": "Visit the Capybara Oasis and interact with curious, friendly Capybaras with realistic physics and sounds!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://soaringrocstudio.net/policy", "developer_terms_