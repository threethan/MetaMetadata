5771-25/75334052_1267385283806611_6734565993716385041_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KtQV3ixOxuYQ7kNvgEvxtvw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVAx08lq7YwQ1QmsZkggviv&oh=00_AYAOyyO_glpl9BqZAjok5-1XZJe3h5bMY0-q94QZIIH2vQ&oe=66E96D4F"}, {"file_name": "SS-5.png", "id": "1077630013634443", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_1077630016967776_186279786779265448_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i7QL9FT15JQQ7kNvgGYTroP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVAx08lq7YwQ1QmsZkggviv&oh=00_AYAg4li-eVc5BMDdPuSBrUbxsDtoKvmXGvgPvt2JRh9xsA&oe=66E97529"}, {"file_name": "SS-4.png", "id": "497580265813913", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_497580269147246_6336026914640517244_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tnvkjtpfaVYQ7kNvgFGGvFy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVAx08lq7YwQ1QmsZkggviv&oh=00_AYCfDsYqWvesbrwOwcJaZ9BTeD05XO0aGYQGNoLrGTcACA&oe=66E9683F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Goalie-Cover.png", "id": "581489990460005", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566689_581489993793338_3745997121238122501_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mV6Jwx6l9doQ7kNvgFC4aZl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVAx08lq7YwQ1QmsZkggviv&oh=00_AYAHNu4luLb5cAvJsiUcVZFjNr3ZI9nGWe8AVqHLpcMyBw&oe=66E95EB4"}, "display_name": "Goalie", "keywords": [], "long_description": "Goalie is a virtual reality game that puts you in the shoes of a goalkeeper. The game is suitable for all ages and offers a calming, minimalistic design that is easy on the eyes. It is great for daily exercise and helps improve your goalkeeping skills. With Goalie, you'll be able to practice your reflexes and hand-eye coordination in a fun and immersive environment. The game features intuitive controls and realistic physics, making it easy to jump right in and start playing. Whether you're a seasoned goalkeeper or just looking for a new way to get active, Goalie is a great choice. So why wait? Put on your VR headset and get ready to defend your goal!", "short_description": "Goalie is a VR game that puts you in the goalkeeper role. Suitable for all ages and featuring a calming design, it's great for daily exercise and improving goalkeeping skills. With realistic physics and intuitive controls, it's easy to jump right in and start playing. Whether you're a seasoned pro or just looking for a fun way to get active, Goalie is a great choice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bitti-gitti.com/vr/goalie#privacy", "developer_terms_of_service_url": null, "publisher_name": "Bitti Gitti", "support_website_url": "https://www.bitti-gitti.com/vr/goalie", "website_url": "https://www.bitti-gitti.com/vr/goalie", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "718475149822501"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1236377761064539"}, {"status": "PUBLISHED", "id": "3027472070891305"}, {"status": "PUBLISHED", "id": "187320283925308"}]}, "baseline_offer": {"id": "187320283925308"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1236377761064539"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4801904416601485", "version": "1.24"