5/57570299_497580269147246_6336026914640517244_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jlEXQH3yjTIQ7kNvgFoHcSc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCP4QnM8Mh2bI0NjOK7nkmFEl0Ut13Qz81_uz15-CJexA&oe=675977BF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Goalie-Cover.png", "id": "581489990460005", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566689_581489993793338_3745997121238122501_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JnRH-HsGHIwQ7kNvgH5GEEU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5eKKSYyqbopJ-ejWYDa4Y34w3DIEs5TY2cS6Mczvsfg&oe=67596E34"}, "display_name": "Goalie", "keywords": [], "long_description": "Goalie is a virtual reality game that puts you in the shoes of a goalkeeper. The game is suitable for all ages and offers a calming, minimalistic design that is easy on the eyes. It is great for daily exercise and helps improve your goalkeeping skills. With Goalie, you'll be able to practice your reflexes and hand-eye coordination in a fun and immersive environment. The game features intuitive controls and realistic physics, making it easy to jump right in and start playing. Whether you're a seasoned goalkeeper or just looking for a new way to get active, Goalie is a great choice. So why wait? Put on your VR headset and get ready to defend your goal!", "short_description": "Goalie is a VR game that puts you in the goalkeeper role. Suitable for all ages and featuring a calming design, it's great for daily exercise and improving goalkeeping skills. With realistic physics and intuitive controls, it's easy to jump right in and start playing. Whether you're a seasoned pro or just looking for a fun way to get active, Goalie is a great choice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bitti-gitti.com/vr/goalie#privacy", "developer_terms_of_service_url": null, "publisher_name": "Bitti Gitti", "support_website_url": "https://www.bitti-gitti.com/vr/goalie", "