ttps://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12138792_188572198148304_471043821_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6pTLtZ5u-oYQ7kNvgFCoGqU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDnzwmqYjBx1sjsS3zLsClFHUWfPfZ3LeoucC1OfiNWLA&oe=6756D6B2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FindingVR", "keywords": [], "long_description": "FindingVR is a first person action/adventure game designed exactly for VR. Imagine that you are no longer a person who control the Hero from a top-down view, you are the Hero himself!\nPlayers could solve puzzles using their intelligence and control skills. The joy of game is based on the adventures as the player explore in the virtual world and the sense of achievements when mission completed. We believe that the intense boss battle will make the player excited.\nYour mission is to find out what happened to this world, and how to save this world. Also, you need to defeat those enemies who stand in front of you, find out the right way in the dungeon, and defeat the final boss of each chapter to move on to the next stage.\nYou can use both touchpad and gamepad to play this exciting, deep ,VR game. This might be the most challenging game you can play by using only touchpad in Gear VR ever.", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.time-vr.com/", "developer_terms_of_service_url": "http://www.time-vr.com/", "publisher_name": "TVR", "support_website_url": null, "website_url": "http://www.time-vr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_