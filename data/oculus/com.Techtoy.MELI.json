ZHQ&oe=67728F3D"}, {"file_name": "Meli_Screenshot_BackShot2.png", "id": "1415903032361800", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003230_1415903035695133_4971914996047705199_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gu1VmaPMuF8Q7kNvgHZc0uM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAzp9ZFJiC8XCOjV_OEcMsJXupWPdVFVHhMlVTfwuVYJw&oe=67729289"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "X-Meli-1440.png", "id": "1151210712450324", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982568_1151210715783657_5044172265416352692_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eZ6nMZTBM4oQ7kNvgGhOmsv&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDUt_X4YuM5-Zo_XQOZeFX6-HlGfX80L7SWxtTJGKcWxw&oe=67728D2F"}, "display_name": "Meli", "keywords": ["conducting", "music", "rhythm", "classicalmusic", "mixedreality"], "long_description": "You're the **conductor**, and the spotlight's on you! Dive into the **musical** world of Meli, where every wave of your hand brings the rhythm to life. With awesome **hand-tracking** and **mixed reality** magic, you can wield your wand and watch as your living room transforms into an extravaganza of lights, colors and sound. Get ready to groove to all the classics, from the graceful *Swan Lake* to the buzzing *Flight of the Bumblebee*. The stage is yours, the wand's ready \u2014 **let's play some music!**", "short_description": "You're the conductor, and the spotlight's on you! Dive into the musical world of Meli, where every wave of your hand brings the rhythm to life. With awesome hand-tracking and mixed reality magic, you can wield your wand and watch as your living room transforms into an extravaganza of lights, colors and sound. Get ready to groove to all the classics, from the graceful 'Swan Lake' to the buzzing 'Flight of the Bumblebee.' The stage is yours, the wand's ready \u2014 let's PLAY some music!"}]}, "developer_name": "techToy Studio", "developer_privacy_