nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nhs6yGFZruUQ7kNvgH0RD-i&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1DrMGuYhi9h9XKkNRfwlYC&oh=00_AYDXqJv3t5tSdX4tuqHgeFYvhun1UF3czSdct-e5S7pcxw&oe=66EAA159"}, {"file_name": "migrated_image.png", "id": "603762903542832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982682_394634374507239_6439063808236322816_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzPrcdVpR0MQ7kNvgHPBgt9&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1DrMGuYhi9h9XKkNRfwlYC&oh=00_AYBx_GeHuEGjsGbIVNJTmnQXs_zaik_Wap03XxAuzI9zBg&oe=66EACEF2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/u0V51Y", "id": "2491391347618703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974588_2491391350952036_5915712212038582272_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c3JAkBFUfcsQ7kNvgET112d&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1DrMGuYhi9h9XKkNRfwlYC&oh=00_AYAiMZIpxDL_b7S4_B3POWYXK8oZnB9w2CuEsa5IbU0oJA&oe=66EAA00E"}, "display_name": "Kingspray Graffiti", "keywords": ["graffiti", "art", "spraypaint", "spray", "kingspray"], "long_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!\n\nWorld-class artists have helped us create caps, realistic pressure and fading, metallics, wet/dry effects and real-world colors from Ironlak!\n\nWe have ten unique environments include a dusky city rooftop, an underpass next to the river, and an abandoned subway station! realistic paint surfaces like trucks, bricks, metals and various concretes!\n\nKingspray supports up to 4 players collaborating in Multiplayer! \n\nThis is just a fraction of the awesomeness you will find in Kingspray. Can't WAIT to see what you make!", "short_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!"}]}, "developer_name": "Infectious Ape", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Infectious Ape", "support_website_url": null, "website_url": "http://www.infectiousape.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "232096102467797"}}]}, "scheduled_offers": {"count": 19, "nodes": [{"status": "CANCELLED", "id": "322467250685871"}, {"status": "CANCELLED", "id": "884368036434327"}, {"status": "PUBLISHED", "id": "659134508455298"}, {"status": "PUBLISHED", "id": "419409186390162"}, {"status": "PUBLISHED", "id": "863985261847816"}, {"status": "PUBLISHED", "id": "885716649258536"}, {"status": "PUBLISHED", "id": "606019769992062"}, {"status": "PUBLISHED", "id": "1131342204351612"}, {"status": "PUBLISHED", "id": "1460087284466251"}, {"status": "PUBLISHED", "id": "350926493080205"}, {"status": "PUBLISHED", "id": "1374833763021418"}, {"status": "PUBLISHED", "id": "400716391376628"}, {"status": "PUBLISHED", "id": "453605785559927"}, {"status": "PENDING", "id": "191515760525570"}, {"status": "PENDING", "id": "788281226634445"}, {"status": "PUBLISHED", "id": "704883870471225"}, {"status": "PUBLISHED", "id": "1067399650896838"}, {"status": "PUBLISHED", "id": "750017302089805"}, {"status": "PUBLISHED", "id": "776723980183665"}]}, "baseline_offer": {"id": "750017302089805"}, "is_approved": true, "firstOf