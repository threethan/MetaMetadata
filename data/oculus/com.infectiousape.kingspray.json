-iad3-2.oculuscdn.com&oh=00_AYDU85ALJilYeW329VjbEFy1fJ99xU-hDAlgVCBzKuvH3w&oe=67052CF2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/u0V51Y", "id": "2491391347618703", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974588_2491391350952036_5915712212038582272_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Si83r9abPuAQ7kNvgH59Jxo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-7qGT70dRCxZMChxc6JX31zMoiElsgRCG472-9xeBAg&oe=6705364E"}, "display_name": "Kingspray Graffiti", "keywords": ["graffiti", "art", "spraypaint", "spray", "kingspray"], "long_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!\n\nWorld-class artists have helped us create caps, realistic pressure and fading, metallics, wet/dry effects and real-world colors from Ironlak!\n\nWe have ten unique environments include a dusky city rooftop, an underpass next to the river, and an abandoned subway station! realistic paint surfaces like trucks, bricks, metals and various concretes!\n\nKingspray supports up to 4 players collaborating in Multiplayer! \n\nThis is just a fraction of the awesomeness you will find in Kingspray. Can't WAIT to see what you make!", "short_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!"}]}, "developer_name": "Infectious Ape", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Infectious Ape", "support_website_url": null, "website_url": "http://www.infectiousape.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIM