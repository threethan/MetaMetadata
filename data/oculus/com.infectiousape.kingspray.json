://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982682_394634374507239_6439063808236322816_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5P6GR_d6TCcQ7kNvgGApKbs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBtFUNiIfZlEZyXWzKyHnvX7QsmAj-wA19HzDSzDv6qTQ&oe=675D8172"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/gW9jvZ", "id": "257878025409463", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003260_257878028742796_350594443750932480_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7E3QQ14S4QEQ7kNvgFFykgZ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYACjEtZtZvxaRgG02E-OwFc3TlztQYFlYq6Aq_R-XwUlA&oe=675D7070"}, "display_name": "Kingspray Graffiti", "keywords": ["graffiti", "art", "spraypaint", "spray", "kingspray"], "long_description": "Create amazing street art with VR. Sharpen your skills or learn new styles with thousands of online artists from around the world. Up to 4 simultaneous players collaborating at once. Customize your in game avatar by designing your own hat, mask and spray can. Use True to life Ironlak Aerosol colours to design and develop skills and bring your concepts closer to reality. Feel immersed in 12 realistic environments including a trainyard, Alleyway, dusky city rooftop, and an abandoned subway station! This is just a fraction of the awesomeness you will find in Kingspray. Can't WAIT to see what you make!", "short_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!"}]}, "developer_name": "Infectious Ape", "developer_privacy_policy_url": "http://infectiousape.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Infectious Ape", "support_website_url": null, "website_url": "http://www.infectiousape.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "3626