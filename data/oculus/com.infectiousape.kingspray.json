NvgFpJaxo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdGfv90eGQ_qtwrZsO-g8KqDtaK4lgeG0UDoptkeHxrg&oe=66CD9F0E"}, "display_name": "Kingspray Graffiti", "keywords": ["graffiti", "art", "spraypaint", "spray", "kingspray"], "long_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!\n\nWorld-class artists have helped us create caps, realistic pressure and fading, metallics, wet/dry effects and real-world colors from Ironlak!\n\nWe have ten unique environments include a dusky city rooftop, an underpass next to the river, and an abandoned subway station! realistic paint surfaces like trucks, bricks, metals and various concretes!\n\nKingspray supports up to 4 players collaborating in Multiplayer! \n\nThis is just a fraction of the awesomeness you will find in Kingspray. Can't WAIT to see what you make!", "short_description": "Creating amazing street art would be much more fun without the jail time! Kingspray is a battle-tested VR Graffiti Simulator, with realistic spray, colors, drips, metallics, and more!"}]}, "developer_name": "Infectious Ape", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Infectious Ape", "support_website_url": null, "website_url": "http://www.infectiousape.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interact