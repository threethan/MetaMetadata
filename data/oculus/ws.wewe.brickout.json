xHNcRf7LdvDf2yl-Y6tbLDkb4O5r7OPQ&oe=66E6C779"}, {"file_name": "screenshot_5120x2880_2024-04-28_11-55-34.png", "id": "2066531700400917", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195909_2066531703734250_7885857791064812933_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QDJhSp0AGnIQ7kNvgHeWUUA&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIt1arEGa7E1tOmEg8hqjmdiF-RMis8AlhBdRFT8KgVQ&oe=66E6C602"}, {"file_name": "screenshot_5120x2880_2024-04-28_11-57-03.png", "id": "320674754381486", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035368_320674757714819_9003143656134787564_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_BdLgShd5dcQ7kNvgHGiMma&_nc_ht=scontent.oculuscdn.com&oh=00_AYCei6g897sAKlGuZFaXog7JsaI7eyuEwLapaC_BFH_jvQ&oe=66E6A9FD"}, {"file_name": "screenshot_5120x2880_2024-04-28_11-53-32.png", "id": "456149783575268", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_456149786908601_7844323022018035828_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1AE9UsSWr40Q7kNvgEw2L7U&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8tYTkh5zYK43bdBWk--v4guiv25IoD00a17CJDhydCg&oe=66E6D247"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot_5120x2880_2024-04-27_15-47-38.png", "id": "1585000759006328", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982707_1585000762339661_8361056392347693395_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DvdQhWlp27MQ7kNvgEdAThq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNC7gwrbiP_ShoRhaInjDpp6TPLv2XUSLU8_TI8VTVlg&oe=66E6BAD1"}, "display_name": "Brick Smash VR", "keywords": [], "long_description": "Welcome to \"Brick Smash VR\", the ultimate brick-breaking in VR. Dive into one hundred exhilarating challenges.\n\nGreat for VR beginners.\n\nKey Features:\n\n\u2b50 Immersive VR Experience: With Meta Quest 2, 3, Pro, experience lifelike brick-breaking and precise paddle controls, immersing you in an unparalleled gaming adventure.\n\n\u2b50 Diverse Skills: Encounter various abilities like Fireball, Enlarge Paddle, Speed Up Ball, and Split Ball, each presenting unique strategic challenges to test your skills.\n\n\u2b50 Rich Variety of Bricks: From Iron Bricks to Teleportation Points, encounter a range of brick types with distinct characteristics, adding depth and excitement to gameplay.\n\n\u2b50 Challenging Levels: Navigate meticulously designed levels, from simple to advanced, honing your skills and strategy with each progression.\n\n\u2b50 Beautiful Backgrounds and Music: Enjoy ten stunning Skybox 360-degree backgrounds and ten immersive tracks, enhancing the visual and auditory experience.\n\n\u2b50 Challenge Leaderboard: Compete on the global leaderboard, aiming for faster completion times and climbing to the top ranks for global recognition.\n\n\u2b50 Passthrough Mode Integration: Immerse yourself further with passthrough mode on Meta Quest devices, seamlessly switching between virtual and real-world environments for enhanced spatial awareness.\n\n\u2b50 The game is highly optimized, running smoothly, providing you with the best gaming experience.\n\nEmbark on this brick-breaking journey and conquer each level's challenges in \"Brick Smash VR\"!", "short_description": "Welcome to \"Brick Smash VR\", the ultimate brick-breaking in VR. Dive into one hundred exhilarating challenges.\n\nGreat for VR beginners."}, {"images": {"nodes": []}, "id": "877907337699998", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u7816\u5757\u5927\u4f5c\u6218VR", "keywords": [], "long_description": "\u6b22\u8fce\u6765\u5230\u300a\u7816\u5757\u5927\u4f5c\u6218VR\u300b\u7684\u4e16\u754c\uff0c\u8fd9\u662f\u4e00\u6b3e\u6781\u5177\u6311\u6218\u6027\u548c\u8da3\u5473\u6027\u7684\u6253\u7816\u5757\u6e38\u620f\uff0c\u4e13\u4e3a Meta Quest 2\u30013\u3001Pro \u6253\u9020\u3002\u5728\u8fd9\u8ff7\u4eba\u7684VR\u73af\u5883\u4e2d\uff0c\u4f60\u5c06\u6311\u621810\u4e2a\u5927\u5173\u5361\uff0c\u603b\u5171\u6709100\u4e2a\u5173\u5361\u7b49\u7740\u4f60\u6311\u6218\u3002\n\n\u975e\u5e38\u9002\u5408VR\u5165\u95e8\u8005\u3002\n\n\u6e38\u620f\u7279\u8272\uff1a\n\n\u2b50 \u8eab\u4e34\u5176\u5883\u7684VR\u4f53\u9a8c\uff1a \u900f\u8fc7 Meta Quest 2\u30013\u3001Pro\uff0c\u4f60\u5c06\u7f6e\u8eab\u4e8e\u5168\u65b0\u7684\u865a\u62df\u4e16\u754c\u4e2d\uff0c\u611f\u53d7\u903c\u771f\u7684\u7816\u5757\u6253\u51fb\u548c\u624b\u628a\u64cd\u4f5c\uff0c\u5e26\u6765\u524d\u6240\u672a\u6709\u7684\u6e38\u620f\u4f53\u9a8c\u3002\n\n\u2b50 \u591a\u6837\u5316\u7684\u6280\u80fd\u9009\u62e9\uff1a \u5728\u6e38\u620f\u4e2d\uff0c\u4f60\u5c06\u9047\u5230\u591a\u79cd\u6280\u80fd\u53ef\u4f9b\u9009\u62e9\uff0c\u5982\u706b\u7130\u7403\u3001\u6269\u5927\u7403\u62cd\u3001\u52a0\u901f\u7403\u3001\u5206\u88c2\u7403\u7b49\uff0c\u6bcf\u79cd\u6280\u80fd\u90fd\u5e26\u6765\u4e0d\u540c\u7684\u6218\u7565\u6311\u6218\uff0c\u8ba9\u4f60\u65bd\u5c55\u81ea\u5df1\u7684\u7b56\u7565\u548c\u6280\u5de7\u3002\n\n\u2b50 \u4e30\u5bcc\u591a\u5f69\u7684\u7816\u5757\u7c7b\u578b\uff1a \u9664\u4e86\u666e\u901a\u7684\u7816\u5757\u5916\uff0c\u6e38\u620f\u4e2d\u8fd8\u6709\u5404\u79cd\u7279\u6b8a\u7c7b\u578b\u7684\u7816\u5757\uff0c\u5982\u94c1\u5757\u3001\u52a0\u901f\u7816\u3001\u4f20\u9001\u70b9\u3001\u70df\u96fe\u5f39\u7b49\uff0c\u6bcf\u4e00\u79cd\u7816\u5757\u90fd\u62e5\u6709\u72ec\u7279\u7684\u7279\u6027\u548c\u6311\u6218\uff0c\u8ba9\u6e38\u620f\u66f4\u52a0\u591a\u53d8\u6709\u8da3\u3002\n\n\u2b50 \u6311\u6218\u6027\u5173\u5361\u8bbe\u8ba1\uff1a \u6bcf\u4e2a\u5173\u5361\u90fd\u8bbe\u8ba1\u4e86\u4e0d\u540c\u7684\u5e03\u5c40\u548c\u6311\u6218\uff0c\u4ece\u7b80\u5355\u7684\u5f00\u59cb\u5230\u6781\u5177\u6311\u6218\u6027\u7684\u9ad8\u7ea7\u5173\u5361\uff0c\u8ba9\u4f60\u5728\u4e0d\u540c\u7684\u6e38\u620f\u573a\u666f\u4e2d\u6311\u6218\u81ea\u6211\uff0c\u63d0\u9ad8\u6280\u5de7\u3002\n\n\u2b50 \u7cbe\u7f8e\u7684\u80cc\u666f\u4e0e\u97f3\u4e50\uff1a \u6e38\u620f\u4e2d\u7cbe\u5fc3\u6311\u9009\u4e86\u5341\u4e2a\u6f02\u4eae\u7684360\u5ea6\u80cc\u666f\u548c\u5341\u9996\u6781