_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7704631686261190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9124571574267187"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3303216509972681"}]}, "change_log": "Bugfixes, UX enhancements, and performance improvements to the new trading card game mode life counters and discard pile interactions.\n\nNew navigation arrow and recentering indicators to help you find the game table if you lose track of it or the initial saved position is far from your current location.", "created_date": 1734040488, "id": "9054823917908620", "version": "0.9.1", "version_code": 18, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7704631686261190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9124571574267187"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3303216509972681"}]}, "change_log": "This release is focused on improving the experience of playing Trading Card Games in Table Space. We've added:\n\n- Added new sphere counters with +1, -1, +10, -10 options.\n\n- Added a discard pile.", "created_date": 1733786483, "id": "9038937876163891", "version": "0.9", "version_code": 17, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7704631686261190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9124571574267187"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3303216509972681"}]}, "change_log": "This update to Table Space brings usability and multiplayer quality of life improvements!\n\n\nWe added a new table locking interaction to avoid accidentally moving the table while you're playing.\n\nWe now support destinations and invites on Quest, so you can easily launch into multiplayer rooms with your friends!", "created_date": 1731704471, "id": "8908077292583284", "version": "0.8", "version_code": 16, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}