404179_7640095952276930352_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=feb-__IHRegQ7kNvgHMB-9G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDl_RhC0isaO8UH83vGvyn6pQQVYze-DsaqC7FHYgaD4A&oe=67598471"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "table_space_quest_landscape_placeholder.png", "id": "2029875434122575", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375751_2029875440789241_3772080188190154170_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UpKBdWUx7UgQ7kNvgHmXe9O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4KOXHVwZ-ElgRByhokXLu5p8NxZHrHkM6iMp4QabXoA&oe=67599547"}, "display_name": "Table Space", "keywords": ["Tarot", "Poker", "Card", "Board", "Tabletop"], "long_description": "# Table Space: The Ultimate Mixed-Reality Tabletop Games Sandbox\n\nWelcome to Table Space, a new sandbox where your favorite tabletop games come to life! Play classic games like Texas Hold'em Poker, Hanafuda, Tarot, Trading Card Games, or any card game imaginable with friends in a fully immersive environment.\n\nCustomize your gaming space with various themes and settings to create the perfect atmosphere. Connect with friends through integrated voice chat, join public lobbies, and personalize your experience. With a growing library of game modes and regular updates, there's always something new to discover.\n\n### Features:\n- **Versatile Gameplay:** Enjoy a wide range of games including Texas Hold'em Poker, Tarot, Trading Card Games, Hanafuda, and more to come.\n- **Customizable Environments:** Tailor your gaming space with various themes and settings.\n- **Social Integration:** Connect with friends, join public lobbies, and enjoy seamless voice chat.\n- **Constant Updates:** Benefit from regular updates and new game modes.\n- **Mixed-Reality Innovation:** Interact with the game using your hands just like in a real-life card game, enhanced by our custom-designed interactions for an even better experience.\n\nJoin the Table Space community and redefine your tabletop gaming experience. Every game is a new adventure in this vibrant and ever-evolving platform. Discover the future of tabletop gaming with Table Space!", "short_description": "Welcome to Table Space, a new sandbox where your favorite tabletop games come to life! Play classic games like Texas Hold'em Poker, Hanafuda, Tarot, Trading Card Games, or any card game imaginable with friends in a fully immersive environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.boxtree.gg/privacy", "developer_terms_of_service_url": null, "publisher_name": "Boxtree Inc", "support_website_url": null, "website_url": "https://www.boxtree.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "1700921480735423"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8844433915614289"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974471_481856121229919_6525324133491801388_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e_AuEAdMQdUQ7kNvgFmHF58&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRUzfkp3LWyoJpL6xPHgEgkzf8ww9ovVB5YmgFJ9vlLw&oe=67598010"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Table Space", "platform": "ANDROID_6DOF", "context_category": {"context_categor