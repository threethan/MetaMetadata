** Tailor your gaming space with various themes and settings.\n- **Social Integration:** Connect with friends, join public lobbies, and enjoy seamless voice chat.\n- **Constant Updates:** Benefit from regular updates and new game modes.\n- **Mixed-Reality Innovation:** Interact with the game using your hands just like in a real-life card game, enhanced by our custom-designed interactions for an even better experience.\n\nJoin the Table Space community and redefine your tabletop gaming experience. Every game is a new adventure in this vibrant and ever-evolving platform. Discover the future of tabletop gaming with Table Space!\n", "short_description": "Mixed-reality tabletop games sandbox: play poker, hanafuda, or anything you can imagine with a standard deck of cards with friends. More game modes are being added constantly!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.boxtree.gg/privacy", "developer_terms_of_service_url": null, "publisher_name": "Boxtree Inc", "support_website_url": null, "website_url": "https://www.boxtree.gg/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "275629210202852"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7704631699594522"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "535690312452451"}]}, "baseline_offer": {"id": "535690312452451"}, "is_approved": true, "firstOffer": 