515639570957681", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262746_515639577624347_1373455528808098209_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NDw6NlAq9JoQ7kNvgGZTR1F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9ik9vzC13ccqHaSAVRpe0qeb9yzFMadhonwY2Xzop7w&oe=67598E72"}, {"file_name": "Frame 3.png", "id": "405246912080596", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240103_405246915413929_4553693275267120884_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UpL6jvtZzOYQ7kNvgEziToz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA-OEXkCHHUy1faUjYIlNnfRVlMKmSfwjFyl2c2p_Ux7w&oe=67596048"}, {"file_name": "Frame 1.png", "id": "916501470333222", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035353_916501473666555_8271221439670753435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MfjsDdfHOBIQ7kNvgGF52o2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVXD0JJUT5v8WYsPZ03BdpH5dNLtoHmkGQ4Q9LAIbFNw&oe=6759747F"}, {"file_name": "Frame 4.png", "id": "1691163371737513", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572751_1691163378404179_7640095952276930352_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=feb-__IHRegQ7kNvgHMB-9G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDl_RhC0isaO8UH83vGvyn6pQQVYze-DsaqC7FHYgaD4A&oe=67598471"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Table Space", "keywords": [], "long_description": "# Table Space: The Ultimate Mixed-Reality Tabletop Games Sandbox\n\nWelcome to Table Space, a new sandbox where your favorite tabletop games come to life! Play classic games like poker, hanafuda, or any card game imaginable with friends in a fully immersive environment.\n\nCustomize your gaming space with various themes and settings to create the perfect atmosphere. Connect with friends through integrated voice chat, join public lobbies, and personalize your experience. With a growing library of game modes and regular updates, there's always something new to discover.\n\n### Features:\n- **Versatile Gameplay:** Enjoy a wide range of games including poker, hanafuda, and more to come.\n- **Customizable Environments:** Tailor your gaming space with various themes and settings.\n- **Social Integration:** Connect with friends, join public lobbies, and enjoy seamless voice chat.\n- **Constant Updates:** Benefit from regular updates and new game modes.\n- **Mixed-Reality Innovation:** Interact with the game using your hands just like in a real-life card game, enhanced by our custom-designed interactions for an even better experience.\n\nJoin the Table Space community and redefine your tabletop gaming experience. Every game is a new adventure in this vibrant and ever-evolving platform. Discover the future of tabletop gaming with Table Space!\n", "short_description": "Mixed-reality tabletop games sandbox: play poker, hanafuda, or anything you can imagine with a standard deck of cards with friends. More game modes are being added constantly!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.boxtree.gg/privacy", "developer_terms_of_service_url": null, "publisher_name": "Boxtree Inc", "support_website_url": null, "website_url": "https://www.boxtree.gg/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "275629210202852"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "