t-iad3-1.oculuscdn.com&oh=00_AYCFBUxCL5OTE05qIlZuLsdY4J72a6MuPYoG_bGAhdISgg&oe=6773EC72"}, {"file_name": "Frame 3.png", "id": "405246912080596", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240103_405246915413929_4553693275267120884_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ntNm9eemOg0Q7kNvgHFu4LU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQEM-1O4GKYpxixBMCVZXBhKU3mhvBYbfSgg63CEs1cA&oe=6773BE48"}, {"file_name": "Frame 1.png", "id": "916501470333222", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035353_916501473666555_8271221439670753435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YML7OmOEw2kQ7kNvgGaqAGW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAw3PAyASLhlLq2VKC2quiW4E43jWsUeiE5qLRLf4UKUQ&oe=6773D27F"}, {"file_name": "Frame 4.png", "id": "1691163371737513", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572751_1691163378404179_7640095952276930352_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qayteSxAIroQ7kNvgFceJ5e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnIq892w3URp0Ckvx3e3wTZ41sal7tbniMsSfivij1Gg&oe=6773E271"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Table Space", "keywords": [], "long_description": "# Table Space: The Ultimate Mixed-Reality Tabletop Games Sandbox\n\nWelcome to Table Space, a new sandbox where your favorite tabletop games come to life! Play classic games like poker, hanafuda, or any card game imaginable with friends in a fully immersive environment.\n\nCustomize your gaming space with various themes and settings to create the perfect atmosphere. Connect with friends through integrated voice chat, join public lobbies, and personalize your experience. With a growing library of game modes and regular updates, there's always something new to discover.\n\n### Features:\n- **Versatile Gameplay:** Enjoy a wide range of games including poker, hanafuda, and more to come.\n- **Customizable Environments:** Tailor your gaming space with various themes and settings.\n- **Social Integration:** Connect with friends, join public lobbies, and enjoy seamless voice chat.\n- **Constant Updates:** Benefit from regular updates and new game modes.\n- **Mixed-Reality Innovation:** Interact with the game using your hands just like in a real-life card game, enhanced by our custom-designed interactions for an even better experience.\n\nJoin the Table Space community and redefine your tabletop gaming experience. Every game is a new adventure in this vibrant and ever-evolving platform. Discover the future of tabletop gaming with Table Space!\n", "short_description": "Mixed-reality tabletop games sandbox: play poker, hanafuda, or anything you can imagine with a standard deck of cards with friends. More game modes are being added constantly!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.boxtree.gg/privacy", "developer_terms_of_service_url": null, "publisher_name": "Boxtree Inc", "support_website_url": null, "website_url": "https://www.boxtree.gg/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "275629210202852"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7704631699594522"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "535690312452451"}]}, "baseline_offer": {"id": "535690312452451"}, "is_approved": true, "firstOffer": {"nodes": [{"start_tim