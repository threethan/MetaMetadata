": "HeroCoverLaunchVariant.png", "id": "529452990026644", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572757_529452993359977_907074505075533526_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AVlpuOyrd8sQ7kNvgEkKUyg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDR0vlHOYTllyQeikLUIkbBZqd8Rcjm56rnWHej8kTBlw&oe=6731FC00"}, {"file_name": "PBGIcon.png", "id": "517610221188856", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_517610224522189_7500405442120626656_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LppxUyUvFLoQ7kNvgHCwLO-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADHLMu2VXWpA_0pMn8sa-l2ZNwtIIS8v1KN7nFn4tEqA&oe=6731D3C9"}]}, "id": "1650724715476260", "locale": "en_US", "screenshots": [{"file_name": "HighresScreenshot00008_resized.png", "id": "558321513415683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035397_558321516749016_6753816091515147136_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h9cTvsG5IccQ7kNvgFxiBVj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwvKCk9xltzi3m4bsM4vwAvDJ2_c_gb_vZ2e-IU60taw&oe=673205ED"}, {"file_name": "pb_screenshot2.png", "id": "1008650424289125", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031524_1008650427622458_24755236093743180_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qyi1UPH8Z4EQ7kNvgE6Q1sW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzjBE49TyMW1qxPpQWwVHRt8XiqSiyJzPzfwf9AMGwwg&oe=6731FF84"}, {"file_name": "HighresScreenshot00005_resized.png", "id": "537871895500926", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982447_537871898834259_3643365479463745391_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rzwVH7X4g8YQ7kNvgEEoy3n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCj_Cs4_WJMf4Z2ouVbEs_2KjMs9WrdL59dFZoAfYmzSg&oe=673203EB"}, {"file_name": "HighresScreenshot00001_resized.png", "id": "1046740546923523", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974751_1046740550256856_1961426217202714013_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6Co80r5gScQ7kNvgEGVPXv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIbiy5188ddGSeSpTsUkhO71cmo5z2sGIopDcMNE-G0g&oe=6731E3D5"}, {"file_name": "HighresScreenshot00000_resized.png", "id": "1026808455889120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031340_1026808459222453_3107553487636415056_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jLn3wM-gwPsQ7kNvgFlqlBR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwAA_a_HfcP-oFULtmqz268hgwTBCIAkfDXLASRFih_g&oe=6731E1FA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PBGLandscape1.png", "id": "916414023856274", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75245817_916414027189607_1799958869549848484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpsDpUuunU4Q7kNvgGGzs9p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDovAJuLDXLl-XOf7K9kjT93h5tAXeoDGYt9cjzWGJpqg&oe=6731F62A"}, "display_name": "Plastic Battlegrounds", "keywords": ["plastic", "battlegrounds", "sandbox", "toys", "armymen"], "long_description": "Welcome to Plastic Battlegrounds, the newly commissioned sandbox toy-based battle simulator that includes objective based modes, where your plastic soldiers engage in intense set piece battles. Set up the battlefield with an ever growing list of units, vehicles, emplacements, and environment hazards then either join the battle as a plastic soldier or be life sized and tower over the chaos. Drive fast moving toy jeeps or pilot drones armed with explosives and machine guns. Blow up toy brick fortifications and tear apart your virtual living space in ways you absolutely cannot do in real life!\n\nIn sandbox mode, setup battles by placing units, setting up spawners, and make  combat scenarios unique to each play session. It's what you could previously only imagine toy soldiers doing, but now they are truly brought into action!\n\nTry the experimental Conquest mode where you are tasked with holding the majority of capture points to achieve victory over the enemy team.\n\nThis game is very early in development, there is much to be done and the toy war has only begun. Join our Discord community linked in our website to keep up with development news - see you on the battlefield, soldier! ", "short_description": "Create and participate in the battles of your childhood dreams, watch as the plastic soldiers and toys you place come to life in both creative sandbox and strategic objective based modes. Be life sized, watch the battle from above, and crush the toys with your fists or be a plastic soldier wielding a variety of ballistic or explosive based weapons with powerful vehicles at your disposal and gain the tactical advantage over the enemy toys."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.simulated-minds.com/legal/privacy-policy-games", "developer_terms_of_service_url": null, "publisher_name": "Simulated Minds", "support_website_url": null, "website_url": "https://www.simulated-minds.com/plastic-battlegrounds", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8534717713282704"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75439594_4620050848220021_434229737