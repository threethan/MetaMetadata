 {"file_name": "HighresScreenshot00000_resized.png", "id": "1026808455889120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031340_1026808459222453_3107553487636415056_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jOoCe_0QuxQQ7kNvgE6uOyg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzoW_3e_tH94i1djwMigYKsreeYpIhnWPiLhyTK3f0nw&oe=671E1B7A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PBGLandscape1.png", "id": "916414023856274", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75245817_916414027189607_1799958869549848484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ptMaoTg8OoAQ7kNvgHxSAmj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKowSNQX1g4eElJoyGmtaSWMtwv47qU7-LcMkZWkcwBA&oe=671E2FAA"}, "display_name": "Plastic Battlegrounds", "keywords": ["plastic", "battlegrounds", "sandbox", "toys", "armymen"], "long_description": "Welcome to Plastic Battlegrounds, the newly commissioned sandbox toy-based battle simulator that includes objective based modes, where your plastic soldiers engage in intense set piece battles. Set up the battlefield with an ever growing list of units, vehicles, emplacements, and environment hazards then either join the battle as a plastic soldier or be life sized and tower over the chaos. Drive fast moving toy jeeps or pilot drones armed with explosives and machine guns. Blow up toy brick fortifications and tear apart your virtual living space in ways you absolutely cannot do in real life!\n\nIn sandbox mode, setup battles by placing units, setting up spawners, and make  combat scenarios unique to each play session. It's what you could previously only imagine toy soldiers doing, but now they are truly brought into action!\n\nTry the experimental Conquest mode where you are tasked with holding the majority of capture points to achieve victory over the enemy team.\n\nThis game is very early in development, there is much to be done and the toy war has only begun - see you on the battlefield, solder!", "short_description": "Create and participate in the battles of your childhood dreams, watch as the plastic soldiers and toys you place come to life in both creative sandbox and strategic objective based modes. Be life sized, watch the battle from above, and crush the toys with your fists or be a plastic soldier wielding a variety of ballistic or explosive based weapons with powerful vehicles at your disposal and gain the tactical advantage over the enemy toys."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.simulated-minds.com/legal/privacy-policy-games", "developer_terms_of_service_url": null, "publisher_name": "Simulated Minds", "support_website_url": null, "website_url": "https://www.simulated-minds.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8456036347817508"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001705_1681310402690269_7442836310790813415_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-C2PnPF_A3UQ7kNvgE7dg9T&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTGId_tWfI_0ItpcwVi4UjupJGrEELE26Lk3GX0Jml6g&oe=671E1155"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Plastic Battlegro