://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974751_1046740550256856_1961426217202714013_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6Co80r5gScQ7kNvgFgpsZJ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA5HSN8_JNCFBSEONN4oQ_EH_3X4JrH4w3VTiSKWeWwSA&oe=67309255"}, {"file_name": "HighresScreenshot00000_resized.png", "id": "1026808455889120", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031340_1026808459222453_3107553487636415056_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jLn3wM-gwPsQ7kNvgEg2wWs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDh3-DbpdvWLQTC0Q3Ge3rC2O6L0BtuFS5PsvEx4cRP6A&oe=6730907A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PBGLandscape1.png", "id": "916414023856274", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75245817_916414027189607_1799958869549848484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpsDpUuunU4Q7kNvgFul8sK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDeWQlijuGV-lLe4Vk9QTGYcIDC4qQFj4zti0ssMCHlcw&oe=6730A4AA"}, "display_name": "Plastic Battlegrounds", "keywords": ["plastic", "battlegrounds", "sandbox", "toys", "armymen"], "long_description": "Welcome to Plastic Battlegrounds, the newly commissioned sandbox toy-based battle simulator that includes objective based modes, where your plastic soldiers engage in intense set piece battles. Set up the battlefield with an ever growing list of units, vehicles, emplacements, and environment hazards then either join the battle as a plastic soldier or be life sized and tower over the chaos. Drive fast moving toy jeeps or pilot drones armed with explosives and machine guns. Blow up toy brick fortifications and tear apart your virtual living space in ways you absolutely cannot do in real life!\n\nIn sandbox mode, setup battles by placing units, setting up spawners, and make  combat scenarios unique to each play session. It's what you could previously only imagine toy soldiers doing, but now they are truly brought into action!\n\nTry the experimental Conquest mode where you are tasked with holding the majority of capture points to achieve victory over the enemy team.\n\nThis game is very early in development, there is much to be done and the toy war has only begun. Join our Discord community linked in our website to keep up with development news - see you on the battlefield, soldier! ", "short_description": "Create and participate in the battles of your childhood dreams, watch as the plastic soldiers and toys you place come to life in both creative sandbox and strategic objective based modes. Be life sized, watch the battle from above, and crush the toys with your fists or be a plastic soldier wielding a variety of ballistic or explosive based weapons with powerful vehicles at your disposal and gain the tactical advantage over the enemy toys."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.simulated-minds.com/legal/privacy-policy-games", "developer_terms_of_service_url": null, "publisher_name": "Simulated Minds", "support_website_url": null, "website_url": "https://www.simulated-minds.com/plastic-battlegrounds", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8534717713282704"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75439594_4620050848220021_434229737