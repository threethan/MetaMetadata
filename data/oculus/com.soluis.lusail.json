ideo_trailer_thumbnail": {"file_name": "/tmp/JPY9Gg", "id": "496854654200319", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982631_496854660866985_2400507082009739264_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cyb5R2QT3IgQ7kNvgGSVUur&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAyPKD453FgRazbzhuxjB6KaqMUDVL_-PPkX-FII2ctiQ&oe=670269F3"}, "display_name": "Lusail Stadium VR Experience \u062a\u062c\u0631\u0628\u0629 \u0627\u0633\u062a\u0627\u062f \u0644\u0648\u0633\u064a\u0644 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629", "keywords": ["World", "Cup", "Qatar", "2022", "Lusail"], "long_description": "Get a front-row seat for a match at the Qatar 2022 final stadium. \n\nOur Lusail Stadium experience puts you at the heart of the action in the 80,000-seat arena, which will also open the historic tournament.\n\nIt was in Lusail where Qatar\u2019s founder, Sheikh Jassim bin Mohammed Al Thani, lived in the early 20th century, drawing up the blueprint for a new nation focused on the human and social development of its people above all else.\n\nThe centrepiece of Lusail City, a newly built and truly state-of-the-art metropolis, the venue will write a new page in Qatar\u2019s history, while paying homage to the rich past of the country and region. \n\nThe Lusail Stadium VR Experience is available in both English and Arabic.\n\n\u062a\u062c\u0631\u0628\u0629 \u0627\u0633\u062a\u0627\u062f \u0644\u0648\u0633\u064a\u0644 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629 \u0645\u062a\u0648\u0641\u0631\u0629 \u0628\u0627\u0644\u0644\u063a\u062a\u064a\u0646 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u0625\u0646\u062c\u0644\u064a\u0632\u064a\u0629", "short_description": "Get a front-row seat for a match at the Qatar 2022 final stadium. \n\nOur Lusail Stadium experience puts you at the heart of the action in the 80,000-seat arena, which will also open the historic tournament.\n\nThe Lusail Stadium VR Experience is available in both English and Arabic.\n\n\u062a\u062c\u0631\u0628\u0629 \u0627\u0633\u062a\u0627\u062f \u0644\u0648\u0633\u064a\u0644 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629 \u0645\u062a\u0648\u0641\u0631\u0629 \u0628\u0627\u0644\u0644\u063a\u062a\u064a\u0646 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u0625\u0646\u062c\u0644\u064a\u0632\u064a\u0629"}]}, "developer_name": "Soluis Technologies Ltd", "developer_privacy_policy_url": "https://www.qatar2022.qa/en/privacy", "developer_terms_of_service_url": "https://www.qatar2022.qa/en/terms-of-use", "publisher_name": "Supreme Committee for Delivery & Legacy", "support_website_url": null, "website_url": "https://www.qatar2022.qa/en/home", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2772648879707632"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982615_710051466128595_4703848431687303168_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_n4Ueqf0NqYQ7kNvgEH0wY_&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD6G7A9cH-3HkKFnMNp95nqed10k3PiTM9ByDzMcE_guw&oe=6702856E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Lusail Stadium VR Experience \u062a\u062c\u0631\u0628\u0629 \u0627\u0633\u062a\u0627\u062f \u0644\u0648\u0633\u064a\u0644 \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629", "platfor