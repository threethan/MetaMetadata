_sid=6e7a0a&_nc_ohc=uX0QOUMzqhoQ7kNvgF0FW-9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAul3rSOdO6OiuLgMma5qZspuZiuoEQ1278X4gpAn4aZw&oe=671B8DEC"}, {"file_name": "Screenshot 2.png", "id": "1037410648387030", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031520_1037410651720363_7760900814908694990_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uUulhv_WPbUQ7kNvgF9lwL5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMmMuda2p6gCT9c8AZl0atgivZQVa-Spc2ZoaUpB1mgw&oe=671B9B4C"}, {"file_name": "Screenshot 4.png", "id": "526556643182507", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207238_526556646515840_4210419533547246176_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iCEmux3gv-EQ7kNvgFAZ5sj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBjBQliCy5fshctTjRzaJiOOZAcgu_NtgLu_wzpU7JxrA&oe=671B8FDB"}, {"file_name": "Screenshot 5.png", "id": "874596974608482", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035452_874596977941815_6396562645775943895_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s6rB-hUJqf0Q7kNvgG8kCjB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAss3mxfTn3LQFE4DEuXbdtfTkmPPEzjxcvb1AWpgolTA&oe=671B6A29"}, {"file_name": "Screenshot 3.png", "id": "1151332952610184", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254869_1151332955943517_5839283989083184281_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_PPkIpWrkEQ7kNvgHRop5y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzr9NEwLlQuas5lfchVHO0r-0PKPa0TZoROfxrC7hjCA&oe=671B863C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Edda \u7269\u7406\u5b66 1", "keywords": ["\u6559\u80b2", "\u7269\u7406", "\u5b66\u4e60", "\u5b9e\u9a8c\u5ba4", "\u5b9e\u9a8c\u9a8c"], "long_description": "\u6b22\u8fce\u6765\u5230 Edda \u7269\u7406\u5b66 1\uff0c\u8fd9\u662f\u4e00\u6b3e\u7531\u745e\u5178\u516c\u53f8\u5f00\u53d1\u7684\u5f00\u521b\u6027 VR \u7269\u7406\u5e94\u7528\u7a0b\u5e8f\u3002Edda \u7269\u7406\u5b66 1 \u91c7\u7528\u79d1\u5b66\u4e25\u8c28\u7684\u6559\u5b66\u65b9\u6cd5\u8bbe\u8ba1\uff0c\u5c06\u590d\u6742\u7684\u79d1\u5b66\u6982\u5ff5\u8f6c\u5316\u4e3a\u5f15\u4eba\u5165\u80dc\u7684\u52a8\u624b\u5b66\u4e60\u3002\n\n**Edda \u7269\u7406\u5b66 1 \u63d0\u4f9b\u516d\u4e2a\u6c89\u6d78\u5f0f\u5b9e\u9a8c\u5ba4\uff1a**\n\n  - **\u963f\u57fa\u7c73\u5fb7\u539f\u7406\uff1a** \u53d1\u73b0\u6d6e\u529b\u548c\u6d41\u4f53\u52a8\u529b\u5b66\u7684\u79d8\u5bc6\u3002\n  - **\u725b\u987f\u8fd0\u52a8\u5b9a\u5f8b\uff1a** \u4f53\u9a8c\u652f\u914d\u8fd0\u52a8\u7684\u57fa\u672c\u539f\u7406\u3002\n  - **\u6838\u7269\u7406\u5b66\uff1a** \u63a2\u7d22\u539f\u5b50\u80fd\u7684\u5965\u79d8\u3002\n  - **\u76f8\u5bf9\u8bba\uff1a** \u7a7f\u8d8a\u65f6\u7a7a\u7684\u7ed3\u6784\u3002\n  - **\u79d1\u91cc\u5965\u5229\u6548\u5e94\uff1a** \u89c1\u8bc1\u5851\u9020\u5929\u6c14\u6a21\u5f0f\u548c\u6d0b\u6d41\u7684\u529b\u91cf\u3002\n  - **\u5e93\u4ed1\u5b9a\u5f8b\uff1a** \u63a2\u7d22\u7535\u8377\u53ca\u5176\u76f8\u4e92\u4f5c\u7528\u3002\n\n\u6bcf\u4e2a\u5b9e\u9a8c\u5ba4\u90fd\u662f\u5b8c\u5168\u4e92\u52a8\u7684\uff0c\u5141\u8bb8\u60a8\u64cd\u63a7\u53d8\u91cf\u5e76\u5b9e\u65f6\u67e5\u770b\u7ed3\u679c\uff0c\u4f7f\u5b66\u4e60\u65e2\u6709\u8da3\u53c8\u6709\u6548\u3002\u901a\u8fc7 VR\uff0cEdda \u7269\u7406\u5b66 1 \u5f25\u5408\u4e86\u7406\u8bba\u77e5\u8bc6\u4e0e\u5b9e\u9645\u5e94\u7528\u4e4b\u95f4\u7684\u5dee\u8ddd\uff0c\u63d0\u4f9b\u4e86\u65e0\u4e0e\u4f26\u6bd4\u7684\u6c89\u6d78\u5f0f\u4f53\u9a8c\u3002\n\n**\u4e3a\u4ec0\u4e48\u9009\u62e9 Edda \u7269\u7406\u5b66 1\uff1f**\n\n  - **\u4e92\u52a8\u5b66\u4e60\uff1a** \u53c2\u4e0e\u52a8\u624b\u5b9e\u9a8c\u548c\u4e92\u52a8\u573a\u666f\u3002\n  - **\u79d1\u5b66\u4e25\u8c28\uff1a** \u91c7\u7528\u6559\u5b66\u4e0a\u4e25\u8c28\u7684\u65b9\u6cd5\u5b66\u4e60\u3002\n  - **\u6709\u8da3\u4e14\u6559\u80b2\u6027\u5f3a\uff1a** \u8ba9\u5b66\u4e60\u7269\u7406\u6210\u4e3a\u4e00\u79cd\u4e50\u8da3\u3002\n\n\u8e0f\u5165\u6559\u80b2\u7684\u672a\u6765\uff0c\u4e0e Edda \u7269\u7406\u5