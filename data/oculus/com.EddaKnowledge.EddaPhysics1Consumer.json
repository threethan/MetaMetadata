1-7&_nc_sid=6e7a0a&_nc_ohc=ARqRcD8KlNYQ7kNvgE3wSY0&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA4Td0QaCArPYZvDNAmj0R8EDUAwNPDMbMYDx1vKoB3mQ&oe=6710EB04"}, {"file_name": "Screenshot 4.png", "id": "994392019037173", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38984442_994392022370506_4769827041526421674_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nKYJo30NhbMQ7kNvgE_4_hN&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA_q6ZqY0gqQtLpi3CtUHpgqqL2ozzgzIUEYB7nM-wgPg&oe=6710F285"}, {"file_name": "Screenshot 5.png", "id": "872378151044994", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003284_872378154378327_1971325718886904661_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OzhJ8h32GCAQ7kNvgGIJ-kc&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAh74LEoook4XgMy9ln3PL_gZsMV7B0TlmpgO-TnRgTbw&oe=67110E0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1477129366304721", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75262747_1477129372971387_2473087848575864391_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1xWBTUlyrkQ7kNvgGeSKm9&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCqvDxy0mgduy3ceCM27LmcDDXkyIffjf-Em83bZA-pZQ&oe=67110454"}, "display_name": "Edda Physics 1", "keywords": ["education", "physics", "learning", "lab", "experiment"], "long_description": "Welcome to Edda Physics 1, a groundbreaking VR physics app developed by a Swedish company. Designed with scientifically robust pedagogic methods, Edda Physics 1 transforms complex scientific concepts into engaging, hands-on learning.\n\n**Edda Physics 1 offers six immersive labs:**\n\n  - **Archimedes' Principle:** Discover the secrets of buoyancy and fluid dynamics.\n  - **Newton's Laws of Motion:** Experience the fundamental principles that govern movement.\n  - **Nuclear Physics:** Delve into the mysteries of atomic energy.\n  - **The Theory of Relativity:** Journey through the fabric of spacetime.\n  - **The Coriolis Effect:** Witness forces shaping weather patterns and ocean currents.\n  - **Coulomb's Law:** Explore electric charges and their interactions.\n\nEach lab is fully interactive, allowing you to manipulate variables and see real-time results, making learning both engaging and effective. With VR, Edda Physics 1 bridges the gap between theoretical knowledge and practical application, providing an unparalleled immersive experience.\n\n**Why Choose Edda Physics 1?**\n\n  - **Interactive Learning:** Engage with hands-on experiments and interactive scenarios.\n  - **Scientifically Sound:** Learn with pedagogically robust methods.\n  - **Fun and Educational:** Make learning physics a joy.\n\nStep into the future of education with Edda Physics 1. Download today and embark on a journey where science is not just observed but truly experienced. Transform your understanding of the physical world with the most engaging VR physics app available.", "short_description": "Explore the world of Edda Physics 1 which contains 6 labs where you'll get to experiment with Archimedes' principle, newtons laws of motion, nuclear physics, the theory of relativity, the coriolis effect and coloumbs law! All labs are entirely interactable and teaches you the principles governing our physical world. "}, {"images": {"nodes": [{"file_name": "background.png", "id": "1564661221100614", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001680_1564661224433947_7690187653499389845_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cHHl5rjXZhIQ7kNvgEAVtR0&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCFvKyrM7Dk3tviQlIFES1uW0dzlSPHyp59Glnk_Jetzw&oe=6711001D"}, {"file_name": "Portrait.png", "id": "1490504474914277", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75245820_1490504478247610_7476599560205274451_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v4QENXo4V4sQ7kNvgFCLPGK&_nc_ht=scontent-sea1-1.oculuscdn.c