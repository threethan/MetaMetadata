7&_nc_sid=6e7a0a&_nc_ohc=lzVpGNSo0HMQ7kNvgFjIfvP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIU8W9tLZZoK0e8lFVHChk1MKCnEdnmL0l2GWE5Z7z9A&oe=675AD192"}, {"file_name": "4A_Crater_Garden_Source_Exported_PSVR2_4K_03.09.2024_16-16-33.png", "id": "978679550695786", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272207_978679554029119_6261717649903546043_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CRuDQ3UL0TkQ7kNvgEp8vQI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVi7fKk7cF3tRMxZHPEbD-LhbgWOCWXeJ8Kxtod8lNSw&oe=675AD250"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Starship Troopers: Continuum", "keywords": ["Bugs", "Shooter", "FPS", "Guns", "PVE"], "long_description": "THE FIRST AND ONLY STARSHIP TROOPERS VR GAME\n\nIt\u2019s 25 years since the Battle of Klendathu, and the war between the Federation and the Arachnid is deadlocked. But the planet Janus-4 holds a secret that threatens to tip the balance of the war - one way or the other. \n \nCAMP TRIUMPH\nA new cohort of recruits is about to land at Camp Triumph, expecting light resistance from a minor bug infestation. Nope. Wrong! Those recruits just plunged into hell! They are now the last Troopers standing between the Federation and total Arachnid dominance! \n \n- 3 player online squad-based combat - team up to survive!\n- 20+ weapons - aim well and reload quickly if you want to live!\n- The classic bugs return and bring new friends - all mean, all hungry, all lethal!\n- Boss battles against Tankers and Plasmas - plus something new!\n- Epic missions in both familiar and unexplored terrain - bugs can come from anywhere!\n \nTHE CONTINUUM\nWelcome to the Continuum, a psychic weapon created to end the war. You are an experiment, a PsyCommander, with advanced psychic powers!\n \n- Control Troopers, rank them up, and try to keep them alive!\n- Promote them to citizenship for big bonuses, and advance your own powers faster!\n- Add psychic perks to build your perfect Trooper!\n- They will fight, die, and fight again - and they will win!\n \nTeam up and fight the war of the future against the most lethal enemy imaginable, with the life of every living human being at stake, in STARSHIP TROOPERS: CONTINUUM!", "short_description": "Battle lethal bugs on a distant planet in this epic 3 player VR PVE shooter"}]}, "developer_name": "XR Games", "developer_privacy_policy_url": "https://www.xrgames.io/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Sony Pictures Virtual Reality ", "support_website_url": null, "website_url": "https://www.xrgames.io/games", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8251380028272501"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "516185068078560"}, {"status": "PUBLISHED", "id": "1555882762477023"}, {"status": "PUBLISHED", "id": "864551632300886"}, {"status": "PUBLISHED", "id": "404559815675990"}]}, "baseline_offer": {"id": "1555882762477023"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "516185068078560"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8668903206520179", "version": "1.0.14185"}, "id": "1217368035518408", "ch