n.com/v/t64.5771-25/38974803_388230814292775_1039003180891009605_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ncveNcLokDgQ7kNvgF4dwX4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtIP4CIZzhGEXIjAV_RXt1XzIURC1b69dRqTeIYqJP5Q&oe=67542187"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Basketball_2560x1440.png", "id": "488297973938633", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86631738_488297977271966_2011727931340007606_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XMVrp7hGiPwQ7kNvgGh1HRQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAX1Z9mchna3Www7DgdgVIj9WqVFbz6CrmFlmW1nK6mFA&oe=67543C51"}, "display_name": "TOTALLY BASKETBALL", "keywords": ["basketball", "sports", "simulation", "fun", "multiplayer"], "long_description": "TOTALLY BASKETBALL lets you play the full sport of Basketball in VR!  Jump for the Tip-Off! Shoot free throws! Steal the ball but don't get a Foul! This game gives you the awesome ability to control your teammates when playing full court 3v3 matches. Use your buttons to move your teammates to better positions or to pass the ball when you've got a good shot!\n\nNewest Update:\n-Added Multiplayer Horse\n-Better shooting assist - Low, Med, High\n-More competitive AI players\n\nFeatures:\n-Top notch realistic shooting physics!\n-Practice and tutorial modes for new players\n-Multiple teams/venues to play\n-Multiplayer\n-Customize your character\n-Monthly Game updates\n-Large community on Discord\n\nCOMING SOON:\n-More Mini Games\n-New Multiplayer modes\n.... And So Much More!", "short_description": "Control your A.I. teammates in 3v3 Basketball with a singleplayer campaign or play a friend in VS mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zevogames.com/totally-basketball-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zevo Games", "support_website_url": null, "website_url": "https://zevogames.com/", "category": null, "comfort_ratin