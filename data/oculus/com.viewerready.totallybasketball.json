K6xBXAUpBY6x-Of-OD4sU-cahnLw97jws5MmVQ&oe=677E6858"}, {"file_name": "4.png", "id": "3896389530629172", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39001676_3896389533962505_314231226312175465_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=na0NTNTt4PgQ7kNvgEObq-l&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCkVm7v67_JbnnGuDcboYcpBOv9FcBBN_cA_7ZfTFvL6g&oe=677E4A36"}, {"file_name": "3.png", "id": "434089773009018", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38982518_434089776342351_5112110884632620738_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0AW5sPAubhoQ7kNvgFEx0ZU&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYDrIfN1mueU_Ut8_uJ-PfzoXKFoya_lhpKpyY-YNM4dQg&oe=677E4F3D"}, {"file_name": "5.png", "id": "388230810959442", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974803_388230814292775_1039003180891009605_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t3tnq6Lv0osQ7kNvgHE3LyF&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYD7JnEadjtDzpLqj-0t7hx7GPGqqV0suiz6x6qI0Tw7Lg&oe=677E5187"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Basketball_2560x1440.png", "id": "488297973938633", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/86631738_488297977271966_2011727931340007606_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H59U-2T3of4Q7kNvgEsXi2x&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYDcE7IBB_T5BNCG9jcRDBovtE2tsGbq0YAlfBEhiTQGsw&oe=677E6C51"}, "display_name": "TOTALLY BASKETBALL", "keywords": [], "long_description": "TOTALLY BASKETBALL lets you play the full sport of Basketball in VR!  Jump for the Tip-Off! Shoot free throws! Steal the ball but don't get a Foul! This game gives you the awesome ability to control your 2 teammates when playing full court 3v3 matches. Use your buttons to move your teammates to better positions or to pass you the ball when you've got a good shot!\n\n\nFeatures:\n-Practice and tutorial modes for new players\n-Multiple teams/venues to choose from (and play against)\n-Top notch realistic shooting physics\n-Multiplayer (Play against a friend and control your own teams or play a 1 on 1 game of Horse together)\n-Customizer (Make your Avatar look as cool as you want)\n-Fun seasonal updates (Check out new stadiums and new items throughout the year)\n-Large community of people to play with or get tips from (See our Discord)\n\nCOMING SOON: 5v5 Multiplayer (up to 10 friends)\n", "short_description": "Control your A.I. teammates in 3v3 Basketball with a singleplayer campaign or play a friend in VS mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zevogames.com/totally-basketball-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zevo Games", "support_website_url": null, "website_url": "https://zevogames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8234853729909895"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "3907045666232136"}, {"status": "PUBLISHED", "id": "529717906260927"}]}, "baseline_offer": {"id": "529717906260927"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "3907045666232136"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8975744065820854", "version": "0.411"}, "id": "1003977160878152", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6781908485204434", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8975744065820854"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1003977160878152"}]}, "change_log": "Patch Notes (v0.411):\nBug Fixes:\nFixed an issue causing AI dunks to miss the basket.\nResolved several timing issues causing the AI to get stuck in animations.\nMade a correction to the item database connection information.\nFixed an issue with positioning during Free Throws.\nImprovements:\nMultiplayer Versus now allows up to 6 players.\nResolved several specific causes of desyncs in multiplayer.\nImproved general multiplayer synchronization.\nNew Features:\nNew Multiplayer game mode: Free Roam\u2026 Get out there and play how you want to play (up to 6 players)\nNew Dribbling Mode: Automatic\u2026 Start that dribble cycle and let the game do the rest.", "created_date": 1734734151, "id": "8975744065820854", "version": "0.411", "version_code": 411, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6781908485204434", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8975744065820854"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1003977160878152"}]}, "change_log": "Basketball Patch Notes (Live v0.410):\n\nBug Fixes:\n\n    - The AI no longer get stuck in the hoop base.\n\n    - Fixed an issue with the no-go zone in Multiplayer Horse at Toronto Arena.\n\n    - Resolved an issue causing disconnects when transitioning from the lobby into a multiplayer match.\n\n    - Resolved a few issues with the Tutorial.\n\n    - General stability fixes to multiplayer horse to prevent stuck states.\n\nImprovements:\n\n    - Modified shooting assists for a better overall feel.\n\n    - Expanded multiplayer horse to allow up to 6 players.\n\n    - Improved AI decision making.\n\n    - Reduced the sitting height adjustment.\n\n    - Improved the fall animation when an AI is pushed.\n\n    - Art improvements throughout.\n\n    - Increased the smoothness of AI movements and behavior.\n\nNew Features:\n\n    - Is the game taking too long? You can now choose to play 2 minute quarters instead or keep the classic 3 minute quarters.\n\n    - Increased the aggressiveness of the AI by giving them the ability to steal.\n\n    - Players now become ghost spectators in multiplayer horse when they lose.", "created_date": 1732311686, "id": "8820549284673667", "version": "0.410", "version_code": 410, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6781908485204434", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8975744065820854"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732216807, "id": "8814258178636111", "version": "0.409", "version_code": 409, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "Andr