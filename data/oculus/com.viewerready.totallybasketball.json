n.com/v/t64.5771-25/38974803_388230814292775_1039003180891009605_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gCYjrRVCfW8Q7kNvgHZnG4W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCM7GtCGdRUouf1lRbT2PWHscgQmQ7IKCxd5MkgNqb5Ww&oe=67332C07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Basketball_2560x1440.png", "id": "488297973938633", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86631738_488297977271966_2011727931340007606_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lQB0EF9uYqEQ7kNvgHKovD3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGyJDIcIxntNHL8IQbsuxDMwDHX7YAdZfiIU0KpV6MHQ&oe=673346D1"}, "display_name": "TOTALLY BASKETBALL", "keywords": ["basketball", "sports", "simulation", "fun", "multiplayer"], "long_description": "TOTALLY BASKETBALL lets you play the full sport of Basketball in VR!  Jump for the Tip-Off! Shoot free throws! Steal the ball but don't get a Foul! This game gives you the awesome ability to control your 2 teammates when playing full court 3v3 matches. Use your buttons to move your teammates to better positions or to pass you the ball when you've got a good shot!\n\n\nFeatures:\n-Top notch realistic shooting physics!\n-Practice and tutorial modes for new players\n-Multiple teams/venues to choose from (and play against)\n-Multiplayer (Play against a friend and control your own teams or play a 1 on 1 game of Horse together)\n-Customizer (Make your Avatar look as cool as you want)\n-Fun seasonal updates (Check out new stadiums and new items throughout the year)\n-Large community of people to play with or get tips from (See our Discord)\n\nCOMING SOON:\n-New Game Modes\n-New Multiplayer options\n-More Mini-Games\n.... And So Much More!\n", "short_description": "Control your A.I. teammates in 3v3 Basketball with a singleplayer campaign or play a friend in VS mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zevogames.com/totally-basketball-privacy-policy/", "develop