dn.com&_nc_gid=AaBYN7zAzQt3uYycwVL1iTk&oh=00_AYB2n-45lUd6o2s8OmuxeUgKg4ReYrdHqY7saThn8h-1eg&oe=66F3FED1"}, "display_name": "TOTALLY BASKETBALL", "keywords": [], "long_description": "TOTALLY BASKETBALL lets you play the full sport of Basketball in VR!  Jump for the Tip-Off! Shoot free throws! Steal the ball but don't get a Foul! This game gives you the awesome ability to control your 2 teammates when playing full court 3v3 matches. Use your buttons to move your teammates to better positions or to pass you the ball when you've got a good shot!\n\n\nFeatures:\n-Practice and tutorial modes for new players\n-Multiple teams/venues to choose from (and play against)\n-Top notch realistic shooting physics\n-Multiplayer (Play against a friend and control your own teams or play a 1 on 1 game of Horse together)\n-Customizer (Make your Avatar look as cool as you want)\n-Fun seasonal updates (Check out new stadiums and new items throughout the year)\n-Large community of people to play with or get tips from (See our Discord)\n\nCOMING SOON: 5v5 Multiplayer (up to 10 friends)\n", "short_description": "Control your A.I. teammates in 3v3 Basketball with a singleplayer campaign or play a friend in VS mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zevogames.com/totally-basketball-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zevo Games", "support_website_url": null, "website_url": "https://zevogames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages":