}, {"file_name": "2.png", "id": "855602862779757", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982723_855602866113090_5553262818950153892_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BBz3EW5-lTkQ7kNvgHtCOLQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvDCRsuWVNblkDqnm_57BrlUr6B45HTzrVgfwbzmaGcQ&oe=66FBE3D8"}, {"file_name": "4.png", "id": "3896389530629172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001676_3896389533962505_314231226312175465_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x-_fGrKvaLMQ7kNvgGPKsJs&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaQ0oFVsL_HFS4sEvNVsO50rNQqmqyNz-89BzKSVmv6w&oe=66FBC5B6"}, {"file_name": "3.png", "id": "434089773009018", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_434089776342351_5112110884632620738_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ke-647fJQasQ7kNvgEc-yQ0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuhov1K04f0kIbz_dn1k5_GXzPZOl4MmpbzzJbSf_DXw&oe=66FBCABD"}, {"file_name": "5.png", "id": "388230810959442", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974803_388230814292775_1039003180891009605_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8xdPGFrv6dkQ7kNvgERgHhv&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9qDSw-2tiq761Kp7-lkxDjsJG_BpIRBreN_6fGyILrg&oe=66FBCD07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Basketball_2560x1440.png", "id": "488297973938633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86631738_488297977271966_2011727931340007606_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q_DYzWk1CNYQ7kNvgFcPwPP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPWmVmBUc42OlkH2di3m8GfNgMASHGW7TZyk53h0lCDA&oe=66FBE7D1"}, "display_name": "TOTALLY BASKETBALL", "keywords": [], "long_description": "TOTALLY BASKETBALL lets you play the full sport of Basketball in VR!  Jump for the Tip-Off! Shoot free throws! Steal the ball but don't get a Foul! This game gives you the awesome ability to control your 2 teammates when playing full court 3v3 matches. Use your buttons to move your teammates to better positions or to pass you the ball when you've got a good shot!\n\n\nFeatures:\n-Practice and tutorial modes for new players\n-Multiple teams/venues to choose from (and play against)\n-Top notch realistic shooting physics\n-Multiplayer (Play against a friend and control your own teams or play a 1 on 1 game of Horse together)\n-Customizer (Make your Avatar look as cool as you want)\n-Fun seasonal updates (Check out new stadiums and new items throughout the year)\n-Large community of people to play with or get tips from (See our Discord)\n\nCOMING SOON: 5v5 Multiplayer (up to 10 friends)\n", "short_description": "Control your A.I. teammates in 3v3 Basketball with a singleplayer campaign or play a friend in VS mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zevogames.com/totally-basketball-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zevo Games", "support_website_url": null, "website_url": "https://zevogames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8234853729909895"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "529717906260927"}]}, "baseline_offer": {"id": "529717906260927"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 172676520