ize your monke with a few items available in the in-game shop.\n\nFeel the spook in the Horror mode, with a creepy environment and a scary monster await.\n", "short_description": "Monke Happy is a Gorilla Tag fangame with FREE MODS, Rising Lava, Zero Gravity, Shop, and HORROR!"}]}, "developer_name": "duncemonkey", "developer_privacy_policy_url": "https://sites.google.com/view/monkehappy/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "duncemonkey", "support_website_url": null, "website_url": "https://sites.google.com/view/monkehappy/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25592056947109187"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1649072169266201"}]}, "baseline_offer": {"id": "1649072169266201"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718752263, "status": "PUBLISHED", "id": "1649072169266201"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25653873287594219", "version": "0.2"}, "id": "963726848819430", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25592056937109188", "is_concept": false, "latest_released_binary": {"__typename": "Androi