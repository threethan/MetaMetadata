n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i4gczcRqGt8Q7kNvgFrs9gl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUN0MWZID-yo6ThLTYXnxSHAnyFJ9uzx3WRhBfjtVJFw&oe=672B5B14"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Image.png", "id": "6202047503195544", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982698_6202047506528877_2817186000954123797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2LtBuITGywQ7kNvgHWipsJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMpVw41qSKra710wPWnLt3FK78q2B45UrCbK4nVZBpSQ&oe=672B6BE0"}, "display_name": "Tennis League VR", "keywords": ["Tennis", "Sports", "Multiplayer", "Arcade", "Simulator"], "long_description": "Tennis League VR delivers the thrill of landing the perfect ace, whether you are a casual gamer or an aspiring pro. Use real tennis techniques to dominate the court and smash the competition! You can play solo in a variety of game modes such as career or custom games, or take your skills online and put them to the test.\n\nRefine your slice, topspin, and lob with time-attack and precision challenges. You can even test your aim against an ever-increasing army of robots in our newest game mode Droid Rush!\n\nDeveloped with the help of real athletes and sports professionals, Tennis League VR offers a challenge for every skill level.\n\n~Features~\n\n\ud83c\udfbe Become a VR Tennis Ace\n\nJump into Career mode and compete in tournaments against challenging AI opponents across numerous different courts. \n\n\ud83c\udfbe Training Lessons\n\nLearn the basics of ground strokes, volleys, and serves with the robust Training Mode, which includes customizable ball cannon practice options and engaging skill challenges.\n\n\ud83c\udfbe Droid Rush Mode\n\nMaster your swing against a swarm of robot invaders in Droid Rush. Hone your aim and take out those shields quickly!\n\n\ud83c\udfbeOnline Multiplayer\n\nTest your skills against other players online from around the globe. Invite up to 8 friends to jeer or cheer you on from the sidelines.\n\n\ud83c\udfbe Multiple Control Options\n\nMove around the court by teleporting or using analog stick movement, and customize your playstyle", "short_description": "Tennis League VR delivers the thrill of landing the perfect ace, whether you are a casual player or an aspiring pro"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tennisleaguevr.com/privacy-policy-app/", "developer_terms_of_service_url": null, "publisher_name": "HIP", "support_website_url": null, "website_url": "http://tennisleaguevr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7093644620684445"}, "review_messages": ["Approved."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982468_1276934016364024_2170394684159187162_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CQoNrcw6FZQQ7kNvgFnMTu7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCY36WZBm6sPWebiaVb4wn56HGft_0vCqUgT7Og2MgULQ&oe=672B5AEB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tennis League VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "i