3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmQpt8pBBszhsZ5zree840IAj7XvZBc1H-fdhVngVzZw&oe=672B670B"}, {"file_name": "Screenshot 3.png", "id": "908464796939542", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/54823267_908464800272875_1011895239082764107_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-yWaqOj5yG8Q7kNvgHBilyn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJLjMsrXD8AUZ0MBtG2UazrcxZoKFvKAZGXoiUJcSzdg&oe=672B3D88"}, {"file_name": "Screenshot 1.png", "id": "1855449781477264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001719_1855449784810597_5162547841034130380_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bpo1ZTVmBNQQ7kNvgGyM7mm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFDNOL68FQEr5dkBEhvTHNLsK8ByELtbrdEoADHy3OTg&oe=672B5D72"}, {"file_name": "Screenshot 5.png", "id": "934116651270684", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974711_934116654604017_3600594800906826846_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i4gczcRqGt8Q7kNvgFrs9gl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUN0MWZID-yo6ThLTYXnxSHAnyFJ9uzx3WRhBfjtVJFw&oe=672B5B14"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Image.png", "id": "6202047503195544", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982698_6202047506528877_2817186000954123797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2LtBuITGywQ7kNvgHWipsJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMpVw41qSKra710wPWnLt3FK78q2B45UrCbK4nVZBpSQ&oe=672B6BE0"}, "display_name": "Tennis League VR", "keywords": ["Tennis", "Sports", "Multiplayer", "Arcade", "Simulator"], "long_description": "Tennis League VR delivers the thrill of landing the perfect ace, whether you are a casual gamer or an aspiring pro. Use real tennis techniques to dominate the court and smash the competition! You can play solo in a variety of game modes such as career or custom games, or take your skills online and put them to the test.\n\nRefine your slice, topspin, and lob with time-attack and precision challenges. You can even test your aim against an ever-increasing army of robots in our newest game mode Droid Rush!\n\nDeveloped with the help of real athletes and sports professionals, Tennis League VR offers a challenge for every skill level.\n\n~Features~\n\n\ud83c\udfbe Become a VR Tennis Ace\n\nJump into Career mode and compete in tournaments against challenging AI opponents across numerous different courts. \n\n\ud83c\udfbe Training Lessons\n\nLearn the basics of ground strokes, volleys, and serves with the robust Training Mode, which includes customizable ball cannon practice options and engaging skill challenges.\n\n\ud83c\udfbe Droid Rush Mode\n\nMaster your swing against a swarm of robot invaders in Droid Rush. Hone your aim and take out those shields quickly!\n\n\ud83c\udfbeOnline Multiplayer\n\nTest your skills against other players online from around the globe. Invite up to 8 friends to jeer or cheer you on from the sidelines.\n\n\ud83c\udfbe Multiple Control Options\n\nMove around the court by teleporting or using analog stick movement, and customize your playstyle", "short_description": "Tennis League VR delivers the thrill of landing the perfect ace, whether you are a casual player or an aspiring pro"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.anothereality.io/tennis-league-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HIP", "support_website_url": null, "website_url": "http://tennisleaguevr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "723681545866485"}}]}, "scheduled_offers": {"count": 12, "nodes": [{"status": "PUBLISHED", "id": "1846668352394975"}, {"status": "PUBLISHED", "id": "314447417739666"}, {"status": "PENDING", "id": "848285186402027"}, {"status": "PENDING", "id": "1079606046339822"}, {"status": "PUBLISHED", "id": "935923764182652"}, {"status": "PUBLISHED", "id": "208257512003735"}, {"status": "PENDING", "id": "996107108288710"}, {"status": "PUBLISHED", "id": "1316424185670981"}, {"status": "PENDING", "id": "655387566545503"}, {"status": "PENDING", "id": "1212034882798400"}, {"status": "PUBLISHED", "id": "1874145586296953"}, {"status": "PENDING", "id": "647874553659360"}]}, "baseline_offer": {"id": "1874145586296953"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1698080400, "status": "PUBLISHED", "id": "1846668352394975"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6327991453916436", "version": "1.0.2.0"}, "id": "710248737468517", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5847349178647335", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6327991453916436"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "710248737468517"}]}, "change_log": "Physics tuning: \n- Applied more controls over flick movements and strong shots, allowing for better ball control throughout the game. You'll be in full control of your shots. Tuning applied both for Arcade and Simulation modes!\n- We removed some helpers on serve while in Simulation mode. This will allow more \"straight\" and powerful serve shots (with the proper technique)! In Arcade Mode, those helpers remain: they are applied on more strong shots, helping the ball to stay on the court more often at the price of lower shot speed.\n\nExpanded movement options.\nWe've expanded the selector in the settings panel allowing you to choose your preferred locomotion mode among these 4:\n- Default teleport: press input to teleport to the closest position to catch the ball after or before the bounce\n- Advanced teleport: press input to teleport like in default mode, then press again to switch between forehand and backhand position\n- Auto teleport: you'll be automatically teleported to the closest position to receive the ball. Use the input to switch receive position between after or before the bounce\n- Free movement mode: use the analog sticks to move smoothly on the field. Now you can move smoothly while in the home environment too!\n\nOn the teleport modes, you can also select if you prefer to use the buttons (A, B) or the analog stick (forward, backward).", "created_date": 1688629139, "id": "6327991453916436", "version": "1.0.2.0", "version_code": 27, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5847349178647335", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6327991453916436"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "710248737468517"}]}, "change_log": "- Improved user profile management to prevent app from crashing upon closing health and safety splashscreen on some devices", "created_date": 1688147418, "id": "6309881202394128", "version": "1.0.1.3", "version_code": 26, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5847349178647335", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6327991453916436"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "710248737468517"}]}, "change_log": "- Tweaked startup flow to prevent app from crashing upon closing health and safety splashscreen on some devices", "created_date": 1687540277, "id": "6286954754686773", "version": "1.0.1.2", "version_code": 25, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5847349178647335", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6327991453916436"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "710248737468517"}]}, "change_log": "- Fixed a bug that made the app crash to the dashboard for some players, when closing the health and safety splashscreen\n- Fixed some setting on the new avatar skins so they load and perform better", "created_date": 1687427325, "id": "6282399551808960", "version": "1.0.1.1", "version_code": 24, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5847349178647335", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6327991453916436"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "710248737468517"}]}, "change_log": "- Enhanced multiplayer game settings\n\nAll multiplayer games are now set as public by default, ensuring that your matches are visible to your regional community. If you prefer to keep your match private, you can easily switch it back using the lock slider located in the top right corner of the panel.\n\n\n- Expanded avatar customization\n\nWe have listened to our users' feedback regarding limited options for skin tones in the avatar customization feature. We understand the importance of inclusivity and representation, so we have added a wider range of skin tones to choose from. This is just a first step, as we plan to include more physiognomies in the future for a more realistic representation.\n\n\n- Updated tennis court visuals\n\nWe have rectified a texture issue with a specific tennis court environment that previously depicted court lines unrealistically.\n\n\n- Improved color management in headset screens\n\nDue to some missing settings, the game environments occasionally appeared overly red. We have addressed this issue, and now the vibrant colors of the game environments are displayed as intended.\n\n\nWe would like to thank everyone who helped the development of Tennis League with their feedback, and encourage you to provide your thoughts on this update in our Discord community. Your input helps us prioritize future updates and improvements!", "created_date": 1686588308, "id": "6247541615294754", "version": "1.0.1.0", "version_code": 23, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}