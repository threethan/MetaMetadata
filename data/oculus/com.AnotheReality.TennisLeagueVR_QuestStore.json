zTb8QPR2HyDGQ&oe=672B6237"}, {"file_name": "Screenshot 4.png", "id": "475980641320950", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/54823267_475980644654283_8853351377469610015_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dftb5VGCLYMQ7kNvgGcTdA7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBk47EkDlCA9d7mh9SD3EAkXeV90uNH8KCbnwEgSz6QEA&oe=672B6F4A"}, {"file_name": "Screenshot 5.png", "id": "1291766381750558", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974441_1291766385083891_5331294180248446817_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qsaMsMk3leAQ7kNvgEUckKd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD72KBQD8ggp6hA4Vqj2l0pViG5N-gI-fLmNIe8qDM-kA&oe=672B474D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Image.png", "id": "3485484615103181", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_3485484618436514_6061129467658172787_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tTX_Zpik1LcQ7kNvgHaxmJp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQ6uenpTEMswYWfl5VosPI-p1s5u1Uq7BltjejJp8kXw&oe=672B4A23"}, "display_name": "Tennis League VR", "keywords": ["Arcade", "Tennis", "Sport", "Simulazione", "Multiplayer"], "long_description": "Utilizza I fondamenti del Tennis per dominare le classifiche e schiacciare i tuoi avversari. Sfida i tuoi amici online, oppure tuffati da solo in diverse modalit\u00e0 di gioco come\ncarriera o partite personalizzate.\n\nAffina il tuo servizio piatto, topspin o rovescio da paura con sfide di precisione e a tempo. Puoi addirittura salvare il mondo da un'incessante invasione di robot malvagi nella nuova modalit\u00e0 Droid Rush!\n\nSviluppato con l'aiuto di veri atleti e professionisti del settore,\nTennis League VR offre una sfida per qualsiasi livello di esperienza.\n\n~Funzionalit\u00e0~\n\n\ud83c\udfbe Diventa una maestro del Tennis in VR\n\nTuffati nella modalit\u00e0 Carriera e competi in tornei contro la CPU in differenti stadi e campi da tennis.\n\n\ud83c\udfbe Modalit\u00e0 d'allenamento\n\nImpara ad affinare i tuoi dritti, rovesci e servizi con una modalit\u00e0 d'allenamento completa, che include diverse opzioni di pratica con il lanciapalle.\n\n\ud83c\udfbe Modalit\u00e0 Droid Rush\n\nPadroneggia i tuoi colpi contro un'orda incessante di invasori robot in Droid Rush. Migliora la tua mira ed elimina velocemente i loro scudi.\n\n\ud83c\udfbe Multigiocatore Online\n\nCompeti online e domina avversari provenienti da tutto il mondo. Invita fino a 8 amici per farti acclamare dagli spalti!\n\n\ud83c\udfbe Il controllo nelle tue mani\n\nSfreccia su e gi\u00f9 per il campo usando la modalit\u00e0 di teletrasporto veloce, oppure immergiti nell'azione con il movimento tramite stick analogico.", "short_description": "Che tu sia un aspirante professionista o un casual gamer, prova il brivido di mettere a segno l'ace perfetto con Tennis League VR!"}, {"images": {"nodes": [{"file_name": "Cover Square.png", "id": "3545543952439161", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974716_3545543955772494_3733822155857298504_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jDjYrqmYWOYQ7kNvgFFoOYq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGCiNDS0xYXsUej4emnT4PWs3AkerO-UG2XJoKEma1pA&oe=672B547E"}, {"file_name": "Immersive Logo.png", "id": "1668864600251243", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036672_1668864603584576_2682750881899820191_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LsoSFvO7x18Q7kNvgH3ea4M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARMczMyr_dIv7PipHVw_7uM-FqjBF5Z_EP3z-pIeqeEQ&oe=672B493F"}, {"file_name": "Mini Landscape.png", "id": "1396012134493882", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469631_1396012137827215_249834422861478327_n.png?_nc_cat=108&ccb=1-7&_nc