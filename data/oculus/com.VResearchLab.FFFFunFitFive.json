vCYyzwj6FJDaPFh3UBDNdo6XXPgw&oe=674EEDE7"}, {"file_name": "Screenshot 3.png", "id": "1347822496180962", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974771_1347822502847628_2973837478951557063_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OW-ayyTVgucQ7kNvgHcTnGa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeQakvIkvAoVaZmkeHpLW84M2QD00QKEgi9kMVMLYOnA&oe=674EE3DC"}, {"file_name": "Screenshot 4.png", "id": "2348443238881357", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982611_2348443242214690_4027168442501217207_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Xh0H3eyftwQ7kNvgF0fxgq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTQY-SyxwzyjnB554DM-Djgw4f_JGkD5WQx2_dYTf9FA&oe=674EF1F4"}, {"file_name": "Screenshot 5.png", "id": "936112251736636", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031555_936112258403302_1756327036982173149_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5LPp9AB8Ze0Q7kNvgFMXte9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBNfzGxY1OYAMlCpOmV0AWTxD7O5PPT_8rZiKXIIyENTw&oe=674EE864"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "422827904084371", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982478_422827907417704_8317134776472567218_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LBKkDBgYiW8Q7kNvgEBStMu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsNteFkSBAD9ROWLKcg2CNTZcRgj6WzW4bRSonHTdygQ&oe=674ED8D5"}, "display_name": "Fun Fit Five", "keywords": ["fitness", "exercise", "workout", "boxing", "movement"], "long_description": "Fun Fit Five is a VR fitness game where you will perform different movements to hit incoming projectiles while you exercise across different themed scenarios in different workouts.\n\n**Start your fitness journey**\n\n- Receive workout recommendations in different categories, based on your own preferences and objectives.\n- Explore a growing library of workouts, with new ones being uploaded constantly.\n- Find the perfect workout for you with a variety of filters.\n- Track your progress with in-depth information and stay connected to your improvement throughout your workout journey!\n- Create your own Weekly Goals and raise the bar with customized steps and suggestions.\n\n**Challenge yourself**\n\n- Execute multiple workout movements with our three Workout Types: Punch, Blades & Hit Back.\n- Try out our unique Workout Events and have an extra-challenge at selected workouts.\n- 360\u00ba Experience: Choose the classic Stationary mode or level up with full-circle movement for a more immersive challenge!\n- Hit harder to score as many points as you can and get to the top of the leaderboard.\n\n**You in control**\n\n- Explore a variety of unique environments, each featuring custom Hit Equipment. Play any workout in any setting you like!\n- Rate your completed workouts and help shape the community rating visible to all players.\n- Prefer different settings? No problem! Tailor each workout with customizable options to make it perfect for you.\n\n", "short_description": "Start your fitness journey by working out in Fun Fit Five! Access different workouts from recommendations tailored to fit your goals or explore a growing library and challenge yourself with different movements while you hit incoming projectiles.\n\nTrack your progress with in-depth information, set your own goals, compete in the leaderboard and much more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://www.funfitfive.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}], "externa