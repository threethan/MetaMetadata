sid=6e7a0a&_nc_ohc=cwcRFAwr0mUQ7kNvgGgNNv9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWgcN2dqi4Zt5YCqdY4qMVs1OlGeJWfopcrZ7EJPCO4w&oe=674F014F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "393927429821046", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982697_393927433154379_443237427313226090_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jlGr8UYpfQYQ7kNvgEJ_4jh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCSV7CEIITdI5j44B5cc9PdBWM1FHgP8Bs-ba_PGIPFKw&oe=674EE138"}, "display_name": "Fun Fit Five", "keywords": [], "long_description": "Burn fat, not boredom, with Fun Fit Five. Ditch the dusty treadmills and reveal your inner athlete in unique VR worlds, where punching, slicing, dodging and mastering hand-crafted workouts become your new obsession.\n\nUnleash your power:\n- Punch, slice, and dodge your way through 45+ hand-crafted workouts across 3 unique themes \u2013 explore a spooky Haunted Mansion, conquer ancient Egypt, and more!\n- Customize your combat and track your progress with in-dept information\n\nFun Fit Five is:\n- Beyond the Gym: Immerse yourself in different VR worlds while you get fit.\n- Your Way to Fitness: Choose from a growing library of 45+ workouts, with new ones added every week! Customize your intensity and Theme and find your perfect flow.\n- Always Evolving: We're in Beta, so you might encounter some minor visual or gameplay glitches as we polish the game and constantly refine and update it based on your feedback. Join the community and experience the latest updates firsthand!\n\nReady to stay healthy? Fun Fit Five is calling. Grab your controllers (or go hands-free!), download now, and join the fitness party!", "short_description": "Punch, slice, hit and dodge from unique projectiles and start working out in the Beta version of Fun Fit Five.\n\nDive into +45 workouts and burn some calories across different themes. Track your progress, move your body, have fun and stay healthy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://vresearchlab.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "541654441494965"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "347660671375581"}]}, "baseline_offer": {"id": "347660671375581"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1705593600, "status": "PUBLISHED", "id": "347660671375581"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8913431812078998", "version": "0.28.2"}, "id": "1027181121998370", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6314552981966907", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8913431812078998"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732827067, "id": "8930592567029589", "version": "0.28.2", "version_code": 282, "release_status": "RELEASE