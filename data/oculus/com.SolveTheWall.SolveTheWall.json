lve the wall.", "short_description": "Solve the Wall combines climbing and puzzle solving in virtual reality. Each wall has a unique layout of handholds, magnets, hooks, and elevators, with only ONE PATH to the top. There are many dead ends where you\u2019ll have no choice but to let go of the wall and restart the level. The goal is to find the right combination of moves that will get you to the top and solve the wall."}]}, "developer_name": null, "developer_privacy_policy_url": "https://solvethewall.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Solve the Wall", "support_website_url": null, "website_url": "https://solvethewall.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7922444161167515"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "507965038870498"}, {"status": "PUBLISHED", "id": "491641623339078"}]}, "baseline_offer": {"id": "491641623339078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "507965038870498"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8010000949078502", "version": "0.4"}, "id": "3839001786329976", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinar