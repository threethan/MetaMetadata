DT3aHQS7g&oe=67558206"}, {"file_name": "1.png", "id": "1392236998308413", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222943_1392237001641746_5442523511094641796_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NwD5IobyhOkQ7kNvgHyG5r0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCScINgs4rrfK6_8Y1l0WokPiZ6pDSPfnrSgaCVPttt8g&oe=67558906"}, {"file_name": "3.png", "id": "3640364926252956", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974482_3640364929586289_8992655601525010842_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUM93GnebnIQ7kNvgEaM9wf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxV_56q1WtdI5leZjmiJ8yh0w6FbBvD7UEZdHj9Dcn9g&oe=67557037"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE_2560x1440.png", "id": "7185582884799521", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982623_7185582888132854_5357891611076837602_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_TQ9BCuGn1gQ7kNvgH4WHkB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVj0zjsoCcivmJ8y-Fik45eFCOpxuYlJmuTTniD7JUUw&oe=67558392"}, "display_name": "Santa's Conveyor Chaos", "keywords": [], "long_description": "Ho Ho Ho! It's Santa here, and I've got a big Christmas challenge for you! My workshop's a bit of a mess, and presents are popping out all over the place \u2014 right into your house!\n\nYou'll grab gifts from moving belts and pack them as fast as you can. It's simple: gifts come in, you pack them up, and together we make sure Christmas is ready to go!\n\nThe game is easy to play but can get pretty zippy, like reindeer on a gingerbread sugar rush. But hey, that's part of the fun! It's all about quick hands, a sharp eye, and a heart full of holiday spirit.\n\nNo scores, no timers, just you saving the day one gift at a time. There's also a personal gift shop for you to treat yourself to some home decoration, like a lovely Christmas tree! So, what do you say? Grab your Quest and make some room \u2014 let's see those present-packing skills in action!\n\nCheers and chuckles,\nSanta \ud83c\udf85\u2728", "short_description": "Ho Ho Ho! It's Santa here, and I've got a big Christmas challenge for you! My workshop's a bit of a mess, and presents are popping out all over the place \u2014 right into your house!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fieldof.vision/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Field Of Vision", "support_website_url": null, "website_url": "https://fieldof.vision/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6691893047573117"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3870098399890768"}]}, "baseline_offer": {"id": "3870098399890768"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1701360000, "status": "PUBLISHED", "id": "3870098399890768"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6830651050363982", "version": "0.1.6"}, "id": "3458487947736214", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6691893034239785", "is_concept": false, "latest_released_binary": {"__t