s4-1.oculuscdn.com&oh=00_AYAoyx0hUa_tAUFFKjS_dH3BAID_OWDkO8X9o-IHM9hUyg&oe=67864986"}, {"file_name": "1.png", "id": "1392236998308413", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75222943_1392237001641746_5442523511094641796_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ax0CH89IDrgQ7kNvgFFyYZo&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDGiKKlKWtv9TTjopx_iYcfopHAaAW2rVoj7vRwHZsHfw&oe=67865086"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE_2560x1440.png", "id": "7185582884799521", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982623_7185582888132854_5357891611076837602_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BaocXSIRiIMQ7kNvgFw4-Do&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAP8RLLL13l8X1_VuHQLL9VfiTwK6Sj1yND3HC56x-_1A&oe=67864B12"}, "display_name": "Santa's Conveyor Chaos", "keywords": [], "long_description": "December event is live! Read post below for details.\n\nHo Ho Ho! It's Santa here, and I've got a big Christmas challenge for you! My workshop's a bit of a mess, and presents are popping out all over the place \u2014 right into your house!\n\nYou'll grab gifts from moving belts and pack them as fast as you can. It's simple: gifts come in, you pack them up, and together we make sure Christmas is ready to go!\n\nThe game is easy to play but can get pretty zippy, like reindeer on a gingerbread sugar rush. But hey, that's part of the fun! It's all about quick hands, a sharp eye, and a heart full of holiday spirit.\n\nNo scores, no timers, just you saving the day one gift at a time. There's also a personal gift shop for you to treat yourself to some home decoration, like a lovely Christmas tree! So, what do you say? Grab your Quest and make some room \u2014 let's see those present-packing skills in action!\n\nCheers and chuckles,\nSanta \ud83c\udf85\u2728", "short_description": "Ho Ho Ho! It's Santa here, and I've got a big Christmas challenge for you! My workshop's a bit of a mess, and presents are popping out all over the place \u2014 right into your house!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fieldof.vision/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Field Of Vision", "support_website_url": null, "website_url": "https://fieldof.vision/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8613149422114127"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036619_867445814845630_2123567116826215072_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vUmxE9JHyZ0Q7kNvgFX-5Vx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDTxW6gyWnA5xs07VhuatLk7PzVfj8-DOAlccMaJ6F0vw&oe=6786451D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Santa's Conveyor Chaos", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1701360000, "lastRevision": {"nodes": [{"id": "6691893050906450", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6691893034239785", "is_first_party": false, "enables_in_ap