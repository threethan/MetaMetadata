UPoCdYSviw6NZ9SJWalqC53fTQtDg&oe=67792BFA"}, "display_name": "VRGym", "keywords": [], "long_description": "Workout Modes:\n1. Battle Rope Play Exercise: Engage in an intense arm and core workout by \n    virtually swinging battle ropes in different patterns.\n\n2. Sandbag Boxing Exercise: Combine virtual sandbag boxing with real \n    punching techniques to improve your boxing skills and fitness levels.\n\n3. Reaction Metal Balls: Improve your reaction time and agility by hitting \n    random virtual metal balls that appear in quick succession.\n\nOperation:\nThe interface is user-friendly, allowing users to start the workout by simply pressing the Start button.\nEach workout session lasts two minutes, after which users can switch to another mode.\nThis app blends efficient exercise with a gaming experience through virtual and hybrid reality, making it suitable for fitness and entertainment for a broad audience.", "short_description": "VRGym is an innovative fitness application offering both Virtual and Mixed Reality scenarios for users to engage in three different exercises."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ecom.iscom.sg/index.php?route=information%2Finformation&language=en-gb&information_id=3", "developer_terms_of_service_url": null, "publisher_name": "IS COM XR Apps Developer", "support_website_url": null, "website_url": "https://iscom.sg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported