25/39035421_543172160695967_4686024457388524508_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xjVTjqDm-mMQ7kNvgF5cbSn&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtTqi7wpJu7CSMCw7JuecxABulrpGC1CejsKCwaKL5Wg&oe=670E3E27"}, {"file_name": "vlcsnap-2022-05-11-22h13m29s843.png", "id": "1908519432671357", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982698_1908519436004690_5303259187601408640_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ByqssFq8x50Q7kNvgEQ0eJg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9nzFmIHB2H8lwL0kSOT9hjUZCy_TQZepGkyLAaJYDnw&oe=670E6FC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Min_2560x1440.png", "id": "689767128802899", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269300_689767135469565_3473535513870065346_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2EEBzr3ubQQ7kNvgH4R95k&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBL6HyKG63nPKxR_k1NoBFksyMgTSiApQ4lnI_WQM3CBQ&oe=670E6C0D"}, "display_name": "The Rhythm of the Knight", "keywords": [], "long_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music.\n\nFeatures :\n\n- Makes you feel epic - Deflect the shots like a jedi, slash your enemies, destroy walls with force impulse. You'll feel so powerful you won't want to stop.\n- Designed by hand levels - All the levels are hand crafted to be unique and fit each song.\n- Six stages declined in 3 difficulties to match the skills of everyone.\n- Improve your skill in a configurable training module and master your lightsaber.", "short_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-c