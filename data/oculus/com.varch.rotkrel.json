c_sid=6e7a0a&_nc_ohc=6pY8hY8TXowQ7kNvgEs9UaL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYBC7dXgW9WNCsHaGNbQqRk-6YfvccAXOPtywBAq8H9pqA&oe=66EABEEB"}, {"file_name": "vlcsnap-2022-05-11-22h20m42s592.png", "id": "543172157362634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_543172160695967_4686024457388524508_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BJuSiQ9LppUQ7kNvgHfQ6B6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYAZ76du61eqPSREKIoFyXlZu_vuQ-UU0UO0axibLbO8sQ&oe=66EAA5A7"}, {"file_name": "vlcsnap-2022-05-11-22h13m29s843.png", "id": "1908519432671357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_1908519436004690_5303259187601408640_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KfQxPVbuqXgQ7kNvgEr4oBa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYCCCVPHdR8coEXOFTzfnIZydvkuHaP6HbnValfsk6yFPg&oe=66EA9F09"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Min_2560x1440.png", "id": "689767128802899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_689767135469565_3473535513870065346_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5oE2YC4NooQ7kNvgH2U28N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYBf6toi_s-ixBS9LEwQml01AlGPq5cxrxbyXzb5rcSoZA&oe=66EAD38D"}, "display_name": "The Rhythm of the Knight", "keywords": [], "long_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music.\n\nFeatures :\n\n- Makes you feel epic - Deflect the shots like a jedi, slash your enemies, destroy walls with force impulse. You'll feel so powerful you won't want to stop.\n- Designed by hand levels - All the levels are hand crafted to be unique and fit each song.\n- Six stages declined in 3 difficulties to match the skills of everyone.\n- Improve your skill in a configurable training module and master your lightsaber.", "short_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.voxel-arch.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VArch", "support_website_url": null, "website_url": "https://rotk.voxel-arch.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "685131475926461"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5027696027336126", "version": "2.0"}, "id": "513430290195040", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4695358653903200", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5027696027336126"}, "release_status": "RELEASED"}, "binary_release_channels":