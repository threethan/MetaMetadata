37_8964138983681427924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jiyGtei_X2wQ7kNvgGo970k&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYCl-7tgp9tQpbVTET6rF-1ZkNm9LMsjOR9CTU0ymblc1A&oe=66F2A7EB"}, {"file_name": "vlcsnap-2022-05-11-22h20m42s592.png", "id": "543172157362634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_543172160695967_4686024457388524508_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jm-pw4jufmQQ7kNvgHOZhyu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYAUxcZDA0AoL_wBHRAVgr0mMk9LxumDlHyNka9BiDx7oQ&oe=66F28EA7"}, {"file_name": "vlcsnap-2022-05-11-22h13m29s843.png", "id": "1908519432671357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_1908519436004690_5303259187601408640_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wCXSyh-4qY0Q7kNvgG0dKUQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYBcinq1gM8a5kNzT9wBecy2CBDSu_RJS4AwPgZkxPHjYQ&oe=66F28809"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Min_2560x1440.png", "id": "689767128802899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_689767135469565_3473535513870065346_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUY9i_0R4HcQ7kNvgHhWvYj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYBCyS7YrdgPUXqFrmoKe-3WTOIVNjp_hyyK5Txi8S7P3A&oe=66F2BC8D"}, "display_name": "The Rhythm of the Knight", "keywords": [], "long_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music.\n\nFeatures :\n\n- Makes you feel epic - Deflect the shots like a jedi, slash your enemies, destroy walls with force impulse. You'll feel so powerful you won't want to stop.\n- Designed by hand levels - All the levels are hand crafted to be unique and fit 