T6rF-1ZkNm9LMsjOR9CTU0ymblc1A&oe=66F2A7EB"}, {"file_name": "vlcsnap-2022-05-11-22h20m42s592.png", "id": "543172157362634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_543172160695967_4686024457388524508_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jm-pw4jufmQQ7kNvgHOZhyu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYAUxcZDA0AoL_wBHRAVgr0mMk9LxumDlHyNka9BiDx7oQ&oe=66F28EA7"}, {"file_name": "vlcsnap-2022-05-11-22h13m29s843.png", "id": "1908519432671357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_1908519436004690_5303259187601408640_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wCXSyh-4qY0Q7kNvgG0dKUQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYBcinq1gM8a5kNzT9wBecy2CBDSu_RJS4AwPgZkxPHjYQ&oe=66F28809"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Min_2560x1440.png", "id": "689767128802899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_689767135469565_3473535513870065346_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUY9i_0R4HcQ7kNvgHhWvYj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYBCyS7YrdgPUXqFrmoKe-3WTOIVNjp_hyyK5Txi8S7P3A&oe=66F2BC8D"}, "display_name": "The Rhythm of the Knight", "keywords": [], "long_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music.\n\nFeatures :\n\n- Makes you feel epic - Deflect the shots like a jedi, slash your enemies, destroy walls with force impulse. You'll feel so powerful you won't want to stop.\n- Designed by hand levels - All the levels are hand crafted to be unique and fit each song.\n- Six stages declined in 3 difficulties to match the skills of everyone.\n- Improve your skill in a configurable training module and master your lightsaber.", "short_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.voxel-arch.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VArch", "support_website_url": null, "website_url": "https://rotk.voxel-arch.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "685131475926461"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_1065183851072473_6287303416542783360_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nSW_mR10bYgQ7kNvgH_Alv-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyyoOf6DvcoFfS6193acsCm&oh=00_AYDxnh1E1OXkn3HrLihCS7j_ooENxemSQjPi4hg3fOWfAQ&oe=66F2946F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Rhythm of the Knight", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1654035091, "lastRevision": {"nodes": [{"id": "719399849078770", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4695358653