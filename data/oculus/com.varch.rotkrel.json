NbQqRk-6YfvccAXOPtywBAq8H9pqA&oe=66EABEEB"}, {"file_name": "vlcsnap-2022-05-11-22h20m42s592.png", "id": "543172157362634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_543172160695967_4686024457388524508_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BJuSiQ9LppUQ7kNvgHfQ6B6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYAZ76du61eqPSREKIoFyXlZu_vuQ-UU0UO0axibLbO8sQ&oe=66EAA5A7"}, {"file_name": "vlcsnap-2022-05-11-22h13m29s843.png", "id": "1908519432671357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982698_1908519436004690_5303259187601408640_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KfQxPVbuqXgQ7kNvgEr4oBa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYCCCVPHdR8coEXOFTzfnIZydvkuHaP6HbnValfsk6yFPg&oe=66EA9F09"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Min_2560x1440.png", "id": "689767128802899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269300_689767135469565_3473535513870065346_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5oE2YC4NooQ7kNvgH2U28N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYBf6toi_s-ixBS9LEwQml01AlGPq5cxrxbyXzb5rcSoZA&oe=66EAD38D"}, "display_name": "The Rhythm of the Knight", "keywords": [], "long_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music.\n\nFeatures :\n\n- Makes you feel epic - Deflect the shots like a jedi, slash your enemies, destroy walls with force impulse. You'll feel so powerful you won't want to stop.\n- Designed by hand levels - All the levels are hand crafted to be unique and fit each song.\n- Six stages declined in 3 difficulties to match the skills of everyone.\n- Improve your skill in a configurable training module and master your lightsaber.", "short_description": "ROTK is a VR rhythm game based on your reflex and lightsaber skill.\n\nDeflect shots, slash projectiles, slash enemies, dodge obstacles, use your powers to break others. All this to the beat of a dark techno song in hand-crafted levels designed to match the music."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.voxel-arch.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VArch", "support_website_url": null, "website_url": "https://rotk.voxel-arch.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "685131475926461"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_1065183851072473_6287303416542783360_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TTqc-pGn12MQ7kNvgFZKR4b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfRbQxILE6bCXUePSkSkmwy&oh=00_AYCSu8tZ2C7GBg5y5YGXDymcDzOSjyXnZA7cm65iq4_wUw&oe=66EAAB6F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Rhythm of the Knight", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1654035091, "lastRevision": {"nodes": [{"id": "719399849078770", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4695358653903200", "is_first_party": false, "enables_in_app_a