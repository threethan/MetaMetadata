91089248181_5154468179816218624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d3DpUMBEXokQ7kNvgGOj6NU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZJnyv9ro9vU3x0F_K9VkgpVUZeATWHvvSSc46ZEhjHw&oe=675995B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/wbrxIT", "id": "302917347084383", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974583_302917350417716_8523960999525482496_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sCTrjKH1sS4Q7kNvgFI2zp4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChZwX8aOwk_MCZkWOcJTqOC0IAn23e-gvDgJTIZiyn-w&oe=6759618F"}, "display_name": "Marble Land", "keywords": ["puzzle", "physics", "casual"], "long_description": "Marble Land is a physics-based puzzle game that was designed primarily for VR. The purpose of the game is to guide a rolling marble on the correct path to its target destination by changing the configuration of the elements in the level. The game contains 45 levels of increasing difficulty, split across three different environments: the desert, the cave and the mountain. There is no time limit on the puzzles and you can try as many different approaches as you like in order to find the solution. Marble Land offers an immersive and comfortable experience that doesn\u2019t induce any VR motion sickness.", "short_description": "Marble Land is a physics-based VR puzzle game. The objective is to guide a marble into a designated target area by using various contraptions scattered across the level."}]}, "developer_name": "Devious Technologies", "developer_privacy_policy_url": "http://devioustech.com/privacy.html", "developer_terms_of_service_url": "http://devioustech.com/tos.html", "publisher_name": "Devious Technologies", "support_website_url": null, "website_url": "http://devioustech.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres"