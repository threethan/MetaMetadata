.5771-25/38982563_2051132501915741_2330309998337430645_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XPsUATk2w8cQ7kNvgF_WQoe&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnZaosWnv1Dx3pob80vlKCGju72aSFRdW14kXWz53hvA&oe=66F94FBE"}, {"file_name": "Screenshot 2.png", "id": "706887621445613", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974744_706887624778946_776466655587481436_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K3Qksw-DiioQ7kNvgFEzGp_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfmh17Men6e6-41HKzKoNes7-UWQ66Ey79gPsM3XWSlQ&oe=66F93B92"}, {"file_name": "Screenshot 4.png", "id": "854427776158253", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031600_854427779491586_8904541745359560062_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iOWsyIdxn6wQ7kNvgFPEQxJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvBgOedGHnLI3P1MN_sKBf56E6VRu6G9_qhWn0S1K_BA&oe=66F95132"}, {"file_name": "Screenshot 5.png", "id": "1329781061044074", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572945_1329781064377407_4796999962754259958_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ec-48wCajuEQ7kNvgGn_Aez&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSL1qhkVhf2Ftdpsm2XiItRgCFCGwDZ_IKQhol0BQG9w&oe=66F9394F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Swarm2_Meta_CoverImage_Landscape.png", "id": "672037128375486", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_672037131708819_6561405701581941803_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9CfB6DjalaMQ7kNvgEFs6xM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCx16gO55UadKoag1qBLRzR5PqeuE5wgY4SReLcVpUDGg&oe=66F94B7D"}, "display_name": "Swarm 2", "keywords": ["Spiderman", "Roguelike", "Roguelite", "Flying", "Shooter"], "long_description": "SWARM 2, the highly anticipated sequel to SWARM is an electrifying rogue-like shooter. \n\nWith epic new environments, intoxicating rogue-like progression, and globally competitive leaderboards - this is what VR is really made for!\n\n\nRECLAIM A WORLD OVERRUN\nAs Marv, the last surviving grapple commando, you\u2019ll use your trusty pistol and grappling hook to battle back the Swarm and save Earth - with style! - while growing stronger and unraveling more of the story with each unique mission to the surface. \n\nTRANSFORM INTO A LEGENDARY HERO\nWith Auggie's help, harness revolutionary Shard Tech to permanently upgrade your skills. Choose among dozens of perks to find the perfect combination and turn the tide of war.\n\nBUILT FOR REPLAYABILITY,\nEvery mission brings unexpected challenges as you navigate through the neon-lit ruins of Earth, now a constantly changing battleground. Each encounter with the Swarm is a unique experience, with tactics and strategies evolving to match your growing skills. \n\nSIGNATURE SMOOTH GRAPPLING SYSTEM\nSwarm\u2019s Signature Smooth Grappling System turns you into a dynamic pendulum; master the art of building momentum by swooping close to the ground and timing your swings to perfection. \n\nIntense. Demanding. Exhilarating.\n\nThis is SWARM 2.", "short_description": "SWARM 2, the highly anticipated sequel to SWARM is an electrifying rogue-like shooter. \n\nWith epic new environments, intoxicating rogue-like progression, and globally competitive leaderboards - this is what VR is really made for!\n\nIntense. Demanding. Exhilarating.\n\nThis is SWARM 2."}]}, "developer_name": "Greensky Games", "developer_privacy_policy_url": "https://www.swarm2vr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Greensky Games", "support_website_url": "https://www.swarm2vr.com/contact", "website_url": "https://www.greensky.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_conn