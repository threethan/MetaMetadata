", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982640_1234367867113507_6515706368886082053_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DJyBDqtusR8Q7kNvgFV-mNh&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDqOgCHsokCY3-sA4J4wX_YQ6TAG_M27CDwTMHGjHViHw&oe=6756F002"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "beyondreal trailer.png", "id": "1524969777995754", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974854_1524969781329087_1803815209289572873_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2BXgJjgvXsQ7kNvgEKsVih&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCmJFLZDzVuwkeWaz2OTmZHJYsp4fVaXQt5HeL63CRieg&oe=6756BFD5"}, "display_name": "Beyondreal", "keywords": [], "long_description": "Beyondreal virtual offices - a collaboration space for teams in stunning locations.\n\n- whiteboarding as an entire location, \n- photorealistic full-body avatars with face recognition: be yourself,  just  upload your picture,\n- increase your productivity: use multiple screens, 3D tools, stickers, \n- create smart maps, show products and enrich your workflow,\n- use your VR headset or invite others via standard video streaming tools,\n- record and stream from multiple cameras,\n- work in impressive and exciting locations and have engaging and productive meetings,\n- make the space your own: brand and save your meeting space and reuse it at anytime,\n- connect  to your team and plan activities: play basketball, chess, chat next to the fireplace or even visit an art exhibition\u2026\n\nBuild greater things and have a better communication in Beyondreal virtual offices, which do not just give you a place to work, but immerse you in a engaging workflow.", "short_description": "Beyondreal is an enterprise collaboration suite that allow you to:\n- whiteboard with ease, use your corporate tools or Beyondreal self made applications, \n- create a space that you can save and reuse with multiple screens, 3D tools, stickers and much more,\n- use your full photorealistic body avatar, and face recognition to give presentations, create smart maps, show products, or play basketball and just relax and chat with a friend at the campfire."}]}, "developer_name": null, "developer_privacy_policy_url": "https://beyondreal.life/privacy-policy/", "developer_terms_of_service_url": "https://beyondreal.life/terms-and-conditions/", "publisher_name": "Anasaea", "support_website_url": null, "website_url": "https://beyondreal.life/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "2687655338230691"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "732688938424113"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75240099_779432097095511_4736103183242242863_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WTywLwzmCwQ7kNvgExE4Zn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDVCVfMjdPyfBSH2WTlK8SPUKV0icN0PTTAnFfgUZ2Rgw&oe=6756D299"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Beyondreal", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Events", "id": "2687655338230691"}], "release_date":