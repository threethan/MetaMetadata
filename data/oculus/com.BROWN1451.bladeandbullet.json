om/v/t64.5771-25/75608435_803000231863632_7622821291718186613_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MvWsPigJZsoQ7kNvgHSdKNL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFTjqznLfz9-q4J_nONpkCtygq4Y7Lb4HVETuC4XXREw&oe=673F30C9"}, {"file_name": "3.png", "id": "1040595613580992", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982710_1040595616914325_7582154344866719136_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DQxu4KeEqssQ7kNvgFepw4B&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwkw6Rv394ghV5hyC7SWQOuX3SM1zDcW92ewsDKLS_NQ&oe=673F1B98"}, {"file_name": "2.png", "id": "494422933279312", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75443246_494422936612645_1880563353709562009_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTS0NDL45PsQ7kNvgF9RD3g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcGTYM21Wz65kFDxnrWhiDUdqzfz9PPLTjUIXGtg78Hw&oe=673F1F32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "997322675508817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974685_997322685508816_924110274691852915_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=68fGBM0dMO0Q7kNvgE9KMdQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD73XUK_YdGSm5FZ5oZA_NmPpVTkqt7RqgLL4QLmTYXWA&oe=673F0B20"}, "display_name": "Blade and Bullet", "keywords": [], "long_description": "In the heart of a neon-lit metropolis, where the lines between the ancient and the futuristic blur, chaos reigns. The city of Neo-Shinobi is under siege by powerful criminal syndicates and rogue AI. As the last surviving member of an ancient ninja clan, you are thrust into a battle for survival and justice. Armed with a katana and a high-tech gun, your mission in \"Blade and Bullet\" is to defend the city from relentless assaults and restore peace to Neo-Shinobi.\nKey Features\n\n1. Immersive VR Experience\n\n    Dive into the neon-drenched streets of Neo-Shinobi with stunning VR visuals. The high-fidelity graphics and realistic soundscapes create an unparalleled sense of immersion, making you feel as if you are truly in the midst of a cyberpunk dystopia.", "short_description": "Storyline\n\nIn the heart of a neon-lit metropolis, where the lines between the ancient and the futuristic blur, chaos reigns. The city of Neo-Shinobi is under siege by powerful criminal syndicates and rogue AI. As the last surviving member of an ancient ninja clan, you are thrust into a battle for survival and justice. Armed with a katana and a high-tech gun, your mission in \"Blade and Bullet\" is to defend the city from relentless assaults and restore peace to Neo-Shinobi.\nKey Features\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/blade-and-bullet/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "BROWN1451 Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/blade-and-bullet", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "644354873106712"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26123991423880865"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26242951428651530", "version": "1.0