le_name": "3.png", "id": "1040595613580992", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982710_1040595616914325_7582154344866719136_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u0lMJIDyeBgQ7kNvgHmQFs9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCfdaQXeqUrbTEHE7Zwy_QNjTmFLalrg--OSmVZqlHuQ&oe=66FA8D98"}, {"file_name": "2.png", "id": "494422933279312", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443246_494422936612645_1880563353709562009_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UApo0BsjG14Q7kNvgEaeYAy&_nc_ht=scontent.oculuscdn.com&oh=00_AYAu_Jhc8tgiCVc_fBn2B5CqGnb_k4YTs-yy43tHIAZcgA&oe=66FA9132"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "997322675508817", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_997322685508816_924110274691852915_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d-XuSWSqz54Q7kNvgHgBiO5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVKDhSjWAdBxO0h0T3pksjskuBGWDLwthTZbS7oirsBg&oe=66FA7D20"}, "display_name": "Blade and Bullet", "keywords": [], "long_description": "In the heart of a neon-lit metropolis, where the lines between the ancient and the futuristic blur, chaos reigns. The city of Neo-Shinobi is under siege by powerful criminal syndicates and rogue AI. As the last surviving member of an ancient ninja clan, you are thrust into a battle for survival and justice. Armed with a katana and a high-tech gun, your mission in \"Blade and Bullet\" is to defend the city from relentless assaults and restore peace to Neo-Shinobi.\nKey Features\n\n1. Immersive VR Experience\n\n    Dive into the neon-drenched streets of Neo-Shinobi with stunning VR visuals. The high-fidelity graphics and realistic soundscapes create an unparalleled sense of immersion, making you feel as if you are truly in the midst of a cyberpunk dystopia.", "short_description": "Storyline\n\nIn the heart of a neon-lit metropolis, where the lines between the ancient and the futuristic blur, chaos reigns. The city of Neo-Shinobi is under siege by powerful criminal syndicates and rogue AI. As the last surviving member of an ancient ninja clan, you are thrust into a battle for survival and justice. Armed with a katana and a high-tech gun, your mission in \"Blade and Bullet\" is to defend the city from relentless assaults and restore peace to Neo-Shinobi.\nKey Features\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/blade-and-bullet/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "BROWN1451 Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/blade-and-bullet", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26123991423880865"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1637575616785367"}]}, "baseline_offer": {"id": "1637575616785367"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721792370, "status": "PUBLISHED", "id": "1637575616785367"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26242951428651530", "version": "1.0"}, "id": "847502627256908", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "Andr