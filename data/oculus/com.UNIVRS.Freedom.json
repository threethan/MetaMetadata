43", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031530_990842675920576_2997217541020898258_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ipBEwA_TWj4Q7kNvgGCoQQT&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJPi1Jg_HV-5fd8r4zuDSVCI0bzW0ohKpjezcnckACHA&oe=66F69D97"}, {"file_name": "AOTVR_EA_Store_Screenshot_05.png", "id": "1466537183982433", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_1466537187315766_8033804177771505194_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0G5-I-OdfuQQ7kNvgH30XoU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRzPP1UcBmqAHY38wsjA24yNHoU2VblsrymGAD-rso1w&oe=66F6A367"}, {"file_name": "AOTVR_EA_Store_Screenshot_01.png", "id": "2215257825495772", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520134_2215257828829105_4328287129276342367_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ENhshGhZT2MQ7kNvgEluf2W&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfq719Nclo0-rK82s_BBWgGGQvTAvn6gYharkV1oYB2A&oe=66F69AA4"}, {"file_name": "AOTVR_EA_Store_Screenshot_02.png", "id": "1026008562272957", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035456_1026008568939623_8044874005300952786_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJsOhUkVx0EQ7kNvgH4CCJC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEwTJT5CH1fuhoIOTbvs53h7yyMQ4xMkRbfB-K9T82Jw&oe=66F6A2A5"}, {"file_name": "AOTVR_EA_Store_Screenshot_04.png", "id": "471362702166284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035352_471362705499617_9042510161505635150_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JFv2JjQGbaUQ7kNvgFwE_Vd&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZEPJpO8bWe50ZXQHj8ZxjqH5JOxLSQ2ZXp8iAS7Qjuw&oe=66F6A6D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FREEDOM_2560x1440_EarlyAccess_EN.png", "id": "3764424213828319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031584_3764424217161652_6681042915870702667_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8CxmK9muNEkQ7kNvgHg_rVh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbVyzzrH76wB1BgUY1bWjFPJMZiYf4Ow8pQnKfJAtsTg&oe=66F686FF"}, "display_name": "Attack on Titan VR: Unbreakable - Early Access", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "**Now available in Early Access!**\n---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n{1280368342833344}\nPrepare for combat with Omni-Directional Mobility Gear and fly head-first into battle! Defy all odds and eliminate the Titans!\n\nAttack on Titan VR: Unbreakable, the first-person action-adventure VR platformer based on the highly acclaimed manga \u201cAttack on Titan\u201d and the latest installment of the VR series. \n\n\n\nJoin the Scout Regiment as an aspiring recruit and help defend mankind from the Titan invasion.\n\n\n# Omni-Directional Mobility Gear\nUtilize the Omni-Directional Mobility Gear to maneuver through the air and combat the onslaught of Titans! \n{1195760871453526}\n\n\n# The Titan Threat\nTitans rely on their instincts to hunt humans and satisfy their insatiable appetites.\nOvercome the fear of death and lay waste to the Titan army!\n{1042373100565202}\n\n\n# Distinct Weapons\nEach weapon offers unique characteristics that can alter the course of battle and how it is approached!\n{469443659357575}\n\n\n\n# Roadmap\n{1529176934658114}\nEarly Access will consist of the first two chapters.\nThere will also be free update support through Early Access and 1.0.\nThe second half of the campaign and mulit-player co-op support will release alongside 1.0 later in 2024.\n\n\n\u00a9 Hajime Isayama / Kodansha Ltd. \u00a9 UNIVRS, Inc.\n", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni-Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": "https://univrs.jp/terms-of-use/", "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26205780399037672"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974567_8775185002498651_1786863801430242365_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIRqlwqGaYkQ7kNvgHkxsln&_nc_ht=scontent.oculuscdn.com&oh=00_AYCM-ZEnBXCHk70US0VWqtSMKUcGEtulAe6dC6eHFVsFIQ&oe=66F6AD51"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Attack on Titan VR: Unbreakable - Early Access", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Flying", "id": "388572352490011"}], "release_date": 1721746800, "lastRevision": {"nodes": [{"id": "2862578270719706", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "