-iad3-1.oculuscdn.com/v/t64.5771-25/38982470_522080740331918_7013171494774244989_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=miHt99bjxUMQ7kNvgHdtx9c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAL5YXSIbYdZtwyHtoucJR957bGhhM5Xwt0mjJDq4GPsg&oe=674841A2"}]}, "id": "1729016941167988", "locale": "en_US", "screenshots": [{"file_name": "AOTVR_EA_Store_Screenshot_03.png", "id": "990842672587243", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031530_990842675920576_2997217541020898258_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5njnYOF-L_EQ7kNvgFJrKhZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgdrAwpsn05PpUSTBbjhr6vFYb2Sda2G8taQ7i8xWYKg&oe=67485A97"}, {"file_name": "AOTVR_EA_Store_Screenshot_05.png", "id": "1466537183982433", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974685_1466537187315766_8033804177771505194_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eco_SeCjBAUQ7kNvgEXx0Wz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPWvW-vykbJciPdDi-HgmPNtYForAK0oQC-p0_RRT8kg&oe=67486067"}, {"file_name": "AOTVR_EA_Store_Screenshot_01.png", "id": "2215257825495772", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75520134_2215257828829105_4328287129276342367_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P-yJur6ljiwQ7kNvgEMVvez&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDv_LQ_jm84ehrL1vzEi0nMQ8dyTbwDCHLs-0VOVqzmzQ&oe=674857A4"}, {"file_name": "AOTVR_EA_Store_Screenshot_02.png", "id": "1026008562272957", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035456_1026008568939623_8044874005300952786_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nHtGnIgMTLcQ7kNvgF-x1XZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBc-n4epDfhmkN3teHF6dAZLl9Gvp3NpxcTgUzn3cCX1g&oe=67485FA5"}, {"file_name": "AOTVR_EA_Store_Screenshot_04.png", "id": "471362702166284", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035352_471362705499617_9042510161505635150_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ufzIo0tQM0Q7kNvgFDJj6r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDf6j-vvYt6f9Ru9KMbYmzlqLFFxPKxvT49GSHs3BXdww&oe=674863D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FREEDOM_2560x1440_EN.png", "id": "1094041468789844", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035308_1094041472123177_4489883078141673961_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-i4Kw2gg7IQ7kNvgEdS3ms&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDuEK2iWTEP6DBS5QAhPrBA2fxiJ0VKCZLwSQ9OTm_xSA&oe=674852AB"}, "display_name": "Attack on Titan VR: Unbreakable", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n{1280368342833344}\nPrepare for combat with Omni-Directional Mobility Gear and fly head-first into battle! Defy all odds and eliminate the Titans!\n\nAttack on Titan VR: Unbreakable, the first-person action-adventure VR platformer based on the highly acclaimed manga \u201cAttack on Titan\u201d and the latest installment of the VR series. \n\n\n\nJoin the Scout Regiment as an aspiring recruit and help defend mankind from the Titan invasion.\n\n\n# Omni-Directional Mobility Gear\nUtilize the Omni-Directional Mobility Gear to maneuver through the air and combat the onslaught of Titans! \n{1195760871453526}\n\n\n# The Titan Threat\nTitans rely on their instincts to hunt humans and satisfy their insatiable appetites.\nOvercome the fear of death and lay waste to the Titan army!\n{1042373100565202}\n\n\n# Distinct Weapons\nEach weapon offers unique characteristics that can alter the course of battle and how it is approached!\n{469443659357575}\n\n\n\n# Roadmap\n{1529176934658114}\nThe current version consist of the first two chapters.\nThe second half of the campaign and mulit-player co-op support will release alongside 1.0 later in 2024.\n\n\n\u00a9 Hajime Isayama / Kodansha Ltd. \u00a9 UNIVRS, Inc.\n", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni-Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": "https://univrs.jp/terms-of-use/", "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26755143367434703"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974456_1234320757838953_3010482075072307363_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B4r1RzSJNRcQ7kNvgHcxtGV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAzeI_uInl27n9fNYTeXFaVwm-zfHPBj3vv8962Ah2WjA&oe=67484BD4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Attack on Titan VR: Unbreakable", "platf