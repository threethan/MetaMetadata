n.com/v/t64.5771-25/38974826_202173989290229_1891626494795887815_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GzKrJrW-2oMQ7kNvgE4k19n&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCf2Q0J3pINcxy8Dkk4ifZxdhqz5d63p4J9Yqyzu3rZAg&oe=67430833"}, {"file_name": "ss_2560x1440px_EN03.png", "id": "1622609694896483", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982539_1622609698229816_6033631396183468683_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HVWMpHUUCwYQ7kNvgF7voRa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAW_vR4GqJN0Ie5l5zcUdULtbl0hB_2EeFpVoDCZi9zwA&oe=67431799"}, {"file_name": "ss_2560x1440px_EN04.png", "id": "1184521208904946", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_1184521212238279_2189773883167472246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O0OH15bUwxgQ7kNvgF8Ffhl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLqUNtK2-IAF5ynr14rEFT4KPvuOIZXIDGknjKLHoEJw&oe=6742FB88"}, {"file_name": "ss_2560x1440px_EN05.png", "id": "612034144312016", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035367_612034147645349_1842494341011147337_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qc24hcFdngYQ7kNvgHu_POt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn6-UwCn4DoZTkyVPichkBeolk_LRxs3Zy_iC9YU6XFw&oe=67431FD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u3010\u82f1\u8a9e \u5b8c\u6210\u7248 \u6a2a\u3011\u30e1\u30a4\u30f3\u30d2\u3099\u30b7\u3099\u30e5\u30a2\u30eb.png", "id": "762478728591491", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982441_762478731924824_3731905345530924161_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3KYPeCjHbosQ7kNvgFJQUJ9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwqZZc4wmyNiiTgYhqJRCVyU7UagkeMfMpSIZKY4q18w&oe=674312F9"}, "display_name": "Attack on Titan VR: Unbreakable", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\nFeatures:\n\nExhilarating Flight Experience: Get ready for a unique adventure with UNIVRS\u2019 anti-motion sickness technology that will help bring the thrilling cross-range combat against killer Titans to life.\n\nMultiplayer: Team up with another member of the Scout Regiment in two-player co-op or go solo in the fight for humanity. \n\nDevise a strategy: There will be a number of enemies out to get you. With a wider range of weapons at your disposal, devise and execute the best plan to cut down the Titan population in the city.\n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc.", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_