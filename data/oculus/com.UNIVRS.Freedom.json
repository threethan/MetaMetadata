kQ7kNvgHc_xnv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AojJMG4Sc_9TgHfl2EdvCOS&oh=00_AYDmZ5ccItjR2aNXPuY4d7op-RxMAK3YAHQKveBdKNV5Bw&oe=66F2AE25"}, {"file_name": "AOTVR_EA_Store_Screenshot_04.png", "id": "471362702166284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035352_471362705499617_9042510161505635150_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PiW_xCjblO0Q7kNvgETMxjX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AojJMG4Sc_9TgHfl2EdvCOS&oh=00_AYDjXqoScqe8cU9PhoTBq6LfuUBqkhvgNWc9FIQeBVf02Q&oe=66F2B255"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FREEDOM_2560x1440_EarlyAccess_EN.png", "id": "3764424213828319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031584_3764424217161652_6681042915870702667_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xVnRDC2OiIMQ7kNvgFDwwpF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AojJMG4Sc_9TgHfl2EdvCOS&oh=00_AYD0RK4E6EBqDh-iOzF2nc8jrwuapwrXXoD57ij44sgHyA&oe=66F2927F"}, "display_name": "Attack on Titan VR: Unbreakable - Early Access", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "**Now available in Early Access!**\n---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n{1280368342833344}\nPrepare for combat with Omni-Directional Mobility Gear and fly head-first into battle! Defy all odds and eliminate the Titans!\n\nAttack on Titan VR: Unbreakable, the first-person action-adventure VR platformer based on the highly acclaimed manga \u201cAttack on Titan\u201d and the latest installment of the VR series. \n\n\n\nJoin the Scout Regiment as an aspiring recruit and help defend mankind from the Titan invasion.\n\n\n# Omni-Directional Mobility Gear\nUtilize the Omni-Directional Mobility Gear to maneuver through the air and combat the onslaught of Titans! \n{1195760871453526}\n\n\n# The Titan Threat\nTitans rely on their instincts to hunt humans and satisfy their insatiable appetites.\nOvercome the fear of death and lay waste to the Titan army!\n{1042373100565202}\n\n\n# Distinct Weapons\nEach weapon offers unique characteristics that can alter the course of battle and how it is approached!\n{469443659357575}\n\n\n\n# Roadmap\n{1529176934658114}\nEarly Access will consist of the first two chapters.\nThere will also be free update support through Early Access and 1.0.\nThe second half of the campaign and mulit-player co-op support will release alongside 1.0 later in 2024.\n\n\n\u00a9 Hajime Isayama / Kodansha Ltd. \u00a9 UNIVRS, Inc.\n", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni-Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": "https://univrs.jp/terms-of-use/", "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26205780399037672"}, "revi