00_AYAyFGLUGJtQktoxPy__ryBQX9LSPAEwjHVUjyMfVWBKMQ&oe=67680199"}, {"file_name": "ss_2560x1440px_EN04.png", "id": "1184521208904946", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_1184521212238279_2189773883167472246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2_qujvXpUAMQ7kNvgH8PZns&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBeTbMqci6X0ujHpldpfJvML6Fh8n-TJ5rChAPNjSDpew&oe=6767E588"}, {"file_name": "ss_2560x1440px_EN05.png", "id": "612034144312016", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035367_612034147645349_1842494341011147337_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gtOcE-iAalMQ7kNvgFYxxq6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLR3wag_LynWyKZZI9HLx768BZQCTAtUAWNkouSp-AMw&oe=676809D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u3010\u82f1\u8a9e \u5b8c\u6210\u7248 \u6a2a\u3011\u30e1\u30a4\u30f3\u30d2\u3099\u30b7\u3099\u30e5\u30a2\u30eb.png", "id": "762478728591491", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982441_762478731924824_3731905345530924161_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZEygisnfcCQQ7kNvgG1l_f4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsNwK8yOXmHYsu3xtsUAt8XqkJhM22ZVBlek9DjCn3vw&oe=6767FCF9"}, "display_name": "Attack on Titan VR: Unbreakable", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\nFeatures:\n\nExhilarating Flight Experience: Get ready for a unique adventure with UNIVRS\u2019 anti-motion sickness technology that will help bring the thrilling cross-range combat against killer Titans to life.\n\nMultiplayer: Team up with another member of the Scout Regiment in two-player co-op or go solo in the fight for humanity. \n\nDevise a strategy: There will be a number of enemies out to get you. With a wider range of weapons at your disposal, devise and execute the best plan to cut down the Titan population in the city.\n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc.", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "SINGLE_USER", "MULTI_USER"], "id": "279794847557331"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1602220677334089"}, {"status": "PUBLISHED", "id": "483082747635808"}, {"status": "PUBLISHED", "id": "9586207628059270"}]}, "baseline_offer": {"id": "1602220677334089"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734447600, "status": "PUBLISHED", "id": "1602220677334089"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27864728269809535", "version": "1.0.2207"}, "id": "248404610529705", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103719433003732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27864728269809535"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734461545, "id": "27869700825978946", "version": "1.0.2210", "version_code": 2210, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27869669812648714"}, "asset_files": {"count": 16}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103719433003732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27864728269809535"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734450984, "id": "27868370872778608", "version": "1.0.2209", "version_code": 2209, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27868342142781481"}, "asset_files": {"count": 16}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103719433003732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27864728269809535"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734443867, "id": "27867442229538139", "version": "1.0.2208", "version_code": 2208, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27867408919541470"}, "asset_files": {"count": 16}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103719433003732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27864728269809535"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "248404610529705"}]}, "change_log": "\u2694\ufe0f Ver.1.0 & Part 2 Now Live! Join Co-op Battles and Face the Armored Titan! \u2694\ufe0f\n\nWe are thrilled to announce that Attack on Titan VR: Unbreakable has officially launched Ver.1.0, and Part 2 is now live! Fight alongside friends in the all-new Co-op Multiplayer Mode and experience epic new chapters.\n\nWhat\u2019s Included in Part.2:\n\n- \ud83d\udca5Later Chapters of Campaign Mode\nExperience Chapter 3, Chapter 4, and the Epilogue, including the intense Armored Titan boss battle.\n\n- \ud83d\udc65Co-op Mode\nJoin forces with another player in Co-op Mode to take on every chapter together, whether it\u2019s a friend or someone from across the globe.\n\n- \ud83d\udd25Survival Mode\nTest your limits in Survival Mode\u2014defeat 100 Titans and prove you're among the elite Scouts!\n\n- \u2694\ufe0fNew Weapons\nUnlock and master new weapons to diversify your tactics and elevate your combat prowess.\n\nEach chapter is packed with multiple missions, offering unique challenges as you fight for survival in a world dominated by towering Titans. Whether you\u2019re battling solo or teaming up with others, every mission tests your strategy, reflexes, and courage!\n\nAdditionally, the Thunder Spear Unlock Event is on the horizon\u26a1\ufe0f\nJoin forces with Scouts from around the world and prepare to take on this global challenge\ud83c\udf0e\ufe0f\n\n\ud83d\udd14 Note: To play Part 2, please purchase the add-on \"Attack on Titan VR: Unbreakable - Part.2\".\n\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\u30fc\n\u2694\ufe0fVer.1.0 & Part.2 \u914d\u4fe1\u958b\u59cb\uff01\u2694\ufe0f\n\n\u300e\u9032\u6483\u306e\u5de8\u4ebaVR: Unbreakable\u300f\u304c\u6b63\u5f0f\u30ea\u30ea\u30fc\u30b9\u3068\u306a\u308a\u3001\u5f85\u671b\u306eVer.1.0\u3068Part.2\u304c\u914d\u4fe1\u958b\u59cb\u3057\u307e\u3057\u305f\uff01\u4ef2\u9593\u3068\u5171\u306b\u5de8\u4eba\u306b\u7acb\u3061\u5411\u304b\u3046\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30e2\u30fc\u30c9\u304c\u3064\u3044\u306b\u767b\u5834\u3067\u3059\uff01\n\nPart.2 \u306b\u542b\u307e\u308c\u308b\u5185\u5bb9\uff1a\n\n- \ud83d\udca5\u30ad\u30e3\u30f3\u30da\u30fc\u30f3\u30e2\u30fc\u30c9\u5f8c\u534a\n\u7b2c3\u7ae0\u3001\u7b2c4\u7ae0\u3001\u30a8\u30d4\u30ed\u30fc\u30b0\u3092\u4f53\u9a13\u3002\u93a7\u306e\u5de8\u4eba\u3068\u306e\u58ee\u5927\u306a\u30dc\u30b9\u6226\u3082\u53ce\u9332\u3002\n\n- \ud83d\udc65\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30e2\u30fc\u30c9\n\u30d5\u30ec\u30f3\u30c9\u3084\u4e16\u754c\u4e2d\u306e\u30d7\u30ec\u30a4\u30e4\u30fc\u3068\u30aa\u30f3\u30e9\u30a4\u30f3\u5354\u529b\u30d7\u30ec\u30a4\u3067\u5de8\u4eba\u306b\u6311\u3080\u3053\u3068\u304c\u53ef\u80fd\u306b\u3002\n\n- \ud83d\udd25\u30b5\u30d0\u30a4\u30d0\u30eb\u30e2\u30fc\u30c9\n\u6975\u9650\u72b6\u614b\u3067\u306e\u751f\u5b58\u3092\u76ee\u6307\u3059\u65b0\u30e2\u30fc\u30c9\u306b\u6311\u6226\u3002\n\n- \u2694\ufe0f\u65b0\u3057\u3044\u6b66\u5668\n\u6226\u7565\u3092\u5e83\u3052\u308b\u65b0\u305f\u306a\u6b66\u5668\u304c\u767b\u5834\u3002\n\n\u5404\u7ae0\u306b\u306f\u8907\u6570\u306e\u30df\u30c3\u30b7\u30e7\u30f3\u304c\u7528\u610f\u3055\u308c\u3066\u304a\u308a\u3001\u5de8\u4eba\u306b\u652f\u914d\u3055\u308c\u305f\u4e16\u754c\u3067\u306e\u751f\u5b58\u3092\u304b\u3051\u305f\u591a\u5f69\u306a\u6311\u6226\u304c\u5f85\u3063\u3066\u3044\u307e\u3059\u3002\u4e00\u4eba\u3067\u6311\u3080\u304b\u3001\u8ab0\u304b\u3068\u5354\u529b\u3059\u308b\u304b\u306b\u95a2\u308f\u3089\u305a\u3001\u5168\u3066\u306e\u30df\u30c3\u30b7\u30e7\u30f3\u304c\u3042\u306a\u305f\u306e\u6226\u7565\u3001\u53cd\u5c04\u795e\u7d4c\u3001\u305d\u3057\u3066\u52c7\u6c17\u3092\u8a66\u3057\u307e\u3059\uff01\n\n\u3055\u3089\u306b\u3001\u300c\u96f7\u69cd\u89e3\u653e\u30a4\u30d9\u30f3\u30c8\u300d\u304c\u8fd1\u65e5\u767b\u5834\u4e88\u5b9a\u26a1\ufe0f\n\u4e16\u754c\u4e2d\u306e\u8abf\u67fb\u5175\u56e3\u54e1\u3068\u529b\u3092\u5408\u308f\u305b\u3001\u30b0\u30ed\u30fc\u30d0\u30eb\u30c1\u30e3\u30ec\u30f3\u30b8\u306b\u6311\u307f\u307e\u3057\u3087\u3046\uff01\n\n\ud83d\udd14 \u3054\u6ce8\u610f: Part.2 \u3092\u30d7\u30ec\u30a4\u3059\u308b\u306b\u306f\u3001\u30a2\u30c9\u30aa\u30f3\u300c\u9032\u6483\u306e\u5de8\u4ebaVR: Unbreakable - Part.2\u300d\u306e\u8cfc\u5165\u304c\u5fc5\u8981\u3067\u3059\u3002", "created_date": 1734422830, "id": "27864728269809535", "version": "1.0.2207", "version_code": 2207, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27864698209812541"}, "asset_files": {"count": 16}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103719433003732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27864728269809535"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1734418532, "id": "27864220736526955", "version": "1.0.2206", "version_code": 2206, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "27864196009862761"}, "asset_files": {"count": 16}, "debug