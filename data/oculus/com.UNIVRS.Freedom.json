60x1440px_EN04.png", "id": "1184521208904946", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_1184521212238279_2189773883167472246_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CJIrZOFSo4MQ7kNvgGHZhtS&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQ5NnelxzpJSv3MOm-kmxhHF-UB4QvGoMavVB37OsjBQ&oe=6708F988"}, {"file_name": "ss_2560x1440px_EN05.png", "id": "612034144312016", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035367_612034147645349_1842494341011147337_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YK8Bt_4LetwQ7kNvgFvQUqp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBifjoQuOsnbDM1vYmzU3E2BuPiXyb_kRlSTTJBNtG8g&oe=67091DD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u3010\u82f1\u8a9e \u5b8c\u6210\u7248 \u6a2a\u3011\u30e1\u30a4\u30f3\u30d2\u3099\u30b7\u3099\u30e5\u30a2\u30eb.png", "id": "762478728591491", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982441_762478731924824_3731905345530924161_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aaWNDH4K9RsQ7kNvgEPOR_M&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoOk2_B8pJk1P3wsr_rOQ_J5-t-FplzJceRvs8jElS6A&oe=670910F9"}, "display_name": "Attack on Titan VR: Unbreakable", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\nFeatures:\n\nExhilarating Flight Experience: Get ready for a unique adventure with UNIVRS\u2019 anti-motion sickness technology that will help bring the thrilling cross-range combat against killer Titans to life.\n\nMultiplayer: Team up with another member of the Scout Regiment in two-player co-op or go solo in the fight for humanity. \n\nDevise a strategy: There will be a number of enemies out to get you. With a wider range of weapons at your disposal, devise and execute the best plan to cut down the Titan population in the city.\n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc.", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "SINGLE_USER", "MULTI_USER"], "id": "279794847557331"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "483082747635808"}]}, "baseline_offer": {"id": "483082747635808"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721746800, "status": "PUBLISHED", "id": "483082747635808"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26203989329216779", "version": "0.1.1726"}, "id": "248404610529705", "channel_name":