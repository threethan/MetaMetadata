587243", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031530_990842675920576_2997217541020898258_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pv5VWwpilIEQ7kNvgFAteHA&_nc_ht=scontent.oculuscdn.com&oh=00_AYAy8BMMTGWJO76b3gG5JY89KFvC0UTkXXINhKQTXFbw5Q&oe=66D99C97"}, {"file_name": "AOTVR_EA_Store_Screenshot_05.png", "id": "1466537183982433", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974685_1466537187315766_8033804177771505194_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=StEWV18P_acQ7kNvgHzXcJk&_nc_ht=scontent.oculuscdn.com&oh=00_AYApOoGY8hHGFMB41q8QL2jp1PpGmeKCIL_gHmweVJXE3w&oe=66D9A267"}, {"file_name": "AOTVR_EA_Store_Screenshot_01.png", "id": "2215257825495772", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520134_2215257828829105_4328287129276342367_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77heZNGzX5EQ7kNvgGbxMFv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVp_yzCvT8OTAUlJILDLwI4F-CNyKaEoUtZ2avFivYFQ&oe=66D999A4"}, {"file_name": "AOTVR_EA_Store_Screenshot_02.png", "id": "1026008562272957", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035456_1026008568939623_8044874005300952786_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XbNZnvpvb9MQ7kNvgGQ6biw&_nc_ht=scontent.oculuscdn.com&oh=00_AYBabGa94eTdhajDogp9q9-pC2NwhkSd2CH9NRRQ6VyDag&oe=66D9A1A5"}, {"file_name": "AOTVR_EA_Store_Screenshot_04.png", "id": "471362702166284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035352_471362705499617_9042510161505635150_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QI2jfM9qJh4Q7kNvgGkGS8T&_nc_ht=scontent.oculuscdn.com&oh=00_AYDOKfvl25p8AnGOkugbkaiLFDF0g_NEAzuyLuo17giPpQ&oe=66D9A5D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FREEDOM_2560x1440_EarlyAccess_EN.png", "id": "3764424213828319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031584_3764424217161652_6681042915870702667_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3KF-mEdWdu0Q7kNvgE5Mcu2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDedIetysMhYofiD15xVQ7tP8YTeDKNFkQ59EOPGXh2DA&oe=66D985FF"}, "display_name": "Attack on Titan VR: Unbreakable - Early Access", "keywords": ["AttackonTitan", "AoT", "Shingeki", "Action", "Hunting"], "long_description": "**Now available in Early Access!**\n---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------\n{1280368342833344}\nPrepare for combat with Omni-Directional Mobility Gear and fly head-first into battle! Defy all odds and eliminate the Titans!\n\nAttack on Titan VR: Unbreakable, the first-person action-adventure VR platformer based on the highly acclaimed manga \u201cAttack on Titan\u201d and the latest installment of the VR series. \n\n\n\nJoin the Scout Regiment as an aspiring recruit and help defend mankind from the Titan invasion.\n\n\n# Omni-Directional Mobility Gear\nUtilize the Omni-Directional Mobility Gear to maneuver through the air and combat the onslaught of Titans! \n{1195760871453526}\n\n\n# The Titan Threat\nTitans rely on their instincts to hunt humans and satisfy their insatiable appetites.\nOvercome the fear of death and lay waste to the Titan army!\n{1042373100565202}\n\n\n# Distinct Weapons\nEach weapon offers unique characteristics that can alter the course of battle and how it is approached!\n{469443659357575}\n\n\n\n# Roadmap\n{1529176934658114}\nEarly Access will consist of the first two chapters.\nThere will also be free update support through Early Access and 1.0.\nThe second half of the campaign and mulit-player co-op support will release alongside 1.0 later in 2024.\n\n\n\u00a9 Hajime Isayama / Kodansha Ltd. \u00a9 UNIVRS, Inc.\n", "short_description": "Fight for your life against man-eating Titans in Attack on Titan VR: Unbreakable. In a thrilling mix of hunting and action, join the Scout Regiment and put on your Omni-Directional Mobility Gear to defend and protect humanity against the Titans. \n\n\u00a9 Hajime Isayama / Kodansha Ltd.   \u00a9 UNIVRS, Inc."}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://univrs.jp/privacy-policy/", "developer_terms_of_service_url": "https://univrs.jp/terms-of-use/", "publisher_name": "UNIVRS, Inc.", "support_website_url": null, "website_url": "https://aotvrub.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26205780399037672"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974567_8775185002498651_1786863801430242365_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fR0cmrsn58IQ7kNvgEVDGIx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCuwA4uAQTsRVTAP-woxoDTxWy_1AKKVV_xlE22X6RkMg&oe=66D9AC51"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Attack on Titan VR: Unbreakable - Early Access", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Flying", "id": "388572352490011"}], "release_date": 1721746800, "lastRevision": {"nodes": [{"id": "2862578270719706", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale