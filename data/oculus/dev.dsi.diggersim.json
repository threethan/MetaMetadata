ntrols, you'll feel like you're really operating heavy machinery. In this game, you'll be tasked with completing a variety of excavation jobs, from digging foundations to clearing land. You'll have to carefully manoeuvre your excavator through tight spaces and navigate around obstacles to complete the level. As you progress through the game, you'll have challenges that will test your skills and abilities. With immersive gameplay and realistic controls, \"DiggerSim\" is the ultimate experience for fans of construction and heavy machinery. So put on your hard hat and get ready to dig in!", "short_description": "Virtual reality Excavator & Heavy Equipment Simulator for Oculus Quest"}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydiggersim.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Dreamsoft Innovations", "support_website_url": null, "website_url": "https://mydiggersim.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8116547131693099"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "3410681335902144"}, {"status": "PUBLISHED", "id": "385659157697381"}]}, "baseline_offer": {"id": "3410681335902144"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729070940, "status": "PUBLISHED", "id": "3410681335902144"}]}, "liveChannel": {"nodes": [{"latest_supporte