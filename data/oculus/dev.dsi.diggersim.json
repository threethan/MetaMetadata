074312432297003_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6P1yPIgC03UQ7kNvgEPGzmg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC08QA-9J6JMQ_fscQxVzEWYBGOKgLmp8kN4x1yzR0CAA&oe=672225E0"}, {"file_name": "Screenshot3.png", "id": "725559013025455", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031513_725559016358788_1147664398361415793_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9IAROpYoQkMQ7kNvgFSfSCM&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXLsJvbviZO43VFr2OVSglWLU0NYSjZoTwpCNRxymNlA&oe=67220A2C"}, {"file_name": "Screenshot4.png", "id": "1634716480603761", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469622_1634716483937094_8892917174639453908_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UNgQQhHdppwQ7kNvgFb1Ybx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJbgoJ13UJIfqj6DpAmNz02MgE5aJC79WSNYoD5DghaA&oe=67222573"}, {"file_name": "Screenshot5.png", "id": "1557636064811119", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75355156_1557636068144452_8966300487237368107_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OCbhEuE25nUQ7kNvgGssyvx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6opjPP8A3Py1Y23AzP5Jm3yS9XOY7Bq49ifeXAsYFRQ&oe=67221139"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandScape.png", "id": "844161867746207", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974692_844161871079540_4176021455143514163_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTiLX5cvMxsQ7kNvgF0_mzY&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvnLB5Ct1v8I7nkeQEGM5mOIMG2st4fFcSncBexzmhBg&oe=67221788"}, "display_name": "DiggerSim - Excavator & Heavy Equipment Simulator VR", "keywords": [], "long_description": "\"DiggerSim\" is a thrilling excavator and heavy equipment simulator that puts you in the driver's seat of a powerful excavator. With realistic controls, you'll feel like you're really operating heavy machinery. In this game, you'll be tasked with completing a variety of excavation jobs, from digging foundations to clearing land. You'll have to carefully manoeuvre your excavator through tight spaces and navigate around obstacles to complete the level. As you progress through the game, you'll have challenges that will test your skills and abilities. With immersive gameplay and realistic controls, \"DiggerSim\" is the ultimate experience for fans of construction and heavy machinery. So put on your hard hat and get ready to dig in!", "short_description": "Virtual reality Excavator & Heavy Equipment Simulator for Oculus Quest"}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydiggersim.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Dreamsoft Innovations", "support_website_url": null, "website_url": "https://mydiggersim.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8116547131693099"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "3410681335902144"}, {"status": "PUBLISHED", "id": "385659157697381"}]}, "baseline_offer": {"id": "3410681335902144"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729070940, "status": "PUBLISHED", "id": "3410681335902144"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9227226363958498", "version": "1.5.3"}