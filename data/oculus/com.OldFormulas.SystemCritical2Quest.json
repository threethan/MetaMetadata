s and fight bosses to progress. Expect a fun and addictive game that feels rewarding when you complete a difficult level. Experience the feeling of being a futuristic Cyborg in VR that strikes quickly and kills with deadly precision.", "short_description": "System Critical 2 is bigger & badder than ever before! Get ready to experience a platformer shooter like no other in VR. Blast your arm cannon and use guns, melee weapons, grenades,& shields to make your way through the carefully crafted levels with epic boss battles and tons of enemies to kill."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1xvZa8lDaZ6EqFPTYsS0ERTAbSm1_WTzR/edit?usp=sharing&ouid=103483450248593078910&rtpof=true&sd=true", "developer_terms_of_service_url": null, "publisher_name": "Old Formulas", "support_website_url": null, "website_url": "https://youtube.com/@RxPharmacytech", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "317201160755965"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "906216571338308"}, {"status": "PUBLISHED", "id": "498710396111245"}, {"status": "PUBLISHED", "id": "310477488753982"}, {"status": "PUBLISHED", "id": "932133727853140"}]}, "baseline_offer": {"id": "310477488753982"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730314800