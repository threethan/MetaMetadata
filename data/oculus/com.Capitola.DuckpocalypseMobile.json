ith the scrap you gathered from an annoying robot duck, and so this is how your duck hunt starts!\n\nDuckpocalypse is a VR arcade-style game made for the HTC Vive. Get in, grab your guns, take a second to let the new pixel world around you sink in, and then shoot that start button! Get on a fast paced challenge to bring down as many of those robot ducks as you can! Invite your friends over and see who can set the best score!", "short_description": "The most intense VR shooter you will ever play."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.vr.capitola.nl/", "developer_terms_of_service_url": "http://www.vr.capitola.nl/", "publisher_name": "Capitola VR", "support_website_url": null, "website_url": "http://www.vr.capitola.nl/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "ARCADE", "SHOOTER", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1341798126234463"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1834477123501996"}]}, "baseline_offer": {"id": "1834477123501996"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1487181600, "status": "PUBLISHED", "id": "1834477123501996"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1292741817465400", "version": "1.2"}, "id": "226132784482808", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinar