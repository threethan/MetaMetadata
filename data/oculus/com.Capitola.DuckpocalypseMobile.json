 best score!", "short_description": "The most intense VR shooter you will ever play."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.vr.capitola.nl/", "developer_terms_of_service_url": "http://www.vr.capitola.nl/", "publisher_name": "Capitola VR", "support_website_url": null, "website_url": "http://www.vr.capitola.nl/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "ARCADE", "SHOOTER", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1341798126234463"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1834477123501996"}]}, "baseline_offer": {"id": "1834477123501996"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1487181600, "status": "PUBLISHED", "id": "1834477123501996"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1292741817465400", "version": "1.2"}, "id": "226132784482808", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1264133353659580", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1292741817465400"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "226132784482808"}]}, "change_log": "Increased performance on S7 by various player settings, better meshes, performance manageme