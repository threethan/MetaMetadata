915520_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tICbivL2bboQ7kNvgFJMcI4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpKPC8aAFiRAE7whgWhMjnNO1c_XxHWwCr3M-tRR2d7w&oe=6784E6C2"}, {"file_name": "migrated_image.png", "id": "518362262389532", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031494_403097963744304_4587097094434586624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ubq_Xl8WCf8Q7kNvgFBRjsc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZne2QPpC2sR0OCjY6aLqxKE9tVWTypGgowCsYtzvj_A&oe=67850948"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/2WBUw9", "id": "572409526627746", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974693_572409533294412_7428283179816976384_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FRPu7_T4HtMQ7kNvgFXMwDA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7YdW9_QcwArKx2Gfjtk-oWQiEGgBJ9dk0xAU8Bc96pw&oe=67850702"}, "display_name": "Cave Digger: Riches", "keywords": ["Cave", "Digger", "Mine", "Western", "Adventure"], "long_description": "Features:\n-Explore the elevator shaft and four massive train levels full of mysteries, riches and strange happenings. Some fishy higher power seems to engulf the Frontier!\n\n-Build up the way to the mines by gearing up and upgrading your vehicle. But beware, the adventure can end in eight different ways depending on the actions and choices taken.\n\n-Meet a companion to help to carry the weight on your shoulders.\n\n-Go on a treasure hunt for hidden magical loot.\n\n-Item upgrades \u2013 technology advances in unimaginable ways, making mining more profitable!\n\n-28 achievements and more to come in free content updates.\n\nHow much riches will be enough? Will you be able to stop? What happens if you don\u2019t? The answers to these questions and more will be found as you dig deeper into the mines!", "short_description": "Cave Digger is a mining adventure game, which takes place in a small town of an alternative Western universe full of mystery, dark humor and full of experimental tools for the brave miners!\n\nGear up to explore the town and the depths of the mountain. Excavate bedrock with your hard swings, reap the rewards of Mother Earth and trade mined valuables for new gadgets. Outside of the saloon, a town in ruin awaits it\u2019s savior! Fix the train to enter the mines and dig deeper than any miner before you."}]}, "developer_name": "Mekiwi", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://vrkiwi.org/terms-conditions-privacy-policy/", "publisher_name": "Mekiwi", "support_website_url": "https://vrkiwi.org/bug-report/", "website_url": "https://vrkiwi.org/products/cave-digger-riches/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "238437518491334"}}]}, "scheduled_offers": {"count": 38, "nodes": [{"status": "PUBLISHED", "id": "1103002891830457"}, {"status": "PUBLISHED", "id": "3450013431966462"}, {"status": "PUBLISHED", "id": "1063070745188975"}, {"status": "CANCELLED", "id": "874132554531709"}, {"status": "PUBLISHED", "id": "832717625397292"}, {"status": "PUBLISHED", "id": "1627922984706372"}, {"status": "CANCELLED", "id": "748372472324450"}, {"status": "PUBLISHED", "id": "489838442571210"}, {"status": "CANCELLED", "id": "638779317323956"}, {"status": "PUBLIS