e3JnwdL1vYhA&oe=66CC5153"}, {"file_name": "migrated_image.png", "id": "141417287250823", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982445_302585133798528_6811045136126967808_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WnRGFKutK7YQ7kNvgE-47Ze&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8plK7tDZlg1SbXlKyOOQNPFg3UagNVs41QHkrlgNSmA&oe=66CC6449"}]}, "id": "323696001922105", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "715703355633187", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_2041697292598107_5279938674341969920_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Sntxcpq2F4Q7kNvgGIsn8l&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnfAzrb8VqlBsht72OzvClEYfe5Web3l5S8UWlOwM_7A&oe=66CC6A9F"}, {"file_name": "migrated_image.png", "id": "197784358315793", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974601_642270766282754_6003902570823680000_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fWX_jTMfSmwQ7kNvgEXIFsC&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8o_SmpS57NLDz_6sm-ez4-DKRrzMDQCxB4SpnT66qCw&oe=66CC673F"}, {"file_name": "migrated_image.png", "id": "212185513224930", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_1130238993840340_2424151538399182848_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uqAUmON5UGMQ7kNvgEDnrZs&_nc_ht=scontent.oculuscdn.com&oh=00_AYCq5VbhVvNcnl6YkY8r4jGO_QuSKx2epiZ4RXPZdGPTEA&oe=66CC5A1E"}, {"file_name": "migrated_image.png", "id": "202189077757139", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031392_371855520409988_4046232833511915520_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAEamylhNVIQ7kNvgHR2bl-&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2kF_ngZjD-L010AFU4h5jVPjkNWLbuA0W-OXZwK5Itg&oe=66CC54C2"}, {"file_name": "migrated_image.png", "id": "518362262389532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031494_403097963744304_4587097094434586624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rk4_f0yS--EQ7kNvgGIIAzU&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYhtkU45kOPkZB8mfBsqcsfPx5Ns4RqlqpFxojsR6FyQ&oe=66CC7748"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/2WBUw9", "id": "572409526627746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974693_572409533294412_7428283179816976384_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XtstTmU5K6EQ7kNvgH_pW8L&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhWe0XWwTWzKqRICO1uc3j3HLkMEjpaXkgfoh9QnKifQ&oe=66CC7502"}, "display_name": "Cave Digger: Riches", "keywords": ["Cave", "Digger", "Mine", "Western", "Adventure"], "long_description": "Features:\n-Explore the elevator shaft and four massive train levels full of mysteries, riches and strange happenings. Some fishy higher power seems to engulf the Frontier!\n\n-Build up the way to the mines by gearing up and upgrading your vehicle. But beware, the adventure can end in eight different ways depending on the actions and choices taken.\n\n-Meet a companion to help to carry the weight on your shoulders.\n\n-Go on a treasure hunt for hidden magical loot.\n\n-Item upgrades \u2013 technology advances in unimaginable ways, making mining more profitable!\n\n-28 achievements and more to come in free content updates.\n\nHow much riches will be enough? Will you be able to stop? What happens if you don\u2019t? The answers to these questions and more will be found as you dig deeper into the mines!", "short_description": "Cave Digger is a mining adventure game, which takes place in a small town of an alternative Western universe full of mystery, dark humor and full of experimental tools for the brave miners!\n\nGear up to explore the town and the depths of the mountain. Excavate bedrock with your hard swings, reap the rewards of Mother Earth and trade mined valuables for new gadgets. Outside of the saloon, a town in ruin awaits it\u2019s savior! Fix the train to enter the mines and dig deeper than any miner before you."}]}, "developer_name": "Mekiwi", "developer_pri