_name": "Virtual Virtual Reality", "keywords": ["story", "comedy", "adventure", "explore", "VR"], "long_description": "V-VR is a narrative-driven comedy-adventure game about VR and AI. In a future where AI has transformed society, can humans still find purpose? Find out with Activitude, a service that lets humans aid AI clients in increasingly curious ways. Follow the instructions of Activitude\u2019s AI overlord, Chaz, and find your calling in this tech-fueled future \u2013 or try to break free and reclaim your humanity before it\u2019s too late. Use virtual VR headsets to explore over 50 unique virtual virtual realities, going deeper into the inner workings of Activitude as the story unfolds.\n\nKey Features:\n50+ unique virtual virtual realities\n4+ hours of gameplay\nAn artichoke screams at you", "short_description": "A comedic adventure in VR about VR"}]}, "developer_name": "Tender Claws", "developer_privacy_policy_url": "http://tenderclaws.com/privacy/PrivacyPolicy.html", "developer_terms_of_service_url": "http://tenderclaws.com/privacy/EULA.html", "publisher_name": "Tender Claws", "support_website_url": null, "website_url": "http://vvr.tenderclaws.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_TW", "de", "es_MX", "fr", "it", "ja", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "236003435392167"}}]}, "scheduled_offers": {"count": 22, "nodes": [{"status": "PUBLISHED", "id": "1985115311801099"}, {"status": "PUBLISHED", "id": "2060673650815397"}, 