.com/privacy-policy-hololight-hub/", "developer_terms_of_service_url": "https://hololight.com/terms-conditions/", "publisher_name": "Holo-Light GmbH", "support_website_url": "https://support.hololight.com/", "website_url": "https://hololight.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7964874676902943"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462964_897959915498906_8011188420198605567_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rop-sfBi4voQ7kNvgETRNDh&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao7UStuy-rnpZLKL8eY7_kE&oh=00_AYA7AyUZbeObDSklOyVJW-_AicB6EL-Ar8TZqWVnqdGWPw&oe=66EBFE85"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hololight Hub", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Business", "id": "421923165850360"}], "release_date": 1719994893, "lastRevision": {"nodes": [{"id": "7911925585531186", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7911925448864533", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "4053520714726665"}, "iarc_email": null, 