3N46o4ztDTNzCW8Aq8P5KHI2Bghjn_g&oe=66E415A3"}, {"file_name": "12602136_1351466771541719_2397558359327768576_n.png", "id": "469756501248687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031447_469756504582020_4276110840378856002_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPaBdw9wcCIQ7kNvgEe5Y50&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_0yeDgqt_i2mUMe4YKUhK9Dl73EFhHisqNnA0B8Bpdg&oe=66E43230"}, {"file_name": "12482393_2241339569424895_2106404257203748864_n.png", "id": "1303923850053623", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982635_1303923853386956_2350044789179652741_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EjPHCFYY_xwQ7kNvgForWwb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYAIGf4NPI8gO9Jgn9VPjvEdeU3IHSjVZAUEqEPPWTig&oe=66E43615"}, {"file_name": "12602284_1394786057255255_5073183737601064960_n.png", "id": "634683507801702", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469625_634683511135035_7306497319730044986_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4CjmH17L2nEQ7kNvgFdFAP1&_nc_ht=scontent.oculuscdn.com&oh=00_AYCF22dQCvN7sUPQ_5foZJfVWscvg_AkL7xlMNbC2tW1MQ&oe=66E4378B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "279891320927077", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974817_279891324260410_3171953507906637115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0cU8x32YqggQ7kNvgFw4AoK&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJLrtzzO_N5Rl6CGG_JVCymRUCpjAdX_neM6bb70Zk1g&oe=66E42668"}, "display_name": "Moon VR Video Player", "keywords": [], "long_description": "Moon VR is a free VR video player for Oculus Quest headset. Since 2017, we have been pioneering VR video technologies and challenging what defines the best VR player.\u2028Today, we are proud to launch a new version customized for Quest series. With a wide range of advanced features, Moon VR transforms your headset into an immersive theater. But don't let its sophistication deter you\u2014 it also comes with a simple and intuitive interface.\n\nKey features:\nMultiple modes supported and automatically recognized: 180\u00b0/ 360\u00b0/ 2D/ 3D\nMultiple formats supported: mkv/ mp4/ wmv/ mov/ avi/ rmvb/ flv\nMultiple subtitles and audio tracks supported\nRemove faulty ghosting in videos\nHead tracking and effortless hands-free control\nMoon Link: wirelessly watch VR videos from your computer\nScreen adjustments: Brightness, distance, zoom, and curved display\nRotate, mirror and single-eye viewing\nBackground environments: galaxy, sea view and more to be released\nAdvanced antialiasing to smooth shaking\n\nChill and Enjoy!", "short_description": "Stream and watch the best VR videos for FREE! Moon VR can also stream virtual reality videos from your PC."}]}, "developer_name": null, "developer_privacy_policy_url": "https://moonvrplayer.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "InnoVision", "support_website_url": null, "website_url": "https://moonvrplayer.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "UTILITY", "MEDIA_PLAYER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "470518061388466"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "512129734789852"}, {"status": "PUBLISHED", "id": "1103068890662257"}, {"status": "PENDING", "id": "1315068202714798"}, {"status": "PUBLISHED", "id": "645537876534568"}]}, "baseline_offer": {"id": "1103068890662257"}, "is_approved": true, "firstOffer": {"nodes": [{"s