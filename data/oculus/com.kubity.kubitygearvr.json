854_151575327225675776_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=15sVMzB98jIQ7kNvgGIxqSE&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADTryadLfPQtkbfUJEU4O0Z&oh=00_AYA3LXdgwLhVMbjnmiO2d4_LDo_go258vj6wU_CkBH-cWQ&oe=66F67EDD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "147436909356199", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386259_147436912689532_2294681183780339712_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NziVlMztKb8Q7kNvgGJj8zs&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADTryadLfPQtkbfUJEU4O0Z&oh=00_AYCmOAhf4vqwM5t5ZqLRu7Qa-yu-MGXm45dzlOGmS1jouQ&oe=66F67D5D"}, "display_name": "Kubity VR", "keywords": ["Autodesk", "Revit", "SketchUp", "Kubity", "Multiplex"], "long_description": "Step inside a new world and instantly visualize 3D models with Gear VR.\n\nKubity \u2014 the first mixed reality multiplex, is a system to instantly visualize SketchUp\u2122 and Autodesk\u2122 Revit\u2122 models on multiple devices: desktop computers, smartphones, tablets, augmented reality gear and virtual reality glasses. \n\nIt\u2019s an everyday solution to streamline conversations between architects, engineers, contractors, their clients, and the rest of the world. \n\n3D storytelling has never been simpler.\n\nIf you have any questions, please contact the team at: support@kubity.com\n\nwww.kubity.com", "short_description": "Step inside a new world and instantly visualize SketchUp and Revit models with Gear VR."}]}, "developer_name": "Kubity SAS", "developer_privacy_policy_url": "https://www.kubity.com/privacy", "developer_terms_of_service_url": "https://www.kubity.com/terms", "publisher_name": "Kubity", "support_website_url": null, "website_url": "https://www.kubity.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["UTILITY", "EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "inte