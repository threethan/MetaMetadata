854_151575327225675776_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HWjqo67KVtQQ7kNvgGULPLV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGxY5nyC3xwUTQ0ikdxVS-U&oh=00_AYDpSLfnfLrda2Le9KT5cE5qXTK0CxvA3Pi7VR8sH88hxQ&oe=66EE95DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "147436909356199", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386259_147436912689532_2294681183780339712_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kM1yc_1GyFIQ7kNvgHqqFYQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGxY5nyC3xwUTQ0ikdxVS-U&oh=00_AYB56XeLAa76NNb5QwSIX_6yCyLiC0hYf82lRLSADEmBZw&oe=66EE945D"}, "display_name": "Kubity VR", "keywords": ["Autodesk", "Revit", "SketchUp", "Kubity", "Multiplex"], "long_description": "Step inside a new world and instantly visualize 3D models with Gear VR.\n\nKubity \u2014 the first mixed reality multiplex, is a system to instantly visualize SketchUp\u2122 and Autodesk\u2122 Revit\u2122 models on multiple devices: desktop computers, smartphones, tablets, augmented reality gear and virtual reality glasses. \n\nIt\u2019s an everyday solution to streamline conversations between architects, engineers, contractors, their clients, and the rest of the world. \n\n3D storytelling has never been simpler.\n\nIf you have any questions, please contact the team at: support@kubity.com\n\nwww.kubity.com", "short_description": "Step inside a new world and instantly visualize SketchUp and Revit models with Gear VR."}]}, "developer_name": "Kubity SAS", "developer_privacy_policy_url": "https://www.kubity.com/privacy", "developer_terms_of_service_url": "https://www.kubity.com/terms", "publisher_name": "Kubity", "support_website_url": null, "website_url": "https://www.kubity.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["UTILITY", "EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "inte