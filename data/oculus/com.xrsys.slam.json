_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974611_264812613157343_4859997760815386136_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rdg6bv-g5GkQ7kNvgHPNmu1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYBvMyf0ZjfTO6sa5d8WREnS4YKyy2qVTrklhJMmkHBRtw&oe=66E422CF"}]}, "id": "313939124445114", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-08-28 at 9.32 1.png", "id": "684005236912593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422394_684005240245926_8484125489449991264_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJBoK6VWfKEQ7kNvgFkMlXc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYBih6volH-T6LXoIKmsyHjde7FNK50_HlIQQSr8yLwYYg&oe=66E40BD1"}, {"file_name": "Screenshot 2023-08-28 at 10.07 1.png", "id": "210368152015962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254875_210368155349295_2852346711864923415_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ri8v6Fjec3UQ7kNvgENVpn_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYAygkdAQHXVa-s_Nf2lpOOZvRsVADpoenUduOGnVFf4UQ&oe=66E41367"}, {"file_name": "Screenshot 2023-08-28 at 9.47 1.png", "id": "546888080896299", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75339313_546888084229632_1914750524933103956_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uQ0DXFoud_IQ7kNvgGoDAjx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYBkL6HlsPn5URcPxqyGa7UGjDTMoBvRXiREuYA6eB-LjQ&oe=66E43A68"}, {"file_name": "Screenshot 2023-08-28 at 9.53 1.png", "id": "701670631500809", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_701670634834142_5121723908228449659_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pJpR1lCCqD0Q7kNvgFlI8SL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYDlycD1kpPpRBEt_NXNP4u9xOiSpGaeoTWsxLZtU3-6Kw&oe=66E40F08"}, {"file_name": "Screenshot 2023-08-28 at 9.56 1 (1).png", "id": "294280946636804", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_294280949970137_6965906294267218481_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B5CBDBbFYK0Q7kNvgHg7_1A&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYDpBwjKuUL479qo1aPL-Sssy_JYYVw5eFaLy5MWZ7d3aA&oe=66E42BD3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 119.png", "id": "1224162988977336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031328_1224162995644002_3571595554411355435_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SuDi82qY7_QQ7kNvgFJvTK-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AT7EK4ld6cWveI_-qmNOfxR&oh=00_AYD2BNoT_Bz6WQIcAadpfjjCck7Uf34iQ1NxYCVwBZRLFQ&oe=66E42D04"}, "display_name": "Slam", "keywords": [], "long_description": "Slam is an innovative multiplayer tennis game designed exclusively for the Meta Quest platform. Notably, it stands out as the very first rhythm-based tennis workout experience in the gaming world. Central to the game mechanics is an energy gauge. As players engage in matches, they have the opportunity to charge this gauge by hitting targets placed around the court as hard as possible. Building up this energy is crucial because it unlocks the ability to unleash a power shot. Landing a power shot can drastically tip the scales in favor of the player, giving them a significant edge in potentially clinching the point. To master the game and maintain a competitive edge, players accumulate energy by consistently hitting these targets on the court.", "short_description": "Slam is an innovative multiplayer tennis game designed exclusively for the Meta Quest platform. It also stands out as the very first rhythm-based tennis workout experience in the gaming world. Dive into matches where you charge an energy gauge by hitting on-court targets. Unleash power shots to dominate your opponent! The first of its kind, Slam revolutionizes tennis gaming. Join in and feel the rhythm on the court!"}]}, "developer_name": null, "developer_privac