t=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bv1DdNzfJOYQ7kNvgFZ-gXT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ6YVxFCkKWPUD9-oBK7l0tXJb6cP15GNg6HwWGf_yMg&oe=6718E7D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 119.png", "id": "1224162988977336", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031328_1224162995644002_3571595554411355435_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WPQemT8jkg8Q7kNvgE6j0OF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC85FmwU1ZGk-18b6csqlnnKtTjRl9piegAPIApqY4W8g&oe=6718E904"}, "display_name": "Slam Sports Tennis", "keywords": ["tennis", "sports", "racket", "rhythm", "arcade"], "long_description": "Ready to take your tennis game to the next level\u2014and beyond reality? Dive into **Slam**, the ultimate multiplayer tennis experience exclusively on Meta Quest! Remember that classic motion-controlled tennis game everyone was obsessed with? Imagine that, but fully immersive in VR! **Slam** is rhythm-based and seriously action-packed. You'll smash on-court targets to charge up your energy, then unleash epic power shots to obliterate your opponents.\n\nFeel the beat as you dominate the court with jaw-dropping moves and combos synced perfectly to the rhythm. Challenge your friends or face off against players worldwide in this revolutionary tennis game.\n\nSo grab your headset, step onto the virtual court, and get ready to **slam** like never before!", "short_description": "Ready to level up your tennis game? Dive into Slam, the ultimate multiplayer tennis experience exclusive to Meta Quest! Remember that classic motion-based tennis game everyone loved? This is like that\u2014but in VR. It's rhythm-based and seriously action-packed! Hit on-court targets to charge your energy, then unleash epic power shots to smash your opponents. Feel the beat, dominate the court, and challenge your friends in this game-changing tennis game. Grab your headset and get ready to slam!"}]}, "developer_