VW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDGmVEIGLdIhijq4jPSvexgDwbTbOe0MJOwuSuBfipJDg&oe=66D5A24F"}]}, "id": "313939124445114", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-08-28 at 9.32 1.png", "id": "684005236912593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422394_684005240245926_8484125489449991264_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hnz4_TOQGtYQ7kNvgFya9Dn&_nc_ht=scontent.oculuscdn.com&oh=00_AYADdecagkKySMlEWJmA0MkAY2QofURNEX-uczlK2vaPtw&oe=66D58B51"}, {"file_name": "Screenshot 2023-08-28 at 10.07 1.png", "id": "210368152015962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254875_210368155349295_2852346711864923415_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ovKPOi-sjA4Q7kNvgGwUIbR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdJ8rkqZHIHn0b4n32SVd47DUrXiZXyTLSlxo53BDJAg&oe=66D592E7"}, {"file_name": "Screenshot 2023-08-28 at 9.47 1.png", "id": "546888080896299", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75339313_546888084229632_1914750524933103956_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zAff6RBt1fkQ7kNvgGjW3rf&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlEM_Ag5MxJ0-G0r5qq_TxGbc8Jl95KwGdk1ao2Eq31w&oe=66D5B9E8"}, {"file_name": "Screenshot 2023-08-28 at 9.53 1.png", "id": "701670631500809", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_701670634834142_5121723908228449659_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qd-6zsrXCBkQ7kNvgEQ9nEs&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjzMYDAOo-I7H4QZsuAuuyEp3G-wfHSS4_9gHz1ULGew&oe=66D58E88"}, {"file_name": "Screenshot 2023-08-28 at 9.56 1 (1).png", "id": "294280946636804", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_294280949970137_6965906294267218481_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=amS8iCL2b6sQ7kNvgFQE-Vq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoFtMMbJyRbtoywDkPzGqxJT0J9XgwJepWSGZmFFzKGg&oe=66D5AB53"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 119.png", "id": "1224162988977336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031328_1224162995644002_3571595554411355435_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYQbclZYwJUQ7kNvgG-QYUM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdHueSohughHCNwoOPkcpESIAYGrV72rIM-DmiR7dATQ&oe=66D5AC84"}, "display_name": "Slam", "keywords": [], "long_description": "Slam is an innovative multiplayer tennis game designed exclusively for the Meta Quest platform. Notably, it stands out as the very first rhythm-based tennis workout experience in the gaming world. Central to the game mechanics is an energy gauge. As players engage in matches, they have the opportunity to charge this gauge by hitting targets placed around the court as hard as possible. Building up this energy is crucial because it unlocks the ability to unleash a power shot. Landing a power shot can drastically tip the scales in favor of the player, giving them a significant edge in potentially clinching the point. To master the game and maintain a competitive edge, players accumulate energy by consistently hitting these targets on the court.", "short_description": "Slam is an innovative multiplayer tennis game designed exclusively for the Meta Quest platform. It also stands out as the very first rhythm-based tennis workout experience in the gaming world. Dive into matches where you charge an energy gauge by hitting on-court targets. Unleash power shots to dominate your opponent! The first of its kind, Slam revolutionizes tennis gaming. Join in and feel the rhythm on the court!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrsys.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRSYS", "support_website_url": null, "website_url": "https://www.xrsys.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, 