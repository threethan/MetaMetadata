ontent.oculuscdn.com/v/t64.5771-25/39001660_294280949970137_6965906294267218481_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N4u01ouLxQsQ7kNvgEhB5jc&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa8NQ7ldU9EVn7msf5oo4St&oh=00_AYAx2l9VKqN91PSm_PHly-WmW512AObgSTlju9qMG5rV9Q&oe=66F54F53"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 119.png", "id": "1224162988977336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031328_1224162995644002_3571595554411355435_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e8FrPO-qZocQ7kNvgGJz_pN&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa8NQ7ldU9EVn7msf5oo4St&oh=00_AYCwxTpkYy_mExS-_O-Qmq3UD9jN5OTjTh2CWoMMLd7MeQ&oe=66F55084"}, "display_name": "Slam Sports Tennis", "keywords": ["tennis", "sports", "racket", "rhythm", "arcade"], "long_description": "Ready to take your tennis game to the next level\u2014and beyond reality? Dive into **Slam**, the ultimate multiplayer tennis experience exclusively on Meta Quest! Remember that classic motion-controlled tennis game everyone was obsessed with? Imagine that, but fully immersive in VR! **Slam** is rhythm-based and seriously action-packed. You'll smash on-court targets to charge up your energy, then unleash epic power shots to obliterate your opponents.\n\nFeel the beat as you dominate the court with jaw-dropping moves and combos synced perfectly to the rhythm. Challenge your friends or face off against players worldwide in this revolutionary tennis game.\n\nSo grab your headset, step onto the virtual court, and get ready to **slam** like never before!", "short_description": "Ready to level up your tennis game? Dive into Slam, the ultimate multiplayer tennis experience exclusive to Meta Quest! Remember that classic motion-based tennis game everyone loved? This is like that\u2014but in VR. It's rhythm-based and seriously action-packed! Hit on-court targets to charge your energy, then unleash epic power shots to smash your opponents. Feel the beat, dominate the court, and challenge your friends in this game-changing tennis game. Grab your headset and get ready to slam!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.xrsys.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "XRSYS", "support_website_url": null, "website_url": "https://www.xrsys.net/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "9048669815148222"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974852_1240582549932068_3086090223049495400_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8xuyRMXnfHAQ7kNvgGjPorT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa8NQ7ldU9EVn7msf5oo4St&oh=00_AYAyFJjTAlq_cA6MxySGSFhspjBzKKKDgKVOr6IliuhNUg&oe=66F53815"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Slam Sports Tennis", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Music & Rhythm", "id": "939033889924114"}], "release_date": 1674894600, "lastRevision": {"nodes": [{"id": "6416298681718695", "release_type": "SCHEDULED",