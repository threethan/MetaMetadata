=00_AYDgDXLVdiiF_Lf-Dlg4wEfpZz9YW-JgCRkPA_cuxUXZGQ&oe=6720BCB1"}, {"file_name": "Screenshot_com.qjtc.zhiciqinglv_2024.08.07-15.47.27.373_673_\u526f\u672c_\u526f\u672c.png", "id": "820892783526499", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974468_820892786859832_4080045266342485046_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B6dEeHu8dh8Q7kNvgHxV5Ju&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBA5Kc4zGEW9HzCV7OwtuDb1MO1nF7stFDHeR2Tcy47pw&oe=6720E3C5"}, {"file_name": "Screenshot_com.qjtc.zhiciqinglv_2024.08.07-15.47.50.229_133_\u526f\u672c_\u526f\u672c.png", "id": "510598871550632", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982484_510598874883965_1955532416435314891_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JSJ6jGEn4RQQ7kNvgHCIwOP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAL7SxhVoir2n0U5IJyNd_ULOPqEZJw3YQrPTzSvIwdhA&oe=6720D1AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u5bb9\u5668 317@1x_\u526f\u672c.png", "id": "750260607126786", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982483_750260610460119_8049027481302987210_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=869UIzK-HToQ7kNvgE_G4i_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsxX5hhtXGA3qomfuaOzNbNiThNaW4YKwVaaEEbygS3w&oe=6720DC6E"}, "display_name": "Poetic Dance", "keywords": [], "long_description": "The creative inspiration for Poetic Dance \"The Journey of a Legendary Landscape Painting\" comes from the \"A Panorama of Mountains and Rivers\" painting.\n\n\"A Panorama of Mountains and Rivers\" is one of the top ten most famous ancient Chinese paintings passed down through generations. It was painted by the Northern Song Dynasty artist Wang Ximeng in half a year when he was only 18 years old. Unlike the black and white tones of ink wash paintings, this painting is named for the use of mineral pigments of azurite and malachite green, depicting the splendid and magnificent scenery of thousands of miles of rivers and mountains with its gorgeous green and blue hues.\n\nThe entire ballet poem is structured around chapters such as \"Scroll Unfolding, Seal Tracing, Silk Reeling, Minerals Exploring, Brush Making, Ink Grinding, Painting Alive\" narrating the story of a young researcher from the Palace Museum who \"time travels\" back to the Northern Song Dynasty, and from the perspective of an \"The Scroll Opener\", \"witnesses\" the story of the painter Wang Ximeng creating the \"A Panorama of Mountains and Rivers\"\n\nThis group dance expresses the concept of layered mountain ranges. The dancers, with their resplendent bodies, outline the boundless rivers and mountains that are as poetic and illusory as a dream, narrating the legendary tales of classical Chinese style.", "short_description": "The Journey of a Legendary Landscape Painting."}, {"images": {"nodes": [{"file_name": "20240805-155222.png", "id": "1696540241087677", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/54770914_1696540244421010_724349100188658269_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0CKXGoioY1AQ7kNvgGYwQQi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSNEJIAPJjTvspj5vAtGQ6vjDgXUH8p10AW-9SHasWoQ&oe=6720D0F0"}, {"file_name": "\u7ec4 344@1x.png", "id": "1263677808416788", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974888_1263677811750121_5447872420596645171_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O2UHIRzWJ7MQ7kNvgFvunAA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkoX6Om2W8nQietaReU0-FeAzDiMYk2tfvo8D2M9oVug&oe=6720B2F4"}, {"file_name": "20240807-155627_\u526f\u672c.png", "id": "1035260088203075", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035308_1035260091536408_3276939169422989872_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ceKLxNLx4R4Q7kNvgEruInV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiuqMzCrcsPkhLtYjq4OF532VFnJGQSSza3z3kTKwjew&o