=00_AYCXDZO0y06IOqv3davXolg56xIr6skh896G5k8axBWivg&oe=670F9931"}, {"file_name": "Screenshot_com.qjtc.zhiciqinglv_2024.08.07-15.47.27.373_673_\u526f\u672c_\u526f\u672c.png", "id": "820892783526499", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974468_820892786859832_4080045266342485046_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huOI0ELRXr4Q7kNvgFcXc41&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB0aLdyBvG8yyURvQlDASbf3YFYn1gkzqeBho6-7TTxvA&oe=670FC045"}, {"file_name": "Screenshot_com.qjtc.zhiciqinglv_2024.08.07-15.47.50.229_133_\u526f\u672c_\u526f\u672c.png", "id": "510598871550632", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982484_510598874883965_1955532416435314891_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tTdSisZD8eAQ7kNvgHveVqX&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYALFS8NB7-w2qKxhGlsyuQ3Tbe0o-owaqAXLy-VyTeoxA&oe=670FAE2F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u5bb9\u5668 317@1x_\u526f\u672c.png", "id": "750260607126786", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982483_750260610460119_8049027481302987210_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8AZz-E3sIXoQ7kNvgGb7O1T&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDT7lI-s7-ZkCKvj-nTa_1wtGwFiIn2A0K2A8fRzL-EAQ&oe=670FB8EE"}, "display_name": "Poetic Dance", "keywords": [], "long_description": "The creative inspiration for Poetic Dance \"The Journey of a Legendary Landscape Painting\" comes from the \"A Panorama of Mountains and Rivers\" painting.\n\n\"A Panorama of Mountains and Rivers\" is one of the top ten most famous ancient Chinese paintings passed down through generations. It was painted by the Northern Song Dynasty artist Wang Ximeng in half a year when he was only 18 years old. Unlike the black and white tones of ink wash paintings, this painting is named for the use of mineral pigments of azurite and malachite green, depicting the splendid and magnificent scenery of thousands of miles of rivers and mountains with its gorgeous green and blue hues.\n\nThe entire ballet poem is structured around chapters such as \"Scroll Unfolding, Seal Tracing, Silk Reeling, Minerals Exploring, Brush Making, Ink Grinding, Painting Alive\" narrating the story of a young researcher from the Palace Museum who \"time travels\" back to the Northern Song Dynasty, and from the perspective of an \"The Scroll Opener\", \"witnesses\" the story of the painter Wang Ximeng creating the \"A Panorama of Mountains and Rivers\"\n\nThis group dance expresses the concept of layered mountain ranges. The dancers, with their resplendent bodies, outline the boundless rivers and mountains that are as poetic and illusory as a dream, narrating the legendary tales of classical Chinese style.", "short_description": "The Journey of a Legendary Landscape Painting."}, {"images": {"nodes": [{"file_name": "20240805-155222.png", "id": "1696540241087677", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/54770914_1696540244421010_724349100188658269_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1peXw_dG_8cQ7kNvgHtbUMI&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD2SnnTSza9MUKfeiP8D97gq_Zqw5AhJ0DXBK_X3raPmw&oe=670FAD70"}, {"file_name": "\u7ec4 344@1x.png", "id": "1263677808416788", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974888_1263677811750121_5447872420596645171_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gs2Sysd5fKAQ7kNvgHW5sZ7&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCynb6sywjXAP4hI9rrwu6rLmfxZYycTzqs1pm7LyNLmg&oe=670F8F74"}, {"file_name": "20240807-155627_\u526f\u672c.png", "id": "1035260088203075", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035308_1035260091536408_3276939169422989872_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BaKHyKOQAz0Q7kNvgG8NZ-g&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYChSUmAQ3lbCg_Wc7rVEFfE7gwH7BgaPSvLsiwUeWKjxg&o