/t64.5771-25/38974642_563303767729730_4066052651589042176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULal8fBSZBIQ7kNvgHuWNAw&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBaj2uvElNxqTD001RzPppoKm35kXL4JlmLmfO8dcM6IA&oe=6787B959"}, {"file_name": "migrated_image.png", "id": "211805150067920", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974801_635791003833804_1624164186747568128_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mWzGvzw-0_AQ7kNvgE47sMj&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBm1VlYFFIBZB0dC4QCiwdQ1Fc-5_qI7303zjWAaZpzIA&oe=67879E7D"}, {"file_name": "migrated_image.png", "id": "210025490085588", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982534_235334027473014_3739899500920045568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=71QMPzvGevwQ7kNvgEgGhC7&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBUM3As3Wzdro10Hy2x8uvWq_uyhuRoq-IgtzXCIQyOsw&oe=6787A92D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hRlCa1", "id": "1529592850550515", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982513_1529592853883848_3292407579904311296_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-ZiDDH5wFEQ7kNvgFx7S-G&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDdvYAmpAsqieDTQkHRVJ6PxXWblaTT4AboAX0tp7GJsg&oe=67879F40"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world'