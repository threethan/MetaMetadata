v/t64.5771-25/38974642_563303767729730_4066052651589042176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9tR196FtAU4Q7kNvgGZX_rm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAXTd7-SJFlPieWMC-UoKGKmUOSuvWZtS7YD0ITYKjjg&oe=67505A59"}, {"file_name": "migrated_image.png", "id": "211805150067920", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974801_635791003833804_1624164186747568128_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VOmxKC1-A6QQ7kNvgEaMgBY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDMZj2k3BdrL4yxWrj6lQPAPXB3vb_2LTfTRjmYcru8PQ&oe=67503F7D"}, {"file_name": "migrated_image.png", "id": "210025490085588", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982534_235334027473014_3739899500920045568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3wRiEVBmSfkQ7kNvgFqiGet&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDcyC3nCD_RcdksLqvBGvoMQOp14zcHDIxwC6SwoxNGbw&oe=67504A2D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hRlCa1", "id": "1529592850550515", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982513_1529592853883848_3292407579904311296_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iYLGiPV0bWUQ7kNvgFirKNC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8Q5jWYRrAh57MRuLIpZuFQWCIqLjoYUGsyN-a9C2EtA&oe=67504040"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world