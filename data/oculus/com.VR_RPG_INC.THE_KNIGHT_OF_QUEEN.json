/t64.5771-25/38974642_563303767729730_4066052651589042176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P6fejQwbwDkQ7kNvgGZyPA4&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCu4R8vsFrbujuJeA8f16v4pXBVLzb2uGLJRqld546zNA&oe=675EDAD9"}, {"file_name": "migrated_image.png", "id": "211805150067920", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974801_635791003833804_1624164186747568128_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1rEbpKixsTMQ7kNvgFKreat&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDXPWHPpCsbMEuoWW6ZkAsqgET_gWp1eZwm2CQbiJs6-Q&oe=675EBFFD"}, {"file_name": "migrated_image.png", "id": "210025490085588", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982534_235334027473014_3739899500920045568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oOpJeHa9yZYQ7kNvgExwLKk&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDZKG7ozA3UPMkMZoNuni4ID6B_CNhqUwaKNPelBON7vg&oe=675ECAAD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hRlCa1", "id": "1529592850550515", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982513_1529592853883848_3292407579904311296_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pF42CC08hgEQ7kNvgHqYAbN&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYB9smh9geSSKWq6K6I1F6aMz_vrS48YFiiXLHYekBONwg&oe=675EC0C0"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world'