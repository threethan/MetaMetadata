=scontent.oculuscdn.com&oh=00_AYAk_OwwrS841GxsOZjzmiaSQiyW6X9wdD8K3UjBw7VBOA&oe=66DEE9DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_LogoProduct_2560_1440.png", "id": "626641151271936", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196217_626641154605269_5988859305026201536_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HYSHxGeVv6MQ7kNvgE15VPU&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHYlO3xss8qcBfJjZP1MEN6ClCCdLvbbYqNWjiiPnjfg&oe=66DEED5F"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR !\n\nExperience a sense of reality that cannot be reproduced on a TV or smartphone screen.", "short_description": "Dive into the world of old-school RPG in VR !!\n\nBecome the Hero of her majesty the Queen,\nand travel to defeat the evil Devil King,\nbringing peace to the world !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "website_url": "https://www.theknightofqueen.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RPG", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "re