a7KlkoQ7kNvgEHtdzD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPjAPNGw5rJHHrPQYEnumwZ0KtFPqB9jNwtcFyODIOgA&oe=673C878E"}, {"file_name": "SS5.png", "id": "268246814603782", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75334066_268246817937115_2767763391105192992_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1h66Uq2dDrEQ7kNvgGUVjgQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfKlxb-nRI3Jcazk-eGHGOcfYWqcjV_fItcEn2T8cdAg&oe=673C845C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_LogoProduct_2560_1440.png", "id": "626641151271936", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196217_626641154605269_5988859305026201536_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1RHp0sgTeIQQ7kNvgEiYx_X&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALxfKixzuS-7dXJAIUss73ONpSpalzlGg9L_Hhqav4bQ&oe=673C87DF"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR !\n\nExperience a sense of reality that cannot be reproduced on a TV or smartphone screen.", "short_description": "Dive into the world of old-school RPG in VR !!\n\nBecome the Hero of her majesty the Queen,\nand travel to defeat the evil Devil King,\nbringing peace to the world !!"}, {"images": {"nodes": []}, "id": "405999175902821", "locale": "ja_JP", "screenshots": [{"file_name": "SS1.png", "id": "2700425486891479", "uri": "https://scontent-iad3-