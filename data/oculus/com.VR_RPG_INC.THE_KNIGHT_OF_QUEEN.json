/t64.5771-25/38974642_563303767729730_4066052651589042176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lI6vEiixPh0Q7kNvgFtsEcA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7bvdcqjWnbGZX72R9fAeihnj4ZKilIMuQO0FhjcU-WA&oe=6766C3D9"}, {"file_name": "migrated_image.png", "id": "211805150067920", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974801_635791003833804_1624164186747568128_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uORqUHxk1UwQ7kNvgH0T9H3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAraDGXNKf9PX9-gdSi14EqOaACwtjYs87-EqeE6_hhlg&oe=6766A8FD"}, {"file_name": "migrated_image.png", "id": "210025490085588", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982534_235334027473014_3739899500920045568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O0-9XGL0XMgQ7kNvgFC8c-1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIRhp7OL6OquWwNfR12Hol7VRvcgcKAyfc6aJsrACulg&oe=6766B3AD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hRlCa1", "id": "1529592850550515", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982513_1529592853883848_3292407579904311296_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P12njbVdKJ0Q7kNvgEroZ3j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCXXwnIOp38FZJlhFuqsBUG_ZBhv8uvrhO7p9y0C5dEgQ&oe=6766A9C0"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world'