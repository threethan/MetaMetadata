xhJEo0Q7kNvgE0wfNA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBdG_hxB04DUU5B9jzUxJsrTdGgJ5At-iR67dOK4D4mkA&oe=6756E58E"}, {"file_name": "SS5.png", "id": "268246814603782", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75334066_268246817937115_2767763391105192992_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=da3ONZnL1KEQ7kNvgEihQOm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBL1aKdT865vaY1Kkh_rMcGedGxuB8B4tthFp89czllzw&oe=6756E25C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_LogoProduct_2560_1440.png", "id": "626641151271936", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75196217_626641154605269_5988859305026201536_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_718YXjPrEQ7kNvgHYlts2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA2Sir1T1iyV6p3wRVz0F--ytcqgE-V1-cgYxTh_pip-A&oe=6756E5DF"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR !\n\nExperience a sense of reality that cannot be reproduced on a TV or smartphone screen.", "short_description": "Dive into the world of old-school RPG in VR !!\n\nBecome the Hero of her majesty the Queen,\nand travel to defeat the evil Devil King,\nbringing peace to the world !!"}, {"images": {"nodes": []}, "id": "405999175902821", "locale": "ja_JP", "screenshots": [{"file_name": "SS1.png", "id": "2700425486891479", "uri": "https://scontent-ams4-