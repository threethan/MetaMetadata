v/t64.5771-25/38974642_563303767729730_4066052651589042176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jyWb-syAnlsQ7kNvgFHPTrx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8sYCCvMYYUr160DRSKvFaLnbFrAijsbQLYO2dCxUtXA&oe=673C93D9"}, {"file_name": "migrated_image.png", "id": "211805150067920", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974801_635791003833804_1624164186747568128_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=39DyOa5ojW4Q7kNvgGCMUT4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBA_gJCGWgtDt4QD5cvsq3a953cZwIrZplioep67BkDWg&oe=673C78FD"}, {"file_name": "migrated_image.png", "id": "210025490085588", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982534_235334027473014_3739899500920045568_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aIXBQioqgKwQ7kNvgE327q1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-jUTFqHRc2IIzVpvfkGYBi-64OphccxaZfnUoD6Vo9w&oe=673C83AD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/hRlCa1", "id": "1529592850550515", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982513_1529592853883848_3292407579904311296_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C18sTWnSZtwQ7kNvgFjynQG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDts68VbTFWcpeE0L0vZB1Suf6EGt71qfky526aVIH6oA&oe=673C79C0"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": ["RPG", "QUEEN", "KNIGHT", "retro", "old"], "long_description": "Once sealed in time by the legendary Hero, the Devil King arises, and the world is on the brink of losing peace once again.\nYou, as the Queen's knight, depart on a mission to rid of the Devil King and restore tranquility to the world.\nCan you safely defeat the Devil King, and protect the world from an evil era ?\n\nThe battle system uses a one-to-one turn-based command input.\nWith an old-school system feel let's you play right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world