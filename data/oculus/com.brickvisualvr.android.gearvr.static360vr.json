com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYCK5A-TwVLUyvY3QAosm3PwXsX6SFND2PxdM-CIY0F5fQ&oe=66D1A4E4"}, {"file_name": "migrated_image.png", "id": "192521432198935", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139302_310537312769074_8023845236528644096_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1qNB4mDGAcQ7kNvgEn03ym&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYAIKZIv3f-Lq_zytp2hBgubCIHaFG2Jt4TrNlHDeStF_A&oe=66D1C356"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BrickVR_Gallery_Art_01_fin.png", "id": "573688289670583", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482156_573688299670582_3841047200511557632_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x7I-XCtAmxMQ7kNvgHzBdDP&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYAuYhawSp7-3r2tJ0QQO3UYl_Z-GX_bvhB0N4tFLOKSiw&oe=66D1A646"}, "display_name": "BrickVR", "keywords": ["brick", "brickvisual", "brickvr", "brickvisualvr", "360"], "long_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo to experience the feeling of the presence. The application developed by Brick Visual, a world famous architectural visualization company. It is a panoramic 360 viewer application with the following features:\n- Share the VR experience live\n- Navigate by hotspots or layout\n- Choose between different interior design styles or different architectural phases\n- Choose between different time of the day\n \nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual.", "short_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo, to experience the feeling of the presence. It is a panoramic 360 viewer application with extended features, such as live sharing, style chooser, time of the day chooser.\nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual."}]}, "developer_name": "Zsolt Simon", "developer_privacy_policy_url": "http://brickvisualvr.com/brick-vr-application-privacy-policy/", "developer_terms_of_service_url": "http://brickvisualvr.com/brick-vr-application-terms-of-service/", "publisher_name": "Brickvisual", "support_website_url": null, "website_url": "http://brickvisualvr.com/static-360-vr/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PRODUCTIVITY", "SIMULATION", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "1017042822495611"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410440_2072777399606626_3595474100241301504_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1wzq_4MF6EkQ7kNvgFhh8BC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYBEWd1gUrnpdDm4TFzNYCnfIQ0oT6Y0EMgB2P780c0LAA&oe=66D1C116"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BrickVR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1520445600, "lastRevision": {"nodes": [{"id": "1853902148273533", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1516314451794036", "is_first_party": false, "enables_in_app_ads": false, "