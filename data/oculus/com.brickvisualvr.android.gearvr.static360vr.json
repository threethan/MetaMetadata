ntent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYCiFOUUdmd2OlswMFTGOlJh_M1rMojJHGDIE2t181Ud3A&oe=66D1A224"}, {"file_name": "migrated_image.png", "id": "200847261146525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386340_1272801076155040_3493058818361786368_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FqFkC-p4P6wQ7kNvgFgssw6&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYBTRYIRJ4spuDkqa-lCkM4bRx9uT9rDwbHKzsw-5w2L2Q&oe=66D1B7E1"}, {"file_name": "migrated_image.png", "id": "196400831799362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139302_310537312769074_8023845236528644096_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1qNB4mDGAcQ7kNvgEn03ym&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYAIKZIv3f-Lq_zytp2hBgubCIHaFG2Jt4TrNlHDeStF_A&oe=66D1C356"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BrickVR_Gallery_Art_01_fin.png", "id": "1275507662553933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162766_1275507665887266_8095396630016032768_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0g-fgCRNa_sQ7kNvgG885Hi&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am7e-bNBURbGT0Yjl-hxYYi&oh=00_AYC3m7altEj7jNJw3628SprBd0Us-6VXMeNYB9umAIu4Qw&oe=66D1B683"}, "display_name": "BrickVR", "keywords": ["brick", "brickvisual", "brickvr", "brickvisualvr", "360"], "long_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo to experience the feeling of the presence. The application developed by Brick Visual, a world famous architectural visualization company. It is a panoramic 360 viewer application with the following features:\n- Share the VR experience live\n- Navigate by hotspots or layout\n- Choose between different interior design styles or different architectural phases\n- Choose between different time of the day\n \nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual.", "short_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo, to experience the feeling of the presence. It is a panoramic 360 viewer application with extended features, such as live sharing, style chooser, time of the day chooser.\nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual."}]}, "developer_name": "Zsolt Simon", "developer_privacy_policy_url": "http://brickvisualvr.com/static360vr/gearvr/gearvr-privacy-policy/", "developer_terms_of_service_url": "http://brickvisualvr.com/static360vr/gearvr/gearvr-terms-of-service/", "publisher_name": "Brickvisual", "support_website_url": null, "website_url": "http://brickvisualvr.com/static360vr/gearvr/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "UTILITY", "EXPLORATION", "PRODUCTIVITY", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "688537572148275"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1641535682605245", "version": "0.3.1"}, "id": "478279622556229", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binarie