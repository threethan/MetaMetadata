ment project or an exclusive condo, to experience the feeling of the presence. It is a panoramic 360 viewer application with extended features, such as live sharing, style chooser, time of the day chooser.\nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual."}]}, "developer_name": "Zsolt Simon", "developer_privacy_policy_url": "http://brickvisualvr.com/static360vr/gearvr/gearvr-privacy-policy/", "developer_terms_of_service_url": "http://brickvisualvr.com/static360vr/gearvr/gearvr-terms-of-service/", "publisher_name": "Brickvisual", "support_website_url": null, "website_url": "http://brickvisualvr.com/static360vr/gearvr/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "UTILITY", "EXPLORATION", "PRODUCTIVITY", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "688537572148275"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1641535682605245", "version": "0.3.1"}, "id": "478279622556229", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1516314451794036", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "164153