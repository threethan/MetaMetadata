dn.com/v/t64.5771-25/12139302_310537312769074_8023845236528644096_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ar8NURLxEJwQ7kNvgEGacQS&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCZrPHdAd8zYSZSh2wQYXsNgd0VH7fnAac7DF2p8rN1Tg&oe=67110B56"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BrickVR_Gallery_Art_01_fin.png", "id": "573688289670583", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/12482156_573688299670582_3841047200511557632_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LTpA8-kMTW0Q7kNvgG_48hQ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA1A0G5d0NCP49IkQPQF3bWg3Cl1fZzd19ezszXLxHxrw&oe=6710EE46"}, "display_name": "BrickVR", "keywords": ["brick", "brickvisual", "brickvr", "brickvisualvr", "360"], "long_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo to experience the feeling of the presence. The application developed by Brick Visual, a world famous architectural visualization company. It is a panoramic 360 viewer application with the following features:\n- Share the VR experience live\n- Navigate by hotspots or layout\n- Choose between different interior design styles or different architectural phases\n- Choose between different time of the day\n \nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual.", "short_description": "Brick VR is a the next step to communicating architecture.\n\nBrick VR allows you to discover unbuilt architecture. You can step into a large scale development project or an exclusive condo, to experience the feeling of the presence. It is a panoramic 360 viewer application with extended features, such as live sharing, style chooser, time of the day chooser.\nVisit brickvisualvr.com to find out more about the VR solutions of Brick Visual."}]}, "developer_name": "Zsolt Simon", "developer_privacy_policy_url": "http://brick