-iad3-1.oculuscdn.com&oh=00_AYDcKjYb_DE3rSoZpXCd1lKJ23h6Yt5Wl3bBv8j8q8NfxA&oe=678262D5"}]}, "id": "1431600507797995", "locale": "en_US", "screenshots": [{"file_name": "Screen capture 1 - agree.png", "id": "1104135617759944", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031606_1104135624426610_1324015692044806744_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ol5NMdWBGeoQ7kNvgFLKYrV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-P5Ia0w-1mWwMOx24HqE_aYK2XJpKvj4cE3aN5_xTMw&oe=67826ACF"}, {"file_name": "Dino-scratching-002.png", "id": "3944089872578150", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974631_3944089875911483_7181942785909815962_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-UsCvFJAfB8Q7kNvgFBHTn4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZrjcc5N3BFp5G9lcxhhUquu4YUJdD4g05QSRuTYkGIQ&oe=67824D9A"}, {"file_name": "Mixed-reality_017.png", "id": "1283378833081372", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982458_1283378836414705_375518605733744241_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9RF7FjqFdn0Q7kNvgFbTwtm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuHMZ68mXqURbbEjuzMcD-S5LInlxzcpMHG964VY29Gw&oe=6782510D"}, {"file_name": "Laura moved back - reco to include a baby this is important.png", "id": "914512210174908", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75361355_914512213508241_4729821749254970352_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sznFXsFhDXcQ7kNvgHeDEgG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDMvtjSpDR6A_MexIuE5FyEM4FWZlyQLvAH-qquxzXGWQ&oe=67825887"}, {"file_name": "T-Rex-004.png", "id": "1317209869690824", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974680_1317209873024157_7390816256896039028_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=btkDUWGjI94Q7kNvgGWDzjE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHKPeJjCqMQotoha7wiqEm7i_wrr_sYf1eyypHakTVmw&oe=67824882"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "860056172970022", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75348041_860056176303355_8712151701602841115_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bDvaHCYnRU4Q7kNvgHtoUN-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhNYb8oSIruiOKu6b0eP-QrHkTBDj7tY9SLlY4N2edbg&oe=67823D3F"}, "display_name": "Dino Hab", "keywords": ["Dinosaur", "Simulation", "Travel", "Learning", "Puzzle"], "long_description": "# Catastrophe has struck the prehistoric world.\n\nAs a new cadet of the time-traveling Paleoguard, your mission is to raise baby dinosaurs into powerful adults with thriving herds, while restoring their prehistoric habitats.\n\n\n**Nurture Your Dinosaurs**\n\nRaise baby dinosaurs from hatchlings to towering adults. Bond with them as you care for their needs and watch your herds grow over time.\n\n{1338223984221286}\n\n**Manage Your Habitats**\n\nDiscover and build unique evolving habitats for your dinosaurs while adapting to challenges like storms and volcanic eruptions\n\n{556128130600558}\n\n**Unlock Rewards and New Ecosystems**\n\nYour progress will earn you rewards and unlock new habitats. 3 full habitats are included with their own dinosaurs, climate, flora, fauna, fungi, and more.\n\n{477140771581246}\n\n**Your Personal AI Companion**\n\nYour AI companion, Puck, will travel with you between the present day in mixed reality and the prehistoric world in virtual reality. Call on Puck for support as you restore balance to your prehistoric habitats.\n\n{2544933682564116}\n\n\n", "short_description": "Catastrophe has struck the prehistoric world. As a new cadet of the time-traveling Paleoguard, your mission is to raise baby dinosaurs into powerful adults with thriving herds, while restoring their prehistoric habitats.\n\nExplore and build evolving habitats for your dinosaurs, while overcoming environmental challenges like storms and volcanic eruptions. The more you bond with and care for your dinosaurs, the more rewards and new ecosystems you\u2019ll unlock.\n\n"}]}, "developer_name": "Dark Slope Inc.", "developer_privacy_policy_url": "https://www.dinohab.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "30 Ninjas", "support_website_url": null, "website_url": "https://dinohab.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1725996564472128"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8926564277431356"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443248_1266404608028918_1466471759230922077_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hBfKXeLFQx4Q7kNvgFtNySf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8cvnWE3fNad7tqFZAghONtzWq8JESgfpn15jyoLHYHQ&oe=67826832"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dino Hab", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "World Creation", "id": "1725996564472128"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1734616800, "lastRevision": {"nodes": [{"id": "8411450365609419", "release_type": "SCHEDULED", "administra