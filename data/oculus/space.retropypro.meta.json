4-1.oculuscdn.com/v/t64.5771-25/38974688_2253852244987854_5726517220935198158_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6TuFDN7fLB0Q7kNvgHFBJql&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAfOM7OC_NwuFcQl6XWw6asptZcab2XIDIaQPELNEj4pA&oe=6756DDCB"}, {"file_name": "vlcsnap-2024-07-19-15h18m13s079.png", "id": "496257609955774", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036629_496257613289107_1586315745250351762_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mb9HgRREaIoQ7kNvgHIlT8y&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCOZO34s5SAjcS-5AsmWxtp50fZg8O8fa_WHTcjihQ9HA&oe=6756C244"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandScape.png", "id": "3775055796048792", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036629_3775055799382125_4088374143721690922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CKiR-7H08hIQ7kNvgGj5QEt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD-l-1pp2Xm_h5TOwMNfWL6GXNdorGW0Mih6ox34OU4mQ&oe=6756C386"}, "display_name": "Retropy Pro", "keywords": [], "long_description": "Retropy Pro is the deluxe, premium version of Retropy with more puzzles, music selections, and exclusive VR environments.\n\nWith many different puzzles to choose from, get lost in the warm environments for hours on end. There are more genres of puzzles, mission modes, and increased puzzle piece count for players to enjoy.\n", "short_description": "Retropy Pro is a relaxing 3-D jigsaw puzzle game meant to inspire creativity and generate nostalgia.\n\nRestore everyday objects in a puzzling world that brings together exciting puzzles in a calming flow. \n\nRetropy is inspired by the meditative state of puzzling, which allows us to complete a familiar object and also strengthen our cognitive function. You can play standing or seated for maximum comfort and enjoyment. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retropy.space/privacy", "developer_terms_of_serv