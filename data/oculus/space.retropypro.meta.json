.com/v/t64.5771-25/39036629_496257613289107_1586315745250351762_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aG8DqXvcp18Q7kNvgH0wRW4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDg4jXZIvhL5DX1kaBYJRAIV_RstQPiVH5B5YRRpLOIiw&oe=67839544"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LangScape.png", "id": "3826036104276304", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036602_3826036107609637_4470162773859765169_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iMMfAYFtXz0Q7kNvgFpe2Hn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZeieT2QUxTGPXTYRqnYZCsdZUz3PO4CREIr9aQgVgIQ&oe=67839612"}, "display_name": "Retropy Pro", "keywords": [], "long_description": "Retropy Pro is the deluxe, premium version of Retropy with more puzzles, music selections, and exclusive VR environments.\n\nWith many different puzzles to choose from, get lost in the warm environments for hours on end. There are more genres of puzzles, mission modes, and increased puzzle piece count for players to enjoy.\n", "short_description": "Retropy Pro is a relaxing 3-D jigsaw puzzle game meant to inspire creativity and generate nostalgia.\n\nRestore everyday objects in a puzzling world that brings together exciting puzzles in a calming flow. \n\nRetropy is inspired by the meditative state of puzzling, which allows us to complete a familiar object and also strengthen our cognitive function. You can play standing or seated for maximum comfort and enjoyment. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retropy.space/privacy", "developer_terms_of_service_url": "https://retropy.space/tos", "publisher_name": "Surf Punk Interactive", "support_website_url": null, "website_url": "https://retropy.space/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type"