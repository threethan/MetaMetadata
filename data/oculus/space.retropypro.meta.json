_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDo3cQZUF8VjvhkzxVkYLs4dILEsr92KAHhaj3oWoDPyA&oe=67237232"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandScape.png", "id": "3775055796048792", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036629_3775055799382125_4088374143721690922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gtLx6iHLvNUQ7kNvgFAclqE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwY9sGXy0H_wMkSWyHChWdMkT68dbIM40RVaSp3ZOgug&oe=67235906"}, "display_name": "Retropy Pro", "keywords": [], "long_description": "Retropy Pro is the deluxe, premium version of Retropy with more puzzles, music selections, and exclusive VR environments.\n\nWith many different puzzles to choose from, get lost in the warm environments for hours on end. There are more genres of puzzles, mission modes, and increased puzzle piece count for players to enjoy.\n", "short_description": "Retropy Pro is a relaxing 3-D jigsaw puzzle game meant to inspire creativity and generate nostalgia.\n\nRestore everyday objects in a puzzling world that brings together exciting puzzles in a calming flow. \n\nRetropy is inspired by the meditative state of puzzling, which allows us to complete a familiar object and also strengthen our cognitive function. You can play standing or seated for maximum comfort and enjoyment. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retropy.space/privacy", "developer_terms_of_service_url": "https://retropy.space/tos", "publisher_name": "Studio Sunset", "support_website_url": null, "website_url": "https://retropyhome.my.canva.site/success", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommende