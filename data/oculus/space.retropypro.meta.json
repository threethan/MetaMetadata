852724375_489601951735700816_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nJRofWihTnQQ7kNvgFQC5hx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAV68A8vOw8UPb9azfFlr0-Vo6TMRmBOqhfhbZkq7RD9w&oe=67485C32"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandScape.png", "id": "3775055796048792", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036629_3775055799382125_4088374143721690922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xim6XeAPA8UQ7kNvgEsnWQT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3O79fjB1tdaHbBjVVvxtxuHpnCyXaktgObk1uFQ2duw&oe=67484306"}, "display_name": "Retropy Pro", "keywords": [], "long_description": "Retropy Pro is the deluxe, premium version of Retropy with more puzzles, music selections, and exclusive VR environments.\n\nWith many different puzzles to choose from, get lost in the warm environments for hours on end. There are more genres of puzzles, mission modes, and increased puzzle piece count for players to enjoy.\n", "short_description": "Retropy Pro is a relaxing 3-D jigsaw puzzle game meant to inspire creativity and generate nostalgia.\n\nRestore everyday objects in a puzzling world that brings together exciting puzzles in a calming flow. \n\nRetropy is inspired by the meditative state of puzzling, which allows us to complete a familiar object and also strengthen our cognitive function. You can play standing or seated for maximum comfort and enjoyment. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retropy.space/privacy", "developer_terms_of_service_url": "https://retropy.space/tos", "publisher_name": "Surf Punk Interactive", "support_website_url": null, "website_url": "https://retropy.space/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "gen