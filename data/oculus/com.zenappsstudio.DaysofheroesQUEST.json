73068139714_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EdJW8UwdKDQQ7kNvgHEeVmB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEXApOzGOMetx_2NjHRnWingTfiI-mvri7_rRgOrkmmQ&oe=672221AC"}, "display_name": "Days of Heroes: D-Day (Demo)", "keywords": [], "long_description": "Days of Heroes: D-Day have a two unique perspectives, experience the largest landing operation in martial history regarding the forces and means used. Take on the role of an airborne division jumper who descends into enemy territory to destabilize the enemy troops under the cover of night. Alternately, become a soldier beginning their heavy crossing of Omaha beach on D-Day.\n\nComplete diversified military missions, from short- and long-range skirmishes with Nazis, by employing anti-aircraft fire, destroying enemy tanks, and breaking through the trenches and escaping from a POW camp. Use over a dozen weapons typical to the World War II period that have been accurately reproduced in terms of appearance and mechanics.\n\nFinish the campaign and practice your skills on the shooting range, which offers four different gameplay modes. Once ready, unlock Hardcore Mode, which will take your cleverness, strategic thinking, and will to survive to the extreme.", "short_description": "This is demo of Days of Heroes: D-Day, try it now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenappsstudio.pl/daysofheroes/privacy-policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Zen Apps Studio", "support_website_url": null, "website_url": "https://zenappsstudio.pl/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics":