uminous colored cloud."}]}, "developer_name": null, "developer_privacy_policy_url": "https://imaginaryobjects.io/imaginary-objects-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Imaginary Objects LLC", "support_website_url": "https://www.imaginaryobjects.io/", "website_url": "https://www.imaginaryobjects.io/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "EXPERIENCE_360_NON_GAME", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1152635825509194"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "245611767879937"}, {"status": "PUBLISHED", "id": "288981900009378"}]}, "baseline_offer": {"id": "245611767879937"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1679955360, "status": "PUBLISHED", "id": "245611767879937"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4757162004380571", "version": "2.0"}, "id": "971066900148592", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4395607993869309", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4757162004380571"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"chann