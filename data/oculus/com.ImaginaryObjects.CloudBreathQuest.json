28_424038009406791_1795171070576386841_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wDx2WNCzh0kQ7kNvgEruyhc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrCWoXdjeVEK1iKhMfaTtuFSj9tzoN6V1Bjt-KHu8M8A&oe=6709294B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "02-CoverLandscape-CloudBreath.png", "id": "923528738527797", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974867_923528741861130_1137451032775002230_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VpbOKsTV7F4Q7kNvgES7Gq2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCcGUMANDm07DvYL9Gt3SWJlTXQb5Ln1GIA_4L_biWD0w&oe=6708FECC"}, "display_name": "Cloud Breath", "keywords": [], "long_description": "Cloud Breath is a 13-minute seated VR breathing meditation app, which immerses you in a changing environment of color, light and sound. It gently guides you to focus on each of your chakras, the seven energy centers in your body (red, orange, yellow, green, cyan, indigo, and violet) by timing your breath to the movements of a luminous colored cloud.\n\nIn a powerful and hypnotic original score by NYC-based multi-instrumentalist Greg Fox, each level has a unique composition \u2014 a modular-synth and percussive drone, based on the musical note assigned to each Chakra.", "short_description": "Cloud Breath is a 13-minute seated VR breathing meditation app, which immerses you in a changing environment of color, light and sound. It gently guides you to focus on each of your chakras, the seven energy centers in your body (red, orange, yellow, green, cyan, indigo, and violet) by timing your breath to the movements of a luminous colored cloud."}]}, "developer_name": null, "developer_privacy_policy_url": "https://imaginaryobjects.io/imaginary-objects-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Imaginary Objects LLC", "support_website_url": "https://www.imaginaryobjects.io/", "website_url": "https://www.imaginaryobjects.io/", "category": "APPS", "comfort_rating