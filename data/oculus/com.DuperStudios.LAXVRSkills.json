=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9J0oV20I_EQ7kNvgG3gIeu&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAPdQT13JxA9p6Dy_BgXAyGnHe-Q-5rqPtg70RvUHeK_Q&oe=677676D6"}, {"file_name": "1440X1440.png", "id": "441126115705019", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974860_441126119038352_2884899896599361267_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lpiSXMVqxIQ7kNvgEiTUma&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB71bvM5EqE0Gg5T-o6G6mKZnspCApY-WxEB0-QdqMvOg&oe=67767904"}]}, "id": "773707004929259", "locale": "en_US", "screenshots": [{"file_name": "ssShootingMode.png", "id": "872535834211244", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974711_872535837544577_5310422381761124475_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lihTG0VR1UwQ7kNvgGglLTW&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDon89VcW6-0Ynm2ijhLNGbjmKZvpRIrjSq8RNSHCopog&oe=677683C5"}, {"file_name": "screenshot3-GoalieMode.png", "id": "324634503308151", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982563_324634506641484_1756516055424560387_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XXBOcMKr73oQ7kNvgGHhfAp&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCfLdguK6HVGhqox1W95cZkiuR-rxOm3CnND_xKSgg45w&oe=677666CD"}, {"file_name": "screenshot2-defenderMode.png", "id": "690323585937024", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57575356_690323589270357_6573697315152692856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0koebm6_1bUQ7kNvgErB4h-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDwzzqruH2MD6GyOGfpzyPAlXvrS8KsyIpYLb112_1X_w&oe=67767655"}, {"file_name": "MGPost2560x1440Content.png", "id": "331756112747064", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982600_331756119413730_2102063463568969114_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vk_DLke484wQ7kNvgFXaxj7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDKihmZFThSaWBsUBFFyBl4nZ4p9INuMmOAMAZgO8_klg&oe=67767226"}, {"file_name": "screenshotMenu.png", "id": "9210961488948872", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036606_9210961495615538_4622789879229780214_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylH2DfEoIC4Q7kNvgE2vFqX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBP0eSr73-HVy1NDsHDNky8zi64A6iHvzqaME-YvIt0Pg&oe=6776632D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "842965181141388", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974759_842965184474721_1485266597461374600_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgctc5-cv4kQ7kNvgFAt0kg&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDoJ6P6Q_g1-vdaGhqCBKUbkutD6rkasgLVWim-3JWUpA&oe=67766794"}, "display_name": "Lacrosse", "keywords": ["lacrosse", "lax"], "long_description": "**Lacrosse Skills: Immersive Lacrosse in Virtual Reality**\n\nDive deep into the thrilling world of lacrosse like never before with LAXVR Skills, an unparalleled virtual reality experience. Crafted for both enthusiasts and novices, this game offers a chance to immerse yourself fully in the realm of lacrosse from a first-person perspective. Here's a glimpse into what awaits you:\n\n1. **Four Main Game Modes:** \n   **Shooting Mode:** Hone your shooting skills, master different techniques, and aim for that perfect shot.\n   **Goalie Mode:** Stand tall between the posts, anticipate your opponent's moves, and make that crucial save.\n   **Defender Mode:** Learn the art of defense, stop the attackers in their tracks, and reclaim the ball.\n   **The Medicine Game:** Embark on a historical journey that pays homage to the deep-rooted origins and traditions of lacrosse. Experience the soul of the game and its spiritual significance.\n\n2. **Casual Play Modes:** \n   **Wall Ball:** Perfect for those who cherish the simple joys of the game. Bounce, catch, and repeat. Sharpen your hand-eye coordination and reflexes.\n   **Free Shoot:** Sometimes, all you need is the open field, a stick, a goal, and a ball. Practice your shots or just enjoy the serenity of the virtual field.\n\n3. **Community and Competition:** \n   **Leaderboards:** Push your limits! Challenge yourself, compete with your friends, and see how you rank globally in the LAX VR community. ", "short_description": "Pick up a stick and elevate your lacrosse game! Engage in thrilling drills: fire precision shots, stuff attackers, and de-twig attackers with decisive checks. Can you score a 2-pointer past our goalie? Stop a 12-yard step down shot? Or shut down an attacker's split dodge? Challenge awaits in every corner!"}]}, "developer_name": "Duper Studios", "developer_privacy_policy_url": "https://laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27689844393996384"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974860_441126119038352_2884899896599361267_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lpiSXMVqxIQ7kNvgEiTUma&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD2E8SUOiz49_t