NvgEecCP2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgAs3umJIWaBXUdNfAvMvWM&oh=00_AYBB1W16CXKxvBy1-JUFxuA1IF8c1y8P0sB20bjr3rxixQ&oe=66F53F26"}, {"file_name": "screenshot1-mainmenu.png", "id": "1492025668264421", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_1492025671597754_8047331025133290047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5y17UF__eIQ7kNvgGtCYgo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgAs3umJIWaBXUdNfAvMvWM&oh=00_AYBe6DKLbPq7MaxCyXEgaHXWUKx97OBN1XzOevjut_aDXg&oe=66F56433"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "696966651969139", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982522_696966655302472_5287169594548358940_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffp11YOKcjsQ7kNvgHZbfS2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgAs3umJIWaBXUdNfAvMvWM&oh=00_AYBgK623ZWxsajds_TVss-ie2i_ZqHW7jEY8AJODJepqng&oe=66F54BC3"}, "display_name": "LAXVR Skills", "keywords": [], "long_description": "**LAXVR Skills: Immersive Lacrosse in Virtual Reality**\n\nDive deep into the thrilling world of lacrosse like never before with LAXVR Skills, an unparalleled virtual reality experience. Crafted for both enthusiasts and novices, this game offers a chance to immerse yourself fully in the realm of lacrosse from a first-person perspective. Here's a glimpse into what awaits you:\n\n1. **Four Main Game Modes:** \n   **Shooting Mode:** Hone your shooting skills, master different techniques, and aim for that perfect shot.\n   **Goalie Mode:** Stand tall between the posts, anticipate your opponent's moves, and make that crucial save.\n   **Defender Mode:** Learn the art of defense, stop the attackers in their tracks, and reclaim the ball.\n   **The Medicine Game:** Embark on a historical journey that pays homage to the deep-rooted origins and traditions of lacrosse. Experience the soul of the game and its spiritual significance.\n\n2. **Casual Play Modes:** \n   **Wall Ball:** Perfect for those who cherish the simple joys of the game. Bounce, catch, and repeat. Sharpen your hand-eye coordination and reflexes.\n   **Free Shoot:** Sometimes, all you need is the open field, a stick, a goal, and a ball. Practice your shots or just enjoy the serenity of the virtual field.\n\n3. **Community and Competition:** \n   **Leaderboards:** Push your limits! Challenge yourself, compete with your friends, and see how you rank globally in the LAX VR community. ", "short_description": "Dive into LAXVR Skills and elevate your lacrosse game! Engage in thrilling drills: fire precision shots, stuff attackers, and de-twig attackers with decisive checks. Can you score a 2-pointer past our goalie? Stop a 12-yard step down shot? Or shut down an attacker's split dodge? Challenge awaits in every corner!"}]}, "developer_name": "Duper Studios", "developer_privacy_policy_url": "https://laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26022091307438376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982563_1037285323960834_8202808848487851216_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c4qqsRhgBL8Q7kNvgHyxoQn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgAs3umJIWa