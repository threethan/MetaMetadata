6F0F7"}, {"file_name": "512x512Transparent.png", "id": "216454134774599", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375768_216454138107932_8541042433937575746_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_VVi3gWjahsQ7kNvgFaZAeY&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGyGBRYHXLRP4wj6nQ113uYe0UhULVGmNA8TqeUooeaw&oe=66D6ED2C"}]}, "id": "1552763031945949", "locale": "en_US", "screenshots": [{"file_name": "ssShootingMode.png", "id": "872535834211244", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_872535837544577_5310422381761124475_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPyU2aYj39oQ7kNvgGu0c6H&_nc_ht=scontent.oculuscdn.com&oh=00_AYDL4bZosVawVX0FvNmlifFUbZ12LO9eNNojtIGvy6ayUg&oe=66D6FE45"}, {"file_name": "screenshot3-GoalieMode.png", "id": "324634503308151", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982563_324634506641484_1756516055424560387_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xjz854e5PKcQ7kNvgEuBXoj&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqOnpbh0opCvmboClSadLhwp08j_Y58gXiY7L7ScrEPw&oe=66D6E14D"}, {"file_name": "screenshot2-defenderMode.png", "id": "690323585937024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575356_690323589270357_6573697315152692856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=btdHrHBJNH0Q7kNvgFny5z5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIjQz_APeLliFNE_kow-fye2VilkQ0gig1lwFzlFePyQ&oe=66D6F0D5"}, {"file_name": "MGPost2560x1440Content.png", "id": "331756112747064", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982600_331756119413730_2102063463568969114_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1aPdUEiMdn8Q7kNvgHW5F3X&_nc_ht=scontent.oculuscdn.com&oh=00_AYBD8YHD1WbdqMQNp3c1lzpSBCklZdRDw2LxfXznKEXqqA&oe=66D6ECA6"}, {"file_name": "screenshot1-mainmenu.png", "id": "1492025668264421", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_1492025671597754_8047331025133290047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AJyAYfTL3QQ7kNvgGxZODX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHnYQxnoV2u1BsOeAvYNKEvU0rCbqWEDYtDkWvXAEnKA&oe=66D6D973"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "696966651969139", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982522_696966655302472_5287169594548358940_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uk2gzCChtCAQ7kNvgF02NZO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM9cHJQbyEcDRcvIKAF1lZ3XDbMfJWDeRULkq5Xqu-ow&oe=66D6F943"}, "display_name": "LAXVR Skills", "keywords": [], "long_description": "**LAXVR Skills: Immersive Lacrosse in Virtual Reality**\n\nDive deep into the thrilling world of lacrosse like never before with LAXVR Skills, an unparalleled virtual reality experience. Crafted for both enthusiasts and novices, this game offers a chance to immerse yourself fully in the realm of lacrosse from a first-person perspective. Here's a glimpse into what awaits you:\n\n1. **Four Main Game Modes:** \n   **Shooting Mode:** Hone your shooting skills, master different techniques, and aim for that perfect shot.\n   **Goalie Mode:** Stand tall between the posts, anticipate your opponent's moves, and make that crucial save.\n   **Defender Mode:** Learn the art of defense, stop the attackers in their tracks, and reclaim the ball.\n   **The Medicine Game:** Embark on a historical journey that pays homage to the deep-rooted origins and traditions of lacrosse. Experience the soul of the game and its spiritual significance.\n\n2. **Casual Play Modes:** \n   **Wall Ball:** Perfect for those who cherish the simple joys of the game. Bounce, catch, and repeat. Sharpen your hand-eye coordination and reflexes.\n   **Free Shoot:** Sometimes, all you need is the open field, a stick, a goal, and a ball. Practice your shots or just enjoy the serenity of the virtual field.\n\n3. **Community and Competition:** \n   **Leaderboards:** Push your limits! Challenge yourself, compete with your friends, and see how you rank globally in the LAX VR community. ", "short_description": "Dive into LAXVR Skills and elevate your lacrosse game! Engage in thrilling drills: fire precision shots, stuff attackers, and de-twig attackers with decisive checks. Can you score a 2-pointer past our goalie? Stop a 12-yard step down shot? Or shut down an attacker's split dodge? Challenge awaits in every corner!"}]}, "developer_name": "Duper Studios", "developer_privacy_policy_url": "https://laxvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Duper Studios", "support_website_url": null, "website_url": "https://www.laxvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26022091307438376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982563_1037285323960834_8202808848487851216_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k5w06zlPN2wQ7kNvgFVH8mc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPJFdm1R6v3hWBZ4od-_UBEfoUuDKdGDrFeGq4emHQRQ&oe=66D6EF28"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LAXVR Skills", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1695839855, "lastRevision": {"nodes": [{"id": "9877510535656377", 