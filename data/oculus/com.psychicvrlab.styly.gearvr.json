\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3067\u3059\u3002\nSTYLY\u306b\u306f\u3001\u30d5\u30a1\u30c3\u30b7\u30e7\u30f3\u3084\u97f3\u697d\u3001\u6620\u50cf\u3001\u30b0\u30e9\u30d5\u30a3\u30c3\u30af\u306a\u3069\u3001\u73fe\u4ee3\u306e\u30ab\u30eb\u30c1\u30e3\u30fc\u3092\u4f53\u73fe\u3059\u308b\u4e16\u754c\u4e2d\u306e\u30a2\u30fc\u30c6\u30a3\u30b9\u30c8/\u30af\u30ea\u30a8\u30a4\u30bf\u30fc\u304c\u4f5c\u6210\u3057\u305f\u500b\u6027\u8c4a\u304b\u306aVR\u30b7\u30fc\u30f3\u304c10,000\u4ee5\u4e0a\u6295\u7a3f\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u3053\u308c\u3089\u30b7\u30fc\u30f3\u306b\u5168\u3066\u7121\u6599\u3067\u30a2\u30af\u30bb\u30b9\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\n\u25ef10,000\u4ee5\u4e0a\u306e\u30af\u30ea\u30a8\u30a4\u30c6\u30a3\u30d3\u30c6\u30a3\u6ea2\u308c\u308bVR\u30b7\u30fc\u30f3\u306b\u30a2\u30af\u30bb\u30b9\nSTYLY\u306b\u306f\u30a2\u30fc\u30c8/\u30d5\u30a1\u30c3\u30b7\u30e7\u30f3/\u30df\u30e5\u30fc\u30b8\u30c3\u30af/\u30a8\u30f3\u30bf\u30fc\u30c6\u30a4\u30f3\u30e1\u30f3\u30c8/\u30a2\u30fc\u30ad\u30c6\u30af\u30c1\u30e3\u30fc\u3068\u3044\u3063\u305f\u69d8\u3005\u306a\u30b8\u30e3\u30f3\u30eb\u306e10,000\u3092\u8d85\u3048\u308bVR\u30b7\u30fc\u30f3\u304c\u6295\u7a3f\u3055\u308c\u3066\u3044\u307e\u3059\u3002STYLY Gallery\u306b\u30a2\u30af\u30bb\u30b9\u3059\u308c\u3070\u3001\u3042\u306a\u305f\u306e\u304a\u6c17\u306b\u5165\u308a\u306eVR\u30b7\u30fc\u30f3\u304c\u304d\u3063\u3068\u898b\u3064\u304b\u308b\u306f\u305a\u3002\n\n\u25ef\u30de\u30a4\u30ea\u30b9\u30c8\u6a5f\u80fd\u3084\u30e9\u30a4\u30af\u6a5f\u80fd\u306b\u3088\u308a\u3001\u304a\u6c17\u306b\u5165\u308a\u306eVR\u30b7\u30fc\u30f3\u3092\u4fdd\u5b58\nSTYLY\u306b\u306f\u3001\u304a\u6c17\u306b\u5165\u308a\u306eVR\u7a7a\u9593\u3092\u30ea\u30b9\u30c8\u5316\u3067\u304d\u308b\u30de\u30a4\u30ea\u30b9\u30c8\u6a5f\u80fd\u3084\u30af\u30ea\u30a8\u30a4\u30bf\u30fc\u306e\u6700\u65b0\u306e\u4f5c\u54c1\u3092\u30c1\u30a7\u30c3\u30af\u3067\u304d\u308b\u30d5\u30a9\u30ed\u30fc\u6a5f\u80fd\u3