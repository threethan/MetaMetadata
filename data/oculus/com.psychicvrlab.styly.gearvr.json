uluscdn.com&oh=00_AYD0Tpu_HPL7Mdepha4NdcKmEogB6Eg_TBdb8N_SSmEhwQ&oe=6729F7BE"}, {"file_name": "2.png", "id": "3908518769206242", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75441574_3908518772539575_7827405150702148721_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fa6Hm348iKcQ7kNvgHh1SpJ&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAYBomVpuGe6U6MClVnhl_QWM_7gKI_PCMFels0dT5GhA&oe=672A1F8E"}, {"file_name": "3.png", "id": "272250564551247", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/57568679_272250567884580_4459073889513214597_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9jH452I_qwQ7kNvgHD9Pt_&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCuAHnJNNZIJSwdaZNAVzT0pAGSe6tpqr35j02J-HievA&oe=6729FEFD"}, {"file_name": "4.png", "id": "882416005866061", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39031545_882416009199394_5500742744697898843_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7pfZaI5mHkQ7kNvgHGXqN2&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYD9fH9ReAt8RVhPeat-UBbVknungLKSIWLA65IPRgl00A&oe=672A069D"}, {"file_name": "5.png", "id": "249808333218415", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75404374_249808336551748_7974648744233421584_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3DYqoBapZn0Q7kNvgH3U2UL&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDbYNO-QVgZn3HEZpXqz2W2N68yiBl1KEX1yjXd8tE4vw&oe=6729F708"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STYLY", "keywords": [], "long_description": "The world of expression will transform from the conventional two-dimensional space to an even richer three-dimensional space which connects us to the real world.\nSTYLY is the VR creative platform for \u201cUltra Experience\u201d created by artists all over the world.\nYou can explore over 10,000 unique VR scenes in STYLY, created by artists / creators around the world who embody modern culture, including fashion, music, video and graphics. All these scenes can be accessed for free.\n\n\u25efYou can experience over 10000 VR Scenes.\nOver 10,000 VR scenes from various genres, including art, fashion, music, entertainment, architecture, and more are gathered. By accessing the STYLY Gallery, you can find your favorite VR scenes.\n\n\u25efKeep your favorite VR scenes by LIKE and with My List.\nSTYLY provides users many features, including the My List which allows users to create lists with their favorite VR spaces, and follow other creators / check their latest works.\n", "short_description": "STYLY allows you to experience a variety of VR scenes."}, {"images": {"nodes": []}, "id": "233107141633704", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STYLY", "keywords": [], "long_description": "\u8868\u73fe\u306e\u4e16\u754c\u306f\u3001\u3053\u308c\u307e\u3067\u306e2\u6b21\u5143\u304b\u3089\u3001\u73fe\u5b9f\u4e16\u754c\u3068\u901a\u3058\u308b3\u6b21\u5143\u306e\u8c4a\u304b\u306a\u30af\u30ea\u30a8\u30a4\u30b7\u30e7\u30f3\u3078\u30fc\u30fc\u3002\nSTYLY\u306f\u3001\u4e16\u754c\u4e2d\u306e\u30a2\u30fc\u30c6\u30a3\u30b9\u30c8\u304c\u5275\u9020\u3057\u305f\u201d\u8d85\u4f53\u9a13\u201d-Ultra Experience-\u304c\u96c6\u307e\u308bVR\u30af\u30ea\u30a8\u30a4\u30c6\u30a3\u30d6\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3067\u3059\u3002\nSTYLY\u306b\u306f\u3001\u30d5\u30a1\u30c3\u30b7\u30e7\u30f3\u3084\u97f3\u697d\u3001\u6620\u50cf\u3001\u30b0\u30e9\u30d5\u30a3\u30c3\u30af\u306a\u3069\u3001\u73fe\u4ee3\u306e\u30ab\u30eb\u30c1\u30e3\u30fc\u3092\u4f53\u73fe\u3059\u308b\u4e16\u754c\u4e2d\u306e\u30a2\u30fc\u30c6\u30a3\u30b9\u30c8/\u30af\u30ea\u30a8\u30a4\u30bf\u30fc\u304c\u4f5c\u6210\u3057\u305f\u500b\u6027\u8c4a\u304b\u306aVR\u30b7\u30fc\u30f3\u304c10,000\u4ee5\u4e0a\u6295\u7a3f\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u3053\u308c\u3089\u30b7\u30fc\u30f3\u306b\u5168\u3066\u7121\u6599\u3067\u30a2\u30af\u30bb\u30b9\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\n\u25ef10,000\u4ee5\u4e0a\u306e\u30af\u30ea\u30a8\u30a4\u30c6\u30a3\u30d3\u30c6\u30a3\u6ea2\u308c\u308bVR\u30b7\u30fc\u30f3\u306b\u30a2\u30af\u30bb\u30b9\nSTYLY\u306b\u306f\u30a2\u30fc\u30c8/\u30d5\u30a1\u30c3\u30b7\u30e7\u30f3/\u30df\u30e5\u30fc\u30b8\u30c3\u30af/\u30a8\u30f3\u30bf\u30fc\u30c6\u30a4\u30f3\u30e1\u30f3\u30c8/\u30a2\u30fc\u30ad\u30c6\u30af\u30c1\u30e3\u30fc\u3068\u3044\u3063\u305f\u69d8\u3005\u306a\u30b8\u30e3\u30f3\u30eb\u306e10,000\u3092\u8d85\u3048\u308bVR\u30b7\u30fc\u30f3\u304c\u6295\u7a3f\u3055\u308c\u3066\u3044\u307e\u3059\u3002STYLY Gallery\u306b\u30a2\u30af\u30bb\u30b9\u3059\u308c\u3070\u3001\u3042\u306a\u305f\u306e\u304a\u6c17\u306b\u5165\u308a\u306eVR\u30b7\u30fc\u30f3\u304c\u304d\u3063\u3068\u898b\u3064\u304b\u308b\u306f\u305a\u3002\n\n\u25ef\u30de\u30a4\u30ea\u30b9\u30c8\u6a5f\u80fd\u3084\u30e9\u30a4\u30af\u6a5f\u80fd\u306b\u3088\u308a\u3001\u304a\u6c17\u306b\u5165\u308a\u306eVR\u30b7\u30fc\u30f3\u3092\u4fdd\u5b58\nSTYLY\u306b\u306f\u3001\u304a\u6c17\u306b\u5165\u308a\u306eVR\u7a7a\u9593\u3092\u30ea\u30b9\u30c8\u5316\u3067\u304d\u308b\u30de\u30a4\u30ea\u30b9\u30c8\u6a5f\u80fd\u3084\u30af\u30ea\u30a8\u30a4\u30bf\u30fc\u306e\u6700\u65b0\u306e\u4f5c\u54c1\u3092\u30c1\u30a7\u30c3\u30af\u3067\u304d\u308b\u30d5\u30a9\u30ed\u30fc\u6a5f\u80fd\u306a\u3069\u304c\u5099\u308f\u3063\u3066\u3044\u307e\u3059\u3002\n\u3053\u308c\u3089\u306e\u6a5f\u80fd\u3092\u4f7f\u3063\u3066\u3001\u4e16\u754c\u4e2d\u306e\u30a2\u30fc\u30c6\u30a3\u30b9\u30c8\u304c\u5275\u9020\u3057\u305fVR\u7a7a\u9593\u3092\u63a2\u7d22\u3057\u304a\u6c17\u306b\u5165\u308a\u30ea\u30b9\u30c8\u3092\u4f5c\u6210\u3057\u307e\u3057\u3087\u3046\u3002", "short_description": "STYLY\u3067\u306f\u69d8\u3005\u306aVR\u30b7\u30fc\u30f3\u304c\u4f53\u9a13\u53ef\u80fd\u3067\u3059\u3002"}]}, "developer_name": null, "developer_privacy_policy_url": "https://styly.cc/styly-service-privacy-policy/", "developer_terms_of_service_url": "https://styly.cc/styly-terms-of-use/", "publisher_name"