sn-CAJnA9ucFNJeV-vZjw&oe=67334FBE"}, {"file_name": "migrated_image.png", "id": "197753348195831", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001681_628152247697827_1340700004523704320_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=51eS7Rk0eTAQ7kNvgEhDt_L&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfPRzXOWARrR0BBx7-kLGmt9KoTUwnpY1Ylm2Sr2gRlA&oe=6733476C"}, {"file_name": "migrated_image.png", "id": "503515603653362", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974479_2899613513510282_8320205423130968064_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZUAYrSJJmcQ7kNvgHjiqhC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADFRD_AM8Gl-8n-Mu7nhp9gB9fI_NRmtTPvns3WdNM9w&oe=6733408A"}, {"file_name": "migrated_image.png", "id": "800375970472797", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982587_2369010843386418_857954347697307648_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MlUzJtsZfYkQ7kNvgFXyTo3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFOSGfXeZdZvkKh5xkMjVUjZQd6LPHz_tzAjuQfYfMiQ&oe=673337AD"}, {"file_name": "migrated_image.png", "id": "516998989005107", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982701_2132798307018173_6530639606273015808_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HsNivswAUZcQ7kNvgHejpu6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAj6v1PiJmGqDb8vJCN8UYVXeIEYGAuJaMCtPk06y1oWA&oe=673344EB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gadgeteer", "keywords": ["ruberg", "rube", "physics", "contraption", "machine"], "long_description": "Gadgeteer is a physics-based VR puzzle game where you build chain reaction machines to solve fun, intricate puzzles. Your machines will use gadgets to launch, bump, twist, and turn\u2014creating chain reactions that may even end up tearing apart the fabric of space-time.\n\nPrepare your wits because you'll need them to build your masterpiece!\n\nPUZZLE MODE:\nSolve 60 physics puzzles in endless ways.\n\nSANDBOX MODE:\nBuild your dream machine without any rules but the rules of physics. When you're done, share your masterpiece or experience the engineering marvels of others.\n\nFEATURES:\n- Build with freedom. No restrictions on where and how you build your incredible machines.\n- Chain together 50+ unique gadgets to build your crazy machines.\n- Create, edit, destroy with 3 powerful toolheads.\n- Painlessly undo your mistakes.\n- Infinite replayability with lots of depth.", "short_description": "Gadgeteer is a physics-based VR puzzle game where you build chain reaction machines to solve fun, intricate puzzles. Your machines will use gadgets to launch, bump, twist, and turn\u2014creating chain reactions that may even end up tearing apart the fabric of space-time."}]}, "developer_name": "Metanaut", "developer_privacy_policy_url": "http://metanautvr.com/privacypolicy", "developer_terms_of_service_url": "https://metanautvr.com/gadgeteer-eula/", "publisher_name": "Metanaut", "support_website_url": "https://www.reddit.com/r/gadgeteergame/", "website_url": "https://gadgeteergame.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "987981031798532"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "510234585343551"}, {"status": "PUBLISHED", "id": "1