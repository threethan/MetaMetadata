sid=6e7a0a&_nc_ohc=irhm3eShj1gQ7kNvgEs0fKb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdAzw2iJWLhFAYzw6141ZTpR2wnE1P9vdYKJnJ4SpIDQ&oe=67544239"}, {"file_name": "Screenshot_20230904_203452.png", "id": "610020447986805", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982675_610020451320138_2735289997432158872_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eM2nvk_3AmAQ7kNvgFpxqtu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2oyLX4IApqplki4NuSQyYTD0Bq6bhHW15VYJ78afN1Q&oe=67543B6C"}, {"file_name": "Screenshot_20230828_172310.png", "id": "300478555953156", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_300478562619822_8806227422623848698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8hZ8OK-cTE0Q7kNvgH2tKOx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUrYmh1KxerxrR9EY9tl1GlzGc0V7T5_SJUwGEhfAkrw&oe=67542D2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "325625909929158", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982457_325625913262491_8659356926128038723_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4DcYHi96t-IQ7kNvgHl8uO_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDj8nxFTe9BjVnGepImUsXXLAEYK8FTst6GO4-YVFkRjw&oe=67544A9C"}, "display_name": "Fantasia Canvas", "keywords": [], "long_description": "Fantasia Canvas invites you to seamlessly transition from the bustling demands of daily life into an atmosphere of tranquility and relaxation.\n\nColoring vivid miniatures is a truly mesmerizing and engaging experience, complemented by a perfect harmony of effects, sounds, and surroundings designed to alleviate the stresses of a hectic day.\n\nThe game doesn't require any physical or in-game movement from you. You can play it comfortably both while standing and sitting. And the entire gameplay is exceptionally smooth, enveloping you in a meditative atmosphere.\n\nOur team is preparing numerous new exciting episodes for you to enjoy soon.\n\nEmbark on this engaging adventure and experience the meditative power of VR with a painting journey.", "short_description": "Fantasia Canvas invites you to seamlessly transition from the bustling demands of daily life into an atmosphere of tranquility and relaxation.\n\nColoring vivid miniatures is a truly mesmerizing and engaging experience, complemented by a perfect harmony of effects, sounds, and surroundings designed to alleviate the stresses of a hectic day.\n\nEmbark on this engaging adventure and experience the meditative power of VR with a painting journey."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fantasia.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fantasia Games", "support_website_url": null, "website_url": "https://fantasia.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "ru", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "852132063143126"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "10088472994527789", "version": "1.0.1"}, "id": "1459403621485398", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBina