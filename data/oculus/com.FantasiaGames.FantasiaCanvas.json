t=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RnyWHLJm1FYQ7kNvgHQuwVu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAbAloFkhmMhBDZ2vB-WZHWGFHMkeX4z_wPDZNoOY3cg&oe=676E996C"}, {"file_name": "Screenshot_20230828_172310.png", "id": "300478555953156", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_300478562619822_8806227422623848698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZD-tJ96R-BAQ7kNvgFJA6Ns&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4z8a7yVbLEqHvurtcD08Vk2dv3p-AKAnMDlht4Zpasg&oe=676E8B2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "325625909929158", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982457_325625913262491_8659356926128038723_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bTH6DH0BPmUQ7kNvgG7AfYf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCe1rM0BwiNgE41-pJyQ_JAp7bVVk1C8MopIbZAqfoIGQ&oe=676EA89C"}, "display_name": "Fantasia Canvas", "keywords": [], "long_description": "Fantasia Canvas invites you to seamlessly transition from the bustling demands of daily life into an atmosphere of tranquility and relaxation.\n\nColoring vivid miniatures is a truly mesmerizing and engaging experience, complemented by a perfect harmony of effects, sounds, and surroundings designed to alleviate the stresses of a hectic day.\n\nThe game doesn't require any physical or in-game movement from you. You can play it comfortably both while standing and sitting. And the entire gameplay is exceptionally smooth, enveloping you in a meditative atmosphere.\n\nOur team is preparing numerous new exciting episodes for you to enjoy soon.\n\nEmbark on this engaging adventure and experience the meditative power of VR with a painting journey.", "short_description": "Fantasia Canvas invites you to seamlessly transition from the bustling demands of daily life into an atmosphere of tranquility and relaxation.\n\nColoring vivid miniatures is a truly mesmerizing and engaging experience, complemented by a perfect harmony of effects, sounds, and surroundings designed to alleviate the stresses of a hectic day.\n\nEmbark on this engaging adventure and experience the meditative power of VR with a painting journey."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fantasia.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fantasia Games", "support_website_url": null, "website_url": "https://fantasia.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "ru", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "852132063143126"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982469_688155379440471_968527184404160470_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VgEki1-v5n4Q7kNvgExQnwu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpwiklFz9YtXfC5F1jr9AFgAKX_8PKBmk4I20RANEyxA&oe=676EA8B2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Fantasia Canvas", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "release_date": 1694021766, "lastRevision": {"nodes": [{"id": "10043841318990957", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"ap