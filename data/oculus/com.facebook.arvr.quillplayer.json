n.com/v/t64.5771-25/38982571_1631285461137461_4302012558881163548_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SX0GdKl1rY0Q7kNvgEEf7JG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrJ3WXQcwsw8vp5iYSGFSEmBoAE8UqECXtRo68LaFbXA&oe=675AD29D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_2560x1440.png", "id": "1040588121135362", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974508_1040588131135361_6327032771678843995_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mMJd5Uj7xHgQ7kNvgGpbZz0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUoCySjO0j9PEYBxLe-aPJum_x_EzfYFSWgvuv1wcksQ&oe=675ACAAE"}, "display_name": "Theater Elsewhere", "keywords": ["quill", "art", "media", "story", "animation"], "long_description": "Dive into art that lives elsewhere, hand painted and animated by creators from all over the world. Enjoy expressive characters, delightful moments, and long form narratives in virtual reality. Theater Elsewhere brings the magic to you.  \n\nFeaturing:\n- 2400+ delightful immersive animated content\n- 6 beautiful immersive backgrounds that can be set as the default browsing environment\n- Intuitive and fast user interface\n- Freefly Mode that allows users to move freely within each experience\n\nIf you would like to share your own creations, test your hand in the VR painting and animation app, Quill by Smoothstep, available on the Meta Quest PCVR platform, upload your content through Meta Quest Media Studio and it will appear in the \u201cNewest\u201d section of Theater Elsewhere.  \n\nQuill by Smoothstep\n\nhttps://www.meta.com/experiences/pcvr/quill-by-smoothstep/5910229332328230/\n\nMeta Quest Media Studio\n\nhttps://creator.oculus.com/manage/mediastudio/\n", "short_description": "Dive into art that lives elsewhere, hand painted and animated by creators from all over the world. Enjoy expressive characters, delightful moments, and long form narratives in virtual reality. Theater Elsewhere brings t