_AYDZIAW-KOM5opW1EFUWOLidD04Er1U2IomiMy6oCrJeVA&oe=675AE9A4"}, {"file_name": "migrated_image.png", "id": "1307113416335272", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982481_719842158522703_3431715943661699072_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kg_7snyZn_MQ7kNvgEdZ2BL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALw9NgWvx5gOXoE9xdAfC_rPuEI71RLxwPXtcz-BwErg&oe=675AE220"}, {"file_name": "migrated_image.png", "id": "2621666021452696", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974447_2602922926464209_3477359222541254656_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IFZUHH96QRMQ7kNvgHeVepy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYFvJliJ0KHvY49N59gLWamvzPrnWraEaawaMF76pMyA&oe=675ADD91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/0v0bKO", "id": "431345634210355", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269160_431345637543688_191274663425343488_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cg5NMWdRj24Q7kNvgFpaP57&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSdDsAGN3sFbFN_SpX73uHuCfz2BvV8wVkPpWvIsXNOA&oe=675ACDF0"}, "display_name": "Quill Theater", "keywords": ["quill", "art", "media", "story", "narrative"], "long_description": "Step into wonderful, immersive VR stories, hand painted and animated in VR with Quill. These VR stories not only let your view a painting on a wall, but transport you into the painting itself. Experience expressive characters, fantastic creatures, and complete narratives in these VR animations. . \n\nRegularly updated, the Quill Theater lets you visit high quality immersive  animations from the comfort of Oculus TV, bringing you the best in immersive entertainment. \n\nThese immersive animations are fully 6DOF, some including multiple viewpoints to let your move positionally within the art, and the ability for you to both \u201cPause\u201d the story to take in every brush stroke, and \u201cStart\u201d to bring the story back to life! \n\nTo create your own VR stories, test your hand in the VR illustration and animation tool, Quill, available on the Rift platform. https://www.oculus.com/experiences/rift/1118609381580656/\n\nRequires the latest version of Oculus TV.", "short_description": "Step into wonderful VR stories, hand painted and animated in VR with Quill. These VR stories not only let your view a painting on a wall, but transport you into the painting itself. Experience expressive characters, fantastic creatures, and complete narratives in these VR animations. \n\nRegularly updated, the Quill Theater lets you visit high quality immersive  animations from the comfort of Oculus TV, bringing you the best in immersive entertainment. \n\nRequires the latest version of Oculus TV."}]}, "developer_name": "Facebook Technologies, LLC", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Facebook Technologies, LLC", "support_website_url": "https://quill.fb.com/support/", "website_url": "https://quill.fb.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "MEDIA_PLAYER", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1022951591901985"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "441100279911646"