5/38974444_2374125652821643_5221594318174683136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zhog7QHNLY0Q7kNvgEnFdB0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjPLWfo2q4tAcMFvbgEbB5VGyKRpU3s6BH0lQO2HYKTA&oe=66CC62D0"}, {"file_name": "migrated_image.png", "id": "160935941682878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974897_1314608455356236_8536830147473440768_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLim7jRzaTgQ7kNvgEgHNcg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMRSbY07zvsUWzhyE8f67x9R-AIW9mxrITmmBrSJvTOg&oe=66CC6F31"}, {"file_name": "migrated_image.png", "id": "981824885552431", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974607_1220619491430615_8775075990587047936_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yNVJE1UGa9sQ7kNvgHq6IuN&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXAxi00AhDCbFtzvx-vluoF1cpX4od3o4jKTU2jwhtFA&oe=66CC7BE6"}, {"file_name": "migrated_image.png", "id": "196174435136250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_452065525529300_581180156857548800_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GaWICqKtMG8Q7kNvgFEbv9t&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKWzlw9oVJiRimrFhVK8RUtpq3GjdU25DWhsWo8y9cJw&oe=66CC68CB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Electronauts", "keywords": ["music", "creative", "dance", "electronauts", "casual"], "long_description": "Ever wanted to ride the vibes of a top DJ playing a packed festival\u2019s main stage? Here\u2019s your chance to shine: all it takes to be an Electronaut is the passion to become one with the beat. Create music with confidence, no matter your skill level, as you make music magic in this VR-exclusive experience featuring 80-plus songs from over 80 top artists across EDM, hip hop, trap, and countless other genres.\nExplore. Experiment. Electrify: Jam on eight digital instruments only possible in VR arrayed on a customizable deck. Record loops and sequences, layer filters, mashup and arrange songs to your style as you make them your own.\nMusic Reality Engine\u2122: Electronauts\u2019 proprietary technology always keeps your sounds bumpin\u2019 on beat, no matter how much you mix.", "short_description": "Immerse yourself in an interactive sonic environment where you build, drop, remix, and jam on 80+ songs from over 80 artists. Mix your own songs, crush sets, and express yourself like never before. Electronauts sets the stage for you to DJ, perform, and make music magic in virtual reality."}]}, "developer_name": "Survios", "developer_privacy_policy_url": "https://survios.com/studio/privacy/", "developer_terms_of_service_url": "https://survios.com/studio/terms/", "publisher_name": "Survios", "support_website_url": null, "website_url": "https://survios.com/electronauts/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3203824519946872"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031422_2376209489131723_8775444838083461120_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpfJ5lnm2i4Q7kNvgFY_wt9&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaG_0DVrSe4jLxY_EGF8_HUqmQM2lWiqHzi4nS7jWSsg&oe=66CC5681"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Electronauts", "platform": "ANDROID_6DOF", "con