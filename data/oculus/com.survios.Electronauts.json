h=00_AYD28xFkgDEosBTMyigBz0IOgz6q3LeE5Yvjzh7_Seq-qg&oe=676D5999"}, {"file_name": "migrated_image.png", "id": "203960004035262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974444_2374125652821643_5221594318174683136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T9cKEuFmEZYQ7kNvgF60GZw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBm3D49gIbDd6eKVOEI68l3GFDJpviodZzEmby8Chp6kw&oe=676D39D0"}, {"file_name": "migrated_image.png", "id": "160935941682878", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974897_1314608455356236_8536830147473440768_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1iSGn3cgcXMQ7kNvgFF5uI6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLMwB8Lr9Q3eHPQ1CwUsBd1ZkvU20RAyFx_rb0wjAgbQ&oe=676D4631"}, {"file_name": "migrated_image.png", "id": "981824885552431", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974607_1220619491430615_8775075990587047936_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mLnQ1vhSOkkQ7kNvgHyaYBe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARNEGzkwefZvmxSsxLsLp9MIWsetdfKcr2uW7HWqTyMg&oe=676D52E6"}, {"file_name": "migrated_image.png", "id": "196174435136250", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031344_452065525529300_581180156857548800_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mTwfqHVuM00Q7kNvgHbj8c6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmdvXMS3gO0D7ZZupTR6wVVo0V1NK2kypbWXTaNPyKIQ&oe=676D3FCB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Electronauts", "keywords": ["music", "creative", "dance", "electronauts", "casual"], "long_description": "Ever wanted to ride the vibes of a top DJ playing a packed festival\u2019s main stage? Here\u2019s your chance to shine: all it takes to be an Electronaut is the passion to become one with the beat. Create music with confidence, no matter your skill level, as you make music magic in this VR-exclusive experience featuring 80-plus songs from over 80 top artists across EDM, hip hop, trap, and countless other genres.\nExplore. Experiment. Electrify: Jam on eight digital instruments only possible in VR arrayed on a customizable deck. Record loops and sequences, layer filters, mashup and arrange songs to your style as you make them your own.\nMusic Reality Engine\u2122: Electronauts\u2019 proprietary technology always keeps your sounds bumpin\u2019 on beat, no matter how much you mix.", "short_description": "Immerse yourself in an interactive sonic environment where you build, drop, remix, and jam on 80+ songs from over 80 artists. Mix your own songs, crush sets, and express yourself like never before. Electronauts sets the stage for you to DJ, perform, and make music magic in virtual reality."}]}, "developer_name": "Survios", "developer_privacy_policy_url": "https://survios.com/studio/privacy/", "developer_terms_of_service_url": "https://survios.com/studio/terms/", "publisher_name": "Survios", "support_website_url": null, "website_url": "https://survios.com/electronauts/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "MUSIC"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8860267324094078"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031422_2376209489131723_8775444838083461120_n.png?stp=dst-png_s36