98", "locale": "en_US", "screenshots": [{"file_name": "2_Skellys.png", "id": "518116167583659", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75411991_518116170916992_7297976181162357139_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxtjYLgmVUAQ7kNvgFRucWG&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAboLv_3Fobz8XxgEhf8iRDU7RZha6XV-xc7DsC-K53Q&oe=67066D4D"}, {"file_name": "SPOILER_Freeze_tag_render.png", "id": "1105890251107742", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035348_1105890254441075_8920079678906154812_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o1VxTcF-hiYQ7kNvgEghMEG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCALUca1ESKqMKwY_-08kSsgf183ZMMa1RjGOLg5pJJqQ&oe=670686C7"}, {"file_name": "What_Happened_.png", "id": "507784381980507", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262746_507784385313840_8907246316856751473_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4XXqeOLwXT4Q7kNvgHsi9FJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7UDPTWzwhgHoIrB8SSVSCJxxOTS8fA9z0jZIGdhxM5g&oe=670670B7"}, {"file_name": "Skelly_Lobby_Leak1.png", "id": "883055507218736", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_883055510552069_6202024101949124698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BmRYS8AOxikQ7kNvgE42g9i&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7AHQOc3Dpe_VpDgIQrM3ji7wor-JU8ISGt3feY0k6GA&oe=6706504A"}, {"file_name": "SPOILER_rgb_render.png", "id": "2846110012231381", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75584096_2846110015564714_8502869453271173333_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7SHlzKFiMAoQ7kNvgGq2s_6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNm6MOPIdrOUAMimuRW_VsrUMRgYd_lg_8wWrSS4iXeg&oe=670671DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "New Project (1).png", "id": "402912782857965", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75608434_402912786191298_9107133272886868732_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gOav9nx9nO0Q7kNvgHpBNUy&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDG_d6SxltHOgS8mhUhN9KUBE-hvv24mwQ9rJqm-hwPAQ&oe=67067366"}, "display_name": "Skelly", "keywords": [], "long_description": "Hop in with your friends and play around as a skeleton in a bright and colorful world that we call Skelly! Hangout in the lobby with fellow Skelly's, play any of our 3 action packed game modes and check out our rotating shop with many items to wear and hold to be the coolest Skelly!\n\nGame Modes:\nKnockout - Knockout is a fast paced, action packed game mode where the last person alive wins! Punch people, use baseball bats, grenades, smoke bombs and blasters to knock people off the map to claim your crown as the winner of Knockout!\n\nCapture the Bone - Up to 14 players go head to head in a blue vs red capture the bone match! Play defense and punch people away from your bone, play offense and grab the bone at the enemy base and bring the bone back to get the ultimate reward of scoring a point for your team! \n\nFreeze Tag - Don't let the freezers freeze you... RUN!! If a fellow runner gets frozen into an ice cube, grab a bone and crack them out! \n\nJoin the Skelly Discord - https://discord.gg/skellyvr", "short_description": "Hop in with your friends and play around as a skeleton in a bright and colorful world that we call Skelly! Hangout in the lobby with fellow Skelly's, play any of our 3 action packed game modes, Knockout, Capture the Bone and Freeze Tag! Check out our rotating shop with many items to wear and hold to be the coolest Skelly!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://skellystudios.xyz/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Skelly Studios", "support_website_url": null, "website_url": "https://skellystudios.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_catego