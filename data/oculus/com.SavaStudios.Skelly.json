7Kg&oe=676572C7"}, {"file_name": "What_Happened_.png", "id": "507784381980507", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262746_507784385313840_8907246316856751473_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1x7MFisPugAQ7kNvgEizdiw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSK_NXojKQcEXcpbZYjN3Lke5a2iw1OI7NNKjF7V6dhA&oe=67655CB7"}, {"file_name": "Skelly_Lobby_Leak1.png", "id": "883055507218736", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_883055510552069_6202024101949124698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aGUuSTuHgV0Q7kNvgFdI3B7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8OOaojEHu6mTYja5VB3yugcEsPmZtE3zHw1v0uoZQ1Q&oe=6765748A"}, {"file_name": "SPOILER_rgb_render.png", "id": "2846110012231381", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75584096_2846110015564714_8502869453271173333_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KUUpocMafhAQ7kNvgF9GOup&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvg9LcPDnjXpH7kN8Is6IQc3j0WGHH4prcC19RD3Rtlg&oe=67655DDF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "New Project (1).png", "id": "402912782857965", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75608434_402912786191298_9107133272886868732_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xG_cd-n3C7YQ7kNvgF38mh0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnLLcPW-rkrBTWinltpJO0AwU2Mo8RLtl3n12sbnxb5w&oe=67655F66"}, "display_name": "Skelly", "keywords": [], "long_description": "Hop in with your friends and play around as a skeleton in a bright and colorful world that we call Skelly! Hangout in the lobby with fellow Skelly's, play any of our 3 action packed game modes and check out our rotating shop with many items to wear and hold to be the coolest Skelly!\n\nGame Modes:\nKnockout - Knockout is a fast paced, action packed game mode where the last person alive wins! Punch people, use baseball bats, grenades, smoke bombs and blasters to knock people off the map to claim your crown as the winner of Knockout!\n\nCapture the Bone - Up to 14 players go head to head in a blue vs red capture the bone match! Play defense and punch people away from your bone, play offense and grab the bone at the enemy base and bring the bone back to get the ultimate reward of scoring a point for your team! \n\nFreeze Tag - Don't let the freezers freeze you... RUN!! If a fellow runner gets frozen into an ice cube, grab a bone and crack them out! \n\nJoin the Skelly Discord - https://discord.gg/skellyvr", "short_description": "Hop in with your friends and play around as a skeleton in a bright and colorful world that we call Skelly! Hangout in the lobby with fellow Skelly's, play any of our 3 action packed game modes, Knockout, Capture the Bone and Freeze Tag! Check out our rotating shop with many items to wear and hold to be the coolest Skelly!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://skellystudios.xyz/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Skelly Studios", "support_website_url": null, "website_url": "https://skellystudios.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8121842007883841"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1149748869700356"}]}, "baseline_offer": 