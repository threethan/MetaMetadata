0FFE"}, {"file_name": "3.png", "id": "2245538989150890", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572954_2245538992484223_8598079660398496648_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t05_RPZbPZMQ7kNvgHrvCmL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpM6Qmm3rtcXmA8ShXvmH6I6whr1SZwDteZgZySz5hCA&oe=6768157C"}, {"file_name": "2.png", "id": "2673319909520060", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982510_2673319912853393_2503569918825159240_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-IjZuZzmyGkQ7kNvgFkaNRK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0sx8RqkCaRcXf9DXgIusC3ekveNZx6CKQBT6F0rCVwA&oe=67681257"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Drum Circle Cover Art (2560 x 1440 px) (1).png", "id": "1161447404916858", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982625_1161447408250191_2650284731583729103_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ubBwE2AzJy0Q7kNvgESDaUa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-ig9f3X7upNFcQr-P8gVCOqSuY6D8SsflmcJXSER4NA&oe=6767F582"}, "display_name": "Drum Circle", "keywords": ["Drum", "Music", "Piano", "Jam", "Songs"], "long_description": "Unleash your inner musician with *Drum Circle*! Step into a vibrant virtual world where you can play a variety of instruments using just your hands. Whether you're grooving on the conga drums, tapping out rhythms on the bongos, creating melodies on a keyboard, or shaking maracas to the beat, *Drum Circle* brings the joy of music-making to life in immersive VR.\n\n**Features:**\n- Play a range of instruments: congas, bongos, keyboards, and maracas!\n- Play along with *music tracks* or create your own rhythms and melodies\n- Intuitive hand-tracking lets you perform naturally without controllers\n- Get real-time feedback to stay on beat with BPM Indicator mode\n- Use passthrough to enhance real-world collaboration and participate in live music sessions\n\nGet ready to feel the rhythm, unleash your creativity, and make music like never before with *Drum Circle*!", "short_description": "Unleash your inner musician with Drum Circle! Step into a vibrant virtual world where you can play a variety of instruments using just your hands. Whether you're grooving on the conga drums, tapping out rhythms on the bongos, creating melodies on a keyboard, or shaking maracas to the beat, Drum Circle brings the joy of music-making to life in immersive VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisanreality.com/privacy-policy-for-drum-circle", "developer_terms_of_service_url": null, "publisher_name": "Artisan Effects", "support_website_url": null, "website_url": "https://artisanreality.com/drum-circle", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9617642184917022"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330719_893663626159359_5302583485306378745_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TYJCRjQOxycQ7kNvgGFMTAw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpD4ddLJGdVXUIToeBQi12-OKhv7q7FWmXkgF_abYfZg&oe=6768151F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Drum Circle", "platform": "ANDROID_6D