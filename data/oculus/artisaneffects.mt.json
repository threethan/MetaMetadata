24FE"}, {"file_name": "3.png", "id": "2245538989150890", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57572954_2245538992484223_8598079660398496648_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4c6bI14C8jsQ7kNvgG35FJQ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC6nu5i0FSXD4DfCBoGWmR9EnUGSbmaZeTRn6-bJIMrDA&oe=67262A7C"}, {"file_name": "2.png", "id": "2673319909520060", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982510_2673319912853393_2503569918825159240_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GJg3II6NTTQQ7kNvgHOQwdC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA5XZkSj_guLIMiv17HCv18HomRFX9EBUfPq1Ms_dW8AQ&oe=67262757"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Drum Circle Cover Art (2560 x 1440 px) (1).png", "id": "1161447404916858", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982625_1161447408250191_2650284731583729103_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=twNN4w_6zvgQ7kNvgH_Szve&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDtlY4AelAubuA_-I_vklm_oIqwGTbuPjnXO-gnGYs3gQ&oe=67260A82"}, "display_name": "Drum Circle", "keywords": ["Drum", "Music", "Piano", "Jam", "Songs"], "long_description": "Unleash your inner musician with *Drum Circle*! Step into a vibrant virtual world where you can play a variety of instruments using just your hands. Whether you're grooving on the conga drums, tapping out rhythms on the bongos, creating melodies on a keyboard, or shaking maracas to the beat, *Drum Circle* brings the joy of music-making to life in immersive VR.\n\n**Features:**\n- Play a range of instruments: congas, bongos, keyboards, and maracas!\n- Play along with *music tracks* or create your own rhythms and melodies\n- Intuitive hand-tracking lets you perform naturally without controllers\n- Use passthrough to enhance real-world collaboration and participate in live music sessions\n\nGet ready to feel the rhythm, unleash your creativity, and make music like never before with *Drum Circle*!", "short_description": "Unleash your inner musician with Drum Circle! Step into a vibrant virtual world where you can play a variety of instruments using just your hands. Whether you're grooving on the conga drums, tapping out rhythms on the bongos, creating melodies on a keyboard, or shaking maracas to the beat, Drum Circle brings the joy of music-making to life in immersive VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisanreality.com/privacy-policy-for-drum-circle", "developer_terms_of_service_url": null, "publisher_name": "Artisan Effects", "support_website_url": null, "website_url": "https://artisanreality.com/drum-circle", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "514087707868786"}, {"id": "2687655338230691"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9382183541796222"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75330719_893663626159359_5302583485306378745_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hu4IT0HG7sAQ7kNvgFk-Kv1&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCOqYx1Xu-oRZat5iNLWwe63AJeeZCqj6XyX8p_Lg9ocw&oe=67262A1F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Drum Circle", "platform": "ANDROID_6DOF", "context_category": {"context_cate