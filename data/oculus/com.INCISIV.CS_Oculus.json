.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fI4MCyZ6lx0Q7kNvgGcsNVL&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAG3t1AMpuF_HCpWm0vk14kB6cXYONU3Rzl5MwEzENY-A&oe=673081F6"}, {"file_name": "ScreenShot30.png", "id": "3018567605026697", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75207238_3018567611693363_7580319390470995157_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hWAGrfo3uvgQ7kNvgFZWuEN&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAuoUPB4l1K6kxGaFfP6Os64HFpdqfimZEN6TZ_e6aSig&oe=6730A1B5"}, {"file_name": "ScreenShot20.png", "id": "7007902192583301", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75404387_7007902202583300_6002235336908425173_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgsqY4Salv8Q7kNvgGQyuTe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCF8Sz0teCcgGNdMZHmtHJG4DnD2bYoR3SB9v_iweXVXQ&oe=67309685"}, {"file_name": "ScreenShot40.png", "id": "652957112512679", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86634394_652957125846011_7033100691724568704_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e7WQ_0AAuJsQ7kNvgFMGOWk&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBCD31mI6gyN6xv3vSkWGswMKpxnciwje_ZeYagVbtLzA&oe=6730B45D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Incisiv Cleansheet__CoverImageSafeAreaTemplateLandscape_2560x1440px.png", "id": "632708781347232", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974504_632708784680565_8218995193895721669_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3LmCrqWmJKUQ7kNvgGTFIMz&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDYZgM5IkpQlJHnpSuRsjZI407uqModcOT2wabDKKbUAQ&oe=67307FAA"}, "display_name": "Cleansheet", "keywords": [], "long_description": "From the creators of goalkeeping technology used by professional football clubs throughout the world, CleanSheet is now ready to play in the comfort of your living room for the Oculus platform. Train like the pros and sharpen your decision-making, awareness, and reactions using cutting-edge ball physics.\n\nKEY FEATURES:\nIntelligent AI scales shots to your body size\nRealistic Ball Physics generate match-like shots\nSurvival Quickfire mode trains decision-making\nSet Play mode (COMING SOON)\n\nGAME CREDITS:\nMr Howard van Waard - Lead Developer\nDr James Stafford - Lead Game Project Manager/Marketing\nProf Cathy Craig - Research & Development Lead\nDr Adrien Kissenpfennig - Tech Oversight Lead\nMr Neven Kissenpfennig - Design Lead\n\nPhotos: Jeffrey F Lin/Rhett Lewis (www.unsplash.com)\nMusic: Chosic (www.chosic.com/free-music/all/)\n\n\n\n", "short_description": "The VR game used by professional football clubs throughout the world is now ready to play in your own living room. Cleansheet is based on 20 years scientific research to determine what makes a goalkeeper great. Sharpen your reactions, awareness, and timing using realistic physics that have been shown to scientifically improve goalkeeping performance."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.incisiv.tech/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "INCISIV Ltd", "support_website_url": "https://www.incisiv.tech/#footer-contact-form", "website_url": "https://www.incisiv.tech/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "