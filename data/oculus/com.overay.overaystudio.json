ontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974767_542494358471530_7595171324725982555_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8NXV_G0Fn9AQ7kNvgF1mwTJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAjr5Kjk9dWbfk4WlYBDbNEcNmsJ5pAn-5a83xHGZpluw&oe=6724B177"}]}, "id": "498945849636178", "locale": "en_US", "screenshots": [{"file_name": "screen-01.png", "id": "1282212269802601", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974698_1282212273135934_4472800857484779926_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=511WlIalek8Q7kNvgEZxY4e&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCvmce5iWIug699_fLM9VOeMOtCPKoWUu8b4G9qgqMdGA&oe=6724B6F0"}, {"file_name": "screen-02.png", "id": "1651493395422430", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75608442_1651493398755763_4556322552469627481_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXwRj6zrhhAQ7kNvgH9ovr_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBmeFqRTb6lKwyxENrB4qJoQUQm8TPrq4GcA2qYm3ex2g&oe=6724CC66"}, {"file_name": "screen-03.png", "id": "8126704710788463", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984460_8126704757455125_108881668196644069_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EoXKOQKt3AsQ7kNvgEFRIp7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCg_AwfEApZsX9N6nMT3XBi6qtuGRjnFfBhgJWzyo7Kjw&oe=6724D747"}, {"file_name": "screen-04.png", "id": "1579239319342090", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035332_1579239322675423_7428975662956517976_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qoRham6gYFgQ7kNvgF2FZQF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBVVRMvt0u7PgyVjXRQ0bhiViQo5wTVQlUp0jbKqOo_Hg&oe=6724C548"}, {"file_name": "screen-05.png", "id": "1071700544544178", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569458_1071700547877511_3894759084831309614_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M-bho0VXaUsQ7kNvgGh-68R&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDYbbiJ3r35ZqAd7BDrSh5PBcFOLOyw8PYls6KrRFBHQw&oe=6724D2D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailor-cover.png", "id": "1928607067623101", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031493_1928607070956434_5898141224729612957_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mYBzW26fFZMQ7kNvgEG_tyn&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBjXwRVCNRRq2c1svJOfWSuXujkO2sJltl9j-KRaFxcfQ&oe=6724CBED"}, "display_name": "OVERAY STUDIO", "keywords": ["Productivity", "VirtualOffice", "MultiMonitor"], "long_description": "OVERAY STUDIO is not just another virtual workspace; it's a fusion of immersive experience and practicality, tailored for both professionals and enthusiasts. At its core, this platform provides access to essential features completely free of charge. Users can effortlessly integrate up to five virtual monitors, enjoying the freedom to customize their spatial layout or opt for our handy preset configurations. The software seamlessly syncs with Windows, ensuring an automatic match with your monitor layout for a frictionless experience.\n\nBoasting an intuitive user interface, controlling your spatially arranged monitors becomes second nature. Paired with user-friendly passthrough capabilities, you can immerse yourself in a variety of virtual spaces provided at no additional cost, turning mundane tasks into engaging experiences.\n\nWhile OVERAY STUDIO is currently in its beta phase and there may be areas awaiting refinement, your support fuels our passion. We're committed to enhancing the platform, with upcoming features set to redefine the PC-VR integration landscape. Dive into the future of productivity with OVERAY STUDIO, and be a part of this pioneering journey.", "short_description": "Enjoy your elevated virtual workspace with OVERAY STUDIO \u2013 Your free gateway to an immersive VR-PC integration."}]}, "developer_name": "Overay Inc.", "developer_privacy_policy_url": "