uluscdn.com/v/t64.5771-25/39001724_2843277822473867_5827143783894822490_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNbGUcEFAKoQ7kNvgGcYcvU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKl5RsTFC-9oVDT4HuCBPPD&oh=00_AYAu6YyJdFca6OLQw24qlpj02KlqIdWrQBwAtZAKDpChlg&oe=66F1572C"}, {"file_name": "8.png", "id": "781253063329377", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974732_781253066662710_4858183234566166318_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=srt3jRDtPZMQ7kNvgHI_2UL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKl5RsTFC-9oVDT4HuCBPPD&oh=00_AYC67xEpliM4yWF1ZF3O9H6meyRA0Mn3To1D8iu9eqwyNQ&oe=66F144CF"}, {"file_name": "6.png", "id": "940819263893066", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031628_940819267226399_2397100471894061859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TV6OI3QSclAQ7kNvgF7gURh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKl5RsTFC-9oVDT4HuCBPPD&oh=00_AYAq7qFlSm6JyUWWzj_gnpcxvcP85eb0f8FuWkbBE7abWQ&oe=66F16CEA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DISUKU (2).png", "id": "1427444654739536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_1427444658072869_3041765525580465306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=blPH38cQ3GEQ7kNvgEbt8ES&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKl5RsTFC-9oVDT4HuCBPPD&oh=00_AYAlV7_6Fsr5IQJOlHkkKte37xEolR7IgnDfjp4i0xQXOg&oe=66F15089"}, "display_name": "Disuku", "keywords": [], "long_description": "Join us for a sneak peek at our early-stage VR game, Zero-G Disc Tag, code-named Disuku! \n\nWith two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n\nJoin our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN \n\nGet ready to challenge your reflexes and strategy skills in Zero-G Disc Tag!", "short_de