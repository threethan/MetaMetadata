uluscdn.com/v/t64.5771-25/39001724_2843277822473867_5827143783894822490_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNbGUcEFAKoQ7kNvgEqp8ei&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjckdoAFPpWHHfoSzUjyqXY&oh=00_AYBAjeRKQG3SEnixTXaDeeucDo6FdYoaa2xsIHXAnBqOpw&oe=66F2A8AC"}, {"file_name": "8.png", "id": "781253063329377", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974732_781253066662710_4858183234566166318_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KiSYHct_kD8Q7kNvgEfCxQC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjckdoAFPpWHHfoSzUjyqXY&oh=00_AYA-7ITdxO__lMVhuVl1965k5MyWuLs9I2AremposM9SvA&oe=66F2964F"}, {"file_name": "6.png", "id": "940819263893066", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031628_940819267226399_2397100471894061859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TV6OI3QSclAQ7kNvgEGHcSZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjckdoAFPpWHHfoSzUjyqXY&oh=00_AYC0fVGK8JiHYG36fskmDHHI8mK60zwM6hg-nUZJGcqf_Q&oe=66F2BE6A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DISUKU (2).png", "id": "1427444654739536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_1427444658072869_3041765525580465306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=blPH38cQ3GEQ7kNvgHRIwMx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjckdoAFPpWHHfoSzUjyqXY&oh=00_AYBymOYwIV8vWRZaOWo5Ra8Malnw5037pZ36nvtv3QtTzA&oe=66F2A209"}, "display_name": "Disuku", "keywords": [], "long_description": "Join us for a sneak peek at our early-stage VR game, Zero-G Disc Tag, code-named Disuku! \n\nWith two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n\nJoin our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN \n\nGet ready to challenge your reflexes and strategy skills in Zero-G Disc Tag!", "short_de