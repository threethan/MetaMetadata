g?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XRGuKUErwoIQ7kNvgGODPMk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBexdgD36lzV527_skwZTkJksi3Wp7lbELvtyv7H84ZQw&oe=6707AE4F"}, {"file_name": "6.png", "id": "940819263893066", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031628_940819267226399_2397100471894061859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WWvNxtaTHtIQ7kNvgECHUlM&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARRYRt467esjNo0JTVY5mRDUGGDklx3CfTHk0s-cYejg&oe=6707D66A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DISUKU (2).png", "id": "1427444654739536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982709_1427444658072869_3041765525580465306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qRxAmlqJaZcQ7kNvgHxXvJx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCjvFIxan9YmASfQVON4F_R_8hT3Q8SRcOSEmgfnzx0Q&oe=6707BA09"}, "display_name": "Disuku", "keywords": [], "long_description": "Join us for a sneak peek at our early-stage VR game, Zero-G Disc Tag, code-named Disuku! \n\nWith two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n\nJoin our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN \n\nGet ready to challenge your reflexes and strategy skills in Zero-G Disc Tag!", "short_description": "Introducing Disuku: A New VR Game for Fast-Paced Strategic Fun! With two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_servic