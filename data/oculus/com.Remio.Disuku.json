uluscdn.com/v/t64.5771-25/39001724_2843277822473867_5827143783894822490_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mzv0SB3MuWUQ7kNvgGxGSvm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AropJqc0K283mslB3avFVBD&oh=00_AYDAeSV90VsAeuInLHO66xlsyUR1sKALzImEhD3EOsZT5w&oe=66ED62AC"}, {"file_name": "8.png", "id": "781253063329377", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974732_781253066662710_4858183234566166318_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1dGJbgeFMI8Q7kNvgGW4x7d&_nc_ht=scontent.oculuscdn.com&_nc_gid=AropJqc0K283mslB3avFVBD&oh=00_AYBReDw2x0KkP8P3HMK2cBkJRP06gtXmkH6Y6AgwVZUxyg&oe=66ED504F"}, {"file_name": "6.png", "id": "940819263893066", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031628_940819267226399_2397100471894061859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E3M9lhjAtKoQ7kNvgFP0WVj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AropJqc0K283mslB3avFVBD&oh=00_AYClON3xmP535QHTM3C8cF1rw7lusFx7NLIVVpT3CuzXIQ&oe=66ED786A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DISUKU (2).png", "id": "1427444654739536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_1427444658072869_3041765525580465306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=amhwoYItszQQ7kNvgHl44_7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AropJqc0K283mslB3avFVBD&oh=00_AYAu0zRZo1sBev_URcw4IC1uuMPhbgAXpKyoG3bCAzOl3w&oe=66ED5C09"}, "display_name": "Disuku", "keywords": [], "long_description": "Join us for a sneak peek at our early-stage VR game, Zero-G Disc Tag, code-named Disuku! \n\nWith two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n\nJoin our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN \n\nGet ready to challenge your reflexes and strategy skills in Zero-G Disc Tag!", "short_de