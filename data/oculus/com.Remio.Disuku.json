g?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4EBIIBSF_4Q7kNvgFhJT04&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBt-dK55lSNnOuUNOkBVX2taGidL-_QSF6O5AC5FqqQlA&oe=67123A4F"}, {"file_name": "6.png", "id": "940819263893066", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031628_940819267226399_2397100471894061859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCPhYHRYZ48Q7kNvgHB5uCV&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBhq1waRV8eAQDcHLbfxfnQfzPJBw9xBZEcWE21RNsSow&oe=6712626A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DISUKU (2).png", "id": "1427444654739536", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982709_1427444658072869_3041765525580465306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gSKkG6S_Ky4Q7kNvgGp5dr_&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAUhuAubNDrgS3GY6Txp-017YTA0eaFa_mvbPM7djqFCw&oe=67124609"}, "display_name": "Disuku", "keywords": [], "long_description": "Join us for a sneak peek at our early-stage VR game, Zero-G Disc Tag, code-named Disuku! \n\nWith two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n\nJoin our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN \n\nGet ready to challenge your reflexes and strategy skills in Zero-G Disc Tag!", "short_description": "Introducing Disuku: A New VR Game for Fast-Paced Strategic Fun! With two teleportation discs in each hand, you'll need to think fast and move even faster to outwit your opponents in this exciting, fast-paced game. Aim to tag your opponents with your discs while avoiding their own attacks, and master rapid teleportation to come out on top. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_servic