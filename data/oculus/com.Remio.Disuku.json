scdn.com/v/t64.5771-25/57574726_839342410388429_7759086106456759168_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VlBdmNatPEMQ7kNvgHyiSDZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2eL1GVdmyUgHVic3che7zxz-_nIc55iJxy7SoOnDVWQ&oe=67238724"}, {"file_name": "1.png", "id": "3752823961613564", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982608_3752823964946897_8762463223028396624_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ElPahFEHQQQ7kNvgF9u2dt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfRGk7SZ5aXxs4GrcaD9xA-MRNJwACNEBc1F5mjP7u7w&oe=67235B26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "remio new cover (1).png", "id": "604743228394489", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75348033_604743231727822_4312116999464871277_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tQgqryQnLrQQ7kNvgEku2-b&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxnbSkJWbRbiT_RLH1vHIStuRVwTkwj6lJ7rlzgqr5Cg&oe=6723728B"}, "display_name": "Disc Wars", "keywords": [], "long_description": "To Dominate the Ether you have to Become One with the Disc.\n\nOr even better, Master the Art of Dual Discs!\n\nRedefining VR E-sports and introducing you to ultra-fast-paced strategic battles that will keep your pulse pounding! Outmaneuver your foes with clever blink techniques, create diversions with deceptive throws, and reign supreme in this otherworldly competition.\n\nDiscord:\nhttps://discord.com/invite/YrZwpCANQN ", "short_description": "To Dominate the Ether you have to Become One with the Disc.\n\nOr even better, Master the Art of Dual Discs!\n\nRedefining VR E-sports and introducing you to ultra-fast-paced strategic battles that will keep your pulse pounding! Outmaneuver your foes with clever blink techniques, create diversions with deceptive throws, and reign supreme in this otherworldly competition.\n\nDiscord:\nhttps://discord.com/invite/YrZwpCANQN "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remio