3-1.oculuscdn.com/v/t64.5771-25/11162679_131355520749874_300544837663326208_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2D8VhOah0XYQ7kNvgGj_HbR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmrMc-KRK_x-Uttd_alKx05zbI0HfO1fS6FkWmO_imSQ&oe=6735F356"}, {"file_name": "migrated_image.png", "id": "245821116575741", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162681_1359113674180123_2380436781439909888_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFHoanueHGkQ7kNvgG5BER_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBu8Rux2rbRzWbrltjZNTqbzz65mDy07OvFyiHBJaNarA&oe=6735F40C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Kismet", "keywords": ["fortune", "psychic", "astrology", "horoscope", "tarot"], "long_description": "Would you like to know what the future holds in store for you? Developed by award-winning creative studio Psyop, Kismet is a collection of three activities, including a past-present-future Tarot Card reading (the Cards), daily Astrology session (the Stars), and ancient board game, Ur (a game of Wit). Kismet is meant to be experienced daily, with unique outcomes every calendar day that are directly tied to not only the cards that you choose, but your individual birth date and the actual alignment of celestial bodies at the time of your reading. Named after the mysterious character at its core, Kismet is inspired by the mystic arts of tarot and astrology, brought to life in a beautifully detailed, handmade, Gothic style.", "short_description": "Kismet is a VR fortune-teller experience inspired by the mystic arts of tarot and astrology, brought to life in a beautifully detailed, handmade, gothic style."}]}, "developer_name": null, "developer_privacy_policy_url": "http://kismetvr.com/privacy-policy", "developer_terms_of_service_url": "http://kismetvr.com/privacy-policy", "publisher_name": "Psyop", "support_website_url": null, "website_url": "https://www.kismetvr.com/", "category": "APPS", "com