E"}, {"file_name": "3.png", "id": "1656549745092658", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227837668_1656549748425991_1143631201984089429_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dSmLkIeow4YQ7kNvgE8BxZo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2_062WpbYuLanC72bO1U9G&oh=00_AYA5OXymc2i_BNHp3LDsLsMS3MPjqoRiQALBSZ1wfTSC6g&oe=66EAC888"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1838571613315973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003272_1838571616649306_6242989053745109081_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2cat_MYgGj0Q7kNvgGSTI5J&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2_062WpbYuLanC72bO1U9G&oh=00_AYC_rfkrLeLKqpE1yL8XzF7NhiQRHQ5qRzOc10V8AcP4Gw&oe=66EAA4DC"}, "display_name": "Testvr", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Holoren", "support_website_url": null, "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "889588098232891"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "7741684322541286"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031373_7884496791612900_4665903026284222946_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aWSBPCOTGUgQ7kNvgGHjXqk&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2_062WpbYuLanC72bO1U9G&oh=00_AYByI3g6xRyt1-8-owJzXqhJtfCJsbwBU60piOCAL8LqGw&oe=66EAC541"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Testvr", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Battle Royale", "id": "889588098232891"}], "release_date": 1718353498, "lastRevision": {"nodes": [{"id": "7727081750668210", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7727081730668212", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "3728329660731794"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "1440.png", "id": "7884496788279567", "image_type": 