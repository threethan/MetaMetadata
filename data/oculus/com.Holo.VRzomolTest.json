a0a&_nc_ohc=IUYvXAlzFJIQ7kNvgFRs43a&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQXMw_RSBjU5eY9bAG-QG0uPJimlqyRe2GK1NSP-v19w&oe=670A6C88"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1838571613315973", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003272_1838571616649306_6242989053745109081_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zTgVrtqtQbkQ7kNvgHjzHq3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDzem4TQP6k0EBoKDKJpo34kB08g7hlOTD9SiBxYpGI8A&oe=670A48DC"}, "display_name": "Testvr", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Holoren", "support_website_url": null, "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_ca