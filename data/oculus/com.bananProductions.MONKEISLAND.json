25257994632994", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_1825257997966327_6379464755957542704_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_BPVfWnll_MQ7kNvgEaL1yC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTGCNdd0ET68p2Jggod3KgS3DU_Qd39az8K2kL5V1bJA&oe=66F7E0A2"}, {"file_name": "ScreenShot4.png", "id": "841419990840334", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982637_841419994173667_5268022981001009628_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zIrdCNueehEQ7kNvgGlZoUU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBKpoBXVS2xMYYAvnKkCLjA34Q2l4x8-c3q7rugCjdDIg&oe=66F7D307"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monke Mash", "keywords": [], "long_description": "In Monke Mash, you dive into a thrilling murder mystery where stealth and strategy are your best allies. As you take on a unique role with distinct abilities, you gather clues and identify the culprit among your friends. Trust no one, knowing danger lurks around every corner and everyone has their own agenda. To enhance your experience, you can customize your look with a plethora of skins for your gun, knife, and character. Whether you choose a fearsome appearance to intimidate or a stealthy disguise to blend in, your strategy will be key. You must piece together the puzzle in high-stakes multiplayer matches, testing your detective skills against players from around the world. In Monke Mash, every player is a suspect, and every moment is a fight for survival.", "short_description": "Become Monke, it's easy."}]}, "developer_name": "Banan Studios", "developer_privacy_policy_url": "https://enderdragon0928.wixsite.com/monkephobia/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Skizzo", "support_website_url": null, "website_url": "https://enderdragon0928.wixsite.com/monkephobia", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "co