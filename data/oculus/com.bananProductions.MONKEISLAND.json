_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qjTjb8kmlpYQ7kNvgEhQc45&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCs6yL7HhDV-VzoTRL9HSzj0EjuQ8wwB4YjL30v7RXesQ&oe=6756C98E"}, {"file_name": "ScreenShot3.png", "id": "1825257994632994", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974528_1825257997966327_6379464755957542704_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_qxBBzwdeG8Q7kNvgEDGdfr&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCmAmppsUeJnxTVgBcqiNuos6Sxk7DA9O0ah0bAISFkFw&oe=6756CCA2"}, {"file_name": "ScreenShot4.png", "id": "841419990840334", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982637_841419994173667_5268022981001009628_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b_QqK8O3L3wQ7kNvgFSXZV0&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCpm_FOZItetfqLboMuEM5TVPhWZePIoITBc8b_vRZU7g&oe=6756BF07"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monke Mash", "keywords": [], "long_description": "In Monke Mash, you dive into a thrilling murder mystery where stealth and strategy are your best allies. As you take on a unique role with distinct abilities, you gather clues and identify the culprit among your friends. Trust no one, knowing danger lurks around every corner and everyone has their own agenda. To enhance your experience, you can customize your look with a plethora of skins for your gun, knife, and character. Whether you choose a fearsome appearance to intimidate or a stealthy disguise to blend in, your strategy will be key. You must piece together the puzzle in high-stakes multiplayer matches, testing your detective skills against players from around the world. In Monke Mash, every player is a suspect, and every moment is a fight for survival.", "short_description": "Become Monke, it's easy."}]}, "developer_name": "Banan Studios", "developer_privacy_policy_url": "https://enderdragon0928.wixsite.com/monkephobia/privacy-policy", "developer_terms_of_service_u