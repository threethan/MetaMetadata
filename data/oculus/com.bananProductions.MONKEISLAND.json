_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8lHUfu1EYz8Q7kNvgEqEFJA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC17nZCdxPouDFmikM7nQYOrAedttLHCQPAlEUXDZf97A&oe=671F6A8E"}, {"file_name": "ScreenShot3.png", "id": "1825257994632994", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974528_1825257997966327_6379464755957542704_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FYa3KcKstncQ7kNvgEv2iHS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8Y_YZaYWZv8_7YQa6rjjIRUZeveiefBBcZHSJMx-Z5w&oe=671F6DA2"}, {"file_name": "ScreenShot4.png", "id": "841419990840334", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982637_841419994173667_5268022981001009628_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=byUmFLRQ48sQ7kNvgEpgxEM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCc34BVm3kj7Dnbof4ZkOhKKWMjwmWbrniT9J9IF4XT1w&oe=671F6007"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monke Mash", "keywords": [], "long_description": "In Monke Mash, you dive into a thrilling murder mystery where stealth and strategy are your best allies. As you take on a unique role with distinct abilities, you gather clues and identify the culprit among your friends. Trust no one, knowing danger lurks around every corner and everyone has their own agenda. To enhance your experience, you can customize your look with a plethora of skins for your gun, knife, and character. Whether you choose a fearsome appearance to intimidate or a stealthy disguise to blend in, your strategy will be key. You must piece together the puzzle in high-stakes multiplayer matches, testing your detective skills against players from around the world. In Monke Mash, every player is a suspect, and every moment is a fight for survival.", "short_description": "Become Monke, it's easy."}]}, "developer_name": "Banan Studios", "developer_privacy_policy_url": "https://enderdragon0928.wixsite.com/monkephobia/privacy-policy", "developer_terms_of_service_u