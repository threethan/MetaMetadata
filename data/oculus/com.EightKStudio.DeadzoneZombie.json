7067D58"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Art_2560_1440.png", "id": "525252999448110", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65227368_525253006114776_6043420586234449926_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k6jVtk2BznMQ7kNvgHy32sF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFaW4Tt_-FWvp36hbFZeb3lG19IGwcVCdivd5fmwc66g&oe=670671B0"}, "display_name": "DeadZone Zombie", "keywords": [], "long_description": "Massive arsenal with dozens of different weapons, including many different types depending on the player's preference: handgun, shotgun, assault, automatic and a variety of high-damage melee weapons.\n\nMore special is the item and trap system, depending on your attack and defense strategy to choose the right type of trap such as: Fence, Sawblade Trap, Gun Turret, Electrical Turret, Thorn Trap, Fire Turret or Drone.\n\n100 missions with dozens of different types of zombies and bosses will bring you a great challenge and experience.\n\nIn addition, you can team up with friends to conquer the hardest challenge of the game with 100 stages.\n", "short_description": "If you are brave and like to challenge yourself, then surely you will not be disappointed with this virtual reality zombie game, with a world destroyed by zombie virus, endless chase in the Scary background, will definitely create a strong feeling for players, in addition the game also has a coop feature to play with friends. Let's play together now.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deadzonezombie.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "8K Studio", "support_website_url": null, "website_url": "https://deadzonezombie.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED