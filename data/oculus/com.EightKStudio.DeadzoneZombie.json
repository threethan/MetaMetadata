027358020_7620078546683690455_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h5F3gOk3AYkQ7kNvgE--ByL&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af4GL7fNu_hHPmTfvKhZcCC&oh=00_AYCntm3E7yOmE9egDgcIohvugPhsQiJOUx0Ia2UrhclhoA&oe=66DEF058"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Art_2560_1440.png", "id": "525252999448110", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65227368_525253006114776_6043420586234449926_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zpLg8kBxAIQ7kNvgGM3jkq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af4GL7fNu_hHPmTfvKhZcCC&oh=00_AYCDGJ1voRLzuZ_IRuXx1sEYVA6kkwMvkvK1ujeciQq01g&oe=66DEE4B0"}, "display_name": "DeadZone Zombie", "keywords": [], "long_description": "Massive arsenal with dozens of different weapons, including many different types depending on the player's preference: handgun, shotgun, assault, automatic and a variety of high-damage melee weapons.\n\nMore special is the item and trap system, depending on your attack and defense strategy to choose the right type of trap such as: Fence, Sawblade Trap, Gun Turret, Electrical Turret, Thorn Trap, Fire Turret or Drone.\n\n100 missions with dozens of different types of zombies and bosses will bring you a great challenge and experience.\n\nIn addition, you can team up with friends to conquer the hardest challenge of the game with 100 stages.\n", "short_description": "If you are brave and like to challenge yourself, then surely you will not be disappointed with this virtual reality zombie game, with a world destroyed by zombie virus, endless chase in the Scary background, will definitely create a strong feeling for players, in addition the game also has a coop feature to play with friends. Let's play together now.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deadzonezombie.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "8K Studio", "support_website_url": null, "website_url": "https://deadzonezombie.com/",