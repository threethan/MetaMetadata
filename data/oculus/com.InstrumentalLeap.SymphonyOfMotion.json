ntent-iad3-1.oculuscdn.com&oh=00_AYAvxlgmbkZjxIbvPll1JiBu7QLK9X7glttWby1w9ZnF2Q&oe=6767E27C"}, {"file_name": "1.png", "id": "541066850814745", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572932_541066854148078_2845143470434249405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKDuj9rZN0AQ7kNvgGRaUEa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBmsc9pq1Iqx9lf1JSM7e-LbKajXZeD0-uoTr21TPWE4Q&oe=6767ED6C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1084809205444174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394636_1084809208777507_5661361267561165032_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YEXFksKVqQAQ7kNvgGAZ6Vg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABohikKZu7fApFeHErCzUOO-fobQ_CFomHATcjsSA4Dw&oe=6767E2F6"}, "display_name": "Symphony Of Motion", "keywords": [], "long_description": "Symphony Of Motion offers a unique way to create and experience music without the need for any prior musical knowledge. Whether you're a seasoned musician or a complete beginner, this is a new and intuitive way to create and experience music. In its simplest form, you just move your hands around to create unique sounds, melodies and rhythms. There are no \u201cwrong\u201d notes to worry about and you can always stay on perfect tempo with the build-in perfect timing assistant. For more experienced musicians there are a lot of customization options and a build-in looper to play with.", "short_description": "An innovative musical playground that turns your motion into music. The built-in looper, drum kit builder, and a large selection of motion-reactive synthesizers and drum samples will keep you jamming for hours and hours."}]}, "developer_name": "Instrumental Leap", "developer_privacy_policy_url": "https://symphonyofmotion.com/?page_id=66", "developer_terms_of_service_url": "https://symphonyofmotion.com/?page_id=66", "publisher_name": "Instrumental Leap", "support_website_url":