rns your motion into music. The built-in looper, drum kit builder, and a large selection of motion-reactive synthesizers and drum samples will keep you jamming for hours and hours."}]}, "developer_name": "Instrumental Leap", "developer_privacy_policy_url": "https://symphonyofmotion.com/?page_id=66", "developer_terms_of_service_url": "https://symphonyofmotion.com/?page_id=66", "publisher_name": "Instrumental Leap", "support_website_url": null, "website_url": "https://symphonyofmotion.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1086682942204632"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "383112683882365"}, {"status": "PUBLISHED", "id": "612793837095182"}, {"status": "PUBLISHED", "id": "952227296111956"}, {"status": "PUBLISHED", "id": "1547786532299213"}]}, "baseline_offer": {"id": "952227296111956"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1654546500, "status": "PUBLISHED", "id": "383112683882365"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5599374473495415", "version": "0.23"}, "id": "1147464706052982", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "467689614240