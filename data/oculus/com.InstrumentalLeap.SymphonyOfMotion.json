c=RlzmoOYF8GcQ7kNvgE_xTdX&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYC3XZWmzoq1sdsFQOYiOoVJOyWlw7DhJ-sdODMvreMe4w&oe=677E56EC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1084809205444174", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/75394636_1084809208777507_5661361267561165032_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=py3WbqaYW4kQ7kNvgHPPIjg&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAXvUDbnR6KhbAcbxDE7C7Cb-o63JCq3eIcIOfzd0VlDw&oe=677E4C76"}, "display_name": "Symphony Of Motion", "keywords": [], "long_description": "Symphony Of Motion offers a new unique way to create and experience music without the need for any prior musical knowledge. Whether you're a seasoned musician or a complete beginner, this is a new and intuitive way to create and experience music. In its simplest form, you just move your hands around to create unique sounds, melodies, and rhythms. There are no \u201cwrong\u201d notes to worry about (as you always play in a specific scale) and you can always stay on perfect tempo with the build-in perfect timing assistant. For the more experienced musicians, it also offers a lot of customization options, a build-in looper, and new levels of expressional depth with its three-dimensional motion modulation, live pitch-shifting drums, and melodic pads.", "short_description": "An innovative musical playground that turns your motion into music. Featuring a large selection of motion-reactive synthesizers, multi-pitched drum and melodic percussion pads, a built-in looper, and a drum kit builder that will keep you jamming for hours on end."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vTml4NDv2-HKPSFPSy9sA4DCRO54sd6Aadn_O17yHGtpq6fyjRE-wC6hGbjIDZ01MXtv24vk5wlBWL0/pub", "developer_terms_of_service_url": "https://docs.google.com/document/d/e/2PACX-1vTml4NDv2-HKPSFPSy9sA4DCRO54sd6Aadn_O17yHGtpq6fyjRE-wC6hGbjIDZ01MXtv24v