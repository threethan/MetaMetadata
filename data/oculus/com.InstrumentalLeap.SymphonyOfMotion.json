ontent-iad3-1.oculuscdn.com&oh=00_AYBlVKX8qgpWEByWInUVbRVfMfZgx0yUH0mtxxyCkcUPjw&oe=672DE07C"}, {"file_name": "1.png", "id": "541066850814745", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572932_541066854148078_2845143470434249405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50dBrajo8egQ7kNvgGqsZN9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCuGD9dRL2JrbCrWLeobbQxVuG8aKU5dtflqxIS8MnpwQ&oe=672DEB6C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover.png", "id": "1084809205444174", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394636_1084809208777507_5661361267561165032_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cBtjguEN0BMQ7kNvgF7sKfJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7HmxaeqItRAhkwIp58KUH19MTE1-EudmDLZ7zZu-gYw&oe=672DE0F6"}, "display_name": "Symphony Of Motion", "keywords": [], "long_description": "Symphony Of Motion offers a unique way to create and experience music without the need for any prior musical knowledge. Whether you're a seasoned musician or a complete beginner, this is a new and intuitive way to create and experience music. In its simplest form, you just move your hands around to create unique sounds, melodies and rhythms. There are no \u201cwrong\u201d notes to worry about and you can always stay on perfect tempo with the build-in perfect timing assistant. For more experienced musicians there are a lot of customization options and a build-in looper to play with.", "short_description": "An innovative musical playground that turns your motion into music. The built-in looper, drum kit builder, and a large selection of motion-reactive synthesizers and drum samples will keep you jamming for hours and hours."}]}, "developer_name": "Instrumental Leap", "developer_privacy_policy_url": "https://symphonyofmotion.com/?page_id=66", "developer_terms_of_service_url": "https://symphonyofmotion.com/?page_id=66", "publisher_name": "Instrumental Leap", "support_website_url"