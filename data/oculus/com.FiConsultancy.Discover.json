 Racing, and Shooting Range\u2014directly to your VR headset. Experience the perfect blend of physical and digital worlds, offering unparalleled gaming experiences from the comfort of your home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://nexusarcadevr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "FI Consultancy", "support_website_url": null, "website_url": "https://nexusarcadevr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "6962116043836063"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575362_448787694793887_2087502287628655887_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e7_s7OnMwpcQ7kNvgH2N5e_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHnj_fanJ82_ieAsYT6tU9J&oh=00_AYBXiiSsSUVQ7O3MsrQOrWZcseqpeQulz9ACmzuAkyRwDg&oe=66E812C4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Nexus Arcade", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Racing", "id": "673385183287495"}], "release_date": 1722281096, "lastRevision": {"nodes": [{"id": "6962116057169