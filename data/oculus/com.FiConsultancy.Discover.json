 train, or simply have fun, Nexus Arcade offers something for everyone. Join us on Meta App Lab and be part of the gaming revolution.", "short_description": "Nexus Arcade is a cutting-edge mixed reality gaming platform that brings the excitement of four immersive games\u2014Ten Pin Bowling, Boxing Mitt Training, Car Racing, and Shooting Range\u2014directly to your VR headset. Experience the perfect blend of physical and digital worlds, offering unparalleled gaming experiences from the comfort of your home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://nexusarcadevr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "FI Consultancy", "support_website_url": null, "website_url": "https://nexusarcadevr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "6962116043836063"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "464356303188853"}]}, "baseline_offer": {"id": "464356303188853"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722281096, "status": "PUBLISHED", "id": "464356303188853"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7857342340980091", "version": "0.43"}, "id": "1400587910888620", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": fal