.5771-25/38974819_1096947550936872_6623262552815231899_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-fI2eNi5ksQ7kNvgEfjUor&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzSa1qbM383Hj6vQ_TV89N8hDgX3v9iriUCf1r81VZqA&oe=671E3CCD"}, {"file_name": "Screenshot3.png", "id": "492042612309514", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610702_492042615642847_8961521301303806226_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0AfR0x8PrhIQ7kNvgFT3GdT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhuTCqbxO_j0xHQSgn4edUfoClLQhrjhJfmKpMVWiGhQ&oe=671E146C"}, {"file_name": "Screenshot4.png", "id": "831736571156653", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035344_831736577823319_3749544078509164249_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xF5VIPNMu8YQ7kNvgHi1LuD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSR60uQl637JI2W5I9--LpucLbKnU39ZuCHGJn3X4BHw&oe=671E3002"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1443952479413837", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974677_1443952486080503_3476958366015208444_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lr-ie02nOtMQ7kNvgFjua-6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlzhoUgiu-4vRMhWMcDD11W5cG4L8gk7uUiu6FDA5JMA&oe=671E3AEF"}, "display_name": "3D scan of Collonges-la-Rouge", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a pedestrian in Collonges-la-Rouge, reconstructed from videos taken by two head-held 360 cameras (Gopro Max), whose trajectory is about 1.6km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a medieval town, which was computed by photogrammetry from cubemap videos (4096x1344x2) taken by two head-held 360 cameras (Gopro Max) and by walking about 1.6km in Collonges-la-Rouge (in France).\n"}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8536874146334493"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001717_770726907467789_1893173778065304361_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I9nYvnEU7PsQ7