809_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W2KR7Ebb60cQ7kNvgGrsStF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAC0du3UNjQthrTDxUFe4-xcwWBzYCRdA5C5JFl2Lg_zQ&oe=677669A6"}, {"file_name": "DN_MGolf2.png", "id": "859674204902144", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982487_859674208235477_2344613544708351869_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J49lbQsecmEQ7kNvgEOGxNy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCjd9AQ-WHPXMx9aNwTAyaZ9JmXXBLBwT5bxECM6i7JWA&oe=6776834B"}, {"file_name": "DN_LWay.png", "id": "1512181229167476", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982625_1512181232500809_4799425392250328001_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQuSdHqvPwAQ7kNvgG9GYI7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBMOJKNINW7g4gnGR8Be92ZDswuSJ_CTKVjOmUtPD0Dw&oe=67768ECE"}, {"file_name": "DN_SMountain.png", "id": "1000261940745773", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974483_1000261944079106_2684178465273233153_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4MGAiIYTxMQ7kNvgFYl_ea&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDc9MYMimpxsJKGQt19PT1wb6tFPd3nn07T31khp_koPQ&oe=677680BA"}, {"file_name": "DN_JCity.png", "id": "494014281899320", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/10000000_494014295232652_7739263442387542509_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ij97_n7BojUQ7kNvgHt0PrO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB-UIKGZw-yJ0abu3s7g8evKX9FCA_EzbEsxK54QAlEIA&oe=677682B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "156049823258025", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974655_156049826591358_8782886685581282871_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GKz1iaAL4NMQ7kNvgELBL0P&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBGLzFwN5cNH5p5MGgG1kZEkPvAt8AhC_-aymGiLncTpQ&oe=67766F42"}, "display_name": "Disc Ninja", "keywords": ["discgolf", "japan", "ninja", "sport", "frisbee"], "long_description": "Patience. Precision. Focus.\nThese are the traits of a ninja.\n\nTravel to feudal Japan following the lead of a golden dragon and become a Disc Ninja!\nYour task will be difficult: reach the dragon with as few throws as possible.\n\nImmerse yourself in a breathtaking virtual reality setting and practice your Disc Golf skills, come rain or shine.\nWin tournaments in all provinces and prove that you are the greatest Disc Ninja of all time.\n\nYour path will lead through high mountains, treacherous valleys, beautiful palaces, and temples full of deadly traps.\nThe challenge awaits. Ganbatte!\n\nKey features:\n\u2022 15 maps with beautiful, stylized graphics;\n\u2022 Realistic disc throwing physics with various difficulty levels;\n\u2022 Multiple unlockable collectibles, including unique ninja costumes and disc designs;\n\u2022 Multiplayer mode that allows up to 4 ninjas to compete against each other.\n", "short_description": "Patience. Precision. Focus. These are the traits of a ninja.\nTravel to feudal Japan following the lead of a golden dragon and become a Disc Ninja! Your path will lead through high mountains, treacherous valleys, beautiful palaces, and temples full of deadly traps.\nImmerse yourself in a breathtaking virtual reality setting and practice your Disc Golf skills. Win tournaments in all provinces and prove that you are the greatest Disc Ninja of all time.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games S.A.", "support_website_url": null, "website_url": "https://immersion.games/pl/disc-ninja.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "277654228600