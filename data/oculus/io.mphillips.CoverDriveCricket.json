content.oculuscdn.com/v/t64.5771-25/38982464_434304994438079_7599022713565762144_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lWCMvEghUG4Q7kNvgFCmgWr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvn-WHx98uZTTufXoO-tE7nXoKgKU_FsOmv4u6b1jPmQ&oe=66F7DD5E"}, "display_name": "Cover Drive Cricket Demo", "keywords": [], "long_description": "Missing cricket and wanting to be back at the crease? Cover Drive Cricket puts you at the heart of the action! Play through several different game modes as you test your skills and try to survive against a wide variety of bowling styles.\n\n(If you've previously installed this app through Sidequest, please uninstall that version before updating as the two are incompatible - sorry!)\n\nCome say hi! https://discord.gg/rFUzN6xbmQ\n\nGame modes:\n- Super Over: Score as many runs as you can off 6 balls and try to beat your top score!\n- Spin Target / Survival: Face a fearsome spin line-up as you either chase down a challenging target, or just simply try to survive!\n\nFeatures:\n- 5 bowling styles (Fast, Medium, Slow, Outswing, Off Spin)\n- Village and Pro difficulty modes\n- Left- or right-handed batting\n- Realistic bowling and batting physics\n- See where the ball hits the bat\n- Wagonwheels - see where your shots went\n- Replays - watch any delivery back again!\n- Fireworks!\n\nFull version coming soon!", "short_description": "Cricket, in virtual reality. Have fun and practice your batting, no matter the weather!\nMultiple game modes, difficulties and bowler varieties to play against, for free!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://coverdrive.cricket/privacy", "developer_terms_of_service_url": null, "publisher_name": "Cover Drive Cricket", "support_website_url": null, "website_url": "https://coverdrive.cricket/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type"