4.5771-25/39031395_284760519894772_1843418919124993955_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TdXPiKnHcwQQ7kNvgGYI_M9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuSjGZevQWCL7r6HrCaHcgz&oh=00_AYDcNp-LPK15-UCUurEMZZ9lVMBacdNVkkuiv4sdBvgwRQ&oe=66E81AB7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandscape.png", "id": "434304991104746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_434304994438079_7599022713565762144_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rmzU_E13tbIQ7kNvgFu_Zul&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuSjGZevQWCL7r6HrCaHcgz&oh=00_AYAEXLGMmPXy9jKEoYxGu3k3iY_sAUD9fISllponcg-AlA&oe=66E80B5E"}, "display_name": "Cover Drive Cricket Demo", "keywords": [], "long_description": "Missing cricket and wanting to be back at the crease? Cover Drive Cricket puts you at the heart of the action! Play through several different game modes as you test your skills and try to survive against a wide variety of bowling styles.\n\n(If you've previously installed this app through Sidequest, please uninstall that version before updating as the two are incompatible - sorry!)\n\nCome say hi! https://discord.gg/rFUzN6xbmQ\n\nGame modes:\n- Super Over: Score as many runs as you can off 6 balls and try to beat your top score!\n- Spin Target / Survival: Face a fearsome spin line-up as you either chase down a challenging target, or just simply try to survive!\n\nFeatures:\n- 5 bowling styles (Fast, Medium, Slow, Outswing, Off Spin)\n- Village and Pro difficulty modes\n- Left- or right-handed batting\n- Realistic bowling and batting physics\n- See where the ball hits the bat\n- Wagonwheels - see where your shots went\n- Replays - watch any delivery back again!\n- Fireworks!\n\nFull version coming soon!", "short_description": "Cricket, in virtual reality. Have fun and practice your batting, no matter the weather!\nMultiple game modes, difficulties and bowler varieties to play against, for free!"}]}, "developer_name": null, "de