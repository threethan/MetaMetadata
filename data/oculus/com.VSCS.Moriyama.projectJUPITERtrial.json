\nFar in the distant future. Mankind decides to dispatch an Outer Space Diplomat prior to expanding into the outer solar system. Prior to this, special training is conducted in the former Jupiter region. For now, aim for the portal.\n\nTrial version: This is a trial version.\nThis is a demo version, but the recorded aspects are new works that are not included in the main version. It can also be enjoyed by those who already have the full version of the game.\n\nFull version: This is a trial version of the full version.\nhttps://www.oculus.com/experiences/quest/5275940062439283?ranking_trace=106436491002869_5275940062439283_SKYLINEWEB_d2d76393-415b-4fac-9d76-a66f057ee1bb\n\n", "short_description": "This is a free trial version of \"projectJUPITER_a\", a VR giant maze experience!\n\nCurrently, only Japanese version is available.\n\nClick here for the full version.\n\nhttps://www.oculus.com/experiences/quest/5275940062439283?ranking_trace=106436491002869_5275940062439283_SKYLINEWEB_d2d76393-415b-4fac-9d76-a66f057ee1bb\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://doga.jp/~moriyama/rouKANlien/DownLoadContents/OculusQuest/pckj/pp.html", "developer_terms_of_service_url": null, "publisher_name": "VSC/S.Moriyama", "support_website_url": null, "website_url": "http://doga.jp/~moriyama/rouKANlien/DownLoadContents/OculusQuest/pckj/pckj.html", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "TRAVEL", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_trac