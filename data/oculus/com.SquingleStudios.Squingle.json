jPAoDjKiIQ7kNvgEcXhYa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMrWkAUtnbi74JXFOQMxuwaxhs0lO7jTQDZNGWO4Nnhw&oe=672CB0E9"}, {"file_name": "10_2720.png", "id": "1180218902410590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75435282_1180218905743923_7877774857140923234_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vnQY8L7g1NAQ7kNvgG8B_-O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxejzleOWtrBIg8H14XwLBGI4jYWSlmFiwZO-Vm_B_xg&oe=672CB45B"}, {"file_name": "3_15380.png", "id": "904256780356189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75617324_904256783689522_5644386189345481633_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0uocU_2oG_AQ7kNvgGwwuBM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-Ops8Dh-XJyMjNo8g3hIoe1xkZDFTlHE2Lxh3UGndng&oe=672CA09A"}, {"file_name": "19_12000.png", "id": "170663844814790", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035392_170663848148123_5082411011153165523_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQo1vgaCVmMQ7kNvgEHChBc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDT6ceVl1oEEyedypDAyfiNQIxVbIXge8UBHa2KsRh8pA&oe=672CA5B7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaLandscape_v2_enhanced.png", "id": "862128594403609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75568720_862128597736942_7497711968244642703_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y2bh6I_o8rAQ7kNvgFGQrfe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAL8gCh_SFMgXxma28yO19GJbveg3mm0c9Iw9agn-mdVA&oe=672CBD44"}, "display_name": "Squingle", "keywords": [], "long_description": "Before time there was only Squingle \u2013 and she needs your help to create the Universe!\n\nThe spiraling psychedelic puzzle \u2013 Liquid crystal levels are alive, mystical, and other-worldly, offering a unique multisensory showcase that must be seen, heard and felt to be believed. Grab the two revolving orbs and guide them through iridescent mazes that twist and turn, forming structures like DNA. Will you discover the meaning of Squingle?\n\n> Sensory Satisfaction\nRelax with refreshing visuals and a 3D tactile gameplay experience only possible in VR.\nFind your flow through 100 hand-crafted levels and a changing musical soundscape.\n\n> Get Competitive\nCompete with Steam Leaderboards and Achievements \u2013 calling all Speed Runners \u2013 and challenge your own ghost at double-speed for double satisfaction.\n\n>Addictive Gameplay\nSolve puzzles by switching your rotation with special orbs to find secret items, multiple paths and hidden routes, and master maneuvers around dangerous dances of obstacles.", "short_description": "The spiraling psychedelic puzzle \u2013 Grab revolving orbs and guide them through twisting liquid crystal mazes to create the Universe! A refreshing, relaxing and satisfying \"one more go\" experience, only in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://squingle.com/privacy-policy", "developer_terms_of_service_url": "https://squingle.com/privacy-policy", "publisher_name": "Squingle Studios", "support_website_url": "https://squingle.com/", "website_url": "https://squingle.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "660666945352318"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "285818286546751"}, {"status": "PUB