06&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o1TxHTNfKE8Q7kNvgHio22U&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYB3FoLVzjzwC2DlA9H_HtRpsT5OSXUbDyUG2tj2DGeQQw&oe=66E6BF81"}, {"file_name": "5.png", "id": "1945118289165910", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001664_1945118292499243_1021220941998900134_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pi1aNBk7sNgQ7kNvgGf_e6J&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYC-XSczLWoU_X6LdKP0Nv6Imr3aCKxSMz6PwMOhqtRzKg&oe=66E6B3EF"}, {"file_name": "4.png", "id": "1882373772125657", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001664_1882373775458990_7028507716099184885_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8tfzgR1fIL4Q7kNvgHeDw31&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYAaPCl_A0WlNf3BEGig6MTAHPb9M4Pqq2PG1yCgsuZQpw&oe=66E6B802"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "3445578522431678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223478_3445578525765011_3918502890170441114_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hk26aCR8PbkQ7kNvgGCqrmZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYC_ZdbfppI3qVUqe95QNAG4i6l04yWWOD6yP-ucZaE6JQ&oe=66E6AD03"}, "display_name": "Brite Light", "keywords": [], "long_description": "Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light.\n\nEvoke nostalgia and create wonderful works of art with Bright Light.\n\nFun for creative folks and people just looking to chill.  Brite Light is a fun, zen-like creativity room.  Brite Light includes:\n\n- A giant 4ft by 4ft Brite Lite Board;\n\n- Unlimited Pegs To Create With;\n\n-3 Free Brite Light Patterns;\n\n-An Auto-Save Feature So You Can Build Your Creation Over Time;\n\n-An Interactive Room That Includes Interactable Objects.\n\nBrite Light is the perfect Zen-Like experience for relaxing after a long day or clearing your head and letting your mind wonder safely in a fun, relaxing environment.", "short_description": "Evoke nostalgia and create wonderful works of art with Bright Light. Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/britelight", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "770757604151277"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "26810257991922726"}, {"status": "PUBLISHED", "id": "354557014356991"}, {"status": "PUBLISHED", "id": "782902846534431"}, {"status": "PUBLISHED", "id": "469091572209084"}]}, "baseline_offer": {"id": "354557014356991"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "26810257991922726"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6449347048527075", "version": "3"}, "id": "1184198952210982", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"