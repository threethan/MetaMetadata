U_X6LdKP0Nv6Imr3aCKxSMz6PwMOhqtRzKg&oe=66E6B3EF"}, {"file_name": "4.png", "id": "1882373772125657", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001664_1882373775458990_7028507716099184885_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8tfzgR1fIL4Q7kNvgHeDw31&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYAaPCl_A0WlNf3BEGig6MTAHPb9M4Pqq2PG1yCgsuZQpw&oe=66E6B802"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "3445578522431678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223478_3445578525765011_3918502890170441114_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hk26aCR8PbkQ7kNvgGCqrmZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYC_ZdbfppI3qVUqe95QNAG4i6l04yWWOD6yP-ucZaE6JQ&oe=66E6AD03"}, "display_name": "Brite Light", "keywords": ["light", "zen", "puzzle", "art", "create"], "long_description": "Brite Light: A Tranquil Creation Experience\n\nEmbark on a serene journey with Brite Light, brought to you by the creators of Zen Monkeys. Clear your mind, breathe deeply, and unwind in the soothing ambiance of Brite Light.\n\nTap into nostalgia and unleash your creativity with Brite Light.\n\nIdeal for both artistic souls and those seeking relaxation, Brite Light is your personal oasis of creativity. Immerse yourself in a tranquil environment where inspiration flows freely.\n\nKey Features:\n\n\nEXPANSIVE CANVAS: Craft your masterpiece on a spacious, interactive canvas.\n\nINFINATE CREATIONS: Use the pegs and patterns to spark your imagination.\n\nAUTO-SAFE FUNCTIONALITY: Seamlessly save and build upon your creations at your own pace.\n\nINTERACTIVE ENVIRONMENT: Engage with various objects in a serene, virtual room setting.\n\nBrite Light offers the ultimate Zen-like experience, perfect for unwinding after a hectic day or letting your mind wander in a safe, relaxing environment.\n{519716874070859}", "short_description": "Embark on a serene journey with Brite Light, brought to you by the creators of Zen Monkeys. Clear your mind, breathe deeply, and unwind in the soothing ambiance of Brite Light."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/britelight", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7701758356619265"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031478_1407940079877390_340722245891922930_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rU47xxq2b7MQ7kNvgGcEniF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiOrdSWhMlObzRPnzl2JV8F&oh=00_AYDdD6MgeoHxpcy7eHLJvHmqlKukkVa3P5HkNItK6ABZOQ&oe=66E6ADF7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Brite Light", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1679844060, "lastRevision": {"nodes": [{"id": "5581019098693212", "release_type": "SCHEDULED", "administration_status": "APPROVED"