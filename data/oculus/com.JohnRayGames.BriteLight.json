64_1945118292499243_1021220941998900134_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d-H4SbzYzrIQ7kNvgGWjAfM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiHJqyiwrc0NP5VBxLnnCSCr1Fhfqa5fe47Tc_f_6Axw&oe=6735CDEF"}, {"file_name": "4.png", "id": "1882373772125657", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001664_1882373775458990_7028507716099184885_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DM7GSWku2vYQ7kNvgFOS-ID&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDLzXH7-mbvtZawLl2yOlaeVN9TEiJwP0FZX1GCrUogwQ&oe=6735D202"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "3445578522431678", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_3445578525765011_3918502890170441114_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tkD9Hgta0owQ7kNvgHqo18b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDdKxr3McpDwx1FxxSDbVmhfyLSbo5BiO4H_t_L3CsRw&oe=6735C703"}, "display_name": "Brite Light", "keywords": [], "long_description": "Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light.\n\nEvoke nostalgia and create wonderful works of art with Bright Light.\n\nFun for creative folks and people just looking to chill.  Brite Light is a fun, zen-like creativity room.  Brite Light includes:\n\n- A giant 4ft by 4ft Brite Lite Board;\n\n- Unlimited Pegs To Create With;\n\n-3 Free Brite Light Patterns;\n\n-An Auto-Save Feature So You Can Build Your Creation Over Time;\n\n-An Interactive Room That Includes Interactable Objects.\n\nBrite Light is the perfect Zen-Like experience for relaxing after a long day or clearing your head and letting your mind wonder safely in a fun, relaxing environment.", "short_description": "Evoke nostalgia and create wonderful works of art with Bright Light. Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light."}]}, "developer_name": "John Ray Ga