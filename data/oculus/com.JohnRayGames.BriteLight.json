T8c4_8_6Xw&oe=66D04E82"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "3445578522431678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223478_3445578525765011_3918502890170441114_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bd4k4iBqAYUQ7kNvgGQOjWw&_nc_ht=scontent.oculuscdn.com&oh=00_AYANyNkPXqmc0R17UPjNIps3MnJJZq8jfl0LPy3mobHdpA&oe=66D04383"}, "display_name": "Brite Light", "keywords": [], "long_description": "Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light.\n\nEvoke nostalgia and create wonderful works of art with Bright Light.\n\nFun for creative folks and people just looking to chill.  Brite Light is a fun, zen-like creativity room.  Brite Light includes:\n\n- A giant 4ft by 4ft Brite Lite Board;\n\n- Unlimited Pegs To Create With;\n\n-3 Free Brite Light Patterns;\n\n-An Auto-Save Feature So You Can Build Your Creation Over Time;\n\n-An Interactive Room That Includes Interactable Objects.\n\nBrite Light is the perfect Zen-Like experience for relaxing after a long day or clearing your head and letting your mind wonder safely in a fun, relaxing environment.", "short_description": "Evoke nostalgia and create wonderful works of art with Bright Light. Brite Light is a Zen game from the makers of Zen Monkeys.  Clear your mind, breath and relax with Brite Light."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/britelight", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": f