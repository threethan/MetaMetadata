6e7a0a&_nc_ohc=yMw_lYCJ9XMQ7kNvgGdTiHL&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAqLIauX-fWFn9jeWZ0jhy9c3iwy-1vX6F3A_7h_wbXyQ&oe=67751A02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "3445578522431678", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75223478_3445578525765011_3918502890170441114_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dp1oQ3T9jt8Q7kNvgF4QM6z&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCr-CLD9tJXydUkToqMYxF0f7--GVbyLjwYasxzo0yBkg&oe=67750F03"}, "display_name": "Brite Light", "keywords": ["light", "zen", "puzzle", "art", "create"], "long_description": "Brite Light: A Tranquil Creation Experience\n\nEmbark on a serene journey with Brite Light, brought to you by the creators of Zen Monkeys. Clear your mind, breathe deeply, and unwind in the soothing ambiance of Brite Light.\n\nTap into nostalgia and unleash your creativity with Brite Light.\n\nIdeal for both artistic souls and those seeking relaxation, Brite Light is your personal oasis of creativity. Immerse yourself in a tranquil environment where inspiration flows freely.\n\nKey Features:\n\n\nEXPANSIVE CANVAS: Craft your masterpiece on a spacious, interactive canvas.\n\nINFINATE CREATIONS: Use the pegs and patterns to spark your imagination.\n\nAUTO-SAFE FUNCTIONALITY: Seamlessly save and build upon your creations at your own pace.\n\nINTERACTIVE ENVIRONMENT: Engage with various objects in a serene, virtual room setting.\n\nBrite Light offers the ultimate Zen-like experience, perfect for unwinding after a hectic day or letting your mind wander in a safe, relaxing environment.\n{519716874070859}", "short_description": "Embark on a serene journey with Brite Light, brought to you by the creators of Zen Monkeys. Clear your mind, breathe deeply, and unwind in the soothing ambiance of Brite Light."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/britelight", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8303990156396079"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031478_1407940079877390_340722245891922930_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sHS7lPIOx9sQ7kNvgGaWxyx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDONjRWoVKcQL2OQew38d4KDwK_WL8cstH_SklWWzbXqg&oe=67750FF7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Brite Light", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "release_date": 1679844060, "lastRevision": {"nodes": [{"id": "5581019098693212", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5581019088693213", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "713201320519548"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "1008x1440.pn