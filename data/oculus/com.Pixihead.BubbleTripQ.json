."}, {"images": {"nodes": []}, "id": "1309652353137696", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Bubble Trip 2", "keywords": [], "long_description": "Au centre d'une ar\u00e8ne sph\u00e9rique dont la surface se couvre progressivement de billes.\nVisez et tirez sur les billes pour changer leur couleur et formez des grappes d'au moins 4 billes pour les faire exploser.\nAlignez les coups gagnants pour augmenter le multiplicateur afin de marquer un maximum de points et de recevoir des billes bonus qui vous permettront de d\u00e9truire toutes les billes de l'ar\u00e8ne ou d'\u00e9viter d'\u00eatre submerg\u00e9 par un flux croissant de billes.", "short_description": "Puzzle Shooter."}]}, "developer_name": "Filmo", "developer_privacy_policy_url": "https://pixihead.com/bubble-trip-2-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Pixihead", "support_website_url": null, "website_url": "https://www.pixihead.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1123587924885454"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5678549312202538", "version": "0.35"}, "id": "1338655643298852", "channel_name": "LIVE"}]}, "is_f