licateur afin de marquer un maximum de points et de recevoir des billes bonus qui vous permettront de d\u00e9truire toutes les billes de l'ar\u00e8ne ou d'\u00e9viter d'\u00eatre submerg\u00e9 par un flux croissant de billes.", "short_description": "Puzzle Shooter."}]}, "developer_name": "Filmo", "developer_privacy_policy_url": "https://pixihead.com/bubble-trip-2-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Pixihead", "support_website_url": null, "website_url": "https://www.pixihead.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1123587924885454"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5678549312202538", "version": "0.35"}, "id": "1338655643298852", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5322052644518875", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5678549312202538"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1338655643298852"}]}, "change_