207099", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_673000127540432_6821630397555332269_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7OGKU_TjN4Q7kNvgFyTx0f&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpEDumtRGxU1gS18oReqAGwc4sfPq60GJYvexoKZ_eXQ&oe=66F94B37"}, "display_name": "Surgery Prep", "keywords": [], "long_description": "Help your friend, a narwhal, get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions.  ", "short_description": "Help the narwhal get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://before-inc.com/privacy-policy", "developer_terms_of_service_url": "https://before-inc.com/products", "publisher_name": "Before Inc", "support_website_url": null, "website_url": "https://before-inc.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", 