dn.com/v/t64.5771-25/39031525_2082892158728950_2992807727702231910_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uvfIYGpVRSsQ7kNvgFSnr_c&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU6fpeFa7dlq_hhNbvSkWat&oh=00_AYDiU4SMY6QwTK99Ay-LPuNBitBCq7qIZEvUrGYEZ_6NQA&oe=66F69D3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape_2560x1440.png", "id": "673000124207099", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_673000127540432_6821630397555332269_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jQc8x_gQAM0Q7kNvgHIfFt1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU6fpeFa7dlq_hhNbvSkWat&oh=00_AYDOAvdvG3JDrzKGBnb6w1k2sMOrDf2pgbLB123Ze-eeCQ&oe=66F6A837"}, "display_name": "Surgery Prep", "keywords": [], "long_description": "Help your friend, a narwhal, get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions.  ", "short_description": "Help the narwhal get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://before-inc.com/privacy-policy", "developer_terms_of_service_url": "https://before-inc.com/products