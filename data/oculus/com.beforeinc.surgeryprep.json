&_nc_sid=6e7a0a&_nc_ohc=3v3o7ZH59j0Q7kNvgGOTIBD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUVwDjLQrDdbCFl8Yr22owRoiGDx4K4f85eyynLgIBwg&oe=670E583F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape_2560x1440.png", "id": "673000124207099", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031398_673000127540432_6821630397555332269_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YyQWxCYks9sQ7kNvgEAWBOS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHZJ0nlkZsdoH2goHoi9lnsWQiRjb7wY2X8c5ptv22Kg&oe=670E6337"}, "display_name": "Surgery Prep", "keywords": [], "long_description": "Help your friend, a narwhal, get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions.  ", "short_description": "Help the narwhal get ready for surgery. Accompany them from the pre-op to the operating room. Earn stars by completing activities. It\u2019s like a game, but it helps pediatric patients understand what surgery will be like and feel better about it. As one pediatric patient stated, while playing Surgery Prep at a hospital, \u201cI had fun getting ready for my surgery.\u201d Now you can too because Surgery Prep is available to the public. This is the first release with updates to follow. We welcome suggestions. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://before-inc.com/privacy-policy", "developer_terms_of_service_url": "https://before-inc.com/products", "publisher_name": "Before Inc", "support_website_url": null, "website_url": "https://before-inc.com/", "category":