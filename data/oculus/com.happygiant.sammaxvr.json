trBglAFbt5rd9szWd15Low&oe=677E67A5"}, {"file_name": "SMVRFinalQuestScreenshots13.png", "id": "528250488391317", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39001721_528250491724650_1577659830106612444_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mz0vKLlF42gQ7kNvgHCKxf0&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYD7rXoJOs3_29axBh1JcgHm1E-i-lvxvvFmjPL5TMVk-g&oe=677E5BEC"}, {"file_name": "SMVRFinalQuestScreenshots10.png", "id": "326371915829001", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974680_326371919162334_129873048362627550_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LUIG43gLJQkQ7kNvgE164g1&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBZZ-tNak6XpljmF_kpx89Ch_s73f0Ql2a02APdmzyYHg&oe=677E61AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OculusCover2560x1440VIDEOENDSLATEWITHLEGAL.png", "id": "321306219352083", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39035305_321306222685416_4438699296036008856_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TIzad7Yr5mgQ7kNvgGvbsV9&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYA6eiJ51BarqmEZYaEiHjvAqE11Gcy48545xK7CnZZLAQ&oe=677E4916"}, "display_name": "Sam and Max: This Time It's Virtual!", "keywords": ["Comedy", "Adventure", "Narrative", "Action", "Arcade"], "long_description": "Sam is a dog with a hat.  Max is a hyperkinetic naked rabbity thing.  Together, they\u2019re the Freelance Police, the intergalactically famous agents of indiscriminately applied justice, now starring in their umpteenth video game, Sam & Max: This Time It\u2019s Virtual!  Even multimedia evil-slappers like Sam & Max could use a hand, and this time they\u2019re using the incomprehensible magic of virtual reality to invite the player into their off-kilter world for a furious day of monster-slaying, obstacle courses, responsibly discharged firearms, and, of course, saving the entire freaking world.\nKey features:\n\u2022Discover the horrible and socially relevant secrets lurking behind, under, and within Cap\u2019n Aquabear\u2019s rotting theme park!\n\u2022Push yourself to be the best of the best of the middling, as a dog and a naked rabbity thing harangue and cajole you through a bewildering assortment of Freelance Police Academy training challenges.\n\u2022Immersion so real you can feel Sam\u2019s breath on your neck!\n", "short_description": "Sam is a dog in a suit.  Max is his naked rabbity partner.  Together, they\u2019re the Freelance Police.  Jump into the not-quite-right world of Sam & Max via the wonder science of virtual reality, and join the multimedia darlings in their never-ending quest to slap the stupid grin off the face of evil."}]}, "developer_name": "HappyGiant", "developer_privacy_policy_url": "https://happygiant.com/terms-of-service", "developer_terms_of_service_url": "https://happygiant.com/terms-of-service", "publisher_name": "Big Sugar", "support_website_url": "https://happygiant.com/#contact", "website_url": "http://www.happygiant.com/samandmax", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_VE", "es_AR", "es_PE", "en", "fr", "es", "fr_CA", "es_PR", "fr_BE", "es_CL", "es_MX", "zh_CN", "es_CO"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1056342185237199"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974444_