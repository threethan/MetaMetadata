.\nMINDZENSE DE-STRESS FEATURES: - unique virtual reality environment with unique meditation techniques - captivating and relaxing meditation music - adjustable music and speak track - gaze based and intuitive UI - easy to setup and use - highly effective against stress - relaxes the mind and soul \u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026\u2026 One of the best guided meditation apps. Vastly improve your life. Forget about stress and everyday problems. \nHave a wonderful day!", "short_description": "Take a break and reload your energy"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.mindzense.com/wp-content/uploads/2016/03/Privacy-Policy.pdf", "developer_terms_of_service_url": "http://www.mindzense.com/wp-content/uploads/2016/03/End-user-licence-agreement.pdf", "publisher_name": "Minditorium IVS", "support_website_url": null, "website_url": "http://www.mindzense.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "521014675876243"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12727868_1093303744131311_6556054753124548608_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0SwnoAkLrYMQ7kNvgHUDY8C&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuI9c9qvqzGlUUdXfyAtcbtMK-nv9Q3Y38WycpcKXoSg&oe=66DEED