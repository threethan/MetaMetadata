/v/t64.5771-25/38974506_523378167136800_2928792351118914817_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rRo42rBA8lwQ7kNvgEVbuWc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAh_9z_kCZ5k8SEyc4VjbSRaPEjzZAs_szJiuyNbk25oA&oe=672DE047"}, {"file_name": "Starwave-white-transparent-bg2.png", "id": "469598049092218", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230050_469598052425551_6210667028656987859_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P4uQGtr-vyEQ7kNvgEHhQrB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAzayzxFWSmFPTRjdQK4a-io5X4UQQbF_owSeD-6b3x5A&oe=672DE8EF"}, {"file_name": "Starwave-Key-Art-Square-oct28.png", "id": "423141863939652", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036624_423141867272985_199868837666266316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CHnuMBFub_cQ7kNvgFwt5vH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCM5gu48ThmQX28yQuwjIiDLJOZyABhuotUm_KlHClovw&oe=672DFE2C"}]}, "id": "1261107398534625", "locale": "en_US", "screenshots": [{"file_name": "Bitsummit Screen 5.png", "id": "523173080460191", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031458_523173087126857_5453491403783204118_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A3qo7WvwIXoQ7kNvgE3jZc6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC81Y9y1IWIKu0Jsv6MAowgKlo7YK80H4bjHvnajQv9A&oe=672E0BD0"}, {"file_name": "vlcsnap-2024-06-19-01h00m30s429.png", "id": "989244316237396", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75542968_989244319570729_1181348897418576703_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ocFtWstQpj4Q7kNvgHHF-ua&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKI5pohTHb6qA1bCzODgboaOEaFCYeR6oesID69RtSmw&oe=672DE876"}, {"file_name": "vlcsnap-2024-06-18-23h32m11s912.png", "id": "802919318573388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974626_802919321906721_4454703433468982420_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NrexbIwg0wAQ7kNvgFmkJFS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJMNvL7CcFMyvr84_C4bKRllDvDTT45Vuf_8ymt4sgfA&oe=672DEF22"}, {"file_name": "vlcsnap-2024-06-19-00h16m14s668.png", "id": "477559938163233", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974575_477559941496566_2287056145719861268_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6UNpwAe0jQQ7kNvgEmcX3i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMUYTglNjM7c3iBZJv-CUwqufMBu1ZqBQCSMlwXmzmFQ&oe=672DF9D5"}, {"file_name": "vlcsnap-2024-09-03-15h03m58s811.png", "id": "1339038847501807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974471_1339038850835140_895110495747331504_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mnmx_JGm-nUQ7kNvgF5Ln0o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD75Uk7n47D6Xf9n-_HhOS_29DXG6-79eBCQtPM9DWWZg&oe=672E0900"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Starwave-Key-Art-landscape.png", "id": "968943318328110", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75441576_968943321661443_6833554365313337686_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tb1XqXNi_ZgQ7kNvgFz4OZS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTVx1tDFciIe_YmbJoQffRthkrya4q6851T_XnxWmI3Q&oe=672DE21B"}, "display_name": "STARWAVE", "keywords": ["music", "dance", "fitness", "star", "workout"], "long_description": "Play the top rated new dance music app today and see why the community is raving about Starwave! \n\n\"One of the best VR rhythm games on the market. If you love music, want to improve your fitness, or simply want to immerse yourself in an experience like no other, the answer is clear.\"  -UploadVR\n\n{1224686855429861}\n\n\"Each trip through space is a blast... I can see myself returning again and again.\" - Gaming Age\n\n{830938459116568}\n\n# GAME FEATURES\n\n\ud83e\udd29 **Feel the Adrenaline:** Experience a lightspeed voyage across the stars. Swing at Supernovas in any direction, swirl through Stardust Trails, charge up Comets, and destroy incoming Asteroids. \n\n\u2728 **Free Your Flow:** Create your own style of movement and become the center of gravity. Never flow through a single level the same way twice!\n\n\ud83c\udfb6 **Discover New Music:** Vibe to a pulse-pounding hyperspace soundtrack as you journey across 36 unique areas within six different galaxies. \n\n\ud83c\udf0c **Create Constellations:** Gather star energy and create majestic constellations in the sky. Chill out in \u2018Stargazer\u2019 mode for a meditative retreat to observe your progress.\n\n\ud83d\udcc6 **Play Daily Challenges:** Join the community and play new challenges each day. Tap into the real-time cycles of Earth\u2019s moon for bonus incentives, and complete streaks to rise to the top of the leaderboards!\n\n\ud83d\udc8e **Grab Collectables:** Hone your skills and take a chance at mining the starfield for hidden crystals holding mysteries waiting to be discovered.\n\n{908043680887559}", "short_description": "Starwave is the ultimate high-energy dance voyage through space! Try the top rated new music app today!"}, {"images": {"nodes": []}, "id": "580130151022945", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["musique", "danse", "fitness", "entrainement", "etoile"], "long_description": "\u00ab L'un des meilleurs jeux VR de rythme sur le march\u00e9. Si vous raffolez de musique, que vous voulez parfaire votre condition physique ou que vous voulez simplement vous immerger dans une exp\u00e9rience sans pareille, la r\u00e9ponse est claire. \u00bb \u2013 UploadVR\n\n{593502973005867}\n\n# LES CARACT\u00c9RISTIQUES DU JEU\n\n\ud83e\udd29 **Resentez l'adr\u00e9naline :** Faites l\u2019exp\u00e9rience d\u2019un p\u00e9riple \u00e0 la vitesse de la lumi\u00e8re \u00e0 travers les \u00e9toiles. Frayez-vous un chemin vers les supernovas dans toutes les directions, tourbillonnez dans les tra\u00een\u00e9es de poussi\u00e8res d'\u00e9toiles, chargez les com\u00e8tes et d\u00e9truisez les ast\u00e9ro\u00efdes qui arrivent.\n\n\u2728 **Lib\u00e9rez votre corps :** Cr\u00e9ez votre propre style de mouvement et devenez le centre de gravit\u00e9. Ne traversez jamais deux fois le m\u00eame niveau de la m\u00eame fa\u00e7on !\n\n\ud83c\udfb6 **D\u00e9couvrez de nouvelles musiques :** Vibrez au rythme d'une bande-son palpitante en hyper-espace alors que vous cheminez \u00e0 travers 36 zones uniques dans six galaxies diff\u00e9rentes.\n\n\ud83c\udf0c **Cr\u00e9er des constellations :** Rassemblez l'\u00e9nergie des \u00e9toiles et r\u00e9alisez de majestueuses constellations dans le ciel. D\u00e9tendez-vous en mode \u00ab Stargazer \u00bb (Astronome) pour une retraite m\u00e9ditative et observez vos progr\u00e8s.\n\n\ud83d\udcc6 **Disputer les d\u00e9fis quotidiens :** Rejoignez la communaut\u00e9 et relevez de nouveaux d\u00e9fis chaque jour. Exploitez les cycles en temps r\u00e9el de la lune afin de vous octroyer des bonus, et r\u00e9alisez des s\u00e9ries pour vous hisser au sommet des classements !\n\n{1085000919966811}", "short_description": "Starwave est l'ultime \u00e9pop\u00e9e d\u2019une danse \u00e0 haute \u00e9nergie dans l'espace ! Essayez la nouvelle application musicale la mieux not\u00e9e aujourd'hui ! "}, {"images": {"nodes": [{"file_name": "38974506_523378167136800_2928792351118914817_n.png", "id": "1110370573836031", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974869_1110370577169364_2600734861209428907_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HayjwrkNSXEQ7kNvgHCeWJh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqH6dlc6zJ6qIj-6nbGOeztiuxdDJZwxdfZSgq6-bJCg&oe=672DFCE3"}]}, "id": "579801327730809", "locale": "it_IT", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["musica", "danza", "esercizi", "stella", "allenamento"], "long_description": "Prova la nuova app musicale con le migliori recensioni e scopri perch\u00e9 la comunit\u00e0 impazzisce per Starwave!\n\n\"Uno dei migliori giochi ritmici in realt\u00e0 virtuale sul mercato. Se ami la musica, vuoi miglioreare la tua forma fisica o vuoi semplicemente immergerti in un'esperienza senza pari, la scelta \u00e8 ovvia.\" -UploadVR\n\n{1070529785078419}\n\n# CARATTERISTICHE DEL GIOCO\n\n\ud83e\udd29 **Senti l'adrenalina:** parti tra le stelle per un viaggio alla velocit\u00e0 della luce. Colpisci Supernove in ogni direzione, volteggia nelle scie di polvere stellare, vai alla carica delle comete e distruggi gli asteroidi in arrivo. \n\n\u2728 **Muoviti in libert\u00e0:** crea il tuo modo di muoverti e diventa il centro di gravit\u00e0. Ogni livello sar\u00e0 sempre diverso dal precedente!\n\n\ud83c\udfb6 **Scopri nuova musica:** lasciati trasportare da una coinvolgente colonna sonora iperspaziale mentre esplori 36 aree differenti sparse per sei galassie. \n\n\ud83c\udf0c **Plasma le costellazioni:** raccogli l'energia stellare e crea maestose costellazioni nel cielo. Rilassati nella modalit\u00e0 'Osservatore Stellare' concedendoti una pausa meditativa per ammirare i tuoi progressi.\n\n\ud83d\udcc6 **Affronta sfide quotidiane:** unisciti alla community e affronta ogni giorno nuove sfide. Sfrutta i cicli lunari in tempo reale per ottenere bonus extra e completa serie consecutive per scalare le classifiche!\n\n\ud83d\udc8e **Raccogli oggetti preziosi** affina le tue abilit\u00e0 e mettiti alla prova esplorando il campo stellare alla ricerca di cristalli nascosti che celano misteri tutti da svelare.\n\n{2212724322441875}", "short_description": "Starwave: un viaggio musicale travolgente nello spazio a ritmo di danza! Prova subito la nuova app musicale con le migliori valutazioni!"}, {"images": {"nodes": []}, "id": "565656485932933", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["\u97f3\u697d", "\u30c0\u30f3\u30b9", "\u30d5\u30a3\u30c3\u30c8\u30cd\u30b9", "\u30b9\u30bf\u30fc", "\u30ef\u30fc\u30af\u30a2\u30a6\u30c8"], "long_description": "\u4eca\u3059\u3050\u3053\u306e\u6700\u9ad8\u8a55\u4fa1\u306e\u65b0\u4f5c\u97f3\u697d\u30a2\u30d7\u30ea\u3092\u30d7\u30ec\u30a4\u3057\u3066\u3001\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u306e\u4eba\u3005\u304cStarwave\u3092\u7d76\u8cdb\u3059\u308b\u7406\u7531\u3092\u78ba\u304b\u3081\u3066\u304f\u3060\u3055\u3044\uff01\n\n\u300c\u3053\u306e\u5e02\u5834\u3067\u6700\u9ad8\u306eVR\u30ea\u30ba\u30e0\u30b2\u30fc\u30e0\u306e\u4e00\u3064\u3067\u3059\u3002\u97f3\u697d\u304c\u597d\u304d\u306a\u65b9\u3001\u30d5\u30a3\u30c3\u30c8\u30cd\u30b9\u3092\u5411\u4e0a\u3055\u305b\u305f\u3044\u65b9\u3001\u5358\u306b\u4ed6\u306b\u306f\u306a\u3044\u4f53\u9a13\u306b\u6ca1\u982d\u3057\u305f\u3044\u65b9\u3001\u7b54\u3048\u306f\u660e\u78ba\u3067\u3059\u300d  -\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9VR\n\n\u300c\u5b87\u5b99\u3092\u65c5\u3059\u308b\u305f\u3073\u306b\u6700\u9ad8\u306b\u697d\u3057\u3044\u3067\u3059...\u4f55\u5ea6\u3082\u30ea\u30d4\u30fc\u30c8\u3057\u3066\u3057\u307e\u3046\u3067\u3057\u3087\u3046\u300d - Gaming Age\n\n{853272083644589}\n\n# \u30b2\u30fc\u30e0\u306e\u7279\u5fb4\n\n\ud83e\udd29 **\u30a2\u30c9\u30ec\u30ca\u30ea\u30f3\u3092\u611f\u3058\u308b\uff1a** \u661f\u3005\u3092\u5149\u901f\u3067\u65c5\u3057\u307e\u3057\u3087\u3046\u3002\u8d85\u65b0\u661f\u3092\u7e26\u6a2a\u7121\u5c3d\u306b\u632f\u308a\u56de\u3057\u3001\u30b9\u30bf\u30fc\u30c0\u30b9\u30c8\u30c8\u30ec\u30a4\u30eb\u3092\u65cb\u56de\u3057\u3001\u5f57\u661f\u3092\u30c1\u30e3\u30fc\u30b8\u3057\u3001\u8972\u3044\u6765\u308b\u5c0f\u60d1\u661f\u3092\u7834\u58ca\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\n\u2728 **\u81ea\u5206\u3089\u3057\u3055\u3092\u89e3\u304d\u653e\u3064\uff1a** \u81ea\u5206\u3060\u3051\u306e\u52d5\u304d\u306e\u30b9\u30bf\u30a4\u30eb\u3092\u4f5c\u308a\u3001\u91cd\u5fc3\u306b\u306a\u308a\u307e\u3057\u3087\u3046\u3002\u540c\u3058\u30ec\u30d9\u30eb\u30922\u5ea6\u540c\u3058\u3088\u3046\u306b\u6d41\u308c\u306a\u3044\u3067\u304f\u3060\u3055\u3044\uff01\n\n\ud83c\udfb6 **\u65b0\u3057\u3044\u97f3\u697d\u3092\u767a\u898b\u3059\u308b\uff1a** 6\u3064\u306e\u7570\u306a\u308b\u9280\u6cb3\u306b\u3042\u308b36\u306e\u30e6\u30cb\u30fc\u30af\u306a\u30a8\u30ea\u30a2\u3092\u65c5\u3057\u306a\u304c\u3089\u3001\u30c9\u30ad\u30c9\u30ad\u3059\u308b\u3088\u3046\u306a\u8d85\u7a7a\u9593\u306e\u30b5\u30a6\u30f3\u30c9\u30c8\u30e9\u30c3\u30af\u306b\u8eab\u3092\u4efb\u305b\u307e\u3057\u3087\u3046\u3002\n\n\ud83c\udf0c  **\u661f\u5ea7\u3092\u4f5c\u308b\uff1a** \u661f\u306e\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u96c6\u3081\u3066\u3001\u7a7a\u306b\u58ee\u5927\u306a\u661f\u5ea7\u3092\u4f5c\u308a\u307e\u3057\u3087\u3046\u3002\u300c\u30b9\u30bf\u30fc\u30b2\u30a4\u30b6\u30fc\u300d\u30e2\u30fc\u30c9\u3067\u30ea\u30e9\u30c3\u30af\u30b9\u3057\u3066\u3001\u7791\u60f3\u7684\u306a\u30ea\u30c8\u30ea\u30fc\u30c8\u3067\u81ea\u5206\u306e\u9032\u6b69\u3092\u89b3\u5bdf\u3057\u307e\u3057\u3087\u3046\u3002\n\n\ud83d\udcc6 **\u30c7\u30a4\u30ea\u30fc\u30c1\u30e3\u30ec\u30f3\u30b8\u3092\u30d7\u30ec\u30a4\uff1a** \u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u306b\u53c2\u52a0\u3057\u3066\u3001\u6bce\u65e5\u65b0\u3057\u3044\u30c1\u30e3\u30ec\u30f3\u30b8\u3092\u30d7\u30ec\u30a4\u3057\u307e\u3057\u3087\u3046\u3002\u30dc\u30fc\u30ca\u30b9\u306e\u305f\u3081\u306b\u5730\u7403\u306e\u6708\u306e\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u306e\u30b5\u30a4\u30af\u30eb\u3092\u5229\u7528\u3057\u3001\u9023\u7d9a\u8a18\u9332\u3092\u9054\u6210\u3057\u3066\u30ea\u30fc\u30c0\u30fc\u30dc\u30fc\u30c9\u306e\u30c8\u30c3\u30d7\u306b\u4e0a\u308a\u8a70\u3081\u307e\u3057\u3087\u3046\uff01\n\n\ud83d\udc8e **\u53ce\u96c6\u54c1\u3092\u7372\u5f97\uff1a** \u30b9\u30ad\u30eb\u3092\u78e8\u304d\u3001\u767a\u898b\u3055\u308c\u308b\u306e\u3092\u5f85\u3063\u3066\u3044\u308b\u8b0e\u3092\u79d8\u3081\u305f\u96a0\u3055\u308c\u305f\u30af\u30ea\u30b9\u30bf\u30eb\u3092\u7372\u5f97\u3059\u308b\u305f\u3081\u306b\u3001\u661f\u7a7a\u3092\u63a1\u6398\u3059\u308b\u30c1\u30e3\u30f3\u30b9\u306b\u6311\u307f\u307e\u3057\u3087\u3046\u3002\n\n{535803669262936}", "short_description": "Starwave\u306f\u5b87\u5b99\u3092\u65c5\u3059\u308b\u7a76\u6975\u306e\u30cf\u30a4\u30a8\u30cd\u30eb\u30ae\u30fc\u306a\u30c0\u30f3\u30b9\u3067\u3059\uff01\u30c8\u30c3\u30d7\u30af\u30e9\u30b9\u306e\u97f3\u697d\u30a2\u30d7\u30ea\u3092\u4eca\u3059\u3050\u304a\u8a66\u3057\u304f\u3060\u3055\u3044\uff01"}, {"images": {"nodes": []}, "id": "359271130541738", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["m\u00fasica", "baile", "fitness", "estrella", "entrenamiento"], "long_description": "\u00a1Juega hoy con la aplicaci\u00f3n de m\u00fasica mejor valorada y descubre por qu\u00e9 la comunidad no para de hablar de Starwave! \n\n\"Uno de los mejores juegos de ritmo en VR del mercado. Si amas la m\u00fasica, quieres mejorar tu estado f\u00edsico o simplemente quieres sumergirte en una experiencia como ninguna otra, la respuesta est\u00e1 clara.\" -UploadVR\n\n\"Cada viaje por el espacio es una pasada... Me veo volviendo una y otra vez.\" - Gaming Age\n\n{856208169977641}\n\n# CARACTER\u00cdSTICAS DEL JUEGO\n\n\ud83e\udd29 **Siente la adrenalina:** Experimenta un viaje a la velocidad de la luz a trav\u00e9s de las estrellas. Golpea Supernovas en cualquier direcci\u00f3n, gira por los Senderos de Polvo Estelar, carga Cometas y destruye los Asteroides que se acercan. \n\n\u2728 **Libera tu flow:** Crea tu propio estilo de movimiento y convi\u00e9rtete en el centro de gravedad. \u00a1Nunca recorrer\u00e1s un nivel de la misma forma dos veces!\n\n\ud83c\udfb6 **Descubre nueva m\u00fasica:** Vibra con una banda sonora de alta intensidad mientras viajas por 36 \u00e1reas \u00fanicas en seis galaxias diferentes. \n\n\ud83c\udf0c **Crea constelaciones:** Re\u00fane energ\u00eda estelar y crea majestuosas constelaciones en el cielo. Rel\u00e1jate en el modo \"Observador de Estrellas\" para un retiro meditativo y observa tu progreso.\n\n\ud83d\udcc6 **Juega desaf\u00edos diarios:** \u00danete a la comunidad y juega nuevos desaf\u00edos cada d\u00eda. Con\u00e9ctate a los ciclos reales de la luna de la Tierra para obtener bonificaciones adicionales y completa rachas para llegar a lo m\u00e1s alto de las clasificaciones.\n\n{536641685967019}", "short_description": "\u00a1Starwave es el m\u00e1ximo viaje de baile lleno de energ\u00eda a trav\u00e9s del espacio! \u00a1Prueba hoy la aplicaci\u00f3n de m\u00fasica mejor valorada!"}]}, "developer_name": "Tigertron / Skymap Games", "developer_privacy_policy_url": "https://www.tigertron.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Tigertron / Skymap Games", "support_website_url": "https://www.tigertron.co/contact", "website_url": "http://www.playstarwave.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8757085591016092"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036624_423141867272985_199868837666266316_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_n