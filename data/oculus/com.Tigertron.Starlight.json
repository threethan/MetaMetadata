{"data": {"node": {"__typename": "Application", "id": "3844341792290521", "organization": {"id": "560204500999287", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4687013941420060"}]}, "id": "430218515482525"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "3844341792290521"}]}, "id": "250075246659994"}]}}, "firstRevision": {"nodes": [{"application": {"id": "3844341792290521", "release_date": 1725555600, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 4}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8634233933301259"}, "id": "927032141372592"}]}}, "binary": null, "live_binary": null, "created_date": 1730149315, "id": "8757030901021561", "is_initial_release": false, "name_with_fallback": "v18", "pdp_metadata_with_fallback": {"version": 16, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8757085591016092"}, "release_status": "RELEASED", "id": "3844341792290521"}, "id": "8757085591016092", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3844341792290521", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "857125266277939"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "9456374457711940", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["\uc74c\uc545", "\ub304\uc2a4", "\ud53c\ud2b8\ub2c8\uc2a4", "\ubcc4", "\uc6b4\ub3d9"], "long_description": "\uc9c0\uae08 \ubc14\ub85c \ucd5c\uace0 \ud3c9\uc810\uc744 \ubc1b\uc740 \uc0c8\ub85c\uc6b4 \uc74c\uc545 \uac8c\uc784\uc744 \ud50c\ub808\uc774\ud558\uace0 \ucee4\ubba4\ub2c8\ud2f0\uac00 Starwave\uc5d0 \uc5f4\uad11\ud558\ub294 \uc774\uc720\ub97c \ud655\uc778\ud574 \ubcf4\uc138\uc694! \n\n\"\ud604\uc874\ud558\ub294 \ucd5c\uace0\uc758 VR \ub9ac\ub4ec \uac8c\uc784 \uc911 \ud558\ub098\uc785\ub2c8\ub2e4. \uc74c\uc545\uc744 \uc0ac\ub791\ud558\uac70\ub098, \uccb4\ub825\uc744 \uae30\ub974\uace0 \uc2f6\uac70\ub098, \uadf8\uc800 \uc544\uc8fc \ud2b9\ubcc4\ud55c \uacbd\ud5d8\uc5d0 \ubab0\uc785\ud558\uace0 \uc2f6\ub2e4\uba74 \uadf8 \ub2f5\uc740 \uba85\ud655\ud569\ub2c8\ub2e4.\" -UploadVR\n\n\"\uc6b0\uc8fc\ub97c \uc5ec\ud589\ud560 \ub54c\ub9c8\ub2e4 \uac00\uc2b4\uc774 \ud130\uc9c8 \uac83 \uac19\uc740 \uae30\ubd84\uc785\ub2c8\ub2e4... \uba87 \ubc88\uc774\uace0 \uacc4\uc18d \ub3cc\uc544\uc624\ub294 \uc790\uc2e0\uc744 \ubc1c\uacac\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.\" -Gaming Age\n\n{1007021181183135}\n\n# \uac8c\uc784 \ud2b9\uc9d5\n\n\ud83e\udd29 **\ud3ed\ubc1c\ud558\ub294 \uc544\ub4dc\ub808\ub0a0\ub9b0:** \ube5b\uc758 \uc18d\ub3c4\ub85c \ubcc4\ub4e4\uc744 \uac00\ub85c\uc9c8\ub7ec \ud56d\ud574\ud558\uc138\uc694. \uc544\ubb34 \ubc29\ud5a5\uc73c\ub85c \ucd08\uc2e0\uc131\uc744 \ud5a5\ud574 \ud718\ub450\ub974\uace0, \ubcc4\ubb34\ub9ac\uc758 \uc790\ucde8\ub97c \ub530\ub77c \ube59\ube59 \ub3cc\uace0, \ud61c\uc131\uc744 \ucda9\uc804\ud558\uace0, \ub2e4\uac00\uc624\ub294 \uc18c\ud589\uc131\uc744 \ud30c\uad34\ud558\uc138\uc694.\n\n\u2728 **\uc790\uc720\ub85c\uc6b4 \uc720\uc601:** \ub098\ub9cc\uc758 \ub3d9\uc791 \uc2a4\ud0c0\uc77c\uc744 \ub9cc\ub4e4\uace0 \uc911\ub825\uc758 \uc911\uc2ec\uc774 \ub418\uc138\uc694. \ud55c \ub808\ubca8\uc744 \ub2e4\ub978 \ubc29\uc2dd\uc73c\ub85c \uc720\uc601\ud574 \ubcf4\uc138\uc694!\n\n\ud83c\udfb6 **\uc0c8\ub85c\uc6b4 \uc74c\uc545\uc758 \ubc1c\uacac:** 6\uac1c\uc758 \uc740\ud558\uacc4 \ub0b4\uc5d0 \uc788\ub294 36\uac1c\uc758 \ub3c5\ud2b9\ud55c \uc9c0\uc5ed\uc744 \uc5ec\ud589\ud558\uba74\uc11c \uc2ec\uc7a5\uc774 \ub450\uadfc\uac70\ub9ac\ub294 \ucd08\uacf5\uac04\uc801 \uc0ac\uc6b4\ub4dc\ud2b8\ub799\uc5d0 \ubab8\uc744 \ub9e1\uaca8 \ubcf4\uc138\uc694.\n\n\ud83c\udf0c **\ubcc4\uc790\ub9ac \ucc3d\uc870:** \ubcc4 \uc5d0\ub108\uc9c0\ub97c \ubaa8\uc544 \ud558\ub298\uc5d0 \uc7a5\uc5c4\ud55c \ubcc4\uc790\ub9ac\ub97c \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694. '\ubcc4 \uad00\ucc30\uc790' \ubaa8\ub4dc\uc5d0\uc11c \uba85\uc0c1\uacfc \ud568\uaed8 \ud734\uc2dd\uc744 \uc990\uae30\uba70 \uc9c4\ud589 \uc0c1\ud669\uc744 \ud655\uc778\ud574 \ubcf4\uc138\uc694.\n\n\ud83d\udcc6 **\uc77c\uc77c \ub3c4\uc804 \ud50c\ub808\uc774:** \ucee4\ubba4\ub2c8\ud2f0\uc5d0 \ucc38\uc5ec\ud574 \ub9e4\uc77c \uc0c8\ub85c\uc6b4 \ub3c4\uc804\uc744 \ud50c\ub808\uc774\ud574 \ubcf4\uc138\uc694. \uc9c0\uad6c \ub2ec\uc758 \uc2e4\uc2dc\uac04 \uc8fc\uae30\ub97c \uc774\uc6a9\ud574 \ubcf4\ub108\uc2a4 \uc778\uc13c\ud2f0\ube0c\ub97c \ubc1b\uace0 \uc5f0\uc18d \uc644\ub8cc\ud558\uc5ec \uc21c\uc704\ud45c \uc815\uc0c1\uc5d0 \uc624\ub974\uc138\uc694!\n\n\ud83d\udc8e **\uc218\uc9d1\ud488 \ud68d\ub4dd:** \uc2e4\ub825\uc744 \uc5f0\ub9c8\ud558\uace0 \ubcc4\ubc2d\uc5d0\uc11c \ubbf8\uc2a4\ud130\ub9ac\ub97c \uac10\ucd94\uace0 \uc788\ub294 \uc228\uaca8\uc9c4 \uc218\uc815\uc744 \ucc44\uad74\ud560 \uae30\ud68c\ub97c \uc7a1\uc73c\uc138\uc694.\n\n{3843452385936459}", "short_description": "Starwave\ub294 \uadf9\uac15\uc758 \uc5d0\ub108\uc9c0\ub97c \ubc1c\uc0b0\ud558\uba70 \uc6b0\uc8fc\ub97c \uc5ec\ud589\ud558\ub294 \ub304\uc2a4 \uac8c\uc784\uc785\ub2c8\ub2e4! \uc9c0\uae08 \ubc14\ub85c \ucd5c\uace0 \ud3c9\uac00\ub97c \ubc1b\uc740 \uc74c\uc545 \uac8c\uc784\uc744 \ud50c\ub808\uc774\ud574 \ubcf4\uc138\uc694!"}, {"images": {"nodes": []}, "id": "1273589220501192", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "STARWAVE", "keywords": ["Musik", "Tanzen", "Fitness", "Stern", "Training"], "long_description": "Spiele noch heute die am besten bewertete neue Musik-App und finde heraus, wieso die Community von Starwave begeistert ist!\n\n\"Eines der besten VR-Rhythmusspiele auf dem Markt. Wenn du Musik liebst, deine Fitness verbessern m\u00f6chtest oder einfach nur in eine unvergleichliche Erfahrung eintauchen m\u00f6chtest, ist die Antwort klar.\" - UploadVR\n\n\"Jeder Trip durch den Weltraum ist umwerfend ... ich wei\u00df schon jetzt, dass ich immer wieder zur\u00fcckkehren werde.\" - Gaming Age\n\n{1077390040711091}\n\n# SPIELEIGENSCHAFTEN\n\n\ud83e\udd29 **Sp\u00fcre das Adrenalin:** Erlebe eine Reise zwischen den Sternen mit Lichtgeschwindigkeit. Hole in jeder Richtung zum Schlag gegen Supernovas aus, wirbele durch Sternenstaub-Schweife, st\u00fcrme gegen Kometen an und vernichte herannahende Asteroiden. \n\n\u2728 **Befreie deine Bewegung:** Gestalte deinen eigenen Bewegungsstil und werde zum Gravitationszentrum. Bewege dich durch kein einziges Level zwei Mal auf dieselbe Weise!\n\n\ud83c\udfb6 **Entdecke neue Musik:** Lass dich von einem mitrei\u00dfenden Hyperraum-Soundtrack packen, w\u00e4hrend du 36 einzigartige Gebiete in sechs verschiedenen Galaxien durchreist. \n\n\ud83c\udf0c **Erschaffe Sternbilder:** Sammle Sternenenergie und erschaffe majest\u00e4tische Sternbilder am Himmel. \n\n\ud83d\udcc6 **Spiele t\u00e4gliche Herausforderungen:** Schlie\u00dfe dich der Community an und spiele jeden Tag neue Herausforderungen. Mache dir die Echtzeit-Zyklen des Erdmonds f\u00fcr Bonus-Anreize zunutze und vervollst\u00e4ndige Serien, um an die Spitzen der Ranglisten aufzusteigen!\n\n{571324935369045}", "short_description": "Starwave ist die ultimative energiegeladene Tanzreise durch den Weltraum! Probiere die am besten bewertete neue Musik-App noch heute aus!"}, {"images": {"nodes": [{"file_name": "Starwave-Key-Art-Icon-oct28a.png", "id": "3790134337905490", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036671_3790134341238823_2561148543752046545_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KB3QwWezRPYQ7kNvgEK-fTY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlrFxGmLidCYi1XGQo4UrjthQBCACz23X1vEBcfMCxSA&oe=672E0AFE"}, {"file_name": "Meta_Immersive-Logo_01.png", "id": "3748041782078151", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984472_3748041785411484_170841805742517247_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BXRpA8aBBAsQ7kNvgF6lrTr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9u2uIKzcLpfe8-L2QjCzZA9D_NZmRX1ZPCVVPHsUMpA&oe=672DE5A1"}, {"file_name": "Meta_Immersive-Backdrop_01.png", "id": "1712294642920865", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221317_1712294649587531_5076947331673200485_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4LONNcwSFHgQ7kNvgGG9CSg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD6hzpzIuIIztzUAsN34A2wxsyTDJh_xHeVXnOkly6svg&oe=672DF87F"}, {"file_name": "Starwave-Key-Art-Portrait-oct28.png", "id": "1621918338706931", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982729_1621918345373597_2370853251640145470_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IDWtCmVLd0gQ7kNvgEWE223&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_Zr3qa7YwnEORH0AKPzR5QzkQ4yjHFKONWVYmXD7DXg&oe=672DFF05"}, {"file_name": "Meta_Immersive-Object-Left_01.png", "id": "1566045877670086", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/227909024_1566045881003419_5139495384960872382_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXCvTX0g0d0Q7kNvgEq3KTS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0DPN1At8CL-l9mG9fqBVceBCa1eH1HST0cS-Kq4aKKA&oe=672DE6F2"}, {"file_name": "38974506_523378167136800_2928792351118914817_n.png", "id": "1224686855429861", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375081_1224686858763194_8157