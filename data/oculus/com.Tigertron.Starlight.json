h27m36s987.png", "id": "832995295396285", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036686_832995298729618_477643639364824942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Mde2-tSLMUQ7kNvgGjOvae&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyhl-hN2K5BsqYRDvXgwPacsF0dCKVx3jD6ZBy8UTNFw&oe=66F13A4C"}, {"file_name": "vlcsnap-2024-06-19-00h16m14s668.png", "id": "477559938163233", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974575_477559941496566_2287056145719861268_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Th1vBEuOP64Q7kNvgGHMHc7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCGAZUH9O_-OgxR2aJNk5gSQj06LPnd-QkVrtyxMrHh-g&oe=66F154D5"}, {"file_name": "vlcsnap-2024-06-19-01h00m30s429.png", "id": "989244316237396", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542968_989244319570729_1181348897418576703_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Oo_4LIj18-gQ7kNvgHlCdOc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWmiU9wN_s_ZBxkNxH2PA8PCD5L2bcYg_hMAT_htlkZA&oe=66F14376"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "starlight-screenshot-7.png", "id": "948696866751343", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322602_948696870084676_9063999772544294177_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WhPBCBK5daMQ7kNvgHlhwPT&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0jXQasVoQCQJO5fYkLlx1qhl64vRibxf913pCefk7sw&oe=66F147BA"}, "display_name": "STARWAVE", "keywords": ["stars", "space", "music", "dance", "fitness"], "long_description": "STARWAVE launches you into a cosmic voyage of high-energy music and exhilarating freeform movement inviting you to discover a new way to flow. Feel the rhythm of the universe as you soar through distant galaxies bringing color and light to the night sky. Ride an uplifting wave of energy that delivers you a daily rush of interstellar euphoria \u2013 no subscriptions required.\n\n# GAME FEATURES\n\n- **Feel the Adrenaline:** Experience a lightspeed voyage across the stars. Swing at Supernovas in any direction, swirl through Stardust Trails, charge up Comets, and destroy incoming Asteroids. \n- **Free Your Flow:** Create your own style of movement and become the center of gravity. Never flow through a single level the same way twice!\n- **Discover New Music:** Vibe to a pulse-pounding hyperspace soundtrack as you journey across 36 unique areas within six different galaxies.\n- **Create Constellations:** Gather star energy and create majestic constellations in the sky. Chill out in \u2018Stargazer\u2019 mode for a meditative retreat to observe your progress.\n- **Play Daily Challenges:** Join the community and play new challenges each day. Tap into the real-time cycles of Earth\u2019s moon for bonus incentives, and complete streaks to rise to the top of the leaderboards!\n- **Grab Collectables:** Hone your skills and take a chance at mining the starfield for hidden crystals holding mysteries waiting to be discovered.\n\nComing This September to Meta Quest 2 and Meta Quest 3. Wishlist today to be first in line. ", "short_description": "STARWAVE launches you into a cosmic voyage of high-energy music and exhilarating freeform movement inviting you to discover a new way to flow. Feel the rhythm of the universe as you soar through distant galaxies bringing color and light to the night sky.  "}]}, "developer_name": "Skymap Games", "developer_privacy_policy_url": "https://www.tigertron.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Tigertron", "support_website_url": "https://www.tigertron.co/contact", "website_url": "http://www.playstarwave.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "247629274201183"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1235196074161184"}, {"status": "PUBLISHED", "id": "235793169629279"}, {"status": "PUBLISHED", "id": "1189105702292774"}, {"status": "PUBLISHED", "id": "513832387807224"}]}, "baseline_offer": {"id": "235793169629279"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1235196074161184"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8429108050480516", "version": "1.0"}, "id": "927032141372592", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3844341792290521", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8429108050480516"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726691289, "id": "8438992852825369", "version": "1.0", "version_code": 828, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8438991739492147"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3844341792290521", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8429108050480516"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "927032141372592"}]}, "change_log": "We've just pushed the first ever STARWAVE update to the app! Be sure to update and make sure you're on v0.1.827, as displayed in the top-center of the main menu.\n\nIMPORTANT CHANGES TO COMFORT SETTINGS:\nYou spoke, and we listened. The height of our flow settings under 'Comfort' has now been slightly lowered universally. You will likely need to re-adjust your settings to find which newly updated setting works best for you. \n\nThis also means that the new 'Low' setting is now closer to your waist than it has ever been; the new 'Medium' setting is equal to our previous 'Low' setting; and the new 'High' setting is now closer to the old 'Medium' setting. Listen to your body and find which newly updated combination of settings best suits your needs!\n\nSome other STARWAVE improvements you may notice:\n- Space environments have been improved in various areas for richer color vibrance and variety.\n - We've smoothed out some of the visual effects on stardust trails. Be sure to keep those wands moving and swirl beyond the trails for some freestyle fun!\n - First time users will now be given a new set of fan-favorite levels on their first Daily Voyage.\n - Moon Phase bonuses have been adjusted to clarify your bonus rewards. Don't miss playing on days with Full/New/Quarter Moons on the real-world calendar for extra points after your Daily Voyage!\n - The Tutorial has been improved for legibility.  \n- Stargazer Mode has also been updated after player feedback for a more accessible way to watch constellations come to life from a seated position.\n\nBeyond these updates, we've also been prepping some underlying technology necessary for us to soon provide optional new galaxies to the expanding STARWAVE universe! Look for more news on that soon. ;)\n\nLook to the skies and be sure to join our Official STARWAVE Community on Facebook or our Discord to join the conversation, meet other voyagers, and connect directly with the dev team to have your voices heard.\n\nSTARWAVE Discord: https://discord.com/invite/rRXuJp9m6n \nSTARWAVE Community on Facebook: https://www.facebook.com/groups/playstarwave\n\nThanks to everyone for voyaging with us so far. We can't wait to see where we all go together on the voyage ahead!\n\n -Team STARWAVE\n", "created_date": 1726599660, "id": "8429108050480516", "version": "1.0", "version_code": 827, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8429106670480654"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3844341792290521", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8429108050480516"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726514177, "id": "8419594131431908", "version": "1.0", "version_code": 826, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8419592204765434"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3844341792290521", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8429108050480516"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726269146, "id": "8394369753954346", "version": "1.0", "version_code": 825, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8394368690621119"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "Android