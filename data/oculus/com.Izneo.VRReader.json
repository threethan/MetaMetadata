 et retrouvez vos albums \u00e0 lire en r\u00e9alit\u00e9 virtuelle dans des environnements configurables."}, {"images": {"nodes": [{"file_name": "1080x360_bg.png", "id": "1205263993211836", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_1205263996545169_9148883512724487229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rkVW4_d51gAQ7kNvgFiJfE5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtONTfvV0S5PMijnXeYJd7yU7G36irh9Hdk3GBhc-L5g&oe=66CB13F4"}, {"file_name": "512.png", "id": "1050334919080944", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_1050334922414277_3741888985697961122_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F9jSZWWYfrAQ7kNvgFqVsEq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDT4CJU4mSbidTQgyftJZ5jAOkzLM6HgtqmOhg1KiZ5xg&oe=66CB1556"}, {"file_name": "2560x1440_bg.png", "id": "715429989842664", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982580_715429993175997_4462372464006952430_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ciHYGgJ4DS8Q7kNvgEs1qTl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbQAtj3rTXyvxQ9adbgM1NpZAUJBowM2D_SDzYCu5TSw&oe=66CB2A77"}, {"file_name": "3000x900_pdp-art-safezone.png", "id": "629709414781356", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974472_629709421448022_713197402145434487_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oN1ZN7oF1rIQ7kNvgFwCK7I&_nc_ht=scontent.oculuscdn.com&oh=00_AYANgPIOHzxNokc-2byXw_CKYfotu38_gJYh0w0jGRItgg&oe=66CB2B5B"}, {"file_name": "logo_izneo_9000x1440_transp.png", "id": "347166343946260", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974762_347166347279593_3265815558868633434_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dVCzro6XUpkQ7kNvgEtII30&_nc_ht=scontent.oculuscdn.com&oh=00_AYBK6Dar2dt3afSi4WTLCvAf0iMwBRqnTa0XIiORff5xKw&oe=66CAFFCE"}, {"file_name": "1008x144