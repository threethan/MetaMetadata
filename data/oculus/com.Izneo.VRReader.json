 et retrouvez vos albums \u00e0 lire en r\u00e9alit\u00e9 virtuelle dans des environnements configurables."}, {"images": {"nodes": [{"file_name": "1080x360_bg.png", "id": "1205263993211836", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_1205263996545169_9148883512724487229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hoggYfTvlIwQ7kNvgFw_C9u&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyqJXK_hTEP_Gw1tSNEmJKWRACgceTwyrKPbD4pJMQgw&oe=66D1AB74"}, {"file_name": "512.png", "id": "1050334919080944", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_1050334922414277_3741888985697961122_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9eCXO67wZVoQ7kNvgGcVQrU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIZlEGZLVZhImNWJXBrlG1o-EW_e8GM2qZpNBPi6sbQA&oe=66D1ACD6"}, {"file_name": "2560x1440_bg.png", "id": "715429989842664", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982580_715429993175997_4462372464006952430_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=494YLKqSn4EQ7kNvgHSr-qP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzMkLBketHcOU2nVZDKE1HVPl9Z_hgkT4H0hXKSkepIQ&oe=66D1C1F7"}, {"file_name": "3000x900_pdp-art-safezone.png", "id": "629709414781356", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974472_629709421448022_713197402145434487_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJWFlZ_DppMQ7kNvgF807-p&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9UznVcTDuNgy4HX-I0Ah7Wx8m0VaKApqa7534CZ--sg&oe=66D1C2DB"}, {"file_name": "logo_izneo_9000x1440_transp.png", "id": "347166343946260", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974762_347166347279593_3265815558868633434_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H2rdwry1KlYQ7kNvgFKZ3uQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4shrBiK6VJ3MivO8e3MpqPzae-7DfkMKA1n6eND5E4w&oe=66D1974E"}, {"file_name": "1008x144