culuscdn.com/v/t64.5771-25/39035315_512418213800691_6351743728904448576_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFyxR2w5GV8Q7kNvgEYh_8t&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCssJWTLFZ2oUvUifW1JH9FN_g9oez-pNpal1Ynjy9rRQ&oe=6706760E"}, {"file_name": "512.png", "id": "275470684535859", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982580_275470687869192_3200725871982560911_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VBdprNrV6GYQ7kNvgFhFL7z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBP7FUSfXT2rh-g5_9H7sCjn5wDTqXxHaC65MWE8OxXmQ&oe=670659A9"}]}, "id": "3201778793429512", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "izneo", "keywords": [], "long_description": "izneo est un service cross-plateformes permettant de lire des Mangas, BD, Webtoons et Comics.\nL'utilisation de l'application requi\u00e8re la connexion \u00e0 un compte izneo (\u00e0 cr\u00e9er sur www.izneo.com).\nAcc\u00e9dez \u00e0 votre biblioth\u00e8que izneo en vous connectant depuis l'application.\n\nLisez depuis votre biblioth\u00e8que :\n- Mangas\n- Webtoons\n- Bandes dessin\u00e9es\n- Comics\n\nModifiez l'environnement pour changer l'ambiance de vos lectures.\nUtilisez les contr\u00f4les Oculus Quest pour zoomer et \u00eatre au plus pr\u00e8s des planches dessin\u00e9es.", "short_description": "Izneo est un service cross-plateformes permettant de lire des Mangas, BD, Webtoons et Comics.\nPour utiliser l'application vous devez poss\u00e9der un compte izneo (\u00e0 cr\u00e9er sur www.izneo.com).\nConnectez-vous \u00e0 votre compte et retrouvez vos albums \u00e0 lire en r\u00e9alit\u00e9 virtuelle dans des environnements configurables."}, {"images": {"nodes": [{"file_name": "1080x360_bg.png", "id": "1205263993211836", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982727_1205263996545169_9148883512724487229_n.png?_nc_cat=