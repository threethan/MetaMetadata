 et retrouvez vos albums \u00e0 lire en r\u00e9alit\u00e9 virtuelle dans des environnements configurables."}, {"images": {"nodes": [{"file_name": "1080x360_bg.png", "id": "1205263993211836", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_1205263996545169_9148883512724487229_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SsddFeMI-6kQ7kNvgHq25oV&_nc_ht=scontent.oculuscdn.com&oh=00_AYByG5ZVA-Czi-OWTS4MeZ1xqv169iNQZo9X3tq_04XPug&oe=66D6F174"}, {"file_name": "512.png", "id": "1050334919080944", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984471_1050334922414277_3741888985697961122_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bj6EJZokJT4Q7kNvgFDiL8g&_nc_ht=scontent.oculuscdn.com&oh=00_AYCB5DE4-bxhN4RqJv28rZlyHLWdFMDi0j6SvExVs-UaZA&oe=66D6F2D6"}, {"file_name": "2560x1440_bg.png", "id": "715429989842664", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982580_715429993175997_4462372464006952430_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=du7Qm0yLKx8Q7kNvgH99QHJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfAzzXDZVc71mFotU-S9o0oUu-AYm-DSDyr44BiG_3FQ&oe=66D707F7"}, {"file_name": "3000x900_pdp-art-safezone.png", "id": "629709414781356", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974472_629709421448022_713197402145434487_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v5SR1r-8pJcQ7kNvgHXTWz2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHtgD41k0m6xtzO2bbrcTvuqj2CcM_2e7vIxWIMJ0XGw&oe=66D708DB"}, {"file_name": "logo_izneo_9000x1440_transp.png", "id": "347166343946260", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974762_347166347279593_3265815558868633434_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tIk80vW7f-sQ7kNvgEbpv0S&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvddc8ZhxwAfkG5CzP3NMa0IIdPpEEyLzU3-SEIA2WrQ&oe=66D6DD4E"}, {"file_name": "1008x144