gar Kingdom! Fend off the attacks of hilarious yummy enemies that shatter into pieces on impact!\nMake use of your vast arsenal of weapons that get stronger as you use them. Use special items to gain an advantage over your opponents.\nChallenge mighty bosses, use their weak spots to defeat them!\nOther exciting activities are waiting for you: solve challenging puzzles, ride in a unique vehicle around the kingdom, feel the rhythm and participate in musical performances!\nDive into a fairy tale world and find out the exciting story of the Sugar Prince and his mysterious enemy!", "short_description": "Sugar Mess\u2014Let's Play Jolly Battle is a fun arcade first-person shooter for the whole family. Shoot from a variety of weapons at hilarious opponents! Pass colorful levels with different mechanics and immerse yourself in a fascinating story!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://jollyco.us/docs/privacypolicy.pdf", "developer_terms_of_service_url": null, "publisher_name": "JollyCo LLC", "support_website_url": null, "website_url": "https://jollyco.us/sugarmess/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "3744040075834813"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION", "ARCADE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1099574127529782"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1228616298405822"}, {"status": "PUBLISHED", "id": "538