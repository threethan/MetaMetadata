 world? \n- What does it mean that Noah did what he did \u201cby faith\u201d?\n- How does obedience to God's commandments bless our lives? \n\nThe animals going in were male and female of every living thing, as God had commanded Noah. Then the Lord shut him in.  \nGenesis 7:16", "short_description": "Help Noah gather the animals into the ark before flood waters rise. This whimsical game sets up a compelling structure for a youth night activity and discussion. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersivehistory.com/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": " Immersive History", "support_website_url": null, "website_url": "https://immersivehistory.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25793695480277984"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3355517231410172"}]}, "baseline_offer": {"id": "3355517231410172"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721875903, "status": "PUBLISHED", "id": "3355517231410172"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25937403609240503", "version": "4.4"}, "id": "3412799422361154", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "pr