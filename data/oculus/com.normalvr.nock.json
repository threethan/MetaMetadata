5246117_4804780388933075680_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rq4diqi2rZIQ7kNvgGV_WLO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBz6tjPbrwPVA4jfK8mkf1floDS9i2BJ9ZdmQxKZ8cDHg&oe=66D451BE"}, {"file_name": "ScreenshotNock.png", "id": "167655462970848", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75643374_167655469637514_6822153897786781111_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tLxF1a6SEAQ7kNvgEXSzlD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBufOILrtSxLnuxzjAONtJ2B6CQzOCLHb7j5dtO3fJnsg&oe=66D45DD1"}, {"file_name": "Screenshot3.png", "id": "703926541016940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_703926544350273_1667812412201693133_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l4r_K-9uhywQ7kNvgH6y32v&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_Z_AYuv_3j8UTw8KQ1oEkBwIvIX3b2-aYN1VdBavwIw&oe=66D4675B"}, {"file_name": "forest2.png", "id": "478533937518445", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_478533944185111_7413754463287527069_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=doOZM3YU9oMQ7kNvgEHSyXO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBA_8SxEbzsJdgE-ypjgVpXC0VuDHQRwsGIOEdBUz-I5g&oe=66D4654A"}, {"file_name": "screenshotCosmic.png", "id": "548185793743298", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974658_548185797076631_6295053414421418954_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Otoy0W_wsCwQ7kNvgFa7NJa&_nc_ht=scontent.oculuscdn.com&oh=00_AYALEl-KuH7L0FmNDJ_wDWCJ0nsBvigAbSMTjkn6Dsx-aQ&oe=66D43FBF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Nock: Bow + Arrow Soccer", "keywords": ["soccer", "football", "knock", "archery", "gorilla"], "long_description": "Nock is bow and arrow soccer.\n\nSkate and fly around a pitch while using a bow and arrow to blast the ball into the other team\u2019s goal. Compete in multiplayer ranked matches, or play casual custom games with your friends! \n\nLike a real sport, Nock is easy to learn but difficult to master. Block arrows let you create obstacles and you can even use your body to make a goal or save. A fast-moving ball can knock you out. Skill-based matchmaking keeps every game extremely close and competitive. Casual modes let you challenge yourself against bots or play with friends in custom matches.\n\nNock includes voice chat with individual muting options so you can communicate with teammates easily.", "short_description": "Nock is bow and arrow soccer.\n\nSkate and fly around a pitch while using a bow and arrow to blast the ball into the other team\u2019s goal. Compete in multiplayer ranked matches, or play casual custom games with your friends!"}]}, "developer_name": "Normal", "developer_privacy_policy_url": "https://nock.game/privacypolicy", "developer_terms_of_service_url": "https://normcore.io/legal/termsofservice", "publisher_name": "Normal", "support_website_url": null, "website_url": "https://nock.game/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7408135945877646"}, "review_messages": ["This is submission is approved for your Dec 14th update. Developer will need to go in and set the scheduled date for release. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43997718_883949636446454_2947261530912816551_