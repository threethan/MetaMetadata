": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43997710_746769757338320_5503076305679052844_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vCmUp3aQjaQQ7kNvgEXW-ig&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQDa2TLg51eJPJ89aF9wjJxHflm3veT2OXbm9oKLs2jw&oe=66F7EF8D"}, {"file_name": "LogoImmerersive.png", "id": "628798698784145", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_628798702117478_7195618070939175268_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1VdXWfMDFnoQ7kNvgEupmD3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNZw94vSkgqpzyn8LVRuoCxkz1D1UMlenrbkxHcJwQ_Q&oe=66F80514"}, {"file_name": "HeroNockEvolve.png", "id": "619767166865577", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_619767170198910_2154168202718639452_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XusFqsyVsxQQ7kNvgE_dxbp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCuc-PqDH3NDpPdA71clIdEPQvxeECjnpWwShLpvxieLw&oe=66F7D849"}, {"file_name": "immersiveRight2.png", "id": "618521759778578", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974699_618521763111911_4001573393745429744_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SUt1PO6tIfYQ7kNvgE3w-ZC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZW7vDAQo2bNAS9aYROl4kDyqhDR_2qrN3gm9-vGuodA&oe=66F7D13A"}, {"file_name": "NockLogoWideTransparent.png", "id": "496413158723258", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_496413162056591_3215350679477023559_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QLrEF2FI0CIQ7kNvgEGx5ld&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUcJpyMU073RKdq-FM4j1ug6k_yOZgVkyJhfbUw1m-lw&oe=66F806AF"}]}, "id": "740529391427975", "locale": "en_US", "screenshots": [{"file_name": "Screenshot1.png", "id": "5148178051912784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_5148178055246117_4804780388933075680_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNa3_Xf_RxEQ7kNvgGiniuY&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJiLvQFcgMHrbMvLBANizXk5lAo-tlFXGJl0KtR09YpQ&oe=66F7EA3E"}, {"file_name": "ScreenshotNock.png", "id": "167655462970848", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75643374_167655469637514_6822153897786781111_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4LQlb4IeV3gQ7kNvgFrT2Zd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbciqrMa6wCZwPHKISJ6bYEOAnHD-ZO9aBLQ2x4mvNUg&oe=66F7F651"}, {"file_name": "Screenshot3.png", "id": "703926541016940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_703926544350273_1667812412201693133_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QdTX22WWX80Q7kNvgEuI5an&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIVQYkBzolDEOVnYGGnnvjmTj-6kCucl4wK2MZ5awSKA&oe=66F7FFDB"}, {"file_name": "forest2.png", "id": "478533937518445", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_478533944185111_7413754463287527069_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y7R7IR5MwhYQ7kNvgE1zzt5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCa6Qmx7a_Zwsnm2g8W--vFbUPQ1o1o6pQbTgen5Rngiw&oe=66F7FDCA"}, {"file_name": "screenshotCosmic.png", "id": "548185793743298", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974658_548185797076631_6295053414421418954_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0QPeZp0DW38Q7kNvgE2-bXA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbdYPt1xl01yyGNOoCk-jVrPeWDII_S52ZzuadBPXRvw&oe=66F7D83F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Nock: Bow + Arrow Soccer", "keywords": ["soccer", "football", "knock", "archery", "gorilla"], "long_description": "Nock is bow and arrow soccer.\n\nSkate and fly around a pitch while using a bow and arrow to blast the ball into the other team\u2019s goal. Compete in multiplayer ranked matches, or play casual custom games with your friends! \n\nLike a real sport, Nock is easy to learn but difficult to master. Block arrows let you create obstacles and you can even use your body to make a goal or save. A fast-moving ball can knock you out. Skill-based matchmaking keeps every game extremely close and competitive. Casual modes let you challenge yourself against bots or play with friends in custom matches.\n\nNock includes voice chat with individual muting options so you can communicate with teammates easily.", "short_description": "Nock is bow and arrow soccer.\n\nSkate and fly around a pitch while using a bow and arrow to blast the ball into the other team\u2019s goal. Compete in multiplayer ranked matches, or play casual custom games with your friends!"}]}, "developer_name": "Normal", "developer_privacy_policy_url": "https://nock.game/privacypolicy", "developer_terms_of_service_url": "https://normcore.io/legal/termsofservice", "publisher_name": "Normal", "support_website_url": null, "website_url": "https://nock.game/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7408135945877646"}, "review_messages": ["This is submission is approved for your Dec 14th update. Developer will need to go in and set the scheduled date for release. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43997718_883949636446454_2947261530912816551_n.png?