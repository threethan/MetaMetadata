N01Gmcyx6cqVI03Hlun8LWpQph9UUolg5lxw&oe=66DD8C3E"}, {"file_name": "Screenshot3.png", "id": "703926541016940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035421_703926544350273_1667812412201693133_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FX5-mYRKKQ0Q7kNvgGWkpnk&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0IE3aQ98yomDJak1bRYxf4VnHTx-Zofe7ESEli3YENg&oe=66DDA1DB"}, {"file_name": "Screenshot2.png", "id": "280747354144862", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035322_280747357478195_949002718148707032_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C3VHZywS42AQ7kNvgFXpYtJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEQ900v3JMGAAUdXrQe7dwTxHwIDjH9UCCDOjke1wzVg&oe=66DD9DE9"}, {"file_name": "menuScreenshot.png", "id": "330249632488876", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429288_330249635822209_2400290683021814419_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s6yf_7zseIwQ7kNvgGKvbeC&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_5bacC2Q5468SNWWChzYXFQWYBKbTPK2sSYVMimoosA&oe=66DD756F"}, {"file_name": "NockScreenshots5.png", "id": "346905437312284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974472_346905440645617_3640611684722686033_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oxpB6xG3hkYQ7kNvgFVuyJr&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9LoQVktaCwd3JUnb8dDGFptDaO1JHvthS05emtJgoMw&oe=66DD719F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Nock", "keywords": ["soccer", "bow", "archery", "multiplayer", "sports"], "long_description": "Nock is the first real multiplayer sport for VR. Compete in aerial archery soccer matches from anywhere in the world! It's a brand new game that requires coordination, agility, and strategy. Skate and zip around the pitch while using a bow and arrow to blast the ball into the other team's goal. With intuitive controls and realistic physics, Nock is easy to learn but difficult to master.\n\nLike a real sport, this game can take years to master. Block arrows let you create obstacles and you can even use your body to make a goal or save. A fast-moving ball can knock you out. Skill-based matchmaking keeps every game extremely close and competitive. Casual modes let you challenge yourself against bots or play with friends in custom matches.\n\nNock includes voice chat with individual muting options so you can communicate with teammates easily.", "short_description": "Nock is the first real multiplayer sport for VR! It takes the best parts of soccer and archery and combines them into a completely new game. Skate and fly around a pitch while using a bow and arrow to blast the ball into the other team\u2019s goal. Compete in multiplayer ranked matches, or play casual custom games with your friends!"}]}, "developer_name": "Normal", "developer_privacy_policy_url": "https://normcore.io/legal/privacypolicy", "developer_terms_of_service_url": "https://normcore.io/legal/termsofservice", "publisher_name": "Normal", "support_website_url": null, "website_url": "https://nock.game/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "3173803822946400"}}]}, "scheduled_offers": {"count": 27, "nodes": [{"status": "PUBLISHED", "id": "2252141585149673"}, {"status": "PUBLISHED", "id": "969097008205798"}, {"status": "PUBLISHED", "id": "910483996260903"}, {"status": "PUBLISHED", "id": "802522061421005"}, {"status": "PENDING", "id": "5900345733355446"}, {"status": "PENDING", "id": "228658070244608"}, {"st