g&oe=670FAB68"}, {"file_name": "ScreenShot3.png", "id": "695997255386742", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001730_695997258720075_3137926895526903418_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0v6NkVICz2cQ7kNvgFPfA5m&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBGw4bc7gApRfvubMeMaFjDdF7eIMfUD6rVS1j5xu7e0g&oe=670FB8F3"}, {"file_name": "ScreenShot4.png", "id": "2451315121717447", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982478_2451315125050780_6989657958902584276_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RFVa0YRcJy4Q7kNvgFJxYDM&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCCjBvOWGOzLnAn98U1zIuHmlPYn7GV02UJqIIj6lHiSw&oe=670F8D1D"}, {"file_name": "ScreenShot5.png", "id": "1279033819415378", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003259_1279033822748711_4184824180331397363_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_EmOzsBFbTAQ7kNvgE1lFf0&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDzc5_5yImpqJjNfhjx_CUQnPHcoyxrW7x2PgNPpvq42Q&oe=670F9AA6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unichat", "keywords": [], "long_description": "Unichat is Your Ultimate Choice for VR Meet-Up! \n\n- Add and meet friends in just 5 seconds! And our MR mode keeps your friends with you in the real world.\n- Get ready for encounters at virtual bars, making new friends whenever and wherever. Join public rooms for a variety of exciting activities.\n- Dive into lively chats with AI friends, each with a unique personality, always online, ready to be your confidant.\n\nFeeling a bit lost? No worries! We've got an array of social features at your disposal. Use the 3D brush for a game of \"Guess the Drawing,\" watch sports games together via the browser, or enjoy TikTok and YouTube videos with fascinating strangers. Want to party? Dive into Gomuku and chat card games. Our rich, user-friendly app components guarantee your chat experience is anything but dull.\n\nJoin Unichat right now, where distance is a mere afterthought and friendship knows no bounds.", "short_description": "Unichat is your top choice for VR meet-up!  \n\nYou can meet friends in a VR room or MR environment within 5 seconds, discover exciting activities in public rooms and cultivate deep friendships with AI companions. Additionally, we offer a plethora of useful social components to ensure your chat experience is anything but dull."}]}, "developer_name": null, "developer_privacy_policy_url": "https://portalxr.ai/privacy.html", "developer_terms_of_service_url": "https://portalxr.ai/terms-of-service.html", "publisher_name": "PortalXR LLC", "support_website_url": null, "website_url": "https://portalxr.ai/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "926504651954562"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2043150299400767"}]}, "baseline_offer": {"id": "2043150299400767"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697038110, "status": "PUBLISHED", "id": "2043150299400767"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8469241283121678", "version": "2.4.1"}, "id": "775399923964430", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_bina