_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CkvCDu1XCKIQ7kNvgHtrZ8W&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASrwI24JwhnWgFAatz2YUsc&oh=00_AYDzip-N7dzFEFX2rXZSOAw5Jv2wQIVjMF2_10bsWoLhsw&oe=66F54D68"}, {"file_name": "ScreenShot3.png", "id": "695997255386742", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_695997258720075_3137926895526903418_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJxP4EgHPfEQ7kNvgG1rYQI&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASrwI24JwhnWgFAatz2YUsc&oh=00_AYCQY_Bo5Rv5EL07qzsC8-ueILJRatMmonss893sLKgfDQ&oe=66F55AF3"}, {"file_name": "ScreenShot4.png", "id": "2451315121717447", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_2451315125050780_6989657958902584276_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HDWkoNjSw2oQ7kNvgHAdN-i&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASrwI24JwhnWgFAatz2YUsc&oh=00_AYBb-4MH-B3SJN4hLcGvl7gul_aWl_EZOB2CPdWtMJpd0Q&oe=66F52F1D"}, {"file_name": "ScreenShot5.png", "id": "1279033819415378", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003259_1279033822748711_4184824180331397363_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tWP35vlpD_wQ7kNvgFh2jJo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASrwI24JwhnWgFAatz2YUsc&oh=00_AYC6Y-aTCthlOP65wtfW6co5zfdnNQtZoEHJoA143wreSQ&oe=66F53CA6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unichat", "keywords": [], "long_description": "Unichat is Your Ultimate Choice for VR Meet-Up! \n\n- Add and meet friends in just 5 seconds! And our MR mode keeps your friends with you in the real world.\n- Get ready for encounters at virtual bars, making new friends whenever and wherever. Join public rooms for a variety of exciting activities.\n- Dive into lively chats with AI friends, each with a unique personality, always online, ready to be your confidant.\n\nFeeling a bit lost? No worries! We've got an array of social features at your disposal. Use the 3D brush for a game of \"Guess the Drawing,\" watch sports games together via the browser, or enjoy TikTok and YouTube videos with fascinating strangers. Want to party? Dive into Gomuku and chat card games. Our rich, user-friendly app components guarantee your chat experience is anything but dull.\n\nJoin Unichat right now, where distance is a mere afterthought and friendship knows no bounds.", "short_description": "Unichat is your top choice for VR meet-up!  \n\nYou can meet friends in a VR room or MR environment within 5 seconds, discover exciting activities in public rooms and cultivate deep friendships with AI companions. Additionally, we offer a plethora of useful social components to ensure your chat experience is anything but dull."}]}, "developer_name": null, "developer_privacy_policy_url": "https://portalxr.ai/privacy.html", "developer_terms_of_service_url": "https://portalxr.ai/terms-of-service.html", "publisher_name": "PortalXR LLC", "support_website_url": null, "website_url": "https://portalxr.ai/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "926504651954562"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2043150299400767"}]}, "baseline_offer": {"id": "2043150299400767"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697038110, "status": "PUBLISHED", "id": "2043150299400767"}]}, "liveChannel": {"nodes": [{"latest_s