content-lhr6-2.oculuscdn.com/v/t64.5771-25/75557065_874143490521137_358369232386626125_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-wlxuxP4l4Q7kNvgEfnbg0&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDBzaFR_4zvWA7NlP5I4y2gl-0_xU3hqxydM-wLX_sYdg&oe=6712315E"}, {"file_name": "Screen3.png", "id": "555960036464171", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39003247_555960039797504_6283154447311500594_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZ8FfK_fXcYQ7kNvgE5SW8-&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCGAcCU1veUpn1xNerEKcIl6dS9685gCayA_iFh2pG0xQ&oe=67125906"}, {"file_name": "Screen5.png", "id": "1659979641107269", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75207242_1659979644440602_5068102189490911809_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QnAjzSGYbnIQ7kNvgHgG2U9&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDopQF_crQc02drzHVe_lPxbqG7MUzkTgIlDWAMGatCrw&oe=671257F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "572102931190200", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39035453_572102934523533_7056446585574448466_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ng3lSglUtsEQ7kNvgEkzqvS&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCOEVHBEHnGsqcIQeTMMhde1ANPNJxG291NH5-IeOoa_w&oe=67124AA6"}, "display_name": "Dino Roaryal", "keywords": [], "long_description": "Dino Roaryal is an arcade fighting arena VR experience where the player is put in the perceptive of riding a dinosaur and battling their enemies. During the ancient times when Nephilim walked the earth, Dino Roaryal is the story and gameplay of giant men riding on dinosaurs (T-rex) and fighting those dinosaurs in order to conquer their enemies. In a case where your T-rex's health get low, the game offers different spawns to help recorder health and projectile power.\n\nDino Roaryal is best played sitting. Standing positions are also okay but are not recommended as they limit the player's view. Dino Roaryal offers the player a different experience through the Oculus Goggles than the normal VR Pawn experience. ", "short_description": "Ride your chosen dinosaur and battle your way through the arenas. Overcome your enemies by using projectile attacks or physical tail attacks. "}]}, "developer_name": "KdanssLLC", "developer_privacy_policy_url": "https://www.traindz.com/dinoroaryal", "developer_terms_of_service_url": null, "publisher_name": "KdanssLLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1141512129892633"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75348039_643163971147937_2869582510757944570_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6_auP4jIl3cQ7kNvgGK8XQf&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDwl8pqOgXgXtD3mJhecpPfQAb4ivkEvk3EiccMsl-yAA&oe=67125AD0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dino Roaryal", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Battle Royale", "id": "889588098232891"}, {"topic_name": "Action", "id": "4597815049684