yal is best played sitting. Standing positions are also okay but are not recommended as they limit the player's view. Dino Roaryal offers the player a different experience through the Oculus Goggles than the normal VR Pawn experience. ", "short_description": "Ride your chosen dinosaur and battle your way through the arenas. Overcome your enemies by using projectile attacks or physical tail attacks. "}]}, "developer_name": "KdanssLLC", "developer_privacy_policy_url": "https://www.traindz.com/dinoroaryal", "developer_terms_of_service_url": null, "publisher_name": "KdanssLLC", "support_website_url": null, "website_url": "https://www.traindz.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1141512129892633"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348039_643163971147937_2869582510757944570_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UnW5b34dcgAQ7kNvgEhlT_c&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABM4NdcwguQwaECQQIQwkgBwjc6G_fRi5WR2vGudQXkQ&oe=677D2450"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dino Roaryal", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id"