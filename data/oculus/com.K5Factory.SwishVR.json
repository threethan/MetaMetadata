71692_8642100695877473549_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OWzewA-SY0gQ7kNvgFsezwJ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTE4nS10LSbSzc7UVOUcV5hcOg0k3uq_Yjj8FRqmf-mQ&oe=67090691"}, {"file_name": "World01LevelS01.png", "id": "917074286338898", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_917074289672231_9180431015469304639_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nMMNrjzZ1isQ7kNvgE0lZpS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnk3NUmQl0Cv99p9YyAuj4bgYJvSefMI7-v5AlJD5a-A&oe=6709232A"}, {"file_name": "World04LevelB01.png", "id": "717493169561689", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982564_717493172895022_8925686571337751630_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=53aHlPiDoesQ7kNvgHYJG1H&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBg4Wd1DhIGuHl7gVnzfzn5_VzuABh84dHgEfwcf5ztgA&oe=67090457"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt.png", "id": "619583039246684", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003274_619583042580017_4308525138896237341_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-NRrtxz43aMQ7kNvgEJw1PY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUuYIDh5RXAZkPiEy-uBJxGY-qfgn5xdyI8LevucgnnQ&oe=67092A59"}, "display_name": "TrailBouncer", "keywords": [], "long_description": "TrailBouncer is a fast-paced VR racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment. A steep learning curve pushes players to master the challenging environments with rapid interactions that constantly challenge their skills and reflexes.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players.", "short_description": "TrailBouncer is a fast-paced VR flying racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players."}]}, "developer_name": null, "developer_privacy_policy_url": "https://k5mediagroup.com/terms-of-service-and-privacy-policy-tb/", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.k5factory.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "FLYING", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "686519073151185"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974474_443345340648774_227559332451357751_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zvCi-ftXkJ0Q7kNvgFT6hwC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTY8CYizGBhTAfLqzq75xZtofIljur0pJJnCERNztreg&oe=6708F578"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TrailBouncer", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1638206414, "l