71692_8642100695877473549_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNqzdfa6kksQ7kNvgGbUjxq&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBvMghSthIRQEkL67h22c2od5OnyBUTgyr4VJK_U0_sHA&oe=67124111"}, {"file_name": "World01LevelS01.png", "id": "917074286338898", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75210389_917074289672231_9180431015469304639_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u1rdaoDvcsgQ7kNvgG92jWG&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYA4mpnaTQAnoscRUFlSITLaREDN-93jI3Wd0qgDGc3KHQ&oe=67125DAA"}, {"file_name": "World04LevelB01.png", "id": "717493169561689", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982564_717493172895022_8925686571337751630_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=udh0BmH8KPsQ7kNvgHIIc4h&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCAJJwAFwhT7CGGB_AE_1hM24Sm-Q4Atf90GJNbWi0D7g&oe=67123ED7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt.png", "id": "619583039246684", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39003274_619583042580017_4308525138896237341_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B9xOyBuMsd0Q7kNvgHPvxUY&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBDsmSt2LCkHZKO5uslEFoFKE44Zinf0x47AB2zTc8vsw&oe=671264D9"}, "display_name": "TrailBouncer", "keywords": [], "long_description": "TrailBouncer is a fast-paced VR racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment. A steep learning curve pushes players to master the challenging environments with rapid interactions that constantly challenge their skills and reflexes.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players.", "short_description": "TrailBouncer is a fast-paced VR flying racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players."}]}, "developer_name": null, "developer_privacy_policy_url": "https://k5mediagroup.com/terms-of-service-and-privacy-policy-tb/", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.k5factory.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "FLYING", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "686519073151185"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974474_443345340648774_227559332451357751_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R2CY8V0YP3YQ7kNvgGJbB3a&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCqWrkP2E3BbO0AAv6cH-pfkKXYQtNVYurEXEfSSf1gEA&oe=67122FF8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TrailBouncer", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1638206414, "l