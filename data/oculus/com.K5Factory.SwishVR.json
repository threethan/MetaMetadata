", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39031514_2791596850971692_8642100695877473549_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sI00NBwT8L4Q7kNvgGpjS9K&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCoKxAfxcrvHM3ztWVlv6hf3-8xKksLma783l3VGj8D1A&oe=677E5C11"}, {"file_name": "World01LevelS01.png", "id": "917074286338898", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75210389_917074289672231_9180431015469304639_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ph0FlzjRp94Q7kNvgE87OfI&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBya3fx2nI8InADCTyb3aTikwG_3cQVUyr-O_8z1j-Qcw&oe=677E78AA"}, {"file_name": "World04LevelB01.png", "id": "717493169561689", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982564_717493172895022_8925686571337751630_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYNsuhwzgesQ7kNvgF6Rzju&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAaH_nLnEv8vyQjL3eD3tGLPbfH86GNRIycA6EBZdJFZw&oe=677E59D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt.png", "id": "619583039246684", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39003274_619583042580017_4308525138896237341_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vSJ9vbpN_RUQ7kNvgFJhGhK&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYCLk59KohU0o6O5oiny6gte9l0mYpiskFZMjAaqGtPhJw&oe=677E7FD9"}, "display_name": "TrailBouncer", "keywords": [], "long_description": "TrailBouncer is a fast-paced VR racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment. A steep learning curve pushes players to master the challenging environments with rapid interactions that constantly challenge their skills and reflexes.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players.", "short_description": "TrailBouncer is a fast-paced VR flying racing game where breathtaking locomotion meets ultra-fast ball handling in a stunning and surreal environment.\n\nRace at lightning speed through different zones in a mythical environment. Race and spin up and down the mountains while going over boost pads to be even faster.\n\nStrive to unlock all levels and stay at the top of the game by using power-ups to your advantage and achieve the highest rank among your fellow players."}]}, "developer_name": null, "developer_privacy_policy_url": "https://k5mediagroup.com/terms-of-service-and-privacy-policy-tb/", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.k5factory.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "FLYING", "ACTION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "686519073151185"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974474_443345340648774_227559332451357751_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zp2c1-xb5MEQ7kNvgFww50r&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAjXSQxW3ffAsaccC11ej9te-UXPJI_a4VMQPWaMAnCRw&oe=677E4AF8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_