5063498465", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974534_747485066831798_4834069944485897448_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2TvJY6H4UUYQ7kNvgG_sNQL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrewuSMHfuMqJmXxBgWCGXV4hj1GOCjReSyey6VX7m6w&oe=67615BC4"}, "display_name": "Labyrinth", "keywords": [], "long_description": "Labyrinth is an immersive horror experience that reimagines the world of Gorilla Tag Fangames through a haunting lens. Set within the confines of a sprawling, maze-like structure, the game challenges players to navigate a series of increasingly complex and treacherous environments. As you traverse through dimly lit corridors and shadowy chambers, you'll encounter a variety of Terrifying adversaries that lurk in the darkness, ready to strike when least expected.\n\nEmbark on a harrowing adventure, confront your deepest fears, and discover the secrets that lie hidden within the Labyrinth", "short_description": "Labyrinth is a Terrifying Gorilla Tag fangame that brings players into a nightmarish maze filled with eerie atmospheres and lurking horrors. Navigate through twisted corridors, solve intricate puzzles, and evade terrifying entities as you struggle to find your way out. Will you escape the Labyrinth, or become lost in its endless darkness forever?\""}]}, "developer_name": "Bmix", "developer_privacy_policy_url": "https://sites.google.com/view/graveyardstudios/home", "developer_terms_of_service_url": null, "publisher_name": "GraveYardStudios", "support_website_url": null, "website_url": "https://graveyardstudios6.godaddysites.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_lan