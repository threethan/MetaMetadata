IRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_TW", "ja", "ko"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "945041336380207"}, "review_messages": ["Great job! These assets are excellent.", "Essentially, all of the assets except for the Icon and the Logo must have the same imagery and wording. To be specific, on your submission, the Store Cover Art: Square, the Store Cover Art: Portrait, and Store Cover Art: Landscape all have the same imagery but the Hero Art asset and the VR Landscape do not. We will need all of these assets to have the same background as well as the same logo.\nOne way to do this is to take one image and resize it to fit the different required sizing. ", "Changes are needed to the assets/metadata submitted.\n\nVisual assets must have a consistent design.  \n\nMore information and templates can be found at ocul.us/storeassetguidelines"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974781_1378240208992067_4475925873182113792_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zCZy1rBxhuoQ7kNvgGE0Jh2&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au0Irp6lhlfQKLUv0SGuxFz&oh=00_AYCE7apBVFMkg0RBM2J6QQttXAHqgDjvSTpLcmWqCif14g&oe=66D2ED40"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Polynesian Cultural Center VR Experience", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1555002000, "lastRevision": {"nodes": [{"id": "1691453140959420", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "i