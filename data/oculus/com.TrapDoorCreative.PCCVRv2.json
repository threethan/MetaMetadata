des": [], "user_interaction_modes": ["SINGLE_USER"], "id": "945041336380207"}, "review_messages": ["Great job! These assets are excellent.", "Essentially, all of the assets except for the Icon and the Logo must have the same imagery and wording. To be specific, on your submission, the Store Cover Art: Square, the Store Cover Art: Portrait, and Store Cover Art: Landscape all have the same imagery but the Hero Art asset and the VR Landscape do not. We will need all of these assets to have the same background as well as the same logo.\nOne way to do this is to take one image and resize it to fit the different required sizing. ", "Changes are needed to the assets/metadata submitted.\n\nVisual assets must have a consistent design.  \n\nMore information and templates can be found at ocul.us/storeassetguidelines"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974781_1378240208992067_4475925873182113792_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zCZy1rBxhuoQ7kNvgEOsgfg&_nc_ht=scontent.oculuscdn.com&oh=00_AYBs26ITpt9h7hvC7CevQOc1nH3GnnCHkiVNMMpEBY1Gvw&oe=66D43EC0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Polynesian Cultural Center VR Experience", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1555002000, "lastRevision": {"nodes": [{"id": "1691453140959420", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1814074872024230", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "232661994297699"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2995915970462070", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974911_449357445602687_217239892508278784_n.png