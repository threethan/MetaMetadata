_2289418328001159_7624879462340886528_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GTtObZai2CAQ7kNvgHaZ8J9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBZMmYWGxJTddBbXFJq4p_HRPbfvXiDBLR9OMB8hM7Wg&oe=67556F7A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/UFrZbN", "id": "1007634852773957", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001724_1007634859440623_1019487810001829888_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pcFSZS8R5goQ7kNvgHQAGvB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDWRiATZx5TSZYcLN1z7I5juV7UMnYa1kuegEXCychaw&oe=675587D7"}, "display_name": "The Polynesian Cultural Center VR Experience", "keywords": ["Hawaii", "Travel", "360", "Video"], "long_description": "Have you ever wondered what it's like to spend the day at the Polynesian Cultural Center -  Hawaii's #1 paid attraction - on the North Shore of Oahu? \n\nExperience each of the Center's amazing Polynesian villages, the incredible evening show Ha: Breath of Life, our beautiful mid-day canoe show Huki!, and our delightful Ali'i Luau Dinner Show in full 3D/360 VR.  \n\nThis experience will give you just a taste of what you will find when you visit the Polynesian Cultural Center on your next trip to the beautiful island of Oahu.", "short_description": "Experience the Polynesian Cultural Center in  3D 360VR!"}]}, "developer_name": "TrapDoor Creative, LLC.", "developer_privacy_policy_url": "https://www.polynesia.com/privacy-policy/", "developer_terms_of_service_url": "https://www.polynesia.com/terms-of-use/", "publisher_name": "The Polynesian Cultural Center", "support_website_url": null, "website_url": "http://www.polynesia.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_TW", "ja", "ko"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "945041336380207"}, "review_messages": ["Great job! These assets are excellent.", "Essentially, all of the assets except for the Icon and the Logo must have the same imagery and wording. To be specific, on your submission, the Store Cover Art: Square, the Store Cover Art: Portrait, and Store Cover Art: Landscape all have the same imagery but the Hero Art asset and the VR Landscape do not. We will need all of these assets to have the same background as well as the same logo.\nOne way to do this is to take one image and resize it to fit the different required sizing. ", "Changes are needed to the assets/metadata submitted.\n\nVisual assets must have a consistent design.  \n\nMore information and templates can be found at ocul.us/storeassetguidelines"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974781_1378240208992067_4475925873182113792_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2_Jy5PWvSKsQ7kNvgEg5Wgf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPEtZxNbpUPv57i4mvgh_8Y4-9g--P4JeaUmNpMqWITw&oe=675571C0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Polynesian Cultural Center VR Experience", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1555002000, "lastRevision": {"nodes": [{"id": "1691453140959420", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1814074872024230", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cer