neral questions!\n\nAlso tested on Quest 1.", "short_description": "Shoot moving targets with a variety of guns on your Quest 2/Quest! Free demo!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.reddit.com/r/gunsgame/comments/txi8ah/gunsdemo_privacy_policy/", "developer_terms_of_service_url": null, "publisher_name": "Pellas Innovation", "support_website_url": "https://www.reddit.com/r/gunsgame/comments/r16sj6/rgunsgame_lounge/", "website_url": "https://www.reddit.com/r/gunsgame", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "322396519883189"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "561715481726800"}]}, "baseline_offer": {"id": "561715481726800"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649292000, "status": "PUBLISHED", "id": "561715481726800"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25852385154375897", "version": "0.422"}, "id": "697304768063615", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7394342280606798", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "25852385154375897"}, 