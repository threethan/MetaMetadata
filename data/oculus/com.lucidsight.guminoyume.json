&oh=00_AYC6pYXBkzFeuWojsrL6XxehtmUfsedBlvtMMvuaZwQpuQ&oe=675ECE44"}, {"file_name": "migrated_image.png", "id": "578543349682393", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/12138838_1670000009927916_1630387970_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g4NUhwjMq3gQ7kNvgGh9gox&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAynriT8KWEH9AacTX6QbuYGFkLqYf076A5XO0-3yROmQ&oe=675EB710"}, {"file_name": "migrated_image.png", "id": "585165578759484", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/12138840_1711986285738652_1233354075_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nEMukJOkx8IQ7kNvgGRFT-v&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBP1Xq4jEOKSG_OBIaGJhkB6N-On5wiMVVeg1WkaNj9Vw&oe=675EB896"}, {"file_name": "migrated_image.png", "id": "542206796675018", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/11162745_465791353616207_1881168938_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3qfLCdCSkeEQ7kNvgH93uSu&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCMgHcWAhjymCLXL19UefI3XVdCoRbETGQqCWJYXjPp_w&oe=675ECF94"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Gumi no Yume", "keywords": ["puzzle", "classic", "gummy", "candy", "Sokoban"], "long_description": "Immerse yourself in Gumi no Yume, a virtual dreamworld where you can help Kon-kon and his friends navigate through puzzles full of fluffy marshmallows, jiggly gummies, and much more. It\u2019s a super kawaii candy adventure that brings a new twist to an old puzzle classic.\n\nUse your puzzle-solving power to bump colorful gummies around the game board and win your way through a 3D world inspired by the popular classic, Sokoban. Can you solve the puzzle before you run out of moves? Will Kon-kon ever get to eat all of the yummy candy he collects? The world may never know\u2026but you will if you play Gumi no Yumi!\n\nFeatures:\n-Many puzzling levels to play, with more added all the time\n-A colorful VR adventure sure to please anyone\u2019s sweet tooth\n-Charming friends like Kon-kon the Red Panda to meet along the way\n-Adorable music you can\u2019t help but dance to\n-Easy to learn, fun to play, a challenge to master\n\n(Kon-kon\u2014Nickname for Konpeito, also\u2026What the fox says in Japanese!!)", "short_description": "Immerse yourself in Gumi no Yume, a virtual dreamworld where you can help Kon-kon and his friends navigate through puzzles full of fluffy marshmallows, jiggly gummies, and much more. It\u2019s a super kawaii candy adventure that brings a new twist to an old puzzle classic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/7759324", "developer_terms_of_service_url": "http://www.lucidsight.com/tos.html", "publisher_name": "Lucid Sight, Inc.", "support_website_url": null, "website_url": "http://www.lucidsight.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "PUZZLE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "693836328310685"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/12138787_538901119630861_502562983_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azkGHpPe4wEQ7kNvgEKreG_&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAfw6BCx3nXfAc6S2yYr2I8xq7mYsIYUbmhNbvWhaoLGA&oe=675ED10A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gumi no Yume", "platform": "ANDROID", "context_category": null, "context_topics"