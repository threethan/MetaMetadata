 the energy field, while also highlighting the importance of sustainable practices.", "short_description": "\"Experience the Energy: Take the Challenge\" is a VR experience where players explore different jobs in the energy industry through interactive mini-games."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.redironlabs.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Red  Iron Labs", "support_website_url": null, "website_url": "https://careersinenergy.ca/programs/virtual-reality-experiences/take-the-challenge/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2687655338230691"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24905470979068956"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240095_699604489050113_300893848015113972_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sp5-FgYKJBgQ7kNvgELAKE_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvRPHjdNXlXGXYOghe9_3DI&oh=00_AYDHF7VUHTkbJbF4F_40ZMVRizVjofoTtkvSyoD7PjmwVg&oe=66F6A44F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Experience the Energy: Adapting Futures", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Events", "id": "2687655338230691"}], "release_date": 1709835000, "lastRevision": {"nodes": [