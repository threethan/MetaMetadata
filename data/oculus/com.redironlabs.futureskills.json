ience performing tasks relevant to each role. Whether it's troubleshooting a wind turbine or managing a solar panel installation, the experience provides valuable insights into the diverse careers available in the energy field, while also highlighting the importance of sustainable practices.", "short_description": "\"Experience the Energy: Take the Challenge\" is a VR experience where players explore different jobs in the energy industry through interactive mini-games."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.redironlabs.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Red  Iron Labs", "support_website_url": null, "website_url": "https://careersinenergy.ca/programs/virtual-reality-experiences/take-the-challenge/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2687655338230691"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24905470979068956"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1087884509090722"}]}, "baseline_offer": {"id": "1087884509090722"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709835000, "status": "PUBLISHED", "id": "1087884509090722"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25741662362116476", "version": "5.00"}, "id": "914120833542986", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": fa