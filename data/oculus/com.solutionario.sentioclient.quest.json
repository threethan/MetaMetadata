_nc_sid=6e7a0a&_nc_ohc=LDn93Z1649QQ7kNvgGcB3P2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDWrb_APScCMrwMIIOjAdeoVlVlfDZ9afw7zVP1KiHDGQ&oe=6730B1CC"}, {"file_name": "4.png", "id": "222765492631957", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031465_222765495965290_212792495828102734_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XQY5DTgHbQQ7kNvgFLEEUJ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD6cgoWKr9E2HaLigzhXWF9etdqnd9nE8n8rdAoFWgl5g&oe=6730B34F"}, {"file_name": "3.png", "id": "169433328311430", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982653_169433331644763_6500055822036622297_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDmJoq0ngsYQ7kNvgHRJooC&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBAReAOSlgmRQqtRsRHOVnW_6xIOJYaV1DdEy_HkOQ43Q&oe=67309B18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover image.png", "id": "117521453594753", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974535_117521456928086_99350484779883293_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LATgCL2cSkEQ7kNvgEPlWn6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD2HuSrGVPoWm_BTRph4PFTv67pYvaKO6dG7pHtQVaPLg&oe=6730954C"}, "display_name": "SENTIO VR", "keywords": [], "long_description": "SENTIO VR is the preferred platform for professionals working in the Architecture, Engineering & Construction Industry in 100+ countries. How does a project that has not yet been built look like? Instead of reviewing 2D floorplans, renders & video walkthroughs - SENTIO VR customers put on an Oculus Quest headset for real-time feedback with clients, improved designs & win new projects.\n\nHere are the key features that make SENTIO VR stand out:\n\n1) Plugins for SketchUp & Autodesk Revit\n- No downloads or upload of files needed. Works with your existing design tools\n\n2) No additional downloads\n- No additional PC software is required to manage the model upload process. \n\n3) Intuitive VR meetings\n- Multi-user collaboration meetings have never been easier using access codes & passwords\n\nHave questions? Reach out to us at hello@sentiovr.com", "short_description": "Want to view a construction project before it's built? With SENTIO VR, multiple stakeholders in a project can meet virtually, voice-chat & collaborate over a 3D model enabling better decisions.\n\nSupports SketchUp, Revit & 360 panoramas.\n\nNeed some inspiration? Explore a unique collection of 360 experiences of architectural spaces curated by ArchDaily & our content team.\n\nNote: \n-Permission for Microphone is needed for VR meetings\n-Permission for Device files is needed for downloading 3D models"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1qFROWZPNG97M6dEBbC4k0YLRcanJt7Q98sCi56HR6MI/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "SENTIO VR", "support_website_url": null, "website_url": "https://sentiovr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "3013178319011693"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1095007618657162"}, {"status": "PUBLISHED", "id": "279903826853759"}]}, "baseline_offer": {"id": "279903826853759"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "