jDhZV3QIrmXL3mL0rnSwObMm5VCFSFPQ&oe=673C90CF"}, {"file_name": "3.png", "id": "169433328311430", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982653_169433331644763_6500055822036622297_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NStAf1j8OjYQ7kNvgHzm8h4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDm-pFuoIEAcGxxzxexSZdGrQsrAI6D2YS_WB-Nt3B_iw&oe=673C7898"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover image.png", "id": "117521453594753", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974535_117521456928086_99350484779883293_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_rU7bWOUC4Q7kNvgHDufto&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkn0WxiwTTnz8DUKKUBNOydft682Sm7OmfeVXRiRYgXQ&oe=673C72CC"}, "display_name": "SENTIO VR", "keywords": [], "long_description": "SENTIO VR is the preferred 3D visualization platform for professionals working in the Architecture, Engineering & Construction Industry in 100+ countries. How does a project that has not yet been built look like? Instead of reviewing 2D floorplans, renders & video walkthroughs - SENTIO VR customers put on an Oculus Quest headset for real-time feedback with clients, improved designs & win new projects.\n\nHere are the key features that make SENTIO VR stand out:\n\n1) Plugins for SketchUp & Autodesk Revit\n- No downloads or upload of files needed. Works with your existing design tools\n\n2) No additional downloads\n- No additional PC software is required to manage the model upload process. \n\n3) Intuitive VR meetings\n- Multi-user collaboration meetings have never been easier using access codes & passwords\n\nHave questions? Reach out to us at hello@sentiovr.com", "short_description": "Want to view a construction project before it's built? With SENTIO VR, multiple stakeholders in a project can meet virtually, voice-chat & collaborate over a 3D model enabling better decisions.\n\nSupports SketchUp, Revit & 360 panoramas.\n\nNeed some inspiration? Explore a unique collection of 360 experiences of architectural spaces curated by ArchDaily & our content team.\n\nNote: \n-Permission for Microphone is needed for VR meetings\n-Permission for Device files is needed for downloading 3D models"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sentiovr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "SENTIO VR", "support_website_url": null, "website_url": "https://sentiovr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2621377568007083"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974557_3681210411945497_6364834566122363153_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0LEtLcN_8YwQ7kNvgGvcGtl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRb8Qkoj20Gv5rFkxEPj7g8zJbzhn7Gi7mMW6reZaCxA&oe=673C638C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SENTIO VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Creativity", "id": "1819021644882647"}], "release_date": 1615562541, "lastRevision": {"nodes": [{"id": "16162800