5DQQgQchKwHHkWavh9WbPzbYL8OhCJegM8O2JpLQg&oe=6777E3EA"}, {"file_name": "39031514_435332163879027_5311670094588280832_n.png", "id": "775647697550582", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031310_775647700883915_3401600038298494174_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P-DMbxGDMmMQ7kNvgHVnqcV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYALmJk0xbOTxSNUe5cSe1gqOJKdBA_M89lQ718_UYBVQA&oe=6777C778"}, {"file_name": "migrated_image.png", "id": "206373110704782", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974488_289755085256546_3625119588015931392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_bozWJkZ3YQ7kNvgHNHrkN&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCcuW7e6aBnBT-XACDR_4QzFY22E5rz6DufeTEtJPOJLQ&oe=6777CF93"}, {"file_name": "migrated_image.png", "id": "195359338568251", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974586_372219763376845_2422966105950650368_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yI-laYul6qgQ7kNvgFswqjC&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDZJExnhn1q_zPliLTtHPmdloUhNA8dmjH00MF-brwcgw&oe=6777B463"}, {"file_name": "migrated_image.png", "id": "152353479313496", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982505_593555011145872_6626414323252068352_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pd_nK1OeqVoQ7kNvgGdIVrf&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBuaPnA2y3d9TW-ldUYiUJ29Ju0D4xTGBnj_RdMG0cCGg&oe=6777DD45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gym_screenshot_2560x1440_v2.png", "id": "1972971429770948", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031518_1972971433104281_5584244602626096378_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gEybZju6iwAQ7kNvgH-fkvT&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYApRhIg-OvBaduq6IjgZ2Vlt1PC6TJUVNtkfxqRh5xjvw&oe=6777B73E"}, "display_name": "Gymnasia", "keywords": ["Gymnasia", "Animated", "Movie", "Fears", "Felix"], "long_description": "This ground-breaking interactive stop-motion animation is the first collaboration between the National Film Board of Canada, Felix & Paul Studios and Clyde Henry Productions. Blending 3D 360-degree video, stop-motion, miniatures and CGI, GYMNASIA pushes the art of puppet animation into uncharted territory. Viewers shrink to 1/3 scale as they enter a world built entirely by hand. The first VR experience to induce the elusive anxiety that occurs when the lines between what\u2019s real and unreal are blurred beyond belief, GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful. \n\n\"A dark world of theater, VR, animation, and puppets\" - VRScout \n\u201cPerfectly quirky... plenty of atmosphere and technical beauty\" - Engadget \n\"Surprises abound here, in a unique tale of the utmost artistry\" - Animation Magazine \n\nDuration: 6 minutes 29 seconds.", "short_description": "This ground-breaking interactive stop-motion animation is the first collaboration between the National Film Board of Canada, Felix & Paul Studios and Clyde Henry Productions. Blending 3D 360-degree video, miniatures and CGI, GYMNASIA pushes the art of puppet animation into uncharted territory. Viewers shrink to 1/3 scale as they enter a world built entirely by hand. GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful. \n\nDuration: 6 minutes 29 seconds."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "EXPLORATION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null,