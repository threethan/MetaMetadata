3-2.oculuscdn.com&oh=00_AYBuI6GdcO_wgf8TkVN2z6KhN_XZl2wZbKANYtHdvcONcQ&oe=671B778D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/2V5fX7", "id": "381844472400186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031464_381844475733519_4796273855859523584_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oP8WJb4oHZgQ7kNvgFYtfdc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5TEPUNmlGLSF3m1jJFLtM_hRvGAiEkqd_BMsYyZJV9w&oe=671B75C0"}, "display_name": "Gymnasia", "keywords": ["Gymnasia", "Animated", "Movie", "Fears", "Felix"], "long_description": "Step into the stillness of an abandoned school and enter GYMNASIA, a place where the ghostly ephemera of a lost childhood await you. Recall the particular sights and sounds of a child\u2019s world through the echoes of ball games, school lessons and choir recitals. GYMNASIA reanimates the memories of those forgotten days. \n\nThis ground-breaking, cinematic VR experience is the first collaboration between the National Film Board of Canada, Felix & Paul Studios and Clyde Henry Productions. Blending 3D 360-degree video, stop-motion, miniatures and CGI, GYMNASIA pushes the art of puppet animation into uncharted territory. The first VR experience to induce the elusive anxiety that occurs when the lines between what\u2019s real and unreal are blurred beyond belief, GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful.", "short_description": "Step into the stillness of an abandoned school and enter GYMNASIA, a place where the ghostly ephemera of a lost childhood await you. Recall the particular sights and sounds of a child\u2019s world through the echoes of ball games, school lessons and choir recitals. GYMNASIA reanimates the memories of those forgotten days. \n\nBlending 3D 360-degree video, stop-motion, miniatures and CGI, GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "https