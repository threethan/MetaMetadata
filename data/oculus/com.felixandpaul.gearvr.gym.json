dQNdkgH9DJHmA43MbkxJ_YHzthik09z5YI0M26nEA&oe=671B9AEA"}, {"file_name": "39031514_435332163879027_5311670094588280832_n.png", "id": "775647697550582", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031310_775647700883915_3401600038298494174_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Hw5uU6m-ycQ7kNvgHt34s2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUar4pvESPK_HK-6Ij4gcLtmqIcTou_aR4ad7Gg_XZkQ&oe=671B7E78"}, {"file_name": "migrated_image.png", "id": "206373110704782", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974488_289755085256546_3625119588015931392_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iCGvbYc2GgoQ7kNvgHRxjqA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBm0mi9QQj4Pr-h7Su9yZ7yoTzqt-Xo0dTT9mwAmi8Eig&oe=671B8693"}, {"file_name": "migrated_image.png", "id": "195359338568251", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974586_372219763376845_2422966105950650368_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QMPFaRU8ZJ4Q7kNvgFMmyKT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgbjGmVZQIj6uRrbeqO0c_IVAwV-MsX9YqelmSSOEt0Q&oe=671B6B63"}, {"file_name": "migrated_image.png", "id": "152353479313496", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982505_593555011145872_6626414323252068352_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xwOeSS15pnMQ7kNvgHAWsuh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6n-HwFste2ijYCDVGrxaoRSrvqC1jIE0O5CIwRtFi_g&oe=671B9445"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gym_screenshot_2560x1440_v2.png", "id": "1972971429770948", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031518_1972971433104281_5584244602626096378_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TJw-rPJJGx0Q7kNvgGY67rn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqx1EUgo8X97wquQzybU28LtE9MkbqjibI3kAomcrQBQ&oe=671B6E3E"}, "display_name": "Gymnasia", "keywords": ["Gymnasia", "Animated", "Movie", "Fears", "Felix"], "long_description": "This ground-breaking interactive stop-motion animation is the first collaboration between the National Film Board of Canada, Felix & Paul Studios and Clyde Henry Productions. Blending 3D 360-degree video, stop-motion, miniatures and CGI, GYMNASIA pushes the art of puppet animation into uncharted territory. Viewers shrink to 1/3 scale as they enter a world built entirely by hand. The first VR experience to induce the elusive anxiety that occurs when the lines between what\u2019s real and unreal are blurred beyond belief, GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful. \n\n\"A dark world of theater, VR, animation, and puppets\" - VRScout \n\u201cPerfectly quirky... plenty of atmosphere and technical beauty\" - Engadget \n\"Surprises abound here, in a unique tale of the utmost artistry\" - Animation Magazine \n\nDuration: 6 minutes 29 seconds.", "short_description": "This ground-breaking interactive stop-motion animation is the first collaboration between the National Film Board of Canada, Felix & Paul Studios and Clyde Henry Productions. Blending 3D 360-degree video, miniatures and CGI, GYMNASIA pushes the art of puppet animation into uncharted territory. Viewers shrink to 1/3 scale as they enter a world built entirely by hand. GYMNASIA is a dark dream \u23af unsettling and weirdly wonderful. \n\nDuration: 6 minutes 29 seconds."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "EXPLORATION", "CA