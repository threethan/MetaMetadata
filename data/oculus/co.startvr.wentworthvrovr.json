6747_5858260710852657152_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KKyl2ss8iukQ7kNvgFJRaqi&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8DcrqFm5Kno8H1SUupmjRNNEyLiJF2BUPx8bMOqmQTQ&oe=66CB2742"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wentworth VR", "keywords": ["narrative", "interactive", "drama", "fremantle", "prisoner"], "long_description": "Wentworth VR is a ground breaking interactive cinematic virtual reality experience. It\u2019s the official extension of the award winning TV series Wentworth.\n\nAs a new prisoner at Wentworth, you must find your feet and figure out who to trust in this dangerous new environment.\nThe previous occupant of your cell committed suicide in mysterious circumstances, and the J-Block crew are on the warpath about stolen gear. \n\nWhile trying to navigate complex prison politics, you must also try to piece together your own past - and what you did to get put in here. Are you ready to be locked up?\n\nNOTE: Wentworth VR needs 1GB free to successfully install. If you are having issues installing the app with an error of 'download failed', this may be due to not enough free space on your device.", "short_description": "The official VR app for the hit TV series Wentworth"}]}, "developer_name": "Start VR", "developer_privacy_policy_url": "https://startvr.co/privacy/", "developer_terms_of_service_url": "https://startvr.co/privacy/", "publisher_name": "Start VR", "support_website_url": null, "website_url": "http://www.wentworthvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices