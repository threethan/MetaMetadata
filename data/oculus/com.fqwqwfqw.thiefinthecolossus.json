tent-lga3-1.oculuscdn.com&oh=00_AYBQnSI9fn1bDnQWQ2_5jKUrEloawLNxgkS3EwrPdlWqpg&oe=675FF8A2"}, {"file_name": "ss5.png", "id": "2253978911602216", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/54809986_2253978914935549_4499949495113059499_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=js6CjKmRkwkQ7kNvgHDoM64&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYACBl83gBJmaXDsbEIL4A6Pr-JWhz5MjEmOu57Wr1yAQg&oe=67602329"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x7rJ-AYcdXsQ7kNvgEIJR1D&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBd1PSceOajEIB5qhx66I7yehGKaAj3btpbCbjTjqWLEg&oe=67601738"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SHC3LDQKnsQQ7kNvgHI4lHm&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD4uNb6yxnfGQqXHIMhbMm7bjeD0ZMAhr2_KeT7dWGEFw&oe=67600469"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner.