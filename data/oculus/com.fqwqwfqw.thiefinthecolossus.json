.com/v/t64.5771-25/75443248_780495580955240_3357925061710731014_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bMfCoWwSsxkQ7kNvgH_YUSE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_Fa2Xz0-UlyRvJlxwzfBMr43mTIjVrG-jlELmue8ulA&oe=6784E73F"}, {"file_name": "PDP.png", "id": "685229333766054", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75458092_685229337099387_6988030700365846828_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OcCShBTJgGgQ7kNvgFTbvM5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4TQA3GIK_1zwEHh5u8-LS-wERW7CqiQ9-80i0DcAD1A&oe=6784FA6C"}]}, "id": "1512222939502193", "locale": "en_US", "screenshots": [{"file_name": "ss4.png", "id": "827332199364041", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982458_827332202697374_8816921954735061913_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SExu53ZCrDgQ7kNvgFZA6Ia&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAk_9yTmcoJbGA73NB4wJAIADXrJd4Q-CxRhThVW-_zDw&oe=678507BE"}, {"file_name": "ss3.png", "id": "1019926266589539", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974532_1019926269922872_956344857542529673_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y_E47Kf8P0cQ7kNvgE0RpOR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXAiIHDN0HqgxOjiOzekHCLsfyU20EmX1O2BLUfuptmg&oe=6785158C"}, {"file_name": "ss1.png", "id": "1448633165841123", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75195906_1448633169174456_2867898511672009797_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBqk2rsscEoQ7kNvgF4QdfQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBnhy-WZw-n8sG6xFGclPk3a9EZ9e_eZ8LxcP3vWswTpA&oe=67851AE2"}, {"file_name": "ss5.png", "id": "2253978911602216", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54809986_2253978914935549_4499949495113059499_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H62kwWMutnUQ7kNvgEeEDl-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBsVUTnOWryFR3z44Ot_vbV96nAPKZtzLziEg7FtemMjg&oe=67850D29"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qvLgby5G5yoQ7kNvgG4oOcY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUj8KjuSSbHN7qPdxVrqcz016h8OMdl11BGxRkHmyxlw&oe=67850138"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uzs3Zjd7IEMQ7kNvgFEvuLO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAprUKSFXS9Jt2tL59hSokt4M_jzn1scV5FbQ95R_dXsA&oe=6784EE69"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner. Plan your heist meticulously, use shadows to your advantage, and deploy advanced tools to avoid detection.", "short_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/thief-in-the-colossus/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Jame Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/thief-in-the-colossus", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7612113488916145"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566687_888912543252823_1164337545364395588_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NzH7vZfeUmsQ7kNvgHn0hzH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuHlFQcG0shURW9JomMmkep_yeenFWdsbpOf_YCkIDkw&oe=6784F7B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Thief in the Colossus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1721233394, "lastRevision": {"nodes": [{"id": "7612113502249477", "release_type": "SCHEDULED", "administration_status": "APPROVED", 