3FrPJ9ztSx4v_NwPmzdAQ&oe=66F5620C"}, {"file_name": "ss1.png", "id": "1448633165841123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195906_1448633169174456_2867898511672009797_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eO6K5N1y5ewQ7kNvgGXcdZg&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj61syOZSB6zo-npP35ESlb&oh=00_AYD-GaSi0D6ZPZC3GiDqL5Q1Dw1tZdd6Di6YU5pp-riTvw&oe=66F52F22"}, {"file_name": "ss5.png", "id": "2253978911602216", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54809986_2253978914935549_4499949495113059499_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYUuJkJCu3wQ7kNvgGM7DQH&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj61syOZSB6zo-npP35ESlb&oh=00_AYDbpuZhF2XbvAnzMULoIpag0AINo1l2qhL-w0gF4HWAoQ&oe=66F559A9"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4qhMS4eiLCEQ7kNvgG5FCOs&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj61syOZSB6zo-npP35ESlb&oh=00_AYBlc09zGDYdrNyq0jJhnD_BgBQgRSOkVVXL4IebXWf_jg&oe=66F54DB8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQH9B42r6BoQ7kNvgGpUeLQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj61syOZSB6zo-npP35ESlb&oh=00_AYADyxASBy9lmDMVPWJYu8qGs3pjGiDbCdAFlwCO50g3jQ&oe=66F53AE9"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner. Plan your heist meticulously, use shadows to your advantage, and deploy advanced tools to avoid detection.", "short_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/thief-in-the-colossus/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Jame Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/thief-in-the-colossus", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7612113488916145"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1626491858173038"}]}, "baseline_offer": {"id":