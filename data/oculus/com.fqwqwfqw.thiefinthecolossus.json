FP6q05ka7akIOM3Q8WJkMfN7HghOSqVSxFUdTBad-Kw&oe=672B6729"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WB159nyt4r4Q7kNvgFnoPJw&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAoHAoXZcPYfaEV9LTc2MDtlrIIK_-o9sxRI_wKAf0wIQ&oe=672B5B38"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Puua_ThsHloQ7kNvgERCoeX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCjT0sn-5qJwXYbpLG2l2tFS9A6fp_R07yTVZVoQ-5lkQ&oe=672B4869"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner. Plan your heist meticulously, use shadows to your advantage, and deploy advanced tools to avoid detection.", "short_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/thief-in-the-colossus/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Jame Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/thief-in-the-colossus", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7612113488916145"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566687_888912543252823_1164337545364395588_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kbHR1qXxZgcQ7kNvgHGTLkm&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDUxylIo227j2SwMQJsCnIf2IfTR75bZ5KjMZqYeATW0Q&oe=672B51B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Thief in the Colossus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1721233394, "lastRevision": {"nodes": [{"id": "7612113502249477", "release_type": "SCHEDULED", "administration_status": "APPROVED",