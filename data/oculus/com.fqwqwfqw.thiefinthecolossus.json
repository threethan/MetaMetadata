tent-sjc3-1.oculuscdn.com&oh=00_AYCxeMobDy-uM3loN0Tj_noK4ZyodZh9VuL8trFzB8iaTg&oe=67766222"}, {"file_name": "ss5.png", "id": "2253978911602216", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/54809986_2253978914935549_4499949495113059499_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z49KIkBJcuEQ7kNvgFb0p0V&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC912RxaHTjkJn-atlpvWuFTJ1ijTLC4Zeb1NUBgQIK4g&oe=67768CA9"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQlnB_UQNAMQ7kNvgGF0XoA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCZxCoKExKTSG6Ls5Zv0Z6QSotTF9z-8SCGAwwlETeMzg&oe=677680B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u_EeV6i1VvoQ7kNvgEKEOae&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC5yc9hN1AGPo-Y8OsUZF5sq_Kd33NZE0lhF1QQ2XGZIQ&oe=67766DE9"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner.