.com/v/t64.5771-25/75443248_780495580955240_3357925061710731014_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=84lwIRNtRIgQ7kNvgFzPBxA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiNhtENjiIfBDfuh1tIbHTty5_GqwPget8bfl_cluQQg&oe=674D883F"}, {"file_name": "PDP.png", "id": "685229333766054", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75458092_685229337099387_6988030700365846828_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TK8b5Kc8_LwQ7kNvgFCNv3M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBnyTcwAwk5h94czSUztcdufSlsAhDz9c4LmJhEct4BbA&oe=674D9B6C"}]}, "id": "1512222939502193", "locale": "en_US", "screenshots": [{"file_name": "ss4.png", "id": "827332199364041", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982458_827332202697374_8816921954735061913_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lsirolf7fbUQ7kNvgF8KbjE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9mTnaly6Q7QV1sFbR1HXCJfCPkzqo8ec6ZT2v0oWZYw&oe=674DA8BE"}, {"file_name": "ss3.png", "id": "1019926266589539", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974532_1019926269922872_956344857542529673_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BSVfGEDCCHMQ7kNvgHS9Zkp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBsBSCn4q5FW9gO8uzBL11SuuTGxLU_b_xk8UVEJwVPGw&oe=674DB68C"}, {"file_name": "ss1.png", "id": "1448633165841123", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75195906_1448633169174456_2867898511672009797_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i1aWYwhI6vMQ7kNvgHrornq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAqq9Hr5quXFXRh9U70fT4cZkE_09YTGvtj8yWuV4haw&oe=674D83A2"}, {"file_name": "ss5.png", "id": "2253978911602216", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54809986_2253978914935549_4499949495113059499_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JRysC7VkDG8Q7kNvgEvETnP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqmqFtUZ4GKqz2QEBqJHfpHScFbH-5aCnfImqn8ucj8Q&oe=674DAE29"}, {"file_name": "ss2.png", "id": "846454223549290", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207235_846454226882623_4099923352520741554_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVRHWDVtDdwQ7kNvgENCw0h&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6_lIF35aDHfDz0UkGgy7pTR8ImlvrVNs6ZvDyuDQCDQ&oe=674DA238"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "7957285167664031", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974670_7957285174330697_8761544827049069134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s86uzCpfk6QQ7kNvgE13L3M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCF64iUDbN6DVMJnM5OLZfzbH0dNTVQsIFXVu--g-ppCg&oe=674D8F69"}, "display_name": "Thief in the Colossus", "keywords": [], "long_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment.\n\nGame Features:\n\n    Immersive VR Experience:\n        Fully immerse yourself in a beautifully crafted, gigantic space with state-of-the-art VR graphics. Feel the tension as you navigate through vast rooms filled with high-tech gadgets and traps.\n\n    Stealth and Strategy:\n        Use your cunning and skills to outsmart the colossal room owner. Plan your heist meticulously, use shadows to your advantage, and deploy advanced tools to avoid detection.", "short_description": "Description:\nStep into the shoes of a master thief in the thrilling VR game \"Thief in the Colossus.\" Your mission is to \"borrow\" precious items from an enormous, high-tech space, while avoiding detection by the colossal room owner. This immersive game offers an unparalleled blend of stealth, strategy, and futuristic adventure, set in a sprawling, technologically advanced environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/thief-in-the-colossus/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Jame Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/thief-in-the-colossus", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7612113488916145"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566687_888912543252823_1164337545364395588_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=89UV7ChqDFwQ7kNvgFwjlks&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD11Fo-rFo4KUPIbz4Wk4AkAvVScRSsW5HtyY-0Xk7PKQ&oe=674D98B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Thief in the Colossus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1721233394, "lastRevision": {"nodes": [{"id": "7612113502249477", "release_type": "SCHEDULED", "administration_status": "APPROVED",