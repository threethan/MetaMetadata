"id": "723934089953544", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982598_723934093286877_3873998242090367495_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=da10OkXscYcQ7kNvgHoQ5Hw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOPxoaG5HQQajf2YQdI9ShG6DxkfOQYiqy3xiaHCW_qQ&oe=675AB95F"}, {"file_name": "aim-screenshot-5.png", "id": "514983164763993", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974751_514983168097326_4387669613788468726_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hOOohkww9bEQ7kNvgE9HMRO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDf38UBJJL5RUmQI5jU1mG6mFjI9nUFpPytkc_5aYJnfg&oe=675AC80E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "aim-2560x1440.png", "id": "1709973086599657", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984460_1709973089932990_2973870980577933532_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cM2fIPQvp3gQ7kNvgEoyBvQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0EUmn1Ay43T7AWWxNfOt1qn0rQJkZhREwr1WGuC9XQA&oe=675AD6F0"}, "display_name": "Aim Shooting VR", "keywords": ["aimshooting", "shooting", "gunhandling", "sharpshooter", "aim"], "long_description": "Ready to sharpen your aim and master the art of shooting? Aim Shooting VR is an immersive virtual reality experience designed to help you improve your accuracy while delivering intense, realistic gameplay. Whether you\u2019re a complete novice or a seasoned shooter, this game will guide you through every step of the process, from taking aim to pulling the trigger.\n\n\n**Challenge Your Accuracy**\n\nPut your precision to the test as you gradually advance through a series of increasingly difficult targets. Start with simple, stationary objects, and work your way up to dynamic, moving targets. Every shot counts, and every miss teaches you something valuable about improving your aim.\n\n**Immersive Shooting Experience**\n\nStep into a fully realized VR environment where you can experience the sensation of holding a gun, aiming down sights, and taking a shot. The game\u2019s immersive design makes you feel as if you\u2019re really in the middle of a shooting range, ready to take on the challenge.\n\n**Step-by-Step Instructions**\n\nAim Shooting VR offers voice-guided instructions that lead you through the fundamentals. New players will appreciate the intuitive, easy-to-follow tutorial that teaches you how to hold a gun, load it, and fire accurately. It\u2019s like having your very own shooting instructor by your side, offering tips and feedback.\n\n\nWhether you're looking to hone your shooting skills or just enjoy a realistic VR shooting experience, Aim Shooting VR has everything you need to become a sharpshooter.\n", "short_description": "Get ready for an adrenaline-packed VR experience! Aim Shooting VR challenges your accuracy and reflexes in a thrilling, guided and immersive environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://hitechbuddies.com/privacy_policy", "developer_terms_of_service_url": "https://hitechbuddies.com/terms-and-conditions", "publisher_name": "HiTech Buddies", "support_website_url": null, "website_url": "https://hitechbuddies.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8598737790176119"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculusc