ing (scanning is not available to users today). \n\nAvailable in the US, on Quest 3 only. ", "short_description": "Explore photorealistic digital replicas of spaces from the physical world. It's just like being there."}]}, "developer_name": "Meta", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Meta", "support_website_url": null, "website_url": "http://meta.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "726368587961803"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "ART_CREATIVITY", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8427637457314901"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974456_1021749709634412_4271969872862027814_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h6m7_O9ZQCMQ7kNvgH7hMCW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAqVaUVeXEnCkfLaBh-KFtATugKJqTY_ri-w6ogS4DmFQ&oe=670113E9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meta Horizon Hyperscape Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Lifestyle", "id": "3362542290449643"}, {"topic_name": "Travel & Exploration", "id": "726368587961803"}, {"topic_name": "Creativity & Design", "i