ps://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974700_518300064155936_1530566937483981210_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q_SX6b7dNF4Q7kNvgHhBncd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAHkF0bCiCCsdX-ucKrpsgg0WFXEjYWYkfX4m5UJtwYcw&oe=67308E29"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Horizon Photoreal Beta", "keywords": ["hyperreal", "photoreal", "hyperspace"], "long_description": "Explore photorealistic digital replicas of spaces from the physical world. It's just like being there. Step right into artist creative spaces like Daniel Arsham\u2019s workshop and garage, housing car projects, sculpture, design, and furniture. Examine the details of tools and machines in Rebecca Fox\u2019s studio, and witness the entire assemblage process in Gil Bruvel\u2019s studio. \n\nThis is a demo experience to showcase our vision for photorealism, as a profound new way to feel like you\u2019re physically there. We created these digital replicas using mobile phone scanning and cloud-based processing (scanning is not available to users today). \n\nAvailable in the US, on Quest 3 only. ", "short_description": "Explore photorealistic digital replicas of spaces from the physical world. It's just like being there."}]}, "developer_name": "Meta", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Meta", "support_website_url": null, "website_url": "http://meta.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "ART_CREATIVITY", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": nul