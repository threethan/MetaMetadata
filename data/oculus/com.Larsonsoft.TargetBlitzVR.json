o glory!", "short_description": "Embark on a thrilling shooting spree in Target Blitz VR! With its unique hand-drawn art style and fast-paced gameplay, take aim, shoot, and climb the leaderboards as the timer ticks down. Immerse yourself in arcade-style action like never before. Are you ready to blast your way to the top?\""}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/DallenLarson/Larsonsoft-Privacy-Policy/blob/main/README.md", "developer_terms_of_service_url": null, "publisher_name": "Larsonsoft", "support_website_url": null, "website_url": "http://www.larsonsoft.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25005301012418902"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982533_1156450595348577_118878231020848135_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWGLJ9QVFtQQ7kNvgFak7HU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDztsbFrEm3jzyINjN793cZRIP4rOW7QC0lkAE3EH_-yg&oe=67811A8A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Target Blitz VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Arcade", "id": "1