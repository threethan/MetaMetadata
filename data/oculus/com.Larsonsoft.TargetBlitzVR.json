5F21"}, "display_name": "Target Blitz VR", "keywords": [], "long_description": "Welcome to Target Blitz VR, the ultimate shooting experience in virtual reality! Immerse yourself in our captivating hand-drawn art style as you embark on a thrilling journey of skill and precision. With fast-paced arcade gameplay, you'll find yourself hooked as you take aim, fire, and climb the leaderboards with every shot. Challenge yourself against the ticking timer and see if you have what it takes to emerge victorious. Whether you're a seasoned sharpshooter or new to the world of VR gaming, Target Blitz VR offers endless fun and excitement for all players. Get ready to unleash your inner marksman and blast your way to glory!", "short_description": "Embark on a thrilling shooting spree in Target Blitz VR! With its unique hand-drawn art style and fast-paced gameplay, take aim, shoot, and climb the leaderboards as the timer ticks down. Immerse yourself in arcade-style action like never before. Are you ready to blast your way to the top?\""}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/DallenLarson/Larsonsoft-Privacy-Policy/blob/main/README.md", "developer_terms_of_service_url": null, "publisher_name": "Larsonsoft", "support_website_url": null, "website_url": "http://www.larsonsoft.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25005301012418902"}}]}, "scheduled