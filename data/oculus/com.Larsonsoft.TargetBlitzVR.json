7_8557377004981503250_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M_9AkI7-_mYQ7kNvgHuwYuB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIfqx2sNKiAOgAsqwe5JLnA&oh=00_AYB_KQvVGTHgTegHOnrxlqWRLLPETRb6xPYLOclLPeBllQ&oe=66D45D90"}, {"file_name": "38974788_315902124372049_6223628798340424221_n.png", "id": "418086107412836", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_418086110746169_5975769245380653237_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iYVkfX9eMZwQ7kNvgFouUQW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIfqx2sNKiAOgAsqwe5JLnA&oh=00_AYCH_uj5zeafJuSuTms2OYJuOOkoJL-aCA9tlM_cCwnJtw&oe=66D43797"}, {"file_name": "38974491_332604909180421_8787203125707960536_n.png", "id": "1210406729927569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392878_1210406736594235_1582659760593253_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEAwX5bIuhYQ7kNvgHqJ1Ht&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIfqx2sNKiAOgAsqwe5JLnA&oh=00_AYCqI12okiuf3zpcgUC9jtlxaMZzPpenHASJV5QUlZCTTw&oe=66D452FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled-21.png", "id": "370137062464053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001665_370137065797386_6603111948820454422_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Au5vGfXom3MQ7kNvgF_0Ekj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIfqx2sNKiAOgAsqwe5JLnA&oh=00_AYBMYUIU0ibkm3xF0dTwLmATP2VhC3_3n6y9FxodgQ43iA&oe=66D45F21"}, "display_name": "Target Blitz VR", "keywords": [], "long_description": "Welcome to Target Blitz VR, the ultimate shooting experience in virtual reality! Immerse yourself in our captivating hand-drawn art style as you embark on a thrilling journey of skill and precision. With fast-paced arcade gameplay, you'll find yourself hooked as you take aim, fire, and climb the leaderboards with every shot. Challenge yourself against the ticking timer and see if you have what it takes to emerge victorious. Whether you're a seasoned sharpshooter or new to the world of VR gaming, Target Blitz VR offers endless fun and excitement for all players. Get ready to unleash your inner marksman and blast your way to glory!", "short_description": "Embark on a thrilling shooting spree in Target Blitz VR! With its unique hand-drawn art style and fast-paced gameplay, take aim, shoot, and climb the leaderboards as the timer ticks down. Immerse yourself in arcade-style action like never before. Are you ready to blast your way to the top?\""}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/DallenLarson/Larsonsoft-Privacy-Policy/blob/main/README.md", "developer_terms_of_service_url": null, "publisher_name": "Larsonsoft", "support_website_url": null, "website_url": "http://www.larsonsoft.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25005301012418902"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982533_1156450595348577_118878231020848135_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i8MEUgtKSCIQ7kNvgEpYkdi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIfqx2sNKiAOgAsqwe5JLnA&oh=00_AYDigHqegcGNhL_t_TLYc6Xtr9wW3Kqgd_vqN-0dvz2Aeg&oe=66D4660A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Target Blitz VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, 