d for students of all grades. As you move and slice through shapes, the principles of 3D figures from the curriculum are embedded into your mind. The exciting VR experience combined with a gamification system that encourages active participation promotes voluntary learning and growth.", "short_description": "Cross Math VR | cross-section of a 3D"}]}, "developer_name": "Hey Iam Co., Ltd.", "developer_privacy_policy_url": "https://popschool.us/member/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "Hey Iam Co., Ltd.", "support_website_url": null, "website_url": "https://popschool.us/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7795168817173555"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "919321119414086"}]}, "baseline_offer": {"id": "919321119414086"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1711670700, "status": "PUBLISHED", "id": "919321119414086"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7795146303842473", "version": "1.0.0"}, "id": "719909623596817", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7574733252550447"