ion promotes voluntary learning and growth.", "short_description": "Cross Math VR | cross-section of a 3D"}]}, "developer_name": "Hey Iam Co., Ltd.", "developer_privacy_policy_url": "https://popschool.us/member/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "Hey Iam Co., Ltd.", "support_website_url": null, "website_url": "https://popschool.us/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7795168817173555"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_923398935842501_6815350406929438567_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QtlPfeTpEiAQ7kNvgGu8YmG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAIPS51Dl5tnvDRaSILhcY6h6t6BrjHdMTwVBnmpAAuog&oe=676544D3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Cross Math VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1711670700, "lastRevision": {"nodes": [{"id": "7574733292550443", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7574733252550447", "is_first_party": false, "enables_in_app_ads": false