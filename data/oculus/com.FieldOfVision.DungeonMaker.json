content-iad3-2.oculuscdn.com/v/t64.5771-25/75223476_2606532516189869_8925071117394518670_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JIS3lN-WJt4Q7kNvgGEOgVv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnpkFF4XOzS2H8wuOc35STY-1bf8iJ3xMi6rEuv_q7Gg&oe=67430956"}, {"file_name": "com.FieldOfVision.DungeonMaker-20231018-160334.png", "id": "223387907423746", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542965_223387910757079_4222422163158812466_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ARh7hkH7X0kQ7kNvgEl4h2I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGGr3PPXRgTmgodpDcIdC_BFPKnfZOyFJcWbBcGXKwaw&oe=6742F732"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE_2560x1440.png", "id": "647090750902702", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982671_647090754236035_2054464813285149882_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CyfS9t0b3uEQ7kNvgGOSEv7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCr0c3nSqFfBtgjCvYMBaHCNkzDcLj9ELsI7ouTLJUYWQ&oe=67432768"}, "display_name": "Dungeon Maker", "keywords": ["dungeon", "sandbox"], "long_description": "Greetings My Lord ! \ud83d\udc51\n\nI hath heard thou art quite the dungeon connoisseur, so i maketh this bawbling passthrough system where thee can buildeth thy owneth dungeon using a variety of traps and items, as well as lodging waypoints to giveth goals to the dungeon seekers. \ud83c\udff0\n\nWhat can I expect from my dungeon??\n# -\n# TURN YOUR HOME INTO A DUNGEON\nThe dungeon foundation is generated from your Meta rooms setup! Use the menu to load, design and save your dungeon once you've built it.\n{897653955802688}\n\n# SET DEADLY TRAPS AND QUESTS\nPlenty of traps and quest items to place around your home. Keys and doors, plots anf treasures, deadly pits, swinging axes, skeletons!\n{884487527165107}\n\n# DARE TO ADVENTURE THROUGH IT\n\nOnce you are ready, put down the controllers and enjoy full hand tracking as you journey through your dungeon.\n{836602965118342}\n\n# FIND THE TREASURE!\n\nCan you go deep enough into the dungeon to retrieve the treasure?\n\n{1731354897597483}", "short_description": "Build your own Dungeon in your home using Passthrough!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fieldof.vision/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Field Of Vision", "support_website_url": null, "website_url": "https://fieldof.vision/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "1725996564472128"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9261054523905713"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974513_1940134723053945_2810077118660287737_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RBSyoRqPdCoQ7kNvgFEInsw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0m0xmBHYEp8NKkr1ZR4SnH85w3yWxBKi94wdrpUJ3jA&oe=6743038A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dungeon Maker", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sandbox", "id": "1990104051447093"}, {"topic_name": "World Creation", "id": "1725996564472128"}, {"topic_name": "Party Game", "id": "1700921480735423"}], "re