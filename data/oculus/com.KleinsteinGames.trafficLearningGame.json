265447_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=odqIm_bWAZUQ7kNvgFACg6I&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7B9FlKKRkgGdzluvDP6rGoqMHMd-n5Jdr0dpNTQL0Mg&oe=66D05F40"}, {"file_name": "ss3.png", "id": "1273854476843760", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610708_1273854483510426_3057284611821445687_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HPFsseGir80Q7kNvgGv6onk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBLqkRQxvudPAwUp7ZELLQFE7-Lb8t-oAIMaN36PnDA5g&oe=66D04A0D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1579634055851718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392880_1579634059185051_605609078413117334_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1G4bB0WmHqwQ7kNvgG-On7e&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlnoZuqQcP2sLFm_-gBjZylDYjZyAlOANZzZbGoYPyPA&oe=66D04FA0"}, "display_name": "Traffic Sign Learning", "keywords": [], "long_description": "In this traffic game developed by Kleinstein Games, you will contribute to your children's learning while testing yourself.\nIn this game, which passes over a road in the city, you will try to choose the correct one from the 5 signs that appear in front of you within 60 seconds, according to the voice that guides you when you start the game. The more correct plates you know, the more points you earn. \n\nLanguage is Turkish but English version coming soon. \nGood luck!", "short_description": "In this game developed by Kleinstein Games, you will learn traffic rules as well as traffic signs. You can also play this game with your children and help them learn. \n\nLanguage is Turkish but English version coming soon. \nGood luck!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://kleinstein.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Kleinstein Games", "support_website_url": null, "website_url": "https://kleinstein.games/", "category": null, "comfort_rating": "NOT_RATED", "comfor