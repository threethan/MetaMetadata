372992714083_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HKk07y4qh3MQ7kNvgESJsl-&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC7KLZr4IJ-dieg49TC_MsSqtJbpP3ZXYqBEvB5Tgwiog&oe=6777D7A3"}, {"file_name": "1.png", "id": "1169354034268011", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75422371_1169354037601344_5872491032690942442_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nta4pmsBY5kQ7kNvgFfEWpk&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAlGj1YaFpsUOb5qmEMXmNEmCxozNvLU6VVqp4VToXy7g&oe=6777C6E9"}, {"file_name": "3.png", "id": "440880515477403", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982544_440880518810736_316635682150920127_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nQappASWws8Q7kNvgECk5_h&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD3gADP9JzEyGcYM9Rv02pJRenDKn4w-eq1m1pRwcHgBA&oe=6777E562"}, {"file_name": "4.png", "id": "325927170586372", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75299164_325927173919705_424375392307754339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9VaTbU9EREwQ7kNvgHhqGsK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBnosPENdPL6oklbGto1e_8jeyYbPdQLUp1Yqni6vgjyQ&oe=6777DE31"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mokey.png", "id": "1208068040227162", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75230049_1208068043560495_3271282988630284683_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cr7esTAtruMQ7kNvgH5pZPz&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCuqCufEylJ7cIEMhyXOK0t9gf9nE_zqPCm-5buAfFoag&oe=6777B36E"}, "display_name": "Chimp", "keywords": [], "long_description": "Embark on an exhilarating journey with Chimp, a dynamic fan game that brings the thrill of chimp locomotion to life. Set in diverse environments, Chimp lets you swing through dense jungle canopies, leap across bustling urban landscapes, and navigate challenging terrains with agility and grace.\n\nDiscover richly detailed worlds from lush rainforests to futuristic cityscapes, each offering unique challenges and opportunities for exploration.\n\nEngage in multiplayer races, cooperative missions, and social gatherings with friends and players worldwide. Customize your chimp with unique skins and accessories to stand out in the vibrant community.\n\nMaster challenging maneuvers, complete achievements, and participate in community-driven events to earn rewards and showcase your skills.\n\nForge friendships, share experiences, and celebrate victories in a supportive community of adventurers.\n\nDownload Chimp from Oculus App Lab, create your chimp avatar, and dive into an immersive, community-driven adventure where every swing and leap brings you closer to mastering the art of chimp locomotion.", "short_description": "Chimp is an exhilarating fan game inspired by Gorilla Tag, featuring intuitive chimp locomotion, unique environments, multiplayer fun, and customizable chimps. Download now from App Lab and join the community!c"}]}, "developer_name": "Outspoken", "developer_privacy_policy_url": "https://walkboygaming.wixsite.com/my-site", "developer_terms_of_service_url": null, "publisher_name": "Outspoken", "support_website_url": null, "website_url": "https://walkboygaming.wixsite.com/my-site", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8253239248044017"}}]}, "scheduled_offers": {"count": 0