e": "5.png", "id": "1047906166688332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1047906170021665_2531421372992714083_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WHa2fCbjmAQQ7kNvgFhPmF8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsH1LWT4lLoFfChUgRfn-yR&oh=00_AYDu5JYB1Z7WPusYbHaoep-WiRz-RDDPQDn92QAawzfiDg&oe=66E975A3"}, {"file_name": "1.png", "id": "1169354034268011", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422371_1169354037601344_5872491032690942442_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZw64R4NSwAQ7kNvgG-w3G3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsH1LWT4lLoFfChUgRfn-yR&oh=00_AYAB-jP80xTaHy797RnR1vjxpGQhthm3MJlpA3bq15wp9Q&oe=66E964E9"}, {"file_name": "3.png", "id": "440880515477403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_440880518810736_316635682150920127_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oLkW775lId8Q7kNvgGjh9kK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsH1LWT4lLoFfChUgRfn-yR&oh=00_AYDuh6VLrLMiAcjuFCAGGrEFlWcBW1Z-BklX1PIDNyfP_w&oe=66E98362"}, {"file_name": "4.png", "id": "325927170586372", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299164_325927173919705_424375392307754339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JrI-TmkbiaoQ7kNvgHg14-H&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsH1LWT4lLoFfChUgRfn-yR&oh=00_AYCEAJvMppMt9VuzbbtZDwUWtfW72zZ34Cmrv_yBzsKpmw&oe=66E97C31"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mokey.png", "id": "1208068040227162", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230049_1208068043560495_3271282988630284683_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7wadl2uagk0Q7kNvgEpdRvB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsH1LWT4lLoFfChUgRfn-yR&oh=00_AYAyeiAmND3olUtVqEqXCAj4S2qBGUe6X9jCqdUMZHWvig&oe=66E9516E"}, "display_name": "Chimp", "keywords": [], "long_description": "Embark on an exhilarating journey with Chimp, a dynamic fan game that brings the thrill of chimp locomotion to life. Set in diverse environments, Chimp lets you swing through dense jungle canopies, leap across bustling urban landscapes, and navigate challenging terrains with agility and grace.\n\nDiscover richly detailed worlds from lush rainforests to futuristic cityscapes, each offering unique challenges and opportunities for exploration.\n\nEngage in multiplayer races, cooperative missions, and social gatherings with friends and players worldwide. Customize your chimp with unique skins and accessories to stand out in the vibrant community.\n\nMaster challenging maneuvers, complete achievements, and participate in community-driven events to earn rewards and showcase your skills.\n\nForge friendships, share experiences, and celebrate victories in a supportive community of adventurers.\n\nDownload Chimp from Oculus App Lab, create your chimp avatar, and dive into an immersive, community-driven adventure where every swing and leap brings you closer to mastering the art of chimp locomotion.", "short_description": "Chimp is an exhilarating fan game inspired by Gorilla Tag, featuring intuitive chimp locomotion, unique environments, multiplayer fun, and customizable chimps. Download now from App Lab and join the community!c"}]}, "developer_name": "Outspoken", "developer_privacy_policy_url": "https://walkboygaming.wixsite.com/my-site", "developer_terms_of_service_url": null, "publisher_name": "Outspoken", "support_website_url": null, "website_url": "https://walkboygaming.wixsite.com/my-site", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["