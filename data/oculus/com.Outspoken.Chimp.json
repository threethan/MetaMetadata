e": "5.png", "id": "1047906166688332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1047906170021665_2531421372992714083_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wr9hupPLEJQQ7kNvgFh1Dgg&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALwtLAY5ANFwcv7MuJ2-q3x&oh=00_AYCkp8MvP__dF0Oip5xBdJDgcUDU_PJnnDzySHhEymvjQQ&oe=66F55323"}, {"file_name": "1.png", "id": "1169354034268011", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422371_1169354037601344_5872491032690942442_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JxubFfmouXcQ7kNvgF1fC8Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALwtLAY5ANFwcv7MuJ2-q3x&oh=00_AYCteEPdeLMFqjZBdZfaUJvukwPBIHktyAlpvalCrt9Bng&oe=66F54269"}, {"file_name": "3.png", "id": "440880515477403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_440880518810736_316635682150920127_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=il-4DJr0u-IQ7kNvgGa-8xl&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALwtLAY5ANFwcv7MuJ2-q3x&oh=00_AYCYYRe9Q_jv84RIHQbtOK4pjNjlu8hkv7xeMWN-L_LxnQ&oe=66F560E2"}, {"file_name": "4.png", "id": "325927170586372", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299164_325927173919705_424375392307754339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GETdhzzjSZkQ7kNvgGfprko&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALwtLAY5ANFwcv7MuJ2-q3x&oh=00_AYD0zvFHLVbgkoTBpXJC7YnsqAZGN6oqB7GxuHb4ZfhiyA&oe=66F559B1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mokey.png", "id": "1208068040227162", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230049_1208068043560495_3271282988630284683_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a-L1rhszXPwQ7kNvgEjuygA&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALwtLAY5ANFwcv7MuJ2-q3x&oh=00_AYDjK-Qr6g4Jzv6aB7yxVIo3Jy4FT25oHPuTucCFU7Q4VQ&oe=66F52EEE"}, "display_name": "Chimp", "keywords": [], "long_description": "Embark on an exhilarating journey with Chimp, a dynamic fan game that brings the thrill of chimp locomotion to life. Set in diverse environments, Chimp lets you swing through dense jungle canopies, leap across bustling urban landscapes, and navigate challenging terrains with agility and grace.\n\nDiscover richly detailed worlds from lush rainforests to futuristic cityscapes, each offering unique challenges and opportunities for exploration.\n\nEngage in multiplayer races, cooperative missions, and social gatherings with friends and players worldwide. Customize your chimp with unique skins and accessories to stand out in the vibrant community.\n\nMaster challenging maneuvers, complete achievements, and participate in community-driven events to earn rewards and showcase your skills.\n\nForge friendships, share experiences, and celebrate victories in a supportive community of adventurers.\n\nDownload Chimp from Oculus App Lab, create your chimp avatar, and dive into an immersive, community-driven adventure where every swing and leap brings you closer to mastering the art of chimp locomotion.", "short_description": "Chimp is an exhilarating fan game inspired by Gorilla Tag, featuring intuitive chimp locomotion, unique environments, multiplayer fun, and customizable chimps. Download now from App Lab and join the community!c"}]}, "developer_name": "Outspoken", "developer_privacy_policy_url": "https://walkboygaming.wixsite.com/my-site", "developer_terms_of_service_url": null, "publisher_name": "Outspoken", "support_website_url": null, "website_url": "https://walkboygaming.wixsite.com/my-site", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["