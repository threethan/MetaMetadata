ttps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003238_224935007185349_1570573608510902047_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bAKI7V2lQicQ7kNvgHZ632v&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDASPad2zk63ylpLidWCVPI406urr1qavU2JCGAlLLGsQ&oe=671F728A"}]}, "id": "843883634589468", "locale": "en_US", "screenshots": [{"file_name": "2560x1440_059.png", "id": "1026973598717765", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031479_1026973602051098_5581486762906161019_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WtOXMBqdYcwQ7kNvgHU2DRu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBN7cUm8czqDWQPJBmh1H5LtYEQ-B2o44JHHytQ0OSkJA&oe=671F6190"}, {"file_name": "2560x1440_036.png", "id": "1519635575512572", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982683_1519635578845905_5108407734596965196_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s6F0cxIuRcIQ7kNvgFBkZA4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb4ccDTKjUHI5lHORYXLmNF7TdiMt6YSPeewwmBvouRw&oe=671F65D1"}, {"file_name": "2560x1440_006.png", "id": "122000630998595", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75280980_122000634331928_7764318253159172356_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xOCt810pUTEQ7kNvgEtemyM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyEormg9SgSX0-Y-JebXzPZBQ1Z5yE2zS3WOP36pG0wQ&oe=671F9346"}, {"file_name": "2560x1440_016.png", "id": "1494394691363777", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036696_1494394694697110_313425590469653954_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WIikDcYe7OsQ7kNvgHsay8l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQVmNBzDsSFzD4wsaap_0wvOyJJCOXnadBrsR5a5jcBA&oe=671F8A55"}, {"file_name": "2560x1440_073.png", "id": "259223610402805", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982595_259223613736138_2792562483218118944_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GvQxWh6KcQcQ7kNvgFemc9m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCd5Kut5eJcJncgdYxsQveZT0cJiitIUmHClBTphdZ4fA&oe=671F6816"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Tennis Vision VR - Vision Training", "keywords": ["tennis", "vision", "training", "reactions"], "long_description": "# What Does Tennis Vision VR Do?\nTennis Vision VR trains all of the visual skills needed in tennis:\n\n- **Faster reactions**: So you can easily return bigger serves and have more time on your shots.\n\n- **Better anticipation**: So you can predict where your opponents are going to hit their shot.\n\n- **Quicker decision making**: So you can play the right shot at the right time, even when under pressure.\n\n- \u200b**Enhanced focus & concentration**: So you can make less silly errors and can play your best tennis when it matters most on the big points.\n- **Better ball tracking**: So you watch the ball more effectively through to contact to increase consistency, even when being offensive.\n\n- \u200b**Cleaner timing**: So you can feel more confident in your ball striking.\u200b\n\n# Who Is Tennis Vision VR For?\nTennis Vision VR is designed for competitive tennis players who want to gain an edge over their competition. It's perfect for competitive junior/college &, professional players.\n\n# How Does Tennis Vision VR Work?\nTennis vision VR uses the concepts of applied neuroscience and neuroplasticity to make you a better player. It trains the parts of your brain that create and control all the visual skills needed for tennis.\n\nThink of it like a strength and conditioning program, but for your reactions, ball tracking, focus & decision making etc.\n\nIt takes exercises that have been tried and tested in the fields of \"functional neurology\", \"vision therapy\" & \"behavioural optometry\" and packages them into an easy to use Virtual Reality app. ", "short_description": "Tennis Vision VR trains all the visual skills needed in tennis. Gain Faster Reactions, Better Anticipation, Quicker Decision Making, Enhanced Focus & Concentration, Better Ball Tracking & Cleaner Timing.\n\nThink of it like a strength and conditioning program, but for your reactions, ball tracking, focus & decision making etc.\n\nTennis Vision VR is designed for competitive tennis players.\n\nTennis vision VR uses the concepts of applied neuroscience and neuroplasticity to make you a better player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.tennisvisionvr.com/privacy", "developer_terms_of_service_url": "https://www.tennisvisionvr.com/terms-and-conditions", "publisher_name": "Tennis Hacker", "support_website_url": null, "website_url": "https://tennisvisionvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8276279402490373"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982592_812445343850530_4146022295315313774_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BZHSVBkP3bcQ7kNvgHP1kBg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7uQmAwI3fZm_9zkNQzZFoVlGmC7EXYcrVDH2jCzmtTg&oe=671F77EA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tennis Vision VR - Vision Training", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APP