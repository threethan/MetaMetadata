25/38982704_1102100040849991_1234040549770812861_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=37uI1f1wT4gQ7kNvgFeLWQM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AluuD1yU1SC8j5g5DavTeAD&oh=00_AYCYGgGyaC-puoeiGWTyK_s_u728FFvNBlvV3VHERHVg3Q&oe=66E577BC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "app_lab_combined_2560x1440.png", "id": "1674282936644808", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982712_1674282939978141_5969047132789362294_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GUT0NVMW4iwQ7kNvgFmJVcV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AluuD1yU1SC8j5g5DavTeAD&oh=00_AYB2LePYxWpJelIMCtJLYtsY0fj4_ppm3sRGbqN39wiwgg&oe=66E5880E"}, "display_name": "Allegory", "keywords": [], "long_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. ", "short_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "c