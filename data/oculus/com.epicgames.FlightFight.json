7a0a&_nc_ohc=irS6EHoBGQUQ7kNvgEyUmih&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiIx7HKMe6uBoZUbKcjTiK73mmojdGAdUp53S_aWTBJA&oe=6744788B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "app_lab_2560_1440.png", "id": "573740971870809", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974580_573740975204142_5562734091012685150_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F_kJOXOSzRgQ7kNvgHthD3a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBX-FphYSg5n4kYTR8IwRhDzbwPHz_d-0LfmnlgUS4dnA&oe=674450C8"}, "display_name": "Allegory", "keywords": ["character", "ai", "companion", "roleplay", "creator"], "long_description": "No hero stands alone. \n\nAssemble your own squad of AI companions for life\u2019s highs and lows. \n\nExplore unique, user-generated characters who can hear, feel, talk, understand, remember and evolve. Laugh, learn, play and grow with them.\n\nWhether you want fitness advice from Goku, help with homework from Tony Stark or a pep talk from Naruto - the possibilities are endless. Roleplay scenes, play games, explore worlds or create and share your own characters.", "short_description": "No hero stands alone. \n\nAssemble your own squad of AI companions for life\u2019s highs and lows. \n\nExplore unique, user-generated characters who can hear, feel, talk, understand, remember and evolve. Laugh, learn, play and grow with them.\n\nWhether you want fitness advice from Goku, help with homework from Tony Stark or a pep talk from Naruto - the possibilities are endless. Roleplay scenes, play games, explore worlds or create and share your own characters."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "category": null, "comfort_ratin