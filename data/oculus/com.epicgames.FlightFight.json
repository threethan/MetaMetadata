://scontent.oculuscdn.com/v/t64.5771-25/38982712_1674282939978141_5969047132789362294_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C9jMskzFASsQ7kNvgHmXT6r&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2C0fqAofu397pwuf_B0E8y8MWhZidStlhU61R4WQ2xA&oe=66FE948E"}, "display_name": "Allegory", "keywords": [], "long_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. ", "short_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recomme