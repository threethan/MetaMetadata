=6e7a0a&_nc_ohc=cqToUoaKzyEQ7kNvgGeE6R9&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAzIitWBcB01hssUeBNSNDZ65w3nScQl-aW_kWtqrjw1Q&oe=670BBAED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "banner_landscape_f2p_v2.png", "id": "993932871839479", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75580069_993932875172812_1981840981276440823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eiNg9kGfCqkQ7kNvgFXQgGs&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAkrFJ__FL1ocLY4DqC31sr8PXduYU4rnH4kN0tTvOX6A&oe=670BA060"}, "display_name": "Flight Fight", "keywords": [], "long_description": "Get ready for heart-pounding aerial battles in this multiplayer physics-based flying combat game. Use your wings (arms) to flap, soar, glide, twist and turn in any direction. Predators must work together to track and shoot down the Prey - while the Prey must use their flight skills to finesse through obstacles and juke out incoming Predators. Your wings are super responsive so the movement is easy to learn but also very versatile. Conquer to the skies. ", "short_description": "Use your wings to flap, soar, glide, twist, turn, dive and shoot down other players in epic aerial battles. Fly or die. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app