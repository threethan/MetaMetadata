25/39031403_1530926944401880_2598950862508915332_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93gALBY3xLIQ7kNvgEAergq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxupJXrjbu_DuGMjkzz4kJn&oh=00_AYCLbAO6scy2BPSYHWQyLAtSG3V9nRTH_14tcgvAyNyfJA&oe=66F14EA8"}, {"file_name": "tunnel_lasers.png", "id": "900347214989305", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_900347218322638_3072419956379973379_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=18J7TUrCMKgQ7kNvgGw9hT7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxupJXrjbu_DuGMjkzz4kJn&oh=00_AYCj9Aqonv6eEahzfxSi-SNOrK7BwAseFHnwA2vcXsmsbg&oe=66F15CED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "banner_landscape_f2p_v2.png", "id": "993932871839479", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580069_993932875172812_1981840981276440823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bdoiQ6cBjN8Q7kNvgHbTqfT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxupJXrjbu_DuGMjkzz4kJn&oh=00_AYCCT8kJYz0E780epiRTov0-ttkP7c6crT69mEegOKv_Fg&oe=66F14260"}, "display_name": "Flight Fight", "keywords": [], "long_description": "Get ready for heart-pounding aerial battles in this multiplayer physics-based flying combat game. Use your wings (arms) to flap, soar, glide, twist and turn in any direction. Predators must work together to track and shoot down the Prey - while the Prey must use their flight skills to finesse through obstacles and juke out incoming Predators. Your wings are super responsive so the movement is easy to learn but also very versatile. Conquer to the skies. ", "short_description": "Use your wings to flap, soar, glide, twist, turn, dive and shoot down other players in epic aerial battles. Fly or die. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website