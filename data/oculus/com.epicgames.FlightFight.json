25/38982704_1102100040849991_1234040549770812861_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dBS0vOkg1xIQ7kNvgFKLdqd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1SROhi4dsVC6237ve-Gz1&oh=00_AYCXyVEt7uWhdZVH2T8r5BIjeBUge_-tdS-UzmgYv_Tg1w&oe=66E2D4BC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "app_lab_combined_2560x1440.png", "id": "1674282936644808", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982712_1674282939978141_5969047132789362294_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pvq8S8FH49QQ7kNvgHgER-M&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1SROhi4dsVC6237ve-Gz1&oh=00_AYCb9-y1bk0o8VKNBeZf9uzJtdqVRf03zt9lApFCGZF6qQ&oe=66E2E50E"}, "display_name": "Allegory", "keywords": [], "long_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. ", "short_description": "Explore unique social VR games with friends from around the world.\n\nFlight Fight - Use your wings (arms) to flap, soar, glide, twist and turn in any direction to track and shoot down the prey. \n\nThe Last Lemming - Sway your arms to navigate obstacles and knock down opponents to be the last one standing.\n\nPathogen Patrol - Play as a white blood cell and protect your human from a viral invasion.  \n\n\u2026 and many more games coming soon. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "c