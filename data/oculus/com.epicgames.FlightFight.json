25/39031403_1530926944401880_2598950862508915332_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kAFZJtQc5AEQ7kNvgGWyI9R&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8FTxrAMKBbX9R--CtRpG_7&oh=00_AYChVhWREmERpCMbhrKg4UnPJrWgncak_VBl-BUI-hzuKQ&oe=66ED5A28"}, {"file_name": "tunnel_lasers.png", "id": "900347214989305", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_900347218322638_3072419956379973379_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TFFfFPHVaswQ7kNvgGb8zAU&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8FTxrAMKBbX9R--CtRpG_7&oh=00_AYA8clR7RpnnX80X-R3R-Fi_BIOiM7BmluFe-xUtVXkhrg&oe=66ED686D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "banner_landscape_f2p_v2.png", "id": "993932871839479", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580069_993932875172812_1981840981276440823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ftr0AOXbvEMQ7kNvgE1yFw7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8FTxrAMKBbX9R--CtRpG_7&oh=00_AYDP5v116ScjVIsHaivvAFdCcZrzn5E--VgBXVouPZVipQ&oe=66ED4DE0"}, "display_name": "Flight Fight", "keywords": [], "long_description": "Get ready for heart-pounding aerial battles in this multiplayer physics-based flying combat game. Use your wings (arms) to flap, soar, glide, twist and turn in any direction. Predators must work together to track and shoot down the Prey - while the Prey must use their flight skills to finesse through obstacles and juke out incoming Predators. Your wings are super responsive so the movement is easy to learn but also very versatile. Conquer to the skies. ", "short_description": "Use your wings to flap, soar, glide, twist, turn, dive and shoot down other players in epic aerial battles. Fly or die. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website