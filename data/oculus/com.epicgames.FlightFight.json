c_ohc=rQ0IA-OmJo4Q7kNvgEKmkFF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDUat-WV8X4Qgs7UcKXgp4DxmtHy65bJQXOMKDlZLTmWA&oe=677524A8"}, {"file_name": "tunnel_lasers.png", "id": "900347214989305", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974523_900347218322638_3072419956379973379_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYSRnMCDVAkQ7kNvgHHaxz5&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDPuUW1mfYaEXGft7ne9tmfcwR8u93oCYuXyBopczGLLg&oe=677532ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "banner_landscape_f2p_v2.png", "id": "993932871839479", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75580069_993932875172812_1981840981276440823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L9gqM67P1ukQ7kNvgGOsXaw&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBN7sJ3s8CuzLeuudh69acHn6MHQSsN9w9u19YMdp1ObA&oe=67751860"}, "display_name": "Flight Fight", "keywords": [], "long_description": "Get ready for heart-pounding aerial battles in this multiplayer physics-based flying combat game. Use your wings (arms) to flap, soar, glide, twist and turn in any direction. Predators must work together to track and shoot down the Prey - while the Prey must use their flight skills to finesse through obstacles and juke out incoming Predators. Your wings are super responsive so the movement is easy to learn but also very versatile. Conquer to the skies. ", "short_description": "Use your wings to flap, soar, glide, twist, turn, dive and shoot down other players in epic aerial battles. Fly or die. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.allegory-xr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.allegory-xr.com/terms-of-service", "publisher_name": "Allegory XR", "support_website_url": "https://www.allegory-xr.com/contact", "website_url": "https://www.allegory-xr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category"