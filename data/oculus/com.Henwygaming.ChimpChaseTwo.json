7kNvgEeD25J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEBM4PjBiFRRbVQeIwFfmLLo67WNJsshm4g8oUVJ0P6w&oe=676D596B"}, {"file_name": "deserts part 2.png", "id": "1607737863282615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580063_1607737866615948_5598030592201876940_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CA3llQsysuQQ7kNvgHc6k7y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqu_VfODfmR7AHANj-E8hT4_bCXsdXXsHYHhGsryXYJQ&oe=676D4E52"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "(New Game on Applab OUT) Download: Chimp Chase PVP", "keywords": [], "long_description": "We have currently moved our game to a new applab page called Chimp Chase PVP. \n\nChimp Chase is a thrilling PVP game that redefines the excitement of the Gorilla Locomotion movement system. Immerse yourself in a one of a kind experience as you choose from an arsenal of primary and secondary weapons. Then, dive straight into the battle zone for intense online PVP battles with other players.\n\nComplete quests to earn ores, which you can then use to purchase a wide variety of stylish cosmetics, allowing you to pimp your chimp's appearance and express yourself on the battlefield.\n\nEnter the world of Chimp Chase and take part in awesome battles that combine skill, style, and fun to provide the best possible experience.", "short_description": "We have currently moved our game to a new applab page called Chimp Chase PVP. \n\nWelcome to Chimp Chase, hop straight into the battle zone with your favorite weapons and compete against other players in some good old fashioned PVP!"}]}, "developer_name": "GetaGames", "developer_privacy_policy_url": "https://www.termsfeed.com/live/b4ebb6bd-cbca-4e03-8a17-b5173b980b12", "developer_terms_of_service_url": null, "publisher_name": "GetaGames", "support_website_url": null, "website_url": "https://www.chimpchase.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"i