dn.com/v/t64.5771-25/39031624_850777373752193_6399389938343531100_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b51WuPlcJKIQ7kNvgGQWB5j&_nc_ht=scontent.oculuscdn.com&oh=00_AYBycnx40gJ-Ioc6qYmcGjPaOPMPCR_sRoC_bY7qFc99aQ&oe=66E16F65"}, {"file_name": "4.png", "id": "977806527680306", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974792_977806531013639_8884712140261493557_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8pmT6o-BlFUQ7kNvgGuoHNr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDG5ZTkiCqO5OOOHIwG6kLEzBTHBCZguECD5pd41Wkqww&oe=66E18155"}, {"file_name": "5.png", "id": "383156268105431", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982471_383156271438764_4500580467750980333_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5aZRcONaoHYQ7kNvgE7tI50&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9-kRhr4xwakJGZzwt8eU0dQQ3w8NxdcttGBZXwIJxrw&oe=66E1986B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Probending Arena Landscape.png", "id": "473143148416069", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608439_473143151749402_2787368791221139257_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pWXvEsVsk9YQ7kNvgEqt-Dg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvCnNDFKgckYmzVdj_2pUZo9Xr9ha1FAKVKN2jyjItbA&oe=66E175D0"}, "display_name": "Probending Arena", "keywords": [], "long_description": "Probending Arena is the ultimate VR Player Versus Player experience. You strike poses to unleash different attacks, a fighting experience like no other.\n\nChoose between four elements, each with their own unique play style:\n    Water - Defensive and well rounded overall.\n    Earth - Grounded and heavy hitting in it's attacks.\n    Fire - Fast paced and slick movements.\n    Air - Light on your feet, dodging attacks and striking when ready.\n\nFight with other people and aim to be the best!\n\nOn the roadmap:\n    - 2v2 and 3v3 matches\n    - Character customization\n    - Leaderboards\n\n", "short_description": "Elemental Martial Art Fights"}]}, "devel