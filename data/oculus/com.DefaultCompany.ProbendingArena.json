e": "Probending Arena", "keywords": [], "long_description": "Probending Arena is the ultimate VR Player Versus Player experience. You strike poses to unleash different attacks, a fighting experience like no other.\n\nChoose between four elements, each with their own unique play style:\n    Water - Defensive and well rounded overall.\n    Earth - Grounded and heavy hitting in it's attacks.\n    Fire - Fast paced and slick movements.\n    Air - Light on your feet, dodging attacks and striking when ready.\n\nFight with other people and aim to be the best!\n\nOn the roadmap:\n    - 2v2 and 3v3 matches\n    - Character customization\n    - Leaderboards\n\n", "short_description": "Elemental Martial Art Fights"}]}, "developer_name": null, "developer_privacy_policy_url": "https://desmondlorenzini.github.io/ProbendingArena/", "developer_terms_of_service_url": null, "publisher_name": "Desmond D Lorenzini", "support_website_url": null, "website_url": "https://desmondlorenzini.github.io/ProbendingArena/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7629126017155683"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "757378283266508"}]}, "baseline_offer": {"id": "757378283266508"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718653797, "status": "PUBLISHED", "id": "757378283266508"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__