YBgav7-rwRoldi0ArcU9t34VyvdHM6vLlt2MFk2jw1JmQ&oe=67826F6B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Probending Arena Landscape.png", "id": "473143148416069", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75608439_473143151749402_2787368791221139257_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YLPk9ysxmogQ7kNvgFn20Ur&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSl3W4Co2Ie-WKjBTKW4AVbKIrl6bZT2Sd6RJ02vfg1w&oe=67824CD0"}, "display_name": "Probending Arena", "keywords": [], "long_description": "Probending Arena is the ultimate VR Player Versus Player experience. You strike poses to unleash different attacks, a fighting experience like no other.\n\nChoose between four elements, each with their own unique play style:\n    Water - Defensive and well rounded overall.\n    Earth - Grounded and heavy hitting in it's attacks.\n    Fire - Fast paced and slick movements.\n    Air - Light on your feet, dodging attacks and striking when ready.\n\nFight with other people and aim to be the best!\n\nOn the roadmap:\n    - 2v2 and 3v3 matches\n    - Character customization\n    - Leaderboards\n\n", "short_description": "Elemental Martial Art Fights"}]}, "developer_name": null, "developer_privacy_policy_url": "https://desmondlorenzini.github.io/ProbendingArena/", "developer_terms_of_service_url": null, "publisher_name": "Desmond D Lorenzini", "support_website_url": null, "website_url": "https://desmondlorenzini.github.io/ProbendingArena/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_T