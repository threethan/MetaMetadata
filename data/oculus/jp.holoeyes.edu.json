hP5orgA2crtZmZnGWyUC0qABEnD6G6f9GtJOxuF5XEw&oe=6714F74F"}, {"file_name": "oclus_edu_screenshot5.png", "id": "854494045948939", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75282159_854494049282272_4183089142901367298_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5-L_HOCZr8Q7kNvgEv-6w9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDx7YbnHu367wMm8ljQhBwtiRQjUx8N8k1zhZ-7cy3Lcw&oe=6714E3F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oclus_edu_cover.png", "id": "360324569152720", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982721_360324572486053_1294515362909550491_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Xznehbc4EQQ7kNvgHzMrsO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-Boh6x6NXT2MXw-1jLcqSGn_erIkp0Mu2LeaVPEZyPA&oe=6714D25B"}, "display_name": "Holoeyes Edu", "keywords": [], "long_description": "VR\u306b\u3088\u308b\u65b0\u305f\u306a\u533b\u7642\u6559\u80b2\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u300cHoloeyes Edu(\u30a8\u30c7\u30e5)\u300d\n\n\uff1cHoloeyes Edu 3\u3064\u306e\u7279\u5fb4\uff1e\n1. \u4eba\u4f53\u89e3\u5256\u30fb\u624b\u6280\u30fb\u8853\u5f0f\u3092VR\u3067\u7acb\u4f53\u7a7a\u9593\u7684\u306b\u7406\u89e3\n3D\u30dd\u30ea\u30b4\u30f3\u3067VR\u5316\u3055\u308c\u305f\u4eba\u4f53\u30c7\u30fc\u30bf\u3092\u95b2\u89a7\u3057\u3001 \u57fa\u790e\u89e3\u5256\u30fb\u81e8\u5e8a\u89e3\u5256\u304a\u3088\u3073\u5916\u79d1\u624b\u8853\u306e\u8853\u5f0f\u3092\u5b66\u7fd2\u53ef\u80fd\u3002\n2022\u5e74\u3088\u308a\u3001\u5f85\u671b\u306eMeta Quest 2\u306b\u5bfe\u5fdc\u3002 360\u5ea6\u5168\u65b9\u5411\u3078\u306eVR\u4f53\u9a13\u304c\u3001\u3088\u308a\u4f53\u611f\u3092\u4f34\u3046\u5b66\u7fd2\u3092\u5b9f\u73fe\u3057\u307e\u3057\u305f\u3002\n\n\n2. 3D\u30e2\u30c7\u30eb\u30c7\u30fc\u30bf\u306e\u52d5\u304d\u30fb\u97f3\u58f0\u7b49\u3092\u7acb\u4f53\u7a7a\u9593\u306b\u8a18\u9332 \u30aa\u30ea\u30b8\u30ca\u30ebVR\u6559\u6750\u3092\u8ab0\u3067\u3082\u4f5c\u6210\u53ef\u80fd\n\u57fa\u790e\u89e3\u5256\u307e\u305f\u306f\u6240\u6709\u3059\u308b\u81e8\u5e8a\u89e3\u5256\u306e3D\u30c7\u30fc\u30bf\u3092\u8aad\u307f\u8fbc\u307f\u3001 \u8b1b\u5e2b\u306b\u3088\u308b\u97f3\u58f0\u89e3\u8aac\u3084\u624b\u306e\u52d5\u304d\u7b49\u3092\u8a18\u9332\u3059\u308b\u3060\u3051\u3067\u3001 \u30aa\u30ea\u30b8\u30ca\u30ebVR\u6559\u6750\u30b3\u30f3\u30c6\u30f3\u30c4\u304c\u4f5c\u6210\u53ef\u80fd\u3002\n\u5b66\u6821\u3054\u3068\u306e\u30ab\u30ea\u30ad\u30e5\u30e9\u30e0\u3084\u3001\u533b\u5e2b\u30aa\u30ea\u30b8\u30ca\u30eb\u306e\u624b\u6280\u30fb\u8853\u5f0f\u3092 \u30b3\u30f3\u30c6\u30f3\u30c4\u5316\u3059\u308b\u3053\u3068\u3067\u3001\u72ec\u81ea\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u3088\u308b\u6559\u80b2\u3092\u5b9f\u73fe\u3057\u307e\u3059\u3002\n\n\n3. \u30e6\u30fc\u30b6\u30fc\u306e\u5b66\u7fd2\u884c\u52d5\u5c65\u6b74\u3092\u53d6\u5f97\u53ef\u80fd VR\u6d3b\u7528\u306b\u3088\u308b\u7406\u89e3\u5ea6\u30fb\u6210\u7e3e\u3078\u306e\u52b9\u679c\u304c\u898b\u3048\u308b\u5316\n\u7d44\u7e54\u5168\u4f53\u306e\u5b66\u7fd2\u72b6\u6cc1\u3092\u898b\u3048\u308b\u5316\u3001VR\u6d3b\u7528\u306b\u3088\u308b\n\u7406\u89e3\u5ea6\u30fb\u6210\u7e3e\u5411\u4e0a\u306e\u52b9\u679c\u30fb\u8ca2\u732e\u5ea6\u304c\u308f\u304b\u308a\u307e\u3059\u3002 \n\u307e\u305f\u3001\u5404\u7a2e\u884c\u52d5\u5c65\u6b74\u30c7\u30fc\u30bf\u306fCSV\u3067\u30a8\u30af\u30b9\u30dd\u30fc\u30c8\u3067\u304d\u308b\u305f\u3081 \u65e2\u5b58LMS(\u30e9\u30fc\u30cb\u30f3\u30b0\u30de\u30cd\u30b8\u30e1\u30f3\u30c8\u30b7\u30b9\u30c6\u30e0)\u3068\u306e\u9023\u643a\u304c\u53ef\u80fd\u3067\u3059\u3002", "short_description": "VR\u306b\u3088\u308b\u65b0\u305f\u306a\u533b\u7642\u6559\u80b2\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u300cHoloeyes Edu(\u30a8\u30c7\u30e5)\u300d\n\n2022\u5e74\u3088\u308a\u3001\u5f85\u671b\u306eMeta Quest 2\u306b\u5bfe\u5fdc\u3002 360\u5ea6\u5168\u65b9\u5411\u3078\u306eVR\u4f53\u9a13\u304c\u3001\u3088\u308a\u4f53\u611f\u3092\u4f34\u3046\u5b66\u7fd2\u3092\u5b9f\u73fe\u3057\u307e\u3057\u305f\u3002\n\n\n\uff1cHoloeyes Edu 3\u3064\