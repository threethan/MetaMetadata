040q1rLNFzpjCc1_8BlFZg&oe=67178A94"}, {"file_name": "oclus_edu_screenshot4.png", "id": "1013464242608217", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203622_1013464245941550_5587492047250994430_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iyZK-5mDvTcQ7kNvgG6-qD_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9s4AqecPzI8bTzMEtR7BeOBoFR5bzt9XxrHHDhCGRmg&oe=6717A4CD"}, {"file_name": "oclus_edu_screenshot5.png", "id": "1656496264690319", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65228209_1656496271356985_5972800026002031442_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ADBWu2DR4TIQ7kNvgEoCEil&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5MOsia6HQHNVsH-qyg4bk55KE6ExDxfc1SGEJpWFE6Q&oe=6717A1FC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oclus_edu_cover.png", "id": "374061414344853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982665_374061417678186_7091131881989292693_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xQoioLzEUwAQ7kNvgHk5Av7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn63RkYaX9hRRVqTvyfuvwRziPEwwMdD_5JABQMK1Z5A&oe=6717A1E9"}, "display_name": "Holoeyes Edu", "keywords": [], "long_description": "New medical education platform \"Holoeyes Edu\" by VR\n\n<Three features of Holoeyes Edu>\n1. Understanding human anatomy, techniques, and techniques in 3D space with VR\nIt is possible to browse basic anatomy / clinical anatomy and surgical procedures by viewing VR-converted human body data with 3D polygons.\n\n2. Anyone can create original VR teaching materials by recording the movement and voice of 3D model data in a three-dimensional space.\nOriginal VR teaching material content can be created simply by reading the 3D data of the basic anatomy or the clinical anatomy that you own, and recording the audio commentary and hand movements by the instructor.\n\n3. User's learning behavior history can be acquired Visualize the effect on understanding and grades by utilizing VR\nVisualize the learning situation of the entire organization, by utilizing VR\nYou can see the degree of understanding, the effect of improving grades, and the degree of contribution.", "short_description": "New medical education platform \"Holoeyes Edu\" by VR\n\n<Three features of Holoeyes Edu>\n1. Understanding human anatomy, techniques, and techniques in 3D space with VR\n2. Anyone can create original VR teaching materials by recording the movement and voice of 3D model data in a three-dimensional space.\n3. User's learning behavior history can be acquired Visualize the effect on understanding and grades by utilizing VR"}]}, "developer_name": null, "developer_privacy_policy_url": "https://edu.holoeyes.jp/pp", "developer_terms_of_service_url": "https://edu.holoeyes.jp/tos", "publisher_name": "Holoeyes", "support_website_url": "https://docs.google.com/forms/d/e/1FAIpQLScB4YV7GaDs37UWqhnrcvo_fumY0OQaOmK-xP41nC_L6_6Igg/viewform", "website_url": "https://holoeyes.jp/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "MEDICINE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "743002007057425"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1600144110356221"}]}, "baseline_offer": {"id": "1600144110356221"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1655910000, "status": "PUBLISHED", "id": "1600144110356221"}]}, "liveChannel": {"nodes": [{"latest_suppor