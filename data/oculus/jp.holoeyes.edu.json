sn6YB&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlvBgEnREeCtntM6nwfKi3Xw47NBg2KsVhxvfKJNruwQ&oe=66D6F114"}, {"file_name": "oclus_edu_screenshot4.png", "id": "1013464242608217", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203622_1013464245941550_5587492047250994430_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UDRQwp5_YeYQ7kNvgFBICZS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZ4kTUdp-GnJLp68BC0SwjAgH8AzY3K7wmUjcd3gAbtg&oe=66D70B4D"}, {"file_name": "oclus_edu_screenshot5.png", "id": "1656496264690319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65228209_1656496271356985_5972800026002031442_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mOtYu7cI8x8Q7kNvgE4fNhC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBd_FbjlWL-N8sR12E0g5PPGMK5LKCgDAkZMVXR7RBCTw&oe=66D7087C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oclus_edu_cover.png", "id": "374061414344853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982665_374061417678186_7091131881989292693_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OCKy8MFaOBwQ7kNvgHRBJDK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCvPM-tDskhVPnCfndbWk_4xCxBUowBJyXG6tKq79R_w&oe=66D70869"}, "display_name": "Holoeyes Edu", "keywords": [], "long_description": "New medical education platform \"Holoeyes Edu\" by VR\n\n<Three features of Holoeyes Edu>\n1. Understanding human anatomy, techniques, and techniques in 3D space with VR\nIt is possible to browse basic anatomy / clinical anatomy and surgical procedures by viewing VR-converted human body data with 3D polygons.\n\n2. Anyone can create original VR teaching materials by recording the movement and voice of 3D model data in a three-dimensional space.\nOriginal VR teaching material content can be created simply by reading the 3D data of the basic anatomy or the clinical anatomy that you own, and recording the audio commentary and hand movements by the instructor.\n\n3. User's learning behavior history can be acquired Visualize the effect on understanding and grades by utilizing VR\nVisualize the learning situation of the entire organization, by utilizing VR\nYou can see the degree of understanding, the effect of improving grades, and the degree of contribution.", "short_description": "New medical education platform \"Holoeyes Edu\" by VR\n\n<Three features of Holoeyes Edu>\n1. Understanding human anatomy, techniques, and techniques in 3D space with VR\n2. Anyone can create original VR teaching materials by recording the movement and voice of 3D model data in a three-dimensional space.\n3. User's learning behavior history can be acquired Visualize the effect on understanding and grades by utilizing VR"}]}, "developer_name": "Holoeyes", "developer_privacy_policy_url": "https://edu.holoeyes.jp/pp", "developer_terms_of_service_url": "https://edu.holoeyes.jp/tos", "publisher_name": "Holoeyes", "support_website_url": "https://docs.google.com/forms/d/e/1FAIpQLScB4YV7GaDs37UWqhnrcvo_fumY0OQaOmK-xP41nC_L6_6Igg/viewform", "website_url": "https://holoeyes.jp/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "MEDICINE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "202628509323782"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982498_274814664833748_7958352825385809954_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ex45eiezuhAQ7kNvgEwDAWU&_nc_ht=scontent.oculuscdn.c