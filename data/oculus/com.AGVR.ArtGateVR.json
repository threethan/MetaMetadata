_AYAg43WLfKt7E9LL97uvppzOpgZlXWbu0VfLdBXIsIXe8g&oe=66FA872E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ArtGate_2024.png", "id": "1558563805074161", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_1558563808407494_267285228317837209_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dHcqtNeDKKcQ7kNvgEdbes7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCn1l94doxS7I4EoNYEhiRlt428v6--tVh1S0nDeljmw&oe=66FA82BA"}, "display_name": "Art Gate", "keywords": [], "long_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting global  immersive art events that are accessible to everyone, anywhere. \n\nOur mission is to democratize the access to art, allowing enthusiasts, collectors, and artists from diverse backgrounds to engage with and appreciate art without the constraints of geography. \n\nBy leveraging cutting-edge technology, Art Gate creates immersive, inclusive, and interactive art events that connect creators and audiences in a dynamic, virtual space. Our platform is designed to celebrate creativity and foster a global community of art lovers, making every event a unique, accessible, and enriching experience.\n", "short_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting immersive art events that are accessible to everyone, anywhere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://artgatevr.com/terms-of-use/", "publisher_name": "Art Gate VR Inc.", "support_website_url": "https://www.artgatevr.com/contact/", "website_url": "https://www.artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "con