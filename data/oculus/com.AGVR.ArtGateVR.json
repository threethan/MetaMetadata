_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1VVOW-z323wQ7kNvgFuwdGS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlNykRrcTBdnSjRcR8Kz599kveg4p29bkv-fYLFgZ4ZA&oe=6735F6ED"}, {"file_name": "75443239_230319371319014_4024861978190151680_n.png", "id": "216425160165808", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001721_216425163499141_2644583197426324731_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9wauOMAoTkQ7kNvgEVqUV7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfvs7Iv1DxO7Lwzc_KPKkE9l31y2n8ngfnXlBPvPo6bA&oe=6735DAAE"}, {"file_name": "75302219_1089123061448083_6872039061914124288_n.png", "id": "1415425015455905", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982478_1415425018789238_8587611967391371570_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IrTtE-JkX0UQ7kNvgGM01vO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdfhZCz1Kg1b_y2c0EPaDfGJrH4uBC0q2kmtS8HPYn2A&oe=6735DD12"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover Art.png", "id": "768347673798087", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003239_768347677131420_8476754123177296243_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BpuQlL8n_K8Q7kNvgEMj_GP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTYF1d59sW9FKsw20VhdrX5vp3MZtPoGkZqgFyjPAhsg&oe=6735D483"}, "display_name": "Art Gate VR", "keywords": [], "long_description": "Art Gate is an art market in virtual reality. Exhibitors from North America, South America, Africa, Europe, Asia, and Australia actively curate and host social art events in Art Gate. Erin Loree and Alex McLeod are among the contemporary artists on exhibition. Masters such as Pablo Picasso, Robert Indiana, Cindy Sherman, Louise Nevelson, and many other artists in between can be found in Art Gate as well. All the exhibitions are open to the public for free. \n\n-Join social art events\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries\