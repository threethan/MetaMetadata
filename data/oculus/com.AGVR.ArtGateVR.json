_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_0KWhsAweGMQ7kNvgH58-yq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBtf7UD_DVFq-o-LKdoxjvQhDUFuNirzD65y0rueweZ4w&oe=672624ED"}, {"file_name": "75443239_230319371319014_4024861978190151680_n.png", "id": "216425160165808", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001721_216425163499141_2644583197426324731_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5EQo-AO_ow0Q7kNvgGU8YQ1&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA0_HULNbNhwWMhq1tgWzH99vM2iFrH0H0__2G5bah_ew&oe=672608AE"}, {"file_name": "75302219_1089123061448083_6872039061914124288_n.png", "id": "1415425015455905", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982478_1415425018789238_8587611967391371570_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZDZBQX3TK4sQ7kNvgEuHV0M&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAFgNJPqC0jehGiucwYmVFpObLuKYFUQ9lnbUXYtV-z-Q&oe=67260B12"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover Art.png", "id": "768347673798087", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003239_768347677131420_8476754123177296243_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s4JILhxPlpUQ7kNvgHKRFOP&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYChp4BtcQBip6tYm4BA94Mq9jOKBfVSMpJ1S6A6fZ6rsg&oe=67260283"}, "display_name": "Art Gate VR", "keywords": [], "long_description": "Art Gate is an art market in virtual reality. Exhibitors from North America, South America, Africa, Europe, Asia, and Australia actively curate and host social art events in Art Gate. Erin Loree and Alex McLeod are among the contemporary artists on exhibition. Masters such as Pablo Picasso, Robert Indiana, Cindy Sherman, Louise Nevelson, and many other artists in between can be found in Art Gate as well. All the exhibitions are open to the public for free. \n\n-Join social art events\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries\