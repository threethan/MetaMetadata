com/v/t64.5771-25/38974789_250377929828197_968906876402529959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2yJ_SZ2SlYQ7kNvgFqP_Od&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0S_TXAkt10mr6AQOqdkXi_5Ox1Roee5gp6sysdRe9Sw&oe=66CDD06D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled-1.png", "id": "536038474538452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210390_536038477871785_7800891175797109487_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VopTzGERVHMQ7kNvgFPwrgd&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_kobPXYbGy51i3cxl2_08BcI-r9M-_9cFZSzByvkWBg&oe=66CDC658"}, "display_name": "Art Gate VR", "keywords": [], "long_description": "Art Gate is on a mission to make the arts more accessible. Launched in 2018, it offers customizable  gallery spaces for exhibitions taking place in a fully interactive, social virtual reality (VR) art market. Art Gate presents a new way for artists, aficionados, galleries, dealers, and collectors to discover, buy, and sell art internationally; through a VR headset or simply with their computer (PC/Mac). Regardless of physical location, art can be shared with visitors around the world, who can meet up together in the virtual environment.\n\n- Join art events\n- Curate exhibitions\n- Connect with artists, collectors, and galleries from all over the world\n\nFor our programming schedule visit: www.artgatevr.com/programming", "short_description": "Art Gate is your destination for social art events. Join an art fair, opening reception, artist talk or exhibition tour with other art lovers from around the world. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://artgatevr.com/terms-of-use/", "publisher_name": "Art Gate VR Inc.", "support_website_url": "https://www.artgatevr.com/contact/", "website_url": "https://www.artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "co