 art events in Art Gate. Erin Loree and Alex McLeod are among the contemporary artists on exhibition. Masters such as Pablo Picasso, Robert Indiana, Cindy Sherman, Louise Nevelson, and many other artists in between can be found in Art Gate as well. All the exhibitions are open to the public for free. \n\n-Join social art events\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries\n\nFor our programming schedule visit: www.artgatevr.com/programming", "short_description": "Art Gate is your destination for social art events. Join an art fair, opening reception, artist talk or exhibition tour with other art lovers from around the world. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.artgatevr.com/app/privacy.php", "developer_terms_of_service_url": "https://www.artgatevr.com/app/terms.php", "publisher_name": "Art Gate VR Inc.", "support_website_url": "https://www.artgatevr.com/contact/", "website_url": "https://www.artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1063173634247279"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "750521102492024"}]}, "baseline_offer": {"id": "750521102492024"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1616111940, "status": "PUBLISHED", "id": "750521102492024"}]}, "liveChannel": {"nodes": [{"latest_supported_binary