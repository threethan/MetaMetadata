_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=khAxbsCXtngQ7kNvgFkJYl9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAStoGIfzA7dc7IsiPHigaXn5LGg2R6aYZ3AS3wtZeRyA&oe=6739EB6D"}, {"file_name": "75443239_230319371319014_4024861978190151680_n.png", "id": "216425160165808", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001721_216425163499141_2644583197426324731_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vhVJ3T4Fvs0Q7kNvgE5PDJQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAW72uLuxSZjGLZBwvCHHvu3xa1_f0w4z7UO9k0I_2j9g&oe=6739CF2E"}, {"file_name": "75302219_1089123061448083_6872039061914124288_n.png", "id": "1415425015455905", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982478_1415425018789238_8587611967391371570_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1jKXZqVv-ZwQ7kNvgF177bu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgivbhEd3ltQmMB02X93XJ4a5xK7DjSU8y9mM70bC6rA&oe=6739D192"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover Art.png", "id": "768347673798087", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003239_768347677131420_8476754123177296243_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=owGunTI5-SQQ7kNvgEuPtAd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANNFImUKN0Iter9ONzZvoacjydWHwJhAGZPdl3qz_29A&oe=6739C903"}, "display_name": "Art Gate VR", "keywords": [], "long_description": "Art Gate is an art market in virtual reality. Exhibitors from North America, South America, Africa, Europe, Asia, and Australia actively curate and host social art events in Art Gate. Erin Loree and Alex McLeod are among the contemporary artists on exhibition. Masters such as Pablo Picasso, Robert Indiana, Cindy Sherman, Louise Nevelson, and many other artists in between can be found in Art Gate as well. All the exhibitions are open to the public for free. \n\n-Join social art events\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries\