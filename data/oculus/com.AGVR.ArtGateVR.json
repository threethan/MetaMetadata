1978190151680_n.png", "id": "216425160165808", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001721_216425163499141_2644583197426324731_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1AXkcR9nLRQQ7kNvgErdx1B&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbLD-_CHs6QzAy8MWfPW3xAHpFBJ8LCS04xl1XOtouUw&oe=674C442E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ArtGate_2024.png", "id": "1558563805074161", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031639_1558563808407494_267285228317837209_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U0qiRN_cjb4Q7kNvgF3oKwl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDWlWH_ucfgtZcwJOT7WlCrvvkB-HloyPYHskYCj3Gxzg&oe=674C3FBA"}, "display_name": "Art Gate", "keywords": [], "long_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting global  immersive art events that are accessible to everyone, anywhere. \n\nOur mission is to democratize the access to art, allowing enthusiasts, collectors, and artists from diverse backgrounds to engage with and appreciate art without the constraints of geography. \n\nBy leveraging cutting-edge technology, Art Gate creates immersive, inclusive, and interactive art events that connect creators and audiences in a dynamic, virtual space. Our platform is designed to celebrate creativity and foster a global community of art lovers, making every event a unique, accessible, and enriching experience.\n", "short_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting immersive art events that are accessible to everyone, anywhere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://artgatevr.com/terms-of-use/", "publisher_name