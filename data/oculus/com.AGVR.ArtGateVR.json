3yFL_1GX6rt6cYCAmFKdrV-0f80m80gv8p1FQ&oe=66ED7A6E"}, {"file_name": "75443239_230319371319014_4024861978190151680_n.png", "id": "216425160165808", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001721_216425163499141_2644583197426324731_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=waIVB9AAqWwQ7kNvgHAEW-f&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATfqLPbcddlRLqBLXDcsoJ3&oh=00_AYAiCVRk5_VojMGQf6LimSOaI52aYFTy_WyOJavDUVijgg&oe=66ED582E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ArtGate_2024.png", "id": "1558563805074161", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_1558563808407494_267285228317837209_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLpwflkRpiIQ7kNvgFsTXc4&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATfqLPbcddlRLqBLXDcsoJ3&oh=00_AYBZ7buhBHPZsDaOdm3_aLAlvfym16LqCSRVWfElBoP97g&oe=66ED53BA"}, "display_name": "Art Gate", "keywords": [], "long_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting global  immersive art events that are accessible to everyone, anywhere. \n\nOur mission is to democratize the access to art, allowing enthusiasts, collectors, and artists from diverse backgrounds to engage with and appreciate art without the constraints of geography. \n\nBy leveraging cutting-edge technology, Art Gate creates immersive, inclusive, and interactive art events that connect creators and audiences in a dynamic, virtual space. Our platform is designed to celebrate creativity and foster a global community of art lovers, making every event a unique, accessible, and enriching experience.\n", "short_description": "Art Gate is a pioneering events platform dedicated to the arts, transforming the way art events are experienced around the world. We specialize in hosting immersive art events that are accessible to everyone, anywhere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://artgatevr.com/terms-of-use/", "publisher_name": "Art Gate VR Inc.", "support_website_url": "https://www.artgatevr.com/contact/", "website_url": "https://www.artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "2687655338230691"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7990010331066241"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031444_1048366346723971_2348441553648055345_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gAm3U1VUXaEQ7kNvgHhd6IH&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATfqLPbcddlRLqBLXDcsoJ3&oh=00_AYCP-0BVQ0jzZRKQr5BtlFKb1HG362pjrRUDNmyHa17cZw&oe=66ED47E9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Art Gate", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Lifestyle", "id": "3362542290449643"}, {"topic_name": "Events", "id": "2687655338230691"}, {"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1616111899, "lastRevision": {"nodes": [{"id": "2850321115183346", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata"