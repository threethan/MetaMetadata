036095554_881377421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RTFyTHnT8QQ7kNvgG6XTyv&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK4zXUlVgra0Py_ijrRv4uvZWXzfu8K3-j8pUASyM8bA&oe=66F15148"}, {"file_name": "migrated_image.png", "id": "208383707077968", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427499_323305474667877_1536353967_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xRBfvwRF_D8Q7kNvgEqCiRq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCXCFxhrCcacBo6ODB9RIThmngjLXqpPmPsi2sAlVrsQ&oe=66F145FF"}]}, "id": "654281343542862", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "833857710466449", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12504568_709854435819525_1552087496_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=euA3KMevRi8Q7kNvgEG_fLn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyRXkDCCM-Q6AXUQWfbf85yfCTm7Wh2ZA7I5659iA3cg&oe=66F16597"}, {"file_name": "migrated_image.png", "id": "528712977787440", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427568_556386217897487_81576906_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02q3MYtyG2gQ7kNvgFl618p&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4LFkkmtLhS4xYhR-DstuiAE41at-YfODb7YmL8Ol96A&oe=66F136D3"}, {"file_name": "migrated_image.png", "id": "519560692332425", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427719_251143921943150_1723034249_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=beqdNscbbEsQ7kNvgHlg4Hg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDek2EzA9zNNPNXwunmb-OlZiq--wttkyaeXONWxiVITg&oe=66F14ADB"}, {"file_name": "migrated_image.png", "id": "516226192374346", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12522219_1766462830251061_1236096222_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O56LSlnn-A0Q7kNvgFgocg2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKxGoGCUWNu6UilRseqjqfazIqw-0N_hlquvmhNYMWUg&oe=66F1450F"}, {"file_name": "migrated_image.png", "id": "209845970360475", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162754_933758200077438_514500997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bB7XY6Q1wFoQ7kNvgHPYf1c&_nc_ht=scontent.oculuscdn.com&oh=00_AYDogAj0mI29m08YyQ3KZ-BoWEXBF_hmIJFxQnprKTm7ow&oe=66F159FE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Presence", "keywords": ["Movie", "Film", "Horror", "Interactive", "Seance"], "long_description": "The Presence is a proof-of-concept demonstration showing how interactive elements can make 360\u00b0 films more immersive. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In both versions, the viewer influences how the story unfolds. In the \"active\" version the viewer is able to jump between multiple perspectives at will; while in the \"reactive\" version the viewer's gaze motivates the next shot, editing the film organically.\n\n          Additional storage required:  ~1.5GB\n          Runtime:  ~6 minutes\n\nThe Presence contains strong language and violence and is recommended for a mature audience only.\n\nThe Presence works with the Gear VR touchpad or most Bluetooth controllers. For viewers who have a SubPac, The Presence utilizes SubPac\u2019s tactile audio technology for a more immersive experience.", "short_description": "The Presence is a proof-of-concept demo showing how interactive elements can improve 360\u00b0 films. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In the active version the viewer is able to jump between multiple perspectives at will; while in the reactive version the viewer's gaze motivates the next shot.\n         Additional storage required:  ~1.5GB\n         Runtime:  ~6 minutes"}]}, "developer_name": null, "developer_privacy_policy_url": "http://joshgladstone.com/tos_privacy.htm", "developer_terms_of_service_url": "http://joshgladstone