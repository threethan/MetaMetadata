a0a&_nc_ohc=6vm-x4ninDYQ7kNvgFhL1D1&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBvQSaiGkCfV9eNWPQNvY2Y54s_FvwJnspVyIbG0xsY9Q&oe=6729F58F"}, {"file_name": "migrated_image.png", "id": "209845970360475", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/11162754_933758200077438_514500997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fh6LUe5jft0Q7kNvgHkPqa4&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAzE4kzr47sy-UKuhgcwqQvMDBCLp-3dpRPpPZy1o7ItQ&oe=672A0A7E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Presence", "keywords": ["Movie", "Film", "Horror", "Interactive", "Seance"], "long_description": "The Presence is a proof-of-concept demonstration showing how interactive elements can make 360\u00b0 films more immersive. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In both versions, the viewer influences how the story unfolds. In the \"active\" version the viewer is able to jump between multiple perspectives at will; while in the \"reactive\" version the viewer's gaze motivates the next shot, editing the film organically.\n\n          Additional storage required:  ~1.5GB\n          Runtime:  ~6 minutes\n\nThe Presence contains strong language and violence and is recommended for a mature audience only.\n\nThe Presence works with the Gear VR touchpad or most Bluetooth controllers. For viewers who have a SubPac, The Presence utilizes SubPac\u2019s tactile audio technology for a more immersive experience.", "short_description": "The Presence is a proof-of-concept demo showing how interactive elements can improve 360\u00b0 films. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In the active version the viewer is able to jump between multiple perspectives at will; while in the reactive version the viewer's gaze motivates the next shot.\n         Additional storage required:  ~1.5GB\n         Runtime:  ~6 minutes"}]}, "developer_name": null, "developer_privacy_policy_url": "http://joshgladstone.com/tos_privacy.htm", "developer_terms_of_service_url": "http://joshgladstone.com/tos_privacy.htm", "publisher_name": "Pseudoscience Pictures", "support_website_url": null, "website_url": "http://joshgladstone.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7209422042519811"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/12504572_1651639321824498_633202927_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YrGFF63ifj8Q7kNvgG_i3Xt&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYADK1G6K17rrSBNfPyGyDu_KmBMx3cx-aqAfkVxWsDgcQ&oe=6729EFEF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Presence", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1467183600, "lastRevision": {"nodes": [{"id": "1354967431184006", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "862432087218870", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translati