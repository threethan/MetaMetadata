_nc_ohc=SbCP13HDuy4Q7kNvgGbs80r&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC5s2iqKHRmeEYsN_9Z7MQyvZFVnnd2VGsimPCfrPprdQ&oe=67728CFE"}, {"file_name": "migrated_image.png", "id": "142763513777212", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12427536_253589715002993_418784534_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6aZgzJT7kWIQ7kNvgFrhBlM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAnxuyS0FTY2Etg1AeEosS8Fj7sIZKnq8Y8kZsGsmbJzA&oe=67728174"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Presence", "keywords": ["Movie", "Film", "Horror", "Interactive", "Seance"], "long_description": "The Presence is an interactive, live-action, horror film, built for the Gear VR. The story follows four characters through a s\u00e9ance gone wrong. As the movie progresses viewers are able to affect the point of view and discover different aspects of a complex story. A proof-of-concept piece, The Presence illustrates two new approaches to VR storytelling: free roam and cinematic. In both versions, the viewer influences how the story unfolds. In the free roam version, the viewer is able to jump between multiple perspectives at will; while in the cinematic version, the viewer's gaze motivates the next shot, editing the film organically.\n\n          Additional storage required:  ~1.5GB\n          Runtime:  ~6 minutes\n\nThe Presence contains strong language and violence and is recommended for a mature audience only.\n\nThe Presence works with the Gear VR touchpad or most Bluetooth controllers.", "short_description": "The Presence is an interactive, live-action, horror film following four characters through a s\u00e9ance gone wrong. A proof-of-concept piece, The Presence illustrates two new approaches to VR storytelling: free roam and cinematic. In the free roam version, the viewer is able to jump between multiple perspectives at will; while in the cinematic version, the viewer's gaze motivates the next shot, editing the film organically."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Pseudoscience Pictures", "support_website_url": null, "website_url": "http://pseudoscience.pictures/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["HORROR", "MOVIE", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "495579938646470"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1406462432985832"}]}, "baseline_offer": {"id": "1406462432985832"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1467183600, "status": "PUBLISHED", "id": "1406462432985832"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1251649468297128", "version": "1.7.5"}, "id": "1717244798531172", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "862432087218870", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1251649468297128"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1717244798531172"}]}, "change_log": "Unity update", "created_date": 1501780689, "id": "1251649468297128", "version": "1.7.5", "version_code": 28, "release_status": "RELEASED", "status": "APPROVED", "binary_test_resu