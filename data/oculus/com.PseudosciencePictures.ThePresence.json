a0a&_nc_ohc=sMhtGmCLDKQQ7kNvgEo5nCl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3L7NAsPmz8Qk700gyufxzw06pI5n-b3r28iXnS7bV8A&oe=6771268F"}, {"file_name": "migrated_image.png", "id": "209845970360475", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162754_933758200077438_514500997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IAJ-jApqPkwQ7kNvgH-TuvC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVc4Y8HV2VuJI_77yS6GnrNdk0I18Ci8xVwzXGnv__lg&oe=67713B7E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Presence", "keywords": ["Movie", "Film", "Horror", "Interactive", "Seance"], "long_description": "The Presence is a proof-of-concept demonstration showing how interactive elements can make 360\u00b0 films more immersive. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In both versions, the viewer influences how the story unfolds. In the \"active\" version the viewer is able to jump between multiple perspectives at will; while in the \"reactive\" version the viewer's gaze motivates the next shot, editing the film organically.\n\n          Additional storage required:  ~1.5GB\n          Runtime:  ~6 minutes\n\nThe Presence contains strong language and violence and is recommended for a mature audience only.\n\nThe Presence works with the Gear VR touchpad or most Bluetooth controllers. For viewers who have a SubPac, The Presence utilizes SubPac\u2019s tactile audio technology for a more immersive experience.", "short_description": "The Presence is a proof-of-concept demo showing how interactive elements can improve 360\u00b0 films. The story follows four characters through a s\u00e9ance gone wrong. This demo contains two new approaches to VR storytelling: \"active\" and \"reactive.\" In the active version the viewer is able to jump between multiple perspectives at will; while in the reactive version the v