995_4471550335629762999_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7xof2wF1YtQQ7kNvgHXWIBE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnCfX6xnJyPPD6ZncF2CBBxwDod5UNoaT-6njx2xvd9Q&oe=6763F4BC"}, {"file_name": "1440-ScreenShot13.png", "id": "902714953794064", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031617_902714960460730_2931854413158517337_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=im1lI0Q37VcQ7kNvgFUDC_6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCh_g0VXIVv-lKnqvX43dwvg96wElgj2cKNAt5z51aeHQ&oe=67641F44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1440-ScreenShot33.png", "id": "478769856749003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982602_478769863415669_1634444826754880031_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2sl2BNHQPW0Q7kNvgFVZCQW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBt0R3kDSYVd-yeIS9I87rEYHW-XIs-_Vf5IXIPlUJ9A&oe=6763FE97"}, "display_name": "NaN Industry", "keywords": [], "long_description": "N\u2e31a\u2e31N Industry is a VR puzzle game where you build a \"factory\" in 3D by placing action blocks in space. Arrange them so that they will push, weld, destroy other blocks, fire lasers, and so on. The goal is to guide input blocks to output locations, possibly modifying, splitting or combining them along the way into larger structures.\n\n* 30+ built-in puzzles\n* 6 space locations, no gravity\u2014blocks float\n* increasing puzzle difficulty from easy to seriously hard\n* puzzle editor included\n* in-game workshop of published puzzles made by others\n\nThis game puts emphasis on the freedom of placement one gets from VR: there is no gravity; blocks can be moved and rotated along any axis and float along under their own inertia.", "short_description": "Build a \"factory\" by putting blocks in space which will push, rotate, weld, etc. the products"}]}, "developer_name": "Armin Rigo", "developer_privacy_policy_url": "https://baroquesoftware.com/nan-industry/", "developer_terms_of_service_url": null, "publisher_name": "Baroque Software", "support_website_url": null, "website_url": "https://baroquesoftware.com/nan-industry/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "465571575096919"}, "review_messages": ["", "Hello!\n\nThank you for submitting you application to App Lab. Your metadata makes use of well-known IP. Please provide proof showing your team has rights to the IP utilized in the application's description. For more information, please refer to the Developer Distribution Agreement in your Oculus Dashboard, item 62.\n\nThanks!"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982617_2874344399494289_5764883510462171197_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HZpiaqb44rQQ7kNvgGiTCzO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlr6oK5XTOwcrt1wjagXI-ZD-ZmMiozkWp2UQIcXImxg&oe=6763FBD5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "NaN Industry", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1626472537, "lastRevision": {"nodes": [{"id": "11