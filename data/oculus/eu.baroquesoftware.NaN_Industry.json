itor included\n* in-game workshop of published puzzles made by others\n\nThis game puts emphasis on the freedom of placement one gets from VR: there is no gravity; blocks can be moved and rotated along any axis and float along under their own inertia.", "short_description": "Build a \"factory\" by putting blocks in space which will push, rotate, weld, etc. the products"}]}, "developer_name": "Armin Rigo", "developer_privacy_policy_url": "https://baroquesoftware.com/nan-industry/", "developer_terms_of_service_url": null, "publisher_name": "Baroque Software", "support_website_url": null, "website_url": "https://baroquesoftware.com/nan-industry/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "465571575096919"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "979529176182955"}]}, "baseline_offer": {"id": "979529176182955"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1626472500, "status": "PUBLISHED", "id": "979529176182955"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7873641832703644", "version": "1.2.2"}, "id": "224410712448001", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_