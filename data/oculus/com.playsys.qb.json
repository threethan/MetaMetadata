03", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162739_1046753842064818_2125503902_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dtPNepcJp0AQ7kNvgEoZc0i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCY4GPBdHN-BFJ_1pMYNWCNyBUF74gA3DWCfzkkQgkmhQ&oe=677D241E"}, {"file_name": "migrated_image.png", "id": "519702718734221", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12138792_1002280733153603_1016572639_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qguOY0y4NpwQ7kNvgHdQ6V7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOZZPZ1IyX66vUs8enq6-yJM25z3_BvFdAHlyvzXdghQ&oe=677D1119"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "qb", "keywords": ["shooter", "3d", "puzzle", "firstperson", "railshooter"], "long_description": "qb is an exciting Virtual Reality gaming experience. The goal of the game is to activate Defected Code Streamer Modules by throwing Data Cubes in them. The game has a built-in Store where you can spend your points to unlock upgrades and pass increasingly difficult levels. Twelve levels are currently available and many level packs will be released on every new update.", "short_description": "Help the Code Streamer Processor Unit to fix its own Defected Code Streamer Modules using the provided Data Cubes aka qb, in this exciting first person minimalistic railshooter."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.qb-game.com/healthfirst.html", "developer_terms_of_service_url": "http://www.play-sys.com/privacy-policy.html", "publisher_name": "PlaySys", "support_website_url": null, "website_url": "http://www.qb-game.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "PUZZLE", "SHOOTER", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recom