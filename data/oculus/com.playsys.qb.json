3d puzzle game for Gear VR.\nWander through hi-tech environment and practice your precision and strategic thinking. Spend your points to unlock upgrades in the built-in store."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.play-sys.com/terms/#privacy_policy", "developer_terms_of_service_url": "http://www.play-sys.com/privacy-policy.html", "publisher_name": "PlaySys", "support_website_url": null, "website_url": "http://www.qb-game.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "PUZZLE", "SHOOTER", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "370765004763114"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/11162800_1562219544085142_1485204530_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hMy72_3FMJIQ7kNvgGY3Opr&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBuAY_vXfBVfp7k5PU_JTQYU8AS5f6ifjMtAyViLdpwqA&oe=6710EE75"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "qb", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1465369200, "lastRevision": {"nodes": [{"id": "1198783690133017", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "992805010809326", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null,