ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOKWijTKOayDDjRZ-sX0bpFMVE4EYeT5coOGvj0ki7vA&oe=670A5470"}, {"file_name": "migrated_image.png", "id": "138745274220646", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12139355_157370078058723_6298003321160466432_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wfAnMAmf60sQ7kNvgFYaA7W&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo0d1sruaUYZbxXJa-E51Lz20H4srlP2xr4D4B2qp_dQ&oe=670A6D65"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "qb_video_thumbnail.png", "id": "1673636789604214", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12602290_1673636792937547_6272712586626596864_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aa-eg_6NJfcQ7kNvgHaIxB0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-9NrT8llP7mIhkmS5YemZGiAifU48VSCNMNjshesu9A&oe=670A4B72"}, "display_name": "qb", "keywords": ["puzzle", "3d", "firstperson", "shooter", "railshooter"], "long_description": "GAMEPLAY\nWe developed this game with a pretty simple idea in mind: you throw colored cubes in colored boxes. That's it.\nIs that's so easy, you may ask, well, try it yourself and let us know ;) \n\nENVIRONMENTS\nCreated entirely in 3D computer graphic, qb will transport you in a desolate world ruled by machines.\n\nSTORE\nGot stuck in a level? Visit the integrated store where you can exchange your game points with power-ups. No in-app purchase or real-money requested.\n\nDISCLAIMER\nPlease note that qb is a pure puzzle game for those who like this genere. We designed levels to provide a consistently growing difficulty enriching the traditional puzzle experience using virtual reality technology. If you don't like puzzle challenges then this game may not be for you.\n\nFREE UPDATES\nWith the 2nd update we expanded the game up to 25 levels including two special boss levels with unique gameplay.\nSuggestions or requests? Write us, we're here to develop and expand the world of qb!", "short_description": "qb is a virtual reality 3d puzzle game for Gear VR.\nWander through hi-tech environment and practice your precision and strategic thinking. Spend your points to unlock upgrades in the built-in store."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.play-sys.com/terms/#privacy_policy", "developer_terms_of_service_url": "http://www.play-sys.com/privacy-policy.html", "publisher_name": "PlaySys", "support_website_url": null, "website_url": "http://www.qb-game.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "PUZZLE", "SHOOTER", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "370765004763114"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162800_1562219544085142_1485204530_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7FeRJAwXjUQ7kNvgGBSptZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBMwyhGYxSdBzukQZ2DclTm4Xy_5MqLmB0fyPc1slG4AQ&oe=670A56F5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "qb", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1465369200, "lastRevision": {"nodes": [{"id": "1198783690133017", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "992805010809326", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null,