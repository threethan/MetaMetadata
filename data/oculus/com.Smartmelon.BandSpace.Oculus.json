24140057_6027504179398790082_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P5LczYD_ZeQQ7kNvgHdJ4AP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkRhi0sHhMp2nQ5aABVMWbt&oh=00_AYBDbvpliivTQh38ln5soBa_MGsH8qpKQJadMxlbGH3FeA&oe=66E047FE"}, "display_name": "Band Space", "keywords": [], "long_description": "Team up your band in VR world!Standing in 4 different stage scenes in unique styles and playing 4iconic band instruments with your friends.\n\nForestall to experience the following content in our free demo:\n1-There are 3 different rock songs available for performing and enjoying the immersive doomsday game scene.\n2-There are 4 iconic band instruments with unique feeling and experience.You can choose from: Drum set, Keyboard, Bass, and Guitar. \n3-Every song in our game has an independent concert style lighting show.\n4-You can create a custom playable song from any song you own, and the system will automatically generate matching light effects.(Join our discord server for beatmap)\n\nPlease receive this demo version as an appetizer and an invitation to our full version in the future.\n1-You can team up your band with friends in multiplayer function. Also, you can choose random matches to meet awesome new friends!\n2-4 different performing stage scenes in unique styles: Cyber\\Doomsday\\Moon\\Desert.\n3- 4 instruments support more than 40 songs, that are mainly Rock, but also include Pop, R&B, Soul, Funk, EDM, Jazz, and Hip-hop!Every song in our game has an independent concert style lighting show.\n4-Very generous to beginners,Also very strict to the strongest players~Let's climb to the top on global leaderboards!\n5-Different personalized settings will perfectly meet players' needs.\n\nhttps://discord.com/invite/HWbeUGfVpD\nJoin our discord and experience more content of Band Space.", "short_description": "Team Up Your Band In VR World!!Standing in 4 different stage scenes in unique styles and playing 4iconic band instruments with your friends.Let's become a shining rock band!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://thesmartmelon.com/privacy_en", "developer_terms_of_service_url": null, "publisher_name": "Smartmelon Games", "support_website_url": null, "website_url": "https://www.thesmartmelon.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "168126316071558"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "583797930442271"}]}, "baseline_offer": {"id": "583797930442271"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1682352000, "status": "PUBLISHED", "id": "583797930442271"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8043514559069376", "version": "1.0.12"}, "id": "2961702000788143", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5207196326034561", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8043514559069376"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2961702000788143"}]}, "change_log": null, "created_date": 1724756883, "id": "8043514559069376", "version": "1.0.12", "version_code": 40, "release_