0015233050_3498839772360652388_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UPtQcg54rgkQ7kNvgGQZfNe&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB1a32MXiKfLtmoVDcWOy3MXSRZPn01YKn4LMyFTAK1vg&oe=67012D38"}, {"file_name": "4.png", "id": "640005857872115", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036608_640005861205448_8933428041676451513_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Zl8yn18hKYQ7kNvgHoAszb&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAkFQRGO9ETviu1qxLsBmwd0iHNN8Jo6MUkJitI71l3Rw&oe=67010EAE"}, {"file_name": "2.png", "id": "496771272520484", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982492_496771275853817_1096444124134850214_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XSrFxkBU168Q7kNvgErOQtF&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDkyUANvLoVABUr5kqzmuVeDBTVpSIkGPju_DnnPbV23Q&oe=670129F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape2560x1440.png", "id": "4958963820806724", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001702_4958963824140057_6027504179398790082_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eGwfvW-NlMQQ7kNvgGFnhC5&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYADPkIaQYJeRV13P4Wc4F0R1MeFDLcORgI1K41pkml5TA&oe=67013D7E"}, "display_name": "Band Space", "keywords": [], "long_description": "Team up your band in VR world!Standing in 4 different stage scenes in unique styles and playing 4iconic band instruments with your friends.\n\nForestall to experience the following content in our free demo:\n1-There are 3 different rock songs available for performing and enjoying the immersive doomsday game scene.\n2-There are 4 iconic band instruments with unique feeling and experience.You can choose from: Drum set, Keyboard, Bass, and Guitar. \n3-Every song in our game has an independent concert style lighting show.\n4-You can create a custom playable song from any song you own, and the system will automatically generate matching light effects.(Join our discord server for beatmap)\n\nPlease receive this demo version as an appetizer and an invitation to our full version in the future.\n1-You can team up your band with friends in multiplayer function. Also, you can choose random matches to meet awesome new friends!\n2-4 different performing stage scenes in unique styles: Cyber\\Doomsday\\Moon\\Desert.\n3- 4 instruments support more than 40 songs, that are mainly Rock, but also include Pop, R&B, Soul, Funk, EDM, Jazz, and Hip-hop!Every song in our game has an independent concert style lighting show.\n4-Very generous to beginners,Also very strict to the strongest players~Let's climb to the top on global leaderboards!\n5-Different personalized settings will perfectly meet players' needs.\n\nhttps://discord.com/invite/HWbeUGfVpD\nJoin our discord and experience more content of Band Space.", "short_description": "Team Up Your Band In VR World!!Standing in 4 different stage scenes in unique styles and playing 4iconic band instruments with your friends.Let's become a shining rock band!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://thesmartmelon.com/privacy_en", "developer_terms_of_service_url": null, "publisher_name": "Smartmelon Games", "support_website_url": null, "website_url": "https://www.thesmartmelon.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "168126316071558"}}]}, "scheduled_