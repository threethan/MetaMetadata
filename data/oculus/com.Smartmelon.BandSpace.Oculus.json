1-7&_nc_sid=6e7a0a&_nc_ohc=hdqOryON0LgQ7kNvgH6MXZ1&_nc_ht=scontent.oculuscdn.com&oh=00_AYATmo_ve_XSZh-Idyo1HhLone3VpEZG4HqPSGBCONrKbg&oe=66CB1C78"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape2560x1440.png", "id": "4958963820806724", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001702_4958963824140057_6027504179398790082_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZlqvEpg5DMQ7kNvgGQNOuo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCT-bMGmIBZ7I5TFB_-20KGn5o4WRwwR5J_aN_-Ovokaw&oe=66CB2FFE"}, "display_name": "Band Space", "keywords": [], "long_description": "Team up your band in VR world!Standing in 4 different stage scenes in unique styles and playing 4iconic band instruments with your friends.\n\nForestall to experience the following content in our free demo:\n1-There are 3 different rock songs available for performing and enjoying the immersive doomsday game scene.\n2-There are 4 iconic band instruments with unique feeling and experience.You can choose from: Drum set, Keyboard, Bass, and Guitar. \n3-Every song in our game has an independent concert style lighting show.\n4-You can create a custom playable song from any song you own, and the system will automatically generate matching light effects.(Join our discord server for beatmap)\n\nPlease receive this demo version as an appetizer and an invitation to our full version in the future.\n1-You can team up your band with friends in multiplayer function. Also, you can choose random matches to meet awesome new friends!\n2-4 different performing stage scenes in unique styles: Cyber\\Doomsday\\Moon\\Desert.\n3- 4 instruments support more than 40 songs, that are mainly Rock, but also include Pop, R&B, Soul, Funk, EDM, Jazz, and Hip-hop!Every song in our game has an independent concert style lighting show.\n4-Very generous to beginners,Also very strict to the strongest players~Let's climb to the top on global leaderboards!\n5-Different personalized settings will perfectly meet playe