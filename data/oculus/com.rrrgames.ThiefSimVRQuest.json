9u6I08S4-0Q7kNvgEDMA7l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-xLitSP6qWu4jV0mxa9zQT3uYEOVmbJbDQ1jtRy7fdQ&oe=67432216"}, {"file_name": "Screen3_Cara.png", "id": "539974654359966", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299156_539974657693299_8049250315888172614_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=glDB52lVDlQQ7kNvgFmyXI4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcbxwnf1iF8WVVcydstPZueLPbLXk65n629DBF-ZO3kg&oe=6742FD1D"}, {"file_name": "Screen5_Hideout.png", "id": "1044945933092013", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035432_1044945936425346_9014952971388798693_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pqq5FcrZlgMQ7kNvgF-eSnT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVQPFwlqWsSRjqjcGJDVFOA4avLtQV-AMkikalu4SfvA&oe=674301DB"}, {"file_name": "Screen4_HideoutShopping.png", "id": "5148966528526494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035386_5148966535193160_7611337817706902432_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BONnH-uxJm8Q7kNvgFdnB_m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRU4tAWgjvhdj04YTwq7gjwCTrw-_9zgdDVlo6_p9MIg&oe=67431B05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "2177900065711303", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003244_2177900072377969_7787554301833328181_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2iqyFyg3-YgQ7kNvgEyad9B&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAF66_itjd51pmXWHKiv1n5DLL0DgEqrtLA5Nelq920yQ&oe=6742F553"}, "display_name": "Thief Simulator VR - Greenview Street", "keywords": ["stealth", "sandbox", "exploration", "tactical", "adventure"], "long_description": "Have you ever wondered what it's like to be a real thief? Now you can see for yourself in Thief Simulator VR - an immersive experience of being a minor burglar - without any unnecessary violence.  \n\nSteal in free roam sandbox neighborhoods. Observe your target and gather information that will help you with the burglary. Take the challenge and rob the best secured houses. Buy some hi-tech burglar equipment and learn new thief tricks. Sell stolen goods to the passers. Do anything that a real thief does. And\u2026 don\u2019t get caught!\n\nA good thief always observes his target. What's inside? Who lives there? What's your target day schedule? Find out when the house is empty and if there are any nosy neighbors. Choose from lots of possible approaches and tools to prepare the best plan and execute it without drawing attention. ", "short_description": "Become a thief in VR! Feel the thrill of stealing in free roam sandbox neighborhoods. Use lockpicks and hi-tech hacking tools. Observe your target, gather information and hide from police. Or drive a car like crazy to get out of trouble!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://3r.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "3R Games", "support_website_url": null, "website_url": "https://3r.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "EXPLORATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pl", "fr", "de", "es", "it", "pt", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3046443412272537"}}]}, "scheduled_offers": {"count": 36, "nodes": [{"status": "PUBLISHED", "id": "1334183437747288"}, {"sta