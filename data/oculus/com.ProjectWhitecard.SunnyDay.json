 fun). ", "short_description": "DoVille Adventures has launched! Here's one you can hand to Granny with your (old) Oculus Go. Designed by a team that includes older, nostalgic adults, it's your vacation dream come true! Episode One, Juniper Beach, is a low poly BEACH adventure. Thrill to easy-to-use activities; catch the mysterious art thief and save the beach, or simply stretch out for an extended stay in the warm, warm sun."}]}, "developer_name": "Project Whitecard Digital Inc.", "developer_privacy_policy_url": "https://projectwhitecard.com/pwc/pwcmont/privacy-policy", "developer_terms_of_service_url": "https://projectwhitecard.com/pwc/pwcmont/terms-of-service", "publisher_name": "Project Whitecard Digital Inc.", "support_website_url": "https://adventures.doville.fun/", "website_url": "https://adventures.doville.fun/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EXPLORATION", "NARRATIVE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "611266023291245"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982441_135721588095305_6049224103761509062_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Kc_Ar7mlk4Q7kNvgEDb64s&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCnsGauMj9J-R0CECjlsnc0FY3YGVo_emJLMoXoxbxIew&oe=6724B73E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DoVille Adventures", "platform": "ANDROID", "context_category":