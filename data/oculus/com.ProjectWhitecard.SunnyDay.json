name": "DoVille", "keywords": [], "long_description": "DoVille is in Early Access.\n\nDoVille Episode 1: Juniper Beach, is here.\nDesigned by a team that includes older, nostalgic adults, DoVille is your VR vacation dream come true.\n\nIncluded in the first download is Juniper Beach, a low poly BEACH and sleuthing adventure. Thrill to easy-to-use activities; catch the mysterious art thief and save the beach, or simply stretch out for an extended stay in the warm, warm sun. Take a dip, water ski, or ride the hot-air balloon. \n\nMore episodes are on the way!\nFor more information (and even a report on the positive brain effects, visit doville dot fun). ", "short_description": "DoVille is in Early Access.\n\nDoVille Episode 1: Juniper Beach, is here.\nHere's one you can hand to Granny. Designed by a team that includes older, nostalgic adults, DoVille is your VR vacation dream come true.\n\nIncluded in the first download is Juniper Beach, a low poly BEACH and sleuthing adventure. Thrill to easy-to-use activities; catch the mysterious art thief and save the beach, or simply stretch out for an extended stay in the warm, warm sun. \n\nMore episodes are on the way!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://projectwhitecard.com/pwc/pwcmont/privacy-policy", "developer_terms_of_service_url": "https://projectwhitecard.com/pwc/pwcmont/terms-of-service", "publisher_name": "Project Whitecard Digital Inc.", "support_website_url": "https://adventures.doville.fun/", "website_url": "https://adventures.doville.fun/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ART_CREATIVITY", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_