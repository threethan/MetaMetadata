-iad3-2.oculuscdn.com/v/t64.5771-25/39031438_334598701176881_3091143531464059294_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7IF0xB_vLzwQ7kNvgHGqxKe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCflpQafFiZJg0WaoTluXdHYQuJVuUOXb8gRTipqLMrQQ&oe=676568B3"}, {"file_name": "04_JB_QuestShot.png", "id": "300634451630748", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974513_300634454964081_6851502154246735907_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3HQVpS4jkYQ7kNvgGwCAwj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAg6Ok4s1lLpaYDvoJpJPv8DKIB-V5NleU1eREKFj4KPA&oe=67657126"}, {"file_name": "03_JB_QuestShot.png", "id": "208044811018927", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210887_208044814352260_8555260937360815470_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PcisVMPHJRoQ7kNvgGaT4uX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsAZoiUtdFwqCPlojU8xReRxw9CO7AQZ17C7ENKRdwhw&oe=67655DEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DoVille Trailer Thumb 1440.png", "id": "755854905248627", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_755854908581960_2515936280676052565_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L87EuzsV410Q7kNvgGYaheM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxgbpihGlAhROLFp5OuV_mLcp9fjG9me5SF7zzfM48Gw&oe=67654822"}, "display_name": "DoVille", "keywords": [], "long_description": "DoVille is in Early Access.\n\nDoVille Episode 1: Juniper Beach, is here.\nDesigned by a team that includes older, nostalgic adults, DoVille is your VR vacation dream come true.\n\nIncluded in the first download is Juniper Beach, a low poly BEACH and sleuthing adventure. Thrill to easy-to-use activities; catch the mysterious art thief and save the beach, or simply stretch out for an extended stay in the warm, warm sun. Take a dip, water ski, or ride the hot-air balloon. \n\nMore episodes are on the way!\nFor more information (and even a report on the positive brain effects, visit doville dot fun). ", "short_description": "DoVille is in Early Access.\n\nDoVille Episode 1: Juniper Beach, is here.\nHere's one you can hand to Granny. Designed by a team that includes older, nostalgic adults, DoVille is your VR vacation dream come true.\n\nIncluded in the first download is Juniper Beach, a low poly BEACH and sleuthing adventure. Thrill to easy-to-use activities; catch the mysterious art thief and save the beach, or simply stretch out for an extended stay in the warm, warm sun. \n\nMore episodes are on the way!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://projectwhitecard.com/pwc/pwcmont/privacy-policy", "developer_terms_of_service_url": "https://projectwhitecard.com/pwc/pwcmont/terms-of-service", "publisher_name": "Project Whitecard Digital Inc.", "support_website_url": "https://adventures.doville.fun/", "website_url": "https://adventures.doville.fun/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ART_CREATIVITY", "RELAXATION_MEDITATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "462891615464677"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974635_1406745633057163_740540960698515865_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bhUOGhSrtjAQ7kNvgGtrRa1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=