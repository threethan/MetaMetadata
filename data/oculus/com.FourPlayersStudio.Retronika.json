com&oh=00_AYDPXxmmpF7S_rNISpJ3QVpSDfrRJ91jkgnJD450kClU1w&oe=670272E6"}, {"file_name": "Screen_6_Boss.png", "id": "993535671801293", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031370_993535675134626_6528253582307461366_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=goJGdD9-UBkQ7kNvgGoxLRa&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDAQXVwhGwROlhffJqrXgi5d9-9IcmuwIMWLju1ajBrNg&oe=670263C4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Render Raw v2.png", "id": "419794194156495", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974507_419794197489828_2951621016193546620_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tStpCNpKSr4Q7kNvgGSHNli&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDK11FnCucedEIHkgXBfAC73uUYwigaH54QL7FeSOFcCw&oe=67028CEE"}, "display_name": "Retronika", "keywords": [], "long_description": "Dive into the Retro-Futuristic World of Retronika!\n\nExperience the ultimate fusion of high-speed racing and dynamic combat in Retronika. This story-driven single-player game lets you navigate vibrant cityscapes on your flying bike, facing thrilling challenges that push your skills to the limit.\n\n\nSeamless Racing and Intense Shooting:\n\nControl your bike with unique, intuitive handlebar mechanics for smooth 3D movement. Glide through the skies, dodge obstacles, and outmaneuver enemies with ease. Engage in dynamic battles against enemy drones and weaponized vehicles. Combine weapons for strategic combat and adapt to various scenarios, enhancing your gameplay experience.\n\n\nJoin the Community:\n\nBecome part of the Retronika community and share your experiences with fellow players. Compete on leaderboards, participate in events, and stay updated with the latest game developments. Dive into Retronika on Meta Quest and join a world filled with action and excitement. Get Retronika now and begin your adventure!\n\nDiscord Community:   https://discord.gg/krw4PnkXeT\nReddit:                           https://www.reddit.com/r/RetronikaOfficial/\nTwitter (X):                    https://twitter.com/Retronika2024\n ", "short_description": "Dive into the retrofuturistic world of Retronika, where high-speed flying bikes and dynamic combat collide. Navigate vibrant cityscapes, engage enemy drones, and complete challenging missions. Master the intuitive handlebar controls for seamless 3D movement and strategic shooting. Combine weapons for varied combat strategies. Experience the adrenaline-pumping thrill of Retronika, offering an unparalleled VR adventure on Meta Quest. Race and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.4players-studio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "4Players-Studio", "support_website_url": "https://www.4players-studio.com/contact#contact-message", "website_url": "https://www.4players-studio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "673385183287495"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26079740828341020"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1247343209768424"}, {"status": "PUBLISHED", "id": "969267781668567"}, {"status": "PUBLISHED", "id": "1261477975195211"}]}, "baseline_offer": {"id": "1247343209768424"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725757740, "status": "PUBLISHED", "id": "1247343209768424"}]}, "l