fg-upaQQ7kNvgF9M3BK&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYA26_4hkz44_TyjGJ-d_NO2WTRPM_JXoW_wMk_t3Ji68g&oe=67027652"}, {"file_name": "Screen_4_NightFight.png", "id": "1332643327652314", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75210395_1332643330985647_5148647757128195697_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bv6Ld0ZIyQkQ7kNvgH_0Zas&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDFlmmK2t5irr8lXcRF6a-Q_fCIMqE1KsNyCw8IPdtjXg&oe=67028938"}, {"file_name": "Screen_3_DayFight.png", "id": "436411449143524", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031441_436411452476857_6912955252871556053_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JED-Hvn9UcEQ7kNvgHHIaHr&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDPXxmmpF7S_rNISpJ3QVpSDfrRJ91jkgnJD450kClU1w&oe=670272E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "16x9_Landscape V2.png", "id": "358377297324632", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75429289_358377300657965_6764556560672600057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BMISXt8Vu3QQ7kNvgGiOjPi&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDM41ODhArwWTRuEZR_4KmgbsKdjryJ0jzs2k0khGBmcA&oe=6702737C"}, "display_name": "Retronika", "keywords": ["bike", "racing", "singleplayer", "fly", "shooter"], "long_description": "# Retronika! Now in Early Access!\n\n\n**Fly Fast. Fight Hard.**\n\nWelcome to **Retronika**, where speed and combat merge. Fly through vibrant cityscapes on your bike, overcoming thrilling challenges that push your limits in a story-driven single-player adventure.\n\n\n1. **Seamless Control. Total Freedom.** \u2b06\ufe0f\u2b07\ufe0f\u2b05\ufe0f\u27a1\ufe0f\nTake command with intuitive handlebar mechanics for effortless movement in all three axes. \n{496307063009337}\n\n2. **Unique Arsenal. Fierce Combat.** \u2620\ufe0f\u2694\ufe0f\u2620\ufe0f\nEngage in high-speed battles, taking down drones and enemy vehicles as you race ahead.\n{2149126378814047}\n\n3. **Upgrade. Customize. Dominate.** \ud83d\udd27\ud83c\udfa8\ud83d\udca5\nTransform your hoverbike with powerful upgrades and personalized customizations to enhance performance and style.\n{506856348701488}\n\n4. **Unravel the Mystery.** \ud83c\udf0d\u2753\ud83d\udcd6\nExplore Planet Retronika, where a once-friendly world turns hostile. Uncover the truth as you race to escape.\n{1038876124632578}\n\n\n# Join the Retronika Community! \ud83e\udd1d\ud83d\udce2\ud83c\udfc6\nConnect with fellow players, compete on leaderboards, and stay in the loop with the latest updates. Dive into the action on Meta Quest and start your adventure today. \n\n- Discord Community:    https://discord.gg/krw4PnkXeT\n- Reddit:    https://www.reddit.com/r/RetronikaOfficial/\n- Twitter (X):    https://twitter.com/Retronika2024", "short_description": "Dive into the retrofuturistic world of Retronika, where high-speed flying bikes and dynamic combat collide. Navigate vibrant cityscapes, engage enemy drones, and complete challenging missions. Master the intuitive handlebar controls for seamless 3D movement and strategic shooting. Combine weapons for varied combat strategies. Experience the adrenaline-pumping thrill of Retronika, offering an unparalleled VR adventure on Meta Quest. Race and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.4players-studio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "4Players-Studio", "support_website_url": "https://www.4players-studio.com/contact#contact-message", "website_url": "https://www.4players-studio.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "673385183287495"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_ar