", "safari", "marine"], "long_description": "Welcome to the Mixed Reality Museum, powered by Halo AR!\n\nOur virtual galleries are filled with an ever-expanding library of rich spatial 3D exhibits! Bring the best museum exhibits right into your home or classroom in all their stunning 3D lifelike glory, no school bus or field trip needed.\n\nLearn about real animals and scientific facts in the most realistic environment possible, the real world! Pick your learning experience, and then watch as nature\u2019s most dangerous, endangered, and incredible animals appear in front of you, along with educational narration and videos so you can learn all about them.\n\nExplore featured exhibits, including the fearsome hammerhead shark swimming right in your room, and thousands more made by Halo AR creators from 200+ countries around the world.\n\nBe one of the first visitors to the Mixed Reality Museum during our early access period, completely free of charge.\n", "short_description": "Welcome to the Mixed Reality Museum, powered by Halo AR!\n\nOur virtual galleries are filled with an ever-expanding library of rich spatial 3D exhibits! Bring the best museum exhibits right into your home or classroom in all their stunning 3D lifelike glory, no school bus or field trip needed.\n\nLearn about real animals and scientific facts in the most realistic environment possible, the real world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://haloar.app/privacy", "developer_terms_of_service_url": "https://haloar.app/terms", "publisher_name": "LightUp, Inc.", "support_website_url": null, "website_url": "https://haloar.app/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "r