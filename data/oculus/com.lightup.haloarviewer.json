scdn.com&oh=00_AYCzqU4dcuXHy-s9J_yLuxwzY3_OTItRphEuRVP7nGEOWA&oe=67826DC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover (2560 x 1440).png", "id": "1076557090635014", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974857_1076557093968347_6620815350005885108_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xBp_lVRPZQUQ7kNvgGRh4p7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAC-RpSjZpkxOOgOYicCMK9p-uTpMHUh85e-pXNFTqizg&oe=67826150"}, "display_name": "Mixed Reality Museum | By Halo AR - Educational learning exhibits w/ AI teaching", "keywords": ["augmented", "animals", "zoo", "safari", "marine"], "long_description": "Welcome to the Mixed Reality Museum, powered by Halo AR!\n\nOur virtual galleries are filled with an ever-expanding library of rich spatial 3D exhibits! Bring the best museum exhibits right into your home or classroom in all their stunning 3D lifelike glory, no school bus or admission ticket needed.\n\nLearn about real animals and scientific facts in the most realistic environment possible, the real world! Pick your learning experience, and then watch as nature\u2019s most dangerous, endangered, and incredible animals appear in front of you, along with educational narration and videos so you can learn all about them.\n\nExplore featured exhibits, including the fearsome hammerhead shark swimming right in your room, and thousands more made by Halo AR creators from 200+ countries around the world.\n\nBe one of the first visitors to the Mixed Reality Museum during our early access period, completely free of charge.\n", "short_description": "Welcome to the Mixed Reality Museum, powered by Halo AR!\n\nOur virtual galleries are filled with an ever-expanding library of rich spatial 3D exhibits! Bring the best museum exhibits right into your home or classroom in all their stunning 3D lifelike glory, no school bus or admission ticket needed.\n\nLearn about real animals and scientific facts in the most realistic environment possible, the real world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://haloar.app/privacy", "developer_terms_of_service_url": "https://haloar.app/terms", "publisher_name": "LightUp, Inc.", "support_website_url": null, "website_url": "https://haloar.app/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "726368587961803"}, {"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8742892315780580"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982608_2024013781366349_87821873123878882_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wJV0JarcoSMQ7kNvgH6clpe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBN3DU12NvCnyEyd5JOcu3ABiUdQzdUsHqaRZr7fUMQ1A&oe=678246E9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mixed Reality Museum | By Halo AR - Educational learning exhibits w/ AI teaching", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}, {"topic_name": "Travel & Exploration", "id": "726368587961803"}, {"topic_name": "Media", "id": "434961926215971"}], "release_date": 1727797920, "lastRevision": {"nodes": [{"id": "7560230770713413", "release_type": "SCHEDULED", "administra