_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PRy_7XGdA2UQ7kNvgF95Ine&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCDNdTxm6SzuWWeInQvyzn1mrLIOH3qIL6TQxVHjID_9Q&oe=672A0DA1"}, "display_name": "Gudauri Ski Resort", "keywords": ["winter", "georgia", "travel", "tourism", "paragliding"], "long_description": "With this app you will be able to explore one of the most popular winter destinations Georgia, Gudauri. \nGudauri offers tourists 20 ski slopes with total length of 70 km provide perfect skiing and snowboarding conditions. Gudauri is famous for its off-piste opportunities down the unspoiled virgin slopes and heliskiing options.\nYou can also experience thrill of flying with paragliding activities shown in the app. \n\n\"Georgia Ski Resorts\" app was created and published by VRex Immersive. Our mission is to help travelers worldwide explore destinations and tourism activities in VR.", "short_description": "Explore diverse and exciting Georgian ski resort Gudauri with this interactive VR experience!\nExperience skiing, paragliding, snowmobile rides and breathtaking views of the Caucasus mountains. \nLearn more about the resort and its services while having fun on the slopes of Gudauri."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.vrexbox.com/", "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": null, "website_url": "http://vreximmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_t