E78BF"}, {"file_name": "Bbn5Aa.png", "id": "593223691537556", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035318_593223694870889_6964722669455409152_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2GolrKpf0y8Q7kNvgFE8tt3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLfhLQyGgod_lBPcG4MI1sCur5A6sM_ZfcZqV0m8UgDg&oe=66FE8A3E"}, {"file_name": "GkYATK.png", "id": "553551711932417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269158_553551715265750_6370006579567132672_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AL_IldMx26AQ7kNvgGZ88GB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDc3_RGrCkZ_MFngBuOr5ol-Xjkn0FxiU0p04sYMTzBrQ&oe=66FE9723"}, {"file_name": "4Tdwsp.png", "id": "199414998005836", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982553_199415001339169_876897034668343296_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ApV6CAJ5pYQ7kNvgEL8ifF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKXPiwXDBIs6t2DsFqTfkRxikD3LOgBqt7QOD659RyrQ&oe=66FE8CF6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/r72Ras", "id": "255254845480546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254876_255254848813879_8167350629442781184_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cxTb7rwIK7AQ7kNvgFsi0qY&_nc_ht=scontent.oculuscdn.com&oh=00_AYABp6cF4lJFvtCQj0DjnGpfeKteLhlAgqBZil3oWUQxTg&oe=66FE8C21"}, "display_name": "Gudauri Ski Resort", "keywords": ["winter", "georgia", "travel", "tourism", "paragliding"], "long_description": "With this app you will be able to explore one of the most popular winter destinations Georgia, Gudauri. \nGudauri offers tourists 20 ski slopes with total length of 70 km provide perfect skiing and snowboarding conditions. Gudauri is famous for its off-piste opportunities down the unspoiled virgin slopes and heliskiing options.\nYou can also experience thrill of flying with paragliding activities shown in the app. \n\n\"Georgia Ski Resorts\" app was created and published by VRex Immersive. Our mission is to help travelers worldwide explore destinations and tourism activities in VR.", "short_description": "Explore diverse and exciting Georgian ski resort Gudauri with this interactive VR experience!\nExperience skiing, paragliding, snowmobile rides and breathtaking views of the Caucasus mountains. \nLearn more about the resort and its services while having fun on the slopes of Gudauri."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": "http://vreximmersive.com/", "website_url": "http://vreximmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441519761089747"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1161005834251194"}]}, "baseline_offer": {"id": "1161005834251194"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1587142845, "status": "PUBLISHED", "id": "1161005834251194"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2752570481445348", "version": "1.03"}, "id": "889265818184420", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2745449288824134", "is_concept": false, "latest_released_binary"