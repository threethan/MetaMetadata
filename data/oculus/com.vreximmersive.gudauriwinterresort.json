p travelers worldwide explore destinations and tourism activities in VR.", "short_description": "Explore diverse and exciting Georgian ski resort Gudauri with this interactive VR experience!\nExperience skiing, paragliding, snowmobile rides and breathtaking views of the Caucasus mountains. \nLearn more about the resort and its services while having fun on the slopes of Gudauri."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": "http://vreximmersive.com/", "website_url": "http://vreximmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "441519761089747"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1161005834251194"}]}, "baseline_offer": {"id": "1161005834251194"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1587142845, "status": "PUBLISHED", "id": "1161005834251194"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2752570481445348", "version": "1.03"}, "id": "889265818184420", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2745449288824134", "is_concept": false, "latest_released_b