": "6864855510206242", "locale": "en_US", "screenshots": [{"file_name": "0VrDqm.png", "id": "2531887983582493", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974518_2531887986915826_1721705728718143488_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0RYPUZo8hlkQ7kNvgGdSP5V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_zCcnH9zZ1ItE-1BdJwMLgjXw5P2uWfrUWLmO1Sa-JA&oe=6731E0F5"}, {"file_name": "834Uyi.png", "id": "879017019194369", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75251818_879017022527702_6553676487998832640_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ytZKyjN8OIQQ7kNvgEg-lcJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCNkd1yiv-um0ssvOsnxuEqOdHP71TUlOUpt3JrKjEYg&oe=6731E33F"}, {"file_name": "Bbn5Aa.png", "id": "593223691537556", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035318_593223694870889_6964722669455409152_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6IFtXtmPYOkQ7kNvgFT52nZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFVBpv7749kk7FAhn2e8p2g7BY6QDas80e-WfyHERkvA&oe=6731F4BE"}, {"file_name": "GkYATK.png", "id": "553551711932417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269158_553551715265750_6370006579567132672_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xvH0oREE3QEQ7kNvgFJEs4C&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-dPOjPZmOgcfwDXzztXnfx2dkFQMg85ZEeCU3HfQgag&oe=673201A3"}, {"file_name": "4Tdwsp.png", "id": "199414998005836", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982553_199415001339169_876897034668343296_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p4ZPYBycU2IQ7kNvgFS8R_E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7uGdz-CgIMjiM-kcTNLzEVgc8wr9X41veX6BHbZJvgw&oe=6731F776"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/r72Ras", "id": "255254845480546", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254876_255254848813879_8167350629442781184_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1HsSxR9EVYIQ7kNvgELXERz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoYIwJ0YTPPm3jdDmYk65RIboTnwI5ad_JMEXKWcPmAg&oe=6731F6A1"}, "display_name": "Gudauri Ski Resort", "keywords": ["winter", "georgia", "travel", "tourism", "paragliding"], "long_description": "With this app you will be able to explore one of the most popular winter destinations Georgia, Gudauri. \nGudauri offers tourists 20 ski slopes with total length of 70 km provide perfect skiing and snowboarding conditions. Gudauri is famous for its off-piste opportunities down the unspoiled virgin slopes and heliskiing options.\nYou can also experience thrill of flying with paragliding activities shown in the app. \n\n\"Georgia Ski Resorts\" app was created and published by VRex Immersive. Our mission is to help travelers worldwide explore destinations and tourism activities in VR.", "short_description": "Explore diverse and exciting Georgian ski resort Gudauri with this interactive VR experience!\nExperience skiing, paragliding, snowmobile rides and breathtaking views of the Caucasus mountains. \nLearn more about the resort and its services while having fun on the slopes of Gudauri."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.vrexbox.com/", "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": null, "website_url": "http://vreximmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_t