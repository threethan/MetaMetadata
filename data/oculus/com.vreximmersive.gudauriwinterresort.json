": {"file_name": "/tmp/r72Ras", "id": "255254845480546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254876_255254848813879_8167350629442781184_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ro3yuLt7yAAQ7kNvgFe29d2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgtsVIhtijt8S_nbT5QSl6R&oh=00_AYCyizrR7flzHXev59gl5gBnea4VTpzPU1lkEnL_lSTmhg&oe=66E57FA1"}, "display_name": "Gudauri Ski Resort", "keywords": ["winter", "georgia", "travel", "tourism", "paragliding"], "long_description": "With this app you will be able to explore one of the most popular winter destinations Georgia, Gudauri. \nGudauri offers tourists 20 ski slopes with total length of 70 km provide perfect skiing and snowboarding conditions. Gudauri is famous for its off-piste opportunities down the unspoiled virgin slopes and heliskiing options.\nYou can also experience thrill of flying with paragliding activities shown in the app. \n\n\"Georgia Ski Resorts\" app was created and published by VRex Immersive. Our mission is to help travelers worldwide explore destinations and tourism activities in VR.", "short_description": "Explore diverse and exciting Georgian ski resort Gudauri with this interactive VR experience!\nExperience skiing, paragliding, snowmobile rides and breathtaking views of the Caucasus mountains. \nLearn more about the resort and its services while having fun on the slopes of Gudauri."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.vrexbox.com/", "developer_terms_of_service_url": null, "publisher_name": "VRex Immersive Inc.", "support_website_url": null, "website_url": "http://vreximmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "TRAVEL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_mem