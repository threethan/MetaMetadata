542822_1365243870014603264_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J-_wKYBjhjIQ7kNvgF1DtlU&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae2kK9vuskkr7P19n3jQErJ&oh=00_AYBnA91Lxx176rRkAGeWE6ELhiPW9-kYVOUYgtUdfK_B1A&oe=66E41FFA"}, {"file_name": "migrated_image.png", "id": "211556259913740", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162823_1944864842402289_8090037043406569472_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sbG-DtwrpeIQ7kNvgGQhtLI&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae2kK9vuskkr7P19n3jQErJ&oh=00_AYDB-MDnM54yULzNE-snsfCHoFVlb8W8UYoX1gWmnBkXXQ&oe=66E42ADD"}, {"file_name": "migrated_image.png", "id": "206033647324000", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162801_267824533626791_2002752604563570688_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a6pmmH0gb2QQ7kNvgGLXarF&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae2kK9vuskkr7P19n3jQErJ&oh=00_AYCv5UMlcmf_rSzScBlZw21APIqlpeMZ1uX5bSa67eYxHw&oe=66E42329"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Agent Hawk", "keywords": ["Hidden", "Object", "Exploration", "Spy", "Mystery"], "long_description": "Join a secret international intelligence agency and help uncover a worldwide conspiracy as renowned Agent Hawk.\n\nImmersive Environments - Realistic and interactive locations.\nFreedom to Explore - Move around using a comfortable teleportation system.\nClassic Gameplay - The beloved hidden object gameplay from a whole new perspective.\nGreat Replayability - A different list of items every time you play.\nThrilling Atmosphere - Locations and music that transport you to an exciting world of intrigue and espionage.", "short_description": "Investigate locations around the world as an infiltrated agent and uncover hidden intel in this immersive and challenging VR hidden object game."}, {"images": {"nodes": []}, "id": "138497170920634", "locale": "pt_BR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Agent Hawk", "keywords": ["Explora\u00e7\u00e3o", "Espionagem", "Mist\u00e9rio", "Espi\u00e3o", "Suspense"], "long_description": "Fa\u00e7a parte de uma ag\u00eancia de intelig\u00eancia internacional e ajude a desvendar uma conspira\u00e7\u00e3o mundial como o renomado Agente Hawk.\n\nAMBIENTES IMERSIVOS - Locais realistas e interativos.\n\nLIBERDADE PARA EXPLORAR - Mova-se usando um confort\u00e1vel sistema de teleporte.\n\nGAMEPLAY CL\u00c1SSICO - A consagrada jogabilidade de objetos escondidos com uma nova perspectiva.\n\nJOGUE E REJOGUE - Uma lista de itens diferente toda vez que voc\u00ea joga.\n\nSUSPENSE - Ambiente e m\u00fasica que v\u00e3o te transportar para um emocionante mundo de intriga e espionagem.", "short_description": "Investigue locais ao redor do mundo como um agente infiltrado nesse imersivo e desafiador jogo de objetos escondidos em VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://pp.tappsgames.com.s3.amazonaws.com/GeneralPP.htm", "developer_terms_of_service_url": "http://tos.tappsgames.com.s3.amazonaws.com/GeneralTOS.htm", "publisher_name": "Tapps Games", "support_website_url": null, "website_url": "http://www.tappsgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pt_BR", "zh_CN"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1034620757269207"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162788_1317729141647695_8854365562227130368_n.png?stp=dst-png_s360x360&_nc_cat=