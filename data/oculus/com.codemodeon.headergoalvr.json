43816_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Ts-UKfybZQQ7kNvgHa07CI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCjTDxUFSt-iWG1Nl9alvl5fFm5yG5kDmiVjK7CkIOvMA&oe=67349818"}, {"file_name": "11162706_545880739077015_776248509060874240_n[1].png", "id": "588180505989566", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974883_588180509322899_8292226724069394964_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g0LC9HRtUmMQ7kNvgFFmnh7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB50P36YrvB0z3qoEDqyjOqB4PeKrMT_p9QjM_R2iXbcQ&oe=67347922"}, {"file_name": "11162680_1455800867840203_7849548334011252736_n[1].png", "id": "518428340059190", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974711_518428343392523_5121047208112753300_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxayfogmsK8Q7kNvgF_nbVo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA50jmdG1VDcTgQg_05rBVOMukuAEmAJAwYV0kOOpMK9Q&oe=6734A24E"}, {"file_name": "12410345_966098233512801_9034229463914643456_n[1].png", "id": "593757562311130", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75375083_593757565644463_6230111182284871809_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tmhJBFeubWwQ7kNvgHUko3_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDP62oSQtmeXPKCa3RdJd_qViB_PzatnSUq8BbshcRCJA&oe=67349414"}, {"file_name": "12482260_1151552408262553_1609547455261573120_n[1].png", "id": "765191768012585", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974629_765191771345918_1739664510841846535_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_eofnhfH10AQ7kNvgFk2ZZH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBIc_93v5hrjnbslxAmrOgytjPvvGNCkaDYqXaleDiZ-w&oe=67347B47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031308_3328597104028075_6193775273117411495_n[1].png", "id": "586326426208537", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974671_586326429541870_8809032610806279492_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yzafjYnWvqIQ7kNvgHB9XDr&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCKSOi3sPXHUhH9xtXfoWWgrV13IQL4HRw_ucnjUSNG8Q&oe=6734980E"}, "display_name": "Header Goal VR : Being Axel Rix", "keywords": ["header", "goal", "football", "zombie", "ball"], "long_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player. Your main goal is to hit thrown balls by heading while targeting various objects in a soccer training field. Each stage has a unique level design. To achieve a better score, you should have a plan. Even hitting the targets in the right order makes a great difference. You will start feel like Axel within the immersive atmosphere of the game.\n\nBeing able to hit a virtual ball in the most natural and realistic way makes Header Goal VR the most entertaining way of heading a ball.", "short_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://headergoalvr.co/privacy.pdf", "developer_terms_of_service_url": "https://headergoalvr.co/eula.pdf", "publisher_name": "Codemodeon", "support_website_url": null, "website_url": "https://headergoalvr.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recomm