viobkoKbDkG8YNnLPA&oe=6745B794"}, {"file_name": "12482260_1151552408262553_1609547455261573120_n[1].png", "id": "765191768012585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974629_765191771345918_1739664510841846535_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1cFU83v9HpcQ7kNvgGw6iuG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSRH8qasjSraaFNwT464B6nmvUZt-uAYO8mJI3RTmjRg&oe=67459EC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031308_3328597104028075_6193775273117411495_n[1].png", "id": "586326426208537", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974671_586326429541870_8809032610806279492_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qPgh2az52DMQ7kNvgH1MG-v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxrfBr6o-N71Ogm_3LqQTAi230QKzPH9gBtXoXQ86O6w&oe=6745BB8E"}, "display_name": "Header Goal VR : Being Axel Rix", "keywords": [], "long_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player. Your main goal is to hit thrown balls by heading while targeting various objects in a soccer training field. Each stage has a unique level design. To achieve a better score, you should have a plan. Even hitting the targets in the right order makes a great difference. You will start feel like Axel within the immersive atmosphere of the game.\n\nBeing able to hit a virtual ball in the most natural and realistic way makes Header Goal VR the most entertaining way of heading a ball.", "short_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player."}]}, "developer_name": null, "developer_privacy_policy_url":