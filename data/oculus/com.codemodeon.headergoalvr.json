.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0zI0nCtzTCAQ7kNvgHzsKcX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVmILIx5QLS_altuBSIGCayDJy1yWMwHvcXTwYRgh2RQ&oe=673DD28E"}, "display_name": "Header Goal VR : Being Axel Rix", "keywords": ["header", "goal", "football", "zombie", "ball"], "long_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player. Your main goal is to hit thrown balls by heading while targeting various objects in a soccer training field. Each stage has a unique level design. To achieve a better score, you should have a plan. Even hitting the targets in the right order makes a great difference. You will start feel like Axel within the immersive atmosphere of the game.\n\nBeing able to hit a virtual ball in the most natural and realistic way makes Header Goal VR the most entertaining way of heading a ball.", "short_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://headergoalvr.co/privacy.pdf", "developer_terms_of_service_url": "https://headergoalvr.co/eula.pdf", "publisher_name": "Codemodeon", "support_website_url": null, "website_url": "https://headergoalvr.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recomm