02crhAG47nIr_UDnZjvVdOQYXeUsKidKQ&oe=66E97CCE"}, {"file_name": "12410345_966098233512801_9034229463914643456_n[1].png", "id": "593757562311130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375083_593757565644463_6230111182284871809_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qYxv9k7SSW8Q7kNvgH0_v9e&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_HFKsxGA5vfYVtSPOfCAw&oh=00_AYC3VD7L-oZ3jOB0CApGpMUy3bi_mhRlju97nVQj09C_5w&oe=66E96E94"}, {"file_name": "12482260_1151552408262553_1609547455261573120_n[1].png", "id": "765191768012585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974629_765191771345918_1739664510841846535_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nV0OgPCYWUMQ7kNvgEyS9rX&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_HFKsxGA5vfYVtSPOfCAw&oh=00_AYC_jt77wtw86p96EQSyxDk2aSYQZQWmvCNDJuDaxxAogw&oe=66E955C7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031308_3328597104028075_6193775273117411495_n[1].png", "id": "586326426208537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974671_586326429541870_8809032610806279492_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XL95sx1OWpAQ7kNvgEHPKT-&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_HFKsxGA5vfYVtSPOfCAw&oh=00_AYADL0g1DNxMCHfnhU2bMlKimxNXexg3J55lJIqHCrBOQw&oe=66E9728E"}, "display_name": "Header Goal VR : Being Axel Rix", "keywords": [], "long_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player. Your main goal is to hit thrown balls by heading while targeting various objects in a soccer training field. Each stage has a unique level design. To achieve a better score, you should have a plan. Even hitting the targets in the right order makes a great difference. You will start feel like Axel within the immersive atmosphere of the game.\n\nBeing able to hit a virtual ball in the most natural and realistic way makes Header Goal VR the most entertaining way of heading a ball.", "short_description": "Header Goal VR is a physics based, action pumped, virtual reality sports game with a simulation like interaction dynamics. Through its story based levels you find yourself in the place of the character Axel Rix who is a young soccer player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://codemodeon.com/legal/privacy.pdf", "developer_terms_of_service_url": "https://codemodeon.com/legal/eula.pdf", "publisher_name": "Codemodeon", "support_website_url": null, "website_url": "https://codemodeon.com/headergoalvr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1092175874721227"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1179687656575695"}, {"status": "PUBLISHED", "id": "437126535980592"}, {"status": "PUBLISHED", "id": "1232096651087002"}, {"status": "PUBLISHED", "id": "1040111220028901"}, {"status": "PUBLISHED", "id": "799601624377244"}]}, "baseline_offer": {"id": "437126535980592"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726340400, "status": "PUBLISHED", "id": "1179687656575695"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5482547921806985", "version": "1.3"}, "id": "1227390951388027", "channel_name": "