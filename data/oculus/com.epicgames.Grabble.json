n.com/v/t64.5771-25/75195902_1433343607144147_5985429000769036706_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bseHuDE465AQ7kNvgHhiCiF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDn3UXQ7eM5bQ6btd_eNEjZd8bSkrgfLnYaQhw-OskJGw&oe=6714DBFC"}, {"file_name": "Grabble_AlphaScreenshot_ 2.png", "id": "383730323966774", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974526_383730327300107_3310890588087906732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6Co61CAmrkQ7kNvgEPUYZj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAK3XHXbab8j6du2iw8q1yaVreLvGULupcHv0YtVEkvVA&oe=6714F2CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Grabble_CoverArt_Landscape.png", "id": "334814025421608", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974472_334814028754941_3850824970804458703_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cCaqImZxg_YQ7kNvgGMvKSs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFb3ReY3ziqQgavb_81hIvJKBEK8fYLoLS44p5Rtxzvw&oe=6714D813"}, "display_name": "Grabble", "keywords": [], "long_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters!\n\nGrabble is a new arcade style VR game with a growing community and is available on AppLab while we test the core mechanics. Please join us on discord or twitter to share your experience. We are a team of two developing Grabble on nights and weekends and your feedback and support means the world to us!  \n\nGrabble On!", "short_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters! \n\nWe are a team of two actively building Grabble on nights and weekends. Your feedback and support mean everything to us! If you would like to tell us what you think of grabble, please join our discord or hit us up on twitter. \n\nGrabble on!\n"}]}, "developer_name": "Async Studios", "developer_privacy_policy_url": "https://www.grabblevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Async Audio LLC", "support_website_url": "https://www.grabblevr.com/contact", "website_url": "https://www.grabblevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "478561730749591"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982500_516563816600734_445945753351881721_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XyX5OMQZYf0Q7kNvgHKeGuf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCn27Z-JR9HZ0i8UIwJLB0BXdW9Q-dsfnFRFjNWekOCog&oe=6714DDC5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Grabble", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1651516230, "lastRevision": {"nodes": [{"id": "3633530780104147", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4737808899661568", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1053363455301918"}, "iarc_email"