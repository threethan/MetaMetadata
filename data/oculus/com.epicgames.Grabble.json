n.com/v/t64.5771-25/75195902_1433343607144147_5985429000769036706_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-lILy5i8BfoQ7kNvgH0zO6q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAykTMa9l-VSQFC8M7TzWLk0p_5uACK3wJuEPa79IrWLA&oe=676FD37C"}, {"file_name": "Grabble_AlphaScreenshot_ 2.png", "id": "383730323966774", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974526_383730327300107_3310890588087906732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HXPpokPNkRUQ7kNvgGQlJIN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3sFD5aTB1uU3yK5HUnZHjTiwGPLU1FodcZ4bl9zglsQ&oe=676FEA4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Grabble_CoverArt_Landscape.png", "id": "334814025421608", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974472_334814028754941_3850824970804458703_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fxVwdWFFCA4Q7kNvgH4Zdgm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkqV2HzqjNuWMaqIBhjT7V9vggVVMOdCzOdtYccjCfjg&oe=676FCF93"}, "display_name": "Grabble", "keywords": [], "long_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters!\n\nGrabble is a new arcade style VR game with a growing community and is available on AppLab while we test the core mechanics. Please join us on discord or twitter to share your experience. We are a team of two developing Grabble on nights and weekends and your feedback and support means the world to us!  \n\nGrabble On!", "short_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters! \n\nWe are a team of two actively building Grabble on nights and weekends. Your feedback and support mean everything to us! If you would like to tell us what you think of grabble, please join our discord or hit us up on twitter. \n\nGrabble on!\n"}]}, "developer_name": "Async Studios", "developer_privacy_policy_url": "https://www.grabblevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Async Audio LLC", "support_website_url": "https://www.grabblevr.com/contact", "website_url": "https://www.grabblevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "478561730749591"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982500_516563816600734_445945753351881721_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kCKjs0c1MxsQ7kNvgGSKvm1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBsM4XQ8QEWkkAy-j3Z3Bfi0f5gsZIYX3gRF8z3Zt6Byw&oe=676FD545"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Grabble", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1651516230, "lastRevision": {"nodes": [{"id": "3633530780104147", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"defau