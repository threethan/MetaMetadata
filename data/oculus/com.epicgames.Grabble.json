7&_nc_sid=6e7a0a&_nc_ohc=BJCl20PWm7QQ7kNvgFS40BH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUM2cVQVlRNoSmBwS3vlvkQWd4dU23j1-1_KUxc9QVcg&oe=6708FE7C"}, {"file_name": "Grabble_AlphaScreenshot_ 2.png", "id": "383730323966774", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974526_383730327300107_3310890588087906732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=99Qfb1OWshMQ7kNvgGprN_3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDG3ZmQz18BCHN96300v8aRCtn4OwTieg52udf_fkGpGg&oe=6709154E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Grabble_CoverArt_Landscape.png", "id": "334814025421608", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974472_334814028754941_3850824970804458703_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpsCWlGudWYQ7kNvgEVKQpM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBzNvNi7b53qJJyBzHDkd_dtPvmZ5fHk3n7CoS0faiOkQ&oe=6708FA93"}, "display_name": "Grabble", "keywords": [], "long_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters!\n\nGrabble is a new arcade style VR game with a growing community and is available on AppLab while we test the core mechanics. Please join us on discord or twitter to share your experience. We are a team of two developing Grabble on nights and weekends and your feedback and support means the world to us!  \n\nGrabble On!", "short_description": "Grapple and boost your way through a procedurally generated world. Swing from cube to cube to fly as far as you can. The cubes disappear as you go, so move quickly and don't forget to use you grip boosters! \n\nWe are a team of two actively building Grabble on nights and weekends. Your feedback and support mean everything to us! If you would like to tell us what you think of grabble, please join our discord or hit us up on twitter. \n\nGrabble on!\n"}]}, "devel