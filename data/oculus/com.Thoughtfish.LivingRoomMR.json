{"data": {"node": {"__typename": "Application", "id": "7778145568911617", "organization": {"id": "118627091066481", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7778145568911617"}]}, "id": "1239816683652672"}]}}, "firstRevision": {"nodes": [{"application": {"id": "7778145568911617", "release_date": 1731002400, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 4}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8624516290941203"}, "id": "1095351478230665"}]}}, "binary": null, "live_binary": null, "created_date": 1732210350, "id": "8853768938015936", "is_initial_release": false, "name_with_fallback": "v15", "pdp_metadata_with_fallback": {"version": 14, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8853787728014057"}, "release_status": "RELEASED", "id": "7778145568911617"}, "id": "8853787728014057", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7778145568911617", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1097364788631401"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplateLandscape (5).png", "id": "8456279604482843", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982588_8456279631149507_4305415481854613500_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QA5Gl_yyOzYQ7kNvgEI0nVF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCEQUO9hHOq-Dj4y-BkYMxSXa2xO90Yf3gyenKZXg9QPg&oe=674851F3"}, {"file_name": "ImmersiveImageLayer_Backdrop_1800x700px_2.png", "id": "1643950533084653", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036603_1643950536417986_340771472878403041_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXR8o6b6-4wQ7kNvgFdXlRV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-R3GdNWpRpuBdtzR--sjcgNL9WsWpcEE04jw_nGE_aw&oe=6748412C"}, {"file_name": "Living Room_Logo (1).png", "id": "1364332467873908", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982566_1364332474540574_6913908481569973474_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6PW6ZDjza_YQ7kNvgG1CNlF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmzuIvSn89vOHv0Br_U2S2_oIctExXbv10CTE6rwmQZA&oe=6748594E"}, {"file_name": "ImmersiveImageLayer_ObjectLeft_400x700px_2.png", "id": "1231347154739300", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974468_1231347158072633_7879979760164777339_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iG0T-_cEnNIQ7kNvgFAFu6N&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBcpurwnbtcCioa-K7aIWS8nQyixfYf_sFm_asc7A4pZA&oe=67487119"}, {"file_name": "CoverImageSafeAreaTemplateHero (1).png", "id": "1107980240726007", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031409_1107980247392673_7122004621259517760_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fe9aOboRe0kQ7kNvgENZLqp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpv1NunKN48m3lYUfJzUSQHlLbBtBuRslGiCRaQoLzYg&oe=6748641F"}, {"file_name": "CoverImageSafeAreaTemplateMiniLandscape (1).png", "id": "1101664504996709", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982653_1101664511663375_2922668151521263375_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wcj4iLJWsyEQ7kNvgERkWLp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwAM0dVy2UbhdM8vmh4w0_fgaOxNByP-JqiIjrRv9zCQ&oe=67484B7F"}, {"file_name": "ImmersiveImageLayer_Logo_556x164px.png", "id": "874141991407969", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982653_874141994741302_795256190034598183_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mZzg8QgQCL4Q7kNvgFyLuX1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfm8uZOYI9A_w5NcvvbKg_LeSgB4lvS6gnSOU-IGQGXA&oe=67484139"}, {"file_name": "ImmersiveImageLayer_ObjectRight_400x700px.png", "id": "829534958749127", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982555_829534962082460_8281911485190349175_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Wo_san1TvQQ7kNvgFLk4Az&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCN1GvReEZ3tZh9vbu7pNrT3m6MTX0KlGYDDIro4ojfjA&oe=67487043"}, {"file_name": "LivingRoom_Icon_512px.png", "id": "556150273563557", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221321_556150276896890_4581635495328349416_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RwOZbGg0qQoQ7kNvgGSVYRI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW3d4x8zcO3f9_1vNc_c0e4wg2vwlLyHZyd8dQHwG21g&oe=67486F7D"}, {"file_name": "39031490_848284174052157_4337492943569021724_n.png", "id": "553796827396788", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566690_553796834063454_1397284335905068004_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NDTfCp0tP4MQ7kNvgGTw9Ft&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQM_qvMiwJz186iW3VgTAsEg-aYSD552vIq6xWIvMDDQ&oe=67484F29"}, {"file_name": "CoverImageSafeAreaTemplatePortrait (3).png", "id": "550196077921859", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984442_550196081255192_7349533015362220724_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZtHqPnTbnHUQ7kNvgFNbBRd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQoEbmZtNyxKzBhNL9FFIO77C8u7bi6VRQZOALUz5g7g&oe=67484490"}]}, "id": "1072304084353652", "locale": "en_US", "screenshots": [{"file_name": "LR_Screenshot_1_Large.png", "id": "885462137025151", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031311_885462140358484_3913265485254680533_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZaOYZJ9oFRUQ7kNvgGk06Vw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgUplq3x9fL1lhD7IylvVgYTL7OsHNksZTlc8FyOezfg&oe=6748491C"}, {"file_name": "LR_Screenshot_2_Large.png", "id": "489581567427078", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575346_489581574093744_7010148194791043983_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQIug-rglFEQ7kNvgGMUGH0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdhSwZ7_Kq7dg-eZ1XZkA6_fK-yi5doZSoyfJFbmPdrQ&oe=6748628C"}, {"file_name": "LR_Screenshot_3_Large.png", "id": "1300872987580570", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003244_1300872990913903_6979128887398890125_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YoODp-kQ2L4Q7kNvgEa6TDC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjIKmUuCk3uLLgdOSSAO21iaKftsKOplZ1AfwiZByZlA&oe=67483E03"}, {"file_name": "LR_Screenshot_4_Large.png", "id": "423947064091292", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974468_423947067424625_6949822023324201449_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S6_MsUGT3AgQ7kNvgHCCdaV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZ5lkbKvAZF4t5uC1LyLMIkVA4oKGwsBa82p05U00uYA&oe=67483F95"}, {"file_name": "LR_Screenshot_5_Large.png", "id": "847894390572216", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031608_847894397238882_6353944228420800414_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aGYrvNIgjwgQ7kNvgGEg4Sn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCX48nbLt_klBBxrychEu3DUC_C5Pa5ajoVzBQMqAs-Qw&oe=674850E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape (2).png", "id": "865157162499305", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422388_865157165832638_7089650254847795846_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tJlCdae70QQQ7kNvgHX4aW1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANcQ9VmgI1jMLaOaPs3aDJuLJba3V_i9oJbkXuXxz0hw&oe=674869ED"}, "display_name": "Living Room", "keywords": ["animal", "cozy", "decorating", "family", "pet"], "long_description": "# A Cozy Wildlife Sanctuary Inside Your Home\nExperience nature like never before with Living Room, the mixed-reality game that transforms your home into an enchanting ecosystem. Create lush islands on your furniture, populated by adorable animals that live, breed and evolve around you.\n# Create Your Own Sanctuary\nUse Quest's surface-tracking technology to turn your furniture into rich island habitats where cute critters can grow and thrive.\n{1082890553537100}\n# Solve Quests to Progress\nComplete quests to reveal new biomes, animal and plant species, and decorations - each with their own unique aesthetic.\n{1349714152662616}\n# Breed To Unlock Color Variants\nBreed your animals over time to unlock a kaleidoscope of color variants, making your sanctuary even more colorful and enchanting.\n{1515942259109437}\n# Turn Your Favorite Animal into a (Virtual) Pet\nChoose an animal to join you as a life-sized companion, exploring your space in real-time, digging up treasures, and unlocking surprises.\n{1303676510800715}\n# Multiple Play Modes\nBuild and maintain healthy habitats in Normal Mode, solve tricky puzzles in Challenge Mode, or relax and let your creativity run free in Creative Mode.\n{848862397326395}\n# Customize Your Entire Environment\nDecorate not just your animal oasis, but your entire home - with plushies, Polaroids, plants and more!\n{1077254123604861}\nLiving Room offers a playful, immersive wildlife simulation for nature lovers and casual gamers alike. Start building a vibrant new world today!\n{867652082097596}", "short_description": "Transform your home into a cozy wildlife sanctuary with Living Room! Turn your furniture into vibrant islands, care for cute critters, breed unique color variants and customize your entire space with colorful decorations. Complete quests to unlock new biomes in Normal Mode, solve tricky puzzles in Challenge Mode, or relax and decorate in Creative Mode. You can even turn your favorite animal into a life-sized pet! Available now on Quest."}, {"images": {"nodes": []}, "id": "2187401344989631", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Living Room", "keywords": ["\ub3d9\ubb3c", "VR", "\ud790\ub9c1", "\uafb8\ubbf8\uae30", "\uc2dc\ubbac\ub808\uc774\uc158"], "long_description": "# \ub0b4 \ubc29 \uc548\uc758 \uc57c\uc0dd\ub3d9\ubb3c \ubcf4\ud638\uad6c\uc5ed\n\uac74\uc804\ud558\uace0 \uae30\ubc1c\ud55c \uc99d\uac15 \ud604\uc2e4 \uc2dc\ubbac\ub808\uc774\uc158 \uac8c\uc784\uc778 \u201c\ub9ac\ube59\ub8f8\u201d\uc5d0\uc11c \ub2f9\uc2e0\uc758 \ubc29\uc744 \uc5ed\ub3d9\uc801\uc778 \uc0dd\ud0dc\uacc4\ub85c \ubcc0\uc2e0\uc2dc\ucf1c\ubcf4\uc138\uc694!\n\n\uac00\uad6c\ub97c \uc12c\uc73c\ub85c \ubc14\uafb8\uace0, \ub2e4\uc591\ud55c \ub9f9\ud55c \ub3d9\ubb3c\uacfc \ubb34\uc131\ud55c \uc2dd\ubb3c\ub85c \uac00\ub4dd \ucc44\uc6cc\ubcf4\uc138\uc694. \ub2f9\uc2e0\uc774 \uac00\uc7a5 \uc88b\uc544\ud558\ub294 \ub3d9\ubb3c\uc774 \uc2e4\ubb3c \ud06c\uae30\uc758 \uc560\uc644\ub3d9\ubb3c\ucc98\ub7fc \ubc29\uc744 \ub3cc\uc544\ub2e4\ub2c8\ub294 \uac83\uc744 \uad00\ucc30\ud558\uace0 \ub514\uc9c0\ud138 \ub3d9\ubb3c \ubcf4\ud638\uad6c\uc5ed\uc744 \uad00\ub9ac\ud558\uace0 \ud655\uc7a5\ud558\ub294 \uae30\ubc1c\ud55c \uacbd\ud5d8\uc744 \uc990\uae30\uc138\uc694.\n\n# \ud655\uc7a5 \ud604\uc2e4\uc758 \ub9c8\ubc95\n\ubc29\uc774 \ud65c\uae30\ucc2c \uc790\uc5f0 \ubcf4\ud638\uad6c\uc5ed\uc73c\ub85c \ubc14\ub00c\ub294 \uacfc\uc815\uc5d0\uc11c \ub514\uc9c0\ud138\uacfc \ubb3c\ub9ac\uc801 \uc138\uacc4\uac00 \uc6d0\ud65c\ud558\uac8c \uc870\ud654\ub97c \uc774\ub8e8\uac8c \ud558\uc138\uc694. \uc0dd\ubb3c\uc774 \uc0b4 \uc218 \uc788\ub3c4\ub85d \uac00\uad6c\uc5d0 \uc12c\uc744 \uce60\ud558\uace0 \uacf5\uac04\uc5d0 \uc7ac\ubc30\uce58\ud558\uba70, \uc120\ud0dd\ud55c \ubc18\ub824\ub3d9\ubb3c\uc774 \uc2e4\uc2dc\uac04\uc73c\ub85c \ubc29\uc744 \ub3cc\uc544\ub2e4\ub2c8\uba70 \ud0d0\ud5d8\ud558\ub294 \ubaa8\uc2b5\uc744 \uc9c0\ucf1c\ubcf4\uc138\uc694.\n{355710417568905}\n\ubc29 \uc7a5\uc2dd \uc7a0\uae08\ud574\uc81c\ub97c \ud1b5\ud574 \ubc29\uc744 \uafb8\ubbf8\uace0, \ub0ae\uacfc \ubc24\uc744 \uc624\uac00\uba70 \uc870\uba85\uc758 \ubcc0\ud654\ub97c \uc990\uae30\uc138\uc694.\n\n# \uc57c\uc0dd\ub3d9\ubb3c \ubcf4\uc0b4\ud53c\uae30\n\uc0dd\ud0dc\uacc4\uc758 \uade0\ud615\uc744 \uc720\uc9c0\ud558\uae30 \uc704\ud574 \ubaa8\ub4e0 \uc885\uc758 \uc694\uad6c \uc0ac\ud56d\uc774 \ucda9\uc871\ub418\uc5c8\ub294\uc9c0 \ud655\uc778\ud558\uc138\uc694. \ub3d9\ubb3c\uc774 \uc790\ub77c\ub294 \uac83\uc744 \uc9c0\ucf1c\ubcf4\uace0, \ubc24\uc744 \ubcf4\ub0bc \uc27c\ud130\ub97c \ub9cc\ub4e4\uace0, \ubc88\uc2dd\uc9c0\ub97c \ub9cc\ub4e4\uc5b4 \ub9cc\ud654\uacbd\uc744 \ud1b5\ud574 \ub2e4\uc591\ud55c \uc885\ub958\uc758 \uac1c\uccb4\uc218\ub97c \ub298\ub9ac\uc138\uc694.\n{871950161348817}\n\n# \uc0c8\ub85c\uc6b4 \uc885\uacfc \uc0dd\ubb3c\uad70\uacc4\ub97c \uc7a0\uae08 \ud574\uc81c\ud558\uae30\n\uac8c\uc784\uc744 \uc9c4\ud589\ud558\uba70 \uace0\uc720\ud55c \ub3d9\uc2dd\ubb3c \uc885\uc73c\ub85c \uad6c\uc131\ub41c \uc0c8\ub85c\uc6b4 \uc0dd\ubb3c\uad70\uacc4\ub97c \uc7a0\uae08 \ud574\uc81c\ud558\uace0 \uc0dd\ud0dc\uacc4\uc5d0 \ucd94\uac00\ud574\ubcf4\ubcf4\uc138\uc694.\n{1196659494728138}\n\n# \uce90\uc8fc\uc5bc\ud558\uba74\uc11c\ub3c4 \ub3c4\uc804\uc801\uc778\n\uc77c\ubc18 \ubaa8\ub4dc\uc5d0\uc11c \uc57c\uc0dd\ub3d9\ubb3c\uc774 \ubc88\uc131\ud558\ub294 \ubaa8\uc2b5\uc744 \ubcf4\uba74\uc11c \ud790\ub9c1\ud558\uace0, \ub3c4 \ubaa8\ub4dc\uc5d0\uc11c \uc5b4\ub824\uc6b4 \ud37c\uc990\uacfc \uae4c\ub2e4\ub85c\uc6b4 \uc2dc\ub098\ub9ac\uc624\ub85c \uc9c0\uc2dd\uacfc \uae30\uc220\uc744 \ud14c\uc2a4\ud2b8\ud558\uac70\ub098, \ucc3d\uc758\ub825 \ubaa8\ub4dc\uc5d0\uc11c \uac00\uc7a5 \ubabd\ud658\uc801\uc774\uace0 \uadf8\ub9bc \uac19\uc740 \ubcf4\ud638\uad6c\uc5ed\uc744 \uc790\uc720\ub86d\uac8c \ub514\uc790\uc778\ud558\uc138\uc694.\n\n\n{497486736617844}", "short_description": "\ub0b4 \ubc29 \uc548\uc758 \uc57c\uc0dd\ub3d9\ubb3c \ubcf4\ud638\uad6c\uc5ed\n\uac74\uc804\ud558\uace0 \uae30\ubc1c\ud55c \uc99d\uac15 \ud604\uc2e4 \uc2dc\ubbac\ub808\uc774\uc158 \uac8c\uc784\uc778 \u201c\ub9ac\ube59\ub8f8\u201d\uc5d0\uc11c \ub2f9\uc2e0\uc758 \ubc29\uc744 \uc5ed\ub3d9\uc801\uc778 \uc0dd\ud0dc\uacc4\ub85c \ubcc0\uc2e0\uc2dc\ucf1c\ubcf4\uc138\uc694!\n\n\uac00\uad6c\ub97c \uc12c\uc73c\ub85c \ubc14\uafb8\uace0, \ub2e4\uc591\ud55c \ub9f9\ud55c \ub3d9\ubb3c\uacfc \ubb34\uc131\ud55c \uc2dd\ubb3c\ub85c \uac00\ub4dd \ucc44\uc6cc\ubcf4\uc138\uc694. \ub2f9\uc2e0\uc758 \ubc29\uc774 \ub2e4\ucc44\ub85c\uc6b4 \uc57c\uc0dd\ub3d9\ubb3c\ub4e4\ub85c \uc0b4\uc544 \uc228\uc26c\ub294 \uacbd\ud5d8\uacfc, \ub514\uc9c0\ud138 \ub3d9\ubb3c \ubcf4\ud638\uad6c\uc5ed\uc744 \uad00\ub9ac\ud558\uace0 \ud655\uc7a5\ud558\ub294 \uae30\ubc1c\ud55c \uacbd\ud5d8\uc744 \uc990\uae30\uc138\uc694."}, {"images": {"nodes": []}, "id": "1596103304370303", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Living Room", "keywords": ["animal", "VR", "acogedor", "decoraci\u00f3n", "simulaci\u00f3n"], "long_description": "# Un Santuario de Vida Silvestre Dentro de Tu Habitaci\u00f3n\n\u00a1Transforma tu espacio en tu propio ecosistema din\u00e1mico en Living Room, un juego de simulaci\u00f3n de realidad mixta encantador y peculiar!\n\nConvierte tus muebles en islas y pu\u00e9blalos con animales torpes y plantas exuberantes. Observa c\u00f3mo tu animal favorito recorre la habitaci\u00f3n como una querida mascota a tama\u00f1o real, y disfruta de gestionar y expandir tu santuario digital.\n\n# Magia de Realidad Mixta\nFusiona el mundo digital y f\u00edsico mientras tu habitaci\u00f3n se transforma en una reserva natural. Dibuja islas en tus muebles para tus criaturas, reorgan\u00edzalas, y observa c\u00f3mo tu mascota explora tu espacio en tiempo real.\n{544165058556600}\nDesbloquea decoraciones y observa c\u00f3mo cambia la iluminaci\u00f3n entre el d\u00eda y la noche.\n\n# Cuida de Tu Vida Silvestre\nSatisface las necesidades de tus especies para mantener el equilibrio. Ve crecer a tus animales, constr\u00fayeles refugios y zonas de cr\u00eda para expandir sus poblaciones con variantes coloridas.\n{8651732801574430}\n\n# Desbloquea Nuevas Especies y Biomas\nA medida que progresas, desbloquea nuevos biomas, cada uno con especies \u00fanicas de flora y fauna, y a\u00f1\u00e1delos a tu ecosistema.\n{1247733543142520}\n\n# Relajado Pero Desafiante\nRel\u00e1jate viendo prosperar tu vida silvestre en Modo Normal, pon a prueba tus habilidades en Modo Desaf\u00edo con puzzles, o dise\u00f1a santuarios de ensue\u00f1o en Modo Creativo.\n{565709405934578}", "short_description": "Un Santuario de Vida Silvestre Dentro de Tu Habitaci\u00f3n\n\n\u00a1Transforma tu espacio en tu propio ecosistema din\u00e1mico en Living Room, un juego de simulaci\u00f3n de realidad mixta encantador y peculiar!\n\nConvierte tus muebles en islas y pu\u00e9blaloscon una variedad de animales torpes y plantas exuberantes. Observa c\u00f3mo tu habitaci\u00f3n cobra vida con colorida fauna, y disfruta de la experiencia caprichosa de gestionar y expandir tu santuario digital."}, {"images": {"nodes": []}, "id": "1516546625724406", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Living Room", "keywords": ["animal", "VR", "simulation", "dekorieren", "cozy"], "long_description": "# Ein Wildtierreservat im Wohnzimmer\n\nStarte dein eigenes \u00d6kosystem direkt in deinem Zimmer! In Living Room, unserem charmanten Mixed-Reality-Game, verwandelst du deine M\u00f6bel in farbenfrohe Inseln, die du mit s\u00fc\u00dfen Tieren und \u00fcppigen Pflanzen bev\u00f6lkerst. K\u00fcmmere dich um deine tierischen Mitbewohner und verwandle dein Lieblingstier in ein lebensgro\u00dfes Haustier, das fr\u00f6hlich durch den Raum spaziert und f\u00fcr jede Menge Spa\u00df sorgt.\n\nGestalte deine eigene kleine Welt und erlebe, wie dein Zuhause zum Spielplatz f\u00fcr Flora und Fauna wird!\n\n# Mixed-Reality-Magie\nDigitales und Wirklichkeit verbinden sich nahtlos! Male Inseln auf deine M\u00f6bel, um Lebensr\u00e4ume f\u00fcr deine Tiere zu schaffen, arrangiere alles nach deinem Geschmack und sieh zu, wie deine Lieblinge in Echtzeit durch den Raum streifen. \n{3734140100170376}\nSchalte Dekorationen f\u00fcr dein Zimmer frei und beobachte den Wechsel von Tag und Nacht.\n\n# K\u00fcmmere dich um deine tierischen Freunde\nSorge daf\u00fcr, dass es all deinen Arten gut geht und das Gleichgewicht im \u00d6kosystem erhalten bleibt. Sieh zu, wie deine Tiere wachsen, baue ihnen Schlafpl\u00e4tze und z\u00fcchte, um ihre Population mit vielen bunten Varianten zu erweitern.\n{3784126741904074}\n\n# Entdecke neue Arten und Biome\nSchalte im Laufe des Spiels neue Biome frei, jedes mit einzigartigen Pflanzen- und Tierarten, die du in dein wachsendes \u00d6kosystem integrieren kannst.\n{907241894297609}\n\n# Entspannt oder knifflig \u2013 du entscheidest!\nEntspanne im Normalmodus, stelle dich den Herausforderungen im Challenge-Mode oder gestalte im Creative-Mode dein perfektes Tierparadies!\n{1747910322626991}", "short_description": "Ein Wildtierreservat im Wohnzimmer\n\nStarte dein eigenes \u00d6kosystem direkt in deinem Zimmer! In Living Room, unserem charmanten Mixed-Reality-Game, verwandelst du deine M\u00f6bel in farbenfrohe Inseln, die du mit s\u00fc\u00dfen Tieren und \u00fcppigen Pflanzen bev\u00f6lkerst. \n\nK\u00fcmmere dich um deine tierischen Mitbewohner und verwandle dein Lieblingstier in ein lebensgro\u00dfes Haustier, das fr\u00f6hlich durch den Raum spaziert und f\u00fcr jede Menge Spa\u00df sorgt."}, {"images": {"nodes": []}, "id": "1269329864212282", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Living Room", "keywords": ["animal", "VR", "cosy", "d\u00e9coration", "simulation"], "long_description": "# Un Sanctuaire Animalier Dans Votre Chambre\nTransformez votre espace en votre propre \u00e9cosyst\u00e8me dans Living Room, un jeu de simulation de r\u00e9alit\u00e9 mixte !\n\nTransformez vos meubles en \u00eeles et peuplez-les d'une vari\u00e9t\u00e9 d'animaux farfelus et de plantes luxuriantes. Observez votre animal de compagnie grandeur nature se d\u00e9placer dans votre pi\u00e8ce.\n# La Magie de la R\u00e9alit\u00e9 Mixte\nM\u00e9langez harmonieusement le monde physique et digital pour observer votre pi\u00e8ce se transformer en une r\u00e9serve naturelle. Peignez des \u00eeles sur vos meubles pour y faire vivre vos cr\u00e9atures, r\u00e9organisez-les dans votre espace.\n{1316441059531470}\n\nD\u00e9bloquez des d\u00e9corations pour votre pi\u00e8ce et observez le changement d'\u00e9clairage lorsque vous passez du jour \u00e0 la nuit.\n# Prenez Soin de Votre Faune\nAssurez-vous que les besoins de toutes vos esp\u00e8ces sont satisfaits pour maintenir l'\u00e9quilibre. Regardez vos animaux grandir, construisez-leur des abris pour la nuit et des aires de reproduction afin d\u2019accro\u00eetre leurs populations et r\u00e9v\u00e9ler leur large palette de couleurs.\n{1076662127286626}\n\n# D\u00e9bloquez de Nouvelles Esp\u00e8ces et de Nouveaux Biomes\nD\u00e9bloquez de nouveaux biomes, chacun avec ses propres esp\u00e8ces de flore et de faune uniques.\n{509906028532216}\n\n# D\u00e9contract\u00e9 et Stimulant\nD\u00e9tendez-vous en regardant votre faune prosp\u00e9rer en mode normal, testez vos comp\u00e9tences avec des \u00e9nigmes et des sc\u00e9narios en mode d\u00e9fi, ou concevez librement les sanctuaires les plus oniriques ou pittoresques en mode cr\u00e9atif.\n{1920599568417971}", "short_description": "Un Sanctuaire Animalier Dans Votre Chambre\n\nTransformez votre espace en votre propre \u00e9cosyst\u00e8me dynamique dans Living Room, un jeu de simulation de r\u00e9alit\u00e9 mixte joyeux et original !\n\nTransformez vos meubles en \u00eeles et peuplez-les d'une vari\u00e9t\u00e9 d'animaux farfelus et de plantes luxuriantes. Observez votre pi\u00e8ce prendre vie avec une faune color\u00e9e et profitez de l'exp\u00e9rience fantaisiste de la gestion et de l'expansion de votre sanctuaire digital."}]}, "developer_name": "Thoughtfish GmbH", "developer_privacy_policy_url": "https://www.thoughtfish.de/living-room-privacy-policy/", "developer_terms_of_service_url": "https://www.thoughtfish.de/living-room-terms-of-service/", "publisher_name": "Thoughtfish GmbH", "support_website_url": "https://www.thoughtfish.de/contact-us/", "website_url": "https://www.thoughtfish.de/projects/living-room/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "ja", "ko", "fr_CA", "fr_BE", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "de_CH", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8853787728014