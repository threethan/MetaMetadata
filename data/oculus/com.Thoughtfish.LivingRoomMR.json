188350445_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_vLE-e9r_S4Q7kNvgGLhEwm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBusbs1_PPJ63esnIYbrEz7EZ6mmlfoQXPxnbbxVNCtig&oe=67486ED3"}, {"file_name": "LIVINGRoomScreenshot6.png", "id": "1894518634354895", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031399_1894518641021561_6750685527564816805_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ZizT1fL6HUQ7kNvgE5igS5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFVt_LkGZk7JuolYBpvdMQ_KmWILdQ8JQBFMCyl7yNLQ&oe=67485CD3"}, {"file_name": "LIVINGRoomScreenshot3.png", "id": "434052646103360", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031370_434052656103359_4466726471566270528_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uvIwhtpV2H4Q7kNvgFzYJTu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmd8QpDBw0yslN8hzY3QzXEh7xfo747gLw3G8pzCvyVQ&oe=67485390"}, {"file_name": "LIVINGRoomScreenshot2.png", "id": "357892816944871", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031526_357892820278204_1697351608571542959_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yiEw6NhJavwQ7kNvgGy9pGG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8Ps7rDSMMsZcoR_hf-WA0bvO5T0GfKBX4o0XXMd09OQ&oe=67484B64"}, {"file_name": "LIVINGRoomScreenshot4.png", "id": "777510657833206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569460_777510661166539_5504374753382887937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iJHBTqab3YYQ7kNvgGUiet_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxKnvXa9xSBG4YQDxMTUnakrNbdEnNK3EXWypbUE5N0Q&oe=67484D28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LIVINGRoomTrailerCover.png", "id": "2269996916683404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974689_2269996920016737_3039468053589518207_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pU8MsDge5YsQ7kNvgEp9mfW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRonx-tk3XqPztEkxTOGgwP2xCSUeYg2tHDz60f5llAw&oe=67486829"}, "display_name": "Living Room", "keywords": [], "long_description": "# A Wildlife Sanctuary Inside Your Room\n\nTransform your space into your very own dynamic ecosystem in Living Room - a wholesome and quirky mixed reality simulation game!\n\nTurn your furniture into islands and populate them with a variety of derpy animals and lush plants. Observe as your room comes alive with colorful wildlife, and enjoy the whimsical experience of managing and expanding your digital sanctuary.\n\n# Mixed Reality Magic\n\nSeamlessly blend the digital and physical world as your room transforms into a vibrant nature reserve. Paint islands on your furniture for your creatures to live on, rearrange them in your space, and watch as your chosen explorer pet roams and explores your room in real-time.\n\nUnlock decorations for your room, and witness the change in lighting as you switch between day- and nighttime.\n\n# Care for Your Wildlife\n\nEnsure the needs of all your species are met to maintain balance. Watch your animals grow, build them shelters for the night, and breeding grounds to expand their populations, featuring a kaleidoscope of colorful variants.\n\n# Unlock New Species and Biomes\n\nUnlock new biomes as you progress, each with its own unique species of flora and fauna, and introduce them to your ecosystem.\n\n# Casual Yet Challenging\n\nRelax as you watch your wildlife thrive in Normal Mode, test your knowledge and skill with challenging puzzles and tricky scenarios in Challenge Mode, or freely design the most dreamy and picturesque sanctuaries in Creative Mode.", "short_description": "A Wildlife Sanctuary Inside Your Room\n\nTransform your space into your very own dynamic ecosystem in Living Room - a wholesome and quirky mixed reality simulation game!\n\nTurn your furniture into islands and populate them with a variety of derpy animals and lush plants. Observe as your room comes alive with colorful wildlife, and enjoy the whimsical experience of managing and expanding your digital sanctuary."}]}, "developer_name": "Thoughtfish", "developer_privacy_policy_url": "https://www.thoughtfish.de/living-room-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Thoughtfish", "support_website_url": "https://www.thoughtfish.de/contact-us/", "website_url": "https://www.thoughtfish.de/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE", "fr_BE", "fr_CA", "fr", "de", "de_CH", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7837650752961098"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "547157181425786"}, {"status": "PUBLISHED", "id": "893047166125713"}, {"status": "PUBLISHED", "id": "3758858141005635"}, {"status": "PUBLISHED", "id": "367558502880453"}]}, "baseline_offer": {"id": "893047166125713"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "547157181425786"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8624516290941203", "version": "2024.10.16.r"}, "id": "1095351478230665", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "App