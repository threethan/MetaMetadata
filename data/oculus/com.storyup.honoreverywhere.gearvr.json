, DC plus get an inside look at the USS Nimitz. This virtual tour program is for aging and terminally-ill Veterans & their families who are unable to physically travel on an Honor Flight to see their memorials in Washington, DC. These experiences are donated with love by StoryUp Studios, the makers of Healium, Ohio Hospice-American Pride, Central MO Honor Flight, Jaunt, Veterans United Foundation, & VR volunteers."}]}, "developer_name": "Healium", "developer_privacy_policy_url": "https://honoreverywhere.com/privacy-policy/", "developer_terms_of_service_url": "https://honoreverywhere.com/privacy-policy/", "publisher_name": "Healium", "support_website_url": null, "website_url": "http://www.honoreverywhere.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "378169021184089"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974829_2417669184950411_7660740403447988224_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbAfZC75YPEQ7kNvgElRxsY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBqH5ehCDh4_aWbaqTncvYaiVIVcc0fjgotv_4d08vIw&oe=66EBF648"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Honor Everywhere", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1561654800, "lastRevision": {"nodes": [{"id": "915640308