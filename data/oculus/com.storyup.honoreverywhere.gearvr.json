234790765965", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974455_421534641760319_5544987664593190912_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WAvFY-QIuSgQ7kNvgEbYSxK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTJSwXPPpuxY5BXK7wuhYUxsDWXGnGHRwcL-OAgwgxKw&oe=6714D171"}, {"file_name": "migrated_image.png", "id": "215024553074835", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001682_430579481095544_8380186269212213248_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3Ar2dOoNLQQ7kNvgFaGzhf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBC4MsRwKAgDG_AXihFGE83C9pUZu7Dwktp7iEbtHXTDA&oe=6714F180"}, {"file_name": "migrated_image.png", "id": "203612227570948", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_2120312171414891_1326067806860476416_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OoeSI3kgewYQ7kNvgH8cqg-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr-Vfyp9z5FZbzJAizv3Vj69WraK4EC-sVGUE6Gc1AQQ&oe=67150207"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Honor Everywhere Thumbnail.png", "id": "602672414813535", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031347_602672418146868_7362715714717462095_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UpNaKrnWnyQQ7kNvgFAx3Yx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMCpOxOvrHFYsiDK9LUmkovysBzraiY_GjPlmD_dTE2w&oe=671507D2"}, "display_name": "Honor Everywhere", "keywords": ["honorflight", "honoreverywhere", "veterans", "military", "memorials"], "long_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. These stories told through the eyes of our Veterans are a virtual alternative for aging and terminally ill men and women who aren't able to physically travel on an Honor Flight to see their memorials in Washington, DC. There is no replacement for an in-person Honor Flight but for those unable to physically travel, a virtual tour is one option. To support your local Honor Flight, please visit honorflight.org.", "short_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. This virtual tour program is for aging and terminally-ill Veterans & their families who are unable to physically travel on an Honor Flight to see their memorials in Washington, DC. These experiences are donated with love by StoryUp Studios, the makers of Healium, Ohio Hospice-American Pride, Central MO Honor Flight, Jaunt, Veterans United Foundation, & VR volunteers."}]}, "developer_name": "Healium", "developer_privacy_policy_url": "https://honoreverywhere.com/privacy-policy/", "developer_terms_of_service_url": "https://honoreverywhere.com/privacy-policy/", "publisher_name": "Healium", "support_website_url": null, "website_url": "http://www.honoreverywhere.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "378169021184089"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974829_2417669184950411_7660740403447988224_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KzR-xTEU4tgQ7kNvgGdTpnk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8_ZTrOIJu_9gRvQUcwAFOq4l9iX55B-aJS0dEWhRV_g&oe=6714D4C8"}, "is_concept": false, "is_test": false, "is_trial_offe