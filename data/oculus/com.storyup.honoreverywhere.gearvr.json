t.oculuscdn.com&_nc_gid=AXZXz-OTpOJrg3zbq_qfGdK&oh=00_AYCt78Kng4MgDCKt74f-Vrpg7g7c38ckKWNg6tNXEqS30g&oe=66F1428F"}, {"file_name": "migrated_image.png", "id": "237234790765965", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974455_421534641760319_5544987664593190912_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cVGLmV1JGQAQ7kNvgGKSlWp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXZXz-OTpOJrg3zbq_qfGdK&oh=00_AYAVMV2kBlgthi8Cc-EeUxNQclRSprPZHmysas1_zTevLA&oe=66F138F1"}, {"file_name": "migrated_image.png", "id": "215024553074835", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001682_430579481095544_8380186269212213248_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2IBfXkYuLloQ7kNvgHDldTr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXZXz-OTpOJrg3zbq_qfGdK&oh=00_AYBwoOWWs8jogPTnVDXXxjqbppTT62R217OWIz8qHfb9Dw&oe=66F15900"}, {"file_name": "migrated_image.png", "id": "203612227570948", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_2120312171414891_1326067806860476416_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HoUcIOKIFG0Q7kNvgHqQO9_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXZXz-OTpOJrg3zbq_qfGdK&oh=00_AYCV0iaFRssSN7pVnmgsn6x5Lc-scZgd94ta2N9M1GC1Lw&oe=66F16987"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Honor Everywhere Thumbnail.png", "id": "602672414813535", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031347_602672418146868_7362715714717462095_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LW-lBE6MHKkQ7kNvgH8i_Ox&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXZXz-OTpOJrg3zbq_qfGdK&oh=00_AYA5BNqJa2rmwd8KzcfGXM9ZeeodB22PdehwHtP6-pMRFg&oe=66F13712"}, "display_name": "Honor Everywhere", "keywords": ["honorflight", "honoreverywhere", "veterans", "military", "memorials"], "long_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. These stories told through the eyes of our Veterans are a virtual alternative for aging and terminally ill men and women who aren't able to physically travel on an Honor Flight to see their memorials in Washington, DC. There is no replacement for an in-person Honor Flight but for those unable to physically travel, a virtual tour is one option. To support your local Honor Flight, please visit honorflight.org.", "short_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. This virtual tour program is for aging and terminally-ill Veterans & their families who are unable to physically travel on an Honor Flight to see their memorials in Washington, DC. These experiences are donated with love by StoryUp Studios, the makers of Healium, Ohio Hospice-American Pride, Central MO Honor Flight, Jaunt, Veterans United Foundation, & VR volunteers."}]}, "developer_name": "Healium", "developer_privacy_policy_url": "https://honoreverywhere.com/privacy-policy/", "developer_terms_of_service_url": "https://honoreverywhere.com/privacy-policy/", "publisher_name": "Healium", "support_website_url": null, "website_url": "http://www.honoreverywhere.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "378169021184089"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974829_2417669184950411_7660740403447988224_n.png?stp=dst-png_s360x36