07"}, {"file_name": "migrated_image.png", "id": "580640122529771", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001682_430579481095544_8380186269212213248_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3Ar2dOoNLQQ7kNvgFaGzhf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBC4MsRwKAgDG_AXihFGE83C9pUZu7Dwktp7iEbtHXTDA&oe=6714F180"}, {"file_name": "migrated_image.png", "id": "505155286776746", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974788_394492814480365_4121321205582004224_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IyMEJ4aD-24Q7kNvgGKFNl4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOg4ZkFS5HqVvJqpBAjFaIgtut0ux08yGlX9Nw7Kd_4w&oe=6714E58D"}, {"file_name": "migrated_image.png", "id": "195522608411895", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982494_402082740384263_2099764916368965632_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lvzGGtJkZicQ7kNvgHIBXZK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDI8KnGiwhzb8qqEpMid9MeYGx88oUscrRywsh-wMmljQ&oe=6714DB0F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/2MUf8G", "id": "731600067256685", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982720_731600070590018_2468976093432905728_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w43JrQWVop0Q7kNvgHpBJl3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCcoTeNuTUM9KHbMA6gDBgEgER9g5sAmC7w_vah5m2Tbw&oe=6714E143"}, "display_name": "Honor Everywhere", "keywords": ["honorflight", "honoreverywhere", "veterans", "military", "washington"], "long_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. These stories told through the eyes of our Veterans are a virtual alternative for aging and terminally ill men and women who aren't able to physically travel on an Honor Flight to see their memorials in Washington, DC. There is no replacement for an in-person Honor Flight but for those unable to physically travel, a virtual tour is one option. To support your local Honor Flight, please visit honorflight.org.", "short_description": "Step inside the World War II, Vietnam, Korea, and Women's Memorials in Washington, DC plus get an inside look at the USS Nimitz. This virtual tour program is for aging and terminally-ill Veterans & their families who are unable to physically travel on an Honor Flight to see their memorials in Washington, DC. These experiences are donated with love by StoryUP Studios, the makers of Healium, Central Missouri Honor Flight, Jaunt, Veterans United Foundation, & volunteers who shared their VR headsets"}]}, "developer_name": "StoryUP, Inc.", "developer_privacy_policy_url": "http://www.story-up.com/privacy/", "developer_terms_of_service_url": "http://www.story-up.com/privacy/", "publisher_name": "StoryUP, Inc.", "support_website_url": null, "website_url": "http://www.honoreverywhere.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1312414645903796"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "349169959063557"}]}, "baseline_offer": {"id": "349169959063557"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1561654800, "status": "PUBLISHED", "id": "349169959063557"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": [