ZCs3B064nMrhm4EtqMAXlBxgldybOUMPsOw&oe=671E22FD"}]}, "id": "984290482700737", "locale": "en_US", "screenshots": [{"file_name": "sc-3.png", "id": "277587457971137", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974848_277587461304470_3764641037519360146_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_4pXXqNh0QUQ7kNvgFekgD1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbo9HbRZTLyBj7LdG0OeY4a5PB9VudNLgkAaSsGuEmiw&oe=671E2B24"}, {"file_name": "sc-4.png", "id": "680282937446972", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974711_680282940780305_1136403132871418233_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Owl0k_Cio_8Q7kNvgGm2vug&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVmeWq1ryuINFlLaq4R4FaU0Iai6CID37dk0XiaBAULw&oe=671E0F93"}, {"file_name": "sc-1.png", "id": "1718511225239642", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974629_1718511228572975_6142526062715849289_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lgu9sOWjSG4Q7kNvgF1V0Vj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGJUb9j3HScjasTIcFynyRUJHD0LPXwp5zLexs1p3Kow&oe=671E14D1"}, {"file_name": "sc-2.png", "id": "798593488293358", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982468_798593491626691_4000679900781327174_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NEnDoTc3ZT4Q7kNvgEtFh3u&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBojwTGGQ0lI5Is0XtNMLlD7a7YQxe5-dJd4YjcuU5TEg&oe=671E3009"}, {"file_name": "sc-5.png", "id": "782892266579619", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_782892269912952_1367021943691056169_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02W2GxkOS8oQ7kNvgEyjI-D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBoFk59TNZU6Ugfag1IW06CBgJgOM3TIHLdZ5NGaNfaQA&oe=671E3492"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "8-cover.png", "id": "1237940290182617", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974497_1237940293515950_8379298951291711086_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FLM8cWWWjxgQ7kNvgF9F8f_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCEc0Yy-NJM4RQEz105oTM-QPZfIJsEHJEMUPvatkMOLA&oe=671E2B47"}, "display_name": "Retropolis 2: Never Say Goodbye", "keywords": [], "long_description": "*** Now available for early access! Grab the first episode and secure a season pass to all four thrilling episodes releasing later this year. Dive into the adventure today and become part of the Retropolis legend! ***\n\nThe story of Retropolis 2: Never Say Goodbye is set a year after the events depicted in The Secret of Retropolis, and continues the story of Philip Log, the hard-boiled robo-detective, and Jenny Montage, the automated femme fatale that just can\u2019t keep herself out of trouble. Nonetheless, Retropolis 2: Never Say Goodbye welcomes new visitors to the city of robots, and can be experienced as its own miniseries. \n\nThe Retropolis series is a user-friendly VR experience built from the ground up to support effortless VR interaction. Using Philip Log\u2019s extendo-arms, the player is able to collect items from afar, use them to overcome obstacles, and move the plot forward. On top of the first game\u2019s mechanics, Retropolis 2: Never Say Goodbye features enchanted logic puzzles, new rotation mechanics, and movement between different environments, offering a more challenging adventure with a substantially longer playtime.\n\nEven though set in a post-apocalyptic cityscape inhabited only by robots, all 3D assets in Retropolis 2: Never Say Goodbye were hand painted by living and breathing human beings, making each environment a stunningly detailed piece of art. With improved graphics and character animation, returning to Retropolis is more jaw dropping than ever.\n", "short_description": "***Early Access Available Now*** The critically acclaimed VR adventure series is back! Get lost in a sci-fi mystery spanning over four all-new episodes. Engage a battle of the minds with a sick new villain and use only your wit, your hovering inventory, and a pair of extendo-arms to uncover the truth."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.peanutbutton.net/privacy-policy-retropolis2", "developer_terms_of_service_url": "https://peanutbutton.net/terms", "publisher_name": "Peanut Button", "support_website_url": "http://peanutbutton.net/", "website_url": "http://peanutbutton.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2402621336571961"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "829558286036050"}, {"status": "PUBLISHED", "id": "2046317579143459"}, {"status": "PUBLISHED", "id": "1099062544509252"}, {"status": "PUBLISHED", "id": "431056236341716"}, {"status": "CANCELLED", "id": "975401600886323"}, {"status": "CANCELLED", "id": "374400572303244"}, {"status": "PUBLISHED", "id": "958709485235813"}, {"status": "PUBLISHED", "id": "942831707410928"}, {"status": "PUBLISHED", "id": "2478281739045234"}, {"status": "PUBLISHED", "id": "969119124270829"}]}, "baseline_offer": {"id": "2478281739045234"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "829558286036050"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinar