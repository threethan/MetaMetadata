de all kind of new feelings.\nLeaderboard - A leaderboard shows your position in each challenge, so you can try to dominate it.\nPer match rival - Each time you play a challenge, the system will pick a target rival score, and your main goal will be to overscore it.", "short_description": "Shoot, slash, dodge and survive to blade combats in multiple kind of challenges to test your skills and claim your place in the Omega Blade hall of fame."}]}, "developer_name": null, "developer_privacy_policy_url": "https://s3.us-east-2.amazonaws.com/omegablade.com/OmegaBlade/pp_eula.html", "developer_terms_of_service_url": null, "publisher_name": "Manuel Pasamontes Romera", "support_website_url": null, "website_url": "http://www.omegablade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2005274066301301"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "372216538094025"}, {"status": "PUBLISHED", "id": "250481976731330"}]}, "baseline_offer": {"id": "372216538094025"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1646081580, "status": "PUBLISHED", "id": "372216538094025"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6112443258868377", "version": "2.2"}, "id": "1147443009030138", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "Android