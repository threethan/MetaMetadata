y4MH3BsSx_77Oz8tXF8wszLfihdZ3TSPO4aP4-SnKnQ&oe=66E58956"}, {"file_name": "oculus_tracers.png", "id": "1667374133469905", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035370_1667374136803238_8215864800530603393_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tB6mkKbtOQIQ7kNvgFVoNag&_nc_ht=scontent.oculuscdn.com&_nc_gid=AriQ3v7yn7HVUIUfBBxQyBK&oh=00_AYCAnyNlGLAXqN4golTT2IwQ0x6eyx0tI4z4hXbSoJRSyg&oe=66E58DCD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974634_124670045997361_3416259062334842946_n.png", "id": "164683785204680", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_164683788538013_8122074535895363558_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K2GwP_QHICIQ7kNvgGWwbYa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AriQ3v7yn7HVUIUfBBxQyBK&oh=00_AYDJaNDSjAeG2z88gVg27ZC48tQ1EyOR_Ub1HYSwrY6KoA&oe=66E583F7"}, "display_name": "Omega Blade", "keywords": [], "long_description": ">Now available for free\n\nOmega Blade is a fast paced action game that let you test your skills in several kind of challenges.\nEach challenge sets a weapons set and match rules, and in each match a rival score will be picked as target to defeat. Try your best and claim the 1st place in each challenge leaderboard. \n\nFEATURES\nMulti range combat - Close, middle and lange range combat with flying droids and biped robots.\nFull body action - You set your own peace and combat style based on. Decide the way you want to play it.\nChallenges - Omega Blade don't set a single infinite wave, but a large number of challenges with different weapons, enemies, life, stage and goals combination to keep surprising the player and provide all kind of new feelings.\nLeaderboard - A leaderboard shows your position in each challenge, so you can try to dominate it.\nPer match rival - Each time you play a challenge, the system will pick a target rival score, and your main goal will be to overscore it.", "short_description": "Shoot, slash, dodge and survive to blade combats in multiple kind of challenges to test your skills and claim your place in the Omega Blade hall of fame."}]}, "developer_name": null, "developer_privacy_policy_url": "https://s3.us-east-2.amazonaws.com/omegablade.com/pp_eula.html", "developer_terms_of_service_url": null, "publisher_name": "Manuel Pasamontes Romera", "support_website_url": null, "website_url": "http://www.omegablade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "968284040481756"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462206_1553490121513485_902747156409289412_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gBNv6Kktu1sQ7kNvgEP7TNy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AriQ3v7yn7HVUIUfBBxQyBK&oh=00_AYDiFeqX_cnvtZK9VpP7qT1s0SnSqFQodFLlP_wC9YgMfg&oe=66E58C71"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Omega Blade", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1615506310, "lastRevision": {"nodes": [{"id": "2917918808438557", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3555872834525445", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "385229556020921"}, "iarc_email": null, "msrp": null, "translati