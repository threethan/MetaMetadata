-K3iW3hRCmiCn5bRi60Dl96hi_Sthz_-dCPrQ&oe=677E5B9D"}, {"file_name": "oculus_pasillolaser.png", "id": "850792232375763", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/75223482_850792235709096_3161857383354127169_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5Hn8HQ4ua4Q7kNvgEPNB3S&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCT0jbADjCKGSZvyFxERM8Jpou83yWIKdgzFFtkg2nHeQ&oe=677E5403"}, {"file_name": "oculus_sample01.png", "id": "1183625402054214", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75441575_1183625408720880_2570156203886391617_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ubJEqV5glKsQ7kNvgEkESp7&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYByhhCFGKgO10A3DzQxtzEXa89nC3e5EofJ4I6A4oh3BA&oe=677E7756"}, {"file_name": "oculus_tracers.png", "id": "1667374133469905", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39035370_1667374136803238_8215864800530603393_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KhqF_TPk7HYQ7kNvgEtEa_q&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCpozuVNqmRoOzW0g5e8DmhC5b-CB9GStsWqR3Ub73D3w&oe=677E7BCD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974634_124670045997361_3416259062334842946_n.png", "id": "164683785204680", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974901_164683788538013_8122074535895363558_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWntG78v_74Q7kNvgHViAdI&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAAamyGsoNyDHWLJ9Y0oQSGKUOujDNKlu3ICvQ5M6kddA&oe=677E71F7"}, "display_name": "Omega Blade", "keywords": [], "long_description": "Omega Blade is a fast paced action game that let you test your skills in several kind of challenges.\nEach challenge sets a weapons set and match rules, and in each match a rival score will be picked as target to defeat. Try your best and claim the 1st place in each challenge leaderboard. \n\nFEATURES\nMulti range combat - Close, middle and lange range combat with flying droids and biped robots.\nFull body action - You set your own peace and combat style based on. Decide the way you want to play it.\nChallenges - Omega Blade don't set a single infinite wave, but a large number of challenges with different weapons, enemies, life, stage and goals combination to keep surprising the player and provide all kind of new feelings.\nLeaderboard - A leaderboard shows your position in each challenge, so you can try to dominate it.\nPer match rival - Each time you play a challenge, the system will pick a target rival score, and your main goal will be to overscore it.", "short_description": "Shoot, slash, dodge and survive to blade combats in multiple kind of challenges to test your skills and claim your place in the Omega Blade hall of fame."}]}, "developer_name": null, "developer_privacy_policy_url": "https://s3.us-east-2.amazonaws.com/omegablade.com/OmegaBlade/pp_eula.html", "developer_terms_of_service_url": null, "publisher_name": "Manuel Pasamontes Romera", "support_website_url": null, "website_url": "http://www.omegablade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2005274066301301"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "925839459524481"}, {"status": "PUBLISHED", "id": "372216538094025"}, {"status": "PUBLISHED", "id": "250481976731330"}]}, "baseline_offer": {"id