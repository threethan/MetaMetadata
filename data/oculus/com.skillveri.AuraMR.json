Qh97GsVAQ7kNvgEqqVsF&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCIYqJisSTM2c_0H_d4bzsHHx4cGqhUMXuNV3bLVcNCIQ&oe=6712606D"}, {"file_name": "Welding.png", "id": "1600845170707826", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031333_1600845174041159_2014494973840674057_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IO1zb5nNrMoQ7kNvgG91Yjz&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBD2UMparXowYYUVoGKIheL37noUvzbayjxPjpwWo7qFQ&oe=671253E6"}, {"file_name": "Environemt.png", "id": "7291679210947063", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974568_7291679214280396_5314686185602698795_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9jk4cNI8dNcQ7kNvgE9vV8U&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBtUjqxFh16vzMyQZisQWWwAAD_k1H9_y1WdTCDa8mmng&oe=67122EDC"}, {"file_name": "Skillveri MR 1 (1).png", "id": "1405106287045876", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974662_1405106290379209_8227832584324635084_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vq2zuUCXWQMQ7kNvgHM-VND&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYB-NbRRpItehq2Y-5LFOUL--YghVEa7fqQRM6VoS-pk8w&oe=67126085"}, {"file_name": "Scorecard.png", "id": "1170678537282361", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/86661275_1170678540615694_5909688375189014404_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EOlSY_gYv-kQ7kNvgHog8O8&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCJ-j_CfsRHfSVAawvhV-DuP_f1B-coskQTqh-eyAmOUw&oe=67123E28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Final.png", "id": "727743049389286", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982563_727743052722619_5644352723781924565_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=15CbeQjJTVkQ7kNvgGqCmNe&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAGLM4j8d0TqSBX_PJBPXl7at8o5UC5pbvlpV3VBWvJGQ&oe=6712356E"}, "display_name": "Skillveri Aura MR Welding Simulator", "keywords": [], "long_description": "Weld on real world objects, see it inside your virtual world !\nSkillveri AURA MR welding simulator now blends the best of both worlds in mixed reality mode. \n\nSkillveri Welding simulator now brings the best in class VR experience blended into the actual real world environment of the user. \nReal welding guns sold separately by Skillveri can be used with this version of the software. Our VR welding simulators offer \n4 types of welding (GMAW, GTAW, SMAW, FCAW)\nChoice of different metal types & thickness\nAll welding positions\nLevel based lesson sequence from easy to difficult - unlock as your progress !\nLive feedback \nDetailed scorecard after each lesson\nProgress tracking and reports \n\nTrusted by Industry leaders across the world, and used by 50+ schools & community colleges across North America for their CTE programs. Learn more at www.skillveri.com\n\nExperience the Skillveri difference with a free trial licence.  \nNote : Request a trial license by filling the form at https://skillveri.com/skillveri-metaverse-workshop-trial-request-form/\n", "short_description": "Skillveri Welding simulator now brings the best in class VR experience blended into the actual real world environment of the user. \nReal welding guns sold separately by Skillveri can be used with this version of the software. Our VR welding simulators offer \n4 types of welding (GMAW, GTAW, SMAW, FCAW)\nChoice of different metal types & thickness\nAll welding positions\nLevel based lesson sequence from easy to difficult\nLive feedback \nDetailed scorecard after each lesson\nProgress tracking and report"}]}, "developer_name": "Skillveri Inc", "developer_privacy_policy_url": "https://skillveri.com/skillveri-aura-mr-welding-simulator-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Skillveri Inc", "support_website_url": null, "website_url": "https://www.skillveri.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags