953816079813_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vO6gofXqPFsQ7kNvgEFrBpt&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYCDXXCnhm4aDClZs7bbYHUHb8xyfyt1eAq2xish7Ge70Q&oe=66DEF5ED"}, {"file_name": "Welding.png", "id": "1600845170707826", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031333_1600845174041159_2014494973840674057_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_5DNw-gQoj8Q7kNvgGlDdog&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYCmowFLEj7A65kqqwlE-CEVHlL0oiHT9MJ6l0Qj4Ye3_A&oe=66DEE966"}, {"file_name": "Environemt.png", "id": "7291679210947063", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974568_7291679214280396_5314686185602698795_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YqK507j3bv8Q7kNvgFCK4Ub&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYA0EF-rYLsA9Jn9do3nPAbzRq24PxW8GBKBWipKC7AEPA&oe=66DEC45C"}, {"file_name": "Skillveri MR 1 (1).png", "id": "1405106287045876", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974662_1405106290379209_8227832584324635084_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QwGWvcQiv44Q7kNvgHdShvi&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYCzof1KturWc4Syo6ZdHLKJpI5WWDLNZTELiU4WGkbNNA&oe=66DEF605"}, {"file_name": "Scorecard.png", "id": "1170678537282361", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86661275_1170678540615694_5909688375189014404_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C_6KFZ2yox0Q7kNvgG6Xo8r&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYBUh3BLyf1K6WoraP2LK-di8p1LttT_nH4ddRaMFSIU9A&oe=66DED3A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Final.png", "id": "727743049389286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982563_727743052722619_5644352723781924565_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o3xJL4WXM4QQ7kNvgGxsknu&_nc_ht=scontent.oculuscdn.com&_nc_gid=Arukk22WW8rcE8tXoEj092K&oh=00_AYCZHrzRfiemwljWKEoWQXoKKyaupDaWDq18c_bWG2B0PQ&oe=66DECAEE"}, "display_name": "Skillveri Aura MR Welding Simulator", "keywords": [], "long_description": "Weld on real world objects, see it inside your virtual world !\nSkillveri AURA MR welding simulator now blends the best of both worlds in mixed reality mode. \n\nSkillveri Welding simulator now brings the best in class VR experience blended into the actual real world environment of the user. \nReal welding guns sold separately by Skillveri can be used with this version of the software. Our VR welding simulators offer \n4 types of welding (GMAW, GTAW, SMAW, FCAW)\nChoice of different metal types & thickness\nAll welding positions\nLevel based lesson sequence from easy to difficult - unlock as your progress !\nLive feedback \nDetailed scorecard after each lesson\nProgress tracking and reports \n\nTrusted by Industry leaders across the world, and used by 50+ schools & community colleges across North America for their CTE programs. Learn more at www.skillveri.com\n\nExperience the Skillveri difference with a free trial licence.  \nNote : Request a trial license by filling the form at https://skillveri.com/skillveri-metaverse-workshop-trial-request-form/\n", "short_description": "Skillveri Welding simulator now brings the best in class VR experience blended into the actual real world environment of the user. \nReal welding guns sold separately by Skillveri can be used with this version of the software. Our VR welding simulators offer \n4 types of welding (GMAW, GTAW, SMAW, FCAW)\nChoice of different metal types & thickness\nAll welding positions\nLevel based lesson sequence from easy to difficult\nLive feedback \nDetailed scorecard after each lesson\nProgress tracking and report"}]}, "developer_name": "Skillveri Inc", "developer_privacy_policy_url": "https://skillveri.com/skillveri-aura-mr-welding-simulator-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Skillveri Inc", "support_w