_119183225431057_4735090556374351872_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MmE7Wxr04u4Q7kNvgHi2FI2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdKHCVfAfNKYmd0_WSRXSmK&oh=00_AYAaGZO0EjPEf_G_P6GtE_wxNJJwGAyIISxU_7wdZjMY9Q&oe=66F563F9"}, {"file_name": "migrated_image.png", "id": "573398006597569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162687_287691638397920_836288316453158912_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SxaAEm2fSagQ7kNvgGyB0-i&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdKHCVfAfNKYmd0_WSRXSmK&oh=00_AYCZuo1qrTyCJf3hkfngytBlMKjU82i_mvnDVH9QKRA3mg&oe=66F53A32"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Our Star System GearVR", "keywords": ["planets", "sun", "universe", "space", "solar"], "long_description": "The rotation of the screen follows the movement of your head, providing a 360 degree experience. Thanks to the development of technology, this computer-generated virtual reality is very difficult to distinguish from reality.\nManaging the application is really simple. You can easily select the menu items or the planets with the centered cursor.\nThis interactive educational VR software introduces the solar system, the planets and the satellites. Users can get interesting facts about the space around us, our planet's past, present and future. It is recommended for primary and secondary school students. This virtual reality space adventure is an unforgettable experience.", "short_description": "Discover the star system virtually - Put the VR glasses on and let the virtual reality impress you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://idoctum.com/en/privacy-policy", "developer_terms_of_service_url": "https://idoctum.com/en/", "publisher_name": "Bal\u00e1zs-Di\u00e1k Ltd", "support_website_url": null, "website_url": "https://idoctum.com/en/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subsc