5/11162687_287691638397920_836288316453158912_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0GuljWPsIiYQ7kNvgEM06nu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAT61WKVg6W9s7NuV2MLcYFY_QAbu_KgHTmGO0EBS-wfQ&oe=66FA8032"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Our Star System GearVR", "keywords": ["planets", "sun", "universe", "space", "solar"], "long_description": "The rotation of the screen follows the movement of your head, providing a 360 degree experience. Thanks to the development of technology, this computer-generated virtual reality is very difficult to distinguish from reality.\nManaging the application is really simple. You can easily select the menu items or the planets with the centered cursor.\nThis interactive educational VR software introduces the solar system, the planets and the satellites. Users can get interesting facts about the space around us, our planet's past, present and future. It is recommended for primary and secondary school students. This virtual reality space adventure is an unforgettable experience.", "short_description": "Discover the star system virtually - Put the VR glasses on and let the virtual reality impress you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://idoctum.com/en/privacy-policy", "developer_terms_of_service_url": "https://idoctum.com/en/", "publisher_name": "Bal\u00e1zs-Di\u00e1k Ltd", "support_website_url": null, "website_url": "https://idoctum.com/en/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "hu"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_inte