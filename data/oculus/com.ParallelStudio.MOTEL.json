rated_image.png", "id": "529191211332592", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162683_433253460392390_3729995761602002944_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H93keHmc3j4Q7kNvgHVPmVt&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIskEopiGM3TQDgAMOl1Ua4VAq4R3K6_mnzufIjO3rDw&oe=66DACD17"}]}, "id": "512839636072114", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "1607033566103006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162703_485815874950803_1715822036_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mhDSLshqcagQ7kNvgH8EXJQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPisWEShiSG6o20RhC-SG00WoyjDx-9P9d-pzJTRp3HA&oe=66DAE557"}, {"file_name": "migrated_image.png", "id": "568188487380623", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448899_1155455737837776_10203191_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=II3_gHOO-k4Q7kNvgGAAyZp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCq_ybE0gxAAzFM6KAIMdqJQi-7GtaKFJXlXzCKa3GdaQ&oe=66DADED1"}, {"file_name": "migrated_image.png", "id": "544703409511940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12522199_131697227244106_814250366_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FWsrKyq-SE4Q7kNvgGXr-72&_nc_ht=scontent.oculuscdn.com&oh=00_AYDT5-XNmCTkdHeSDrQ2jRgP3VPYhyCrCJ0GffvMlVb3kQ&oe=66DAD608"}, {"file_name": "migrated_image.png", "id": "264628114537266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12680260_240524789656314_1180019102_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PaawkBn4ThUQ7kNvgGLHHBu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhZFRGJRS7W1J1XAqaRPt-n_ohpRx-ty87OAQvRsfNYg&oe=66DAFCB6"}, {"file_name": "migrated_image.png", "id": "160862711668837", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448853_1318777048151234_251025723_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JfXHRnbtytAQ7kNvgHfcy1N&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYxY46KFxSwZLOmjyBcyyHPO9XtVSh9bmhlsw8jkuUqA&oe=66DAF8A4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Dark Days", "keywords": ["Thriller", "Horror", "Adventure", "Escaperoom", "Storydriven"], "long_description": "/!\\ Note: 2GB of your device storage is needed to complete the install process (final size: 668 MB)\n\n\"Dark Days is probably the most visually complete game on the Gear VR\" -MobileVRDaily\n\n\"A Creepy and Surprising Psychological Thriller\" -UploadVR\n\nThe team that created White Night has gathered once again to offer you a hauntingly unique VR experience. Somewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful and smart! Something is roaming around you... \n\n\u274f A supernatural adventure full of revelations \n\u274f Accessible gameplay and random puzzles \n\u274f Be prepared for jump scares! \n\nTechnical contact : contact@parallel-studio.com", "short_description": "\"Dark Days is probably the most visually complete game on the Gear VR\" -MobileVRDaily Somewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful and smart! Something is roaming around you..."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.parallel-studio.com/", "developer_terms_of_service_url": "http://www.parallel-studio.com/", "publisher_name": "Oculus Studio", "support_website_url": null, "website_url": "http://www.parallel-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": []