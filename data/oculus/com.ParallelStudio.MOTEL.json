4.5771-25/11162703_485815874950803_1715822036_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nDo6g3xyn0oQ7kNvgGs_4xV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCAFXePf_wfqQi8_AGgiUcUhBtiJ42X78YVjqmpsMhDKg&oe=674AF4D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "253623358349253", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12504830_253623361682586_413589518_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sbB3iYU_vZIQ7kNvgGiBqy6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvUgY42yELv4PS05GgG5p9627AS7nPV91ZWZ4e0mQUQQ&oe=674B06D0"}, "display_name": "Dark Days", "keywords": ["Thriller", "Horror", "Adventure", "Escaperoom", "Storydriven"], "long_description": "The team that created White Night has gathered once again to offer you a hauntingly unique VR experience.\n\nSomewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful and smart! Something is roaming around you, a terrifying presence that you need to keep away from by all means.\n\n\u274f A supernatural adventure full of revelations that tells the story of Jade Lacroix, a lost young writer who has to investigate weird events in order to survive, while fighting her inner fears.\n\n\u274f Accessible gameplay and random puzzles inspired by escape rooms games\n\n\u274f A terrifying presence will haunt your progression\u2026 be prepared for jump scares!", "short_description": "Somewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful an