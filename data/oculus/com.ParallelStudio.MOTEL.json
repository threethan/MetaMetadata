.5771-25/11162703_485815874950803_1715822036_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Ghso4VbJcsQ7kNvgFAydhw&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB5jc7EiHrrFzZzin2RlDtOnPfSK5dmpSILpeF9WTNCIQ&oe=6777C7D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "253623358349253", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/12504830_253623361682586_413589518_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EIXuES53xGgQ7kNvgEC0fuj&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCh_ek4K3V0y0Y7SqJ0v5WPcDTjJjOpC_X0d3b21qT7aA&oe=6777D9D0"}, "display_name": "Dark Days", "keywords": ["Thriller", "Horror", "Adventure", "Escaperoom", "Storydriven"], "long_description": "The team that created White Night has gathered once again to offer you a hauntingly unique VR experience.\n\nSomewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful and smart! Something is roaming around you, a terrifying presence that you need to keep away from by all means.\n\n\u274f A supernatural adventure full of revelations that tells the story of Jade Lacroix, a lost young writer who has to investigate weird events in order to survive, while fighting her inner fears.\n\n\u274f Accessible gameplay and random puzzles inspired by escape rooms games\n\n\u274f A terrifying presence will haunt your progression\u2026 be prepared for jump scares!", "short_description": "Somewhere between Twin Peaks and The X-\u00adFiles, Dark Days is a new fantastic virtual reality adventure. You will have to discover what\u2019s going on with an eerie desert motel and its surroundings by solving a number of puzzles. Immerse yourself in the rich environments you will come across, but be careful and smart! Something is roaming around you, a terrifying presence that you need to keep away from by all means."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Oculus Studio", "support_website_url": null, "website_url": "http://www.parallel-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["HORROR", "NARRATIVE", "ADVENTURE", "EXPLORATION", "PUZZLE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "zh_CN", "ko", "de", "es_MX"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "655403412250920"}}]}, "scheduled_offers": {"count": 44, "nodes": [{"status": "PUBLISHED", "id": "142594936361902"}, {"status": "PUBLISHED", "id": "639319273177064"}, {"status": "PUBLISHED", "id": "1390271581109019"}, {"status": "PUBLISHED", "id": "637834363592842"}, {"status": "PUBLISHED", "id": "984534198609848"}, {"status": "PUBLISHED", "id": "473163233224149"}, {"status": "PUBLISHED", "id": "378406829474733"}, {"status": "PUBLISHED", "id": "2141371562816617"}, {"status": "PUBLISHED", "id": "1150011318713409"}, {"status": "CANCELLED", "id": "1433389413403294"}, {"status": "PUBLISHED", "id": "1815858598643586"}, {"status": "PUBLISHED", "id": "558548877964392"}, {"status": "CANCELLED", "id": "695627900634605"}, {"status": "PUBLISHED", "id": "2200896633262562"}, {"status": "PUBLISHED", "id": "1029115180531602"}, {"status": "PUBLISHED", "id": "635225576656820"}, {"status": "PUBLISHED", "id": "308213236768212"}, {"status": "CANCELLED", "id": "358674957926485"}, {"status": "CANCELLED", "id": "20148682254146