nd leap through vibrant environments as you connect and compete with friends in a dynamic, engaging world. \ud83c\udf34\ud83c\udfae Dive into lush jungles, scale towering trees, and navigate treacherous terrains with intuitive movement mechanics that make you feel like a real gorilla. \ud83c\udf3f\ud83c\udf1f Form alliances, challenge rivals, and explore a variety of game modes that promise endless fun and excitement. Get ready to go bananas with Balin TAg! \ud83c\udf4c\ud83c\udf89", "short_description": "Balin Tag is an exhilarating, social VR game that uses innovative gorilla locomotion for a truly immersive experience. Swing, climb, and leap through vibrant environments as you connect and compete with friends in a dynamic, engaging world. Get ready to go bananas!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/balintag/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gamers StudiosVR", "support_website_url": null, "website_url": "https://sites.google.com/view/balintag/homepage", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8193878280670210"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3396809627282876"}]}, "baseline_offer": {"id": "3396809627282876"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 172063298