44233_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P8swF5K7LkMQ7kNvgH738lJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ap7a2c_MB_IKd0Vk6Xyp7Mo&oh=00_AYBVn3VFVJPQ_KyFIQ6-cJaJ_7Eyr_KfYrrfCuGSnuC1vQ&oe=66F0013E"}, {"file_name": "Still5.png", "id": "1851016308697394", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334065_1851016315364060_8866555514133823335_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iHMcvMj2ncgQ7kNvgEuWzo_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ap7a2c_MB_IKd0Vk6Xyp7Mo&oh=00_AYAjF8A1nz1qjBTEUWx64rqtK8cxt1St2Hman_g_QERIcA&oe=66F00875"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_Horizontal.png", "id": "422699117329509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282168_422699120662842_4732102299172740306_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uGiBKUtAhHkQ7kNvgHQZhIY&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ap7a2c_MB_IKd0Vk6Xyp7Mo&oh=00_AYCyO1SsFTX7dXZlFc_7gUqTmGkE1_8XCWHK_t3VyuqjsQ&oe=66EFF710"}, "display_name": "Body of Mine", "keywords": ["Body", "Gender", "Trans", "LGBT", "Queer"], "long_description": "Body of Mine is an award-winning, full-body VR experience that invites you to inhabit the body of another gender and discover stories from transgender individuals.\n\nCombining body, face, and eye tracking with personal interviews of transgender individuals, the experimental storytelling experience allows you to hear, discover, and experience stories of gender dysphoria and euphoria.\n\nWinner of the Producers Guild Innovation Award, and with accolades from BAFTA, SXSW, and Games for Change, Body of Mine \u201cbreaks through a psychological barrier that few pieces of media ever have\u201d (WIRED), taking you on a profound journey of what it means to be a human being.\n\n\n\n{475108011677489}", "short_description": "Body of Mine invites you to step into the body of another gender and discover stories from transgender individuals.\n\n"}]}, "developer_name": "Kost, Inc. & Agile Lens", "develope