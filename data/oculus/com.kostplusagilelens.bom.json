_ht=scontent.oculuscdn.com&_nc_gid=ATlsD_CzK8weKB8BDCmefo9&oh=00_AYCWW4cmuSGiza_wbYMRmcdSI93fTFpjJA55ZdSuTHutEA&oe=66E04652"}, {"file_name": "Still4.png", "id": "300022469870024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299164_300022473203357_5177818308064844233_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dDwt8oZIXzIQ7kNvgHKgHyY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATlsD_CzK8weKB8BDCmefo9&oh=00_AYDE9sAAqJXrLR2W5VgWMK84LbME0ABk3rcyKP2qOOj3nw&oe=66E02F3E"}, {"file_name": "Still5.png", "id": "1851016308697394", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334065_1851016315364060_8866555514133823335_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UyEWXTvca6EQ7kNvgEzm7yk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATlsD_CzK8weKB8BDCmefo9&oh=00_AYDO-qEMoAoKxEN5eiSwFrBAS2NeMJC9u01ciCDuZtATaQ&oe=66E03675"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_Horizontal.png", "id": "422699117329509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282168_422699120662842_4732102299172740306_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mNUNE55WbqcQ7kNvgFixBvg&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATlsD_CzK8weKB8BDCmefo9&oh=00_AYD6chJ55IUxR2eQvZ0TSU4fN9gaCkseQ5tkZFu8WESPBw&oe=66E02510"}, "display_name": "Body of Mine", "keywords": ["Body", "Gender", "Trans", "LGBT", "Queer"], "long_description": "Body of Mine is an award-winning, full-body VR experience that invites you to inhabit the body of another gender and discover stories from transgender individuals.\n\nCombining body, face, and eye tracking with personal interviews of transgender individuals, the experimental storytelling experience allows you to hear, discover, and experience stories of gender dysphoria and euphoria.\n\nWinner of the Producers Guild Innovation Award, and with accolades from BAFTA, SXSW, and Games for Change, Body of Mine \u201cbreaks through a psychological barrier that few pieces of media ever have\u201d (WIRED), taking you on a profound journey of what it means to be a human being.\n\n\n\n{475108011677489}", "short_description": "Body of Mine invites you to step into the body of another gender and discover stories from transgender individuals.\n\n"}]}, "developer_name": "Kost, Inc. & Agile Lens", "developer_privacy_policy_url": "https://kost.ai/privacy", "developer_terms_of_service_url": null, "publisher_name": "Kost, Inc.", "support_website_url": "https://www.bodyofminevr.com/help", "website_url": "https://www.bodyofminevr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1283811691952063"}, {"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7712124185497236"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1035906714475690"}, {"status": "PUBLISHED", "id": "1616126055899825"}]}, "baseline_offer": {"id": "1616126055899825"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726772400, "status": "PUBLISHED", "id": "1035906714475690"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7753794557996865", "version": "1.0"}, "id": "1025079695853309", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7712124182163903", 