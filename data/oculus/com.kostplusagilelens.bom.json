3335_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XFuefUKkxjkQ7kNvgHnOwwi&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDRN7M0xR34zeWP449JR3SrByTpdYcIAtCMU-2_ziMWUw&oe=67124F75"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_Horizontal.png", "id": "422699117329509", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75282168_422699120662842_4732102299172740306_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z5-eAJKEvloQ7kNvgG-wOde&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAbG4-FeuWBGhGP6dRB9a5yJJiadzp_Jz2v7fbhTO9Jiw&oe=67123E10"}, "display_name": "Body of Mine", "keywords": ["Body", "Gender", "Trans", "LGBT", "Queer"], "long_description": "Body of Mine is an award-winning, full-body VR experience that invites you to inhabit the body of another gender and discover stories from transgender individuals.\n\nCombining body, face, and eye tracking with personal interviews of transgender individuals, the experimental storytelling experience allows you to hear, discover, and experience stories of gender dysphoria and euphoria.\n\nWinner of the Producers Guild Innovation Award, and with accolades from BAFTA, SXSW, and Games for Change, Body of Mine \u201cbreaks through a psychological barrier that few pieces of media ever have\u201d (WIRED), taking you on a profound journey of what it means to be a human being.\n\n\n\n{475108011677489}", "short_description": "Body of Mine invites you to step into the body of another gender and discover stories from transgender individuals.\n\n"}]}, "developer_name": "Kost, Inc. & Agile Lens", "developer_privacy_policy_url": "https://kost.ai/privacy", "developer_terms_of_service_url": null, "publisher_name": "Kost, Inc.", "support_website_url": "https://www.bodyofminevr.com/help", "website_url": "https://www.bodyofminevr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "cont