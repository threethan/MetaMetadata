44233_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DfszuqZnUr8Q7kNvgHPIjc0&_nc_ht=scontent.oculuscdn.com&_nc_gid=An9GU7TggB9CQfatdATAf8F&oh=00_AYDgBlyUj0jABnYu8jT_PjLKQpu60uF1tQG4orRvydDAxg&oe=66F698BE"}, {"file_name": "Still5.png", "id": "1851016308697394", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334065_1851016315364060_8866555514133823335_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9y6EfdlxZSoQ7kNvgFX6RFb&_nc_ht=scontent.oculuscdn.com&_nc_gid=An9GU7TggB9CQfatdATAf8F&oh=00_AYCozyE7Mu0Pe9pWA4EoQFpm7kms5f1HDwPlT4s6uhTyPA&oe=66F69FF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_Horizontal.png", "id": "422699117329509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282168_422699120662842_4732102299172740306_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SqWeQPye5RUQ7kNvgGjQ6Yl&_nc_ht=scontent.oculuscdn.com&_nc_gid=An9GU7TggB9CQfatdATAf8F&oh=00_AYBdkUSulcny_oTrTTInSyx_DRiyeWbT6fG04YJPwnNRCQ&oe=66F68E90"}, "display_name": "Body of Mine", "keywords": ["Body", "Gender", "Trans", "LGBT", "Queer"], "long_description": "Body of Mine is an award-winning, full-body VR experience that invites you to inhabit the body of another gender and discover stories from transgender individuals.\n\nCombining body, face, and eye tracking with personal interviews of transgender individuals, the experimental storytelling experience allows you to hear, discover, and experience stories of gender dysphoria and euphoria.\n\nWinner of the Producers Guild Innovation Award, and with accolades from BAFTA, SXSW, and Games for Change, Body of Mine \u201cbreaks through a psychological barrier that few pieces of media ever have\u201d (WIRED), taking you on a profound journey of what it means to be a human being.\n\n\n\n{475108011677489}", "short_description": "Body of Mine invites you to step into the body of another gender and discover stories from transgender individuals.\n\n"}]}, "developer_name": "Kost, Inc. & Agile Lens", "develope