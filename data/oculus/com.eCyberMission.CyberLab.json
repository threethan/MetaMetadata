s created. From the giant airplanes to being able to see thru walls, the eCYBERMISSION VR Lab introduces users to the vast possibilities of STEM.", "short_description": "A virtual reality lab taking people thru the process of Department of Defense problem solving."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1IS97uZsO7t1VsQVKRywh70irnEUtDvKJQ-eYquisSOs/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ROAMVR", "support_website_url": null, "website_url": "https://www.roam-vr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8426409647423353"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "824425056503561"}]}, "baseline_offer": {"id": "824425056503561"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727370000, "status": "PUBLISHED", "id": "824425056503561"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8568707959860187", "version": "0.0.35"}, "id": "875284504478892", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8266267093437610", "is_concept": false, "latest_released_binary": {"__typen