3-1.oculuscdn.com/v/t64.5771-25/38974907_521592813866465_1859723888539701168_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4qRqpJkapI8Q7kNvgGJ4RmX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCuAdbZFxZLo9plu4vTuTAqg7Wam1KYlyXMDyaTPeDojg&oe=677A793E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "eCYBERMISSION VR Lab", "keywords": ["ecyber", "AEOP", "science", "experiment", "stem"], "long_description": "A Virtual Reality laboratory taking learners from the problem a soldier might face in the field, to the solution, via scientific method. It is designed to introduce people to the problems a scientist working for the Department of Defense might face, and how they solve them. This is achieved with videos, immersive science, and working out problems by trial and error.\n\nAlong the way, learners will understand other initiatives STEM learning within a DoD lab has created. From the giant airplanes to being able to see thru walls, the eCYBERMISSION VR Lab introduces users to the vast possibilities of STEM.", "short_description": "A virtual reality lab taking people thru the process of Department of Defense problem solving."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1IS97uZsO7t1VsQVKRywh70irnEUtDvKJQ-eYquisSOs/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ROAMVR", "support_website_url": null, "website_url": "https://www.roam-vr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "s