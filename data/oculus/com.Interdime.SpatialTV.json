QWv4nPEkZ0Q7kNvgHU1Vs6&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBN9tTfVh2pKte8dzHtr_1KLaX-V7HpYrFQA2gMmJHl8Q&oe=670BA667"}, {"file_name": "icons_2560.png", "id": "837700041651002", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031639_837700044984335_7632039083082594382_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GryHEgLgvJEQ7kNvgHCot5B&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAGLW-giEr0zcs-0BpY6bkulsf1ZU5sJ1YRfZSHfsF8Sg&oe=670B9F52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape (2).png", "id": "1728150691275503", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035347_1728150694608836_5619279543287794777_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zqi71zdlzcMQ7kNvgGcGs5U&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCg4yqGm9hyTf_KWOOea34Ds7nZLOE-o-sztbCOJVJBVQ&oe=670BC78D"}, "display_name": "Spatial TV", "keywords": ["Disney", "Video", "Max", "YouTube", "Hulu"], "long_description": "Spatial TV is the ultimate app to watch movies in VR. People love the amazing ambient light that transforms your home into a movie theater. \n\n**Dim your environment and immerse in the amazing lighting effect**\n{852842470242705}\n\n**Supports YouTube, Disney+, HBO Max, Hulu, Apple TV+ and more**\n\nThere's also a built-in browser to access any video you love from the internet!\n\n{1152430492726135}\n\n**You will also love**\n\n- Optimized screen clarity with 3840 x 2160 super-sampled pixels per eye\n\n- Making the screen really huge and enjoying your favorite videos while lying back\n\n- Super flexible screen placement and intuitive design\n\n**Enjoy the breathtaking ambient light now!**\n\n{1150597832678777}\n\nNote: Netflix is not supported on Spatial TV yet", "short_description": "Spatial TV brings Real-time Lighting to your AR Movie experience\n\n- Lie down and enjoy your favorite video on a huge screen\n\n- Feel the magic of real-time screen lighting\n\n- Maximum sharpness with 3840 x 2160 super-sampled pixels\n\n- Supports YouTube, Plex, HBO Max, Hulu, Apple TV+, Disney+, Crunchyroll and more\n\n- Access any web-based content with the built-in browser \n\nNote: Netflix is not supported on Spatial TV yet\n\nFor support, please join our discord: https://discord.gg/G6J67kW2Vb"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spatial-tv.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Interdime", "support_website_url": null, "website_url": "https://spatial-tv.app/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}, {"id": "384928226018505"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7938941889507460"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035347_1013051550355305_6969433255281084616_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQ-TJjtMQZEQ7kNvgFQwvIh&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC5yu8Bz32_KGDiYrZVWPu6pU8wkWnXeCa2kKTO3mG0mA&oe=670BBD74"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spatial TV", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Utilities", "id": "393222478507326"}, {"topic_name": "Media & Streaming", "id": "384928226018505"}], "release_date": 1708640940, "lastRevision": {