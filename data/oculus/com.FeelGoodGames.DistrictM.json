culuscdn.com/v/t64.5771-25/65397209_1389489914745568_5618545857196378289_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xm3CG1YrJcEQ7kNvgEK3nku&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCW6OOx5mJ--392MHSsukuQbOwkuFw5he4mqrEv_st4SQ&oe=67388E74"}, {"file_name": "Screenshot 5 - More Track.png", "id": "3689859557807096", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982717_3689859561140429_3474763701630351775_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ETTOfZT8qNMQ7kNvgEj8yuC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-AGbOyEHdD4id7iUEUFGy4XPNRpEOwR7DRG2selk-lw&oe=67388C99"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art.png", "id": "292551388950776", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221327_292551392284109_5502955673277100807_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kwIeusFYlJMQ7kNvgG6VpDL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJo3Jwd8pNysfuWIzxtuheMYJLTwVwPpGEC4aIGNm95A&oe=673867DB"}, "display_name": "District M", "keywords": [], "long_description": "We're reimagining the classic platformer for VR! \n\nYou play as a stunt cameraman trying to capture the coolest shots of the skater as you guide him through a colorful world filled with challenging puzzles. From chill, lo-fi maps to challenging jazz compositions, District M will toss hardcore platformer puzzles at you and push your mental and physical creativity to the limit! \n\nIt's unlike any VR game you've seen before.\n", "short_description": "Rhythm meets platformer in District M! Dance to a banger soundtrack and show off your control as you stylishly guide a skater through smooth, lovingly handcrafted levels. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://autovrse.in/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "AutoVRse", "support_website_url": null, "website_url": "https://twitter.com/districtmVR", "category": "GAMES", "comfort_r