_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XMoN5t46Kd4Q7kNvgH-kag7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgwrxwQwiYt-b37IG2puuSs&oh=00_AYDD0SJxjuOz_w57XZvnFlkY1jGL00AlEDEZceM2Iv5B9g&oe=66E6B9EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape AppLab2.png", "id": "620208195712325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_620208199045658_1632503818660487642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SnHSUjcIfzwQ7kNvgF2ygtD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgwrxwQwiYt-b37IG2puuSs&oh=00_AYDCYEcjJEi6LMOWB5pdgGs-Ppkepcjv13jmFzhZUhUgUw&oe=66E6BA08"}, "display_name": "District M", "keywords": [], "long_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more.\n\nIf you have any feedback/suggestions or face any issue, please ping us on Discord. We really want to build a great game and we can\u2019t do it without your support.\n\nDo join our discord to meet other players, our devs and playtest more of the game till we roll out.\n\nDiscord link: discord.gg/FunVt2Y4wQ\n\nWelcome to District M :)", "short_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more."}]}, "developer_name": null, "developer_privacy_policy_url": "ht