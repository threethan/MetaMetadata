-2.oculuscdn.com/v/t64.5771-25/38974583_288559199888594_2922592053255209935_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M5AAGPcE0HAQ7kNvgGwGrmk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtRt0d86IQduNmR04zw87JjjRrpmUTwxFX7aSMGtogTg&oe=670CF71C"}]}, "id": "1651352921970934", "locale": "en_US", "screenshots": [{"file_name": "3.png", "id": "349850896868104", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982665_349850903534770_4863273483687921289_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1dE14gu831oQ7kNvgGVBPxp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyw-I5rKtz1W5xg-KgX3XB44V4fX7GTjakl-N_Dao3Ig&oe=670D09D2"}, {"file_name": "5.png", "id": "943657103007405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974561_943657106340738_7480421357867095623_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wuWjzm2fuZYQ7kNvgGcXXmP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAoTpBbJVwGzu-WsAOIOGnrnxqEThdPG2NoJCZa0Gd6CA&oe=670D1EBF"}, {"file_name": "1.png", "id": "500164345041433", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_500164348374766_6413048362635655150_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o5XsS9a75kMQ7kNvgHmO6u7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBe-VDeIvBeqY8J48evO3-pOYVdgAfdcVljcTWV9uenQA&oe=670D128F"}, {"file_name": "2.png", "id": "728708888094492", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974528_728708891427825_2008148098693216975_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mAai8U4ZAFoQ7kNvgH3ZOIm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3APBaOyJtTc37MphgTIqsq2mQRGrQcDb4Etu4aPSuTA&oe=670CF2C6"}, {"file_name": "4.png", "id": "672129227250807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_672129233917473_5164729973480497819_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vvvbs5nVMx0Q7kNvgF9A90B&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmVNXwDO9SkJ7U7ejQz3cswHr2kkIOxqlYN7DvPLcRsw&oe=670CF56B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape AppLab2.png", "id": "620208195712325", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_620208199045658_1632503818660487642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzjQ3VBU9LsQ7kNvgE9ZKCF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfCcE5anER0s2nO3L_YeNnbPvSMo8zaL_H5JGeBy8-Vg&oe=670CF588"}, "display_name": "District M", "keywords": [], "long_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more.\n\nIf you have any feedback/suggestions or face any issue, please ping us on Discord. We really want to build a great game and we can\u2019t do it without your support.\n\nDo join our discord to meet other players, our devs and playtest more of the game till we roll out.\n\nDiscord link: discord.gg/FunVt2Y4wQ\n\nWelcome to District M :)", "short_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.staging.districtmvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AutoVRse", "support_website_url": null, "website_url": "https://twitter.com/districtmVR", "category": "GAMES", "comfort_rating": "NOT_RAT