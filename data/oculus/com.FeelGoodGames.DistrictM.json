-2.oculuscdn.com/v/t64.5771-25/38974583_288559199888594_2922592053255209935_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ofcn1HUiOJ0Q7kNvgFSX52e&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDe-zJYe32uzi-L8rIZpMJxmgi-KOqOS9dGY_Tg0WsNlw&oe=671F6C1C"}]}, "id": "1651352921970934", "locale": "en_US", "screenshots": [{"file_name": "3.png", "id": "349850896868104", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982665_349850903534770_4863273483687921289_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f6rvV1SV-vYQ7kNvgG_41ao&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwO8r1EGeg-GX9NZeRnZnTYhRIkFO9t6mdwRX8A6xddw&oe=671F7ED2"}, {"file_name": "5.png", "id": "943657103007405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974561_943657106340738_7480421357867095623_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wfr9ddZ1OgkQ7kNvgGyOA1Q&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHpxEiaG1FgqafU6b9PodTp-WdqCXWQCowtLM6V8OOcw&oe=671F93BF"}, {"file_name": "1.png", "id": "500164345041433", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_500164348374766_6413048362635655150_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cfTBCozr_tgQ7kNvgHvARqF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5w1Bj9hCmNDxQuwTDzdaruWQVmgeraHPpe2pdiin6kw&oe=671F878F"}, {"file_name": "2.png", "id": "728708888094492", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974528_728708891427825_2008148098693216975_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z8-xIDTAiJAQ7kNvgHdGh7Z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVA0c1fRGr344jqKxC91IfgnCkcqdmu8K1OureVc33mw&oe=671F67C6"}, {"file_name": "4.png", "id": "672129227250807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_672129233917473_5164729973480497819_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wOTutlHYQbEQ7kNvgGWsPls&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDjXjIYK_LZwjj6xb2XIp-aZe8vcrBewvr_-ouA3e-1-A&oe=671F6A6B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape AppLab2.png", "id": "620208195712325", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_620208199045658_1632503818660487642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=otIgxZlQKTAQ7kNvgEUfg1o&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUf9dO6z3eMidd8DHPplHORYao9RbmM_1eJAvDrj-6ng&oe=671F6A88"}, "display_name": "District M", "keywords": [], "long_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more.\n\nIf you have any feedback/suggestions or face any issue, please ping us on Discord. We really want to build a great game and we can\u2019t do it without your support.\n\nDo join our discord to meet other players, our devs and playtest more of the game till we roll out.\n\nDiscord link: discord.gg/FunVt2Y4wQ\n\nWelcome to District M :)", "short_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.staging.districtmvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AutoVRse", "support_website_url": null, "website_url": "https://twitter.com/districtmVR", "category": "GAMES", "comfort_rating": "NOT_RAT