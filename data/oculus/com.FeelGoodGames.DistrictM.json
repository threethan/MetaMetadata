uluscdn.com/v/t64.5771-25/65397209_1389489914745568_5618545857196378289_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IOE8_Z7u3I4Q7kNvgGwAArI&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAo7xXveyYa800SYcuHueemFETSPiyW_zW-UpA88M3Ndg&oe=6787A874"}, {"file_name": "Screenshot 5 - More Track.png", "id": "3689859557807096", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982717_3689859561140429_3474763701630351775_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m9H4GSLCFgwQ7kNvgGojUez&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBZh5JrUBWrtjWcENutqLaN9t1pREuCUQkayv_BFMvSnQ&oe=6787A699"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art.png", "id": "292551388950776", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75221327_292551392284109_5502955673277100807_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D7_cHB3CnqIQ7kNvgHoLSnL&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBt5GnjfYWccCXoJ0RFzYCDm4dQ2slGOSOBcnBCCfnF8w&oe=6787BA1B"}, "display_name": "District M", "keywords": [], "long_description": "We're reimagining the classic platformer for VR! \n\nYou play as a stunt cameraman trying to capture the coolest shots of the skater as you guide him through a colorful world filled with challenging puzzles. From chill, lo-fi maps to challenging jazz compositions, District M will toss hardcore platformer puzzles at you and push your mental and physical creativity to the limit! \n\nIt's unlike any VR game you've seen before.\n", "short_description": "Rhythm meets platformer in District M! Dance to a banger soundtrack and show off your control as you stylishly guide a skater through smooth, lovingly handcrafted levels. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://autovrse.in/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "AutoVRse", "support_website_url": null, "website_url": "https://twitter.com/districtmVR", "category": "GAMES", "comfort_ra