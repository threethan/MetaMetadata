-2.oculuscdn.com/v/t64.5771-25/38974583_288559199888594_2922592053255209935_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G-NAiw1XrPwQ7kNvgHxcJrb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXucq9AFiiW1vjZIGUQq5p2ElBdjoJeM2ifKuxr2YVRA&oe=6709029C"}]}, "id": "1651352921970934", "locale": "en_US", "screenshots": [{"file_name": "3.png", "id": "349850896868104", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982665_349850903534770_4863273483687921289_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5kjMHMfptBwQ7kNvgG4UPGN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBq9z-DfQ4tXKN9YhKkME_zjPx8NmxLYx_W9KRbVF3jhQ&oe=67091552"}, {"file_name": "5.png", "id": "943657103007405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974561_943657106340738_7480421357867095623_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jXOcuTOC_bwQ7kNvgHRTZ6L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASC1yUvzM21HFCV9xtdqfw7ZQpO9lRDzDuU52ze0ns4Q&oe=67092A3F"}, {"file_name": "1.png", "id": "500164345041433", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_500164348374766_6413048362635655150_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IhU4sNYWpDsQ7kNvgEdMrbz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIY8OnylvEexgOVKqKB8cGUKdTPVfZfn22rz5131VnkA&oe=67091E0F"}, {"file_name": "2.png", "id": "728708888094492", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974528_728708891427825_2008148098693216975_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oFZoz5BkksEQ7kNvgEqA4Um&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPgPu3WJW4HAm-BjzzC44HUNMl-QhuDh2wUjg-Sob4Lg&oe=6708FE46"}, {"file_name": "4.png", "id": "672129227250807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_672129233917473_5164729973480497819_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QibOmbt_EmQQ7kNvgFAU2Yq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjrjMq6mMxzPWoS0f4RgdFFNAaGGdV1UtH3SUh8qLACA&oe=670900EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape AppLab2.png", "id": "620208195712325", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_620208199045658_1632503818660487642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77TOV1xu-HAQ7kNvgHOeKrR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQUdSzCz-nYXhoNSvXnaymf402d-QKoTjhb8DIsv5QLA&oe=67090108"}, "display_name": "District M", "keywords": [], "long_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more.\n\nIf you have any feedback/suggestions or face any issue, please ping us on Discord. We really want to build a great game and we can\u2019t do it without your support.\n\nDo join our discord to meet other players, our devs and playtest more of the game till we roll out.\n\nDiscord link: discord.gg/FunVt2Y4wQ\n\nWelcome to District M :)", "short_description": "District M is a VR skater that combines the addictive loop of a rhythm VR game with the madness of a 3rd-person platformer in a stylized festive world.\n\nOur first demo of 2 levels got a lot of love so here\u2019s a new one with 8 test levels that you\u2019ll love even more.\n\nThe game is in development and will launch with 30 levels of increasing difficulty, multiplayer mayhem, gesture-based tricks, magical environments and so much more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.staging.districtmvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AutoVRse", "support_website_url": null, "website_url": "https://twitter.com/districtmVR", "category": "GAMES", "comfort_rating": "NOT_RAT