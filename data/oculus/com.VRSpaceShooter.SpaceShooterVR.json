hallenges at each level and earn attractive rewards.\nJoin the fight in Space Shooter and experience the thrill of defending Earth in this captivating VR adventure!", "short_description": "Space Shooter is an action-packed VR game where you pilot a spaceship to destroy enemies and avoid obstacles. Experience high-quality 3D graphics, diverse weapons, varied game modes, and online leaderboards. Join the battle to protect Earth from alien invaders in this thrilling space adventure!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/vrspaceshooter", "developer_terms_of_service_url": null, "publisher_name": "VR Space Shooter", "support_website_url": null, "website_url": "https://docs.google.com/document/d/13cbiPAUWlbi86NP9azT7q-OsoBuMvl4X94gZPPw76KU/pub", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27111931881731528"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982687_3668126426776046_7060110678931613692_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzSY5KxRmnYQ7kNvgH-130E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDD4hPhU--OoHhOT0NgzZlCg_1RPHd_-Fto8rJEWp2hog&oe=6745B05D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRSpaceShooter