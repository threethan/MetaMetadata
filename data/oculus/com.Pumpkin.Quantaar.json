195905_1958515124538302_2629399278943083843_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Com-k8PYj4Q7kNvgHXBdGi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBst7_NCsd7o0aBVENeqy2q4BwVU6EsM_oOdQ17ff9kcg&oe=671E1472"}, "display_name": "Quantaar", "keywords": [], "long_description": "Quantaar is believed to be the very origin of the Multiverse. Once the player has taken on the role of an Observer, they can summon heroes from the Universe to compete in the most thrilling and merciless combat event history has ever known. The Observer needs to master the heroes\u2019 abilities, level up their rank, and reveal the secret of the Multiverse!\n\nChoose from a variety of heroes each with different skills and ultimate to compete in the thrilling match! Knock opponents out of the arena, unleash the hero's ultimate to destroy everything! Discover the hero's abilities by combining the deep rune system to develop your own playstyle!\n\nThe most epic social playground in the making! Giant gator, floating trampoline...and more! Stay tuned.\n\n", "short_description": "Quantaar is a platform brawler where you can summon heroes to fight and meet new friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://quantaar.com/privacy-policy/", "developer_terms_of_service_url": "https://www.pumpkinvr.com/terms", "publisher_name": "Pumpkin VR", "support_website_url": null, "website_url": "http://www.pumpkinvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_mo