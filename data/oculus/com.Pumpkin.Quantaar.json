771-25/38974699_934464601228005_990972979401639941_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_8p_pmWgPVsQ7kNvgEzAjjW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5K8EQQTxS3x7-bMyH9wzENmiqstkkgvqbdbhrqbGlMA&oe=673B2DDB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "888888888.png", "id": "1447765276038454", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210887_1447765279371787_3979393617025490254_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=plojHS_rmZ0Q7kNvgFHzYpg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEVL2_mMeEEYzWLFCN7C_sfroOk_5sTbD_msStT--sZw&oe=673B1930"}, "display_name": "QUANTAAR", "keywords": [], "long_description": "QUANTAAR is a free-to-play VR Party Brawler! Command Heroes with distinct roles and enhance their abilities with Cores to compete in multiple game modes. Party with friends in themed social rooms and customize yourself with limited-edition cosmetic skins!\n\n// CHOOSE YOUR HERO //\nChoose from four Hero classes: Fighter, Assassin, Shooter, and Generalist, each with unique skills to help you dominate across a variety of adrenaline-pumping game modes. \n\n// POWER UP WITH CORES //\nBuild up your Hero's agility, firepower, and range with Cores to create unlimited combinations. \n\n// MULTIPLE ARENAS //\nExplore exciting new universes, from the icy mountains of Eternal Winter to the desolate lands of Desert Tombs. \n\n// ACTION-PACKED GAME MODES //\nJump into thrilling matches by teaming up with a friend in 2v2 and Soccer modes, or just smash around in Brawler!\n\n// SOCIAL THEMED ROOMS //\nMeet other players in the huge Social Halls like Playground and Space Transport Hub, where you can play air golf, bowling, and more.\n\n\nThere's never a dull moment in QUANTAAR!", "short_description": "QUANTAAR is a free-to-play VR Party Brawler! \nCommand Heroes with distinct roles and enhance Hero abilities with Cores to compete in multiple game modes. Party with friends in social-themed rooms and customize yourself with limited-edition cosmetic skins.\n"}, {"images": {"nodes": [{"file_name": "Hero Cover.png", "id": "1853811518325711", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031380_1853811521659044_6756751171156429795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psiNiEBLuC0Q7kNvgEKMyFg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUqGdHOYLNihUHO7upxQnQDXTqus1xyBBTQI-i-7j9bg&oe=673B2484"}, {"file_name": "Frame 84.png", "id": "1747234655674817", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574717_1747234659008150_751994459856233040_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Jj6bX1ObEsQ7kNvgE6ZTyr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBewiqPuO6hyqrUq-5Q0U0EPiVeMADADIZJSHaJNpBrZA&oe=673B3FC9"}, {"file_name": "Quantaar_Icon+Logo_White-2.png", "id": "1691941741253594", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/227853518_1691941744586927_7515975418370516232_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UEH5UsVr4OIQ7kNvgEf3ktN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAkRBNbd1M2Ni0T0LrDfsTOONb9ji5zLKrL7WOSGGu9qw&oe=673B0F33"}, {"file_name": "Mini Landscape.png", "id": "629084345425352", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001715_629084348758685_4880012990106783570_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KZbaN_zTJBAQ7kNvgHafJcY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeBYJCaS26cmqQQz8YjJBCN7W3FkIbpWzPikBnAszjBQ&oe=673B1E6E"}, {"file_name": "Cover Square.png", "id": "546511937656161", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031582_546511940989494_5977285572963670016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=piIGsnvwmxMQ7kNvgGeFQIT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBz60_G