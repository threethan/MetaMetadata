1670_323542466647661_4122775009854338288_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7D5SZQxUyYQQ7kNvgHH0iYd&_nc_ht=scontent.oculuscdn.com&oh=00_AYDzxskPWvEKefjt7ORACslKEU30O1OX5YAf8JorxvhvCg&oe=66F164AE"}, {"file_name": "ss_9e81b66559cb31279ac9ce2a1dd549d7baac196b.png", "id": "1082041976060756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_1082041979394089_4591425807726282290_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xj-ace9W-n4Q7kNvgGHVxZY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCqBFpfLxnArzH1PcccJvNB5fKQX4t6ZXdOS1-s24o9A&oe=66F16CD8"}, {"file_name": "ss_f5c01a2cb9ea607bb9492987d59a7f48c50eb6f6 1.png", "id": "545919653745897", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_545919657079230_4932556735365250187_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BR52DuBIwYYQ7kNvgH5dN82&_nc_ht=scontent.oculuscdn.com&oh=00_AYCW6lAMvlyjKIGquVq04cDr24C8hZqhW53vI1etmoEGQg&oe=66F16B02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 21.png", "id": "1958515117871636", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195905_1958515124538302_2629399278943083843_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WU_bPUIR2lgQ7kNvgEXcI3q&_nc_ht=scontent.oculuscdn.com&oh=00_AYB64BCmgt3XP2L0SedfICO_3PRpSgwpXfi8e8__WIe32g&oe=66F14172"}, "display_name": "Quantaar", "keywords": [], "long_description": "Quantaar is believed to be the very origin of the Multiverse. Once the player has taken on the role of an Observer, they can summon heroes from the Universe to compete in the most thrilling and merciless combat event history has ever known. The Observer needs to master the heroes\u2019 abilities, level up their rank, and reveal the secret of the Multiverse!\n\nChoose from a variety of heroes each with different skills and ultimate to compete in the thrilling match! Knock opponents out of the arena, unleash the hero's ultimate to destroy everything! Discover the hero's abilities by combining the deep rune system to develop your own playstyle!\n\nThe most epic social playground in the making! Giant gator, floating trampoline...and more! Stay tuned.\n\n", "short_description": "Quantaar is a platform brawler where you can summon heroes to fight and meet new friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://quantaar.com/privacy-policy/", "developer_terms_of_service_url": "https://www.pumpkinvr.com/terms", "publisher_name": "Pumpkin VR", "support_website_url": null, "website_url": "http://www.pumpkinvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1600504033680822"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "732699107801096"}]}, "baseline_offer": {"id": "732699107801096"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1686146400, "status": "PUBLISHED", "id": "732699107801096"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6759195027539349", "version": "1.034"}, "id": "380735547012436", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3984654618326751", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "675