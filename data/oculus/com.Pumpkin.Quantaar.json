771-25/38974699_934464601228005_990972979401639941_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GVv-0RlzkiwQ7kNvgHyAwH5&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBUaAdceiHD7i3YSh0GC66NLg3yR9z3yNNRoZ60JFlJSA&oe=6734965B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "888888888.png", "id": "1447765276038454", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75210887_1447765279371787_3979393617025490254_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qhErJQERAQkQ7kNvgEz1dhM&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB15YCfHuWHBh3QNa0XPUKkj71Dk87Xqkge2e6PzM6AwQ&oe=673481B0"}, "display_name": "QUANTAAR", "keywords": [], "long_description": "QUANTAAR is a free-to-play VR Party Brawler! Command Heroes with distinct roles and enhance their abilities with Cores to compete in multiple game modes. Party with friends in themed social rooms and customize yourself with limited-edition cosmetic skins!\n\n// CHOOSE YOUR HERO //\nChoose from four Hero classes: Fighter, Assassin, Shooter, and Generalist, each with unique skills to help you dominate across a variety of adrenaline-pumping game modes. \n\n// POWER UP WITH CORES //\nBuild up your Hero's agility, firepower, and range with Cores to create unlimited combinations. \n\n// MULTIPLE ARENAS //\nExplore exciting new universes, from the icy mountains of Eternal Winter to the desolate lands of Desert Tombs. \n\n// ACTION-PACKED GAME MODES //\nJump into thrilling matches by teaming up with a friend in 2v2 and Soccer modes, or just smash around in Brawler!\n\n// SOCIAL THEMED ROOMS //\nMeet other players in the huge Social Halls like Playground and Space Transport Hub, where you can play air golf, bowling, and more.\n\n\nThere's never a dull moment in QUANTAAR!", "short_description": "QUANTAAR is a free-to-play VR Party Brawler! \nCommand Heroes with distinct roles and enhance Hero abilities with Cores to compete in multiple game modes. Party with friends in social-themed rooms and customize yourself with limited-edition cosmetic skins.\n"}, {"images": {"nodes": [{"file_name": "Hero Cover.png", "id": "1853811518325711", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031380_1853811521659044_6756751171156429795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gYiELL3hl5IQ7kNvgGpPW_3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCMtrngpqnmvJY4hvoSHvOVjsxrCtvmU-XMaKPLHJtT7w&oe=67348D04"}, {"file_name": "Frame 84.png", "id": "1747234655674817", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57574717_1747234659008150_751994459856233040_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ezwlbrq6KDsQ7kNvgH3vIjD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYASkuDZRfiYZJXfc462ZvC0uKclQ4dwBP8_gjOc_6Sgcw&oe=6734A849"}, {"file_name": "Quantaar_Icon+Logo_White-2.png", "id": "1691941741253594", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/227853518_1691941744586927_7515975418370516232_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iHtIc9EZxIAQ7kNvgG5Xw56&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAG5dRjnJldnj6CldyzjsYIs7UTzpRXN6X15xgMa0J7og&oe=673477B3"}, {"file_name": "Mini Landscape.png", "id": "629084345425352", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001715_629084348758685_4880012990106783570_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fUUrejkiqAAQ7kNvgF_c6Jq&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDrKm6bRfUNJ88YHmVjijfb-js1jzY3tZn2wG_Q1l7uPQ&oe=673486EE"}, {"file_name": "Cover Square.png", "id": "546511937656161", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031582_546511940989494_5977285572963670016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EqffkyReTWUQ7kNvgE5uHm2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCkzO81