00&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vX_yIcyknnoQ7kNvgEOdeZb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMWDMVe7b9JMt1brvwubMiR&oh=00_AYAHnB15E7Ya-GREqmHgg2aZCds1Dy-27GVXt5ZGpE3XcQ&oe=66E58D82"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 21.png", "id": "1958515117871636", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195905_1958515124538302_2629399278943083843_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vI5s7xqV4roQ7kNvgG-xnyS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMWDMVe7b9JMt1brvwubMiR&oh=00_AYDN_kIZhY59dB-eMyaANI54zNhMqzJIE8omJqTh6s7E7A&oe=66E563F2"}, "display_name": "Quantaar", "keywords": [], "long_description": "Quantaar is believed to be the very origin of the Multiverse. Once the player has taken on the role of an Observer, they can summon heroes from the Universe to compete in the most thrilling and merciless combat event history has ever known. The Observer needs to master the heroes\u2019 abilities, level up their rank, and reveal the secret of the Multiverse!\n\nChoose from a variety of heroes each with different skills and ultimate to compete in the thrilling match! Knock opponents out of the arena, unleash the hero's ultimate to destroy everything! Discover the hero's abilities by combining the deep rune system to develop your own playstyle!\n\nThe most epic social playground in the making! Giant gator, floating trampoline...and more! Stay tuned.\n\n", "short_description": "Quantaar is a platform brawler where you can summon heroes to fight and meet new friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://quantaar.com/privacy-policy/", "developer_terms_of_service_url": "https://www.pumpkinvr.com/terms", "publisher_name": "Pumpkin VR", "support_website_url": null, "website_url": "http://www.pumpkinvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "F