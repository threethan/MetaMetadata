771-25/38974699_934464601228005_990972979401639941_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUYWJcS-_eEQ7kNvgEiRdgO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCFH38cKV3jNq3QIHo7A3FxRXajHOcB4M1ezqF8G7tiA&oe=6744685B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "888888888.png", "id": "1447765276038454", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210887_1447765279371787_3979393617025490254_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fP4fdQVG7U0Q7kNvgEbCVRB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChiynlrEbV2ceKfQRvEzVIi7JUvNWb39lIcLsbvqXzYA&oe=674453B0"}, "display_name": "QUANTAAR", "keywords": [], "long_description": "QUANTAAR is a free-to-play VR Party Brawler! Command Heroes with distinct roles and enhance their abilities with Cores to compete in multiple game modes. Party with friends in themed social rooms and customize yourself with limited-edition cosmetic skins!\n\n// CHOOSE YOUR HERO //\nChoose from four Hero classes: Fighter, Assassin, Shooter, and Generalist, each with unique skills to help you dominate across a variety of adrenaline-pumping game modes. \n\n// POWER UP WITH CORES //\nBuild up your Hero's agility, firepower, and range with Cores to create unlimited combinations. \n\n// MULTIPLE ARENAS //\nExplore exciting new universes, from the icy mountains of Eternal Winter to the desolate lands of Desert Tombs. \n\n// ACTION-PACKED GAME MODES //\nJump into thrilling matches by teaming up with a friend in 2v2 and Soccer modes, or just smash around in Brawler!\n\n// SOCIAL THEMED ROOMS //\nMeet other players in the huge Social Halls like Playground and Space Transport Hub, where you can play air golf, bowling, and more.\n\n\nThere's never a dull moment in QUANTAAR!", "short_description": "QUANTAAR is a free-to-play VR Party Brawler! \nCommand Heroes with distinct roles and enhance Hero abilities with Cores to compete in multiple game modes. Party with friends in social-themed rooms and customize yourself with limited-edition cosmetic skins.\n"}, {"images": {"nodes": [{"file_name": "Hero Cover.png", "id": "1853811518325711", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031380_1853811521659044_6756751171156429795_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LTWOR8Wstl0Q7kNvgENohTR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNPnyVLRPZUlI-mDw-ZgrsPxZHb9x676xlIxJEzszTgg&oe=67445F04"}, {"file_name": "Frame 84.png", "id": "1747234655674817", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574717_1747234659008150_751994459856233040_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0kUaYLvOzakQ7kNvgH-uZgh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCVwMm62SNedqd6TkL3CkfCBsfpu_j7y3n8J8JhjLOUZw&oe=67447A49"}, {"file_name": "Quantaar_Icon+Logo_White-2.png", "id": "1691941741253594", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/227853518_1691941744586927_7515975418370516232_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDN2EBEh00sQ7kNvgHioreq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDf3B60JGhFmDYHNh3AduLLxGXApjTe_vlY5IryItHpPQ&oe=674449B3"}, {"file_name": "Mini Landscape.png", "id": "629084345425352", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001715_629084348758685_4880012990106783570_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=znzU_IY1d7AQ7kNvgGarwxo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFLpJIiIqD80RUvYxoemk9IgNEJpgRSlri0Os9ju7WJA&oe=674458EE"}, {"file_name": "Cover Square.png", "id": "546511937656161", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031582_546511940989494_5977285572963670016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4s9VaEZDXfEQ7kNvgHNA5v0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB94633