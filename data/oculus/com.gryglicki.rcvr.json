ountainVR/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ROLLER_COASTER", "ADVENTURE", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "639013217155313"}, "review_messages": ["", "", "Congratulations! Your submission is ready to publish in the Oculus Store.\n\nYour app will be released on 8/8/2018 @ 10AM PT for free under the Apps section of the Mobile store.  Let us know if you would like a different date otherwise we will go ahead and release it.  \n\nBefore your release please update the logo asset to have a transparent background.  Please do not update your online services (such as your back-end servers) during your launch week.\n\nOnce your submission is published, you can access analytics [here](https://developer.oculus.com/apps/). ", "Due to a technical issue in our test results reporting system, we're unable to provide a formal test result at this time.  The VRC failures and feedback below is from our technical review team:\n\nVRC.Mobile.Security.1 - Entitlements check", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12448961_2026094244087067_633536658599313408_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=346qxiSS_tYQ7kNvgG_OWWM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAH1pJ3UQ5MSdJPiPkPvwrPzb1991G7RnFoMPCrQWilRw&oe=6762A02B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "High Mountain Roller Coaster VR", "platform": "ANDROID", "context_category": null, "context_t