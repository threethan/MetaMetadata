34060_286478831120011_8878711438786878353_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgsHhV_Jf_IQ7kNvgE0-kPW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDM9IX7sd4KK6JNaC3ZNYzRoFVcjqT2cMc8n4Qz0sQawg&oe=66D6DAB3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "triptovr9.png", "id": "917320386720448", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003233_917320390053781_1969244523528839186_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=epJ_OzeewWgQ7kNvgEvDo4s&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeMjcir1lf5Wv8eJK6hbGbrSqZHGHgV1eHziLq-bp8_g&oe=66D6EA29"}, "display_name": "TriptoVR", "keywords": ["explore", "360video", "travel", "world", "relax"], "long_description": "Embark on an incredible lifelike virtual adventure with TriptoVR, your gateway to the world's most enchanting destinations. Experience the vibrancy of cities and landscapes, brought to life with stunning realism, from the bustling streets of Tokyo to the tranquil beaches of Cape Town.  All from the comfort of your home.\n\nBoat on the serene canals of Venice in a gondola, marvel at the grandeur of the Eiffel Tower, witness the architectural splendor of the Sydney Opera House, and immerse yourself in the culture, history, and nature of Istanbul, Bali, Prague, Lima, and many more. Our app brings you closer than ever to these breathtaking sites, letting you explore them in vivid detail.\n\nMarvel at the view of Earth from space \u2013 rotate it, zoom in, and choose your trip. Whether you're a curious VR traveler, passionate about history, modern culture or love the outdoors, TriptoVR offers something for everyone.\n\nJoin your fellow VR explorers, pack your virtual backpack, and set off on your journey with TriptoVR. The world is at your fingertips. Download now and start your global adventure today!\n", "short_description": "Travel the world in VR with TriptoVR!  Marvel at the view of Earth from space \u2013 rotate it, zoom in, and choose your trip.Visit the most beautiful and famous places on our planet. Go on a boat ride in Venice, stand in awe beneath the Eiffel Tower in Paris, and witness the Washington Monument. Bask in the sun of Cape Town, or immerse yourself in the bustling energy of Tokyo's famous Shibuya Crossing.  And here is much, much more to see and experience. The world is at your fingertips with TriptoVR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vr-gorilla.com/privacy-policy-triptovr", "developer_terms_of_service_url": "https://www.vr-gorilla.com/terms-of-service-triptovr/", "publisher_name": "VR Gorilla ", "support_website_url": "https://www.vr-gorilla.com/contact/", "website_url": "https://www.vr-gorilla.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7813026025474824"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570307_1087752189014262_4598802276619513712_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=noa7T9bx5gAQ7kNvgEkOfEa&_nc_ht=scontent.oculuscdn.com&oh=00_AYBU24oSinWChaJJzDpUJ41bl4o6WbIpS6YbarLslGHrHQ&oe=66D707B5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TriptoVR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Relax