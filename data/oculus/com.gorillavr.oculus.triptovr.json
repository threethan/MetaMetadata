437318310878104_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YacWWqSu1WMQ7kNvgGu-i0r&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8tqV2Bwr2-arblRMnGUVfQnKQBQ_iH29N_vmEP3m6zw&oe=66D6E07E"}, {"file_name": "machu picchu.png", "id": "1496232124281557", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974602_1496232130948223_8634597678513095839_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y0eRanf2fKgQ7kNvgGZRBtU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBE6b7JIrm3lrUdll7oUktiOBVSmjPpbBDJIC1kSgkh2g&oe=66D700CA"}, {"file_name": "Machu Picchu.00_00_08_14.Still001.png", "id": "286478827786678", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334060_286478831120011_8878711438786878353_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgsHhV_Jf_IQ7kNvgE0-kPW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDM9IX7sd4KK6JNaC3ZNYzRoFVcjqT2cMc8n4Qz0sQawg&oe=66D6DAB3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "triptovr9.png", "id": "917320386720448", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003233_917320390053781_1969244523528839186_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=epJ_OzeewWgQ7kNvgEvDo4s&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeMjcir1lf5Wv8eJK6hbGbrSqZHGHgV1eHziLq-bp8_g&oe=66D6EA29"}, "display_name": "TriptoVR", "keywords": [], "long_description": "Embark on an incredible lifelike virtual adventure with TriptoVR, your gateway to the world's most enchanting destinations. Experience the vibrancy of cities and landscapes, brought to life with stunning realism, from the bustling streets of Tokyo to the tranquil beaches of Cape Town.  All from the comfort of your home.\n\nBoat on the serene canals of Venice in a gondola, marvel at the grandeur of the Eiffel Tower, witness the architectural splendor of the Sydney Opera House, and immerse yourself in the culture, history, and nature of Istanbul, Bali, Prague, Lima, and many more. Our app brings you closer than ever to these breathtaking sites, letting you explore them in vivid detail.\n\nMarvel at the view of Earth from space \u2013 rotate it, zoom in, and choose your trip. Whether you're a curious VR traveler, passionate about history, modern culture or love the outdoors, TriptoVR offers something for everyone.\n\nJoin your fellow VR explorers, pack your virtual backpack, and set off on your journey with TriptoVR. The world is at your fingertips. Download now and start your global adventure today!\n", "short_description": "Travel the world in VR with TriptoVR!  Marvel at the view of Earth from space \u2013 rotate it, zoom in, and choose your trip.Visit the most beautiful and famous places on our planet. Go on a boat ride in Venice, stand in awe beneath the Eiffel Tower in Paris, and witness the Washington Monument. Bask in the sun of Cape Town, or immerse yourself in the bustling energy of Tokyo's famous Shibuya Crossing.  And here is much, much more to see and experience. The world is at your fingertips with TriptoVR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vr-gorilla.com/privacy-policy-triptovr", "developer_terms_of_service_url": "https://www.vr-gorilla.com/terms-of-service-triptovr/", "publisher_name": "VR Gorilla ", "support_website_url": "https://www.vr-gorilla.com/contact/", "website_url": "https://www.vr-gorilla.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6447684148675692"}}]}, "scheduled_offe