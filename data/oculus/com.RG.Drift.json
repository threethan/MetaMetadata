GpfJRDJgQJPRg&oe=670CF50E"}, {"file_name": "migrated_image.png", "id": "783274088748159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974440_521948288402806_4010758564015505408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RKnhRceJWTQQ7kNvgGhfodc&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-XA2WjcGhdVTDqC6x2XeO7MYKMMfikuH-pIqGxqLGWQ&oe=670D1E31"}, {"file_name": "migrated_image.png", "id": "537574533544641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289720_454767502079434_4998640263736852480_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R1bnoNPekuMQ7kNvgHVstBV&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0GGvHeFqZuRK2jBaV-Q96P8siltehlgpzcz_ePSj4Sg&oe=670D1A4E"}, {"file_name": "migrated_image.png", "id": "211517703421457", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031363_2176798282442565_2407368210660720640_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q0TUKQ9vkIcQ7kNvgG-pc33&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6iVD-oMYw6c8UGuE-mVWOk4zrV9HJ5YNmrz_OXELb2w&oe=670CFB7B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/iYe6Qe", "id": "2499538826927684", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984469_2499538830261017_9144273544014725120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s_HPWQZFBWAQ7kNvgGLtS-z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkJAJalNkYBhOk_GNYGSd_T66z_ae8iiiszIyXktjSww&oe=670CEF86"}, "display_name": "Drift Club", "keywords": ["Drift", "Race", "speed", "Extreme", "driving"], "long_description": "Hey, do you need some drift?\nIf you are a fan of speed, and sharp turns, this game is for you.Pimp your skills of extreme driving and feel maximum control of your car.\nThe more you drift the more drift coins you can collect. You can buy new cars by this coins and customise it. Each car has its own characteristics of the ride.\n\nFeatures:\n- First person realistic view\n- 7 tracks with beautiful views\n- 11 cars to use and customise\n- User friendly car control\n\n\nUpdate 1.01\n- Settings with on\\off music in game\n- New free ride drift mode\n- New huge mountain location for free ride\n\nChristmas update 1.02\n- New snowy track\n- New Christmas car\n- Added character with hands", "short_description": "Hey, do you need some drift?\nIf you are a fan of speed, and sharp turns, this game is for you. Pimp your skills of extreme driving and feel maximum control of your car. \n\nFeatures:\n- First person realistic view\n- 7 tracks with beautiful views\n- 11 cars to use and customise\n- User friendly car control\n\nChristmas update 1.02\n- New snowy track\n- New Christmas car\n- Added character with hands"}]}, "developer_name": "Raptor`s Games", "developer_privacy_policy_url": "https://raptorsreality.com/privacypolicy.html", "developer_terms_of_service_url": "https://raptorsreality.com/privacypolicy.html", "publisher_name": "Raptor`s Games", "support_website_url": null, "website_url": "https://raptorsreality.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "755537112722806"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974754_672022143545258_428979319184818176_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jEizsU7iimAQ7kNvgHFoUQJ&_nc_ht