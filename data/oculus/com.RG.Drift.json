scdn.com/v/t64.5771-25/38974440_521948288402806_4010758564015505408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vFjq1O0Ba_4Q7kNvgF2LBTB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJG8z9EI7CWmpdkdU7NsXjS1EbgPqPxpfi3jH_H7dusA&oe=66E558F1"}, {"file_name": "migrated_image.png", "id": "537574533544641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75289720_454767502079434_4998640263736852480_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pI4ejOFAflsQ7kNvgE2vsJ3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCF_0gyNbMPbT8uL5rlVBF0VYs4HOuHbaXhzkJXtEye7Q&oe=66E58D4E"}, {"file_name": "migrated_image.png", "id": "211517703421457", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_2176798282442565_2407368210660720640_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2wQ0IlQYO4sQ7kNvgEbwpUs&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3aVuvuaLYGDwXi33hsDHOCMZxS4XwnM0f7q--_UvYAg&oe=66E56E7B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/iYe6Qe", "id": "2499538826927684", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984469_2499538830261017_9144273544014725120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LbrZkClgx-QQ7kNvgGwyjgy&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdacyVrdOlIXiSwafpF8pS-qF3S7Qsr-7E8SjrqHfBhg&oe=66E56286"}, "display_name": "Drift Club", "keywords": ["Drift", "Race", "speed", "Extreme", "driving"], "long_description": "Hey, do you need some drift?\nIf you are a fan of speed, and sharp turns, this game is for you.Pimp your skills of extreme driving and feel maximum control of your car.\nThe more you drift the more drift coins you can collect. You can buy new cars by this coins and customise it. Each car has its own characteristics of the ride.\n\nFeatures:\n- First person realistic view\n- 7 tracks with beautiful views\n- 11 cars to use and customise\n- User friendly car control\n\n\nUpdate 1.01\n- Settings with on\\off music in game\n- New free ride drift mode\n- New huge mountain location for free ride\n\nChristmas up