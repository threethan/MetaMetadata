scdn.com/v/t64.5771-25/38974440_521948288402806_4010758564015505408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vFjq1O0Ba_4Q7kNvgFryEDE&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyq-xTewIq5PDwkHkf8i_7620T3PUyVpBE15IvAgjJoA&oe=66E43FB1"}, {"file_name": "migrated_image.png", "id": "537574533544641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75289720_454767502079434_4998640263736852480_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qa3q8OcyAbIQ7kNvgF2cLdj&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSMH0Mk7jaQHtPx2vaykkUiAAsm_UZHOeFmN-n8Vt6Eg&oe=66E43BCE"}, {"file_name": "migrated_image.png", "id": "211517703421457", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_2176798282442565_2407368210660720640_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eB9QBNI4eB0Q7kNvgHQqc4S&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIFgKx_RxJUW4M97qIPEVRnfidnXJhlJw9CqdEQXaHXw&oe=66E41CFB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/iYe6Qe", "id": "2499538826927684", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984469_2499538830261017_9144273544014725120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LbrZkClgx-QQ7kNvgGwB4Hp&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwhtPKxNAlKJZS59XjFsW3fMaC4Q1HoaHfLEQhI_RuVg&oe=66E41106"}, "display_name": "Drift Club", "keywords": ["Drift", "Race", "speed", "Extreme", "driving"], "long_description": "Hey, do you need some drift?\nIf you are a fan of speed, and sharp turns, this game is for you.Pimp your skills of extreme driving and feel maximum control of your car.\nThe more you drift the more drift coins you can collect. You can buy new cars by this coins and customise it. Each car has its own characteristics of the ride.\n\nFeatures:\n- First person realistic view\n- 7 tracks with beautiful views\n- 11 cars to use and customise\n- User friendly car control\n\n\nUpdate 1.01\n- Settings with on\\off music in game\n- New free ride drift mode\n- New huge mountain location for free ride\n\nChristmas update 1.02\n- New snowy track\n- New Christmas car\n- Added character with hands", "short_description": "Hey, do you need some drift?\nIf you are a fan of speed, and sharp turns, this game is for you. Pimp your skills of extreme driving and feel maximum control of your car. \n\nFeatures:\n- First person realistic view\n- 7 tracks with beautiful views\n- 11 cars to use and customise\n- User friendly car control\n\nChristmas update 1.02\n- New snowy track\n- New Christmas car\n- Added character with hands"}]}, "developer_name": "Raptor`s Games", "developer_privacy_policy_url": "https://raptorsreality.com/privacypolicy.html", "developer_terms_of_service_url": "https://raptorsreality.com/privacypolicy.html", "publisher_name": "Raptor`s Games", "support_website_url": null, "website_url": "https://raptorsreality.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "755537112722806"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974754_672022143545258_428979319184818176_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pB6lD7c4fQMQ7kNvgGvKl02&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKbuBKrqahujqKgnjj6-JQ2_XGdnCTv8Qr01igM25dHQ&oe=66E41B39"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Drif