hLZ162eXyslc3mvTCn1ALXVJhCdFXA&oe=677FBED1"}, {"file_name": "EK 7.png", "id": "1367451413933223", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974667_1367451420599889_2897464361664604542_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1RUIXLZrO24Q7kNvgHSbIv8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbuLjix2QlED7NuUrtLqcWEZAXhzYau6L9KTirClL-Zg&oe=677FCC33"}, {"file_name": "EK 8.png", "id": "7435959116513244", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75236134_7435959129846576_7230064827312854670_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v6GUc3R4uO8Q7kNvgGrrarj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDzE5fxFzv1sH-xUOWHNVI2_o7yg1tf4dFBSwtL-xpuNA&oe=677FB08D"}, {"file_name": "EK 11.png", "id": "962013369036784", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422394_962013372370117_2584067737468984219_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Y4prRSL61YQ7kNvgGQH3Zy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKWojDs78IZCjAAK2eof3KEFw7u3gfacWAoxqsFL5kbA&oe=677FA660"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Announcement_Trailer_Cover_Image_2560x1440.png", "id": "1163214754815541", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572943_1163214758148874_1548614358813687475_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vhnI6OmmxvgQ7kNvgErwNc1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7rkYs_TMs9Pin9V-hXftc7WYg_QhcrfIyjsj5qrMisg&oe=677FA126"}, "display_name": "Exploding Kittens VR", "keywords": [], "long_description": "Play with up to five players online or against bots and strategically force your opponents to draw the dreaded Exploding Kitten and be the last person standing to win. Customize your own in-game avatars, explore the social hub and dive into a variety of entertaining mini-games. \n\nInteract With Your Favorite Card Game Like Never Before: A VR strategy game experience to socialize with friends and make new enemies. \n\nA Variety of Tools At Your Disposal: Utilize a slew of strategies to outsmart your opponents and come out on top. \n\nThree Unique Game Modes: Battle it out in either classic or blitz mode with up to five players, or against your biggest rival in duel mode.\n\nEngage With the Immersive Social Hub: Discover various activities in the social hub including mini games, character customization and more! ", "short_description": "Based on the popular card game, Exploding Kittens VR is coming soon to Meta Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "https://saber.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Saber Interactive Inc", "support_website_url": "https://support.saber.games/", "website_url": "https://saber.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8200376113327018"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1076191207239581"}, {"status": "PUBLISHED", "id": "1432739220775316"}, {"status": "PUBLISHED", "id": "1577043953235479"}, {"status": "PUBLISHED", "id": "470865652254970"}, {"status": "PUBLISHED", "id": "1715968765601871"}, {"status": "PUBLISHED", "id": "1606200563502338"}]}, "baseline_offer": {"id": "1432739220775316"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1076191207239581"}]}, "