", "keywords": [], "long_description": "Animal Anatomy is a standalone experience that allows players to learn about animal anatomy through open exploration of an anatomically accurate, multi-layered digital replica of animals. In this initial release, two mammals will be included, a dog and a bison/buffalo.\n\nThe experience also features an interactive quiz, which assesses the player\u2019s knowledge of the anatomy of said animal. Players are given feedback on the quiz in real-time and can learn through repetition as the questions in the quiz randomize each time it is taken. ", "short_description": "Animal Anatomy is a standalone experience that allows players to learn about animal anatomy through open exploration of an anatomically accurate, multi-layered digital replica of animals. In this initial release, two mammals will be included, a dog and a bison/buffalo."}]}, "developer_name": "TAFE NSW", "developer_privacy_policy_url": "https://www.tafensw.edu.au/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TAFE NSW", "support_website_url": null, "website_url": "https://www.tafensw.edu.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "850518889583695"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_suppor