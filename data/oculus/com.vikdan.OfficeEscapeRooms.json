5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dBpX0lZnxSAQ7kNvgGE-0wE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgeweqd7Ne466CWx_Stm0HzkefiwqFPPCsk4dhrJh0LA&oe=66D9A5CF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kdcj6v1bijoQ7kNvgFxIaub&_nc_ht=scontent.oculuscdn.com&oh=00_AYAo9ytbYHJu9rqIxa9oO_oPufA0t2COpcdy5uwp0pPNyg&oe=66D99F90"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cfUvyPg8lzkQ7kNvgG35y2j&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQG1MMnd_RhsjeWeeLHxlvFsvUUvv8xMw_vXGgjm9seA&oe=66D9A46E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5feuqGkwTrAQ7kNvgHPQ8M2&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0Rsqt01hAd8Q95DXPtYmcMWcP565WXHRSr7KwHRjxew&oe=66D990CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ttHijg0_HzsQ7kNvgGnt2WI&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3gJdMRmtJn0gUEBAEoDbtiYCtbMgFfLCPAX2xUrCRog&oe=66D988B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport