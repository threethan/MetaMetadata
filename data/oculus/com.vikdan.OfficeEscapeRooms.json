5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5X4RNwJO_4cQ7kNvgHdTn5z&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBfcn_XaeErIXkvX6h9EZdCf0U47U2gjFFlmsQM-EZBA&oe=66D45FCF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v_oWAeVPw74Q7kNvgGbrBFx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMUxpEXVWewSzfxsxto0NPqTwnEnxGwBh9ZMz7HhtsTw&oe=66D45990"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k--l14X9nXIQ7kNvgFyNy-P&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9WJq8_f9u_-JoJBmV8TbyE75EqS2WMM1EK5m2uBv0OA&oe=66D45E6E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qhkFjVE21RoQ7kNvgH6w3ZO&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0QMfQKRcxus7Yu_FwC6wsu_6Npws9A1q_hh01RentfQ&oe=66D44ACA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CmknMoENG1IQ7kNvgEIRimf&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8-1fWcc_K72TtxKTbMDLZL5MrN5TGbXAYyQr157sN3g&oe=66D442B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport