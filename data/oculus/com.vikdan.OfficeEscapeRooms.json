5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ro9mGJRtMwAQ7kNvgHoPRbV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzSGLh3YIXdghHy9jDGu04TX2Kisk8CIyKqkTxlt6Znw&oe=66CC76CF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YdpNVKvRXooQ7kNvgErXsVJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVKLTgib32FENRYTSOl3vTcKQPmF4-JX_W5wZdkNUJew&oe=66CC7090"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uj-O4skU1AwQ7kNvgFWDypx&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmeuNtGJHUzw1oPfaJSoM0pVFMOt4FH8nSewnS6wnPQQ&oe=66CC756E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nE61Qp00uNoQ7kNvgFt30Ur&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtDPNdqMNILtCdr8wAbY5-3HS32u_CG4iSI0lFkY8yrQ&oe=66CC61CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qSXIaK49ZHMQ7kNvgEvTXuv&_nc_ht=scontent.oculuscdn.com&oh=00_AYARqX3hepyZJXRaILf0sOJddYdocjQoeUXj0LHylQhudA&oe=66CC59B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport