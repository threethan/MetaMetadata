3951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lw4tAJqOU_8Q7kNvgGzMI2x&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNw1NRz3iMIryf67p9hpgXXR6A8llBpcxyig545Bp1Gw&oe=66EC1ACF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=geBTVP22nBkQ7kNvgEetTaR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbnTEdEHfhCgl2spLkVFULGRiXDzRf_cZUdKRQPdlkPQ&oe=66EC1490"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QTuHS11zwEgQ7kNvgEUhFph&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEpiEug9GPdbTnsYmS1HqeZlTbfWwZDcLmOioTQ18oOg&oe=66EC196E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpLeKTyifMoQ7kNvgEc0jVL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDadaCTySq_imTmBPz8AjwlmlDKK4VIrIgI8svrrKNpzw&oe=66EC05CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XB348WqJ3CcQ7kNvgG3cXLa&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQxcAczFQwZfdQUX006JGV5pH3LH6RTe3sC3HNTs2kIw&oe=66EBFDB6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport AND s