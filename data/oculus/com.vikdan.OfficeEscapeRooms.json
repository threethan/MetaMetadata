5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0j9f9AP5FygQ7kNvgGfYsJt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCyh4JCpWQECIBvQNp_hoN13QJbj6eDshLC6cJ4qm5sQ&oe=66E431CF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1BBxL6-2yQQ7kNvgEt7E6x&_nc_ht=scontent.oculuscdn.com&oh=00_AYCn0ORxaKiGJ8xvFR_1D-infjzbElesIdzPXqgZidu6Cw&oe=66E42B90"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SR6_km1OOikQ7kNvgHHCvOI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBT0G2LLULCGwsLZTBGgsbLD0dg_tBLxwed7_O63KFlIw&oe=66E4306E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xpLwEGHCT1kQ7kNvgHoe944&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZ5Nj0YRBbyIg6ZGSRh_tWyEBdT7OyVgYmbvjv6WHYvw&oe=66E41CCA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JHgAelhTQfwQ7kNvgGxSkg4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAT_vZwDgbsErYQFaxRSe7byXo_sthabDWGmZnGvWKFHg&oe=66E414B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport