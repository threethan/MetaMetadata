isplay_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport AND smooth locomotion. \n\nFeel free to rate, comment and give us feedback about what you like, dislike and what could be fun to see in the upcoming levels.\n\nIf you encounter any bugs, please report them on our Discord Server.\nWe will also host give aways and events on discord so join us and be a part of our development.\n\nDiscord: https://discord.gg/EGdpMnq22Y", "short_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://vking.dk/PrivacyPolicyOfficeEscapeRooms.pdf", "developer_terms_of_service_url": null, "publisher_name": "Vikdan Games", "support_website_url": null, "website_url": "https://twitter.com/GamesVikdan", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1409784856104402"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "956386368477165"}, {"status": "PUBLISHED", "id": "354129856480362"}]}, "baseline_off