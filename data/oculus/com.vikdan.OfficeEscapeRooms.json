f2o1qTVfA&oe=66E6BFCA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JHgAelhTQfwQ7kNvgGgtMLB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjgtY1TF2JpLb1V85GDao6R&oh=00_AYBiDLrbXndLxyZbZwC-_eCH78NmeX98hx9hMAO9wWoTUA&oe=66E6B7B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport AND smooth locomotion. \n\nFeel free to rate, comment and give us feedback about what you like, dislike and what could be fun to see in the upcoming levels.\n\nIf you encounter any bugs, please report them on our Discord Server.\nWe will also host give aways and events on discord so join us and be a part of our development.\n\nDiscord: https://discord.gg/EGdpMnq22Y", "short_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://vking.dk/PrivacyPolicyOfficeEscapeRooms.pdf", "developer_terms_of_service_url": null, "publisher_name": "Vikdan Games", "support_website_url": null, "website_url": "https://twitter.com/GamesVikdan", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": nu