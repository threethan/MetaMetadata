5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dN6GAYkEjcUQ7kNvgEu6dCi&_nc_ht=scontent.oculuscdn.com&oh=00_AYA08HpzSspio7m1SFQBmsnamuM1puEKE8G9g0EHGaQqmg&oe=66D5B14F"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v_oWAeVPw74Q7kNvgEwXWCX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBN8OfTO7zDZIRBXmI6Z78M2_LrIkvl9IRGRDNU7GN4zA&oe=66D5AB10"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k--l14X9nXIQ7kNvgFYVfKW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGU-iy1aihmvC8CvbQPzJfu8LIjbyqk2hsj8gl7J4new&oe=66D5AFEE"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qhkFjVE21RoQ7kNvgG7EHEw&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuvsW2FG9mnS25ZsqyRGvqwh0cLqumcZooxt1S877T0Q&oe=66D59C4A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CmknMoENG1IQ7kNvgEC0jdo&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9dt_bK1a6hoQxIk9AoYVyJHG0om5bdu4-RwGnG_utrQ&oe=66D59436"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport