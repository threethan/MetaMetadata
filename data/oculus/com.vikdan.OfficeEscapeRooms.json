5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ya93_gAcigQ7kNvgHUJT1i&_nc_ht=scontent.oculuscdn.com&oh=00_AYC3F5VJaIcmFYf7G3l175P0G_Bo4dA2LHMQ2tR57oBv8A&oe=66DEEBCF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fLuBv8bsE2MQ7kNvgHemAQV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK32lg5_wrn842IPoYr8h7Epmu-883XN4cXhJz9jBMlw&oe=66DEE590"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ChVoyz83lCUQ7kNvgHkur3q&_nc_ht=scontent.oculuscdn.com&oh=00_AYC3MSo-tjCblxP-kgaH0s7h4IQTj66Mk_jhbP5p1K_1Lg&oe=66DEEA6E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0SCOKLo_950Q7kNvgEiSqpN&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8Xb9WnGu9Ff7PrTfIegiCGBY6JkRBF_jpw1vWDDLPCw&oe=66DED6CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IUQ4LSLCmxEQ7kNvgGAMaxu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxKrOB8jwz4DuPAnD-aPT0dimh0ELUNmCzhOIlHkVFTw&oe=66DECEB6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport