5/75593951_393544528725401_2340516974188113994_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dN6GAYkEjcUQ7kNvgGi9GBQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgsDmyloS4zYpOEVJfG9tOHkBk3iJgagqpj5iZve9HCA&oe=66D702CF"}, {"file_name": "ALScreen1.png", "id": "547856909909635", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_547856913242968_3970023683110829318_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kdcj6v1bijoQ7kNvgFjnJ6Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfx3_5ScE8gyrUfWbBH6Hx3AfMGp8JFHwKIM79E8wX5Q&oe=66D6FC90"}, {"file_name": "ALScreen3.png", "id": "220039826634022", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031400_220039836634021_1205905519437625499_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cfUvyPg8lzkQ7kNvgGGIMDO&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7xG_7M1qyOmcnw343SfAA8v04ii8PAIzqIgPaPygZCw&oe=66D7016E"}, {"file_name": "ALScreen5.png", "id": "550404923007699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196229_550404926341032_1115564760555346083_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5feuqGkwTrAQ7kNvgHSt4jr&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4A96NboNizdYAn4XXUZJiesTeSVC-mReliXUlxVuYWQ&oe=66D6EDCA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ALCoverLandscape.png", "id": "514478426666006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_514478429999339_583829579942729446_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CmknMoENG1IQ7kNvgHlhl-Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjwL_XJKhXR28FMsCU1RuBYJufoUkAvWt2fYKipo0uzw&oe=66D6E5B6"}, "display_name": "Office Escape Rooms", "keywords": [], "long_description": "Office Escape Rooms is a series of rooms and areas to explore and solve in order to complete them. \n\nThere are 4 completed levels at the moment. Cubicles, Kitchen, Office and Toilet. 2 more levels are coming, and will be announced here on Side Quest and on our Discord Server as soon as possible. \n\nThe controls are simple and there are teleport