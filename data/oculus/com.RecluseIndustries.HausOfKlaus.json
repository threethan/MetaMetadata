scdn.com/v/t64.5771-25/43997709_476746615363463_6714880900978983819_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJzSUQe-IGAQ7kNvgEHOK1g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDPdQAc1F-6fdi1JwSytWOndwLWdjIQfGD1ltZTmLkKUg&oe=6727736E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GameScreenshot133548885049273007.png", "id": "425906933455169", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221326_425906936788502_2661994550130686239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WBkwKQgHZIYQ7kNvgEQvycr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgwBlEFPw3anka7vzcoS7EqfwpBrZzd37CYdh_ODDMNA&oe=672777AD"}, "display_name": "Haus Of Klaus", "keywords": ["rogue", "retro", "arcade", "stealth", "alien"], "long_description": "Find a way in. Overload the reactor core. Get out again in five minutes - before it all goes boom! Sounds easy right? After all, you've survived a nuclear war and now it's payback time for Klaus Von Klensch, mastermind of the apocalypse! With only a handful of items (Plasma Pistol, EMP grenade, Locator, Adrenochrome Booster, and of course Toilet Brush) you're gonna need some serious attitude to succeed in your mission. Stealthy, shooty, sweary, oldskool arcadey action - with a daily random bunker! ", "short_description": "Find a way in. Overload the reactor core. Get out again in five minutes - before it all goes boom! Sounds easy right? After all, you've survived a nuclear war and now it's payback time for Klaus Von Klensch, mastermind of the apocalypse! With only a handful of items you're gonna need some serious attitude to succeed in your mission. Stealthy, shooty, sweary, oldskool arcadey action - with a daily random bunker!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://recluseindustries.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Recluse Industries", "support_website_url": null, "website_url": "http://www.recluseindustri