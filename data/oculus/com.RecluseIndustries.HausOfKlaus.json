934123363_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CuSODikJds8Q7kNvgF9V8bl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKjmBobbzXk8s3uiUqpW4A4DhEOXxIwSJI3xJr0XueoQ&oe=67275EA5"}, {"file_name": "GameScreenshot133492752140270155.png", "id": "390572183328378", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982566_390572186661711_5750080939902724867_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lhbcMz4Z3bsQ7kNvgEn_KJy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdPoZCSaRWO6dZg_zro0r0BwIq_MpngUpAGp9d9TM1Eg&oe=67274F61"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GameScreenshot133548885049273007.png", "id": "425906933455169", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221326_425906936788502_2661994550130686239_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WBkwKQgHZIYQ7kNvgEQvycr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgwBlEFPw3anka7vzcoS7EqfwpBrZzd37CYdh_ODDMNA&oe=672777AD"}, "display_name": "Haus Of Klaus", "keywords": [], "long_description": "CAN YOU DESTROY THE BUNKER? You've survived a nuclear war and now it's payback time for Klaus Von Klensch, mastermind of the apocalypse! Can you evade or destroy his deadly robot sentries long enough to reach the reactor core? And if you can, will you GTFO again with alarms blazing and everything out to get you?  With only a handful of weapons and tools (Plasma Pistol, EMP grenade, Locator, Adrenochrome Booster, and of course Toilet Brush) you'll need determination and quick reactions to succeed in this fun Roguelite stealth and survival shooter!   ", "short_description": "CAN YOU DESTROY THE BUNKER? You've survived a nuclear war and now it's payback time for Klaus Von Klensch, mastermind of the apocalypse! Can you evade or destroy his deadly robot sentries long enough to reach the reactor core? And if you can, will you GTFO again with alarms blazing and everything out to get you?  With only a handful of weapons and tools, you