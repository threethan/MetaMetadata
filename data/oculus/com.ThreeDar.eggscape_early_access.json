", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39031383_599486309251668_7727205189458227471_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i8l6X_qXaJkQ7kNvgHRcXUw&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAAUFdNO9yk5T-RfQVNBFZSKvM5HSGJjnENuKub4_NG9g&oe=677E751E"}, "display_name": "EGGSCAPE", "keywords": ["Games", "Social", "Action", "Casual"], "long_description": "# Control insane little eggs over endless worlds of threats  \nRun for your life. Fight to survive. Hopefully become an **honorable egg**.\n\n- **Multiple game modes**\n- **Fully immersive level builder**\n- **Weapons**\n- **Vehicles**\n- **Realistic physics**\n- **Evil robots**\n\nPlayers get to customize the characters with the most **eggcentric** style. New levels and weapons every week.\n\n**Free to play.**", "short_description": "Control insane little eggs over endless worlds of threats. Run for your life. Fight to survive. Hopefully become an honorable egg. Multiple game modes, fully immersive level builder, weapons, vehicles, realistic physics and evil robots. Players get to customize the characters with the most eggcentric style. New levels and weapons every week. \n\nFree to play. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.eggscape.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Eggscape Entertainment Inc", "support_website_url": null, "website_url": "http://www.eggscape.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "528142316460358"}, {"id": "1725996564472128"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "s