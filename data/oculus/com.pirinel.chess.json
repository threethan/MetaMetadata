19497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJbafQRys8MQ7kNvgGYUW8i&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvzjZAZAOFHdHcX7cEgEu7ns6bICOKJKjhbsNZfTz4JQ&oe=66DED6CA"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nThe game has many different features besides the standard chess gameplay, including:\n- tens of thousands of interesting puzzles, where you need to find a possible checkmate within 1, 2 or 3 moves.\n- ability to analyze your games and see where you made mistakes, what better moves you could have played, what was the balance (your winning chances) at each move, etc.\n- you can optionally create an account and maintain your progress across multiple devices\n- and many others!\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "r