81437269_3949038679320555927_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CLrII9wy_eoQ7kNvgH53Fui&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhxMpYPYy52jGqyMs0eI7cqg1TeVVEAZJpk4iQ_1Dzlg&oe=67430FEA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2313b4MpGJcQ7kNvgEfzDQj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRRzAESjyWjUcxK908d60idVNctwc8sVQa8eyPIsIxfA&oe=674308CA"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graph