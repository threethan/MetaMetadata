scdn.com/v/t64.5771-25/75612006_667507184520938_286378313808694078_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gpObRYtuaogQ7kNvgEeih9I&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuOqybhO060Ni5fai5SJu1l&oh=00_AYCf6SnGclk18pUte2XWmkNs2f2Xq0P7bNBbG2PDAV_Jaw&oe=66D2E6EC"}, {"file_name": "image_033_0000.png", "id": "265075939050528", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297580_265075942383861_4557208847552725230_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2TgJpTWZWkMQ7kNvgGkvCXX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuOqybhO060Ni5fai5SJu1l&oh=00_AYArpt9gu2GwCk3BPwGsh3yvDSWUP9PDacp89QccV4BMIg&oe=66D2FB44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zY2n2_GTlZAQ7kNvgHYd5Jj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuOqybhO060Ni5fai5SJu1l&oh=00_AYDwy2kGDrKAjDT11ki9NR7qxV_OBz3yA0ecoa8WiG44yg&oe=66D2F94A"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nThe game has many different features besides the standard chess gameplay, including:\n- tens of thousands of interesting puzzles, where you need to find a possible checkmate within 1, 2 or 3 moves.\n- ability to analyze your games and see where you made mistakes, what better moves you could have played, what was the balance (your winning chances) at each move, etc.\n- you can optionally create an account and maintain your progress across multiple devices\n- and many others!\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "479781947223135"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1028698058058645"}, {"status": "PUBLISHED", "id": "403262811296035"}, {"status": "PUBLISHED", "id": "404102887847851"}, {"status": "PUBLISHED", "id": "239920581815526"}]}, "baseline_offer": {"id": "239920581815526"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649348400, "status": "PUBLISHED", "id": "1028698058058645"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6239103822778041", "version": "4.82"}, "id": "383393850455453", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5105708302784