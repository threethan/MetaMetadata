1-7&_nc_sid=6e7a0a&_nc_ohc=CMYT0At_hBcQ7kNvgGfFITp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqXLADa1l0STv096aouH_nsn4AEn6jwYoa15Wn2i6cPQ&oe=671507D0"}, {"file_name": "image_027_0000.png", "id": "761457878103936", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035365_761457881437269_3949038679320555927_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Xxvpr1ptyIQ7kNvgEUNcz3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlNCFCeYXEKdxcxKp45b6WbeXd2cJfxKQV2dfleEabSQ&oe=6714EB6A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wHu7U6H-EygQ7kNvgGRD-rH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7NiUL5EX1Vc8mYTd9CQAQ4GHFyDxo7-4PggcxZwYang&oe=6714E44A"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "c