b=1-7&_nc_sid=6e7a0a&_nc_ohc=COaOwm20aqAQ7kNvgGisu1J&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCpGbeUa6yQdHj7UHxxGnobRASt7YiJZcxn-ts9wkzECg&oe=67124344"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Ko0vEprDe0Q7kNvgEgQRuU&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAZEpFxvsH14dn_wpfN6X23Dce-GZ3-idkuZ9bJ2at2gg&oe=6712414A"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nThe game has many different features besides the standard chess gameplay, including:\n- tens of thousands of interesting puzzles, where you need to find a possible checkmate within 1, 2 or 3 moves.\n- ability to analyze your games and see where you made mistakes, what better moves you could have played, what was the balance (your winning chances) at each move, etc.\n- you can optionally create an account and maintain your progress across multiple devices\n- and many others!\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https: