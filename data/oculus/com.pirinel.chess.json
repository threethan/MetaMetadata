08_380616047039140_218998267777114405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h4lzc2p9IO4Q7kNvgGuerO6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOCDeBENk8bdEdLXXBxYcfUre855H5zydmYd0P1PyprQ&oe=672749AF"}]}, "id": "3129099287305431", "locale": "en_US", "screenshots": [{"file_name": "image_029_0000.png", "id": "3146455479008456", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75297583_3146455482341789_5902729047225085315_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z3wmQiup1XcQ7kNvgG8Wbl1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAa3ImevXCIaIZUbJNsK36eCettOba8Auk9tth4YkLkg&oe=67277CD0"}, {"file_name": "image_026_0000.png", "id": "1054727055256011", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003244_1054727061922677_6696811143861016426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tzSyOymmGnYQ7kNvgHCv4jT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4fNe2vDkqIZdNi5Ef0sNo2cXrdkdJP3lG-OunA0Gclg&oe=672774A6"}, {"file_name": "image_025_0000.png", "id": "1037959166802753", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035392_1037959170136086_8811993302742787927_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sa_FZvckUVIQ7kNvgHl8NAG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdsLILLDcaVGN1Gb0Sqh4pTXjdp7MQwMAXCwdPKz0jPw&oe=6727539D"}, {"file_name": "image_031_0000.png", "id": "667507181187605", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612006_667507184520938_286378313808694078_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qj1Ozw1PyfUQ7kNvgFiDijK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0p0ivrmE9-D13D0aOusojg5qrUDYoUMCPoMGHvb0O3Q&oe=672746EC"}, {"file_name": "image_033_0000.png", "id": "265075939050528", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297580_265075942383861_4557208847552725230_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jhzwn-iSPOAQ7kNvgFECW0h&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVi5VkUSRqBkxl_9HlYZNm6x1YYm44URjSpHR0PXCMIA&oe=67275B44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8WUw-Mih-eoQ7kNvgHV_6NR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzu-m_FlgliXsNOBVv_0okLyk-cajrLhZw74cKjf4FTQ&oe=6727594A"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nThe game has many different features besides the standard chess gameplay, including:\n- tens of thousands of interesting puzzles, where you need to find a possible checkmate within 1, 2 or 3 moves.\n- ability to analyze your games and see where you made mistakes, what better moves you could have played, what was the balance (your winning chances) at each move, etc.\n- you can optionally create an account and maintain your progress across multiple devices\n- and many others!\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], 