e": "image_029_0000.png", "id": "3146455479008456", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297583_3146455482341789_5902729047225085315_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8kiPtqcMgcEQ7kNvgFRXJZb&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azr0Cu3rGAexQIKyhmypBFg&oh=00_AYCzjZHGkg_BbmuaLay5cPAjsHQ-1RTyu6ffjvAvAGn-1Q&oe=66EFE590"}, {"file_name": "image_027_0000.png", "id": "761457878103936", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035365_761457881437269_3949038679320555927_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VWbPLHdcuCcQ7kNvgHahUrf&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azr0Cu3rGAexQIKyhmypBFg&oh=00_AYANwt5R-6tPfzo6we6ipm7SLoFA9p7U1wAo8W8fyyqT7A&oe=66F0016A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g2VTNBe01s4Q7kNvgF-x4VB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Azr0Cu3rGAexQIKyhmypBFg&oh=00_AYBUMym8SosL3bO8kNtUu3bCTOiRiqo1Pt0BtcUyoZZatQ&oe=66EFFA4A"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshol