cdn.com&oh=00_AYBgw7LnGvnq1cFsatCaA-Wm29O_qtNDowBZMN72_2iSnA&oe=66F13C2F"}]}, "id": "3129099287305431", "locale": "en_US", "screenshots": [{"file_name": "image_029_0000.png", "id": "3146455479008456", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297583_3146455482341789_5902729047225085315_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8kiPtqcMgcEQ7kNvgFEpWti&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKNEdtEChvkDufOwUgOOt5DuBce8SaDgPMYxELmPQAGA&oe=66F13710"}, {"file_name": "image_026_0000.png", "id": "1054727055256011", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_1054727061922677_6696811143861016426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DUT7Ov-iWfUQ7kNvgHhELDs&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8K25gb03YKeLSE6OAbumo6Fqq2pX45CohEe3QlDdRFw&oe=66F16726"}, {"file_name": "image_025_0000.png", "id": "1037959166802753", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035392_1037959170136086_8811993302742787927_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L2k4u5EpuIQQ7kNvgFYepxV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDuTRi8CW9TnNji7JOryo4zFyIp-of9diuLOV5Yq-g7Kg&oe=66F1461D"}, {"file_name": "image_031_0000.png", "id": "667507181187605", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612006_667507184520938_286378313808694078_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fqvvItmcqXUQ7kNvgF9NKHI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzfz_QIdiAtau4e0_3IHJwPpN4PGz_fa4Y6nZCV1oEzQ&oe=66F1396C"}, {"file_name": "image_033_0000.png", "id": "265075939050528", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297580_265075942383861_4557208847552725230_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jjMUGEDCewwQ7kNvgFAXdyV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCr8mHyYVAHMPvYH2aVhYT7Iip3S2vxnWaI0jVAVvBApQ&oe=66F14DC4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_026_0000.png", "id": "1663884603977026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451777_1663884610643692_5999330319497865154_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFuI8QBya6cQ7kNvgEXMO-8&_nc_ht=scontent.oculuscdn.com&oh=00_AYD96LAtcbKAh4TRMO8_SVD2-BvK6q5RDkF2j79Q-SqS9g&oe=66F14BCA"}, "display_name": "Virtual Chess", "keywords": [], "long_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment.\n\nThe game supports many different platforms - VR, smart phones, tablets, smart TVs, so you can play with your friends even if they don't use a VR headset.\n\nThere are also many online players that you can play with and the rating algorithm will make sure that you're matched with opponents of a similar strength, so you can always enjoy an interesting and competitive game.\n\nThe game has many different features besides the standard chess gameplay, including:\n- tens of thousands of interesting puzzles, where you need to find a possible checkmate within 1, 2 or 3 moves.\n- ability to analyze your games and see where you made mistakes, what better moves you could have played, what was the balance (your winning chances) at each move, etc.\n- you can optionally create an account and maintain your progress across multiple devices\n- and many others!\n\nWe hope you like it!", "short_description": "Play chess with your friends, with random people online or against the computer in a beautiful VR environment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesshold.com/privacy-policy", "developer_terms_of_service_url": "https://chesshold.com/terms", "publisher_name": "Pirinel", "support_website_url": null, "website_url": "https://chesshold.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graph