982606_990452582492472_4565310538538417105_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0mR8iIfqazoQ7kNvgElcAJj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmSYAtmoO9RKVAVTDzrNLESE3LkMhBgx6DxFSB5gjlDA&oe=66CC7839"}, {"file_name": "AppLabScreenshot2.png", "id": "1152365636171360", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982616_1152365639504693_824417062395392486_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7GEb9szAeIgQ7kNvgH2CZrI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEsJFpi3fjHkPwyjKc3CFj11MUUgl2YQ-t8qJ1qUP1aA&oe=66CC69D9"}, {"file_name": "AppLabScreenshot3.png", "id": "413754801149434", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974886_413754804482767_4855071253066670020_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xhhijOVpE_kQ7kNvgGVCtlO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxMujPtkiBhG2osNRKtayly0xwtn1aikAfUdBgc8s6HA&oe=66CC4F96"}, {"file_name": "AppLabScreenshot4.png", "id": "294435413666212", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_294435416999545_3795438112730856325_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CjhhuzJQsPgQ7kNvgEqxkgZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYm_9ZJnFKvxqpZZDbur1yHvCX5FBWFrQfkhf8-vlYwg&oe=66CC7BCA"}, {"file_name": "AppLabScreenshot5.png", "id": "938499564352926", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974657_938499567686259_86769797011572924_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Rff4AcanwsQ7kNvgHB3mqp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCX1LAGLPYJjz09KUtsTdWvCpQfk7wKAnFEPcak_H4qw&oe=66CC810E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover2560x1440.png", "id": "436329968864272", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974655_436329972197605_6304746820845701801_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qnicEPb4p9sQ7kNvgGuezAU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsIR1AKyPoJwxWuD-F96Tlq8hOnUNI6BlqWbVTFT4tAQ&oe=66CC76A1"}, "display_name": "Primitier", "keywords": [], "long_description": "Primitier is a highly flexible VR sandbox game, where you can create tools and machinery by freely cutting and connecting objects in a vast world based on physics simulation.\n\n- True Crafting System\nAlmost all objects in the game can be freely cut or attached to other objects. Instead of assembling pre-defined recipes, you can create tools as freely as you would in real-life crafting.\n\n- Vast World\nYou can seamlessly move through the vast world that is automatically generated. As you explore the world, you may encounter enemies, so create weapons to defend yourself.\n\n- Advanced Physics Simulation\nIn addition to basic rigid body simulation, the game also includes simulations for air resistance, lift, and buoyancy, allowing for the creation of physically operational boats and airplanes.", "short_description": "Primitier is a highly flexible VR sandbox game, where you can create tools and machinery by freely cutting and connecting objects in a vast world based on physics simulation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://primitier.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Ota Mato", "support_website_url": null, "website_url": "https://primitier.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24950376051244970"}}]}, "schedule