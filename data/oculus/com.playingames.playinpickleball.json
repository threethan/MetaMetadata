e=66E42E87"}]}, "id": "494248992997130", "locale": "en_US", "screenshots": [{"file_name": "2.0.10 - Multiplayer 2v2 - Forest - Cole (3rd Person)-00.06.33.669.png", "id": "1047804619590859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031651_1047804622924192_7416084336963619626_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZqOXe5a6qgsQ7kNvgFqdoXq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAL_sHHXrXi_3QUBtKt0Fkiur51dx7BJGEOUHHj2D8oyQ&oe=66E43740"}, {"file_name": "1v1-mixed-reality.png", "id": "1168714654506317", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234370_1168714657839650_8893784557671538106_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sS8oHrficgQQ7kNvgGlDYsz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGv3DdHJHA3w5zo7SKzgYsUO5oJrCLt7FXKzsFghfytA&oe=66E40FA0"}, {"file_name": "training-4.png", "id": "438582305285283", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556279_438582308618616_5242317205619296025_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9NE_GlMrncsQ7kNvgEYYokP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDuIuT3IDilLrdxyDHHOxCONHtj2RrdPMCET765xC_yjg&oe=66E42056"}, {"file_name": "training-2.png", "id": "1847807415653937", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234370_1847807418987270_4105168645406339521_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPNFt_xrtRkQ7kNvgFjv4WC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiTj1y7DfrVuA26_s-DVv1Yow2WLjY9p2p0iMVl0paYA&oe=66E4363B"}, {"file_name": "2v2-men-2.png", "id": "989747499242741", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982475_989747502576074_7858789978786912538_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ePNIQNTTfIQ7kNvgFJkDf_&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0L1RVfUqQPBvqYHrTnY2v2QiqzWPqmYZ97ST4tSUkfg&oe=66E40EE9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pickleball One - Meta Store - Landscape - Characters (2560 x 1440 px).png", "id": "1886405798536207", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974608_1886405801869540_8128136653866527962_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJc6wnVpXWwQ7kNvgFgx_6t&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQzeVr--ZiXJGLTIzQ14u8f_vfx8yWBgus31t7zaM62Q&oe=66E40B6E"}, "display_name": "Pickleball One", "keywords": ["Fitness", "Social", "Tennis", "Health", "workout"], "long_description": "DISCOVER PICKLEBALL FUN\nPickleball One welcomes you to the world of pickleball, perfect for both new and experienced players. With our user-friendly interface, you can dive into the game solo or join others, learning the basics and enjoying the depth it offers for every level.\n\nPLAY WITH FRIENDS IN SINGLES AND DOUBLES\nJoin a vibrant community where friendships flourish over pickleball. Challenge friends to singles or doubles matches, or simply enjoy the social aspects of the game together. It's a fantastic way to keep the spirit of pickleball alive, whether competing or spectating.\n\nMAINTAIN YOUR GAME YEAR-ROUND\nStay sharp and keep your pickleball skills honed with our comprehensive training and fitness modules. Perfect for players looking to maintain their edge during the off-season, our app offers targeted practice for all aspects of the game, from strategic plays to physical fitness.\n\nIMMERSIVE MIXED REALITY EXPERIENCE\nStep into a mixed-reality world where your virtual and physical spaces merge seamlessly. Thanks to advanced technology like the full-color Passthrough feature on select Meta Quest devices, you can enjoy safe, unrestricted movement, enhancing your practice sessions and workouts.\n\nSUPPORTIVE COMMUNITY\nJoin our helpful community! Connect with fellow players and developers via the Pickleball One Discord channel and for direct assistance, email support@playingames.net.", "short_description": "Dive into America's fastest-growing sport while making new friends with Pickleball One. Perfect for both newcomers and experienced players, our user-friendly interface allows you to master pickleball solo or join others. Whether you're learning the basics or diving deep into the game, Pickleball One has something for everyone. Experience the ultimate social sports and fitness platform, complete with in-depth fitness and training modules, immersive wall drills, practice sessions, and workouts."}]}, "developer_name": "Playin Games", "developer_privacy_policy_url": "https://pickleballone.app/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Playin Games", "support_website_url": null, "website_url": "https://pickleballone.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7780736098689608"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974534_1730139507460798_1462078488803047836_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yq_6JOAk3F4Q7kNvgGCJ_XC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdUKjqL5luBVfyGdly5gZXtecHQj0iPHQuoy4lsTX1cA&oe=66E41851"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pickleball One", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Simulation", "id": "3315291881