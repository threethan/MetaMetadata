=6e7a0a&_nc_ohc=b2J0LOYodwMQ7kNvgGI4iEO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCifEzFkp0A56tVbUY-psoJhw-x1iTa-YQapenegEghig&oe=67374E64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pickleball One - Meta Store - Landscape - Characters (2560 x 1440 px)_N1.png", "id": "571883458625830", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392881_571883461959163_416005271325069310_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=39MM2Qu_sN4Q7kNvgHlCO4E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnkDPZWYt1brMv_-HF2-BaZDmWsbPwc9xNmljER7TF3w&oe=67373081"}, "display_name": "Pickleball One", "keywords": ["Fitness", "Sports", "Racket", "Tennis", "Golf"], "long_description": "# THE ULTIMATE PICKLEBALL\nPickleball One delivers unmatched realism for all skill levels. Whether you're a beginner or a pro, you'll love the feel of the ball on paddle. Play solo or with others to learn, compete, and explore the game's ever-expanding features.\n{899864472044928}\n# PLAY SINGLES OR DOUBLES\n\nChallenge friends to singles or doubles matches and enjoy a variety of game modes, social features, and customizable match settings including visibility, physics, and scoring options.\n{842406564539750}\n# MAINTAIN YOUR GAME YEAR-ROUND\n\nPerfect for players looking to maintain their edge during the off-season, Pickleball One offers targeted practice for all aspects of the game, from strategic plays to physical fitness.\n\n{950141080279708}\n\n# COMMON QUESTIONS\n\n**Will I have enough space to play?**\n\nYes, the game adapts to different sized spaces, with adjustable movement settings.\n\n**Do paddle adapters enhance realism?**\n\nYes, and you can choose from a growing list of vendors that provide Pickleball One compatible adapters.\n\n**What is Mixed Reality mode?**\n\nIt\u2019s where your virtual and physical spaces blend, allowing safe, unrestricted movement to enhance your Pickleball One practice sessions and workouts.\n\n**How can I get support or connect with others?**\n\nJoin the Pickleball One Discord or email support@playingames.net for assistance.", "short_description": "Dive into America's fastest-growing sport while making new friends with Pickleball One. Perfect for both newcomers and experienced players, our user-friendly interface allows you to master pickleball solo or join others. Whether you're learning the basics or diving deep into the game, Pickleball One has something for everyone. Experience the ultimate social sports and fitness platform, complete with in-depth fitness and training modules, immersive wall drills, practice sessions, and workouts."}]}, "developer_name": "Playin Games", "developer_privacy_policy_url": "https://pickleballone.app/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Playin Games", "support_website_url": null, "website_url": "https://pickleballone.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8533016206794923"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035422_859433035937363_6327755442539697963_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DWS3SCml72QQ7kNvgE-M6jK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQdHB7BijL0sgQuidaoWfVFoEjRBdlYlwPEg1syO97cQ&oe