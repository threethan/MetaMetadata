645_3635332839698054638_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBfekxyAlrgQ7kNvgEB4kiL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgKIl_zcCh2oGOQ7i0_FeFmId-zuubNvrMsH7CpME0yw&oe=671E380E"}, {"file_name": "Screen_Shots_02_F.png", "id": "593665125587265", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75322602_593665128920598_3332741183428305229_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dij7PfWJ1SYQ7kNvgEDBf88&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHQs6-q8-JL8T-qrQpKhU8PELKeIGcKldGjDBg5HDyXg&oe=671E21E4"}, {"file_name": "Screen_Shot_01.png", "id": "367235285574040", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982708_367235288907373_7715562111438165148_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lux9uXB8Ql0Q7kNvgGGxPCk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3EwOMlx-J2WMxEtGDwKnQ3Pdp9ruAFiLEgiIvzHbVYA&oe=671E2403"}, {"file_name": "Screen_Shot_03.png", "id": "1276336616104304", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001717_1276336619437637_240862550888732066_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zRxkLimaRQ8Q7kNvgEDbyqI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRANcy8gCd1ehXw8TOEkMfZzZpGsapXODKVxPrD1Bh9A&oe=671E349E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_Thumbnail.png", "id": "588051386257626", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_588051389590959_1476709482072288035_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrDlnia-YWkQ7kNvgHPOyC3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4icA0dgRcpG9PS22kDWN9_yjggXDhcfH6QJ29hmzISA&oe=671E3A8C"}, "display_name": "Playin Pickleball", "keywords": [], "long_description": "Playin Pickleball is the first, authentic reproduction of Pickleball in Virtual Reality! Physics, sounds and mechanics have been carefully mapped from actual Pickleball game play. Even the scoring and rules are based on the USA Pickleball Association\u2019s Official Rulebook.\n\nBut don\u2019t worry if you have never played Pickleball before. Playin Pickleball will teach you the basics and help keep score while making sure you are always serving from the correct side of the court! Have fun learning the basics of Pickleball. Train, practice and play single and doubles matches against AI of varying difficulty. \n\nComing soon: multiplayer support \u2013 with casual and ranked matches, more beautiful environments, and more paddles to choose from! Enjoy the game and help us make this the best game ever by joining our \u201cPlayin Pickleball\u201d Discord community. ", "short_description": "Playin Pickleball is the first, authentic reproduction of Pickleball in Virtual Reality! Physics, sounds and mechanics have been carefully mapped from actual Pickleball game play. Even the scoring and rules are based on the USA Pickleball Association\u2019s Official Rulebook.\n\nCome and have fun learning the basics of Pickleball! Train, practice and play single and doubles matches against AI of varying difficulty. Multiplayer, new environments and more paddles are coming soon!"}]}, "developer_name": "Playin Games", "developer_privacy_policy_url": "https://playinpickleball.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Playin Games", "support_website_url": null, "website_url": "https://playinpickleball.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "u