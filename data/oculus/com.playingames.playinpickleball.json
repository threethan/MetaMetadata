=6e7a0a&_nc_ohc=PrvATdr_UWoQ7kNvgEx5uLk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8XiwvXDqj9TyX0nkIIy9sIXnGTfNHIe2N_lYbR3E5og&oe=671E41E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Pickleball One - Meta Store - Landscape - Characters (2560 x 1440 px)_N1.png", "id": "571883458625830", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392881_571883461959163_416005271325069310_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uatl22FFlXoQ7kNvgHvsxJc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBaIBznfScKzhOqJ-UVTdrQiByZdSrX6G3a0IhyrA0lLw&oe=671E2401"}, "display_name": "Pickleball One", "keywords": ["Fitness", "Sports", "Racket", "Table", "Tennis"], "long_description": "# DISCOVER PICKLEBALL FUN\n\nPickleball One delivers the most lifelike pickleball experience for players of all skill levels. Whether you're a beginner or seasoned pro, dive into the game with our easy-to-use interface. Play solo or join others to learn, compete, and enjoy the variety and excitement the game offers.\n{899864472044928}\n# PLAY WITH FRIENDS IN SINGLES AND DOUBLES\n\nJoin a vibrant community where friendships flourish over pickleball. Challenge friends to singles or doubles matches, or simply enjoy the social aspects of the game together. \n{1460345488008501}\n# MAINTAIN YOUR GAME YEAR-ROUND\n\nPerfect for players looking to maintain their edge during the off-season, Pickleball One offers targeted practice for all aspects of the game, from strategic plays to physical fitness.\n\n# EXPERIENCE IMMERSIVE MIXED REALITY \n\nStep into a mixed-reality world where your virtual and physical spaces merge seamlessly. Enjoy safe, unrestricted movement, while enhancing your practice sessions and workouts.\n\n# JOIN OUR HELPFUL COMMUNITY\n\nConnect with fellow players and developers via the Pickleball One Discord channel and for direct assistance, email support@playingames.net.\n\n# A GAME FOR EVERYONE\n\nWhether you\u2019re into racket sports like tennis, padel, ping pong, or precision games like golf, pool, and bowling, Pickleball One has you covered!\n{842406564539750}", "short_description": "Dive into America's fastest-growing sport while making new friends with Pickleball One. Perfect for both newcomers and experienced players, our user-friendly interface allows you to master pickleball solo or join others. Whether you're learning the basics or diving deep into the game, Pickleball One has something for everyone. Experience the ultimate social sports and fitness platform, complete with in-depth fitness and training modules, immersive wall drills, practice sessions, and workouts."}]}, "developer_name": "Playin Games", "developer_privacy_policy_url": "https://pickleballone.app/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Playin Games", "support_website_url": null, "website_url": "https://pickleballone.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8453202058109672"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035422_859433035937363_6327755442539697963_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U3jqv012FokQ7kNvgGP76yO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1bW4APbS4SeNrjvsAw-AwOicHcLfXjT66sN4Fy88ODw&oe=671E2639"}, "is_concept": false, "is_test": f