.com&oh=00_AYCeQc1N7fn0RIlXd517s3_YBfwdYakKOk2lpGj7H0c1NA&oe=66D1AAE4"}, {"file_name": "Screen_Shot_01.png", "id": "367235285574040", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_367235288907373_7715562111438165148_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t2RlfyX3wrIQ7kNvgGmm10X&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBaOQB6xtL0McoNElTbTbQmT6xMXgEU9pyCh7OFhs04w&oe=66D1AD03"}, {"file_name": "Screen_Shot_03.png", "id": "1276336616104304", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001717_1276336619437637_240862550888732066_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1TVCdb-6e2IQ7kNvgHyECXY&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMHmDtCvwTrfzqETcMdGLx0mdisjLEfdXy2vogqO5oYQ&oe=66D1BD9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_Thumbnail.png", "id": "588051386257626", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_588051389590959_1476709482072288035_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eqbCkQnkLpUQ7kNvgG-7f2P&_nc_ht=scontent.oculuscdn.com&oh=00_AYCm1g-1YuKO1PKvNxuuYcLdzgW0VlXtMiWY4QrTAFGHTg&oe=66D1C38C"}, "display_name": "Playin Pickleball", "keywords": [], "long_description": "Playin Pickleball is the first, authentic reproduction of Pickleball in Virtual Reality! Physics, sounds and mechanics have been carefully mapped from actual Pickleball game play. Even the scoring and rules are based on the USA Pickleball Association\u2019s Official Rulebook.\n\nBut don\u2019t worry if you have never played Pickleball before. Playin Pickleball will teach you the basics and help keep score while making sure you are always serving from the correct side of the court! Have fun learning the basics of Pickleball. Train, practice and play single and doubles matches against AI of varying difficulty. \n\nComing soon: multiplayer support \u2013 with casual and ranked matches, more beautiful environments, and more paddles to choose from! Enjoy the game and help us make this the best game ever by joining our \u201cPlayin Pickleball\u201d Discord community. ", "short_description": "Playin Pickleball is the first, authentic reproduction of Pickleball in Virtual Reality! Physics, sounds and mechanics have been carefully mapped from actual Pickleball game play. Even the scoring and rules are based on the USA Pickleball Association\u2019s Official Rulebook.\n\nCome and have fun learning the basics of Pickleball! Train, practice and play single and doubles matches against AI of varying difficulty. Multiplayer, new environments and more paddles are coming soon!"}]}, "developer_name": "Playin Games", "developer_privacy_policy_url": "https://playinpickleball.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Playin Games", "support_website_url": null, "website_url": "https://playinpickleball.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "381508467345114"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "8018895604864620"}, {"status": "CANCELLED", "id": "506603341732212"}, {"status": "PUBLISHED", "id": "466743075913185"}, {"status": "PUBLISHED", "id": "174780079015920"}, {"status": "PUBLISHED", "id": "712844764347985"}, {"status": "PENDING", "id": "663158035754132"}, {"status": "PENDING", "id": "702869911768342"}, {"status": "PUBLISHED", "id": "337999748876899"}, {"status": "PUBLISHED", "id": "782575149551095"}, {"status": "PENDING", "id": "1587824788