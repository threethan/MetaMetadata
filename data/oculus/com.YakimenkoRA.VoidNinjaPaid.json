8823942112660517_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nv9b43IZpyEQ7kNvgHJYLl0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwO4yZ2yzd9iXosvcnuY8lc9sAxcsLRpUXLeCyIL924Q&oe=66FFCCFF"}]}, "id": "1209431700101008", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "862658561998842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569460_862658565332175_7181324119631948326_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_pCO7PQSVvIQ7kNvgHAhQ_Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_EhNMY73a7Uf6jip9WB2xbv1cCixEqfFQ7BcZNS65wQ&oe=66FFD54A"}, {"file_name": "2.png", "id": "288277161030774", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982715_288277164364107_3683242160947525903_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFxJndGfjJcQ7kNvgH3-Xx4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzJmXIz5gsY8HYuGUcSf-uawM8ZlbYODYkzOhOIMYVhQ&oe=66FFC3B7"}, {"file_name": "3.png", "id": "1834265940394865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_1834265947061531_5846647720286157075_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=isCtkkV5bToQ7kNvgEFaChs&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHpj89Rg4fjLe6TPKjRJ_-HmSZv7x9BdrH78eZuK0y4g&oe=66FFBFEF"}, {"file_name": "4.png", "id": "2031682293901788", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570314_2031682300568454_7181790668181460473_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H7yj1dcTOvAQ7kNvgESExyM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAVUKvzs26lyzDuyPqyo_NLejj5ZiJOhPnUnhwPihN5nQ&oe=66FFC7C8"}, {"file_name": "5.png", "id": "1182641809455371", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982685_1182641812788704_4892425978473987963_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IkkZK_IS4PgQ7kNvgFjJK4s&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLo0ZLPtJq43-xZWPqskbiEnkGrYORsrtt0Z6YnVVeCg&oe=66FFD8A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "16x9-2.png", "id": "7747279352020652", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610710_7747279362020651_5612876263433505548_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MBPzYRFdcq0Q7kNvgHtm0km&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4BSQ1KXkPsZ1aIw1KXk-VISFiVZexQGoEZodV58ikxQ&oe=66FFBE5A"}, "display_name": "Void Ninja", "keywords": ["action", "platformer", "runner", "ninja", "void"], "long_description": "Void Ninja is an **action platformer** game that blends runner elements with a unique **\u201cJinba Ittai\u201d locomotion**.  \n\n\ud83d\udc49Gameplay: You're **always on the move and can't stop**. Use your hips and shoulders to steer on the path. Overcome obstacles and clear out enemies.   \n\n\ud83d\udc49**Just one button \u2014 let your body do the rest!*** \nYou don't need to remember million of combinations, or press something to move  - run with the flow.  \n\n\ud83e\udd77\ud83e\udd77\ud83e\udd77  \n\n# Key Features:\n\n- **Unique natural flow locomotion:**   \nInspired by the \"Jinba Ittai\" philosophy, this system ensures perfect unity between player and the game - you simply act as you would in real life  \n\u2796  \n- **Comfort / Motion sickness tested:**  \n 85% of players experienced no symptoms, 10% adapted after 30 minutes, and 5% did not adjust and we prefer not to talk about them  \n\u2796 \n- **Platformer / runner:**   \nFirst-person platforming adventure inspired by a certain blue hedgehog. Intense combats,  adrenaline-pumping jumps and jet-powered flights - this game will keep your heart racing   \n \u2796 \n- **Combat dance:**   \nAs you progress, you'll develop your own unique moves and combos crafted by your skill, not pre-made by the developers  \n \u2796\n- **Level reassembly:**   \nEach time you load a level, it\u2019s generated in a new and unique way   \n\n \n\u2795**21 Level-Stages** designed to test your reflexes, agility, and quick thinking.\n\n\ud83e\udd77\ud83e\udd77\ud83e\udd77 \n\nThis is work in progress version.\n**Share your thoughts, ideas and feedback with us** - let's make the game together.\n\n*rarely its 2 buttons, but you won't confuse them. Only 1 sounds better, right?\n", "short_description": "Void Ninja is an action platformer game that blends runner elements with a unique \u201cJinba Ittai\u201d locomotion system. \n\nLocomotion x Controls. \nJust one button \u2014 let your body do the rest!\nYou don't need to remember million of combinations, or press something to move  - run with the flow & help your enemies to meet your katanas.\n\nStep into the shoes of a hero who races forward through a treacherous void, armed with 2 fast katanas and razor-sharp reflexes."}]}, "developer_name": "Roman Yakimenko", "developer_privacy_policy_url": "https://void-ninja.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Magic Web Solutions", "support_website_url": null, "website_url": "https://void-ninja.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7846840572108730"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223480_1389025115834181_7304722132984924112_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a4sMWz7zSGQQ7kNvgGybB_5&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoD0gvCxiUI3J4wZDUqVxHRdnbjG1QI53oLnJTZHTtJw&oe=66FFEBBA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Void Ninja", "platform":