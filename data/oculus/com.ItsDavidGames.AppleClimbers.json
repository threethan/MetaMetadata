"https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196221_1458156164860457_2430690247570018569_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0CIUz_pR_lMQ7kNvgGLKfOn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-JwSiJOlXFzTFTW6NkorJROndAwVHX8eU8L0ue2R78w&oe=676FD4F4"}, {"file_name": "ss 4.png", "id": "922807669894554", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974666_922807673227887_6616358259615155359_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jjTEiRaLrUsQ7kNvgGSaorA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3envjHb84NfYr_RC0_KX2vFpNXcC-lfM9U2GXc8OcmQ&oe=676FD286"}, {"file_name": "ss 5.png", "id": "1098043458708962", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974879_1098043462042295_8937848613817153701_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bL_FrseRw9AQ7kNvgHgQHGu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAO45k30pU3Ho1Wl1CqPpPWy6l_wRVk1SzLLRERLwaPwQ&oe=676FCDF6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1084728393095589", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982529_1084728396428922_3337893617723643322_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ndPEGuESid8Q7kNvgGRyGQR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3U1NtBecYfQKTp2Avu-TQj8zz3oX8qHLVJTndU01-Ew&oe=676FD550"}, "display_name": "Apple Climbers", "keywords": ["apple", "fangame", "gtag", "climbers", "fast"], "long_description": "Apple Climbers is a hand based locomotion game featuring the wonderful fruit, apples!\n# ABOUT THE GAME\nApple Climbers is a simple game, but with a big twist! Instead of moving normally with your thumbstick, you have to move with your controllers!\n{1251665725975845}\n# THE MAPS AND GAMEMODES\n**MAIN MAP:** The Main Map is the hub space for the apples, with many things to do! Explore what the Main Map has to offer, go into the Closet to look at and purchase cosmetics, or interact with other apples!\n\n**GRAPPLE:** Grapple features a prototype-like land, equipped with a Grapple Gun that you can use to swing on the automatically generated Grapple Blocks!\n\n**FREERUN:** Freerun is a speedrun-like mode, where you can race to get the high score on the leaderboard!\n\n**DUNGEON:** Dungeon is a dark, fast-paced horror mode featuring many creepy and always watching monsters! Can you do it?\n\nExpect more modes to come, have fun!\n{852082436955334}\n\n**DISCLAIMER:**\n\nThis product is not affiliated with Gorilla Tag or Another Axiom LLC and is not endorsed or otherwise sponsored by Another Axiom LLC. Portions of the materials contained herein are property of Another Axiom LLC. \u00a92021 Another Axiom LLC.", "short_description": "Apple Climbers is a hand based locomotion game featuring the wonderful fruit, apples! Play a series of gamemodes including Grapple, Freerun, Dungeon, and more!"}]}, "developer_name": "Applebyte", "developer_privacy_policy_url": "https://applebytevr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Applebyte", "support_website_url": null, "website_url": "https://applebytevr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "9098262460216962"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982711_1204259534136927_2517403