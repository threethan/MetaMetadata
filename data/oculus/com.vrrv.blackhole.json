//scontent.oculuscdn.com/v/t64.5771-25/11162731_512974619047118_7832018412107726848_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OSmbJUoX4eMQ7kNvgG3eYqP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPMpCw-VQt84Qcc7v_INSwh1McklWOXRbph4BkwwKIlA&oe=66D6FB31"}, {"file_name": "migrated_image.png", "id": "509875896351172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_121841808466417_1215290163526107136_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0a6XaPv6XqgQ7kNvgFO138n&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5hfD0G5_i0KSBD2rL3LllQiDIYIa2PPAlVBsQsAj9BQ&oe=66D6FB4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Blackhole.png", "id": "2008295116073869", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162726_2008295119407202_727182055347060736_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wq-wPjOg6MsQ7kNvgFuK_QY&_nc_ht=scontent.oculuscdn.com&oh=00_AYANXx2IKcB5aD1XYKf8o4jP09xChvp6-vGmqpCV5P_ypA&oe=66D70C81"}, "display_name": "Black hole", "keywords": ["blackhole"], "long_description": "Black hole is an educational VR experience which provides a unimaginable immersive way to learn:\nHow a black hole is formed?\nHow to create?\nWhat does it looks like?\nAnd what's inside?\n\nCome in, learn black hole in VR's unique way.", "short_description": "Black hole is an educational VR experience which explains how the black hole is formed, observe it in a very close range, create one by hand and enter to see what's inside."}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrrv.tv/", "developer_terms_of_service_url": "http://vrrv.tv/", "publisher_name": "Photon Interactive", "support_website_url": null, "website_url": "http://vrrv.tv/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "315838003679545"}, "review_messages": ["", "", "Hello, thanks for resubmitting your app. This is an interesting and informative experience. In the Swallow section, there is no explanation or voiceover to help the user understand what is happening. It is generally understandable, but doesn't seem consistent with the way the other sections are represented.\nIn the section where the impact on the grid is portrayed as planets, stars, and eventually the black hole comes towards you, the black hole exhibits a rendering artifact in the grid as it is distorted. As you look at the bottom of the grid, it will pop in/out of visibility for the user. This is particularly a problem as that apex of the curve is exactly where the user will be incentivized to look. Additionally, as planets or objects pass by you, I would recommend you reverse the text so that it remains readable to the user's position, or alternatively make your text billboard one-sided so that the text disappears as the planet or object passes you by. This is getting very close to launch. Look forward to seeing your next build!", "Thanks for submitting to the Oculus Store. We think this is a candidate for the Gallery section. Before approving to release, we wanted to check in and see if you had considered a professional voice over for the app. We think the app would benefit from that type of work. If this something you would be interested in doing, simply re-submit for approval and we'll get you started."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162706_262815920877324_8606548547703144448_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TRDukafPWJsQ7kNvgEM0oQ5&_nc_ht=scont