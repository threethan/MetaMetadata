_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QqOtDGd6MaUQ7kNvgFuyKKS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBDuYuPdzR8-_3qjcfBQnJabBZsGKujUx-OLHfcl_2lzg&oe=66E571AB"}]}, "id": "1046515957075747", "locale": "en_US", "screenshots": [{"file_name": "s1.png", "id": "318780111304792", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974776_318780117971458_2654408182135967797_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffCb8ErDByEQ7kNvgG6zWQi&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtq0wqhDtcYuIbxygOnGRFdduxp_i1Qdm5pkip-gfaxA&oe=66E58323"}, {"file_name": "s5.png", "id": "8130746326955561", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035459_8130746333622227_2717421847225374642_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRTdz5Sr6JkQ7kNvgF6hXpQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDh0_cU-C4RxIlUwd-5NSqQnDaaBZDoi-Qep9zE6DbIYA&oe=66E58DE3"}, {"file_name": "s2.png", "id": "1120491249241440", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570301_1120491252574773_2492706531371093963_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hgKR7RiCCX8Q7kNvgFd8Kq6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpwiiEYOdTs3glhGAgqcFx5tx9kVhBr78XKEQwSkM_2A&oe=66E557C4"}, {"file_name": "s3.png", "id": "503380638698349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031459_503380642031682_9070431829033975989_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uxM0LHTkrbsQ7kNvgE86ia1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDn-6LimHXatN1_eFOzaOGAqwiwjO7wq8usa2bVq4_q_w&oe=66E58720"}, {"file_name": "s4.png", "id": "437303129199364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_437303132532697_7909222666923155644_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6hzMJK-nuxsQ7kNvgG13jb9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAT4VzQIWkQACOnAXqbuGDoP4TrpzuH38c3yKV0Dmyv_Q&oe=66E585DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "I am sequrity 2560 x 1440.png", "id": "1398406160866186", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974689_1398406164199519_4655403560096238791_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f_-_u_rE9d8Q7kNvgH6PdbY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfVp0knx8w0RqE8klWTNh7xCJPjGTqUkFTqZDLtRtvtw&oe=66E558E3"}, "display_name": "I Am Security", "keywords": [], "long_description": "EARLY ACCESS\n\nStep into the shoes of a club security guard in \"I Am Security,\" where your job is to keep the club safe and ensure only the right guests get inside. As a security guard, you\u2019ll face a variety of challenges that will test your observation and decision-making skills.\n\nYour main task is to identify who can enter the club and who can't. Guests will line up, and you must decide if they are allowed in based on certain criteria. Some guests might try to sneak in with prohibited items, and it's up to you to find these hidden objects. Use a range of tools, like metal detectors and scanners, to inspect the guests and uncover anything suspicious.\n\nTo make things more interesting, the game offers a shop where you can buy new items and tools. These upgrades will help you improve your security skills and make your job easier. With every level, the difficulty increases, and you\u2019ll encounter more complex scenarios and tougher decisions.\n\n\"I Am Security\" is all about quick thinking and sharp attention to detail. Will you be able to spot the troublemakers and keep the club safe? Play now and find out!", "short_description": "Security\u2019s call, catch them all."}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "