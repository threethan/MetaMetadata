n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=grdB49Yh63gQ7kNvgGxpcyK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDn1MxrbwvHBe5WJT6-lfkPeSZ76-iJdW4XC6-MR-xK7g&oe=677FC6A0"}, {"file_name": "s4.png", "id": "437303129199364", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035326_437303132532697_7909222666923155644_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rCdVqYo78K0Q7kNvgFfu3Lu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3jndAowDXhikznu9Ss06aEPQNKV-qvvs1odZ6VKWu4A&oe=677FC55F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "I am sequrity 2560 x 1440.png", "id": "1398406160866186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974689_1398406164199519_4655403560096238791_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BywX5F2Zg6MQ7kNvgEIRdIT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAp5GW4F1_84gchwe2-ADNvuOX9teMt71TJMcvlbHHiUg&oe=677FD0A3"}, "display_name": "I Am Security", "keywords": [], "long_description": "EARLY ACCESS\n\nStep into the shoes of a club security guard in \"I Am Security,\" where your job is to keep the club safe and ensure only the right guests get inside. As a security guard, you\u2019ll face a variety of challenges that will test your observation and decision-making skills.\n\nYour main task is to identify who can enter the club and who can't. Guests will line up, and you must decide if they are allowed in based on certain criteria. Some guests might try to sneak in with prohibited items, and it's up to you to find these hidden objects. Use a range of tools, like metal detectors and scanners, to inspect the guests and uncover anything suspicious.\n\nTo make things more interesting, the game offers a shop where you can buy new items and tools. These upgrades will help you improve your security skills and make your job easier. With every level, the difficulty increases, and you\u2019ll encounter more complex scenarios and tougher decisions.\n\n\"I Am Security\" is all about quick thinking and sharp attention to detail. Will you be able to spot the troublemakers and keep the club safe? Play now and find out!", "short_description": "Security\u2019s call, catch them all."}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26261730430078905"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "546521821448237"}, {"status": "PUBLISHED", "id": "527555226431429"}, {"status": "PUBLISHED", "id": "443759852041147"}, {"status": "CANCELLED", "id": "976300467630456"}, {"status": "CANCELLED", "id": "348785128201479"}, {"status": "PUBLISHED", "id": "1838789666597172"}]}, "baseline_offer": {"id": "1838789666597172"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "546521821448237"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28474709732114286", "version": "1.0.4"}, "id": "1596348061148626", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "A