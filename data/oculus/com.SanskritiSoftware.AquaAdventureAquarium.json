wdZOOq11hW0ed_sOc-2jSLUrEORZaU8ug&oe=66EFF7EE"}, {"file_name": "LandingHallUploaded.png", "id": "8328920843836777", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982510_8328920850503443_5824309639553317778_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQDYS2MIFQQQ7kNvgF2HnC8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIgfFWLyYPba9JOFh0tsIYa&oh=00_AYABYxs0gcaA5PLHSOtblcI7Z51Y0DkaEQTfIjvtTnjHhA&oe=66F0166F"}, {"file_name": "LandingHall3.png", "id": "829269906017334", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974795_829269909350667_6989487726579619340_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H14pmseFSxYQ7kNvgGxCNyL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIgfFWLyYPba9JOFh0tsIYa&oh=00_AYDk7bzHB9XvzqJUtNzV4AvQyetG8Gz9WhiK0OLCYrr1EQ&oe=66F000BD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shipwreck1.png", "id": "461632456869271", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035469_461632460202604_6305906705940527865_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wOCmXdxUgKwQ7kNvgE3maAD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIgfFWLyYPba9JOFh0tsIYa&oh=00_AYCoxXcnMxil9jaJMTqzy1IotxhNgnYvxXMlC2lH2zNX5g&oe=66F01978"}, "display_name": "Aqua Adventure Aquarium", "keywords": ["Aquarium", "Nimo", "Fish", "Sea", "Adventure"], "long_description": "\n**Dive into the Enchanting World of Fish and Sea Creatures at Aqua Adventure Aquarium!** \n\nAre you an Adventure Seeker, Sea Enthusiast, or Casual Observer? Aqua Adventure Aquarium has something for everyone!\n\n**Discover and Explore:**\n-\t**Over 50 Sea Creatures:** Walk around and marvel at 3D models of dolphins, sharks, octopuses, clownfish, whales, and more. Learn fascinating facts about these incredible animals.\n-\t**Shipwreck Reef:** Visit this mysterious area where you might encounter gentle manta rays or come face-to-face with deadly sharks.\n-\t**Abyss Adventure Explorer:** Hold your breath and dive underwater in our Scuba Cart to explore uncharted territories.\n\n**What Aqua Adventure Aquarium Offers:**\n1.\t**3D Aquarium:** Five tanks filled with a variety of fish and sea creatures.\n2.\t**Shipwreck Reef:** Explore a shark-infested shipwreck.\n3.\t**Abyss Adventure Explorer:** Step aboard the Scuba Cart for an up-close encounter with reef and deep-sea creatures. Buckle up for a wild ride!\n", "short_description": "Dive into the Enchanting World of Sea Creatures at Aqua Adventure Aquarium!\n\nDiscover and Explore:\n\u2022\tOver 50 Sea Creatures: Walk around and marvel at 3D models of dolphins, sharks, octopuses, clownfish, whales, and more. \n\u2022\tShipwreck Reef: Visit this mysterious area where you might encounter gentle manta rays or come face-to-face with deadly sharks.\n\u2022\tAbyss Adventure Explorer: Hold your breath and dive underwater in our Scuba Cart to explore uncharted territories.\t"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sanskritisoftwareneha.azurewebsites.net/AquaAdventureAquariumPrivacy.html", "developer_terms_of_service_url": "https://sanskritisoftwareneha.azurewebsites.net/SanskritiSoftwareTOC.html", "publisher_name": "Sanskriti LLC", "support_website_url": "https://sanskritisoftwareneha.azurewebsites.net/About.html", "website_url": "https://sanskritisoftwareneha.azurewebsites.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes