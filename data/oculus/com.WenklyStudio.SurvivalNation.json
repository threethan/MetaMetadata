ontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WIeH4UDe8gkQ7kNvgGp2xMz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCtAqG0mnMe8cbgSXfUZht4trIZuZxDKIq5ssZNRMLvLA&oe=67487346"}, {"file_name": "MobileCamp_final.png", "id": "1873686756337067", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984463_1873686759670400_2816863334061966728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TI-IxX_qopoQ7kNvgHwhM8Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD63zVFK9pOnYvNSw_PXzT937ZtcjyxJGiWpiR0XUcBQQ&oe=67486876"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape.png", "id": "332660192743258", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035464_332660196076591_2398118520934284041_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T9FMFmZb_JYQ7kNvgFkTf9L&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyVtb_2cxlww1f2NwErC8Xi6dDlTvdYtm6mfmncIjiTg&oe=674841D0"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8921843074561947"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031499_1280592076306879_111078263859703