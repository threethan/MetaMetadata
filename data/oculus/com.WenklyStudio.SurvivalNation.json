ad3-2.oculuscdn.com/v/t64.5771-25/38974880_1240236593554945_1028188453651503161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vgo4cY3_gE4Q7kNvgHy8tpt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxFWnlXWI0ycfFNDxVss_X88KuJe3GW1R2quKO8d0ktw&oe=671CE32F"}, {"file_name": "MobileFishing_final.png", "id": "137244869308481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031563_137244872641814_5958679507785929342_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J7ML-r9mCh4Q7kNvgEiXmEw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCI0hKKYbnEJTmx2hiXAFWGifWgrxbfXzib-teU8_iYow&oe=671CD9FE"}, {"file_name": "MobileHunting_final.png", "id": "243809111376705", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=poOi4wDNToYQ7kNvgHRXtSp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1FSeRB5D7CaQtHY_TihVGIFaPdYsz0GBqyq3cVKlFIg&oe=671CB986"}, {"file_name": "MobileCamp_final.png", "id": "1873686756337067", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984463_1873686759670400_2816863334061966728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ig3Fg0amvoQ7kNvgFOYikP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZB6lmc25uFeHb5gunuVCj0sChMTGoUNq5CESUaa_UFQ&oe=671CE6F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape (1).png", "id": "645201927360796", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75251816_645201930694129_7399673817513852893_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PoHGAoHQPkEQ7kNvgGGOS-1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGG4XNfqxsD8VegwVGft6fogDNXyarQ2S5h43CMmRNWg&oe=671CEBF7"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {