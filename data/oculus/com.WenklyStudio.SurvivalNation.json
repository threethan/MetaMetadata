luscdn.com&oh=00_AYCim4GTzVH3bqtWvXB38STZbMF0hpAbNA2Is8lS41nrOQ&oe=675ED004"}, {"file_name": "Mobile Zombies_final.png", "id": "1240236590221612", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974880_1240236593554945_1028188453651503161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sqLVsWeY7qUQ7kNvgGr63U_&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBJzykzfkINd9ExuQzVoNuHOnvkGr645K7bYKm8EZfKCg&oe=675ECE2F"}, {"file_name": "MobileFishing_final.png", "id": "137244869308481", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031563_137244872641814_5958679507785929342_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1sfsc7_rQH0Q7kNvgFijOz5&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBHoNSz_9Wv8hLz91VjcvRbjR8h6utRWAyrWS8xvaPV1g&oe=675EC4FE"}, {"file_name": "MobileHunting_final.png", "id": "243809111376705", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TusvC2ZsUwYQ7kNvgFzvCOO&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBjRKzCz3om88oDHYhda5bHN8MXq3qqwkF-96OucWp8tA&oe=675EDCC6"}, {"file_name": "MobileCamp_final.png", "id": "1873686756337067", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38984463_1873686759670400_2816863334061966728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fHdnufL-eH0Q7kNvgGxjm8F&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAz11kWAiVah_z8dGJYq8EKeyLWruiG6uUeixixjgQ2oQ&oe=675ED1F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape (1).png", "id": "645201927360796", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75251816_645201930694129_7399673817513852893_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ddxXzhtjCBQQ7kNvgFO9nuz&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCirKnvoULEk1mRR4xjxaVwuSp3_psPEc26NaK0LzVaYQ&oe=675ED6F7"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_ratin