1-7&_nc_sid=6e7a0a&_nc_ohc=mIhnCdMPpdAQ7kNvgFfyiE4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYDxDj3Sc81vzoDtXBDBfWrYkizSSn35a1UDwIg2cljnPA&oe=66E6D784"}, {"file_name": "Mobile Zombies_final.png", "id": "1240236590221612", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974880_1240236593554945_1028188453651503161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HLyTuHPD52QQ7kNvgHNX2CG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYCn6lOD-DzGr2vmNRNCBkxeYRH60n0dPQu3wYwQR3F2fQ&oe=66E6D5AF"}, {"file_name": "MobileFishing_final.png", "id": "137244869308481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031563_137244872641814_5958679507785929342_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HNKCkvos8BcQ7kNvgHDYHkf&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYBbUFVz_frQ5M1wL18ZAR8tJzcN2evAIpth_NYlUyxpdQ&oe=66E6CC7E"}, {"file_name": "MobileHunting_final.png", "id": "243809111376705", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SHNrs_CHWT4Q7kNvgEMWzZq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYBFKcQpEiStcUiHtKSW6XWz1kiDt_YoHGCaK_2uFUZUhw&oe=66E6AC06"}, {"file_name": "MobileCamp_final.png", "id": "1873686756337067", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984463_1873686759670400_2816863334061966728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=otq0cQinPR0Q7kNvgFUdWGo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYCHuMFOFW6hXfVz1WTaK0lKSXwbcLDcVuktfKHxYTuXqQ&oe=66E6D976"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape (1).png", "id": "645201927360796", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251816_645201930694129_7399673817513852893_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oyC5SB_ffsAQ7kNvgF3UeP2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Fg3s1AZRxnYfQqGmbAubV&oh=00_AYBcr8TQQQCnKN8qXrUnt1edCgROy1O_HKq7yYBde05YrQ&oe=66E6DE77"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "965591897935164"}}]}, "scheduled_offers": {"count": 27, "nodes": [{"status": "PUBLISHED", "id": "1566496093940139"}, {"status": "PUBLISHED", "id": "1407774469941249"}, {"status": "PENDING", "id": "879378993733863"}, {"status": "PENDING", "id": "191276917358032"}, {"status": "PENDING", "id": "268673489367265"}, {"status": "PENDING", "id": "648140487191669"}, {"status": "PUBLISHED", "id": "591991519814013"}, {"status": "PENDING", "id": "639234864854902"}, {"status": "PENDING", "id": "168300336236351"}, {"status": "PENDING", "id": "10033006913438674"}, {"status": "PUBLISHED", "id": "986059092601761"}, {"status": "PUBLISHED", "id": "1651818665640627"}, {"status": "PENDING", "id": "207044158986277"}, {"status": "PUBLISHED", "id": "835694467930516"}, {"status": "PENDING", "id": "943624624037098"}, {"status": "PUBLISHED", "id": "116927234804700"}, {"status": "PUBLISHED", "id": "686263249572078"}, {"status": "PUBLISHED", "id": "690485172987395"}, {"status": "PUBLISHED", "id": "594567422789393"}, {"status": "PUBLISHED", "id": "1562773761184277"}, {"status": "PUBLISHED", "id": "1463048361149368"}, {"stat