cb=1-7&_nc_sid=6e7a0a&_nc_ohc=9gtPOlLIBi4Q7kNvgFSWkUq&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYD54TsQSj1O09ACVdkmA-pbGZf7Ppue4d2vcUMKiq2a8g&oe=677E722F"}, {"file_name": "MobileFishing_final.png", "id": "137244869308481", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031563_137244872641814_5958679507785929342_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u5oYhtNbYUYQ7kNvgGJitYG&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYALk4f5cLGHka2UuI0MoSsQFG9S7m1OEKEZ9RBA6ngtBw&oe=677E68FE"}, {"file_name": "MobileHunting_final.png", "id": "243809111376705", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H9V_I0UkstwQ7kNvgFcw3Qm&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYC1Q2Be3K0PAAV66X2kdSUkCKX4pJYDemg8ksA-b4Od-g&oe=677E4886"}, {"file_name": "MobileCamp_final.png", "id": "1873686756337067", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38984463_1873686759670400_2816863334061966728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XIx4cV0hJ1AQ7kNvgEjkuLO&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYDcY-217ieeLtJcbV8AQxE7mCTCNqL7aGLs3DgR-OS5Sg&oe=677E75F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape (1).png", "id": "645201927360796", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75251816_645201930694129_7399673817513852893_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c165GfA_eBsQ7kNvgFUCbtH&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYDo4IterzuKSj8ipVcUk7AbSFWuwSyOHIkQ0LcN5JHWSA&oe=677E7AF7"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app