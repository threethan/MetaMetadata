ect-Right.png", "id": "675059941141887", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_RIGHT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031629_675059944475220_6668426671850906684_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=teYhRTtayHgQ7kNvgFaMBV6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnxly4Ifmd7tW0h7o9reT3RGGeA2xyk8WfNDWqSMO-tw&oe=676A92C2"}, {"file_name": "Cover-Portrait.png", "id": "551560557846461", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974871_551560561179794_5023426554653396671_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z9JX99_Cpv8Q7kNvgHv0T9S&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCy4SAjHkBvTtuVqrmeocHQB_aSK0SgVMDgPMYTv8Q8AA&oe=676A92C0"}]}, "id": "2013694699114812", "locale": "en_US", "screenshots": [{"file_name": "MobileOil_final.png", "id": "1410592796366968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974848_1410592799700301_7053926378875907756_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5y8eVz9pxAQ7kNvgHoQ5Qq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqc7oPSMwPbRbctMov1R_kB0IOuu-qFYLQbCEnV_H8YQ&oe=676AAD84"}, {"file_name": "Winter.png", "id": "886430037024611", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_886430040357944_5812980164179449555_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=st05e4Q5CnsQ7kNvgGQFA1a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9FY9AKdai254uFxLwNDX8iGIbEtG1GU_hQKSUTOMIzw&oe=676A9A71"}, {"file_name": "Mobile Zombies_final.png", "id": "1240236590221612", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974880_1240236593554945_1028188453651503161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9RoW7Bk6PLwQ7kNvgGa9r-g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7sTd9VISUDYz2xADdk5T19PPkbrvz26LEyzr7DIuc1A&oe=676AABAF"}, {"file_name": "MobileFishing_final.png", "id": "137244869308481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031563_137244872641814_5958679507785929342_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIDmoBofvfcQ7kNvgFcmadK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3C5e-GbxwCZI7DNkwxLLJJKRAodC-3EDzmvPvOlvcHg&oe=676AA27E"}, {"file_name": "MobileHunting_final.png", "id": "243809111376705", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_243809114710038_80950293541711324_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w5XJQAZq-hQQ7kNvgHRTc20&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_kt0slwSflGSPC8LLQbmb9LrE4_KFmqjbqrfbFXipmQ&oe=676A8206"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape.png", "id": "3918375845047944", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_3918375848381277_7942702091234532607_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fd0yE7dOqUEQ7kNvgEx75R3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQVF1DF0mdh2rXYKD_UB80Km80_Nh6UkJRvhGHukb22Q&oe=676A87CD"}, "display_name": "Survival Nation", "keywords": ["RPG", "Multiplayer", "Openworld", "Zombie", "Online"], "long_description": "Survival Nation is an open-world online RPG zombie survival game designed for VR. \n\nSURVIVAL \nTo survive, you need to remember about food and water. \nYou can get food in many ways: by fishing, hunting, gathering, or scouring abandoned houses. \n\nONLINE \nThey say that cooperation is the key. It is no different here. Survival Nation is a game that focuses on multiplayer mode. \nYou can join other players and participate in a joint adventure and exploration of the world. \n\n\nPROGRESSION \nSurvival Nation is not lacking in RPG elements either.\nA whole bunch of missions and side activities are waiting for you. \nYou have at your disposal 3 unique skill trees, which you develop with each level you gain. \n\nACTIVITIES \nIn addition to quests and many forms of food gathering mentioned earlier, there are many other activities. \nYou can search for items with a metal detector, climb on top of various spots, search for treasure using riddles, and much more. \n\nWEAPONS \nSurvival Nation offers a mass of diverse weaponry, starting from pistols and rifles up to bows.\nEach weapon has not only different statistics but also a feeling and a way of reloading. \n\nJoin our Discord server to be updated.\nhttps://discord.gg/survivalnationvr", "short_description": "Survival Nation is an open-world online RPG survival game designed for VR. In this game, you will kill hundreds of zombies, acquire weapons, learn new skills, craft, explore the world, complete quests, and most importantly, fight for survival. Will you join a Survival Nation?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacy-policy-survivalnation", "developer_terms_of_service_url": "https://www.wenklystudio.com/end-user-licence-agreement-survivalnation", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/survivalnation-vr", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "9111099098969676"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569428_2099098943839536_3446671792601723695_n.pn