40_2784707129593999733_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j-9IklX61lcQ7kNvgEud1H9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzNES-Rht8t9aEDBOy4KWfS&oh=00_AYDRKNGVIf3PehEbFEBlzSv67IIUBILXlDKfGmIntSihKg&oe=66DAE8A9"}, {"file_name": "Screenshot-3.png", "id": "1030441884929123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031584_1030441888262456_1953681753583237542_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sANHNg9sL0gQ7kNvgFCCIpG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzNES-Rht8t9aEDBOy4KWfS&oh=00_AYD44jRozFFnWVG5i9rGdu6A451ImY1lLfv6mU5wSdTRuw&oe=66DAD89A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Kanvas", "keywords": ["acrylic", "painting", "art", "drawing", "canvas"], "long_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation\n\nOpen Kanvas provide a realistic simulation of canvas painting in VR, convincingly mimic the way natural media interact with the canvas.\n\nFree version\n- Realistic Oil Simulation\n- Wet-on-wet color blending\n- Impasto effect\n- Built-in Web Browser\n- Capture any pictures and paint\n- 2 basic environment\n- 3 step-by-step tutorial \n- 6 set of paint-by-number\n\n\n---\nPaid DLC ($9.99)\n- coming in Q4/2024\n", "short_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation"}]}, "developer_name": "Happi Art Team", "developer_privacy_policy_url": "https://happi-art.world/privacy", "developer_terms_of_service_url": null, "publisher_name": "Happi Art World", "support_website_url": "https://happi-art.world/support", "website_url": "https://happi-art.world/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": nul