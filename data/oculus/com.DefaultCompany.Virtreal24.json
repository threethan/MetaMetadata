IwX49eNfqKEZa4T9ITkq0a96nWwZwQAyg&oe=67542741"}, {"file_name": "Portrait 1008x1440.png", "id": "373844392388889", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982569_373844395722222_7765026023671086599_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nvTn5MXyZggQ7kNvgGNB_Wa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1EpwBN_WntIz-Y9HH2IyroHGLtQs-gF-DzrZp9RP9gQ&oe=675441F6"}, {"file_name": "deafult-icon.png", "id": "363395803319137", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367592_363395806652470_5169837541306883000_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbYEJWoX3vgQ7kNvgGonDNR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCLilrDJcw026zmY1cSzTobHp47FoyOvLtYMeJlFCllg&oe=67543A01"}]}, "id": "2784376951861557", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 1.png", "id": "780484820954049", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982467_780484824287382_4980005795979528827_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GXWH4XQIsSkQ7kNvgHyBvPj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvA9Ld5w-9fSU1FwvqSThTD5rhLlrb-RhlJLOtj0nLUg&oe=67544456"}, {"file_name": "Screenshot 4.png", "id": "3832719043679306", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86615895_3832719047012639_7982110461625470755_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQgiX7EjoZkQ7kNvgEZWW1c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApgL7teasaKWGs1sx2sXfwuxzkL4skcg_RQHY-q54Juw&oe=675447EF"}, {"file_name": "Screenshot 5.png", "id": "1639894903518336", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974564_1639894906851669_7629757027424532140_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DyMnlFeCRnUQ7kNvgHzsaFN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4chC-RL667RZkMRvvikAg_ueOpZ_HsD43Cy29c0jIQA&oe=67544682"}, {"file_name": "Screenshot 3.png", "id": "1144722010139416", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75593947_1144722013472749_9119886187550761609_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FZb0kfbrYB4Q7kNvgEUcyGo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPMpjZketMYvZqipVQeuDuHuSTjuea25iNBFSqx_dwiw&oe=67542C18"}, {"file_name": "Screenshot 2.png", "id": "374138361923478", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240108_374138365256811_8991096440508324209_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8xOoRZtF1M0Q7kNvgE43i5V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAaD2n3C59d0qKeoicmKxDeiSXYj26wmBSaA6y0D-IV3Q&oe=67541DCA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape 2560x1440.png", "id": "2150976811948546", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035412_2150976815281879_5344597131243168108_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OrBvIVrW3TQQ7kNvgHKK3Kb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbwvcIzDlQ3usOdp8WTnmSVw1-KzocfRu25iEnfhWkzQ&oe=675438A9"}, "display_name": "PatientVR", "keywords": [], "long_description": "For patients confined to healthcare facilities, maintaining a sense of connection to the outside world is crucial for their well-being.\n\nINTERACT \u2013 GAMIFIED INTERACTIONS FOR PATIENTS\nGamified interventions designed to help with distraction and mild interactive and physical activities designed to be simple and can be used controller free, so patients are able to use them with ease sitting down, standing or in confined areas. \n\nWe keep adding to our Interact library so that patients can continually use features such as painting, word search or work on their hoops, darts or slingshot skills We also have mild physical activities such as music boxing and interacting with objects in VR space helping with their dexterity and motor skills. These activities are calming, relaxing and joyful. \n\nSCENES \u2013 IMMERSIVE 360\u00ba LIBRARY\nFrom the Great Barrier Reef to Bondi Beach, to walking in Seville to playing or witnessing the mesmerising Dubai skyline at night, our library offers a wide range of 360\u00ba experiences. Includes access to our expanding 360\u00ba photo and video library, which enables patients to explore diverse locations.\n\nACCESSIBLITY\nActivities can be used controller-free, with either one or both hands and some of them just require head-tracking. A design ensuring that even patients with limited mobility can benefit and engage with PatientVR maximising its usability.\n\nThe primary goal is to bring joy and comfort to patients, contributing to their overall recovery, emotional and overall well-being.\n", "short_description": "PatientVR uses a novel approach to patient experience using Virtual Reality and is built in consultation with health experts. Patients often experience stress, anxiety, and feelings of isolation, which can adversely affect their recovery and quality of life. Our gamified intervention features with the Interact module and 360\u00ba scenes content are designed to help with distraction and general patient wellbeing. \n\nThe activities are designed to be simple, interactive and can be used controller free."}]}, "developer_name": null, "developer_privacy_policy_url": "https://patientvr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.mobiddiction.com.au/terms-conditions/", "publisher_name": "Mobiddiction", "support_website_url": "https://support.mobiddiction.com/", "website_url": "https://patientvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "726368587961803"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7763617290399556"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974537_744920627839395_2541680095614990654_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=klCX3VSwIxEQ7kNvgH9qMXq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC44frmC_o6DLWIK6DeVPFh0BjzlXDPi-3qvtdXPV_6pQ&oe=67544B7E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PatientVR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Travel & Exploration", "id": "726368587961803"}], "release_date": 1720274400, "lastRevision": {"nodes": [{"id": "6028447183916584", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6028447177249918", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "769406742020957"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Landscape 2560x1440.png", "id": "2291808731013360", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/428815834_2291808734346693_6715585051383721155_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kvRIvU07lFcQ7kNvgEIrr7I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkR487k_oxRe9-u2TuJrkTiwwG4dr_QJgB8EwbvDkf-g&oe=67542A74"}, {"file_name": "PDP Art.png", "id": "835457174671821", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/426978279_835457178005154_19