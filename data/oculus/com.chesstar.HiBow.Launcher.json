0\uff084\uff09.png", "id": "152689023329143", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75221313_152689026662476_4017254453095429042_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fY6n3ZEzwRYQ7kNvgFhVba4&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYC-R4dCtXZvB1lypyqa1Hf8D9R18-SGtRicyR12aGx9Hw&oe=6728C90C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u4e3b\u6d77\u62a52560-1440.png", "id": "532546341002288", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982622_532546344335621_2409358825928692675_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tvX7MU9spxcQ7kNvgFReBFt&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDArG9TiJEg3aYNDeSUxgocXWPvKa3sGh4fwU2_JiZ8-w&oe=6728BECD"}, "display_name": "Hibow", "keywords": [], "long_description": "Hibow is a competitive multiplayer VR game with fierce arrow shooting and refreshing flying experience.    \n\nIt provides a smooth archery and flying experience guaranteed by hundreds of updates.\nWith unique muscle memory flying system, you will love it once you\u2019ve tried it.\nCreative features for bows and arrows allowing sniping, scattering, explosion and even blinding! Yes, It\u2019s more than imagination!\nAlong with powerful secondary weapon system, you\u2019ll easily accomplish various unbelievable movements.\nWell-designed Battle Royale mode for VR archery, exicting fighting experience will definitely make everyone keep playing it over and over again.\nPlus full body IK system, dressing up store and various social interactions and social game modes. Hibow will not only give you joy and unforgettable experience, but also friendships.\n\nCome and find more!", "short_description": "A multiplayer Battle Royale archery fighting game with unique flying experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://chesstar.com/?privacy_10%2F", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website