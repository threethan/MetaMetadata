}, {"file_name": "2560_2.png", "id": "192461396961580", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974716_192461400294913_7175964949626297309_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6dNN-yMribIQ7kNvgEJF9RG&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYALLi4Wfb8JwglyWr4iSssNusnmoCMQubhVXbpqKU8kjQ&oe=6728A780"}, {"file_name": "s3.png", "id": "542335511252762", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75356794_542335514586095_216425384345306578_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0mB4XbSo89cQ7kNvgGQ0wfl&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDwuwDOUXaRXS-Tv5iMfV_HlvjyFBp5R5bMXZa81gLS6A&oe=6728BBC7"}, {"file_name": "2560_3.png", "id": "888998762168062", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/227874642_888998765501395_1211087875730036094_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r0QPbjq0TRgQ7kNvgGkdBsc&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYD6GkkYe56DqEQiNCStm3LSQRuZQwzGl5zDHBa_sXN3HA&oe=6728B836"}, {"file_name": "10.png", "id": "580513944186748", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/75485576_580513947520081_2839488034221343197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QXikisSvLL8Q7kNvgEZrkr6&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYD9QILEUBDQuE2Lf17eilunYwlVbWHqTnEY8H8v9g2dhg&oe=6728C1C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u65b0\u7248\u672c\u6d77\u62a5.png", "id": "793511699535511", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39035463_793511702868844_626627210755769106_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jWRkdq-eg1QQ7kNvgE9fsPc&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBOoO8b1IKkuYa_gee5g_ZiRz20nRIxD4HUdzMoshYlrQ&oe=6728B5C1"}, "display_name": "Hibow", "keywords": ["Archery", "Multiplayer", "Battle", "Shooter", "Bow"], "long_description": "# Choose your hero and team up to dominate the future bow fight battlefield!\n\n**1. Immersive archery battles**\nDelve into the meticulously crafted VR archery simulation experience, refined over three years, ensuring you won't be disappointed!\n{834373434687434}\n\n**2. Unique movement system**\n We've developed a movement system based on archery, allowing quick mastery through muscle memory, making it irresistible once you've grasped it!\n{329733713341715}\n\n**3. Hero showdowns, tactical competition**\nEvery battle showcases your strategic prowess. Select your hero, gather weapons and equipment, utilize skills \u2013 every perfect decision significantly increases your chance of victory!\n{824427463068762}\n\n**4. Multiplayer lobby, social upgrade**\n A simple handshake can turn you into friends with other players. Invite them to battle alongside you!\n{428367670175190}\n\n**5. Rich weaponry, equipment upgrades**\n With 7 bows, 6 arrow types, 4 attachments, and 3 melee weapons, upgrading them during battle significantly boosts your combat prowess.\n{811018667625483}\n\n**6. Diverse systems, continuous updates**\nWith new gameplay modes, heroes, maps, weapons, and seasonal features, we continuously update to keep the experience fresh.\n\n# Need Help? \nContact us through Discord, mail, or simply leave a comment. Whether for support or feedback, we are always happy to answer.\n\n# Follow Us:\n- Discord: https://discord.gg/hibow\n- Twitter:  https://twitter.com/HibowVR\n\n", "short_description": "Choose your hero and team up to dominate the future bow fight battlefield!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesstar.com/privacyen/", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://chesstar.com/hibowen.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ko", "de", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7900145836733681"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39001711_984884679775481_1329984787981480460_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LcAdb7lo0i8Q7kNvgGnDxt9&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDod-Yo8IEiiAVQ3zNt_S49-edpgYjWut_HndSfYHeqRw&oe=6728AE18"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hibow", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1620752344, "lastRevision": {"nodes": [{"id": "1694046504115797", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3687705861311054", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "424094729038331"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "LOGO9000-1440.png", "id": "124565666206677", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982721_124565669540010_8260971542218000232_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJxHig1_nXwQ7kNvgHr5OWj&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYB-XioQvoKtzTSiLtPQF2mZjerTP8LZPk34qQfSFPZuRw&oe