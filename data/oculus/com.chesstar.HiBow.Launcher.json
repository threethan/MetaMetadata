578_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N-0fCibLEcUQ7kNvgErtZQ_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCo-W8UZlwQ7GYyrtqGzr_8m2ISyMObImXcq0_4TDRP-g&oe=66CC72C7"}, {"file_name": "2560_3.png", "id": "888998762168062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227874642_888998765501395_1211087875730036094_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TLmWELutWrkQ7kNvgFD_lHN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCk70VWy04yy4JhRVq6-bTOCiSHzsdcGbGPWurTF-VdXw&oe=66CC6F36"}, {"file_name": "10.png", "id": "580513944186748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485576_580513947520081_2839488034221343197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5hpjRgGUg6AQ7kNvgFuKWjA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPk1gfXf3Xz4mdkxVi1UjpuxtiARUSWt7H1av8mf2-ZA&oe=66CC78C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u65b0\u7248\u672c\u6d77\u62a5.png", "id": "793511699535511", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035463_793511702868844_626627210755769106_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Y1cSunfrLIQ7kNvgEf8hpu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsjOyeE9kD_6gXpqtgT0X45eosLfo1xQxGddNk_jBlgA&oe=66CC6CC1"}, "display_name": "Hibow", "keywords": [], "long_description": "# Choose your hero and team up to dominate the future bow fight battlefield!\n\n**1. Immersive archery battles**\n{834373434687434}\nDelve into the meticulously crafted VR archery simulation experience, refined over three years, ensuring you won't be disappointed!\n\n**2. Unique movement system**\n{329733713341715}\n We've developed a movement system based on archery, allowing quick mastery through muscle memory, making it irresistible once you've grasped it!\n\n**3. Hero showdowns, tactical competition**\n{824427463068762}\nEvery battle showcases your strategic prowess. Select your hero, gather weapons and equipment, utilize skills \u2013 every perfect decision significantly increases your chance of victory!\n\n**4. Multiplayer lobby, social upgrade**\n{428367670175190}\n A simple handshake can turn you into friends with other players. Invite them to battle alongside you!\n\n**5. Rich weaponry, equipment upgrades**\n{811018667625483}\n With 7 bows, 6 arrow types, 4 attachments, and 3 melee weapons, upgrading them during battle significantly boosts your combat prowess.\n\n**6. Diverse systems, continuous updates**\nWith new gameplay modes, heroes, maps, weapons, and seasonal features, we continuously update to keep the experience fresh.\n\n# Need Help? \nContact us through Discord, mail, or simply leave a comment. Whether for support or feedback, we are always happy to answer.\n\n# Follow Us:\n- Discord: https://discord.gg/hibow\n- Twitter:  https://twitter.com/HibowVR\n\n", "short_description": "Choose your hero and team up to dominate the future bow fight battlefield!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesstar.com/privacyen/", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://chesstar.com/hibowen.html", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ko", "de", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7622645894483678"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent