a0a&_nc_ohc=IcTe2291hbQQ7kNvgFSeckG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEV4lHs3JMY_balyaUoqExtemXIX_SqcPXFsv4gcy7Cw&oe=67066080"}, {"file_name": "s3.png", "id": "542335511252762", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75356794_542335514586095_216425384345306578_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elIJ-Zms_GEQ7kNvgF33DMi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_U9nNtsnRwX3knTcFJkc596fEdgHDTVp8UzFCMwfcZQ&oe=670674C7"}, {"file_name": "2560_3.png", "id": "888998762168062", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/227874642_888998765501395_1211087875730036094_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BazjkRbbUxwQ7kNvgHwRndg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBC918jD1UN_6tmXJa2B0YwOlFopswfw85htk8qgcHeLg&oe=67067136"}, {"file_name": "10.png", "id": "580513944186748", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75485576_580513947520081_2839488034221343197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gNEEroUX4zYQ7kNvgG1hl6u&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAas0nGnDlcdi5aQX7z2xd-bgpNwFxbqi88Odg9oEcEGg&oe=67067AC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u65b0\u7248\u672c\u6d77\u62a5.png", "id": "793511699535511", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035463_793511702868844_626627210755769106_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1qtI0zk8n-MQ7kNvgGsWAqG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCM7Stc5oMC3bujrQFaUXqHAJnTUkRa-PldapugW3fkhQ&oe=67066EC1"}, "display_name": "Hibow", "keywords": ["Archery", "Multiplayer", "Battle", "Shooter", "Bow"], "long_description": "# Choose your hero and team up to dominate the future bow fight battlefield!\n\n**1. Immersive archery battles**\nDelve into the meticulously crafted VR archery simulation experience, refined over three years, ensuring you won't be disappointed!\n{834373434687434}\n\n**2. Unique movement system**\n We've developed a movement system based on archery, allowing quick mastery through muscle memory, making it irresistible once you've grasped it!\n{329733713341715}\n\n**3. Hero showdowns, tactical competition**\nEvery battle showcases your strategic prowess. Select your hero, gather weapons and equipment, utilize skills \u2013 every perfect decision significantly increases your chance of victory!\n{824427463068762}\n\n**4. Multiplayer lobby, social upgrade**\n A simple handshake can turn you into friends with other players. Invite them to battle alongside you!\n{428367670175190}\n\n**5. Rich weaponry, equipment upgrades**\n With 7 bows, 6 arrow types, 4 attachments, and 3 melee weapons, upgrading them during battle significantly boosts your combat prowess.\n{811018667625483}\n\n**6. Diverse systems, continuous updates**\nWith new gameplay modes, heroes, maps, weapons, and seasonal features, we continuously update to keep the experience fresh.\n\n# Need Help? \nContact us through Discord, mail, or simply leave a comment. Whether for support or feedback, we are always happy to answer.\n\n# Follow Us:\n- Discord: https://discord.gg/hibow\n- Twitter:  https://twitter.com/HibowVR\n\n", "short_description": "Choose your hero and team up to dominate the future bow fight battlefield!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesstar.com/privacyen/", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://chesstar.com/hibowen.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null