6e7a0a&_nc_ohc=uEDa8SOCimwQ7kNvgGvTgAO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYCTRtlZgehpmbAt2WP6yGgpI7fSSOr9CBDgjLAIgfGung&oe=66EFEDFC"}, {"file_name": "2560_2.png", "id": "192461396961580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_192461400294913_7175964949626297309_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UH-i9KydrDMQ7kNvgEXjHAV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYCeheTJ-YvdhChhnCqeHA-1KGUs_Q6M1bauI906GnrWXg&oe=66EFF700"}, {"file_name": "s3.png", "id": "542335511252762", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75356794_542335514586095_216425384345306578_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=83mPCYApApsQ7kNvgGVywr5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYBlcmKVAdygwcuPz9a4urHT8CXwIctHpUi4DKfrGA4V_A&oe=66F00B47"}, {"file_name": "2560_3.png", "id": "888998762168062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227874642_888998765501395_1211087875730036094_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WUtwZZhPxOEQ7kNvgEJDaTe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYB6GEBqTb-3dx7dHkUlUeeVbZKUDYytHl7sgEWSN5ld3Q&oe=66F007B6"}, {"file_name": "10.png", "id": "580513944186748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485576_580513947520081_2839488034221343197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GTDFSfb9FnAQ7kNvgFob4im&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYAsI9MIv44uGY43WmBHpMYd4MSSRA_30dod7nFrfrrrhw&oe=66F01140"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u65b0\u7248\u672c\u6d77\u62a5.png", "id": "793511699535511", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035463_793511702868844_626627210755769106_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aqsVniyFaN0Q7kNvgHAQv6o&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiS7y0sPmknhuCgGsYD01yi&oh=00_AYDoj7RwD9wwbfyTPOhUN73APmxQEIBr9gQkolqDNTyp3Q&oe=66F00541"}, "display_name": "Hibow", "keywords": ["Archery", "Multiplayer", "Battle", "Shooter", "Bow"], "long_description": "# Choose your hero and team up to dominate the future bow fight battlefield!\n\n**1. Immersive archery battles**\nDelve into the meticulously crafted VR archery simulation experience, refined over three years, ensuring you won't be disappointed!\n{834373434687434}\n\n**2. Unique movement system**\n We've developed a movement system based on archery, allowing quick mastery through muscle memory, making it irresistible once you've grasped it!\n{329733713341715}\n\n**3. Hero showdowns, tactical competition**\nEvery battle showcases your strategic prowess. Select your hero, gather weapons and equipment, utilize skills \u2013 every perfect decision significantly increases your chance of victory!\n{824427463068762}\n\n**4. Multiplayer lobby, social upgrade**\n A simple handshake can turn you into friends with other players. Invite them to battle alongside you!\n{428367670175190}\n\n**5. Rich weaponry, equipment upgrades**\n With 7 bows, 6 arrow types, 4 attachments, and 3 melee weapons, upgrading them during battle significantly boosts your combat prowess.\n{811018667625483}\n\n**6. Diverse systems, continuous updates**\nWith new gameplay modes, heroes, maps, weapons, and seasonal features, we continuously update to keep the experience fresh.\n\n# Need Help? \nContact us through Discord, mail, or simply leave a comment. Whether for support or feedback, we are always happy to answer.\n\n# Follow Us:\n- Discord: https://discord.gg/hibow\n- Twitter:  https://twitter.com/HibowVR\n\n", "short_description": "Choose your hero and team up to dominate the future bow fight battlefield!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chesstar.com/privacyen/", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://chesstar.com/hibowen.html", "category": "GAMES", "comfort