t.oculuscdn.com&oh=00_AYA1zKtoFe8JuqFOCG4bBbjoxQr2i_4x9dMQ_j6ld5dJOg&oe=66D2E2DF"}, {"file_name": "\u622a\u56fe2560-1440\uff082\uff09.png", "id": "856438005208748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221327_856438008542081_1901683414352911473_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DyaL-mutiqoQ7kNvgGpUALW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDC_ilhquXZfGdZth0w1xitS6JuG-2pUQ9ba0QkY6kHVw&oe=66D31A3C"}, {"file_name": "\u622a\u56fe2560-1440\uff085\uff09.png", "id": "442177106909710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575352_442177110243043_2941659630946074307_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SJoqFIsAvVcQ7kNvgGLFnqU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJWB-78IMMNvIwV8OAHJ-hc1lSOl1mICW4auslgTRDOg&oe=66D2EC8B"}, {"file_name": "\u622a\u56fe2560-1440\uff083\uff09.png", "id": "1139606619828125", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469630_1139606623161458_2046221803729981381_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6OAlr6535QcQ7kNvgHlCeGU&_nc_ht=scontent.oculuscdn.com&oh=00_AYApEgxeCOmm5dSuui_W_TEu5jmIzkslLKcp10ouos0cFw&oe=66D2ED04"}, {"file_name": "\u622a\u56fe2560-1440\uff084\uff09.png", "id": "152689023329143", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221313_152689026662476_4017254453095429042_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EDxCKGudbmMQ7kNvgEg5dCR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXKOa8MhrtgtSFe4Lv6-8cXE-rl4EZNT-IJHxT7JQ2tQ&oe=66D3178C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u4e3b\u6d77\u62a52560-1440.png", "id": "532546341002288", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982622_532546344335621_2409358825928692675_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6P6Auc5ajrwQ7kNvgEq8lB_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAwCAnmereeZXENFMOSNFTUz0v3lD6qOu5fSfmkrD34mg&oe=66D30D4D"}, "display_name": "Hibow", "keywords": [], "long_description": "Hibow is a competitive multiplayer VR game with fierce arrow shooting and refreshing flying experience.    \n\nIt provides a smooth archery and flying experience guaranteed by hundreds of updates.\nWith unique muscle memory flying system, you will love it once you\u2019ve tried it.\nCreative features for bows and arrows allowing sniping, scattering, explosion and even blinding! Yes, It\u2019s more than imagination!\nAlong with powerful secondary weapon system, you\u2019ll easily accomplish various unbelievable movements.\nWell-designed Battle Royale mode for VR archery, exicting fighting experience will definitely make everyone keep playing it over and over again.\nPlus full body IK system, dressing up store and various social interactions and social game modes. Hibow will not only give you joy and unforgettable experience, but also friendships.\n\nCome and find more!", "short_description": "A multiplayer Battle Royale archery fighting game with unique flying experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://chesstar.com/?privacy_10%2F", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://sidequestvr.com/app/967", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ko", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "984543988823017"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "380339186548252"}]}, "baseline_offer": {"id": "380339186548252"}, "is_approved": true