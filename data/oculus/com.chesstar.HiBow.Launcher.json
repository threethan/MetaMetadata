94D"}, "display_name": "Hibow", "keywords": [], "long_description": "Hibow is a competitive multiplayer VR game with fierce arrow shooting and refreshing flying experience.    \n\nIt provides a smooth archery and flying experience guaranteed by hundreds of updates.\nWith unique muscle memory flying system, you will love it once you\u2019ve tried it.\nCreative features for bows and arrows allowing sniping, scattering, explosion and even blinding! Yes, It\u2019s more than imagination!\nAlong with powerful secondary weapon system, you\u2019ll easily accomplish various unbelievable movements.\nWell-designed Battle Royale mode for VR archery, exicting fighting experience will definitely make everyone keep playing it over and over again.\nPlus full body IK system, dressing up store and various social interactions and social game modes. Hibow will not only give you joy and unforgettable experience, but also friendships.\n\nCome and find more!", "short_description": "A multiplayer Battle Royale archery fighting game with unique flying experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://chesstar.com/?privacy_10%2F", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://sidequestvr.com/app/967", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ko", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "984543988823017"}}]}, "scheduled_offers": {"count": 1,