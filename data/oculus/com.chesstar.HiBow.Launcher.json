a&_nc_ohc=7foQH6ha_bYQ7kNvgHxkllx&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCc8lUqOOCoaYHhDbmyoyXxKXwfITx3RZnjQsnsihBw7g&oe=670FBC8C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u4e3b\u6d77\u62a52560-1440.png", "id": "532546341002288", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982622_532546344335621_2409358825928692675_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fUyf-f53Xw4Q7kNvgGRC1Jr&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCDsCE3Ltkl1VXXmsRop8SHLuBhkp5cJcoli1IwVXZymw&oe=670FB24D"}, "display_name": "Hibow", "keywords": [], "long_description": "Hibow is a competitive multiplayer VR game with fierce arrow shooting and refreshing flying experience.    \n\nIt provides a smooth archery and flying experience guaranteed by hundreds of updates.\nWith unique muscle memory flying system, you will love it once you\u2019ve tried it.\nCreative features for bows and arrows allowing sniping, scattering, explosion and even blinding! Yes, It\u2019s more than imagination!\nAlong with powerful secondary weapon system, you\u2019ll easily accomplish various unbelievable movements.\nWell-designed Battle Royale mode for VR archery, exicting fighting experience will definitely make everyone keep playing it over and over again.\nPlus full body IK system, dressing up store and various social interactions and social game modes. Hibow will not only give you joy and unforgettable experience, but also friendships.\n\nCome and find more!", "short_description": "A multiplayer Battle Royale archery fighting game with unique flying experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://chesstar.com/?privacy_10%2F", "developer_terms_of_service_url": null, "publisher_name": "Chesstar Studios", "support_website_url": null, "website_url": "https://sidequestvr.com/app/967", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, 