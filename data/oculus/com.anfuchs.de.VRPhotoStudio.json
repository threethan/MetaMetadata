785000026_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SNlXCde8_EMQ7kNvgHWSnkY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrzkUFz_U_L9YG4cm4Ew050jDbvFt5LdLnNUr4ZwH_MQ&oe=675C11B7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "370378308471566", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_370378311804899_4661526385962393533_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4gFXANtf2sQ7kNvgHqSdzA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfKkfYYMdck2a9aCcxor8m2tC91-peJEzLYb-Sw7lvaQ&oe=675C0615"}, "display_name": "VR-PhotoStudio", "keywords": [], "long_description": "The VR-PhotoStudio is a Virtual Reality teaching-learning application for photography education. Educational content is conveyed playfully through exploratory learning and made tangible through a combination of knowledge building and deepening. In particular, the medium is used to experience perspective, space, and the design elements of photography.\n\nAwarded with the AVRiL 2022 \u2013Silver\u2013 at the competition \"AVRiL 2022 - Successful VR/AR Learning Scenarios\" of the working group \"VR/AR-Learning\" of the GI specialist groups \u201cEducational Technologies\u201d and \"VR/AR\".\n\nAwarded with the 1st place at the XR SCIENCE AWARD 2022 in the category IMMERSION & INTERFACE by the \"German Institute for Virtual Realities\" (DIVR).", "short_description": "The VR-PhotoStudio is a Virtual Reality teaching-learning application for photography education. Educational content is conveyed playfully through exploratory learning and made tangible through a combination of knowledge building and deepening. In particular, the medium is used to experience perspective, space, and the design elements of photography."}]}, "developer_name": "Andreas Fuchs", "developer_privacy_policy_url": "https://vrphotostudio.fuchs-media-service.de/", "developer_terms_of_service_url": null, "publisher_name": "Andreas Fuchs - Media Ser