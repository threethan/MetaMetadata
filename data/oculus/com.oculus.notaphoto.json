a&_nc_ohc=dAv0UtxmQ_AQ7kNvgE_mer7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWLSR0yxeinGnq97vDBqqhiaH2u-UPBCIeuWpCPBVNGQ&oe=670A4F77"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pch-1f0_o-8Q7kNvgFEunW5&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdgCDEAqg4A7jbMI1XybvzqaS8tEjXAsiUCvui3NdSMQ&oe=670A699E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z7SxLQx4Kw4Q7kNvgH1Sixy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_QbtjBhUl43RdpOyMvOlbFxq4ZGkYi40nhqA6IE3xkQ&oe=670A5B3E"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ljwTFsHyNOcQ7kNvgFgVhdM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAPfW4AqcRmmN3NpX8Ttnk8770ZLVeSkLla4ProwpE0jQ&oe=670A57CB"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MdQgOtbmaisQ7kNvgEIT92_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAi1_3Q4pHyxWGWmaa_SwqoM3hPg_XOIz9fYkFbnKhGvA&oe=670A44A1"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iYTOdOn0AKAQ7kNvgEeaFfd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMilpFce3L8AQp6gYBQjtgaB2i4Neo8tc8onZVrktlUQ&oe=670A54AF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "228173919532150"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscd