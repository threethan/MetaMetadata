uluscdn.com/v/t64.5771-25/12138835_1515814172060050_157655622_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RVTOYaEwbIsQ7kNvgGRtvDl&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYDZGbD2Emx6C6LhSElNy-8fDbgla87_q258lCiEM682MA&oe=66ED4E77"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gPlf2BhdCZAQ7kNvgFhyVpz&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYArfQHmi6pxA4JZCeYnISORFOPsSP3yp0ltGB6-XkHCRA&oe=66ED689E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YZQA3SCzlIAQ7kNvgHfb1la&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYBK2ySPwxiqSp7Irmjfi5938nUhMGoa7AwK_brWJKNTGw&oe=66ED5A3E"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ox_3Owa9FboQ7kNvgGRpc4o&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYCVpCkNXgadmZ89Ia6i3E6RJh0UaHtsIxlkrbIigk-02g&oe=66ED56CB"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bhRBVzJ1HP4Q7kNvgFFkZjO&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYARhiEYEd3m7A74HiDBtiuB6aA4N1GSU093Og_XpKZD2Q&oe=66ED7BE1"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-yF4Z1OgwvQQ7kNvgGTAPcj&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao_Se2paqUsiFmbsdG_X2Ab&oh=00_AYC4uEF014JWIWyu30ZFg2EvzIcfmUWHZMY_xxCtX0IqEw&oe=66ED53AF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "suppo