0050_157655622_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nlih61JgQIEQ7kNvgHkj1jZ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCBJV50qsJJ_-dWHBi6MnRnwHXr7A4flUXo9X-tltYRkw&oe=67347F77"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bDlhECIj7MAQ7kNvgE5ICfw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDGB2_Psq-8_EkSEe1NV4PKgpY0bcuS4GRC1NlGLDz2Uw&oe=6734999E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=65X6EazsOKIQ7kNvgFdE61u&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD5yxxFJPUCa-SFIacZB0ox9pQvC94D5Lu2XUbfA8YbgA&oe=67348B3E"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nxNpVta4zdcQ7kNvgEPSp3x&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD1SB74k0w9B2gpFC2o3BqmcP_-AvKFBpABKcWL5zYPkA&oe=673487CB"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HTgrXV9EzSAQ7kNvgFeuPYn&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD0NMpC7ojQaeE7Ybu64E1_6C9KtM3YpfKNahHiBJELOw&oe=673474A1"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvohfhfv8y4Q7kNvgGjJ4D6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDHQ3l2sTjYlxRL2YW-ko6fXidbOc_lK5cYcYty_vMdiQ&oe=673484AF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "22