0050_157655622_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5pbejMbIZHoQ7kNvgEGaNGT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjkK1NUnT9Ptz3NCjNUYK0Kwmsc5GZUpSDA8syswTTzw&oe=67615277"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b6lupBrogS8Q7kNvgFW-C5b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrh332tebugCR_M0r34-pIP-3WJbm0a849gtBScrIINg&oe=67616C9E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e77wbpHlFUEQ7kNvgG3RAlj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTeDeWHia0mxF21T076Si2Gk_6OBfZjTM3bezvoZ_i0Q&oe=67615E3E"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L3UB1KfmjP4Q7kNvgH08NLB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALKc1GGnUH5WrLaIYXs_5NiEFbl_v4Rgd3uC3xYYHO0A&oe=67615ACB"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=twvlIR4_vq4Q7kNvgGIhQBH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAq-Ez6qLkV7Y7UJaLzed6ka7whuysdEGZHN6Id5Ulg6A&oe=67617FE1"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cI-s9dKE-bUQ7kNvgED-v-z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCy9JwR_AcoQmOj7qJ4IyNNZBbGOfk9U2i_QXGUS6kGLw&oe=676157AF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "228