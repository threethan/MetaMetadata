UJ0HJ7vWIOfZOkFREwpjHmwFKDnw7xQ&oe=66CEFBF7"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3HXyvDD0kwMQ7kNvgHm4hI2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDX3FTtqsUynkTvE7ATRoTx1bm6F1e-gEhEC2pwU_qbEg&oe=66CF161E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s303pUvpjRgQ7kNvgEfV0EH&_nc_ht=scontent.oculuscdn.com&oh=00_AYAb2nBzFVF_8V48qNSOY9K82gjCS0lhHETSVAml-iIcJA&oe=66CF07BE"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7YHOnX1FZJMQ7kNvgGs7mV6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSgGoODXM-G0pprCx9o42GTebr2m2r9Zecy66gpslR8g&oe=66CF044B"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWUAcB_qnp0Q7kNvgENHF7_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiTaaxcoKRqjwvqPDbQ4jtCwIN3B9nXEpAi0knOwj4Dw&oe=66CEF121"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fS_k7ciRdJcQ7kNvgE6uJ7I&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3NXn8gXrsShE44xOGJwWydHSiv9etrBNo3zr9cjgTsw&oe=66CF012F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "228173919532150"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449013_209873299377563_1755831407_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ShTv5nFgEQQ7kNvgENui4e&_nc_ht=scontent.ocu