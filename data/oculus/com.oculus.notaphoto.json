fJQ-z4Au1kSWrfL2pqyEELRWp51rnLQ&oe=66E6B6F7"}]}, "id": "220005902387483", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "240692753766297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138792_976971732388321_849551327_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=koYiLm0rOlIQ7kNvgHqR9Bq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAS49Ymrn5MHIsmg5ZArrEicaoCtrpGNG9hs2gESVJbQ&oe=66E6D11E"}, {"file_name": "migrated_image.png", "id": "2091440707669322", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138834_1757166401179652_1834676902_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WJ9nBf6CgpUQ7kNvgFwB8xc&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWDiFVKr_szeHvPKN19DgcBZNp7fxpuXMAwm1Og2hyMQ&oe=66E6C2BE"}, {"file_name": "migrated_image.png", "id": "3144369895594300", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138832_1248797961801243_1985556965_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5xRJsm4FpbgQ7kNvgHxX1ss&_nc_ht=scontent.oculuscdn.com&oh=00_AYDY6gBU5ZJJJV_D-jlMcHgYvWG_UMvdGRrDFJ1wIncG3w&oe=66E6BF4B"}, {"file_name": "migrated_image.png", "id": "2362415107383295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448837_1712346882351320_445814653_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MF11TMLXD24Q7kNvgGxShEv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRCcXb-_gzV7DElKtDSIPMsJOYRiRPM8SHAnry_ZrUwg&oe=66E6AC21"}, {"file_name": "migrated_image.png", "id": "668669003899669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448842_1552150631781687_1259563216_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2bT3nvhUJwQ7kNvgHKlyJN&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9RRl_J7F_ZQPeVgcqBPqZ6h-DMWvUuBahr7ARdf97-A&oe=66E6BC2F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Window to the World", "keywords": ["photography", "art", "landscape", "transmedia", "experimental"], "long_description": "As a photographer and VR enthusiast I have always dreamed about a way of expressing photography as close as possible to the actual moment of capture, about the moment when reality and photography converge. The first trial was a couple of years ago when I took some photos and made a short film based on the famous parallax techniques but with a twist. The twist was that everything was now in actual 3d and not just 2D layers. The next step was giving the viewer a bit of input and so came to be the online WebGL version. The final step was full immersion; VR was only the natural step forward. \nmore info on how this was achieved : http://aurelm.com/2013/12/15/fernweh-3d-parallax-photography-tutorial/", "short_description": "This is a photographic experiment. It represents what can be achieved using classical landscape photography and virtual reality as means of expression. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://aurelm.com/fully-3d-interactive-photography/", "developer_terms_of_service_url": "http://aurelm.com/fully-3d-interactive-photography/", "publisher_name": "Aurel Manea", "support_website_url": null, "website_url": "http://aurelm.com/fully-3d-interactive-photography/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "228173919532150"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449013_209873299377563_1755831407_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wu1X9urWaZkQ7kNvgEbDgpy&_nc_ht=scontent.ocu