F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RC Helicopter", "keywords": [], "long_description": "RC Helicopter is a video game simulating the flight of a small RC helicopter. Before playing the game, you need to scan the room in order to collide with real world objects.\n\nThe game includes 3 modes, free flight, drone race and demolition game.\n\nTry how to control such an RC helicopter right in your own room. With the difference that in this game the helicopter is unbreakable, so if you crash the helicopter into a wall, it won't be damaged and you can fly again.\n\nAnd enjoy all this starting from your room and the small helipad from where the helicopter takes off.\n\nTry how fast it will be on the racing circuit with a drone or demolish a few objects.", "short_description": "RC Helicopter is an mixed reality video game. Control your own small rc helicopter right in your room, try to control your own helicopter with the possibility of collision with real objects."}]}, "developer_name": null, "developer_privacy_policy_url": "https://bartad6.wixsite.com/alternative-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Alternative VR", "support_website_url": null, "website_url": "https://bartad6.wixsite.com/alternative-vr", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "795