tps://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974499_282331063671038_8052167245686758841_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vxTxMVJuPfkQ7kNvgHqNN5V&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAI2OSnJ2vXjb8b83AdgYIvYDYq7IIpVzlloyoVkZkngg&oe=677689DB"}, {"file_name": "qs14.png", "id": "558373928479801", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974608_558373931813134_2752953515118249281_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5nLQRkFYrJYQ7kNvgGIREKC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBDKSf-sFfkIUFMe5mFAgq_WgC5LkPHgxjj8ZSPDPxDEg&oe=67767BC9"}, {"file_name": "qs12.png", "id": "176934120940778", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974860_176934124274111_8600060491308648842_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNH4gQ-JbocQ7kNvgF6EPlW&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDu9HspYtO8sflHjZy9jWD7UrfYbesaO9_GMUFAh2lSKA&oe=6776715D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "plate_2560X1440.png", "id": "341824033979297", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/10000000_341824043979296_8556433505336198245_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aWZ1eg4HwxAQ7kNvgEtYZ7A&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAFEqTqJaJ_YK-JrEBhDwCjbv5i5-dkDtdmkL3C4uFZrQ&oe=67769428"}, "display_name": "TOTALLY BASEBALL", "keywords": ["baseball", "sports", "simulation", "fun", "tournament"], "long_description": "TOTALLY BASEBALL is the only VR Baseball Game that lets you play the full sport of Baseball! Throw a strike but if the batter hits it to the outfield...BOOM! Now you're an outfielder and now have to run over and catch it!  You'll be amazed at how realistic our throwing feels! Start with easy mode and throwing assist set to high, get better over time and play with less assistance for more of a challenge!  \n\n-Multiple throwing options\n-Multiple venues to choose\n-Multiple locomotion methods\n-Customizable comfort settings\n-Customizable characters\n-Practice and Tutorial modes\n-Multiplayer COMING SOON!\n\nHave trouble with throwing/aiming but still want to play the game?  Don't worry we made a hand cannon option just for you!", "short_description": "Run the bases, throw a strike, catch a pop fly and even make a double play!  TOTALLY BASEBALL is the only VR Baseball game that lets you play the full sport of Baseball!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://viewerready.com/totally-privacy", "developer_terms_of_service_url": null, "publisher_name": "VIEWER READY", "support_website_url": null, "website_url": "https://viewerready.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "624207972026092"}}]}, "scheduled_offers": {"count": 58, "nodes": [{"status": "PUBLISHED", "id": "8631836613560727"}, {"status": "PUBLISHED", "id": "1036077981640797"}, {"status": "PUBLISHED", "id": "1220742932431604"}, {"status": "PENDING", "id": "296571469487556"}, {"status": "PENDING", "id": "961796471550181"}, {"status": "PENDING", "id": "183312424450627"}, {"status": "PENDING", "id": "1008448970533291"}, {"status": "PENDING", "id": "1123091258570533"}, {"status": "PENDING", "id": "902717217296883"}, {"status": "PUBLISHED", "id": "3130290743939237"}, {"status": "PUBLISHED", "id": "474