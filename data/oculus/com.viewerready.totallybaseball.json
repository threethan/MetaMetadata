ontent-sjc3-1.oculuscdn.com&oh=00_AYCuQwfouSUvk_SR-gONg4q-yl-AKGEh1EyjS5Uw7-jU4A&oe=6776625A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Special Pitches 2560x1440.png", "id": "166982723132300", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974589_166982729798966_2594299778133976646_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sRCxECAhaRwQ7kNvgGSE1Tn&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDIA6kg5hfcCuuRheUj_Nj0BfHvG4pu5QtpFLpvuTaxnA&oe=67769482"}, "display_name": "TOTALLY BASEBALL", "keywords": ["baseball", "sports", "simulation", "fun", "multiplayer"], "long_description": "TOTALLY BASEBALL gives you the opportunity to play every part and position of baseball in VR! Whether you want to pitch, bat, field or play a simple game of catch, we've got you covered! Enjoy playing in our small fields or huge stadiums!  Multiplayer from 1v1 all the way up to 20 people in FREE PLAY mode!  Earn coins from winning games and unlock fun and cool items to decorate your character!\n\n\"One of the best sports games on Oculus Quest.\" - ScreenRant\n\n\"Totally Baseball is the complete baseball experience in virtual reality, and there's no other game that compares to it.\" - GameRant\n\n\"Is it good? Heck yes, it's good!\" - BMFVR\n\nFeatures:\n-Practice and tutorial modes for new players to find their pitching/batting sweet spot!\n-Multiple teams/venues to choose from (and play against)\n-Top notch realistic throwing and batting physics\n-Robust multiplayer (1v1 or Free Roam with up to 20+ people at once!)\n-Join our organized leagues and practice with real people on your team\n-(JUST ADDED) Special Pitches! Add curve balls, slowballs, splitters to your options\n-(JUST ADDED) Pro batting mode, after you master \"classic\" batting try the new \"PRO\" option for more of a challenge!\n-Comfort settings and movement settings that can be fine-tuned to your liking or turned off completely\n-Fun seasonal updates (Check out new fields and new items throughout the year)\n-Large community of people to play with or get tips from (See our Discord)\n", "short_description": "Play the full sport of Baseball (every position) on your own or with your friends!  (No subscription needed!)"}]}, "developer_name": null, "developer_privacy_policy_url": "https://viewerready.com/totally-privacy", "developer_terms_of_service_url": null, "publisher_name": "VIEWER READY", "support_website_url": null, "website_url": "https://viewerready.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6946692105376392"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035458_213810124821195_6222422884662619314_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZBdaODxijegQ7kNvgHJGKyA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQGUXmS_fHtmxw7JyW6eafQ0DerNdbWip2C0YWSmf7Gw&oe=677662F8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TOTALLY BASEBALL", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1625752745, "lastRevision": 