40064474653251_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e87PBZBb9LAQ7kNvgH7hwkS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvqzO6iiJwP7majX1NXAXW2esHvOC1np7z-97SLvIQMQ&oe=673F2935"}, {"file_name": "Screen3.png", "id": "245055157078949", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75348043_245055163745615_3924373067454866465_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zMsivMcliy0Q7kNvgH5mJ1k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHkvMLjMV0QjmaHVa9---byyQeXtPPkgeV0j54stF4Mw&oe=673F245D"}, {"file_name": "Screen4.png", "id": "2932674483636521", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974769_2932674486969854_5078026231165140623_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tKKkNCTy-uUQ7kNvgHAoMN9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXJpHoRyDuTrFDlLUyvsWShl293iFAfsY7rsLsZT_XgA&oe=673F2240"}, {"file_name": "Screen5.png", "id": "759389654958540", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_759389658291873_9040706210688267977_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ugCA853VJvcQ7kNvgHR855F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbJoLrte9yBBrgRD-Yazkx0841_qI8Ij7fOTDq6xSR_w&oe=673F0817"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Background-Tournament-2560x1440px.png", "id": "878535942989656", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974682_878535946322989_456871179866758300_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YTxTmG1XTH0Q7kNvgFRuFIH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSvT8M4sZMMpH9oVlaxi1m0C0dmtrTIK5AXNF1rOqrrA&oe=673F2B44"}, "display_name": "Battle Arena VR", "keywords": [], "long_description": "Battle Arena VR is a multiplayer arena shooter, where you are automatically matched with opponents. Main features:\n\n- Multiplayer - best fit for 2-5 users on each map\n- Short sessions - to invoke emotions through sometimes intensive play and discuss it later using voice chat\n- Guided gameplay - warmup and cooldown stages to connect with other players, get familiar with landscape and physics\n- Voice chat during the game - use an open microphone to chat with other players in realtime to share your excitement\n- Multiple servers across the globe so everyone is included and can play with the local community and low latency (for now we have enabled 3 servers, which can be extended for worldwide coverage of 14 servers)\n- Complete tutorial - learn controls and capabilities to get the most from your cyborg\n- Every game gives you experience, level-ups, and change your position in the leaderboard, which is visible to all players\n\nPlease, join our Discord server: \nhttps://discord.gg/BEdWsry", "short_description": "Challenge yourself, challenge everyone in a deathmatch Battle Arena"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drmtm.blob.core.windows.net/policies/battlearenavr/privacypolicy.pdf", "developer_terms_of_service_url": "https://drmtm.blob.core.windows.net/policies/battlearenavr/BattleArenaVR-TermsOfService.pdf", "publisher_name": "DreamTeam Mobile", "support_website_url": "https://battlearenavr.net/feedback", "website_url": "https://battlearenavr.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1340483650106047"}, "review_messages": ["New TOS link looks good. Approved."]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982668_238321391169018_2365347074850027730_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1D4walZdr4QQ7kNvgG2BReF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUqNOEXSJIO8hmgDR9vFXannzpDGseLD3LujATPlYcyg&oe=673F2E69"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Battle Arena VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1615491509, "lastRevision": {"nodes": [{"id": "243354837348639", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3690146771060824", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "798613470941342"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Logo on transparent background.png", "id": "1112117429225443", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974682_1112117432558776_4232435664763984938_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JhpD_W48_b0Q7kNvgGh1E67&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCT8couoYXCu0dLzMu5oJfnUzCe2rluaFsKnILz7-ksvg&oe=673F2B73"}, {"file_name": "Mini Landscape 1080x360px.png", "id": "875924429910094", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221327_875924433243427_6481693614791429144_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzKR4qX4j3cQ7kNvgEnmelB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9KGlZdWGLditFdy_wvQ9gMoE5-2A9MGeGV_4Vi0mLRw&oe=673F0550"}, {"file_name": "Icon.png", "id": "866357467519329", "image_type": "APP_IMG_ICON", "u