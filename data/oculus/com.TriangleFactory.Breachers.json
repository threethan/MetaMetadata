0896203_118152768029565294_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7_-QI_a6JG8Q7kNvgEW_2vN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrAMqxsxHH7mnd0DmxyyQ93s1BoCIPvwxqaYihIWq_Sg&oe=66F7FB6B"}, {"file_name": "ImmersiveLogo.png", "id": "214128257854053", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195913_214128261187386_8217972660968347413_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WVheSdvpT3EQ7kNvgGXVzUl&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4bxSFwG4743Sm1O5gHkW905eaMDaLV0rsWxpISfAU4g&oe=66F7EED7"}]}, "id": "255789722711997", "locale": "en_US", "screenshots": [{"file_name": "2.png", "id": "128020656873509", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_128020660206842_1838067535475478717_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KAlCcLfZyJkQ7kNvgEguVS0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCak1vWm05tgrNHVrtY2jQKSeGTiP_6tgU2Dqh8sh2NtA&oe=66F7F6E6"}, {"file_name": "1.png", "id": "219717977237145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250459_219717980570478_915619153882912634_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=98Q0OA3t64wQ7kNvgHSdV84&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFQIAuDDYt9QyFy-fjSH_Q-Q4Qmhpfo6NvVSZ_w0s8kA&oe=66F7E5A9"}, {"file_name": "5.png", "id": "537146135191812", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75507164_537146138525145_607767114728743415_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bL_FMiOnV7AQ7kNvgHzTgsS&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxioY-632kdAC9s5CJSco5T0NwsbciTjb4pyiHmF7gog&oe=66F7F3E3"}, {"file_name": "3.png", "id": "1360078531504482", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031609_1360078534837815_4355618434683677228_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LNM5Lcf49rUQ7kNvgEbhF9I&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjW2MOQvYPe0rECu2AtGxGIg3bn93MD1g8FFaz1pozlQ&oe=66F80686"}, {"file_name": "4.png", "id": "1211233259534362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982564_1211233266201028_3265958303139352009_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ozSSYiK-BK8Q7kNvgFfbmFK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBcZ6bKanUecFR5Is19wqnB3A6Ycl9yZNbp1BVceMP3nQ&oe=66F80724"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Breachers_006.png", "id": "654460902855884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031315_654460906189217_3205056799537065162_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vr2fEFX27i0Q7kNvgEIYasC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsAv-V9F-roURHu-3rTNuEhL_NGYMcff1wcC4nMyjvFg&oe=66F7E52C"}, "display_name": "Breachers", "keywords": ["Breachers", "fps", "shooter", "tactical"], "long_description": "PRE-ORDER NOW to get the exclusive \"Elite\" JESPER gun skin!\n\nIn Breachers, you plan your assault or orchestrate your defense as a team through intense close-quarters combat. Whether you play as an enforcer or a revolter, master your nifty gadgetry, customize your powerful weaponry and beat your opponents in stunning environments.\n\nIntuitive to grasp. Endlessly playable.\n\nBREACH AS ENFORCERS\nYour goal as an enforcer is to eliminate your enemies and disarm their bombs with an EMP. Rappel and blow up walls, swing through windows and catch your opponents by surprise with gadgetry like drones, cloaking devices, flashbangs and breaching foam.\n\nAMBUSH AS REVOLTERS\nYour goal as a revolter is to prevent your enemies from disarming your bomb by terminating them before they do so. Use doorblockers, tripmines, static field emitters and proximity sensors to defend your position.\n\nCUSTOMIZE POWERFUL WEAPONRY\nTo ensure victory, purchase and customize your extensive weaponry to your liking at the start of each round. Every gun, whether it's pistols, SMGs, shotguns or assault rifles, can be modified with attachments to suit your needs.\n\nBreachers also supports Cross-Buy: Get the Quest version and receive the Rift version for free!", "short_description": "Breachers is a tactical 5v5 VR FPS. Plan your assault or orchestrate your defense as a team through intense close-quarters combat. Climb, vault, rappel, swing, shoot and strategize your way to victory in stunning environments.\n\nBreachers also supports Cross-Buy: Get the Quest version and receive the Rift version for free!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.breachersvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.breachersvr.com/terms-of-use", "publisher_name": "Triangle Factory", "support_website_url": null, "website_url": "https://www.breachersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "cs", "da", "nl", "de", "el", "en_US", "en_GB", "es", "fr", "fi", "it", "ja", "ko", "pl", "pt_BR", "pt", "ro", "ru", "sv", "tr", "zh_CN", "nb", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1540411809669827"}}]}, "scheduled_offers": {"count": 18, "nodes": [{"status": "PUBLISHED", "id": "1722192538185771"}, {"status": "PUBLISHED", "id": "2192756181104983"}, {"status": "PUBLISHED", "id": "775127560518762"}, {"status": "PUBLISHED", "id": "463761696100848"}, {"status": "PENDING", "id": "842852010542388"}, {"status": "PENDING", "id": "714760293794694"}, {"status": "PENDING", "id": "1411812823091854"}, {"status": "PUBLISHED", "id": "3624962541160086"}, {"status": "PENDING", "id": "318312210667010"}, {