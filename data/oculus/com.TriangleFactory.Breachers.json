0_AYDUwjDYbh6tRM6XwITP7tpVOlWEdq-LdD9n7FpkAljBmw&oe=66F2ADE3"}, {"file_name": "3.png", "id": "1360078531504482", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031609_1360078534837815_4355618434683677228_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=htTouO4PrZgQ7kNvgEbylxg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWYMsnGgytYoznVZ8T1MoGs&oh=00_AYAhp7YrqC3sj5oWqKWd4I7g5t2Q_-vYhfXbwrzj832Uew&oe=66F28846"}, {"file_name": "4.png", "id": "1211233259534362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982564_1211233266201028_3265958303139352009_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=38R-9GwC-XAQ7kNvgFBOnW-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWYMsnGgytYoznVZ8T1MoGs&oh=00_AYC9XyVb0VetJJKaMxcUjaor20BouuXfhE8Dah8IJCZ7IQ&oe=66F288E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Breachers_006.png", "id": "654460902855884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031315_654460906189217_3205056799537065162_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=naKxIIZx9lgQ7kNvgFRDIFE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWYMsnGgytYoznVZ8T1MoGs&oh=00_AYACkaeznVwlzsKnn1HOQkbIfDiXB5Cge9D3QSrnA-NcoQ&oe=66F29F2C"}, "display_name": "Breachers", "keywords": ["Breachers", "fps", "shooter", "tactical"], "long_description": "PRE-ORDER NOW to get the exclusive \"Elite\" JESPER gun skin!\n\nIn Breachers, you plan your assault or orchestrate your defense as a team through intense close-quarters combat. Whether you play as an enforcer or a revolter, master your nifty gadgetry, customize your powerful weaponry and beat your opponents in stunning environments.\n\nIntuitive to grasp. Endlessly playable.\n\nBREACH AS ENFORCERS\nYour goal as an enforcer is to eliminate your enemies and disarm their bombs with an EMP. Rappel and blow up walls, swing through windows and catch your opponents by surprise with gadgetry like drones, cloaking devices, flashbangs and breaching foam.\n\nAMBUSH AS REVOLTERS\nYour goal as a revolter is to prevent your enemies from disarming your bomb by terminating them before they do so. Use doorblockers, tripmines, static field emitters and proximity sensors to defend your position.\n\nCUSTOMIZE POWERFUL WEAPONRY\nTo ensure victory, purchase and customize your extensive weaponry to your liking at the start of each round. Every gun, whether it's pistols, SMGs, shotguns or assault rifles, can be modified with attachments to suit your needs.\n\nBreachers also supports Cross-Buy: Get the Quest version and receive the Rift version for free!", "short_description": "Breachers is a tactical 5v5 VR FPS. Plan your assault or orchestrate your defense as a team through intense close-quarters combat. Climb, vault, rappel, swing, shoot and strategize your way to victory in stunning environments.\n\nBreachers also supports Cross-Buy: Get the Quest version and receive the Rift version for free!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.breachersvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.breachersvr.com/terms-of-use", "publisher_name": "Triangle Factory", "support_website_url": null, "website_url": "https://www.breachersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "cs", "da", "nl", "de", "el", "en_US", "en_GB", "es", "fr", "fi", "it", "ja", "ko", "pl", "pt_BR", "pt", "ro", "ru", "sv", "tr", "zh_CN", "nb", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking