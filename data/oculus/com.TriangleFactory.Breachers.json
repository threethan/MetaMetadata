D755A"}]}, "id": "1134318290977432", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "411430824919699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367597_411430828253032_5135291419025181752_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cEV52Rwgd9UQ7kNvgH4uVxu&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9Nn7kxCpuDfqQ_fvpLLokAynXmNTvRZtTFVnrJdZSAg&oe=66DDA234"}, {"file_name": "2.png", "id": "1098324381472905", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572935_1098324384806238_6049362224134146862_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WUZZi5fSb1gQ7kNvgFPMVDj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYTWNg_wfbNAczSTwJ7cKSyAL6PxmcCcyfLFw7NaK8wA&oe=66DD89BA"}, {"file_name": "3.png", "id": "25239335552347153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572931_25239335559013819_6447313941186033703_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b_F8i_aze50Q7kNvgFJ4_2D&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtCKpw-9YYe1vzf9O3FVmFTx3bv8x1IGQ0CltbzkYUgw&oe=66DD7487"}, {"file_name": "4.png", "id": "1060554035052039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974549_1060554038385372_1745280912895752226_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xi3IJQntHNoQ7kNvgF5f731&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhObG7-GwfJJP5MV5w6j065T1Y248LBza9kJJ2mLhdRQ&oe=66DDA61F"}, {"file_name": "4.png", "id": "1211233259534362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982564_1211233266201028_3265958303139352009_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ujop4ALAYoQ7kNvgFZPch_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrCzmoy6sgDpmFKQYgQP32p5EJ-9i_bA4Rf2C46yPPCg&oe=66DD70E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "comtrailerthumb.png", "id": "1146052160011839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974439_1146052163345172_2057977826583500267_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QZf1guQKGTwQ7kNvgF3eWgH&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbkSJ4AZKbwr50U0YgTIPy_N5XGS_dJqzK0jJ4aqIDGg&oe=66DD7BEE"}, "display_name": "Breachers", "keywords": ["Breachers", "fps", "shooter", "tactical"], "long_description": "**CROSS-BUY ENABLED:** Get the Quest version and receive the Rift version for free!\n\nIn Breachers\u2122, you plan your assault or orchestrate your defense as a team through intense close-quarters combat. Whether you play as an enforcer or a revolter, master your nifty gadgetry, customize your powerful weaponry and beat your opponents in stunning environments.\n\n{1658295511676973}\n\n# Intuitive to grasp. Endlessly playable.\n\n{1461782037804068}\n## BREACH AS ENFORCER\nYour goal as an enforcer is to eliminate your enemies and disarm their bombs with an EMP. Rappel and blow up walls, swing through windows and catch your opponents by surprise with gadgetry like drones, cloaking devices, flash bangs, and breaching foam.\n\n{406525419035630}\n## AMBUSH AS REVOLTER\nYour goal as a revolter is to prevent your enemies from disarming your bomb by terminating them before they do so. Use doorblockers, trip mines, static field emitters, and proximity sensors to defend your position.\n\n{387678494293784}\n## CUSTOMIZE POWERFUL WEAPONRY\nTo ensure victory, purchase and customize your extensive weaponry to your liking at the start of each round. Every gun, whether it's pistols, SMGs, shotguns or assault rifles, can be modified with attachments to suit your needs. Every weapon can also be decorated with gorgeous skins in the armory.\n\n{513884097640330}\n## PLAY ON A VARIETY OF MAPS\nFrom the rooftop of a modern city skyscraper, to taking back a research facility in the Arctic. A great variety of maps await your arrival, and frequent content updates will keep you engaged and playing!\n", "short_description": "Breachers\u2122 is a tactical 5v5 VR FPS. Plan your assault or orchestrate your defense as a team through intense close-quarters combat. Climb, vault, rappel, swing, shoot and strategize your way to victory in stunning environments. \n\nBreachers also supports Cross-Buy: Get the Quest version and receive the Rift version for free!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.breachersvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.breachersvr.com/terms-of-use", "publisher_name": "Triangle Factory", "support_website_url": "https://www.breachersvr.com/support/", "website_url": "https://www.breachersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "cs", "da", "nl", "de", "el", "en_US", "en_GB", "es", "fr", "fi", "it", "ja", "ko", "pl", "pt_BR", "pt", "ro", "ru", "sv", "tr", "zh_CN", "nb", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27081875968078245"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_853445732959513_5071435851384612768_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g84MfWMcru8Q7kNvgHEaruV&_nc_ht=scontent.oculuscdn.com&oh=00_AYAD78_mum6DMPrljnCnm47hqYXy6KhJ5UofkReSOI5DOw&oe=66DD736C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Breachers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}], "release_date": 1681405200, "