n.com&oh=00_AYBgJPLyH8Sv_hJ3pwveaJxxZdDdI3OrLCvKLDPoQ6Q2fA&oe=67502CF1"}, {"file_name": "Customization_01.png", "id": "395908836641603", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001705_395908839974936_7994984173032695351_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4hLT11XUlo8Q7kNvgFP2l41&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5HaeYy2SXlnPNF6xK_InxL01vkx09DMloJ5LkJOQIQA&oe=67502B1E"}, {"file_name": "MainGym_02.png", "id": "1627683657962451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404389_1627683661295784_3798084179381757755_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0iiFUOaVJzMQ7kNvgHs5s6A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCuJ4XFWZuptR0OHvoIqoGD5_xvdSTaWqaQubf_g9pkQQ&oe=67502700"}, {"file_name": "vlcsnap-2024-09-13-18h13m00s431.png", "id": "1047580373105794", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982575_1047580376439127_631152668609215326_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=82bXgwbXtKgQ7kNvgGmJsGo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCws_e1-F1ACMyLnyql7mYyJMaOiX9tD21nLyTDmVtMxw&oe=675045BE"}, {"file_name": "vlcsnap-2024-09-13-18h09m07s081.png", "id": "1182587286154988", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031509_1182587289488321_4659015807588489067_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TJB81G3Q-Z8Q7kNvgH6z72U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBULQDO8tbWVQgqgj1JklY4nodF0fxa6j43GXHKw-Yzqw&oe=67504D80"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TOTF2_EarlyAccess_FINAL_16x9_2560x1440 1.png", "id": "1211773973241779", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574716_1211773976575112_6543727280950697760_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdTP7uJvp6oQ7kNvgEQGhe1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChbECX7WnNMAV9rcurfSJzhzX9DS_PIs1bHnNlAmC1eQ&oe=675044C8"}, "display_name": "The Thrill of the Fight 2", "keywords": ["Fighting", "sports", "multiplayer", "mma", "boxing"], "long_description": "**Coming Soon in Early Access**\n\nJab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with a stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring!\n\nGlove up your fully customizable avatar and test your skill while working up a sweat in the new online player versus player mode. Challenge friends or enter the arena through skill-based matchmaking, as you battle through breathtaking arenas. Grab your gloves, step through the ropes, and defend your title!\n\n**MULTIPLAYER EARLY ACCESS**\n\nThe Thrill of the Fight 2 is an Early Access title, which is currently multiplayer only. More single player content, training, and other features and polish are planned, with the goal of exceeding the capability, realism, and variety of the original title. The game's content and features are subject to change during development, and we welcome your feedback while we are building the game. The game's price may increase as more content is added.", "short_description": "Jab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with this stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring! Grab your gloves, step through the ropes, and defend your title!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.halfbrick.com/totf2-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Halfbrick Studios", "support_website_url": null, "website_url": "https://www.thethrillofthefight2.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8040161259366586"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "419968621210544"}]}, "baseline_offer": {"id": "419968621210544"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1732212001, "status": "PUBLISHED", "id": "419968621210544"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8535162373199803", "version": "0.1.17.758452"}, "id": "612735397280626", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8535162373199803"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "612735397280626"}]}, "change_log": "0.1.17 Patch Notes\nAdded the experimental damage system update that can be enabled in custom matches and against the training dummy. Please try it out and give us feedback!\nSlightly reduced body damage.\nIncreased requirements to get a punishment knockdown.\nStanding Mode joystick movement is no longer blocked if you are outside of the shared play area during a match. This will not allow you to exit the play area!\nImproved a portion of our netcode that was failing for players in some regions when they tried to join a match.\nFixed a rare issue where players could get stuck after a knockdown.\nYour ping that is shown during a match now shows the full return trip time to and from your opponent.\nAdjusted some IK settings to improve how the body looks in certain positions.", "created_date": 1732848527, "id": "8535162373199803", "version": "0.1.17.758452", "version_code": 758452, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8535161046533269"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8535162373199803"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732844679, "id": "8534931533222887", "version": "0.1.17.758416", "version_code": 758416, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8534930429889664"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8535162373199803"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732840619, "id": "8534703046579069", "version": "0.1.17.758395", "version_code": 758395, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8534702176579156"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8535162373199803"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "612735397280626"}]}, "change_log": "0.1.16 Patch Notes\nAdded the experimental damage system update that can be enabled in custom matches and against the training dummy. Please try it out and give us feedback!\nSlightly reduced body damage.\nIncreased requirements to get a punishment knockdown.\nStanding Mode joystick movement is no longer blocked if you are outside of the shared play area during a match. This will not allow you to exit the play area!\nImproved a portion of our netcode that was failing for players in some regions when they tried to join a match.\nFixed a rare issue where players could get stuck after a knockdown.\nYour ping that is shown during a match now shows the full return trip time to and from your opponent. \nAdjusted some IK settings to improve how the body looks in certain positions.", "created_date": 1732783679, "id": "8531179326931441", "version": "0.1.16.758275", "version_code": 758275, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8531177880264919"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8535162373199803"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732780537, "id": "8530991903616850", "version": "0.1.16.758247", "version_code": 758247, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8530991043616936"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}