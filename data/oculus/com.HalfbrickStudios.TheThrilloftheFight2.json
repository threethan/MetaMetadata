ore a punishment knockdown.\n- Fixed an issue that could cause errors when players joined a lobby, requiring the lobby to be remade.\n- Updated recenter logic to bring the standing circle to the player's in-game body instead of moving the player's in-game body to the standing circle.\n- KOs and the third knockdown of a TKO now show up in the knockdown count on the scorecard.", "created_date": 1733372411, "id": "8566657950050245", "version": "0.1.20.759728", "version_code": 759728, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8566656586717048"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5479643155418422", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8566657950050245"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733361974, "id": "8566065573442816", "version": "0.1.19.759598", "version_code": 759598, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8566064246776282"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}