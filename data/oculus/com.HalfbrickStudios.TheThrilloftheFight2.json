uluscdn.com&oh=00_AYBU8hQi_Zot6iXvoH6WVu_0tpHMj5QDEapHDyoncWUVTw&oe=67693971"}, {"file_name": "Customization_01.png", "id": "395908836641603", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001705_395908839974936_7994984173032695351_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WULT3x9o8OAQ7kNvgHGLofy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtFG7Ih6IfNundjCgaZ7dNboBz8v-pb7mL9sRaKf38WA&oe=6769379E"}, {"file_name": "MainGym_02.png", "id": "1627683657962451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404389_1627683661295784_3798084179381757755_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=44rzHYJd92QQ7kNvgHEUjSE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBH_VAWuO6bft3eq-H05wkp9w45XbncHmOdoFAd-C89_A&oe=67693380"}, {"file_name": "vlcsnap-2024-09-13-18h13m00s431.png", "id": "1047580373105794", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982575_1047580376439127_631152668609215326_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VhsDdEaeGOQQ7kNvgG_f_D_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChR-SprBlUyvMYr20s-AXUFS3VCUdA2MIFzTtL2QWHOQ&oe=6769523E"}, {"file_name": "vlcsnap-2024-09-13-18h09m07s081.png", "id": "1182587286154988", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031509_1182587289488321_4659015807588489067_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N4wj6cMEQ7UQ7kNvgHOUFHM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCohtpnp95Tpo_nbgy3LxN7nwEbzVVvHwMuq76DyfliKQ&oe=67695A00"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TOTF2_EarlyAccess_FINAL_16x9_2560x1440 1.png", "id": "1211773973241779", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574716_1211773976575112_6543727280950697760_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I5xjD0PkdnMQ7kNvgFx0EvZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCshPQZ-SnnTyEhtp9GsXg7YOPI8CixTXNWpQAR6bAybg&oe=67695148"}, "display_name": "The Thrill of the Fight 2", "keywords": ["Fighting", "sports", "multiplayer", "mma", "boxing"], "long_description": "**Coming Soon in Early Access**\n\nJab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with a stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring!\n\nGlove up your fully customizable avatar and test your skill while working up a sweat in the new online player versus player mode. Challenge friends or enter the arena through skill-based matchmaking, as you battle through breathtaking arenas. Grab your gloves, step through the ropes, and defend your title!\n\n**MULTIPLAYER EARLY ACCESS**\n\nThe Thrill of the Fight 2 is an Early Access title, which is currently multiplayer only. More single player content, training, and other features and polish are planned, with the goal of exceeding the capability, realism, and variety of the original title. The game's content and features are subject to change during development, and we welcome your feedback while we are building the game. The game's price may increase as more content is added.", "short_description": "Jab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with this stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring! Grab your gloves, step through the ropes, and defend your title!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.halfbrick.com/totf2-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Halfbrick Studios", "support_website_url": null, "website_url": "https://www.thethrillofthefight2.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_