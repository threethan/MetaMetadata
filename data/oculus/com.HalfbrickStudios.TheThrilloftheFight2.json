cdn.com&oh=00_AYDumbd4Jw44rATUbzkQmvbYmad_NMukm0ws3MZ3KheLFQ&oe=675D5BF1"}, {"file_name": "Customization_01.png", "id": "395908836641603", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001705_395908839974936_7994984173032695351_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Anr5DRb2OYQ7kNvgFZW0oX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBSf5Pn0caN6mOoJ3WZKWDPajgRzgGZl00GIBIjwWDO4w&oe=675D5A1E"}, {"file_name": "MainGym_02.png", "id": "1627683657962451", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75404389_1627683661295784_3798084179381757755_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lasTQBnPx_QQ7kNvgFE8IvP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDNVXRCa_qG-Qm6oJR5T5xX88Lb-bny2Ec5ABuXTlAeYg&oe=675D5600"}, {"file_name": "vlcsnap-2024-09-13-18h13m00s431.png", "id": "1047580373105794", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982575_1047580376439127_631152668609215326_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZOz0GSasHSAQ7kNvgGS4nFj&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCcRrJtUbcATpYCyp8veeYuOecavzPLQNCu6EDDl3PeiQ&oe=675D74BE"}, {"file_name": "vlcsnap-2024-09-13-18h09m07s081.png", "id": "1182587286154988", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031509_1182587289488321_4659015807588489067_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OD1zBhj6pE8Q7kNvgEzb0B6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDtlYIFJNJw3yM4Wj0lRDqHr6wp_wcyxGTpQ0jF7CeaRg&oe=675D7C80"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TOTF2_EarlyAccess_FINAL_16x9_2560x1440 1.png", "id": "1211773973241779", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57574716_1211773976575112_6543727280950697760_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MEl5WKAMn9sQ7kNvgENaK6b&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYChiIHtHRk9IyA3xu3vwhUnPIH0m28PAvvlvAgyhLs76g&oe=675D73C8"}, "display_name": "The Thrill of the Fight 2", "keywords": ["Fighting", "sports", "multiplayer", "mma", "boxing"], "long_description": "**Coming Soon in Early Access**\n\nJab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with a stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring!\n\nGlove up your fully customizable avatar and test your skill while working up a sweat in the new online player versus player mode. Challenge friends or enter the arena through skill-based matchmaking, as you battle through breathtaking arenas. Grab your gloves, step through the ropes, and defend your title!\n\n**MULTIPLAYER EARLY ACCESS**\n\nThe Thrill of the Fight 2 is an Early Access title, which is currently multiplayer only. More single player content, training, and other features and polish are planned, with the goal of exceeding the capability, realism, and variety of the original title. The game's content and features are subject to change during development, and we welcome your feedback while we are building the game. The game's price may increase as more content is added.", "short_description": "Jab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with this stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring! Grab your gloves, step through the ropes, and defend your title!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.halfbrick.com/totf2-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Halfbrick Studios", "support_website_url": null, "website_url": "https://www.thethrillofthefight2.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME