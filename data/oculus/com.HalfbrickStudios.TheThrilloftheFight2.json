cdn.com&oh=00_AYDpIw_BSEgmX514URh2gUDW-0ommCPxB5pv11f56-DMSA&oe=676544F1"}, {"file_name": "Customization_01.png", "id": "395908836641603", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001705_395908839974936_7994984173032695351_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DqKLVYnIorQQ7kNvgFoMIMT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCiUct6z__cCzu-cClS4f8TRYWCqBPCOO3KqQYcj342zw&oe=6765431E"}, {"file_name": "MainGym_02.png", "id": "1627683657962451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404389_1627683661295784_3798084179381757755_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QqTwaejdXCEQ7kNvgE6F97m&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8u6FAaCj-pJiYkNMBvBTa5qFqSZ8X9aBAf6MFStAewg&oe=67653F00"}, {"file_name": "vlcsnap-2024-09-13-18h13m00s431.png", "id": "1047580373105794", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982575_1047580376439127_631152668609215326_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IMCV6DCTVIUQ7kNvgEYn9E0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCxh76UUzgSmNbNXlT1c3mJCMGy7J1CWch8n_tNik0tQ&oe=67655DBE"}, {"file_name": "vlcsnap-2024-09-13-18h09m07s081.png", "id": "1182587286154988", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031509_1182587289488321_4659015807588489067_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yQ89wILMGHYQ7kNvgGwQph9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA12nZGMCcTyi81pXlZH3v5eAZn4GggvBQiz5BNwyYDwA&oe=67656580"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TOTF2_EarlyAccess_FINAL_16x9_2560x1440 1.png", "id": "1211773973241779", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574716_1211773976575112_6543727280950697760_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D_NV9o6WqLMQ7kNvgECIqP_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAg17g8d6QvKIYdMJuqAnHR4Oe2e6GbLtWaL3Xdy8AP1g&oe=67655CC8"}, "display_name": "The Thrill of the Fight 2", "keywords": ["Fighting", "sports", "multiplayer", "mma", "boxing"], "long_description": "**Coming Soon in Early Access**\n\nJab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with a stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring!\n\nGlove up your fully customizable avatar and test your skill while working up a sweat in the new online player versus player mode. Challenge friends or enter the arena through skill-based matchmaking, as you battle through breathtaking arenas. Grab your gloves, step through the ropes, and defend your title!\n\n**MULTIPLAYER EARLY ACCESS**\n\nThe Thrill of the Fight 2 is an Early Access title, which is currently multiplayer only. More single player content, training, and other features and polish are planned, with the goal of exceeding the capability, realism, and variety of the original title. The game's content and features are subject to change during development, and we welcome your feedback while we are building the game. The game's price may increase as more content is added.", "short_description": "Jab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with this stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring! Grab your gloves, step through the ropes, and defend your title!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.halfbrick.com/totf2-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Halfbrick Studios", "support_website_url": null, "website_url": "https://www.thethrillofthefight2.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME