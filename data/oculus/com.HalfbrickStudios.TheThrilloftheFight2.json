cdn.com&oh=00_AYB3p87DKt1SHuHobWhPZfqNab3DnWG8VQMnXRa3ByYzAA&oe=675FFEF1"}, {"file_name": "Customization_01.png", "id": "395908836641603", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39001705_395908839974936_7994984173032695351_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Anr5DRb2OYQ7kNvgGftGzy&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBcU0CiQlKuTCIa2tiancwzMFNXu8JFPl2gMU572_CQtQ&oe=675FFD1E"}, {"file_name": "MainGym_02.png", "id": "1627683657962451", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75404389_1627683661295784_3798084179381757755_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rPdRTEDrlXAQ7kNvgFDnbbA&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDGUXneVCLBg3DKCWdZZB-3RoSYWpobCsp3u7P6muYRuQ&oe=675FF900"}, {"file_name": "vlcsnap-2024-09-13-18h13m00s431.png", "id": "1047580373105794", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982575_1047580376439127_631152668609215326_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ct9gSJxJ3HcQ7kNvgHHP1vs&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDlYNBPK1Ka1bZTWIqzLOppW_Kw7DPiKaIj6WXtOOEhUg&oe=676017BE"}, {"file_name": "vlcsnap-2024-09-13-18h09m07s081.png", "id": "1182587286154988", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031509_1182587289488321_4659015807588489067_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2h3VkGEOtHkQ7kNvgFxHC7X&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDoeuZ1mJAJtrjiO67IJIGSzU8RI91EXyUhpmWBoClvVQ&oe=67601F80"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TOTF2_EarlyAccess_FINAL_16x9_2560x1440 1.png", "id": "1211773973241779", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57574716_1211773976575112_6543727280950697760_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WMG19Lq86YkQ7kNvgGUUUvx&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDin_kZDTK2IUaOqKEx5UNe2b4Xu9iLOTnIV_InDcFV3A&oe=676016C8"}, "display_name": "The Thrill of the Fight 2", "keywords": ["Fighting", "sports", "multiplayer", "mma", "boxing"], "long_description": "**Coming Soon in Early Access**\n\nJab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with a stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring!\n\nGlove up your fully customizable avatar and test your skill while working up a sweat in the new online player versus player mode. Challenge friends or enter the arena through skill-based matchmaking, as you battle through breathtaking arenas. Grab your gloves, step through the ropes, and defend your title!\n\n**MULTIPLAYER EARLY ACCESS**\n\nThe Thrill of the Fight 2 is an Early Access title, which is currently multiplayer only. More single player content, training, and other features and polish are planned, with the goal of exceeding the capability, realism, and variety of the original title. The game's content and features are subject to change during development, and we welcome your feedback while we are building the game. The game's price may increase as more content is added.", "short_description": "Jab, dodge, and sweat your way to the top of the boxing world! The undisputed champion of VR boxing games returns with this stunning, fully-reimagined sequel to the original breakout hit. The Thrill of the Fight 2 delivers a truly authentic boxing experience that may be the closest you\u2019ll ever get to stepping into the ring! Grab your gloves, step through the ropes, and defend your title!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.halfbrick.com/totf2-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Halfbrick Studios", "support_website_url": null, "website_url": "https://www.thethrillofthefight2.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME