oidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6008883965894107", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7510010972448058"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "154817690767674"}]}, "change_log": "Access remains through the same test account as for version 3.9.8\n\nUser ID: InnoactivePortalMetatest@gmail.com\nPassword: Pleasechange9\n\nThis is on the assumption that password was not changed last time, if you need a new one then please let us know.\n\nIn relation to the previous rejection topics:\n1. Monetization. The app complies with Meta policies, we do not monetize XR content in any form. It is a tool for our customers to upload content to and for them to stream it to the Quest headsets in their fleet. This allows them to access content on the Quest that would previously have been the preserve of PC based VR.\n\n2. Our dev team have improved the frame rate on the app and no longer see any warnings when testing\n\n3. The Boeing demo app is removed. The 2 remaining pieces of content (Pick by Frame & Work at Heights) are purely for the purpose of demoing how the platform works and are not for sale to customers.\n\n4. The privacy policy has been updated to reflect the concern raised in the previous submission. It is available here: https://www.innoactive.io/privacy-policy", "created_date": 1700498070, "id": "6929283287187499", "version": "3.9.10-store", "version_code": 3009010, "release_status": "PENDING", "status": "CHANGES_REQUESTED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}