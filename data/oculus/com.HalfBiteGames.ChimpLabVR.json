tJGX22YVL97Osok4oX4LBouznlDzEwEkA&oe=678270E5"}, {"file_name": "Screenshot_2023-10-29_174217.png", "id": "346421244575935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982705_346421247909268_2388611141235679750_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1MOERyvrAAQ7kNvgEg5yqG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwp1A7GPbfBpfcRhXarG2Y7sJbh1OFzYHW92G67nA2mQ&oe=67826BF5"}, {"file_name": "Screenshot_2023-10-29_174225.png", "id": "6655247577890656", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974499_6655247581223989_60171651874699647_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ElggeYJbAY8Q7kNvgFwOTW5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCibI4ttK084ro3VovfqAD1e9Pvi-ux1JPpw0Lt2R3g2w&oe=67825ED5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Chimplab VR", "keywords": [], "long_description": "Welcome to 'Chimplab,' a bone-chilling virtual reality experience that plunges you into the depths of terror like never before. In this sinister laboratory, the line between the known and the unknown blurs, as you assume the role of a lovably goofy chimp with an extraordinary twist. You were once a simple chimp, but a clandestine experiment has granted you heightened intelligence and, at the same time, unleashed the horrors lurking within this forsaken facility.\n\nAs you navigate the eerie corridors of the lab, your heart will race, and your instincts will kick in as you face grotesque and malevolent chimp mutants that now roam freely. The darkness is your only ally, concealing the secrets hidden behind abandoned equipment and flickering lights. In 'Chimplab,' every footstep echoes ominously, and every door you open may reveal a new nightmare.\n\nYour mission is simple: survive, escape, and uncover the sinister truth behind the experiments that transformed you. You'll need to employ your newfound chimp-like dexterity, solve perplexing puzzles, and muster every ounce of courage to make it out alive. But be warned, the chimp mutants have evolved, becoming more cunning and relentless with every step you take.", "short_description": "Welcome to 'Chimplab,' a bone-chilling virtual reality experience that plunges you into the depths of terror like never before. In this sinister laboratory, the line between the known and the unknown blurs, as you assume the role of a lovably goofy chimp with an extraordinary twist. You were once a simple chimp, but a clandestine experiment has granted you heightened intelligence and, at the same time, unleashed the horrors lurking within this forsaken facility."}]}, "developer_name": "Shiva", "developer_privacy_policy_url": "https://sites.google.com/view/halfbite-games/privacy-policy?authuser=0", "developer_terms_of_service_url": null, "publisher_name": "Shiva", "support_website_url": null, "website_url": "https://sites.google.com/view/halfbite-games/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6708619672579609"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6779070738867835", "version": "0.3"}, "id": "2374946926047838", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false