EQ7kNvgGBxUCg&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDYqbdjV0YsYWlxbgOvhKgJHM94kkm7NHnzcvdIaLiyvw&oe=67811F0F"}, {"file_name": "com.WellsStudios.WellsTaggers-20241101-175810 (1).png", "id": "1549630812590254", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984460_1549630815923587_3757692530628789073_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9oXyjgKtDOAQ7kNvgG4bkz7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCWwW0hCQZK1kN57noP3CTY62pkpl1Cv_tLxliGkxnDlA&oe=67811723"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wells Taggers", "keywords": [], "long_description": "Overview\nWells Taggers is an exhilarating, fast-paced multiplayer game where players engage in the classic playground game of tag within a vibrant, interactive Roblox world. Inspired by the timeless fun of \"Gorilla Tag,\" this game takes the simple concept of tag and elevates it with dynamic environments, diverse characters, and unique abilities.\n\nGameplay\nObjective:\nPlayers are divided into two teams: Taggers and Runners. The Taggers' goal is to chase and tag all the Runners before the timer runs out. Runners must avoid being tagged and use the environment and power-ups to outmaneuver the Taggers.\n\nGame Modes:\n\nClassic Tag: Traditional tag mode where Taggers must tag all Runners to win.\nInfected Tag: Tagged players become Taggers, spreading the infection until only one Runner remains.\nFreeze Tag: Tagged players are frozen in place until a teammate unfreezes them. Taggers win by freezing all players.\nMaps:\n\nUrban Playground: Navigate through a bustling cityscape with rooftops, alleys, and parks.\nEnchanted Forest: A magical forest filled with hiding spots and mystical creatures.\nSpace Station: A futuristic environment with zero-gravity zones and space-themed obstacles.\nPower-Ups:\n\n\n", "short_description": "Overview\nWells Taggers is an exhilarating, fast-paced multiplayer game where players engage in the classic playground game of tag within a vibrant, interactive Roblox world. Inspired by the timeless fun of \"Gorilla Tag,\" this game takes the simple concept of tag and elevates it with dynamic environments, diverse characters, and unique abilities.\n\nGameplay\nObjective:\nPlayers are divided into two teams: Taggers and Runners. The Taggers' goal is to chase and tag all the Runners before the timer."}]}, "developer_name": "Wells_VR", "developer_privacy_policy_url": "https://sites.google.com/view/wellstaggersprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "Wells_VR", "support_website_url": null, "website_url": "https://sites.google.com/view/wellstaggerswebsite/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8897346306993846"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75476593_438242239299197_9140197821919784639_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t10eGoAjQaAQ7kNvgHVb38D&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAT61cbG1KrpEsXd9WAvPBIg0HsQ0C_HWQxGtGqc4VfAA&oe=67812254"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wells Taggers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id"