ps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572940_830763345799411_4192181376620077197_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M9ZFwBY2L1cQ7kNvgHkvGti&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBEz78SV77FMwLNGFXKrA7f1B0rt5u5_DSOuH6s2sSwQ&oe=6746EE7B"}, {"file_name": "zerog5e.png", "id": "1048405573450539", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001714_1048405576783872_3723899864187407035_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bqZLGnyT72MQ7kNvgFoC4nS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBokH1odfU5tp4tvmJQm93tOVXaCtfFxdfYB_tYHCqLkw&oe=674708FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vIDEOcOVETR.png", "id": "8964806610218356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974646_8964806620218355_1338032258312468621_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rvLtwXYj_8EQ7kNvgFNNCn8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8cl1wYdUHTS5yZmwKT3C1mtf6hnip4T7kRUOybVhV3Q&oe=674717EA"}, "display_name": "Banana Company", "keywords": [], "long_description": "Banana.Co is a fun and engaging virtual reality game where players embody bananas in a whimsical world. Inspired by Gorilla Tag mechanics, it offers a lighthearted adventure perfect for those aged 13 and up. We welcome everyone as long as they practice safe gaming.\n\nCommunity Guidelines: Our inclusive community prioritizes enjoyment and respect. A dedicated moderation team ensures a safe and friendly environment.\n\nGameplay Features: Explore imaginative maps, customize your banana with various cosmetics, and engage in creative activities. Players can forge friendships and enjoy lively interactions.\n\nJoin us in Banana.Co for a unique experience that celebrates fun, creativity, and camaraderie in a world of laughter!\n[Yellow44 is watching]", "short_description": "This is a very fun VR game using the gorilla tag loco motion system but you're a banana! So if you want to play a fun funny game where you can bring in your inner banana then play Banana.Co."}]}, "developer_name": "ZaneyGames", "developer_privacy_policy_url": "https://sites.google.com/view/bannacompanyoffical?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Zane2Evil", "support_website_url": null, "website_url": "https://66d7a5532d916.site123.me/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27418109511136613"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003280_1096492131988547_4214927259696477984_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psDJUB0K3DYQ7kNvgH9ijxJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAO7nFHkGztLAkleLMEXoxRgflxfysG4YyGbqDBt9iN6Q&oe=6746FDA8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Banana Company", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1729114140, "lastRevision": {"nodes": [{"id": "27395736396707258", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "27395736353373929", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "p