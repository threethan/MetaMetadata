197_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p4utP7zISugQ7kNvgE6G1LN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq6tcMcmMXrjTQop4okjnhL795ngcqbWahkS_DP71UsA&oe=6720B2FB"}, {"file_name": "zerog5e.png", "id": "1048405573450539", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001714_1048405576783872_3723899864187407035_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JYOpsASMoE4Q7kNvgFr_0de&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBL2-38E6lieSzNeSeRYcD_bLNudjReEwZcntyxqJUzCQ&oe=6720CD7B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vIDEOcOVETR.png", "id": "8964806610218356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974646_8964806620218355_1338032258312468621_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ugGe6ZfNxEQ7kNvgFtysBO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAoOPko4VlXPHdpTpwuEEhqR0NuaQpiUXbxZ83BWoHasA&oe=6720DC6A"}, "display_name": "Banana Company", "keywords": [], "long_description": "Banana.Co is a fun and engaging virtual reality game where players embody bananas in a whimsical world. Inspired by Gorilla Tag mechanics, it offers a lighthearted adventure perfect for those aged 13 and up. We welcome everyone as long as they practice safe gaming.\n\nCommunity Guidelines: Our inclusive community prioritizes enjoyment and respect. A dedicated moderation team ensures a safe and friendly environment.\n\nGameplay Features: Explore imaginative maps, customize your banana with various cosmetics, and engage in creative activities. Players can forge friendships and enjoy lively interactions.\n\nJoin us in Banana.Co for a unique experience that celebrates fun, creativity, and camaraderie in a world of laughter!\n[Yellow44 is watching]", "short_description": "This is a very fun VR game using the gorilla tag loco motion system but you're a banana! So if you want to play a fun funny game where you can bring in your inner banana then play Banana.Co."}]}, "developer_name": "ZaneyGames", "develop