197_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o9D65YCzqvkQ7kNvgEDrTJh&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYB7A7p6TwOTKFzYe5bL3bn6JOlBU5l0JVMh4uFaVbpTrg&oe=671A1B7B"}, {"file_name": "zerog5e.png", "id": "1048405573450539", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39001714_1048405576783872_3723899864187407035_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6L023FlPPeYQ7kNvgGI4QMI&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAPhamdaME3n5X91QfPk0CBQE4drmw__eWPEDjKYWDFDA&oe=671A35FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vIDEOcOVETR.png", "id": "8964806610218356", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974646_8964806620218355_1338032258312468621_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SPdp7G8uE30Q7kNvgHmGo2d&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCpMCbzkW-4swqr9grv2Z5UpsW_Prsp0EpepGZ1LbzG7Q&oe=671A44EA"}, "display_name": "Banana Company", "keywords": [], "long_description": "Banana.Co is a fun and engaging virtual reality game where players embody bananas in a whimsical world. Inspired by Gorilla Tag mechanics, it offers a lighthearted adventure perfect for those aged 13 and up. We welcome everyone as long as they practice safe gaming.\n\nCommunity Guidelines: Our inclusive community prioritizes enjoyment and respect. A dedicated moderation team ensures a safe and friendly environment.\n\nGameplay Features: Explore imaginative maps, customize your banana with various cosmetics, and engage in creative activities. Players can forge friendships and enjoy lively interactions.\n\nJoin us in Banana.Co for a unique experience that celebrates fun, creativity, and camaraderie in a world of laughter!\n[Yellow44 is watching]", "short_description": "This is a very fun VR game using the gorilla tag loco motion system but you're a banana! So if you want to play a fun funny game where you can bring in your inner banana then play Banana.Co."}]}, "developer_name": "ZaneyGames", "develop