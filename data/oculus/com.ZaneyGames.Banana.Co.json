ps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572940_830763345799411_4192181376620077197_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o9D65YCzqvkQ7kNvgGLIiX7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDP5G1HUMRBglMRpPwogkCt0t-iSmNVCc3ETsYx2oQA4g&oe=6718C9FB"}, {"file_name": "zerog5e.png", "id": "1048405573450539", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001714_1048405576783872_3723899864187407035_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6L023FlPPeYQ7kNvgGrierB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4639FEUjYqsNEn29yPFACkJl5uHWXoMVMu2KOktfbHA&oe=6718E47B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vIDEOcOVETR.png", "id": "8964806610218356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974646_8964806620218355_1338032258312468621_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-nCYs0dmcEQ7kNvgGjBZMc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDx7WajEuvo2uyYEeVyx6Lh6Tj87TMpMpq1kMnc4A47AA&oe=6718F36A"}, "display_name": "Banana Company", "keywords": [], "long_description": "Banana.Co is a fun and engaging virtual reality game where players embody bananas in a whimsical world. Inspired by Gorilla Tag mechanics, it offers a lighthearted adventure perfect for those aged 13 and up. We welcome everyone as long as they practice safe gaming.\n\nCommunity Guidelines: Our inclusive community prioritizes enjoyment and respect. A dedicated moderation team ensures a safe and friendly environment.\n\nGameplay Features: Explore imaginative maps, customize your banana with various cosmetics, and engage in creative activities. Players can forge friendships and enjoy lively interactions.\n\nJoin us in Banana.Co for a unique experience that celebrates fun, creativity, and camaraderie in a world of laughter!\n[Yellow44 is watching]", "short_description": "This is a very fun VR game using the gorilla tag loco motion system but you're a banana! So if you want to play a fun funny game where you can bring in your inner banana then play Banana.Co."}]}, "developer_name": "ZaneyGames", "developer_privacy_policy_url": "https://sites.google.com/view/bannacompanyoffical?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Zane2Evil", "support_website_url": null, "website_url": "https://66d7a5532d916.site123.me/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "961172191044986"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27418109511136613"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003280_1096492131988547_4214927259696477984_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NNPkT5a0D-4Q7kNvgE5x83E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrXZdxwvv4mQ04zEQk6pK8bhl7zNxWrnbXetVbey6-KA&oe=6718D928"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Banana Company", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "RPG (Role Playing Games)", "id": "961172191044986"}], "release_date": 1729114140, "lastRevision": {"nodes": [{"id": "27395736396707258", "release_type": "SCHEDULED", "administration_stat