overt is a cooperative heist game where you and a friend work together to pull off the heist of a century."}]}, "developer_name": "White Elk LLC", "developer_privacy_policy_url": "http://whiteelkstudios.com/index.php/privacy/", "developer_terms_of_service_url": "http://whiteelkstudios.com/index.php/privacy/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://thecovertgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2720827291556251"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "311056959495809"}, {"status": "PUBLISHED", "id": "271645033526663"}, {"status": "PUBLISHED", "id": "291561038180641"}, {"status": "PUBLISHED", "id": "413772986033040"}, {"status": "PUBLISHED", "id": "384314225626030"}, {"status": "PUBLISHED", "id": "649827842093917"}, {"status": "PUBLISHED", "id": "445581909533454"}, {"status": "PUBLISHED", "id": "2112640855713654"}, {"status": "PUBLISHED", "id": "413037712668542"}, {"status": "PUBLISHED", "id": "2195178844086605"}]}, "baseline_offer": {"id": "2195178844086605"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1542873600, "status": "PUBLISHED", "id": "311056959495809"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2809867032420710", "version": "1.1.3"}, "id": "229008304439273", "channel_name": "LIVE"}]}, "is_for_oculus_keys_onl