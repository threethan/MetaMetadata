73457130109927424_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eXI_e_JAyk0Q7kNvgGQ0985&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBj1EpscuD2E2ae4DAObQcRv4AMzfGRip83IXF9q9xYXQ&oe=6720CE5F"}, {"file_name": "migrated_image.png", "id": "247460932948909", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974836_336366803585011_7366122813926670336_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2y86TSEyXGAQ7kNvgHA-yJ2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBiTbjlJ0SO3vGKciUkUrBYMvogIo7UkI0dpTOaZWyomQ&oe=6720E4A3"}, {"file_name": "migrated_image.png", "id": "207202277197797", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974447_2101040860225378_8310325426392137728_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JiQZgtKQSAUQ7kNvgGd2Jgg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn8Wb5llAl7_UTQmir5ZIYS9HHMwnYnEE8FQ-7acZiYA&oe=6720D1A1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Covert", "keywords": ["covert", "heist", "coop", "hacker", "stealth"], "long_description": "\u2022\u2022\u2022NOTE\u2022\u2022\u2022 Please make sure you have a device that is fully compatible with the companion app - Supports Android 7.0 - iOS 6 & above.\n\nRecruited by a mysterious client, you & a partner take on a series of high-profile heists. Utilize gadgets to infiltrate heavily guarded facilities as the crafty Thief in VR. Breach through security systems as the clever Hacker on a mobile device.  Cooperation & trust will be needed to sneak past guards, hack through laser grids, crack safes, & much more\u2026\n\nTeam up & pull off the heist of the century!\n\nFeatures:\n6+ hours of gameplay\nCooperative: A successful heist cannot be achieved alone!\nAsymmetric gameplay: Experience the heist as The Thief in VR, or as The Hacker on a mobile device\nCompanion app: Free! Only the VR app requires purchase\nOnline: Play with your friends & family from anywhere\nPass-and-play: Introduce your friends & family to the unique & immersive experience of VR, while putting your stealth, communication, & trust to the test!", "short_description": "Covert is a cooperative heist game where you and a friend work together to pull off the heist of a century."}]}, "developer_name": "White Elk LLC", "developer_privacy_policy_url": "http://whiteelkstudios.com/index.php/privacy/", "developer_terms_of_service_url": "http://whiteelkstudios.com/index.php/terms-of-service/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://thecovertgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "470227511229240"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974653_257272078527628_6430438023552303104_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WzFYbla8dMkQ7kNvgFGmRwr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdHfepc9yUbYARE3Ryk7cPXdEoo1SW1GzRoETHZnOSOw&oe=6720D80D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Covert", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1542304800, "lastRevision": {"nodes": [{"id": "1986489521414198", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2108210925919661", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "A