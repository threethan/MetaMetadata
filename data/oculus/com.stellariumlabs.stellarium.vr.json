om/v/t64.5771-25/38984445_795106512373494_8755154068071746895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZngHisSIBxcQ7kNvgHx_k0z&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYClo4bRvaNVCeZrCbQqfHgvUi1V0vOu5MX5YXgzOYehlQ&oe=6787AA97"}, {"file_name": "screenshot-oculus-sky.png", "id": "312378328289673", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39035472_312378331623006_2826745704380686642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ps2EAnhZJ7wQ7kNvgGnEzsI&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAOgZVhGGs2ei2rXCR-ztVfOvDTbNlfSTh-20xM5pGcdA&oe=67879B61"}, {"file_name": "screenshot-oculus-infos.png", "id": "5258432357613826", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031528_5258432364280492_6464416999568491607_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CtGj8rreUfcQ7kNvgFaVIcn&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBT6XoDP_wwptsdC_T9hcDpyP4c8p5Ppdd8K3Wumj7PVg&oe=6787872B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-01-10-18h03m50s692.png", "id": "1354737558748315", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031541_1354737562081648_7100547001598281103_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p7mO7Ro3OakQ7kNvgE9RxKO&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDAGXkDpll6v7nZMOQ18SeyJ2gxO4SsC3_Q-HtOlTDxYw&oe=6787B002"}, "display_name": "Stellarium VR", "keywords": [], "long_description": "Identify stars, constellations, planets, satellites (such as the ISS), and other deep sky objects in real time in the sky above you.\n\n- View an accurate night sky simulation of stars and planets for any date, time and location.\n\n- Dive in a collection of many stars, nebulas, galaxies, star clusters and other deep sky objects.\n\n- Zoom on realistic Milky Way and Deep Sky Objects images.\n\n- Discover how people living in other regions of the planet see the stars by selecting the shapes and illustrations of the constellations for many sky cultures.\n\n- Track artificial satellites, including the International Space Station.\n\n- Simulate landscape and atmosphere with realistic sunrise, sunset and atmosphere refraction.\n\n- Discover 3D rendering of the major solar system planets and their satellites.\n\nStellarium VR is made by the original creator of Stellarium, the well known open source planetarium on Desktop PC.", "short_description": "Stellarium VR is a planetarium that shows exactly what you see when you look up at the stars."}]}, "developer_name": null, "developer_privacy_policy_url": "https://stellarium-labs.com/privacy-policy-for-stellarium-vr", "developer_terms_of_service_url": null, "publisher_name": "Stellarium Labs", "support_website_url": "https://www.stellarium-labs.com/contact-us/", "website_url": "https://www.stellarium-labs.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6836812049777835"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "4032799253622528"}, {"status": "PUBLISHED", "id": "1104367044601473"}, {"status": "PUBLISHED", "id": "895537098668755"}, {"status": "PUBLISHED", "id": "362632513585665"}, {"status": "PUBLISHED", "id": "388392270391572"}]}, "baseline_offer": {"id": "388392270391572"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1738004400, "status": "PUBLISHED", "id": "4032799253622528"}]