k0xso23fl9NCCA&oe=66E97F08"}, {"file_name": "screenshot-oculus-phobos.png", "id": "795106509040161", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984445_795106512373494_8755154068071746895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1VzAe80dt5EQ7kNvgFT2vtC&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARLCEApoXr_M-ZoeTXmUSzR&oh=00_AYBok5gZ9uaDSLKfURjiZEIY-8Y8-73TQv449r11ceXZGA&oe=66E97697"}, {"file_name": "screenshot-oculus-sky.png", "id": "312378328289673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035472_312378331623006_2826745704380686642_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IcBgXG0VxQwQ7kNvgGnVvM7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARLCEApoXr_M-ZoeTXmUSzR&oh=00_AYAcoAkhmSFIJ48vJW5wrH0hv6Dpps-zhI-WGYZW4ImILw&oe=66E96761"}, {"file_name": "screenshot-oculus-infos.png", "id": "5258432357613826", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031528_5258432364280492_6464416999568491607_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kLdXgIu0Ka4Q7kNvgGX_i6n&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARLCEApoXr_M-ZoeTXmUSzR&oh=00_AYB53mfB0TwWUaYCqaakkN_vQzYypZ4bFubbP-qAS9FOqA&oe=66E9532B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-01-10-18h03m50s692.png", "id": "1354737558748315", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031541_1354737562081648_7100547001598281103_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5vs7lt4lJhYQ7kNvgH0EGVa&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARLCEApoXr_M-ZoeTXmUSzR&oh=00_AYBg1IOKmQPit3m3pOqZSO8A63A9YybTeb2YSq6oQ000Pg&oe=66E97C02"}, "display_name": "Stellarium VR", "keywords": [], "long_description": "Identify stars, constellations, planets, satellites (such as the ISS), and other deep sky objects in real time in the sky above you.\n\n- View an accurate night sky simulation of stars and planets for any date, time and location.\n\n- Dive in a collection of many stars, nebulas, galaxies, star clusters and other deep sky objects.\n\n- Zoom on realistic Milky Way and Deep Sky Objects images.\n\n- Discover how people living in other regions of the planet see the stars by selecting the shapes and illustrations of the constellations for many sky cultures.\n\n- Track artificial satellites, including the International Space Station.\n\n- Simulate landscape and atmosphere with realistic sunrise, sunset and atmosphere refraction.\n\n- Discover 3D rendering of the major solar system planets and their satellites.\n\nStellarium VR is made by the original creator of Stellarium, the well known open source planetarium on Desktop PC.", "short_description": "Stellarium VR is a planetarium that shows exactly what you see when you look up at the stars."}]}, "developer_name": null, "developer_privacy_policy_url": "https://stellarium-labs.com/privacy-policy-for-stellarium-vr", "developer_terms_of_service_url": null, "publisher_name": "Stellarium Labs", "support_website_url": "https://www.stellarium-labs.com/contact-us/", "website_url": "https://www.stellarium-labs.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6836812049777835"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "362632513585665"}, {"status": "PUBLISHED", "id": "388392270391572"}]}, "baseline_offer": {"id": "388392270391572"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED