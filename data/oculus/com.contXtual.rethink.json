dn.com/v/t64.5771-25/39036667_1114358712697101_709184002875007329_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gbI2QBb7am4Q7kNvgF49O1V&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBvPQmNmypPCYh5ijc4DwO-zd5P_D8c_A0MAoXqwUXdcw&oe=6728A37D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "710611507097881", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974549_710611510431214_2744730596441595896_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cLhqjUciNT0Q7kNvgG-dHvZ&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCVFscL6znNhyqu3KdMxdAxobH7wRYv336FKXkTDbO8lQ&oe=6728B4AC"}, "display_name": "RETHINK", "keywords": [], "long_description": "RETHINK harnesses the power of human connection to bring creatives, thinkers and innovators together to get work done. Designed to unleash creative ideas, enable flow state & reduce time to iteration, RETHINK supercharges creative collaboration, brainstorms, workshops, presentations, and product reviews.\n\nPersistent spaces. Share creative, collaborate, and capture feedback with on and off-site teams and clients. Immersive ideation and design thinking tools enabling hyperfocus and flow state.", "short_description": "RETHINK harnesses the power of human connection to bring creatives, thinkers and innovators together to get work done. Designed to unleash creative ideas, enable flow state & reduce time to iteration, RETHINK supercharges creative collaboration, brainstorms, workshops, presentations, and product reviews.\n\nPersistent spaces. Share creative, collaborate, and capture feedback with on and off-site teams and clients. Immersive ideation and design thinking tools enabling hyperfocus and flow state."}]}, "developer_name": null, "developer_privacy_policy_url": "https://getrethink.com/Legal/Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "reTHINK: by contXtual", "support_website_url": null, "website_url": "https://www.getrethink.