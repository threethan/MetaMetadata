png", "id": "581194047356315", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75241698_581194050689648_8505522211629746230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VtHHUKoWYjcQ7kNvgGRlF7_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDX4GMUPwd7WxiQ_JHatWbcvrRhuc6CEwt0k-j0Ne4Peg&oe=673C946A"}, {"file_name": "SS4 2560x1440.png", "id": "893415995117898", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75245822_893415998451231_7980186069490287141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WN_LIpv47KYQ7kNvgG7rTHY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwxYUrBnoBrb2LZ5zkToJM9c4PlVSaVQ85utzAf8RyuQ&oe=673C8020"}, {"file_name": "SS5 2560x1440.png", "id": "1944031919266874", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003253_1944031929266873_2451649239643841108_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzKmX4quROgQ7kNvgEfdcE5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHVioJTkMsBQjYwaRoBm0NMzVH-sW06LcBFJyVC5Nt6A&oe=673C8F89"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Art Gallery VR", "keywords": [], "long_description": "The Art Gallery VR is a one-of-a-kind virtual reality experience that takes art lovers on a journey through the world of Pierre-Auguste Renoir. This app transports users to a stunningly designed virtual art gallery, where they can explore Renoir's iconic paintings up close and personal. From the comfort of their own home, users will be transported to a space that feels like a real art gallery, complete with the sounds and ambiance of a traditional museum.\n\nWhether you're an art lover, an admirer of Renoir's work, or simply looking for a unique and immersive experience, this app is a must-try. With its stunning visuals and interactive content, this app is sure to delight and engage users of all ages. So, get ready to step into the world of Impressionism and experience the beauty of Renoir's paintings like never before!", "short_description": "The Art Gallery VR is an immersive virtual reality experience that transports you to a beautifully crafted art gallery displaying the masterpieces of Pierre-Auguste Renoir. You can explore the gallery at your own pace, viewing the paintings up close and personal. With the VR headset on, you will feel as if you are actually standing in front of Renoir's iconic pieces."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thelonelydeveloper.net/the-art-gallery-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "The Lonely Developer", "support_website_url": null, "website_url": "https://thelonelydeveloper.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4549429955181619"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "3659115881006484"}, {"status": "PUBLISHED", "id": "1061557648342852"}, {"status": "PUBLISHED", "id": "514353940846148"}, {"status": "PUBLISHED", "id": "1296888984317553"}]}, "baseline_offer": {"id": "3659115881006484"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724188320, "status": "PUBLISHED", "id": "3659115881006484"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6293962333968724", "version": "6"}, "id": "701659171492623", "channel_name": "LIVE"}]},