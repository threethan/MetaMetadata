75241698_581194050689648_8505522211629746230_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5edHbGgROxQQ7kNvgGQLD1T&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYANcoXxHQEeuHbVbci9uJgmBJOw1XtyPh3SMG13Yt4_DA&oe=671112EA"}, {"file_name": "SS4 2560x1440.png", "id": "893415995117898", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75245822_893415998451231_7980186069490287141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cpQ4YTcWcYEQ7kNvgHZJ3KM&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD2c_MSBMPOmCLu3oDE1cRsqfXZP4V3jFnrqESHxjfWkg&oe=6710FEA0"}, {"file_name": "SS5 2560x1440.png", "id": "1944031919266874", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003253_1944031929266873_2451649239643841108_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e0iuOZJy8_4Q7kNvgEZmGHc&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCGWa-LD-qoyn3jMOiVZmcWtXBDOkKn3NCKWtguLsDudw&oe=67110E09"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Art Gallery VR", "keywords": [], "long_description": "The Art Gallery VR is a one-of-a-kind virtual reality experience that takes art lovers on a journey through the world of Pierre-Auguste Renoir. This app transports users to a stunningly designed virtual art gallery, where they can explore Renoir's iconic paintings up close and personal. From the comfort of their own home, users will be transported to a space that feels like a real art gallery, complete with the sounds and ambiance of a traditional museum.\n\nWhether you're an art lover, an admirer of Renoir's work, or simply looking for a unique and immersive experience, this app is a must-try. With its stunning visuals and interactive content, this app is sure to delight and engage users of all ages. So, get ready to step into the world of Impressionism and experience the beauty of Renoir's paintings like never before!", "short_description": "The Art Gallery VR is an immersive virtual reality experience that transports you to a beautifully crafted art gallery displaying the masterpieces of Pierre-Auguste Renoir. You can explore the gallery at your own pace, viewing the paintings up close and personal. With the VR headset on, you will feel as if you are actually standing in front of Renoir's iconic pieces."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thelonelydeveloper.net/the-art-gallery-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "The Lonely Developer", "support_website_url": null, "website_url": "https://thelonelydeveloper.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4549429955181619"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "3659115881006484"}, {"status": "PUBLISHED", "id": "1061557648342852"}, {"status": "PUBLISHED", "id": "514353940846148"}, {"status": "PUBLISHED", "id": "1296888984317553"}]}, "baseline_offer": {"id": "3659115881006484"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724188320, "status": "PUBLISHED", "id": "3659115881006484"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6293962333968724", "version": "6"}, "id": "701659171492623", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "An