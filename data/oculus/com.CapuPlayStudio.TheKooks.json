815878_1152504309175678_8185601224155798434_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PMQSTG_CnXAQ7kNvgEZPUqv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACM1dJEDZOkMM-YFDoAYW3-&oh=00_AYCPa_AarWMIaAJ9vgLJTLbfHHwF-FgVWkv-F4zp76wfSQ&oe=66F13656"}, {"file_name": "Untitled Project (83).png", "id": "863476979076923", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974574_863476982410256_4912669286032729521_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IXX_iVnytuwQ7kNvgHKX-m8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACM1dJEDZOkMM-YFDoAYW3-&oh=00_AYCW_HsqalZVU-LKLQQ0mcrRHkn3BaJm0YIf0cNL5vriWA&oe=66F13BF2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Kookys: Lost In The Abyss", "keywords": ["Kooky", "TheKookys", "HORROR"], "long_description": "The Kookys...\n\nWARNING: This game contains Blood, Gore, Suicide.\n\nStory Mode\n\nAs the mystery deepens, it's crucial to find out what lies behind the old Kooky Labs. Staff members who dared to venture into the depths of the abandoned facility have gone missing without a trace. The truth behind their disappearances is buried within the dark corridors, where an unsettling presence seems to lurk.\n\nWhat really happened in the old lab? Why was it shut down, and what secrets were left behind? Uncovering the truth might be the only way to understand the strange occurrences in the new facility above.\n\nBut be warned\u2014whatever you find could change everything. If you proceed, be prepared to face the consequences of the dark history that continues to haunt Kooky Labs.\n\nMultiplayer\n\nWe have/will have\nOnly Up\nTag\nHorror\nShop\nZero Gravity\nChill Room\nRacing\nPVP\nParkour\n\n\n\nBe funni, Be Kooky, But NEVER be a Skibidi Toxic Non-Sigma rizzy bear!", "short_description": "The Kookys...\nA gorilla tag fan game which has a series of Gamemodes and Lots of fun and horror is now released to the public...\n\nWe have/will have\nOnly Up\nTag\nHorror\nShop\nZero Gravity\nChill Room\nRacing\nStoryMode\n\nPlease follow the rules and have a great time"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/kookymonkesprivacypolicy", "developer_terms_of_service_url": "https://docs.google.com/document/d/1Om0eZrnqTKwgOZsmUswq1kA8Rb795LX04UUf41gsbLE/edit?usp=sharing", "publisher_name": "CapuPlay", "support_website_url": null, "website_url": "https://sites.google.com/view/capuweb", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7993740664081036"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974700_517118660810629_3874749448060938140_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w8rEShhlOrIQ7kNvgEsOK7W&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACM1dJEDZOkMM-YFDoAYW3-&oh=00_AYC7CLS85Tev-3ZEA11I_uFXgSczHPNPh11f7fUqh2G9lg&oe=66F15886"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Kookys: Lost In The Abyss", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1721407404, "lastRevision": {"no