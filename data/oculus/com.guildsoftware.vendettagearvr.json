s in a vast universe. Users may build their characters in any direction they desire, becoming rich captains of industry, military heroes, or outlaws. A fast-paced, realtime \"twitch\" style combat model gives intense action, coupled with the backdrop of RPG gameplay in a massive online galaxy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vendetta-online.com/h/privacy.html", "developer_terms_of_service_url": "https://www.vendetta-online.com/h/eula.html", "publisher_name": "Guild Software, Inc.", "support_website_url": null, "website_url": "https://www.vendetta-online.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["RPG", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "305886778256030"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162801_825723877575675_3875057891182379008_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qk5zxrVPu6IQ7kNvgEDPyr5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVWYvYUHbUAwrJMAd-LCveh&oh=00_AYCvgf2gHhAPVktlChxFPayQaT9lwAhHjFv1FeTreX1ARA&oe=66E55DFB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Vendetta Online VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1476860400, "lastRevision": {"nodes": [{"id": "424241577699870", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "115924403414343