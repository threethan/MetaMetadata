3309791_457548879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mr7fuBoFVs8Q7kNvgFPnEyw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9k9qBOPyu1dmNf686sH0u3xjJMkvHzvt6S8kvB7fszg&oe=677A8346"}, {"file_name": "migrated_image.png", "id": "239870640385792", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12533746_1088554031181786_1963803798_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSC2qYG0G3oQ7kNvgEGKRPG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3Nl4u_UaRtITzPEAgXTfumoQ87oKzo5PfTzZkktC5SQ&oe=677A6979"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Vendetta Online VR", "keywords": ["space", "mmo", "mmorpg", "shooter", "vendetta"], "long_description": "Vendetta Online is a cross-platform 3D space combat MMORPG, allowing thousands of players to interact as the pilots of spaceships in a vast universe. Users may build their characters in any direction they desire, becoming rich captains of industry, military heroes, or outlaws. A fast-paced, realtime \"twitch\" style combat model gives intense action, coupled with the backdrop of RPG gameplay in a massive online galaxy. Three major player factions form a delicate balance of power, with several NPC sub-factions creating situations of economic struggle, political intrigue and conflict. The completely persistent universe and detailed storyline add to the depth of immersion, resulting in a unique online experience.\n\n- Integrated voice chat, Speech Recognition, gamepad support.\n- Vendetta Online for GearVR is Free To Play, with optional purchases to accelerate or unlock certain benefits. There is a level cap for Free users, but it usually takes weeks to reach. We plan to remove the level cap.", "short_description": "Vendetta Online is a cross-platform 3D space combat MMORPG, allowing thousands of players to interact as the pilots of spaceships in a vast universe. Users may build their characters in any direction they desire, becoming rich captains of industry, military heroes, or outlaws. A fast-paced, realtime \"twitch\" style combat model gives intense action, coupled with the backdrop of RPG gameplay in a massive online galaxy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vendetta-online.com/h/privacy.html", "developer_terms_of_service_url": "https://www.vendetta-online.com/h/eula.html", "publisher_name": "Guild Software, Inc.", "support_website_url": null, "website_url": "https://www.vendetta-online.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["RPG", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "305886778256030"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162801_825723877575675_3875057891182379008_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uawApdj4E3kQ7kNvgE32CS8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiv1JUHrz5scCO2wm7O0UpPMmjZ4bjWiea8Znd4cvtFg&oe=677A577B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Vendetta Online VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1476860400, "lastRevision": {"nodes": [{"id": "424241577699870", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1159244034143439", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "i