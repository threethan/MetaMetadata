27123309791_457548879_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u4JRPub5gP0Q7kNvgG8pWYe&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAUayR929AYbvGuiEXNYv0MmDA2WskhBM5GY7IlGCBgJA&oe=6728C646"}, {"file_name": "migrated_image.png", "id": "239870640385792", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/12533746_1088554031181786_1963803798_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Cm59yJ6uK4Q7kNvgFOLPfm&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAsY-9L_iU2lsHwjAAQ-9zY9e2AYw1-IoFyBVZoGDM2Ww&oe=6728AC79"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Vendetta Online VR", "keywords": ["space", "mmo", "mmorpg", "shooter", "vendetta"], "long_description": "Vendetta Online is a cross-platform 3D space combat MMORPG, allowing thousands of players to interact as the pilots of spaceships in a vast universe. Users may build their characters in any direction they desire, becoming rich captains of industry, military heroes, or outlaws. A fast-paced, realtime \"twitch\" style combat model gives intense action, coupled with the backdrop of RPG gameplay in a massive online galaxy. Three major player factions form a delicate balance of power, with several NPC sub-factions creating situations of economic struggle, political intrigue and conflict. The completely persistent universe and detailed storyline add to the depth of immersion, resulting in a unique online experience.\n\n- Integrated voice chat, Speech Recognition, gamepad support.\n- Vendetta Online for GearVR is Free To Play, with optional purchases to accelerate or unlock certain benefits. There is a level cap for Free users, but it usually takes weeks to reach. We plan to remove the level cap.", "short_description": "Vendetta Online is a cross-platform 3D space combat MMORPG, allowing thousands of players to interact as the pilots of spaceships in a vast universe. Users may build their characters in any direction they desire, becoming rich captains of industry, military heroes, or outlaws. A fast-paced, realtime \"twitch\" style combat model gives intense action, coupled with the backdrop of RPG gameplay in a massive online galaxy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vendetta-online.com/h/privacy.html", "developer_terms_of_service_url": "https://www.vendetta-online.com/h/eula.html", "publisher_name": "Guild Software, Inc.", "support_website_url": null, "website_url": "https://www.vendetta-online.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["RPG", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "305886778256030"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/11162801_825723877575675_3875057891182379008_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ch7ZtYsCvq8Q7kNvgHTXdbU&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAfmp3JzUII4RiWwqeXP_pW-4ToBgp6qE5gvuw1LHELGQ&oe=67289A7B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Vendetta Online VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1476860400, "lastRevision": {"nodes": [{"id": "424241577699870", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1159244034143439", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": n