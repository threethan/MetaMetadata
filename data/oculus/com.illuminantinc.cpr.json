32WQ3hRZ_aKAkpwWvh3kffZGK6MVA6blmlYH14A&oe=670F9A45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_021_0000.png", "id": "544033911331106", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035304_544033914664439_4283417437674977072_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4FN3cjl930sQ7kNvgHydvhx&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBG8yNWpJZp_l-Wpn6Nxd_zK3zeXML8ALVEJjJ9lLjcyA&oe=670FB89B"}, "display_name": "Illuminant CPR", "keywords": ["training", "medical", "cpr", "gaming", "casual"], "long_description": "**Illuminant CPR Training**\n\n\n\nMaster life-saving skills with Illuminant CPR Training, the ultimate VR experience for learning CPR and BLS based on AHA (American Heart Association) guidelines.\n\nKey Features:\n\n\n\n- **AHA Guidelines-Based Training:** Follow expert instructions based on the latest American Heart Association guidelines to ensure you're learning the most effective techniques.\n- **Immersive Virtual Hospital:** Train in a realistic hospital environment, providing a true-to-life experience.\n- **Hand Tracking Technology:** Perform chest compressions and interact with equipment seamlessly using hand tracking.\n- **Physical and Virtual Patient Modes:** Choose between aligning a physical CPR dummy with the virtual patient for authentic resistance and feedback or use the virtual patient mode, where no physical dummy is required.\n- **Mistake Tracking:** Receive detailed feedback on your performance, with a log of all mistakes and the times they were made, helping you improve with each session.\n- **Real World Mode:** Challenge yourself in Real World Mode, where you'll have to save the patient without any assistance or instruction, testing your skills in a high-pressure scenario.\n\n\nWhether you're a healthcare professional or a concerned citizen, Illuminant CPR Training offers an engaging and effective way to master essential CPR skills. Download now and be prepared to save lives with confidence!", "short_description": "Learn life saving skills!"}]}, "developer_name": "Illuminant Inc", "developer_privacy_policy_url": "https://illuminantincvr.wixsite.com/mysite/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Illuminant Inc", "support_website_url": null, "website_url": "https://illuminantincvr.wixsite.com/mysite", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27883433237922048"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75532179_2243994545965139_8307922738287996140_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hO0uI132ocAQ7kNvgH_7fX5&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCBJix6vPYSVz_j1kCbe38nChiDiqdJGlZyiNjNCbwnqw&oe=670F9C80"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Illuminant CPR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}], "release_date": 1726680720, "lastRevision": {"nodes": [{"id": "27607215908877117", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "27607215812210460", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform