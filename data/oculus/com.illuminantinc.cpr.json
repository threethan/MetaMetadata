uscdn.com/v/t64.5771-25/39031348_1263919934965691_805118127311952490_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eVUcgH5QCj0Q7kNvgFxbf_R&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCZRfHqvZXayRO6totDezuuafl9XW1Z9FNgvu94eqnkQA&oe=672B4DC6"}, {"file_name": "image_009_0000.png", "id": "819087513411949", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569446_819087516745282_8610873754496928773_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qYc0yPFnyyAQ7kNvgGHIlsd&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCv9grHJ6_CASlkKUtqoAfJ6EE_EPidus8SRkVFYauFqQ&oe=672B3C94"}, {"file_name": "image_016_0000.png", "id": "433995429689105", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982570_433995433022438_1323499070480054407_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zT3He0k0S1kQ7kNvgG0ZrRm&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBLU6YIzPXddcec9OQ7rjfE37sReU0kLQScdAQIvPEf_Q&oe=672B49C5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Illuminant CPR", "keywords": ["training", "medical", "cpr", "gaming", "casual"], "long_description": "**Illuminant CPR Training**\n\n\n\nMaster life-saving skills with Illuminant CPR Training, the ultimate VR experience for learning CPR and BLS based on AHA (American Heart Association) guidelines.\n\nKey Features:\n\n\n\n- **AHA Guidelines-Based Training:** Follow expert instructions based on the latest American Heart Association guidelines to ensure you're learning the most effective techniques.\n- **Immersive Virtual Hospital:** Train in a realistic hospital environment, providing a true-to-life experience.\n- **Hand Tracking Technology:** Perform chest compressions and interact with equipment seamlessly using hand tracking.\n- **Physical and Virtual Patient Modes:** Choose between aligning a physical CPR dummy with the virtual patient for authentic resistance and feedback or use the virtual patient mode, where no physical dummy is required.\n- **Mistake Tracking:** Receive detailed feedback on your performance, with a log of all mistakes and the times they were made, helping you improve with each session.\n- **Real World Mode:** Challenge yourself in Real World Mode, where you'll have to save the patient without any assistance or instruction, testing your skills in a high-pressure scenario.\n\n\nWhether you're a healthcare professional or a concerned citizen, Illuminant CPR Training offers an engaging and effective way to master essential CPR skills. Download now and be prepared to save lives with confidence!", "short_description": "Learn life saving skills!"}]}, "developer_name": "Illuminant Inc", "developer_privacy_policy_url": "https://illuminantincvr.wixsite.com/mysite/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Illuminant Inc", "support_website_url": null, "website_url": "https://illuminantincvr.wixsite.com/mysite", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27659109213687786"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "489533950659066"}]}, "baseline_offer": {"id": "489533950659066"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726680720, "status": "PUBLISHED", "id": "489533950659066"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test