h=00_AYD3NYrUBGX5EpR5KrjuZPBOR72fTE-4TyeMF_JNuXn56g&oe=66F2B2F5"}, {"file_name": "image_021_0000.png", "id": "1263919931632358", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031348_1263919934965691_805118127311952490_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGP3PXfjqz4Q7kNvgHOv1tB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahh0M7QDdGrcTcyHQd3EtKr&oh=00_AYD-2yDHwd4XJqxRWx_j467oHxM5YTtAOUIvRCPfxi2QqQ&oe=66F29D46"}, {"file_name": "image_009_0000.png", "id": "819087513411949", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569446_819087516745282_8610873754496928773_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-cYvIde-oBwQ7kNvgH4AZ9z&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahh0M7QDdGrcTcyHQd3EtKr&oh=00_AYBJ9HJWna6XE45VmVcUt5102lxZS_Glzg3GRHdyjv2KFg&oe=66F28C14"}, {"file_name": "image_016_0000.png", "id": "433995429689105", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982570_433995433022438_1323499070480054407_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_O24dnzgHzIQ7kNvgFt-N0x&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahh0M7QDdGrcTcyHQd3EtKr&oh=00_AYDIYs-8NLn0sc4jGnwsCRTXu0qxF_Fkd9lJL2sW8ho5GA&oe=66F29945"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Illuminant CPR", "keywords": ["training", "medical", "cpr", "gaming", "casual"], "long_description": "**Illuminant CPR Training**\n\n\n\nMaster life-saving skills with Illuminant CPR Training, the ultimate VR experience for learning CPR and BLS based on AHA (American Heart Association) guidelines.\n\nKey Features:\n\n\n\n- **AHA Guidelines-Based Training:** Follow expert instructions based on the latest American Heart Association guidelines to ensure you're learning the most effective techniques.\n- **Immersive Virtual Hospital:** Train in a realistic hospital environment, providing a true-to-life experience.\n- **Hand Tracking Technology:** Perform chest compressions and interact with equipment seamlessly using hand tracking.\n- **Physical and Virtual Patient Modes:** Choose between aligning a physical CPR dummy with the virtual patient for authentic resistance and feedback or use the virtual patient mode, where no physical dummy is required.\n- **Mistake Tracking:** Receive detailed feedback on your performance, with a log of all mistakes and the times they were made, helping you improve with each session.\n- **Real World Mode:** Challenge yourself in Real World Mode, where you'll have to save the patient without any assistance or instruction, testing your skills in a high-pressure scenario.\n\n\nWhether you're a healthcare professional or a concerned citizen, Illuminant CPR Training offers an engaging and effective way to master essential CPR skills. Download now and be prepared to save lives with confidence!", "short_description": "Learn life saving skills!"}]}, "developer_name": "Illuminant Inc", "developer_privacy_policy_url": "https://illuminantincvr.wixsite.com/mysite/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Illuminant Inc", "support_website_url": null, "website_url": "https://illuminantincvr.wixsite.com/mysite", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27659109213687786"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "489533950659066"}]}, "baseline_offer": {"id": "489533950659066"}, "is_approved": true, "firstOffer": {"nodes": [{"start_t