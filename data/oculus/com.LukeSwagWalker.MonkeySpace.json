t=scontent-ams4-1.oculuscdn.com&oh=00_AYD2vx1trASEb6r8wMF9Z7ntObcncaWqz0yA9x7azkWO8g&oe=67811EAA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monkey Space", "keywords": ["Build", "Social", "Creative", "Fun", "FanGame"], "long_description": "Monkey Space is a fan game that combines the creative building mechanics of Minecraft with a hand based locomotion system.\n\nWhat To Do?!\nThere is no goal in this game just build stuff like in Minecraft creative mode. You can build monkey launchers with the fan block, or anti gravity globes with the space block and glass. And trust me it is so much more fun with other people so invite your friends to play as well.\n\nPlease if you have ANY feed back, put it in the discord or email it to me.", "short_description": "Monkey Space is a fan game that combines the creative building mechanics of Minecraft with a hand based locomotion system.\n\nWhat To Do?!\nThere is no goal in this game just build stuff like in Minecraft creative mode. You can build monkey launchers with the fan block, or anti gravity globes with the space block and glass. And trust me it is so much more fun with other people so invite your friends to play as well.\n\nPlease if you have ANY feed back, put it in the discord or email it to me."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/9717cec5-fd86-432a-ab3a-ec8a1c993eab", "developer_terms_of_service_url": null, "publisher_name": "LukeSwagWalker", "support_website_url": null, "website_url": "https://docs.google.com/document/d/1TSX42uHNHcKdPgUfM4k1Ar6vLe9Gzu8hGVhFzK_IoC8/pub", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_grap