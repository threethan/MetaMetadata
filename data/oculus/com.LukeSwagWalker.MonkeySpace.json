ame_Custom..._19.09.2024_16-43-17.png", "id": "823277980005322", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035428_823277986671988_6030168098621021744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2BQ_jb5Mnn4Q7kNvgGnoGDE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHJZbXcUNOL1uUc8K_e1Qo3FoQ3g0fwWCti5sbKg8yCw&oe=6706832A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monkey Space", "keywords": ["Build", "Social", "Creative", "Fun", "FanGame"], "long_description": "Monkey Space is a fan game that combines the creative freedom of placing blocks with a physical, hand based locomotion system. In this multiplayer VR game, players can build by placing blocks while moving through the environment using a unique hand based movement mechanic. The game focuses on providing a fun, interactive space where players can join together online and create structures while moving energetically with this immersive locomotion system. With simple block placing mechanics, the game emphasizes creativity and physical activity in an open online environment.", "short_description": "Monkey Space is a fan game that combines the creative building mechanics of Minecraft with a hand based locomotion system."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/9717cec5-fd86-432a-ab3a-ec8a1c993eab", "developer_terms_of_service_url": null, "publisher_name": "LukeSwagWalker", "support_website_url": null, "website_url": "https://docs.google.com/document/d/1TSX42uHNHcKdPgUfM4k1Ar6vLe9Gzu8hGVhFzK_IoC8/pub", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "r