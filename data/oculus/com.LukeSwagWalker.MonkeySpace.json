il": null, "display_name": "Monkey Space", "keywords": ["Build", "Social", "Creative", "Fun", "FanGame"], "long_description": "Monkey Space is a fan game that combines the creative freedom of placing blocks with a physical, hand based locomotion system. In this multiplayer VR game, players can build by placing blocks while moving through the environment using a unique hand based movement mechanic. The game focuses on providing a fun, interactive space where players can join together online and create structures while moving energetically with this immersive locomotion system. With simple block placing mechanics, the game emphasizes creativity and physical activity in an open online environment.", "short_description": "Monkey Space is a fan game that combines the creative building mechanics of Minecraft with a hand based locomotion system."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/9717cec5-fd86-432a-ab3a-ec8a1c993eab", "developer_terms_of_service_url": null, "publisher_name": "LukeSwagWalker", "support_website_url": null, "website_url": "https://docs.google.com/document/d/1TSX42uHNHcKdPgUfM4k1Ar6vLe9Gzu8hGVhFzK_IoC8/pub", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8423880161037811"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974442_1270789840716755_7401