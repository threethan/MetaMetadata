d3-2.oculuscdn.com/v/t64.5771-25/39031631_825803462970867_613125718274049068_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C89oD_A679UQ7kNvgHXdPlj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvnIAOnCRlqh8RCQm0md_rvU2Q5ao-c10FEpyJq0ktyQ&oe=676FF5CA"}, {"file_name": "ss2.png", "id": "878915074198405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984475_878915077531738_2888961735902259771_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cPHufIXb5KoQ7kNvgGcdAtt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7GkBhdbTdlkg94homj072q3fE84hsFc_fWnu7-jPB9g&oe=676FC806"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover1.png", "id": "1192361738645756", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1192361741979089_3870097066250648076_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a98wtpXvO4UQ7kNvgHqj75g&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB83IDMrcpPnkEf5hRcjU6CxVeVRjCItQTrW14PxZbbRA&oe=676FD296"}, "display_name": "Russian Roulette", "keywords": ["roulette", "russian", "russianroulette", "onlineroulette", "RussianRoulette"], "long_description": "Russian Roulette is no longer just a game of chance\u2014it\u2019s a survival battle that also requires tactical intelligence! In this tension-filled game, every move is made on the thin line between life and death. With a variety of abilities at your disposal, you can take control of your fate and outsmart your opponent. Use the Handcuff ability to nullify your opponent's move and gain the chance to shoot instead, putting the power in your hands. The Energy Drink lets you eject the bullet from the chamber, providing a moment of relief and a chance to change the course of the game. Want more? With the Double Shot ability, you can pull the trigger twice in one turn, taking a calculated risk and applying extra pressure on your opponent. In this deadly duel, knowing when and how to use your abilities is the key to survival.\n\nBut this adventure isn't just limited to solo play! Soon, with the online option, you'll be able to share the thrill of Russian Roulette with your friends. Plan your strategy, take risks, defeat your friends, and claim victory! Get ready to find out who will survive in this deadly game.", "short_description": "Here\u2019s an adrenaline-filled experience: VR Russian Roulette! Push your limits in virtual reality and walk the edge of danger in this game that will have your heart racing. Summon your courage, pull the trigger, and see if you can survive! With lifelike graphics and an immersive atmosphere, this game will get your pulse pounding. Are you ready?"}]}, "developer_name": null, "developer_privacy_policy_url": "http://mesutkocaker.online/private.pdf", "developer_terms_of_service_url": null, "publisher_name": "mesutkocaker", "support_website_url": null, "website_url": "http://mesutkocaker.online/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "tr", "de", "it", "fr", "zh_CN", "ja", "es", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8210647152391262"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "437900949392766"}, {"status": "PUBLISHED", "id": "1198877241190188"}, {"status": "PUBLISHED", "id": "516438024508643"}]}, "baseline_offer": {"id": "516438024508643"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1737057600, "stat