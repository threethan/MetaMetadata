 new.png", "id": "1957606174719717", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974869_1957606181386383_8267351661661590516_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-f6TzyCboPcQ7kNvgHb2UoO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2oSRO9PF_X2tKDMLKIbJtDrou3erPY65b_aMJ2LhnXg&oe=674C3438"}, "display_name": "Neao Group Therapy", "keywords": ["Neao", "Therapy", "MentalHealth", "Group", "Support"], "long_description": "# Revolutionizing Group Therapy with Neao\n\nNeao's cutting-edge VR platform transforms the way therapy is delivered, fostering genuine connections and personal growth in immersive environments. We set a new standard for mental health support, enhancing both group therapy and individual sessions.\n\n**Unlock Potential in Every Session:** Immerse participants in supportive, virtual spaces that encourage authentic communication and healing, enabling individuals to connect and thrive.\n\n**Empower Therapists and Participants:** With realistic simulations and personalized programs, Neao equips therapists with tools for impactful sessions, while participants benefit from a deeply engaging experience.\n\n**Enhance Remote Therapy:** Facilitate remote sessions in VR spaces that foster strong emotional connections, regardless of physical distance.\n\n**Data-Driven Insights:** Our platform offers analytics that provide therapists with actionable insights to tailor treatment to individual needs.\n\n**Accessible VR for Mental Health:** Neao\u2019s solutions revolutionize therapy, offering a more effective alternative to traditional methods.\n\n**Join Neao:** Explore how Neao's VR solutions can reshape therapy, driving better outcomes for both therapists and clients.", "short_description": "Neao is a pioneering platform delivering end-to-end VR solutions for Group Therapy. Our immersive VR platform with unique treatment programs creates a powerful tool for therapists and empowers individuals to connect, grow, and heal in safe and supportive virtual environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://neao.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://neao.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8654749854602997"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031606_1793028344896577_5382712256996693789_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M8VN76o-BrcQ7kNvgFzD0Ig&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHLgbDN9Y8rTTyKvPacaur5qzpmwBT-Wl9mYX8t7eC3A&oe=674C459C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Neao Group Therapy", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Community", "id": "1228796255027646"}], "release_date": 1729185240, "lastRevision": {"nodes": [{"id": "8222701327807854", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": 