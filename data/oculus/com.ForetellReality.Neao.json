949_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QHABctpQJuIQ7kNvgE-tZzs&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYC82mJ7cA2GMkq8h_DVFc_sz6igenRaXhV0zIXpV1lZGQ&oe=6751B290"}, {"file_name": "38974528_300985632637458_6044806980667952672_n.png", "id": "453499873812461", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75356794_453499877145794_8306574212514530433_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zVQ9rMUw2hwQ7kNvgFB5lBW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDgvdvcBVYtmEiHaT4jlHyHin3gbsAf6tLhSuFHHz6BCA&oe=675187A0"}, {"file_name": "39035412_1424002995154831_7627870931299930738_n.png", "id": "1197650474672785", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75622009_1197650478006118_4379851118877732930_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vOVD5CEgkEkQ7kNvgEud2jW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAd4lXfb7Etd83IUI-7LXdIRZvQvDXQlypfA8chYtAZ-A&oe=67517C18"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Neao", "keywords": ["Neao", "Health", "Therapy", "MentalHealth", "GroupTherapy"], "long_description": "# Revolutionizing Group Therapy with Neao\n\nNeao's cutting-edge VR platform transforms the way therapy is delivered, fostering genuine connections and personal growth in immersive environments. We set a new standard for mental health support, enhancing both group therapy and individual sessions.\n\n**Unlock Potential in Every Session:** Immerse participants in supportive, virtual spaces that encourage authentic communication and healing, enabling individuals to connect and thrive.\n\n**Empower Therapists and Participants:** With realistic simulations and personalized programs, Neao equips therapists with tools for impactful sessions, while participants benefit from a deeply engaging experience.\n\n**Enhance Remote Therapy:** Facilitate remote sessions in VR spaces that foster strong emotional connections, regardless of physical distance.\n\n**Data-Driven Insights:** Our platform offers analytics that provide therapists with actionable insights to tailor treatment to individual needs.\n\n**Accessible VR for Mental Health:** Neao\u2019s solutions revolutionize therapy, offering a more effective alternative to traditional methods.\n\n**Join Neao:** Explore how Neao's VR solutions can reshape therapy, driving better outcomes for both therapists and clients.", "short_description": "Neao is a pioneering platform delivering end-to-end VR solutions for group therapy. Our immersive VR platform with unique treatment programs creates a powerful tool for therapists and empowers individuals to connect, grow, and heal in safe and supportive virtual environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://neao.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://neao.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8222701301141190"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1078267453958495"}]}, "baseline_offer": {"id": "1078267453958495"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729185240, "status": "PUBLISHED", "id": "1078267453958495"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename"