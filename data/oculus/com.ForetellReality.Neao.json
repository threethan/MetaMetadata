n.png", "id": "1622468745149688", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974700_1622468748483021_7417750549606292009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=peeY1M3BxXIQ7kNvgGKEz3i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvC8c9QZjY4WchybTEvB0albYuEK7ut9bjzY7sp8JjxQ&oe=6718DBD6"}, {"file_name": "38982533_293198043571933_8596478235430145082_n.png", "id": "1222599278861935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203618_1222599282195268_7543529969959741226_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FEYEMJKVgz8Q7kNvgEnCS1H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKnqJoSSraXdRoGcCOf2JYJhnrUQKgndduWFjCzwPmdg&oe=6718CCCF"}, {"file_name": "86653846_1511662882914046_7441619705300833097_n.png", "id": "408918818917948", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031452_408918822251281_925653654580631949_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mky5wVrVrSQQ7kNvgGO51aq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_FEyuKGxHqWMMQjACCxRlPepoUyWVpbu_UkAm2A3MHw&oe=6718C9D0"}, {"file_name": "38974528_300985632637458_6044806980667952672_n.png", "id": "453499873812461", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75356794_453499877145794_8306574212514530433_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jRyAS6IsLtcQ7kNvgEcNLDs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5r0YQEfD-0mWfE1JoFzSnH4VEtIPN_7QW1JAhAZCFbA&oe=6718D720"}, {"file_name": "39035412_1424002995154831_7627870931299930738_n.png", "id": "1197650474672785", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75622009_1197650478006118_4379851118877732930_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0ReNg-HzLcQ7kNvgEsej9C&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdetj0oi1jDRv0xg43JH4tEvcuYnvL_KQye12WayLOag&oe=6718CB98"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Neao", "keywords": ["Neao", "Health", "Therapy", "MentalHealth", "GroupTherapy"], "long_description": "# Revolutionizing Group Therapy with Neao\n\nNeao's cutting-edge VR platform transforms the way therapy is delivered, fostering genuine connections and personal growth in immersive environments. We set a new standard for mental health support, enhancing both group therapy and individual sessions.\n\n**Unlock Potential in Every Session:** Immerse participants in supportive, virtual spaces that encourage authentic communication and healing, enabling individuals to connect and thrive.\n\n**Empower Therapists and Participants:** With realistic simulations and personalized programs, Neao equips therapists with tools for impactful sessions, while participants benefit from a deeply engaging experience.\n\n**Enhance Remote Therapy:** Facilitate remote sessions in VR spaces that foster strong emotional connections, regardless of physical distance.\n\n**Data-Driven Insights:** Our platform offers analytics that provide therapists with actionable insights to tailor treatment to individual needs.\n\n**Accessible VR for Mental Health:** Neao\u2019s solutions revolutionize therapy, offering a more effective alternative to traditional methods.\n\n**Join Neao:** Explore how Neao's VR solutions can reshape therapy, driving better outcomes for both therapists and clients.", "short_description": "Neao is a pioneering platform delivering end-to-end VR solutions for group therapy. Our immersive VR platform with unique treatment programs creates a powerful tool for therapists and empowers individuals to connect, grow, and heal in safe and supportive virtual environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://neao.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://neao.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_ca