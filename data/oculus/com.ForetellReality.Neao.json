 "39031369_1099908320974568_466864774701843832_n.png", "id": "1622468745149688", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974700_1622468748483021_7417750549606292009_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EZyCGPSdB7MQ7kNvgFOnM3P&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDSllr6uYY7UQ0kbEvbaVXn8_e43vAvwRl651CDCNAsvQ&oe=67518C56"}, {"file_name": "38982533_293198043571933_8596478235430145082_n.png", "id": "1222599278861935", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75203618_1222599282195268_7543529969959741226_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w8X1TGk0RfAQ7kNvgHo2PUb&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCtYs6w3iWMdHse-F_GL3x_mnVkBs-SIRDU0YVf_Vx8QQ&oe=67517D4F"}, {"file_name": "86653846_1511662882914046_7441619705300833097_n.png", "id": "408918818917948", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39031452_408918822251281_925653654580631949_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QHABctpQJuIQ7kNvgE-tZzs&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYC82mJ7cA2GMkq8h_DVFc_sz6igenRaXhV0zIXpV1lZGQ&oe=6751B290"}, {"file_name": "38974528_300985632637458_6044806980667952672_n.png", "id": "453499873812461", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75356794_453499877145794_8306574212514530433_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zVQ9rMUw2hwQ7kNvgFB5lBW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDgvdvcBVYtmEiHaT4jlHyHin3gbsAf6tLhSuFHHz6BCA&oe=675187A0"}, {"file_name": "39035412_1424002995154831_7627870931299930738_n.png", "id": "1197650474672785", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75622009_1197650478006118_4379851118877732930_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vOVD5CEgkEkQ7kNvgEud2jW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAd4lXfb7Etd83IUI-7LXdIRZvQvDXQlypfA8chYtAZ-A&oe=67517C18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape new.png", "id": "1957606174719717", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974869_1957606181386383_8267351661661590516_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cTX9BUkZ0vwQ7kNvgEqRric&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDHSugoFarSd5GUbr61tgAclakPI7Z07F86h_mMrH5oMA&oe=6751B278"}, "display_name": "Neao Group Therapy", "keywords": ["Neao", "Therapy", "MentalHealth", "Group", "Support"], "long_description": "# Revolutionizing Group Therapy with Neao\n\nNeao's cutting-edge VR platform transforms the way therapy is delivered, fostering genuine connections and personal growth in immersive environments. We set a new standard for mental health support, enhancing both group therapy and individual sessions.\n\n**Unlock Potential in Every Session:** Immerse participants in supportive, virtual spaces that encourage authentic communication and healing, enabling individuals to connect and thrive.\n\n**Empower Therapists and Participants:** With realistic simulations and personalized programs, Neao equips therapists with tools for impactful sessions, while participants benefit from a deeply engaging experience.\n\n**Enhance Remote Therapy:** Facilitate remote sessions in VR spaces that foster strong emotional connections, regardless of physical distance.\n\n**Data-Driven Insights:** Our platform offers analytics that provide therapists with actionable insights to tailor treatment to individual needs.\n\n**Accessible VR for Mental Health:** Neao\u2019s solutions revolutionize therapy, offering a more effective alternative to traditional methods.\n\n**Join Neao:** Explore how Neao's VR solutions can reshape therapy, driving better outcomes for both therapists and clients.", "short_description": "Neao is a pioneering platform delivering end-to-end VR solutions for Group Therapy. Our immersive VR platform with unique treatment programs creates a powerful tool for therapists and empowers individuals to connect, grow, and heal in safe and supportive virtual environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://neao.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://neao.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}, {"id": "1228796255027646"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8654749854602997"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031606_1793028344896577_5382712256996693789_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kc0z_1uvrAoQ7kNvgFuELNP&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCT4RseLoRIqsV3iTwcfgc5GB4eWODX_nU7mIUYerBzvw&oe=67518B9C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Neao Group Therapy", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Community", "id": "1228796255027646"}], "release_date": 1729185240, "lastRevision": {"nodes": [{"id": "8222701327807854", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": 