6jmXcUPK_nA&oe=675ADFAF"}, {"file_name": "Terra Alia Screenshot 4.png", "id": "234548326001165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982638_234548329334498_1360834122964031973_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kjz8F1zPYYYQ7kNvgH2dnAZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAo8Cb9iK7plVysPn6isluQ_-azU1s0VpJ-nSxPC5FLcA&oe=675AE6DA"}, {"file_name": "Terra Alia Screenshot 5.png", "id": "273990318340587", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_273990321673920_5780660771656919889_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxRt9OptGesQ7kNvgFw76T0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-bulPWXDD-fq48hXHh4lmTWduACWG39Dv7gli6btIQQ&oe=675AD28D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Terra Alia Launch Trailer Thumbnail.png", "id": "3167922023512616", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982708_3167922030179282_7769879824967010062_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qwneIwlQI6EQ7kNvgEtCK3f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo00vV76ETmnrgomNIFg3kRlffjyOGsoK07S4Kt_VrsA&oe=675AD722"}, "display_name": "Terra Alia", "keywords": ["magic", "language", "learning", "educational", "puzzle"], "long_description": "Welcome to Terra Alia, an exceptional realm where the lines blur between technology, magic, and language. Designed to captivate and educate--transforming language learning into an interactive experience. Technology, magic, and language are intricately intertwined, creating a compelling educational escapade that transcends conventional learning paradigms.\n\n\ud83d\udcdc MULTILINGUAL MYSTERY: QUEST FOR THE MISSING MENTOR\nBegin your journey within the ivy-covered walls of Terra Alia's most prestigious magical academy. Your pursuit of arcane knowledge is guided by Professor Esperanto, a mentor whose sudden disappearance thrusts you into a spiralling quest rife with secrets, puzzles, and hidden wisdom.\n\n\ud83c\udfaf INTERACTIVE & DYNAMIC COMBAT\nMaster the art of spell-casting in ten distinct languages, employing a versatile arsenal of evocative spells synthesised from hundreds of words. Engage in tactical,crafted-for-VR combat, and fine-tune your strategies to adapt to various enemies.\n\n\ud83d\udd0d Quests & Puzzles: Follow clues and complete quests, solve environmental puzzles, and unearth the enigma of Esperanto's disappearance.\n\n\ud83d\udcaaDynamic Leveling: Get stronger by learning new words, unlock magical items, and power up your character through magical Statues.\n\n\u2694\ufe0f Captivating Combat: Cast spells and dodge incoming attacks with combat that blends education and excitement. \n\n\ud83c\udf10 Learn in Ten Languages: English, Spanish, Italian, French, German, Russian, Japanese, Korean, Chinese, and Brazilian Portuguese. \n", "short_description": "Words forge worlds, and mysteries await at every corner in Terra Alia. Unlock the magic of language from 10 diverse tongues. Embark on quests teeming with lexical challenges across ever-changing biomes, from academic campuses to the mystic unknown. Engage with enthralling characters and confront a myriad of foes. Your spells are crafted from hundreds of words, forming an arsenal for battles, puzzle-solving, and rich dialogues. Your vocabulary is your victory. Your lexicon, your legacy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://30parallelgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "30 Parallel Inc", "support_website_url": null, "website_url": "http://30parallelgames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "re