ile_name": "02.png", "id": "188615316434195", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031571_188615319767528_4763129071368843402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a3YGxyrmPfIQ7kNvgGHk_-U&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDL2WmSqeUkvy0Xi9BEnDhk9V7bcOOlBlRair0nnHb_2A&oe=6756CC10"}, {"file_name": "03.png", "id": "494518415073950", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974444_494518421740616_8556150623646762977_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9qZ11khFgjcQ7kNvgGXG_yl&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBsY0B3wl02NigP7rpKfqzg8nh76JZd9RVMtj6GNUF1fQ&oe=6756E49D"}, {"file_name": "04.png", "id": "935251280382157", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974787_935251283715490_5067068688868105902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tfK5OgTYRToQ7kNvgH_SCxH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD6HNq3SA5nNz4VAQIlGFi3YKjPReAZ8G_SVWggzOluRQ&oe=6756E86C"}, {"file_name": "05.png", "id": "2829380303968661", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974797_2829380307301994_8001908959296168963_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzVo4T5m9K4Q7kNvgEnaCpW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB2jl4licGJgjEzjDrVvaPzYzVN-BX1rmeWk83hC4tBuA&oe=6756E3A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "762810351097460", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75222945_762810354430793_937232459314771842_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_EjOjA6p5aMQ7kNvgFr3grO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDz1CnRQly6z4g84JrAAl9XiDiMa_GRgcWaCcQguN8tWQ&oe=6756F414"}, "display_name": "ForeVR Bowl", "keywords": [], "long_description": "\u201cForeVR Bowl is the best bowling game of all time\u201d -Vicki P, Mother of the Game Designer\n\nForeVR Bowl delivers fun for you, your family and friends like no other game in VR. Enjoy  lightweight competition and unlock over 75 collectible balls each with its own unique throwing style. Play online multiplayer with up to 4 friends, meet new people or go up against NPCs in six alleys (1990\u2019s hall, the Moon, Palm Springs, a Stadium, a Disco Club, and Tiki Island) each with its own immersive landscape, soundtrack and easter egg surprises with new alleys added regularly.  \n\nAt its core, ForeVR Bowl is an incredible bowling simulator thanks to a cutting edge game engine and Real Feel Throw technology to recreate everything you\u2019d expect in a bowling alley... except for smelly rental bowling shoes!", "short_description": "\u201cForeVR Bowl is the best bowling game of all time\u201d -Vicki P, Mother of the Game Designer\n\nGame night is back! ForeVR Bowl is fun for you, your family and friends like no other game in VR. Enjoy lightweight competition and unlock over 75 collectible balls each with its own unique throwing style. Play with up to 4 friends or meet new people in online multiplayer across six alleys, each with its own immersive landscape and soundtrack. \n\nGet ready for the best bowling simulator on Earth. \n\nGAME ON!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://forevrgames.com/privacy", "developer_terms_of_service_url": "http://forevrgames.com/tos", "publisher_name": "ForeVR Games Inc", "support_website_url": null, "website_url": "http://forevrgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_device