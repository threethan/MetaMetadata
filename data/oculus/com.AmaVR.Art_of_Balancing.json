_name": "ScreenShot_4_1.png", "id": "1599711943752549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_1599711947085882_701139155010109058_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PASgH7jqoocQ7kNvgEuXOKp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbSHd-vIQ1ADNfofXxgy4bD&oh=00_AYAph3-o2kAFFUZdxNcDvETQqihlNXUM9nvV_Oo3eV6IhA&oe=66E814AE"}, {"file_name": "ScreenShot_5.png", "id": "129317875732014", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299157_129317879065347_2083993127004899267_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sgNSzaHOygUQ7kNvgGxPCtH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbSHd-vIQ1ADNfofXxgy4bD&oh=00_AYALCuereto7roFgLDAgF3WmRjGAf_A9iwH6evp74yLTFA&oe=66E7FB35"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art of Balancing", "keywords": [], "long_description": "Atop the sea of clouds, there exists a garden where the past and present intersect. A space designed to preserve our collective story. But decades of neglect have left the garden barren and forgotten. Now it is up to you to restore our connection to the past by creating rock sculptures that anchor our absent-minded world.\n\nIn Art of Balancing, you are a rock balancer making your way up a mountain in search of the garden. Along the way, you create rock sculptures. Picking up stones, you feel their weight, hear their voice, and find their balance. A collection of carefully thought out prompts will then guide you to reflect on your past and embed your personal story into the stone.", "short_description": "Master the art of rock balancing and restore the balance to our world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.amavr.com/privacy-policy", "developer_terms_of_service_url": "https://www.amavr.com/terms-and-conditions", "publisher_name": "AmaVR", "support_website_url": "http://www.amavr.com/connect", "website_url": "https://www.amavr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tag