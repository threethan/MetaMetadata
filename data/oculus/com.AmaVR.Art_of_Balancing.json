&_nc_sid=6e7a0a&_nc_ohc=zGW_B5nLIG4Q7kNvgEFZw_T&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeQv5N0x0F5a6Y_DX3_Hr3thbd618xeRyCm-F9EqqCPA&oe=6703C42E"}, {"file_name": "ScreenShot_5.png", "id": "129317875732014", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299157_129317879065347_2083993127004899267_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ep017Wt3HYQ7kNvgHIF996&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsk_soKMZdgH4n08nQdfnrc4jLKxo1cYeO8i2lDijllw&oe=6703E2F5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art of Balancing", "keywords": [], "long_description": "Atop the sea of clouds, there exists a garden where the past and present intersect. A space designed to preserve our collective story. But decades of neglect have left the garden barren and forgotten. Now it is up to you to restore our connection to the past by creating rock sculptures that anchor our absent-minded world.\n\nIn Art of Balancing, you are a rock balancer making your way up a mountain in search of the garden. Along the way, you create rock sculptures. Picking up stones, you feel their weight, hear their voice, and find their balance. A collection of carefully thought out prompts will then guide you to reflect on your past and embed your personal story into the stone.", "short_description": "Master the art of rock balancing and restore the balance to our world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.amavr.com/privacy-policy", "developer_terms_of_service_url": "https://www.amavr.com/terms-and-conditions", "publisher_name": "AmaVR", "support_website_url": "http://www.amavr.com/connect", "website_url": "https://www.amavr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_a