BjA7Q35-ChqS1eQ&oe=677E5E3A"}, {"file_name": "ScreenShot_3.png", "id": "422188228843788", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75404370_422188232177121_3120282046784821020_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tlc3JxObJTwQ7kNvgHgMGhC&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCZLV6dGQ8-Vw25O8WZg8Zwt1GAfE3ghBet1k_-Pp0DCA&oe=677E61B0"}, {"file_name": "ScreenShot_4_1.png", "id": "1599711943752549", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39003273_1599711947085882_701139155010109058_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7P3u1N489ZoQ7kNvgGEgkxX&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYC8wnVEhvLx0eZGhy_D0ex9Pd5dJ8av1j5NobibIfN9oA&oe=677E5FAE"}, {"file_name": "ScreenShot_5.png", "id": "129317875732014", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/75299157_129317879065347_2083993127004899267_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7RK9mp3fGZoQ7kNvgFdBxCo&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYB_pgrp8hahUxZVAP0wjy2pyHs1Hmec4I5OGI_RZK7bXQ&oe=677E7E75"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art of Balancing", "keywords": [], "long_description": "Atop the sea of clouds, there exists a garden where the past and present intersect. A space designed to preserve our collective story. But decades of neglect have left the garden barren and forgotten. Now it is up to you to restore our connection to the past by creating rock sculptures that anchor our absent-minded world.\n\nIn Art of Balancing, you are a rock balancer making your way up a mountain in search of the garden. Along the way, you create rock sculptures. Picking up stones, you feel their weight, hear their voice, and find their balance. A collection of carefully thought out prompts will then guide you to reflect on your past and embed your personal story into the stone.", "short_description": "Master the art of rock balancing and restore the balance to our world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.amavr.com/privacy-policy", "developer_terms_of_service_url": "https://www.amavr.com/terms-and-conditions", "publisher_name": "AmaVR", "support_website_url": "http://www.amavr.com/connect", "website_url": "https://www.amavr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1008279844328894"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4819542131434763"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3857584514354126", "version": "7"}, "id": "411564913240508", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3627738584005388", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "3857584514354126"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "411564913240508"}]}, "change_log": null, "created_date": 1619518509, "id": "3857584514354126", "version": "7", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "bin