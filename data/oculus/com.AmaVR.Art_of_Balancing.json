E"}, {"file_name": "ScreenShot_5.png", "id": "129317875732014", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75299157_129317879065347_2083993127004899267_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y1epU4ddPqQQ7kNvgEx6JHo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzLn3N4vLcL8Y_eJbGfrdhF3m-QLGEhmph-dkgv6cnNw&oe=66D2E335"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art of Balancing", "keywords": [], "long_description": "Atop the sea of clouds, there exists a garden where the past and present intersect. A space designed to preserve our collective story. But decades of neglect have left the garden barren and forgotten. Now it is up to you to restore our connection to the past by creating rock sculptures that anchor our absent-minded world.\n\nIn Art of Balancing, you are a rock balancer making your way up a mountain in search of the garden. Along the way, you create rock sculptures. Picking up stones, you feel their weight, hear their voice, and find their balance. A collection of carefully thought out prompts will then guide you to reflect on your past and embed your personal story into the stone.", "short_description": "Master the art of rock balancing and restore the balance to our world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.amavr.com/privacy-policy", "developer_terms_of_service_url": "https://www.amavr.com/terms-and-conditions", "publisher_name": "AmaVR", "support_website_url": "http://www.amavr.com/connect", "website_url": "https://www.amavr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], 