2BuO129FZi_7w&oe=67542E3A"}, {"file_name": "ScreenShot_3.png", "id": "422188228843788", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75404370_422188232177121_3120282046784821020_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S-5K-C3sMw4Q7kNvgGolRxX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCELunAX1P8V68MC5Nm85LnhVuwrFr0w0u7bdvOZ9K3nw&oe=675431B0"}, {"file_name": "ScreenShot_4_1.png", "id": "1599711943752549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003273_1599711947085882_701139155010109058_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6zXEQhVdncgQ7kNvgGdD4ad&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCh3e28b-8Xc8_nJ7bQyXfMuLJdzdJ0HEsnKxY-MrhBdg&oe=67542FAE"}, {"file_name": "ScreenShot_5.png", "id": "129317875732014", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299157_129317879065347_2083993127004899267_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rBJjRqSKmpMQ7kNvgFRCBbU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGmDx5qiK0cCUUaxgXgCMBkoBmvrC2_gzWbP1ZHslx-A&oe=67544E75"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art of Balancing", "keywords": [], "long_description": "Atop the sea of clouds, there exists a garden where the past and present intersect. A space designed to preserve our collective story. But decades of neglect have left the garden barren and forgotten. Now it is up to you to restore our connection to the past by creating rock sculptures that anchor our absent-minded world.\n\nIn Art of Balancing, you are a rock balancer making your way up a mountain in search of the garden. Along the way, you create rock sculptures. Picking up stones, you feel their weight, hear their voice, and find their balance. A collection of carefully thought out prompts will then guide you to reflect on your past and embed your personal story into the stone.", "short_description": "Master the art of rock balancing and restore the balance to our world."