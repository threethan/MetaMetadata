file_name": "Image Sequence_006_0001.png", "id": "1032584778066271", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001697_1032584781399604_3190573640588349027_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzliAQJO_9oQ7kNvgH6LOCN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYCW8mApPURsoP9GDE-yBHa_wlnQfYzF7DxJR0itHmRTcQ&oe=66F146CD"}, "display_name": "Portal Rush", "keywords": ["casual", "runner", "hypercasual", "action", "challenge"], "long_description": "Portal Rush is an innovative VR runner game that immerses you in a thrilling, action-packed world. Your objective is to race through fast-paced courses filled with obstacles, aiming for the highest score possible. What sets this game apart is the ability to instantly teleport to different locations by opening portals with a click. This unique mechanic not only increases the game's pace but also requires you to strategize your moves carefully. Each level presents progressively harder tracks that test your reflexes to the limit. As you advance, you can collect points to climb the leaderboard and compete with other players. The visual effects and VR's immersive realism enhance the game's atmosphere, making every run a captivating experience. \"Portal Dash\" offers an adrenaline-fueled adventure for both VR enthusiasts and runner game fans. Dive into this fast and dynamic world, teleport through portals, race against time, and become the best. Each run brings a new challenge and a new adventure!", "short_description": "Portal Rush is an exhilarating VR runner game that challenges you to navigate obstacle-filled courses at high speed. As you dash through the levels, you can instantly teleport to different locations by opening portals where you click. This dynamic game tests your reflexes and pushes you to conquer increasingly difficult tracks. Your goal is to reach the finish line as quickly as possible and achieve high scores. With its unique portal mechanic, this game brings a fresh twist to classic runner "}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/portal-rush", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9149118831771162"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1055265386000768"}]}, "baseline_offer": {"id": "1055265386000768"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726266901, "status": "PUBLISHED", "id": "1055265386000768"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9136314546384924", "version": "0.2"}, "id": "1953219375149693", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9081696921846687", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9136314546384924"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name"