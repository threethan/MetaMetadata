_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYCRUOS64ga4--AFQUXqzat3fu4BszCxqEZ04r22Id84-Q&oe=66F14D38"}, {"file_name": "Image Sequence_002_0001.png", "id": "1056220476068384", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982697_1056220479401717_7840162379227703404_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AHPmclccZWQQ7kNvgGPtqPU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYAhaAOiMOKYywu3IFSaZ8etOy_j0lFl619wWvtsUoNUGw&oe=66F14B03"}, {"file_name": "Image Sequence_005_0001.png", "id": "1051164063205208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984466_1051164066538541_7036220709104598103_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6fhApBBaT1wQ7kNvgGpARMc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYA9m0TH9xnqVHyP6hiBWxjj0rxv0Y9fy0M9GFV3Rd2CZw&oe=66F16A0C"}, {"file_name": "Image Sequence_006_0001.png", "id": "865084521857384", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003242_865084528524050_4676146938380815761_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lJa9Qs2MOkQQ7kNvgFmRuPB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYBSqTJYP2S8621d78WiZc1KtyE_Ldkl8I9Ct2T4xLl8VQ&oe=66F147A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Image Sequence_006_0001.png", "id": "1032584778066271", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001697_1032584781399604_3190573640588349027_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzliAQJO_9oQ7kNvgH6LOCN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQvpcQMXHx0IsZXKg4iGS66&oh=00_AYCW8mApPURsoP9GDE-yBHa_wlnQfYzF7DxJR0itHmRTcQ&oe=66F146CD"}, "display_name": "Portal Rush", "keywords": ["casual", "runner", "hypercasual", "action", "challenge"], "long_description": "Portal Rush is an innovative VR runner game that immerses you in a thrilling, action-packed world. Your objective is to race through fast-paced courses filled with obstacles, aiming for the highest score possible. What sets this game apart is the ability to instantly teleport to different locations by opening portals with a click. This unique mechanic not only increases the game's pace but also requires you to strategize your moves carefully. Each level presents progressively harder tracks that test your reflexes to the limit. As you advance, you can collect points to climb the leaderboard and compete with other players. The visual effects and VR's immersive realism enhance the game's atmosphere, making every run a captivating experience. \"Portal Dash\" offers an adrenaline-fueled adventure for both VR enthusiasts and runner game fans. Dive into this fast and dynamic world, teleport through portals, race against time, and become the best. Each run brings a new challenge and a new adventure!", "short_description": "Portal Rush is an exhilarating VR runner game that challenges you to navigate obstacle-filled courses at high speed. As you dash through the levels, you can instantly teleport to different locations by opening portals where you click. This dynamic game tests your reflexes and pushes you to conquer increasingly difficult tracks. Your goal is to reach the finish line as quickly as possible and achieve high scores. With its unique portal mechanic, this game brings a fresh twist to classic runner "}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/portal-rush", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_conn