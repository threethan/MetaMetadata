ame": "Goliath_Venice_Press_Announcement_1.png", "id": "1657367554615329", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_1657367557948662_240041854237545087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VEG3_vQqu-MQ7kNvgG64QKo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYD4M9FoEtWUEZh9I3JBNhadW5Pi3Y8If3fTxcPXJbOdMw&oe=66ED5799"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2021-08-04-15h00m21s650.png", "id": "988126451974078", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984440_988126455307411_574716995406426680_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xB-1iq9IVqcQ7kNvgH9Vzax&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYDXQG-W7Ev3q0yewHKmWT19hgcRlNtKTE6NCyZJn1vBeQ&oe=66ED50AC"}, "display_name": "Goliath", "keywords": [], "long_description": "\"The Universe is revolving around me in a bad way.\u201d \n\nThrough mind-bending animation, explore the limits of reality and a true story of so-called \u2018schizophrenia\u2019 and the power of gaming communities.\n\nEcho (narrated by Tilda Swinton) guides you through the many realities of Goliath, a man who spent years isolated in psychiatric institutions but finds connection in multiplayer games. Combining heartfelt dialogue, mesmerising visuals and symbolic interactions, weave through multiple worlds to uncover Goliath's poignant story.\n\nCreated by Anagram, the team that brought you The Collider and Door into the Dark. Winners of the 2015 Tribeca Film Festival Storyscapes award, the 2019 Sandbox Immersive Art award, and part of the Best VR in 2019 at the Venice International Film Festival.\n\nTake part in the World Premiere at the Venice International Film Festival on 1 September. \nComing to the Oculus Quest store on 9 September. \n\ngoliathvr.io \n#goliathvr", "short_description": "Through mind-bending animation, explore the limits of reality and a true story of mental health and the power of gaming. Echo (narrated by Tilda Swinton) guides you through the many realities of Goliath, a man who spent years isolated in mental health institutions but finds connection in multiplayer games. Combining heartfelt dialogue, mesmerising visuals and symbolic interactions, weave through multiple worlds to uncover Goliath's poignant story."}]}, "developer_name": null, "developer_privacy_policy_url": "https://goliathvr.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "We Are Anagram Ltd", "support_website_url": null, "website_url": "https://weareanagram.co.uk/project/goliath", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "DOCUMENTARY_HISTORY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "271948868309363"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2410725085737702"}, {"status": "PUBLISHED", "id": "1724623461245499"}]}, "baseline_offer": {"id": "1724623461245499"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1631206800, "status": "PUBLISHED", "id": "2410725085737702"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4372756382787330", "version": "1.7.3"}, "id": "2644174862539854", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "