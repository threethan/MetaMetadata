.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYBxWrgIl9boe7x4rRV59JaY71VqpPEbfjvjg-h63aAK4Q&oe=66ED6848"}, {"file_name": "BREAKDOWN (DJ)_040821.png", "id": "352949216401015", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982485_352949223067681_6191682655007434949_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ADU1jxWdLFwQ7kNvgHOyKHc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYACnjJ_V-mVcLte_-pDHZpOIzW40VTDRHlaPdiKR02lRg&oe=66ED78C1"}, {"file_name": "Goliath_Venice_Press_Announcement_1.png", "id": "1657367554615329", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_1657367557948662_240041854237545087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VEG3_vQqu-MQ7kNvgG64QKo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYD4M9FoEtWUEZh9I3JBNhadW5Pi3Y8If3fTxcPXJbOdMw&oe=66ED5799"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2021-08-04-15h00m21s650.png", "id": "988126451974078", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984440_988126455307411_574716995406426680_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xB-1iq9IVqcQ7kNvgH9Vzax&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASNdKKV7Xs2FfbYZqhDdCi8&oh=00_AYDXQG-W7Ev3q0yewHKmWT19hgcRlNtKTE6NCyZJn1vBeQ&oe=66ED50AC"}, "display_name": "Goliath: Playing with Reality", "keywords": [], "long_description": "# UPDATE \ud83d\ude80\n**Impulse, Playing with Reality**, the second instalment of the Playing with Reality collection, is available to download from 12 September, 2024. \n\nWinner of Venice Achievement Prize at the 81st Venice International Film Festival (2024), Impulse is a 40-minute interactive mixed reality documentary about ADHD, and how you make sense of the world around you, told through the stories of four people who are coming to terms with the decisions which have chartered their lives.\n\n{1937707116700494}\n\n----------\nThrough mind-bending animation, GOLIATH: PLAYING WITH REALITY explores the limits of reality and a true story of so-called \u2018schizophrenia\u2019 and the power of gaming communities. Echo (Tilda Swinton) guides you through the many realities of Goliath, a man who spent years isolated in psychiatric institutions but finds connection in multiplayer games. Combining heartfelt dialogue, mesmerising visuals and symbolic interactions, weave through multiple worlds to uncover Goliath\u2019s poignant story. \n\nWinner of the Grand Jury Prize for Best VR Work at the 78th Venice International Film Festival and nominated for an Emmy Award in the Outstanding Interactive Media Innovation category.\n\nCreated by the award-winning creative studio Anagram.\n\n*Please note, you will be required to use your microphone during this experience. \n\n**For users who have trouble leaving the room in the sequences on the arcade machine, please use the thumb-stick to move out the door. The door is not visible when seated.\n", "short_description": "Through mind-bending animation, award-winning GOLIATH: PLAYING WITH REALITY explores the limits of reality and a true story of mental health and the power of gaming. Echo (narrated by Tilda Swinton) guides you through the many realities of Goliath, a man who spent years isolated in mental health institutions but finds connection in multiplayer games. Combining heartfelt dialogue, mesmerising visuals and symbolic interactions, weave through multiple worlds to uncover Goliath's poignant story."}]}, "developer_name": null, "developer_privacy_policy_url": "https://goliathvr.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Anagram, Flor\u00e9al", "support_website_url": null, "website_url": "https://goliathvr.io/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1283811691952063"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "DO