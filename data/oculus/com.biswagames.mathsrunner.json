: null, "video_trailer_thumbnail": {"file_name": "/tmp/MuGxlQ", "id": "748047012367967", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974895_748047015701300_2758205324358844416_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1rvGDtUFm3sQ7kNvgFyrT67&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDoCaYtcA_e_Q0GRoFufLK7BXSCAsQX720dPq2cRGqZOA&oe=6751AA56"}, "display_name": "Maths Runner", "keywords": ["Infinite", "Racer", "temple", "run", "Kid"], "long_description": "Want to check your Addition/Subtraction skills? Then Maths Runner is the game for you. Maths Runner is an infinite racing game. Player needs to run through infinite environments while solving the mathematics question. Doors to the next environment will only open if the user solves the questions correctly. Multiple choices will be there in the environment to choose from. You can use \u201cCrush\u201d power up to destroy a question and move to the next environment. You can also use\n Revive to continue the game even after a wrong answer\n Magnet to collect all coins for few seconds\n Wizard to disable questions and move without any challenge for few seconds\n 2X to get double bonus coins for few seconds\nYou will experience\nLovely Fantasy world\nMultiple Complexity of Mathematics\nConcentrate Avoid Obstructions created by Fantasy Worlds \nAttract the coins using Magnets", "short_description": "Want to check your basic Mathematics skills while concentrating for obstacles?"}]}, "developer_name": "Biswanath Das", "developer_privacy_policy_url": "https://www.biswagames.com/privacy_policy/app/MathsRunner.html", "developer_terms_of_service_url": null, "publisher_name": "Biswa Games", "support_website_url": null, "website_url": "https://www.biswagames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "PUZZLE"], "has_in_app_ads":