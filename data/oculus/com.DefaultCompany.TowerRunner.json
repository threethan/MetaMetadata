03151890935065_8140742154684598433_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iPBr-I_FELUQ7kNvgFUCtg4&_nc_ht=scontent.oculuscdn.com&oh=00_AYABbe2JsI9_JCECbGW78veyNirW_Dcw_rpJE2hJii6rTQ&oe=66CDD343"}]}, "id": "841421999789250", "locale": "en_US", "screenshots": [{"file_name": "cover.png", "id": "158557562756417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035433_158557566089750_7489491460094422170_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GMLNqS2Fsq0Q7kNvgFQzLvy&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9hJlcqDn5F91dw50RScndSBM1OwC-ImxCwGyT5IE_qg&oe=66CDBE13"}, {"file_name": "s2.png", "id": "490340735485521", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031490_490340745485520_38214018525166416_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FymZP3ExTOgQ7kNvgEI07tm&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOL1L1woYQt86MNg1ozzivaZZOAIOU8NWIRCpN3iakIg&oe=66CDA23F"}, {"file_name": "s3.png", "id": "925505954930537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572934_925505958263870_8731403431658683426_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hG0wF3Gdn3IQ7kNvgHvzzc_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqQK0G3hSvAbRQ9l-UqtZOLL_5He6g52MGvoqLwhYSyw&oe=66CDC04C"}, {"file_name": "s4.png", "id": "850850508798480", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203624_850850512131813_7353756723277509783_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=21IgXULjo7oQ7kNvgE-swoT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCdvu8FjWWbb8EuBXUHW47VRCiJHFqbDY4igS14R23N5Q&oe=66CDB093"}, {"file_name": "s5.png", "id": "924033128354831", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984465_924033131688164_9210507137629765858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2jlzbP4PSYQ7kNvgGROyr3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBew9N0qvEcLKto3fUV4HuFH7wYEu2Wj5SqKziyHu4IdA&oe=66CDC9B7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WorldTreeClimber", "keywords": [], "long_description": "Game Rules\nTry not to fall off the path.\nMake the hero jump while moving forward.\n\nThere are enemies standing in the way, but the hero is very strong, so there is no problem even if you hit them.\n\nDefeat the dragon at the top to clear the game!\n\nOperation explanation\nRight hand side Oculus Touch A button (Decision, Jump)\nLeft hand side Oculus Touch stick (left/right) (change perspective mode)\n\nGame Play Time\nAbout 5 minutes", "short_description": "Aim for the sky with the touch of a button! Casual VR game!\n\nUse the A button to make your hero jump.\nJump with the A button and aim for the top of the world tree!"}, {"images": {"nodes": []}, "id": "202727748079833", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WorldTreeClimber", "keywords": [], "long_description": "\u30b2\u30fc\u30e0\u30eb\u30fc\u30eb\n\u9053\u304b\u3089\u843d\u3061\u306a\u3044\u3088\u3046\u30bf\u30a4\u30df\u30f3\u30b0\u3092\u307f\u3066\n\u52c7\u8005\u3092\u30b8\u30e3\u30f3\u30d7\u3055\u305b\u306a\u304c\u3089\u9032\u3093\u3067\u304f\u3060\u3055\u3044\u3002\n\n\u9802\u4e0a\u306b\u3044\u308b\u30c9\u30e9\u30b4\u30f3\u3092\u5012\u3059\u3068\u30af\u30ea\u30a2\u3067\u3059\u3002\n\n\u203b\u9053\u4e2d\u306b\u306f\u6575\u304c\u7acb\u3061\u3075\u3055\u304c\u3063\u3066\u3044\u307e\u3059\u304c\u3001\n\u52c7\u8005\u304c\u3068\u3066\u3082\u5f37\u3044\u305f\u3081\u5f53\u305f\u3063\u3066\u3082\u554f\u984c\u3042\u308a\u307e\u305b\u3093\u3002\n\n\u64cd\u4f5c\u8aac\u660e\n\u53f3\u624b\u5074Oculus Touch \u3000A\u30dc\u30bf\u30f3\u3000(\u6c7a\u5b9a\u3001\u30b8\u30e3\u30f3\u30d7)\n\u5de6\u624b\u5074Oculus Touch \u3000\u30b9\u30c6\u30a3\u30c3\u30af(\u5de6\u53f3)\u3000(\u8996\u70b9\u306e\u30e2\u30fc\u30c9\u5909\u66f4)\n\n\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\u6642\u9593\n5\u5206\u7a0b\u5ea6", "short_description": "\u7c21\u5358\u64cd\u4f5c\u3067\u697d\u3057\u3081\u308b\u30ab\u30b8\u30e5\u30a2\u30ebVR\u30b2\u30fc\u30e0\u767b\u5834\uff01\n\nA\u30dc\u30bf\u30f3\u