RCpN3iakIg&oe=66CDA23F"}, {"file_name": "s3.png", "id": "925505954930537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572934_925505958263870_8731403431658683426_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hG0wF3Gdn3IQ7kNvgHvzzc_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqQK0G3hSvAbRQ9l-UqtZOLL_5He6g52MGvoqLwhYSyw&oe=66CDC04C"}, {"file_name": "s4.png", "id": "850850508798480", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203624_850850512131813_7353756723277509783_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=21IgXULjo7oQ7kNvgE-swoT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCdvu8FjWWbb8EuBXUHW47VRCiJHFqbDY4igS14R23N5Q&oe=66CDB093"}, {"file_name": "s5.png", "id": "924033128354831", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984465_924033131688164_9210507137629765858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2jlzbP4PSYQ7kNvgGROyr3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBew9N0qvEcLKto3fUV4HuFH7wYEu2Wj5SqKziyHu4IdA&oe=66CDC9B7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WorldTreeClimber", "keywords": [], "long_description": "Game Rules\nTry not to fall off the path.\nMake the hero jump while moving forward.\n\nThere are enemies standing in the way, but the hero is very strong, so there is no problem even if you hit them.\n\nDefeat the dragon at the top to clear the game!\n\nOperation explanation\nRight hand side Oculus Touch A button (Decision, Jump)\nLeft hand side Oculus Touch stick (left/right) (change perspective mode)\n\nGame Play Time\nAbout 5 minutes", "short_description": "Aim for the sky with the touch of a button! Casual VR game!\n\nUse the A button to make your hero jump.\nJump with the A button and aim for the top of the world tree!"}, {"images": {"nodes": []}, "id": "202727748079833", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "WorldTreeClimber", "keywords": [], "long_description": "\u30b2\u30fc\u30e0\u30eb\u30fc\u30eb\