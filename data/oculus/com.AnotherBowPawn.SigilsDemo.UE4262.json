=1-7&_nc_sid=6e7a0a&_nc_ohc=AADZogVPbXgQ7kNvgFnUO7I&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9lYdrmpgUojiTCBp1fT52sW7yVi3DlcxS7B_gRuwCyA&oe=66F15657"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sigils_Trailer_CoverImage.png", "id": "1265919334077285", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375753_1265919337410618_3623123092678503033_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TYP-4PsL3gUQ7kNvgEKCQDS&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAsd_lG7GwKW05VHa51Fdpd-Az7pMmCN7yZADmZ2U7Jw&oe=66F15B15"}, "display_name": "Sigils DEMO", "keywords": [], "long_description": "Fight your way through a fantasy world filled with magic and monsters, using your druidic dragon powers and sigils.\n\nUse physical motion to generate magic energy by punching spells, or slashing multiple enemies in your dragon form.\n\nEnter your spirit form and take control of your primary guardian and set it free when you rain down destruction with your magic sigils.\n\nMake the right tactical choices to balance your mana and energy levels, using your bow, magic and motion, combined with sigil and guardian cooldowns.\n\nCollect dragon eggs to obtain the power of all the guardian\u2019s and gain strength, stamina and endurance from crystals as you defeat the corrupted elementals.", "short_description": "Sigils is a stylized Action Strategy Magic Cards adventure where you create powerful sigils and grow stronger as you progress through the treacherous environment.\n\nIn this demo, you'll be introduced to the abilities of a Dragon Druid, and test your strength, courage, and cunning. \n\nSo strap on your headset, grab your controllers, and prepare to unleash the dragon within you!"}]}, "developer_name": "Sigils", "developer_privacy_policy_url": "https://sigils.studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Sigils Studio", "support_website_url": null, "website_url": "https://sigils.studio/", "category": null, "comfort_rating": "NOT_R