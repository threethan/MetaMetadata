uscdn.com/v/t64.5771-25/38982453_358453423375789_6200493142914047639_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WX7FU3ZmLLsQ7kNvgHG7ks_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLUyyF9tfqKMtODnZrraeVGWe1fT4egRsWAItPehq5iw&oe=670D06F5"}, {"file_name": "Sigils_Screenshot3.png", "id": "850342790156206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001670_850342793489539_8903931807220071004_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_xJrs3Hx2AUQ7kNvgGw3JDs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfULLw4M0WGNAM2jCk0Fy5dn04X70QSpQrUR0SGu05vQ&oe=670D0E5C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sigils_CoverImage.png", "id": "1153631758938934", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031344_1153631762272267_6012782483585075551_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VeaPLa0UwE0Q7kNvgHuEoVS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBs0BBIk_nYuohNVtCWsbiwZc5pO6bho1ETlEWFYks1yg&oe=670D0908"}, "display_name": "Sigils - DEMO", "keywords": [], "long_description": "Fight your way through a fantasy world filled with magic and monsters, using your druidic dragon powers and sigils.\n\nUse physical motion to generate magic energy by punching spells, or slashing multiple enemies in your dragon form.\n\nEnter your spirit form and take control of your primary guardian and set it free when you rain down destruction with your magic sigils.\n\nMake the right tactical choices to balance your mana and energy levels, using your bow, magic and motion, combined with sigil and guardian cooldowns.\n\nCollect dragon eggs to obtain the power of all the guardian\u2019s and gain strength, stamina and endurance from crystals as you defeat the corrupted elementals.", "short_description": "Sigils is a stylized Action Strategy Magic Cards adventure where you create powerful sigils and grow stronger as you progress through the treacherous environment.\n\nIn this demo, you'll be introduced to the abilities of a Dragon Druid, and test your strength, courage, and cunning. \n\nSo strap on your headset, grab your controllers, and prepare to unleash the dragon within you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sigils.studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Sigils Studio", "support_website_url": null, "website_url": "https://sigils.studio/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7306221032793294"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "756435406341687"}]}, "baseline_offer": {"id": "756435406341687"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1700780400, "status": "PUBLISHED", "id": "756435406341687"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7760898980658828", "version": "1.0"}, "id": "837924324681573", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7306221016126629", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7760898980658828"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes"