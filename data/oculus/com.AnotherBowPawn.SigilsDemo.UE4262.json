ACaYAd-AIbkMa9-y6QCyfp3yO0pF-Lm6z6sIRxD6Zw0w&oe=6777CFB9"}, {"file_name": "Sigils_Screenshot2 - Copy.png", "id": "1478315192732904", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75223475_1478315196066237_7349018609400958167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b8dsIM0M81YQ7kNvgF7wgSc&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC1X7C3nEF-Vf44eMD53Yt-cS8UIr24mv0exu-2wVGu5A&oe=6777CF57"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sigils_Trailer_CoverImage.png", "id": "1265919334077285", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75375753_1265919337410618_3623123092678503033_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WE6dOWxBO9QQ7kNvgEOXbvd&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBgVmdp2SAyQ2-eUWAYSx7vZ1y-T66VCCpKoyY3a34ayw&oe=6777D415"}, "display_name": "Sigils DEMO", "keywords": [], "long_description": "Fight your way through a fantasy world filled with magic and monsters, using your druidic dragon powers and sigils.\n\nUse physical motion to generate magic energy by punching spells, or slashing multiple enemies in your dragon form.\n\nEnter your spirit form and take control of your primary guardian and set it free when you rain down destruction with your magic sigils.\n\nMake the right tactical choices to balance your mana and energy levels, using your bow, magic and motion, combined with sigil and guardian cooldowns.\n\nCollect dragon eggs to obtain the power of all the guardian\u2019s and gain strength, stamina and endurance from crystals as you defeat the corrupted elementals.", "short_description": "Sigils is a stylized Action Strategy Magic Cards adventure where you create powerful sigils and grow stronger as you progress through the treacherous environment.\n\nIn this demo, you'll be introduced to the abilities of a Dragon Druid, and test your strength, courage, and cunning. \n\nSo strap on your headset, grab your controllers, and prepare to unleash the dragon within you!"}]}, "developer_name": "Sigils", "developer_privacy_policy_url": "https://sigils.studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Sigils Studio", "support_website_url": null, "website_url": "https://sigils.studio/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7443080685773994"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035390_882914603062741_7772687024572992577_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LF_DSyM-zLwQ7kNvgFrIJNs&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCjvzdfsgwcraW8aXcyQiPXzKGR3ZTI77bdBcctI0egYQ&oe=6777BD23"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sigils DEMO", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1700780400, "lastRevision": {"nodes": [{"id": "7306221059459958", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7306221016126629", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert":