_ohc=kBkKveA60S0Q7kNvgEw8_YN&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Nxbpyb0Q6MXzKzMMyXcH0&oh=00_AYBGiYismC4DKLEqk8nznPDJZcxc5s8h6FIRAR_NdIO8eQ&oe=66EEB3B9"}, {"file_name": "Sigils_Screenshot2 - Copy.png", "id": "1478315192732904", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223475_1478315196066237_7349018609400958167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AADZogVPbXgQ7kNvgGssPT6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Nxbpyb0Q6MXzKzMMyXcH0&oh=00_AYBJ_-tFDazSdGSTxIwMi2Lk6FKe0veIYY8jApFu-ldJUg&oe=66EEB357"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sigils_Trailer_CoverImage.png", "id": "1265919334077285", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375753_1265919337410618_3623123092678503033_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TYP-4PsL3gUQ7kNvgFnxS9h&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Nxbpyb0Q6MXzKzMMyXcH0&oh=00_AYAAgIUXNfakSFemj8ZwF3pKdwzqfVED2GyIzSHrNNXttA&oe=66EEB815"}, "display_name": "Sigils DEMO", "keywords": [], "long_description": "Fight your way through a fantasy world filled with magic and monsters, using your druidic dragon powers and sigils.\n\nUse physical motion to generate magic energy by punching spells, or slashing multiple enemies in your dragon form.\n\nEnter your spirit form and take control of your primary guardian and set it free when you rain down destruction with your magic sigils.\n\nMake the right tactical choices to balance your mana and energy levels, using your bow, magic and motion, combined with sigil and guardian cooldowns.\n\nCollect dragon eggs to obtain the power of all the guardian\u2019s and gain strength, stamina and endurance from crystals as you defeat the corrupted elementals.", "short_description": "Sigils is a stylized Action Strategy Magic Cards adventure where you create powerful sigils and grow stronger as you progress through the treacherous environment.\n\nIn this demo, you'll be introduced to the abilities of a Dragon Druid, and test your strength, courage, and cunning. \n\nSo strap on your headset, grab your controllers, and prepare to unleash the dragon within you!"}]}, "developer_name": "Sigils", "developer_privacy_policy_url": "https://sigils.studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Sigils Studio", "support_website_url": null, "website_url": "https://sigils.studio/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7443080685773994"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035390_882914603062741_7772687024572992577_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7Dnk_sE1I4Q7kNvgEr_cAs&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2Nxbpyb0Q6MXzKzMMyXcH0&oh=00_AYClxhK4TyEdJch3H5W-MXEm927ny8qKLvdZZ8sJdrklJA&oe=66EEA123"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sigils DEMO", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "RPG (Role Playing Games)", "id": "961172191044986"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1700780400, "lastRevision": {"nodes": [{"id": "7306221059459958", "release_type": "SCHEDULED", "administration_sta