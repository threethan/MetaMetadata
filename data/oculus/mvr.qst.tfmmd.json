_&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARahhIF6zoqEhoSgGPbYPDK&oh=00_AYBjrmTIwhhwpQs79ork5Dhv5oMlvOVVW90d689TaUxFVw&oe=66EC20D7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "mmd viewer", "keywords": [], "long_description": "\u65e5\u672c\u306eWindows\u30d5\u30ea\u30fc\u30bd\u30d5\u30c8\u30a6\u30a7\u30a2\u300c\u30df\u30af\u30df\u30af\n\u30c0\u30f3\u30b9\uff08MMD\uff09\u300d\u75283D\u30e2\u30c7\u30eb\u306e\u30e2\u30c7\u30eb\u30d3\u30e5\u30ef\u30fc\n\u3067\u3059\u3002MMD\u30e6\u30fc\u30b6\u30fc\u304c\u4f5c\u6210\u3057\u305f3D\u30e2\u30c7\u30eb\u3092\n\u4f7f\u7528\u3057\u3001\u30c0\u30f3\u30b9\u3092\u8e0a\u3089\u305b\u308b\u3053\u3068\u304c\u53ef\u80fd\u3067\u3059\u3002\n\u30a4\u30f3\u30bf\u30fc\u30cd\u30c3\u30c8\u4e0a\u306b\u306f\u3001MMD\u30e6\u30fc\u30b6\u30fc\u304c\u4f5c\u6210\n\u3057\u305f3D\u30e2\u30c7\u30eb\u3001\u30c0\u30f3\u30b9\u30e2\u30fc\u30b7\u30e7\u30f3\u3001\u66f2\u304c\u591a\u304f\n\u5b58\u5728\u3057\u307e\u3059\u3002\n\u305d\u308c\u3089\u306f\u3001\u307b\u307c\u7121\u6599\u306a\u306e\u3067\u3001WindowsPC\u7b49\u3067\n\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3001QUEST\u306b\u30b3\u30d4\u30fc\u3059\u308b\u3053\u3068\u3067\u3001\n\u591a\u304f\u306e3D\u30e2\u30c7\u30eb\u306e\u30c0\u30f3\u30b9\u3092\u697d\u3057\u3080\u3053\u3068\u304c\n\u53ef\u80fd\u3067\u3059\u3002\n\u307e\u305f\u30013D\u30e2\u30c7\u30eb\u3092\uff12\u4f53\u3001\u66f2\u30c0\u30f3\u30b9\u3092\uff13\u30bb\u30c3\u30c8\u3001\n3D\u30b9\u30c6\u30fc\u30b8\u30e2\u30c7\u30eb\u3092\uff13\u4f53\u30d7\u30ea\u30bb\u30c3\u30c8\u3057\u3066\u3042\u308a\n\u307e\u3059\u306e\u3067\u3001\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3001\u30b3\u30d4\u30fc\u7b49\u306e\u64cd\u4f5c\n\u306a\u3057\u3067\u3082\u3001\u30a2\u30d7\u30ea\u5358\u4f53\u3067\u3082\u697d\u3057\u3080\u3053\u3068\u304c\u53ef\u80fd\u3067\u3059\u3002\n3D\u30e2\u30c7\u30eb\u3092\u30e1\u30cb\u30e5\u30fc\u30bf\u30d6P5\u300c\u30de\u30ea\u30aa\u30cd\u30c3\u30c8\n\u30e2\u30fc\u30c9\u300d\u3067\u30ed\u30fc\u30c9\u3057\u3066\u3044\u30