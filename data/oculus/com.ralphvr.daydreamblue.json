0DMj7PmOr4rVUvF9iZfA9gL8ZadQ&oe=675431C3"}, {"file_name": "migrated_image.png", "id": "490634071823704", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162813_576647222476682_1691495687_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Bu1k8XNFiEQ7kNvgFN1nu6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUo4Ysz0Ibk1LOJLHMeBX-pq38GHHO9635k2_wzwCzyQ&oe=6754200B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Daydream Blue", "keywords": [], "long_description": "Daydream Blue, Gold Prize Winner in the 2015 Oculus Mobile VR Jam, puts a virtual valley at your fingertips. Mold the world to play golf, combine rocks and wood into a hatchet and chop down trees, play fetch with your robot buddy, and camp under the stars. In Daydream Blue, you play by a different set of rules:  your house is inside your mailbox, cooked coconuts are crafted into beachballs, and you control time with the clock on your backpack.\n\n\n\n\nWill you Daydream Blue?\n", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "RalphVR", "support_website_url": null, "website_url": "http://www.daydreamblue.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EXPLORATION", "SIMULATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": null, "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "624942722126462"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "886912888051537"}, {"status": "CANCELLED", "id": "861608880669057"}, {"status": "PUBLISH