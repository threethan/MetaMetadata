_2104833042_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZJwowsXia5kQ7kNvgGTmI69&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF5EJu_Ee6YGUNH46PsrlPC&oh=00_AYCyUSv18xikFOvrhS9IRCZmJgGTdTsbcpOsS_AVuNxPlg&oe=66EFFFC3"}, {"file_name": "migrated_image.png", "id": "490634071823704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162813_576647222476682_1691495687_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xjy1eF2grRAQ7kNvgHbgQEf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF5EJu_Ee6YGUNH46PsrlPC&oh=00_AYAlpeqb2rNVJK6GdKbg_AldVYy1mZdpSbwdGefg4oK1UA&oe=66EFEE0B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Daydream Blue", "keywords": [], "long_description": "Daydream Blue, Gold Prize Winner in the 2015 Oculus Mobile VR Jam, puts a virtual valley at your fingertips. Mold the world to play golf, combine rocks and wood into a hatchet and chop down trees, play fetch with your robot buddy, and camp under the stars. In Daydream Blue, you play by a different set of rules:  your house is inside your mailbox, cooked coconuts are crafted into beachballs, and you control time with the clock on your backpack.\n\n\n\n\nWill you Daydream Blue?\n", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "RalphVR", "support_website_url": null, "website_url": "http://www.daydreamblue.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EXPLORATION", "SIMULATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": null, "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "62494