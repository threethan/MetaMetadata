ZH3pIX4yxCTz&oh=00_AYB9q1C6bcYoi7BtybgRIFkwQZJTUgivPhNieB6YXzFL5g&oe=66EABF43"}, {"file_name": "migrated_image.png", "id": "208826913686206", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12680297_1892763980951337_8298338112539459584_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WoXXAId2b0QQ7kNvgHFQ1_2&_nc_ht=scontent.oculuscdn.com&_nc_gid=APIGpacGrj_ZH3pIX4yxCTz&oh=00_AYD_H4_7kS4eQs_U5hmQWYN7OWdk9ZuAb-gI3I_gzNOMKg&oe=66EAAF2A"}, {"file_name": "migrated_image.png", "id": "139433187474552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410343_372469353086254_3448822755451994112_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZK_9w25cmnMQ7kNvgEh_2p8&_nc_ht=scontent.oculuscdn.com&_nc_gid=APIGpacGrj_ZH3pIX4yxCTz&oh=00_AYD8I9rM61bs2g0p44HBCgsZI0HEt5o3q4WdGtCSBfRjMQ&oe=66EABA12"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Daydream Blue", "keywords": ["relaxing", "casual", "multiplayer", "social", "funny"], "long_description": "There is a magical world where games, smiles, and a serene lake beckons.  A place where your robot pal lives.  Where items waiting to be crafted share warm afternoons with friends waiting to be found.  A place once out of reach - but now accessible from anywhere in the world through the dimension-piercing magic of virtual reality.  \n\n\nThis place is called Daydream Blue.\n\n\nThe lake is there, and a raft for you to lie upon.  Your campsite, too. A tent rests just aside the fire under a glowering starlit dusk.  Nearby, your favorite rock and stones perfect for skipping.  Trees high as the heavens.  This is where you can smile, where you can connect with all those other people across the world looking for a little relaxation and lot of fun.\n\n\nMultiplayer?  Yep.  Fishing?  Of course.  UFO invasions?  If you know where to look.  Daydream Blue explores a reality just outside ours. It\u2019s a feeling out there in the space between hassles.  It\u2019s your own place.  Your own dream.", "short_description": "Relax, play games, and build friendships, all inside the world of Daydream Blue."}]}, "developer_name": null, "developer_privacy_policy_url": "http://ralphvr.github.io/", "developer_terms_of_service_url": "http://www.daydreamblue.com/", "publisher_name": "RalphVR", "support_website_url": null, "website_url": "http://www.daydreamblue.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION", "RPG", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "904546173562937"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138848_1674193699558666_2375952895712428032_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EehoONNeWRQQ7kNvgFyao1h&_nc_ht=scontent.oculuscdn.com&_nc_gid=APIGpacGrj_ZH3pIX4yxCTz&oh=00_AYCJXqX5s1Rikd6bbGK0TJdJ0krCHluxRX9tJNrZZCnFIQ&oe=66EAB36D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Daydream Blue", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1442818800, "lastRevision": {"nodes": [{"id": "1054252104609537", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "888915797823449", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", 