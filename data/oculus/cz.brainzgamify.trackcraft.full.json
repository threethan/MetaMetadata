_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYAGFqr4fMejrEJaxhGQaXpzwn92LzCQmhNlV_GPzw6zKw&oe=66D6EEA3"}, {"file_name": "rd still vr_1.1.4.png", "id": "528545392967530", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75508952_528545396300863_1444802787237307590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pan8KHxWRsMQ7kNvgEn9ZIu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYB1CZRmWPJMwlje0kjAl46YOkzXded2Gm5_0ehrdltxTA&oe=66D6EA7F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KV 1.png", "id": "1035717108228383", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_1035717111561716_4865861407543801459_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5hIUZ1oFDXMQ7kNvgEIZW5z&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYDmYeJVylvtIG53RP-1mPouAbiQlGi0mK_Npv9ZrHTaWQ&oe=66D7006E"}, "display_name": "Track Craft", "keywords": ["track", "craft", "racing", "car", "mixed"], "long_description": "**Track Craft is a mixed-reality racing game where you can turn your surroundings into a racetrack. Craft tracks, and share them with friends. Race. Repeat.**\n\n\n# ULTIMATE MR PLAYGROUND \n\nUse your surroundings and turn them into a mixed-reality race track.\n\n{1272215014134973}\n\n\n\n# EXPLORE DIFFERENT WORLDS\n\nGet behind the wheel and experience the 104 pre-built tracks spread across 5 different worlds. Each brings new mechanics, challenges, cars, and skins to unlock.\n\n{2499265100265459}\n\n\n# CRAFT YOUR OWN TRACKS\n\nCreate tracks intuitively thanks to full hand tracking and share them online. Or just race on new tracks created by the community every day.\n\n{1695057567991201}\n\n# ONLINE MULTIPLAYER\n\nPlay and Craft with your friends at home or online with players across the globe.\n\n{1046525373656002}\n\n\n# BUILD UP YOUR COLLECTION\n\nUnlock new exciting cars by collecting stars.\n\n{850050203892697}\n\n\n# THE FUN NEVER ENDS\n\n\n\nAvailable on Quest 3, Quest Pro, and Quest 2.", "short_description": "CRAFT. SHARE. RACE. REPEAT.\n\nTrack Craft is a mixed-reality racing game where you can turn your surroundings into a racetrack. Craft tracks, Share them with friends. Race. Repeat.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.gamify.cz/privacy-policy", "developer_terms_of_service_url": "https://www.gamify.cz/terms-of-service", "publisher_name": "Brainz Gamify s.r.o.", "support_website_url": null, "website_url": "https://www.trackcraft.cz/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7299537410148571"}, "review_messages": ["", "VRC correction regarding Terms of Service violation", "Hello, flagging that the first line of the short description seems to have formatting errors. If the intention is bolding or adjusting copy, an error is in place where special characters are being shown:\n\n#**CRAFT. SHARE. RACE. REPEAT.**\n"]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86594851_470741182550369_8126739762120011575_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XTvk8KULaAUQ7kNvgE3JexO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYCD1bt3XdOFNXJVP35Vry7Yn8puYK3MHXMDXKmmqdWSBg&oe=66D6DBEA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Track Craft", "platform": "A