9954"}, {"file_name": "sc11 (1).png", "id": "748117920441316", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_748117923774649_4364177760068745790_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8AA1oIptc5oQ7kNvgGRGOKn&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbBXtkGXjOGG7xj3RpG43F-bVUpUiVPdiwE-WgHz4-IQ&oe=66D59679"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "698424879019836", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974606_698424882353169_6437639616530020312_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kU47QxFzHdgQ7kNvgHHCy7X&_nc_ht=scontent.oculuscdn.com&oh=00_AYCdo0AsZTKOZ72dy4eeUrJSk3MV8ZyKXMVuYjpAvKHZJw&oe=66D5B568"}, "display_name": "Track Craft", "keywords": [], "long_description": "Ever dreamt of racing toy cars through your home, creating imaginative tracks, and sharing the excitement with fellow players? \n\nTrack Craft makes it all possible.\n\n* 3 Unique Track Packs: Each with its own visual style, sound design, cars, and special pieces for unique gameplay.\n* Arcade Mode: Race and conquer over 50 levels.\n* New Car Physics: Experience guaranteed fun with our revamped car physics.\n* Free Drive: Roam freely around your home with toy cars based on your room mesh.\n* Custom Editor: Build tracks with simple blocks, special pieces, props, various materials, and more.\n* Community Sharing: Share your tracks and compete against other players.\n* Unlimited Community Levels: Endless possibilities created by the community.\n\nThe game is available on Quest 3, Quest Pro and Quest 2.\n\nUpcoming Features (the current version is paid early access, and we will be rolling out more incredible features in the following months):\n\n* Trackmania-Style Multiplayer\n* Asian Style Track Pack: New design, cars, and special pieces.\n* Improved Community Levels\n* Garage Feature\n* Live Multiplayer (2024)\n\nGet ready for a unique mixed reality experience with Track Craft!", "short_description": "Track Craft \u2014 where you turn your world into a mixed-reality playground!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.gamify.cz/privacy-policy", "developer_terms_of_service_url": "https://www.gamify.cz/terms-of-service", "publisher_name": "Brainz Gamify s.r.o.", "support_website_url": null, "website_url": "https://www.trackcraft.cz/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "673505748021099"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "430110146043211"}, {"status": "PUBLISHED", "id": "1747737802339431"}]}, "baseline_offer": {"id": "430110146043211"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724836260, "status": "PUBLISHED", "id": "430110146043211"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7221001684668811", "version": "2.40"}, "id": "6899762856734245", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5802051039897223", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7221001684668811"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes"