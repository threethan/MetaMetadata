5/57572940_1470820243801438_5369248229209341125_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h5DWOh-CiTkQ7kNvgEi21RM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCd-KCIeOgF2EefUcocGo4cU21HnJa7dQmeKwWSt01ow&oe=66DC3FD1"}, {"file_name": "TJ vR still 2_1.1.8.png", "id": "1199027898001704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348041_1199027901335037_7675997282911940636_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fQhQVZM1vh4Q7kNvgGkGy8M&_nc_ht=scontent.oculuscdn.com&oh=00_AYA61CzDrgeezRcq-Mpn0c-WJ5D8cka4IULB-ydTRP09ig&oe=66DC2B93"}, {"file_name": "sr mr still_1.1.1.png", "id": "1204815720835317", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348041_1204815724168650_4815988994423431141_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3-HCa0lD13IQ7kNvgFnGsqI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPMWK6aOczcEWhywkbxbgIsBxlgSoyi_UpCnKxwACw9Q&oe=66DC4E19"}, {"file_name": "sd still 3rd3_1.1.13.png", "id": "1160293758530776", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003231_1160293761864109_6378340370639651060_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hqcyy7VX4s8Q7kNvgEtvmKO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbA1TGoHme39NCy7uLkl-zt4hGRpCBVjVVpzUDqx5eTA&oe=66DC34A3"}, {"file_name": "rd still vr_1.1.4.png", "id": "528545392967530", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75508952_528545396300863_1444802787237307590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7U9_RUjQ7dAQ7kNvgHKlG6i&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9JZXUWwmpebowRbYkzbmJaXM1nVzrWJo6Dw6FAJG3qg&oe=66DC307F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KV 1.png", "id": "1035717108228383", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_1035717111561716_4865861407543801459_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ceqq8l-G62gQ7kNvgGPcXuZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoNTdgHSNJu2JxnTNTdf9BzgDikpb6AHKxkI2O96RwTg&oe=66DC466E"}, "display_name": "Track Craft", "keywords": ["track", "craft", "racing", "car", "mixed"], "long_description": "**Track Craft is a mixed-reality racing game where you can turn your surroundings into a racetrack. Craft tracks, and share them with friends. Race. Repeat.**\n\n\n# EXPLORE DIFFERENT WORLDS\n\nGet behind the wheel and experience the 104 pre-built tracks spread across 5 different worlds. Each brings new mechanics, challenges, cars, and skins to unlock.\n\n{2499265100265459}\n\n\n# CRAFT YOUR OWN TRACKS\n\nCreate tracks intuitively thanks to full hand tracking and share them online. Or just race on new tracks created by the community every day.\n\n{1695057567991201}\n\n\n# ULTIMATE MR PLAYGROUND \n\nUse your surroundings and turn them into a mixed-reality race track.\n\n{1272215014134973}\n\n\n# ONLINE MULTIPLAYER\n\nPlay and Craft with your friends at home or online with players across the globe.\n\n{1046525373656002}\n\n\n# BUILD UP YOUR COLLECTION\n\nUnlock new exciting cars by collecting stars.\n\n{850050203892697}\n\n\n# THE FUN NEVER ENDS\n\n\n\nAvailable on Quest 3, Quest Pro, and Quest 2.", "short_description": "CRAFT. SHARE. RACE. REPEAT.\n\nTrack Craft is a mixed-reality racing game where you can turn your surroundings into a racetrack. Craft tracks, Share them with friends. Race. Repeat.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.gamify.cz/privacy-policy", "developer_terms_of_service_url": "https://www.gamify.cz/terms-of-service", "publisher_name": "Brainz Gamify s.r.o.", "support_website_url": null, "website_url": "https://www.trackcraft.cz/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_pro