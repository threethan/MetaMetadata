0_8512610445760542396_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wsafW7Czc-EQ7kNvgH4hXEX&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYCqOjxmYHwe9QUkdUeft62z73qKvd6UYgzWFe4L1mQP_w&oe=66D6ED45"}, {"file_name": "S7 (1).png", "id": "183743528061492", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982453_183743531394825_2264642617860965174_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MDSGMLmTsQUQ7kNvgEGdnw1&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYCpmjsRsH686XZHvOnDiIOXOA2awynGU9MA8BIUG57nkA&oe=66D6ED74"}, {"file_name": "sc 12 (2).png", "id": "357212356780710", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974798_357212360114043_8870245353045085890_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T2UOuzf6Sc8Q7kNvgGCwEJi&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYCYnM75qmRN4hPVfxFc6xolKfMKDqyFBX4SSmt5fWD4TA&oe=66D6EAD4"}, {"file_name": "sc11 (1).png", "id": "748117920441316", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_748117923774649_4364177760068745790_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8AA1oIptc5oQ7kNvgHP8uJM&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYAvxtMkhctsEBC-6-RN2PIcOnjVXjQfPxXjiHLAtF5kzw&oe=66D6E7F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "698424879019836", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974606_698424882353169_6437639616530020312_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kU47QxFzHdgQ7kNvgECEt8O&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACKK_snYqhYeeAtxTZvq-vc&oh=00_AYDCYpPtasM_oEurfoM4Eg2sZkiTG8eFl59iYZ9lU5X3Sw&oe=66D706E8"}, "display_name": "Track Craft", "keywords": [], "long_description": "Ever dreamt of racing toy cars through your home, creating imaginative tracks, and sharing the excitement with fellow players? \n\nTrack Craft makes it all possible.\n\n* 3 Unique Track Packs: Each with its own visual style, sound design, cars, and special pieces for unique gameplay.\n* Arcade Mode: Race and conquer over 50 levels.\n* New Car Physics: Experience guaranteed fun with our revamped car physics.\n* Free Drive: Roam freely around your home with toy cars based on your room mesh.\n* Custom Editor: Build tracks with simple blocks, special pieces, props, various materials, and more.\n* Community Sharing: Share your tracks and compete against other players.\n* Unlimited Community Levels: Endless possibilities created by the community.\n\nThe game is available on Quest 3, Quest Pro and Quest 2.\n\nUpcoming Features (the current version is paid early access, and we will be rolling out more incredible features in the following months):\n\n* Trackmania-Style Multiplayer\n* Asian Style Track Pack: New design, cars, and special pieces.\n* Improved Community Levels\n* Garage Feature\n* Live Multiplayer (2024)\n\nGet ready for a unique mixed reality experience with Track Craft!", "short_description": "Track Craft \u2014 where you turn your world into a mixed-reality playground!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.gamify.cz/privacy-policy", "developer_terms_of_service_url": "https://www.gamify.cz/terms-of-service", "publisher_name": "Brainz Gamify s.r.o.", "support_website_url": null, "website_url": "https://www.trackcraft.cz/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [],