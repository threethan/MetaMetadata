cription": "A VIRTUAL SANCTUARY\nLevitate bridges inner imagination and engaging virtual experiences to create immersive realms that foster deep and meaningful meditative practices.\n \nDESIGNED BY EXPERTS\nA team of experienced meditation practitioners teamed up with clinical psychologists, visual artists, voice talent, musicians, and app programmers to develop worlds that are beautiful, engaging, and healing.\n \nINFORMED BY PSYCHOLOGY\nMeditation and mindfulness practices have become a core part of psychological therapy, proven by research to enhance wellness, reduce stress, and promote inner balance.\n \nEVOLVING REALMS\nLevitate will continue to develop new worlds and experiences for users, creating choices for your unique goals and style of meditative practice.", "short_description": "Levitate designs spaces to balance inner and outer experiences.  These realms are created to illuminate self reflection and well-being."}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.termly.io/document/privacy-policy/32d2f504-0d9e-4402-a53b-bb85c20ea5fd", "developer_terms_of_service_url": null, "publisher_name": "Kai VR, Inc.", "support_website_url": null, "website_url": "https://levitate.world/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "742241603610483"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1294111337