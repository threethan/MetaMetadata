.com/v/t64.5771-25/39003274_1510615402822107_4486380117244694869_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n870gRxN8dMQ7kNvgF2S-pu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMjB7M5obDEIInfbO4peE40&oh=00_AYDILBEtLsp0XUeYcb101MVyJIt7g2oWOXAX8YwbDWsssw&oe=66F14701"}, {"file_name": "BalloonSubmissionScreenshot8.png", "id": "7622309104472023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_7622309114472022_2835181190969317424_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-IXZWcY0LdEQ7kNvgEdAseW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMjB7M5obDEIInfbO4peE40&oh=00_AYALc-8S9W9r7CFfr0TiYu67C1OqbQwq0CkFe_lP7CHjkQ&oe=66F14DE3"}, {"file_name": "BalloonSubmissionScreenshot4.png", "id": "1352299155722919", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982710_1352299159056252_5704974820123579807_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Y7drAFS9QAQ7kNvgFP0kcF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMjB7M5obDEIInfbO4peE40&oh=00_AYCCwEQHl_CgnBVk87OeO1VimIPOVNhaZA62SqYuZhT08g&oe=66F15796"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER_ART_01 (1).png", "id": "772685718326861", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223484_772685721660194_8856219106640634409_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qc21HDIkFj8Q7kNvgHGhOpo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMjB7M5obDEIInfbO4peE40&oh=00_AYC75SaAceMvy6CYAk-8NipXLs_aC2FztHKVbT_yHzw5Mg&oe=66F1612C"}, "display_name": "Balloon", "keywords": [], "long_description": "Balloon delivers a controller-less mixed reality experience that seamlessly integrates virtual elements into your real-world environment.\n\nWe created a full spatial audio identity for Balloon providing 360 degrees of sound that delights with original music, informs people with dynamic and high quality text-to-speech, directs people to objects of importance even if out of view, and adds realism and reinforces people\u2019s actions in surprisingly natural and delightful ways.\n\nThe result is