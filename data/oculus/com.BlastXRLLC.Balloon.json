p a virtual balloon in the air while moving through your real space, colliding and interacting with spatial obstacles."}]}, "developer_name": "Afloat Studios", "developer_privacy_policy_url": "https://www.balloongame.app/privacy", "developer_terms_of_service_url": null, "publisher_name": "Blast XR LLC", "support_website_url": null, "website_url": "https://www.balloongame.app/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7555404114553281"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569425_467539302456168_183827402198947527_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8gciyj4hihQQ7kNvgHJyyjd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMjB7M5obDEIInfbO4peE40&oh=00_AYDrY161ht_mUteOmOfGsSSPlKZFVtCpZaEgRTZ7bmOYBA&oe=66F149D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Balloon", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1717191396, "lastRevision": {"nodes": [{"id": "7555404141219945", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7555404101219949", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platf