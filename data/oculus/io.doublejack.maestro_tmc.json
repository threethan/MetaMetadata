//scontent.oculuscdn.com/v/t64.5771-25/38982658_1076061473308851_7642840722211962573_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=izwCXqobI_kQ7kNvgEZ0uMe&_nc_ht=scontent.oculuscdn.com&oh=00_AYARVPCywMDAD_KTjIea0xtUqd6dYwg7cyJFgPs9WQkJ3A&oe=66DAE63C"}, {"file_name": "Salute.png", "id": "3075149322814927", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031378_3075149326148260_7294879501717846732_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xX7wWEhr2ioQ7kNvgFAsgJb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcAxQBflRmJaNty4MgqM6oWs7j28Lu1B9oLnCkjiV0lg&oe=66DAE4DE"}, {"file_name": "Crescendo Accent 1.png", "id": "1198335817645449", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1198335820978782_4282314951259127723_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_eVlQI9ciIQ7kNvgGCbn3w&_nc_ht=scontent.oculuscdn.com&oh=00_AYAOyfEExzydWq5clrZ3KO_N1LkhGMWcyb-nFKsr47MOiQ&oe=66DAD464"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "5224521377585105", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974671_5224521380918438_3554792086355919042_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7lCpRFsFIhMQ7kNvgFljNYI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtpEV4m546IdsEYy4b08KabrzCL-iqT0k8JrIwtTNBwg&oe=66DAEDA3"}, "display_name": "Maestro: The Masterclass", "keywords": [], "long_description": "Step on the podium and become a true orchestra conductor in Maestro: The Masterclass. Play hands free or grab a chopstick and master the real hands motions that command the orchestra through an off the rail conducting masterclass that culminates with an epic symphonic concert in a packed opera house. Good luck, Maestro!\n\n- Step into a gorgeous opera house packed with a thousand music fans, face a mammoth orchestra of over two hundred virtuosos, and get ready to throw some serious power moves.\n- Learn to beat tempo, cue musicians or guide crescendos with the power of your hands only\n- Conduct all music genres from Electro to Jazz, Hip Hop and finish up with an epic Symphonic music concert to become a true Maestro!", "short_description": "Step on the podium and become a true orchestra conductor in Maestro: The Masterclass. Play hands free or grab a chopstick and master the real hands motions that command the orchestra through an off the rail conducting masterclass that culminates with an epic symphonic concert in a packed opera house. Good luck, Maestro!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vQchKcAJz15RJwRzoOYKTPM2xqzk_3USAS7mSXQVI63k8zBRTkP6BVlRifGdSjSa5ALGtGgQmQYRWck/pub", "developer_terms_of_service_url": null, "publisher_name": "Double Jack", "support_website_url": null, "website_url": "https://maestro-game.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "748704793107144"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "461509242157906"}]}, "baseline_offer": {"id": "461509242157906"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1660860000, "status": "PUBLISHED", "id": "461509242157906"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6741777065928283", "version": "0.0.212"}, "id": "426610022635003", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4813149252124417", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6741777065928283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "426610022635003"}]}, "change_log": "Maestri! \ud83c\udf93\u200b\n\nWe are delighted to announce the release of a new free update!\nWe want to make Culture accessible to everyone, so we have added the option to make the experience fully playable with controllers!\u200b\n\nConcert\n- Updated gameplay score for Verdi - Dies Irae.\n \nSubtitles\n- Added subtitles for the Masterclass and translations for all 10 languages\n- Subtitles can be toggled from the main menu\n \nLocalization\n- Translation fixes in various languages\n- More content was localised (ie: end of concert quotes, game logo)\n\nController support\n- You can now play Maestro: The Masterclass with controllers, and haptics!\n- General bug fixing & improvements\n- Improved audio issue that could cause severe latencies\n- Tweaks to audio effects\n- Tweaks to improve performance\n", "created_date": 1706190432, "id": "6741777065928283", "version": "0.0.212", "version_code": 212, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4813149252124417", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6741777065928283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1704906643, "id": "6687589104680413", "version": "0.0.211", "version_code": 211, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4813149252124417", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6741777065928283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1699637986, "id": "6469124226526903", "version": "0.0.210", "version_code": 210, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4813149252124417", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6741777065928283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1697209873, "id": "6366431883462805", "version": "0.0.209", "version_code": 209, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4813149252124417", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6741777065928283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "426610022635003"}]}, "change_log": "Maestri! \nWe're excited to announce a new update for Maestro: The Masterclass. We have some improvements for you!\n\n9 new languages:\n- English\n- Spanish\n- Italian\n- French \n- German \n- Japanese \n- Korean \n- Russian  \n- Chinese (trad./simpl.) \n\nPerformance improvements:\n- Musicians are now rendered at different frame rates giving us some extra performance.\n- HMD state polling optimisation, regular checks such as input validity or whether the headset is being worn are done less often.\n\nBug fixes:\n- Input pop-ups can no longer be displayed during level transitions.\n- Fermata and Dynamics validation conditions adjustments.\n- Audio adjustments throughout the game.\n- Interface anti-aliasing visual improvements.\n\nOther updates:\n- New hand tracking system, with new hand models. \n- The baton is now automatically adjusted based on the hand pose. ", "created_date": 1682344194, "id": "5788430841262915", "version": "0.0.205", "version_code": 205, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}