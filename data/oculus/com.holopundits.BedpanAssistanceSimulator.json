_nc_sid=6e7a0a&_nc_ohc=itOgc-5Q8CIQ7kNvgFJd0_J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-pHkVs7ZXeoq8XeKgjcS_8APIr6uOn-RWmgvO9Jyryg&oe=676BFEF7"}, {"file_name": "Bedpan_simulator_SS_02.png", "id": "440396755794727", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031647_440396759128060_448295323192632376_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AZTU1ApG5igQ7kNvgFm0HWw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKMa0uA72lVwU4JQBeW2eBWrJrh2pmHZfRo5ExkI8yEw&oe=676C08CD"}, {"file_name": "Bedpan_simulator_SS_03.png", "id": "955295586479144", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974589_955295589812477_1715534801932147904_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dYoF82ci3UAQ7kNvgHFLiZZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNtp20h_MuHY6B56lGnJ8uutTIQ9wxdL_mwFMhaaxX4Q&oe=676BE27A"}, {"file_name": "Bedpan_simulator_SS_04.png", "id": "527933043570821", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974891_527933046904154_6902961956548712077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oabYdXnChWMQ7kNvgHxbw7m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBz8JYOuuWXz8yDPaftUrt4OgwhSijksf5R-vUeMLgPRA&oe=676BDC47"}, {"file_name": "Bedpan_simulator_SS_05.png", "id": "2529029040628033", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982539_2529029043961366_3304790259249323740_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWcCmPDcQcoQ7kNvgHZxHuC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6LC2lBGu0ousO9MDV9YOHb1-1KrjSQljSCKUL_ZV1kg&oe=676BD391"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Bedpan_simulator_SS_03.png", "id": "1097577158716427", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974642_1097577162049760_3289320270198962489_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ukXL0m-_DM0Q7kNvgGZ7Y7b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqdXrKDVSQK0pMcC_RTWajZEqYPi92PKT9XIgT32Zz6A&oe=676BF13F"}, "display_name": "Bedpan Assistance Simulator", "keywords": ["CNA", "nurse", "nursing", "bedpan", "healthcare"], "long_description": "The Bedpan Assistance tutorial immerses Certified Nursing Assistant (CNA) trainees in a realistic virtual environment to practice and master the skills required for providing proper bedpan assistance. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives:  \n- Remembering the steps and protocols for bedpan assistance \n- Understanding the importance of patient comfort and dignity during the process \n- Applying the correct techniques for positioning and assisting patients \n- Analyzing the situation to provide appropriate care tailored to individual patient needs \n-  Evaluating the effectiveness of the assistance provided and making necessary adjustments \n- Creating a comfortable and respectful environment for patients requiring bedpan assistance.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform bedpan assistance effectively and compassionately in real-world clinical settings. ", "short_description": "Designed to train CNAs in providing proper bedpan assistance through interactive, hands-on practice with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "su