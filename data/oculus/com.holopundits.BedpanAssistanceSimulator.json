6675029345939", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982549_1186675032679272_4057784636743753083_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J3oGktYbW3sQ7kNvgHELKrz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVwfXFoGWiqjOKmRV9hglLlwX2KbRTabRmZVWVhqw4_g&oe=66CDB171"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1144586286617894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031613_1144586289951227_3958037237275083766_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXdb7CFAGPAQ7kNvgFFBC8R&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIOabEgDxPmGhJ8obZeD1mqiN46465w-GVEk8hACI_IQ&oe=66CDB3BD"}, "display_name": "Bedpan Assistance Simulator", "keywords": [], "long_description": "The Bedpan Assistance tutorial immerses Certified Nursing Assistant (CNA) trainees in a realistic virtual environment to practice and master the skills required for providing proper bedpan assistance. This application guides users through each step of the process, including patient positioning, maintaining hygiene, and ensuring patient comfort and dignity.  \n\n# Learning Objectives:  \n- Remembering the steps and protocols for bedpan assistance \n- Understanding the importance of patient comfort and dignity during the process \n- Applying the correct techniques for positioning and assisting patients \n- Analyzing the situation to provide appropriate care tailored to individual patient needs \n-  Evaluating the effectiveness of the assistance provided and making necessary adjustments \n- Creating a comfortable and respectful environment for patients requiring bedpan assistance.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform bedpan assistance effectively and compassionately in real-world clinical settings. ", "short_description": "Designed to train CNAs in providing proper bedpan assistance through interactive, hands-on practice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6596900520434534"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1068937144647284"}]}, "baseline_offer": {"id": "1068937144647284"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722615191, "status": "PUBLISHED", "id": "1068937144647284"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6624829680974951", "version": "1.0"}, "id": "1602473733817451", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6596900503767869", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6624829680974951"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1602473733817451"}]}, "change_log": null, "created_date": 1722250612, "id": "6624829680974951", "version": "1.0", "version_code": 2, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null