90341133951", "locale": "en_US", "screenshots": [{"file_name": "Bedpan_simulator_SS_01.png", "id": "974221464732133", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75269591_974221468065466_8255603175675394048_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5uQyy9B6SoQQ7kNvgHyx2wi&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBomSuhG08A_ljRavrVhvmTfEgGF1_7ryq9cAt9eyas3g&oe=6787AE77"}, {"file_name": "Bedpan_simulator_SS_02.png", "id": "440396755794727", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031647_440396759128060_448295323192632376_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4byrOJiYEDIQ7kNvgGxaF_G&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBxmWcHoXqx_zLAp9S2s7KlgBP3JtTkhp_o0otYEfuHSA&oe=6787B84D"}, {"file_name": "Bedpan_simulator_SS_03.png", "id": "955295586479144", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974589_955295589812477_1715534801932147904_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RmHXrIeJJloQ7kNvgH3qM0r&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYConP0DvsDXB5WeIiGgjMVIsu72IWAnmpf69jNJEn5Tlw&oe=678791FA"}, {"file_name": "Bedpan_simulator_SS_04.png", "id": "527933043570821", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974891_527933046904154_6902961956548712077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7HBc6Zs1HBAQ7kNvgGi4sNw&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCxdcSmLpVCF8uIEu0dSt5bGJwYRwsfqG2bQMo4piqI7w&oe=67878BC7"}, {"file_name": "Bedpan_simulator_SS_05.png", "id": "2529029040628033", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982539_2529029043961366_3304790259249323740_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zUSYRjmYS-4Q7kNvgFKd_h3&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC0_bONQREZmmbqc5xRvqbQEio1r2p9ELVMXafE-z6SEA&oe=67878311"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Bedpan_simulator_SS_03.png", "id": "1097577158716427", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974642_1097577162049760_3289320270198962489_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V7SAYB0uXr4Q7kNvgHqEpDc&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDB6O74sbnwID7abntY8Iz447fdQ1UWy80DkkdKTaiMFQ&oe=6787A0BF"}, "display_name": "Bedpan Assistance Simulator", "keywords": ["CNA", "nurse", "nursing", "bedpan", "healthcare"], "long_description": "The Bedpan Assistance tutorial immerses Certified Nursing Assistant (CNA) trainees in a realistic virtual environment to practice and master the skills required for providing proper bedpan assistance. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives:  \n- Remembering the steps and protocols for bedpan assistance \n- Understanding the importance of patient comfort and dignity during the process \n- Applying the correct techniques for positioning and assisting patients \n- Analyzing the situation to provide appropriate care tailored to individual patient needs \n-  Evaluating the effectiveness of the assistance provided and making necessary adjustments \n- Creating a comfortable and respectful environment for patients requiring bedpan assistance.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform bedpan assistance effectively and compassionately in real-world clinical settings. ", "short_description": "Designed to train CNAs in providing proper bedpan assistance through interactive, hands-on practice with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7460604627397448"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031647_925824962828131_1852857316449281672_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iRNaVLYPqYIQ7kNvgGvN_px&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDUZyUDpBxr0px09Zjl7HvME_64Osk9FeUqeB8vwnx-nA&oe=678799D6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bedpan Assistance Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1722615191, "lastRevision": {"nodes": [{"id": "6596900540434532", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pd