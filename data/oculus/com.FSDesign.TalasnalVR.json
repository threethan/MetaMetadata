png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2IpbyXTLSCcQ7kNvgHkRRvW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDl_ikX7qB-Ta1jkeCgIWZ6Hr_w2TDeAyDsOXx-lueLXA&oe=66F957A5"}, {"file_name": "Talasnal_Cover_Art_1.png", "id": "478020117148149", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542962_478020120481482_2335875178620447945_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ko2aLSU9sd4Q7kNvgHaZCSn&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-OxQcA-y0Hsa7EZSFw4JplzRyZiPQt3VBR-YWH-aYSw&oe=66F936E9"}]}, "id": "593393559002660", "locale": "en_US", "screenshots": [{"file_name": "Talasnal_Screenshot_1.png", "id": "2488119967997651", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_2488119971330984_324807568160469793_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=umhNQgyJ5pUQ7kNvgG-yzPp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBd2BCdt5k1LZL-gYOghiwswljuP1b4xy3esSU77FOJQ&oe=66F958F6"}, {"file_name": "Talasnal_Screenshot_2.png", "id": "437888675024500", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75307246_437888681691166_4385571175614557467_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ggTn3icQVoAQ7kNvgG9vfu4&_nc_ht=scontent.oculuscdn.com&oh=00_AYDX4E0Ei0Cbo3nsSW_YB48cqE5BLcwnJkFTEF2y8Day2w&oe=66F95331"}, {"file_name": "Talasnal_Screenshot_3.png", "id": "2002023723518923", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375756_2002023726852256_8558703323763451720_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Q5EVI3IwtYQ7kNvgEwD0zZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAe7_w8vxfFN2Ei0UNtwyVGHjzEvgxmw3qlRg75g4ENSA&oe=66F938D3"}, {"file_name": "Talasnal_Screenshot_4.png", "id": "1277408626339806", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_1277408633006472_263758744334772154_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v2GH8iuO4-wQ7kNvgGGzhkH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvhSNko1r1smM1McTaSZSAyriogSp36DIZ-7HxgfzwBg&oe=66F93D91"}, {"file_name": "Talasnal_Screenshot_5.png", "id": "811622046873538", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_811622050206871_7484775287227675262_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AqTh_nUjb8QQ7kNvgFjLMhD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCG-GO2cQOVF35raHJbUULQb3b8Kab9zSu-mt7jvIAxQA&oe=66F93F5C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Talasnal House VR", "keywords": [], "long_description": "The exhibition of the Ethnographic Museum Dr. Louz\u00e3 Henriques (opened in 2020) articulates the dimensions of the dominant Portuguese paradigm until the 50s and 60s of the 20th century, corresponding generically to the \"Rural World.\"\n\nThe museographic narrative presented in the exhibition circuit was intended to move away from a representation often associated with the idealization of rural life, either for its emphasis or for the condemnation of its inhuman rudeness.\n\nThe Virtual Tour is an integral part of this circuit. It allows the visit to a typical house of Serra da Lous\u00e3, characterized essentially by its construction in slabs of shale and wood in the jambs, lintels, and aprons. Several specific artifacts are integrated into the house, reinforcing the richness and complexity of some of the numerous human activities in the \"Rural World.\"", "short_description": "A virtual visit to a 20th-century traditional house in the village of Talasnal, located in Serra da Louz\u00e3, Portugal."}]}, "developer_name": "Fernando Sousa", "developer_privacy_policy_url": "https://privacypolicytalasnalhousevr.wordpress.com/2022/08/02/talasnal-house-vr/", "developer_terms_of_service_url": null, "publisher_name": "FSDesign", "support_website_url": null, "website_url": "https://www.behance.net/fernando-sousa", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUME