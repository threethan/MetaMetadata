vgH9LX_E&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAusePC-EPZ6Bj2xboSkGD5EhkxpBAglY4L4M0VvHgGzA&oe=670FA711"}, {"file_name": "Talasnal_Screenshot_5.png", "id": "811622046873538", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57572936_811622050206871_7484775287227675262_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y3ieKeilMtsQ7kNvgHVb58p&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCoYPh6NHuOyeBdA6Bt-AFrKCqrxqtnmuIGxFtEatWlzw&oe=670FA8DC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Talasnal House VR", "keywords": [], "long_description": "The exhibition of the Ethnographic Museum Dr. Louz\u00e3 Henriques (opened in 2020) articulates the dimensions of the dominant Portuguese paradigm until the 50s and 60s of the 20th century, corresponding generically to the \"Rural World.\"\n\nThe museographic narrative presented in the exhibition circuit was intended to move away from a representation often associated with the idealization of rural life, either for its emphasis or for the condemnation of its inhuman rudeness.\n\nThe Virtual Tour is an integral part of this circuit. It allows the visit to a typical house of Serra da Lous\u00e3, characterized essentially by its construction in slabs of shale and wood in the jambs, lintels, and aprons. Several specific artifacts are integrated into the house, reinforcing the richness and complexity of some of the numerous human activities in the \"Rural World.\"", "short_description": "A virtual visit to a 20th-century traditional house in the village of Talasnal, located in Serra da Louz\u00e3, Portugal."}]}, "developer_name": "Fernando Sousa", "developer_privacy_policy_url": "https://privacypolicytalasnalhousevr.wordpress.com/2022/08/02/talasnal-house-vr/", "developer_terms_of_service_url": null, "publisher_name": "FSDesign", "support_website_url": null, "website_url": "https://www.behance.net/fernando-sousa", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags