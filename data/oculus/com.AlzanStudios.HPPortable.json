d": "293127905352109", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302221_293127908685442_8416832960410030877_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4igEYvZVSYQ7kNvgH0t3iP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3fwQGFOKytW8qIMhCovY6uQlKWFs89ZLILjTSkwoIvw&oe=67090BEB"}, {"file_name": "Screen Shot 2.png", "id": "713492899503439", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997713_713492902836772_6323854860762155694_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vIACqwFWxScQ7kNvgERu4BF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDy0qCxqxSpNRrxHLoYWtuW3YP5KZ9J0dnQ8lA6uqErqQ&oe=6708FC3E"}, {"file_name": "Screen Shot 5.png", "id": "741935073032826", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203624_741935076366159_1346622421496653553_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A0h2sWsPnJ4Q7kNvgHoK8_k&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfYBDrWui-nXsvTOyCUXqZNywXA2snqkawq9hpV901yA&oe=670927A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Thumbnail.png", "id": "633850310589484", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031457_633850313922817_752894717263523968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2IVRH8HyG0Q7kNvgFezx7a&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEPWboIGDMQNfGrGK-IycmU4BI1I_bH2ps7K_F4K5PMA&oe=6709111E"}, "display_name": "Holopoint: Oculus Edition", "keywords": ["Archery", "Hologram", "Wave", "Arrow", "Quiver"], "long_description": "Holopoint is pure archery madness. Fight your way through waves of responsive targets, samurai, and highly dangerous ninjas - all while drawing, nocking, and shooting your arrows as quickly as possible. \n\nHolopoint is a skill based game where progression is based on player skill and training rather than unlocks. Like many arcade style games, personal progress and a high score is the goal. This game quickly becomes difficult and requires an active mindset. Holopoint is designed so that only a few determined archers will reach the last wave.\n\nWARNING: THIS GAME GETS INTENSE. REMEMBER TO BREATHE AND TAKE BREAKS.", "short_description": "Holopoint is pure archery madness. Fight your way through waves of responsive targets, samurai, and highly dangerous ninjas - all while drawing, nocking, and shooting your arrows as quickly as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.alzanstudios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Alzan Studios, LLC", "support_website_url": "https://www.alzanstudios.com/contact", "website_url": "http://www.alzanstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "242358471386267"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PUBLISHED", "id": "3866884890225269"}, {"status": "PUBLISHED", "id": "330227858401075"}, {"status": "PENDING", "id": "1992016621182522"}, {"status": "PUBLISHED", "id": "483350939399094"}, {"status": "PUBLISHED", "id": "706543204704469"}, {"status": "PENDING", "id": "1295693981824515"}, {"status": "PUBLISHED", "id": "549058256244600"}, {"status": "PUBLISHED", "id": "687832922645464"}]}, "baseline_offer": {"id": "3866884890225269"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1714749720, "status": "PUBLISHED", "id": "3866884890225269"}]}, "liveChannel": {"nodes": [{"latest_supported_