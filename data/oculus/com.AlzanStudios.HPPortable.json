}, {"file_name": "Screen Shot 4.png", "id": "293127905352109", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302221_293127908685442_8416832960410030877_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AqAJ65P4yvoQ7kNvgEh_YRo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfABmbIEMwrzlbJvGmhmKaXI3oq-yCGVvoHefiCOAb-Q&oe=673B24EB"}, {"file_name": "Screen Shot 2.png", "id": "713492899503439", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997713_713492902836772_6323854860762155694_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yizaZ1SnXw4Q7kNvgExul8F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxsX3OcjpwyanDZxStL5L30vCNnaNl1l2qhJ2DM-Iraw&oe=673B153E"}, {"file_name": "Screen Shot 5.png", "id": "741935073032826", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203624_741935076366159_1346622421496653553_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebHz2WKFxnsQ7kNvgEkRSbP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA-fimqfhxx_5yYOSkIe1gotGfHopX3-G_zlYDdCxcJDg&oe=673B40A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Thumbnail.png", "id": "633850310589484", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031457_633850313922817_752894717263523968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fweqde-0TnwQ7kNvgE4W5Bg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJHJkdgG7rIoULDj6AlFRn59QESE5zCJoqHJH4PdVviQ&oe=673B2A1E"}, "display_name": "Holopoint: Oculus Edition", "keywords": ["Archery", "Hologram", "Wave", "Arrow", "Quiver"], "long_description": "Holopoint is pure archery madness. Fight your way through waves of responsive targets, samurai, and highly dangerous ninjas - all while drawing, nocking, and shooting your arrows as quickly as possible. \n\nHolopoint is a skill based game where progression is based on player skill and training rather than unlocks. Like many arcade style games, personal progress and a high score is the goal. This game quickly becomes difficult and requires an active mindset. Holopoint is designed so that only a few determined archers will reach the last wave.\n\nWARNING: THIS GAME GETS INTENSE. REMEMBER TO BREATHE AND TAKE BREAKS.", "short_description": "Holopoint is pure archery madness. Fight your way through waves of responsive targets, samurai, and highly dangerous ninjas - all while drawing, nocking, and shooting your arrows as quickly as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.alzanstudios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Alzan Studios, LLC", "support_website_url": "https://www.alzanstudios.com/contact", "website_url": "http://www.alzanstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "242358471386267"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "468546489047133"}, {"status": "PUBLISHED", "id": "3866884890225269"}, {"status": "PUBLISHED", "id": "330227858401075"}, {"status": "PENDING", "id": "1992016621182522"}, {"status": "PUBLISHED", "id": "483350939399094"}, {"status": "PUBLISHED", "id": "706543204704469"}, {"status": "PENDING", "id": "1295693981824515"}, {"status": "PUBLISHED", "id": "549058256244600"}, {"status": "PUBLISHED", "id": "687832922645464"}]}, "baseline_offer": {"id": "3866884890