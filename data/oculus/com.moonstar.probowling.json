nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYACF5KwgKyP-nTe-wyNZaip1xEqHjRbTJLWp_cymaMfFA&oe=6756F32D"}, {"file_name": "migrated_image.png", "id": "286926512302306", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974503_2971137249627887_2738815793285300224_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dR1-hA14Ar8Q7kNvgE_xlts&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD_GDNywUQ3tWh6m7aI0N9KGNNv96seQobpQLbycDROSg&oe=6756D3E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen1a.png", "id": "796339428369487", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974474_796339431702820_5955742702304479792_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iPRR_fT0f1MQ7kNvgHkFJBq&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBxsL5iujrP6J0s3joY-u9QrQm-Z8_u3jNDnX2YdW2H4g&oe=6756F36A"}, "display_name": "Pro Bowling Social", "keywords": ["bowling", "tenpin", "multiplayer", "sport", "sports"], "long_description": "Bowling is a fun sports game but you need go to a club since it requires a large space to play. With Pro Bowling Social you can play bowling in the comfort of your home. \nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": "Moonstar Games", "developer_privacy_policy_url": "https://www.moonstargames.com/bowling_privacy.html"