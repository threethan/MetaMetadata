27887_2738815793285300224_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ptLg3MFPAFAQ7kNvgEnGQDK&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9O4TQOXSU2wRH0VxFiF1f_stkGmVg3O5aifjKhrnx_w&oe=66E17E62"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen1a.png", "id": "796339428369487", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974474_796339431702820_5955742702304479792_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iN_gZPb7QpwQ7kNvgF4JYfp&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGOAzT1RyJnFJ6-EOkbo-M2kICjf-TMXaBsRA5K2jfIA&oe=66E165AA"}, "display_name": "Pro Bowling Social", "keywords": ["bowling", "tenpin", "multiplayer", "sport", "sports"], "long_description": "Bowling is a fun sports game but you need go to a club since it requires a large space to play. With Pro Bowling Social you can play bowling in the comfort of your home. \nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": "Moonstar Games", "developer_privacy_policy_url": "https://www.moonstargames.com/bowling_privacy.html", "developer_terms_of_service_url": "https://www.moonstargames.com/bowling_terms.html", "publisher_name": "Moonstar Games", "support_website_url": "http://www.moonstargames.com/", "website_url": "https://www.moonstargames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "