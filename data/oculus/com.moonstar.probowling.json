nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCGgvR8oOiwcCHu5YtyQrMGzLMUQtQE0Be1AmTlPkPk0Q&oe=675EDC2D"}, {"file_name": "migrated_image.png", "id": "286926512302306", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974503_2971137249627887_2738815793285300224_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VR7iwywa1zgQ7kNvgEg_k-C&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBTR7ubytOJPRqzSRZ4zIAXycKNyE3iwGGtDfKvkcYpRw&oe=675EBCE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen1a.png", "id": "796339428369487", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974474_796339431702820_5955742702304479792_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NgJNCy7pIDAQ7kNvgEORhgg&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAd9rfo_zV6MH8LQgSbF76TsfwML_v2KYJjycerSvFI5Q&oe=675EDC6A"}, "display_name": "Pro Bowling Social", "keywords": ["bowling", "tenpin", "multiplayer", "sport", "sports"], "long_description": "Bowling is a fun sports game but you need go to a club since it requires a large space to play. With Pro Bowling Social you can play bowling in the comfort of your home. \nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": "Moonstar Games", "developer_privacy_policy_url": "https://www.moonstargames.com/bowling_privacy.html"