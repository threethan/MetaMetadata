dn.com/v/t64.5771-25/38982461_792421669248655_6240219278589277034_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pea1G6Stm0cQ7kNvgGNam1R&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwBKDA6hriDkjabk2VLAnky&oh=00_AYDeI3fkmL0Eez0KOTDBjKpSUt3-MTsoHG4i5NHOdfATQw&oe=66EAC315"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ChallengeBoxMainPoster.png", "id": "7555878047830023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003236_7555878051163356_6726549998324626644_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u5FImiA7hCEQ7kNvgF5yjM6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwBKDA6hriDkjabk2VLAnky&oh=00_AYBb0csYy-BzrpIyq3g9MFHxp59u-5BHWgj2yFteZz93uA&oe=66EAB898"}, "display_name": "ChallengeBox Boxing Fitness", "keywords": [], "long_description": "Workout with friends 1vs1.\n\nVariety of workouts to 1vs1:\n1. \ud83e\udd4a Boxing Challenge \n2. \u2692\ufe0f Rock Crusher Challenge\n3. \ud83c\udfb6 Lane Leap Challenge \n\n\ud83e\udd4a Boxing:\nA Full body boxing workout, makes you burn ~200 calories in less than 20 mins. \n\n\u2692\ufe0f Rock Crusher:\nBreak as many as rocks you can in 1 min with hammers in both hands.\nIt's a great STRESS BUSTER \ud83d\udc86\u200d\u2642\ufe0f. \n\n\ud83c\udfb6 Lane Leap:\nDodge the blocks, across lanes. \nGreat for LEGS \ud83e\uddb5 and Core \\\u035d(\u2021)\u035d/\n\nKey Features:\n- Real Time 1vs1 matches\n- Voice chat\n- Weekly Leaderboards\n- Tournaments\n\nJoin our growing community on discord and be part of building new features. \nhttps://discord.gg/NgYUXTtmPH \n\nTry for Free!", "short_description": "Workout with friends 1vs1. \n\nVariety of workouts to 1vs1:\n1. \ud83e\udd4a Boxing Challenge \n2. \u2692\ufe0f Rock Crusher Challenge\n3. \ud83c\udfb6 Lane Leap Challenge "}]}, "developer_name": null, "developer_privacy_policy_url": "https://challengebox.app/privacy", "developer_terms_of_service_url": "https://challengebox.app/toc", "publisher_name": "ChallengeBox LLC", "support_website_url": "https://challengeb