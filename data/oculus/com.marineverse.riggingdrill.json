b=1-7&_nc_sid=6e7a0a&_nc_ohc=ffH7rrc6K_UQ7kNvgFsFKc_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDPlHC9Q4LtSDTkGSCYbfwuloYPVr-z57tOyMGz9-H7CA&oe=672621A6"}, {"file_name": "3.png", "id": "1213412455994101", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974905_1213412459327434_6579542241075771915_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-atPIeOKbcQ7kNvgHedHLq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCBmy9dE3EN4nZHHzHivFpC94P0nQVElorol4WlrHK94Q&oe=67261E13"}, {"file_name": "7.png", "id": "649487337111032", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982468_649487343777698_7478990939834003881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BPC3-_80uRYQ7kNvgHogPe_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA8U2JA5bjUEauPe5PYl8m9zrylHj8jFTnIB_TZ9HHjkw&oe=67261368"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BY (1280 \u00d7 720 px) (2560 \u00d7 1440 px).png", "id": "808067730881455", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982710_808067734214788_8484893352327044465_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ybEzefrNV00Q7kNvgHsc4Vy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCvei-_YbTZqDVx6uHa1oqhAs28A7E_u-EuFrqQ_ddfgw&oe=67261CE2"}, "display_name": "Rigging Drill by MarineVerse", "keywords": ["sailing", "knot", "puzzle", "boat", "bowline"], "long_description": "From the creators of MarineVerse Cup comes Rigging Drill, an experimental and innovative game developed for people learning how to sail. Dive into the intricate and crucial art of boat rigging, fully immersed in the experience.\n\nLearn to tie sailing knots like the bowline using a real rope, mixed reality, and our unique voice control user interface.\n\nGet hands-on assembling a boat and gain invaluable insights into the world of sailing as you do.\n\nPLEASE NOTE: This is a brief, experimental experience. For a comprehensive sailing app, we recommend trying MarineVerse Cup.\n\n