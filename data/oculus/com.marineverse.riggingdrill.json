b=1-7&_nc_sid=6e7a0a&_nc_ohc=OaKiEB3nog4Q7kNvgGW9LJ4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCKRw5Si-G-5LoSmmhMaVKFYynKyZWTb9suTcj_gHi4Bw&oe=67407FA6"}, {"file_name": "3.png", "id": "1213412455994101", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974905_1213412459327434_6579542241075771915_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ev5mzc15v9wQ7kNvgH40juw&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD7LENI07xp3UblVkRXYK_B_7Odsmk-wL5vZ2Yec7zQNw&oe=67407C13"}, {"file_name": "7.png", "id": "649487337111032", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982468_649487343777698_7478990939834003881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qI5YsAqhKFgQ7kNvgFZ-g2t&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAe6wJ11kN54iOeZTUij3iT1_I6vsQT2dV7pPFNzPP3OA&oe=67407168"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BY (1280 \u00d7 720 px) (2560 \u00d7 1440 px).png", "id": "808067730881455", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982710_808067734214788_8484893352327044465_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=evOsrrP_ka4Q7kNvgH6kiZK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDTGdi80737F6vlK38N09Yad32ekib5pzcs0iAe0dXuEQ&oe=67407AE2"}, "display_name": "Rigging Drill by MarineVerse", "keywords": ["sailing", "knot", "puzzle", "boat", "bowline"], "long_description": "From the creators of MarineVerse Cup comes Rigging Drill, an experimental and innovative game developed for people learning how to sail. Dive into the intricate and crucial art of boat rigging, fully immersed in the experience.\n\nLearn to tie sailing knots like the bowline using a real rope, mixed reality, and our unique voice control user interface.\n\nGet hands-on assembling a boat and gain invaluable insights into the world of sailing as you do.\n\nPLEASE NOTE: This is a brief, experimental experience. For a comprehensive sailing app, we recommend trying MarineVerse Cup.\n\n