b=1-7&_nc_sid=6e7a0a&_nc_ohc=j4o_Z-FrTCgQ7kNvgFhR00s&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCs_xswMIK_Q7jomsNEd9X8bYuHbga34cqXuHYw48ztZQ&oe=6751A326"}, {"file_name": "3.png", "id": "1213412455994101", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974905_1213412459327434_6579542241075771915_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HOnz5bAt2tkQ7kNvgHlQHbA&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBilsKXt8JN05lgblMYvJoKCcb23DQi2FJX8nfDDiWCaQ&oe=67519F93"}, {"file_name": "7.png", "id": "649487337111032", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982468_649487343777698_7478990939834003881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MLtE5rjJAbgQ7kNvgEZBKl4&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC9jKHKp4eJ5KpSTYBr6gobnuWhFQ_CP3PDG-E6g9myzg&oe=675194E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BY (1280 \u00d7 720 px) (2560 \u00d7 1440 px).png", "id": "808067730881455", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982710_808067734214788_8484893352327044465_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-SnAcmEGC44Q7kNvgERLxB0&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC0zHyxfqXlXYp9tsHrUnF6Ch26HcuHvZ5iuSEFJ73G5g&oe=67519E62"}, "display_name": "Rigging Drill by MarineVerse", "keywords": ["sailing", "knot", "puzzle", "boat", "bowline"], "long_description": "From the creators of MarineVerse Cup comes Rigging Drill, an experimental and innovative game developed for people learning how to sail. Dive into the intricate and crucial art of boat rigging, fully immersed in the experience.\n\nLearn to tie sailing knots like the bowline using a real rope, mixed reality, and our unique voice control user interface.\n\nGet hands-on assembling a boat and gain invaluable insights into the world of sailing as you do.\n\nPLEASE NOTE: This is a brief, experimental experience. For a comprehensive sailing app, we recommend trying MarineVerse Cup.\n\n