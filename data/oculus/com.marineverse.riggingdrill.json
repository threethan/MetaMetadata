/v/t64.5771-25/38974817_795567842272702_6647482580464563619_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6CQZBPB5flYQ7kNvgH2iIGl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchhAfxH5mp9RHzbYNULY8F&oh=00_AYDwFXwtAmPDAXCdF7UZIjnsvISdtGJunmFjDaW-jz_UOA&oe=66DAFC26"}, {"file_name": "3.png", "id": "1213412455994101", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974905_1213412459327434_6579542241075771915_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0aOrhBmcD1sQ7kNvgGsTnb4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchhAfxH5mp9RHzbYNULY8F&oh=00_AYCVlzUS1sL59XK1LinRWJ-fx5StRNH6-TW3gyETn3uDZg&oe=66DAF893"}, {"file_name": "7.png", "id": "649487337111032", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982468_649487343777698_7478990939834003881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NvOAyLFXS3QQ7kNvgFitLQV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchhAfxH5mp9RHzbYNULY8F&oh=00_AYB5h9IaTzL-KKOqzoQ2DViF2s3m3id4x5bEXaX-c9Wnkw&oe=66DAEDE8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BY (1280 \u00d7 720 px) (2560 \u00d7 1440 px).png", "id": "808067730881455", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982710_808067734214788_8484893352327044465_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6_n_X6BfNcQ7kNvgGr_aGD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchhAfxH5mp9RHzbYNULY8F&oh=00_AYDqGEQIi-sTNjwVHTc_iznqQQ81jLXPbWVxh-6SOrcCAA&oe=66DAF762"}, "display_name": "Rigging Drill by MarineVerse", "keywords": ["sailing", "knot", "puzzle", "boat", "bowline"], "long_description": "From the creators of MarineVerse Cup comes Rigging Drill, an experimental and innovative game developed for people learning how to sail. Dive into the intricate and crucial art of boat rigging, fully immersed in the experience.\n\nLearn to tie sailing knots like the bowline using a real rope, mixed reality, and our unique voice control user interface.\n\nGet hands-on assembling a boat and gain invaluable insights into the world of sailing as you do.\n\nPLEASE NOTE: This is a brief, experimental experience. For a comprehensive sailing app, we recommend trying MarineVerse Cup.\n\nVideo trailer and screenshots captured on Meta Quest Pro.", "short_description": "Master the art of boat rigging with this groundbreaking experience from the MarineVerse team. Learn to tie sailing knots like the bowline and solve unique rigging puzzles. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.marineverse.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "MarineVerse", "support_website_url": null, "website_url": "https://www.marineverse.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8112235612195568"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221315_1741634662943927_4133988673721475180_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=stdGaebzcwwQ7kNvgEgOY98&_nc_ht=scontent.oculuscdn.com&_nc_gid=AchhAfxH5mp9RHzbYNULY8F&oh=00_AYCzuLwEcBbCrizDg_3RJllXFuWsIl7F844BZ_vvzsSPaw&oe=66DAD89E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Rigging Drill by MarineVerse", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_t