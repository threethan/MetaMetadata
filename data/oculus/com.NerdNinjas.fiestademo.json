3883BB"}, {"file_name": "6.png", "id": "556098763570189", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974900_556098766903522_8004750842823654047_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Faup5ksS0IQ7kNvgHMjmS7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDOxdWI2Lqb_GfjKZDIl4PbauC13MsOmgBRwLltqeEQw&oe=67387EED"}, {"file_name": "3.png", "id": "9168495186528089", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974439_9168495206528087_4233145093264207487_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wBtDEvRXgGwQ7kNvgHeLd8u&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnEXls1svkMYiGWDkQc1liU1BYZZ6DFA_hT2kAiNS_uQ&oe=67388962"}, {"file_name": "2.png", "id": "476003205442680", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982508_476003212109346_3995292706423684582_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fvc0bIx6M8AQ7kNvgFMbpjj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUZwNf1EpcdDL8kx2j8dYJ6C_vLKgrnHPBlVpzFW739w&oe=67389F61"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rogue Pi\u00f1atas: VRmageddon [DEMO]", "keywords": ["roguelike", "roguelite", "action", "multiplayer"], "long_description": "EXPERIENCE THE DEMO FOR ROGUE PINATAS: VRMAGEDDON!\n\nA multiplayer VR roguelite game. Your mission? Survive the party-apocalyptic world by bashing your way through swarms of invading Pi\u00f1atas, where every swing could mean survival or sweet defeat!\n\nGAME FEATURES:\n\n6 Characters to Choose: As one the few survivors, it's up to you to answer the call!\n\nWeapon Galore: Master over 150+ different combinations of attack through weapon evolutions and Dual Wielding.\n\nWorld-Ending Locations: From your local neighborhood to the treacherous desert, each area offers new dangers and opportunities for mayhem.\n\nCandy-packed Enemies: These pi\u00f1atas are somehow thinking, moving, and growing smarter!\n\nHidden Secrets: Find the hidden Ninjas in every level by looking high and low.", "short_description": "EXPERIENCE THE DEMO FOR ROGUE PINATAS: VRMAGEDDON!\n\nA multiplayer VR roguelite game. Your mission? Survive the party-apocalyptic world by bashing your way through swarms of invading Pi\u00f1atas, where every swing could mean survival or sweet defeat!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nerdninjas.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Nerd Ninjas", "support_website_url": null, "website_url": "https://nerdninjas.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8155850074523275"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1084496399689043"}]}, "baseline_offer": {"id": "1084496399689043"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728914520, "status": "PUBLISHED", "id": "1084496399689043"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8229566277151654", "version": "0.1.0"}, "id": "1517859325512561", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8028361840605433", "is_concept": false, "latest_released_binary": {"__type