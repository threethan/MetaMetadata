9320287350120194_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFrE9hisGDAQ7kNvgFi8spL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBySHii3mz3JTOW7yHY5ZAH5A4bpPHh2sASDDPaMVl9vA&oe=67221074"}, {"file_name": "scrn_1_v1.png", "id": "1518810695690255", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974573_1518810699023588_8319961315715540341_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3qnsPfid4asQ7kNvgHXOtfS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVZEEzKKrNMz-_4jbB7WZ64VlxF5yM-McyhmaMwbTJyA&oe=67221A13"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rogue Pi\u00f1atas: VRmageddon [DEMO]", "keywords": ["roguelike", "roguelite", "action", "roguepinatas", "fighting"], "long_description": "EXPERIENCE THE DEMO FOR ROGUE PINATAS: VRMAGEDDON!\n\nA multiplayer VR roguelite game. Your mission? Survive the party-apocalyptic world by bashing your way through swarms of invading Pi\u00f1atas, where every swing could mean survival or sweet defeat!\n\nFULL GAME FEATURES:\n\n*Quest 2 supporting coming soon!\n\n6+ Different Characters to Choose: \nAs one of the few party-apocalyptic survivors, it\u2019s up to you to answer the call!\n\n12+ Weapons to Master: \nMaster creative and diabolical weapons for both close-quarter and long-ranged fights.\n\n17+ Ingenious Gadgets: \nDiscover and unlock a wide range of wild gadgets to help you survive the chaos. Combine Gadgets with some Weapons for new Evo Weapons!\n\nOnline Multiplayer: \nPlay solo or team up with friends in an intense cooperative multiplayer mode, where you'll need to work together to survive the relentless onslaught of pi\u00f1atas.\n\n30+ Pi\u00f1ata Enemies: \nThese pi\u00f1atas have different behaviors, actions, and a few deadly tricks as the Pi\u00f1ata invasion gets smarter and harder across the different Stages.\n\n6+ Pi\u00f1ata Bosses: \nInsanely big and monstrous Mega Pi\u00f1atas will challenge even the most skilled party of fighters. Bring your A game, or A team, if you want to succeed.\n\n6+ World-Ending Locations: \nFrom your local neighborhood to the treacherous mysteries of the desert, each area offers new dangers and opportunities for mayhem.\n\nHidden Secrets: \nFind secrets in every Stage by looking high and low, and listening well.", "short_description": "EXPERIENCE THE DEMO FOR ROGUE PINATAS: VRMAGEDDON!\n\nA multiplayer VR roguelite game. Your mission? Survive the party-apocalyptic world by bashing your way through swarms of invading Pi\u00f1atas, where every swing could mean survival or sweet defeat!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://nerdninjas.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Nerd Ninjas", "support_website_url": null, "website_url": "https://nerdninjas.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8181924858582463"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1078680477311273_5831992098001725931_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zZxeUzTLRvsQ7kNvgHaCuXR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSViqp0AMWWyTCS2WxDSY_4AEAASlDV-dVpn_W8QiF7A&oe=67220409"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Rogue Pi\u00f1atas: VRmageddon [DEMO]", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release