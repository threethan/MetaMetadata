.png", "id": "3397840737125172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001698_3397840743791838_5680916268405930213_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0YFibb5HI_AQ7kNvgGyCAJP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDy2th3JQ6ckMKSSF3V0tA9yuTWIDN2EMTTMPH85EqStA&oe=6703C43A"}, "display_name": "Curling One", "keywords": [], "long_description": "Curling One allows you to experience the sport of curling, from delivery and sweeping to detailed strategic planning and execution, in a fascinating 3D world.  The advanced physics engine produces realistic curl, effective sweeping functionality, and accurate impact results.  All of the basic curling rules are implemented, including the five-rock rule (free guard zone), hog line violations, and removal of out-of-bounds stones.  Play against an AI opponent, or with friends in pass-and-play mode.", "short_description": "Experience the sport of curling in this virtual reality world.  Deliver the stone and sweep, in single-player or pass-and-play mode.  Throw guards, draws, and take-outs.  Develop and refine curling strategies."}]}, "developer_name": "Hackin' Shack Inc", "developer_privacy_policy_url": "https://hackinshack.org/docs/curling", "developer_terms_of_service_url": null, "publisher_name": "https://hackinshack.org/", "support_website_url": null, "website_url": "https://hackinshack.org/docs/curling", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_t