42279044_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cWjY6ZCP2agQ7kNvgGq2q5Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZctl0wM1uW3jMRIMy54a_wmvk4csei7woUzlgM7P30Q&oe=673B1611"}, {"file_name": "screenshot4.png", "id": "2464972843650350", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569462_2464972846983683_3021874364853938094_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uK12fDkhL8MQ7kNvgGPYrqF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCigahrzSxFoAp3IPc5Wp-sQHPMt0Lg6zsNxcW0qsdkHg&oe=673B0C68"}, {"file_name": "end_over.png", "id": "907018370547600", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75307248_907018373880933_8858027341035918661_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nhl19poK2SEQ7kNvgGYmxed&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnbi2ffmEqpabZph2enWWSUxg6vfZ4Bk0_7ST6Pa7w-g&oe=673B135D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot1.png", "id": "3397840737125172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001698_3397840743791838_5680916268405930213_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1SF42XSILdsQ7kNvgEdglDV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqaybMpWXPwjhkXXIeBgdCO6awbxAI1KpzTAXHS274tw&oe=673B233A"}, "display_name": "Curling One", "keywords": [], "long_description": "Curling One allows you to experience the sport of curling, from delivery and sweeping to detailed strategic planning and execution, in a fascinating 3D world.  The advanced physics engine produces realistic curl, effective sweeping functionality, and accurate impact results.  All of the basic curling rules are implemented, including the five-rock rule (free guard zone), hog line violations, and removal of out-of-bounds stones.  Play solo or with friends in pass-and-play mode.", "short_description": "Experience the sport of curling in this virtual reality world.  Deliver the stone and sweep, in solo or pass-and-play mode.  Throw guards, draws, and take-outs.  Develop and refine curling strategies."}]}, "developer_name": "Hackin' Shack Inc", "developer_privacy_policy_url": "https://hackinshack.org/docs/curling", "developer_terms_of_service_url": null, "publisher_name": "https://hackinshack.org/", "support_website_url": null, "website_url": "https://hackinshack.org/docs/curling", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "666666498794895"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "121435627572987"}]}, "baseline_offer": {"id": "121435627572987"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1680818340, "status": "PUBLISHED", "id": "121435627572987"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "23972969845623465", "version": "1.0"}, "id": "732257648441510", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9443599825653708", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "23972969845623465"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "73225764844