 even abstract masterpieces\u2014all designed to evoke a sense of peace and serenity.", "short_description": "\"Musical Taggers\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity."}]}, "developer_name": "VIPER", "developer_privacy_policy_url": "https://sites.google.com/view/musicaltaggers/home", "developer_terms_of_service_url": null, "publisher_name": "VIPER", "support_website_url": null, "website_url": "https://sites.google.com/view/musicaltaggersss/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7767842613316274"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3595912230629521"}]}, "baseline_offer": {"id": "3595912230629521"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726087920, "status": "PUBLISHED", "id": "3595912230629521"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7914205595346641", "version": "17"}, "id": "877457037633939", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__is