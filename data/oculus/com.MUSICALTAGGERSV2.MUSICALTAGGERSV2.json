LHHXvbQFAuQzZ5hCrAmPPUuvmoNRqmspbcA&oe=67065900"}, {"file_name": "com.oculus.vrshell-20240829-192458 (1).png", "id": "1747651029305189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982458_1747651032638522_4619279032733922698_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ku5lh1VtfJMQ7kNvgEh13Fp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDD53c-c1e6Dpmg3KXg2ZtaA_JjfBmsq6mxscaemNCj2Q&oe=67067347"}, {"file_name": "com.oculus.vrshell-20240829-192549 (1).png", "id": "832907568911177", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572934_832907572244510_4692354010554556052_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vr_1-4atxukQ7kNvgFX79TZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZlmhIhDAzmIzau0I680eUnqL7wLm62sI7CZjkE-t2ZA&oe=670658BE"}, {"file_name": "com.oculus.vrshell-20240829-192624 (1).png", "id": "514164558066659", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036697_514164561399992_5564680968129452594_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GJuc9-WjtKoQ7kNvgHV_te8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2B9vcKRZ7evH2MJ_umhnMrWZ1zs0cQYfK52GPTBEv5A&oe=67068083"}, {"file_name": "com.oculus.vrshell-20240829-192638 (1).png", "id": "1591887348351607", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75287554_1591887351684940_669231293611724332_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yyA81J92KHgQ7kNvgGOgQVv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2NHwrT2iKv8dcIVomNWRQn42kuiDO899eyXuQxg8o2A&oe=670668B2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "musical taggers", "keywords": [], "long_description": "\"Musical Taggers\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity.\nThe objective of Musical Taggers is simple yet delightful: players use virtual reality tools to create beautiful, glowing art installations throughout the game world.\nThese installations can take the form of intricate patterns, flowing designs, or even abstract masterpieces\u2014all designed to evoke a sense of peace and serenity.", "short_description": "\"Musical Taggers\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity."}]}, "developer_name": "VIPER", "developer_privacy_policy_url": "https://sites.google.com/view/musicaltaggers/home", "developer_terms_of_service_url": null, "publisher_name": "VIPER", "support_website_url": null, "website_url": "https://sites.google.com/view/musicaltaggersss/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7767842613316274"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3595912230629521"}]}, "baseline_offer": {"id": "3595912230629521"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726087920, "status": "PUBLISHED", "id": "3595912230629521"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "80143750353