nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uDJKhpaDjqcQ7kNvgHKSuJE&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBuMjwLmkgyWnc7AdOm0fY9rLTHvRwC-Mbl18au3GjgIA&oe=675D6CC5"}, {"file_name": "Screenshot-Focus-5 revised.png", "id": "509537288353957", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75322598_509537291687290_7386728312272241154_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pTjdiH0OVZAQ7kNvgEJ0KVG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCjNbeRB_Dd8oot9ugheCWfX2mM0RZATn7Ha_rl-52zEA&oe=675D684D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Focus", "keywords": ["Productivity", "Brainstorming", "Creative", "Ideation"], "long_description": "Focus is a developer reference app designed to show developers how to build spatialized experiences using the Meta Spatial SDK.\n\nThis spatial brainstorming tool is designed to enhance your productivity and creativity. Experience a new way of working by building mind maps, prioritizing tasks, jotting down ideas and interacting with AI assistance. Transform your workspace with virtual stickers, arrows and post-its, allowing you to visualize and organize your thoughts like never before. Focus rethinks the traditional brainstorming process, enabling you to fully engage with your projects in a dynamic, spatial environment.\n\n**More about Focus:**\n\nhttps://developers.meta.com/horizon/documentation/spatial-sdk/focus\n\n**More about Meta Spatial SDK:**\n\nhttps://developers.meta.com/horizon/develop/spatial-sdk", "short_description": "Focus is a VR/MR app created for developers to demonstrate how you can build a Productivity app using Meta Spatial SDK. The app supports panel and object management, enabling the creation, reuse, and destruction of interactive elements within varied environments."}]}, "developer_name": "Meta", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Meta",