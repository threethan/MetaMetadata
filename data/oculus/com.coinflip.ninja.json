rVvMP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBf8StD9xrpVFCRzCA9AnxXhTDuZOjbjSr2J1VXYFZJTg&oe=67065910"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus_Cover_Landscape_2560x1440.png", "id": "773359876720028", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222941_773359880053361_1774345806852026991_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S0eotAYzkNAQ7kNvgEdn10t&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBd2sjyZxFVkEZA2vO9FIwJFuWqHNd_71T8BcqHVfnE5Q&oe=67066368"}, "display_name": "Ninja Legends", "keywords": ["ninja", "archery", "sword", "saber", "sairento"], "long_description": "* Rise to the occasion as enemies attack from all sides. Defeat simultaneous threats like an epic ninja.\n* Get dropped into the action immediately with dead simple controls that you can learn instantly.\n* Coordinated enemies give you endless challenges to solve.\n* By design, there's no running away. There's no hiding. You must fight!\n* Archery Update: Play 6 uniquely styled archery levels with leaderboards and endless increases in difficulty\n\nExperience blood pumping action in immersive and beautiful VR environments.  Enemy ninjas will utilize cooperative group attacks to swarm and surround you. You'll need to attack and block 360 degrees of action to survive.\n\n24 Levels (Including 6 Archery Levels)\n4 Difficulty Modes\n6 Ninja Weapons\n* Swords\n* Claws\n* Staff\n* Gauntlets\n* Odachi & Wakizashi\n* Naginata\n4 Shadow Skill Abilities\n* Bow & Arrow\n* Shadow Step\n* Energy Blast\n* Chain Dart\nBoss Battles\nDaily Challenges\nUnlockable Secret Modes", "short_description": "The most INTENSE combat experience on the Quest. Fight challenging enemies that attack from all sides while you slice your way through beautiful environments. Now with 6 styles of archery!  Unlock amazing weapons and special ninjitsu abilities in your quest to retrieve the stolen Shadow Scrolls. Do you have what it takes to be a ninja legend?"}]}, "developer_n