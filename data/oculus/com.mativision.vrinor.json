rated_image.png", "id": "444110573018626", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138833_1521316981509621_1328660907_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J5YynPKBU0kQ7kNvgHzoXfp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOjLwXESDlhON5qzBJht6Ll&oh=00_AYAbpFmkj59GQeCg21SZjIPgDEfvm5E-4ijjSCOsB16UAw&oe=66F2A9A5"}, {"file_name": "migrated_image.png", "id": "520298775342566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162739_1749759475243460_1638595940_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZnnxcuD_xIQ7kNvgHt3SJQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOjLwXESDlhON5qzBJht6Ll&oh=00_AYAvfvEI7-4yOc8_N30H-6Jx5cZWBb5-P6qsux-KxYQt7A&oe=66F28C94"}, {"file_name": "migrated_image.png", "id": "1090471127969199", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139059_1702575006684086_137263465_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CoZD5_Ql8LEQ7kNvgGd_dmT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOjLwXESDlhON5qzBJht6Ll&oh=00_AYDcQ5R-IhCtN0zerQyvncad8b0pan4ZxmVyTqD6emNlVg&oe=66F2A547"}, {"file_name": "migrated_image.png", "id": "673926096692621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449016_968176639943000_441039066_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zn-PZb_m5_0Q7kNvgF4HGMz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOjLwXESDlhON5qzBJht6Ll&oh=00_AYAkPTEi1Y9ufLhvv4RpWwQzapWuQRyViDIXLUihIVZZCw&oe=66F2AB2A"}, {"file_name": "migrated_image.png", "id": "192262142077356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138839_1684592765129086_854230490_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tfdsJC5drfgQ7kNvgGMfkik&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOjLwXESDlhON5qzBJht6Ll&oh=00_AYDx489xOYxR7a7PA5mgrb5xq7lSoGzd27Hl6I70OcGJhg&oe=66F2A5D9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VRinOR", "keywords": ["medical", "operation", "vrinor", "surgery"], "long_description": "Mativision, the leading 360 VR Service Provider and Medical Realities an innovative group, expert in medical training VR products, have joined forces by bringing to life the first ever \u201cVRinOR\u201d App. \n\nThis App opens the doors of an Operation Room to students and the public around the world that want to use VR for educational purposes.\n\nA three-hour operation performed by Dr. Shafi Ahmed, the colorectal and laparoscopic surgeon of Barts Health NHS Trust working at The Royal London Hospital , will be Live Streamed in VR and this App will allow anyone to tune into the stream and watch in 360 a live operation.\n\nWARNING: This app contains live video of medical procedures, including blood and surgery. Users are advised to exercise discretion. Not suitable for children. Ages 17+.", "short_description": "This App opens the doors of an Operation Room to students and the public around the world that want to use VR for educational purposes.\n\nA three-hour operation performed by Dr. Shafi Ahmed, the colorectal and laparoscopic surgeon of Barts Health NHS Trust working at The Royal London Hospital , will be Live Streamed in VR and this App will allow anyone to tune into the stream and watch in 360 a live operation."}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Spot Seven ltd.", "support_website_url": null, "website_url": "http://vrinor.mativision.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "272923418244913"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "bas