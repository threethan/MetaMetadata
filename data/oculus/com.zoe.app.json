, "id": "646488084278854", "locale": "en_US", "screenshots": [{"file_name": "zoe-screenshot_mr-space-1.png", "id": "1343507916598380", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974712_1343507919931713_14240278454461323_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f0lGEGGk9KkQ7kNvgE8MKf6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBvjzIBP7S4_hHkv9pmZnQIfcoWsMlj8WYBCkyxKsNRcQ&oe=6756CB89"}, {"file_name": "zoe-screenshot_kawaii-girl-cat.png", "id": "1086880655347229", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982447_1086880662013895_7459296272916914668_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AmWECQUpWq4Q7kNvgFnE4mE&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB5HX1JZOS47LTfsMb8OxYorRcqUZ0e57JdG0Zy_JtjTw&oe=6756EB48"}, {"file_name": "zoe-screenshot_mr-treasure-1.png", "id": "978087459960202", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003227_978087463293535_5093808500715517027_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9YzlULq4VfEQ7kNvgHbIDky&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAR-Ibf5i0b99m3IMNnwasTFr_vh8iA9SKHEBIYHUZnjg&oe=6756D2D7"}, {"file_name": "zoe-screenshot_ocean-interaction.png", "id": "2297620400405646", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974801_2297620403738979_3835636582606660091_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N3hnGRQg9akQ7kNvgHbdBcW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC9t0uCNewqdcXdlxQpfkWExle5YrF17jXNo3J10K_P8w&oe=6756D636"}, {"file_name": "zoe-screenshot_farm-banana.png", "id": "1229949417734356", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75422391_1229949421067689_8784062239281917423_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zuNxY9bnSgEQ7kNvgGYsqen&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAjHydkrrfyIohUgbBVVML1u_Wa6wFEjGzbI6pwX7i8eQ&oe=6756C824"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Art_Landscape.png", "id": "1359054188017007", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75221331_1359054191350340_4019135738094483709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nMgCvjzK2FYQ7kNvgHY50G7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAj7t7zAm3y2i4xsWWE-mh5BcSqeLne1wkk18UTWvJAhw&oe=6756D6DB"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "*new* Apply to become a Zoe content publisher and start building Mixed Reality experiences today!\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host activities, create learning games, build interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. Visit zoeimmersive.com to learn how you can increase the number of collaborators.\n\nReady to use Templates\nEnvironments\n350+ Local Assets\n1M+ Free Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\n", "short_description": "For ages 13 and up\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zoeimmersive.com/privacy-policy/", "developer_terms_of_service_url": "https://zoeimmersive.com/terms-of-service/", "publisher_name"