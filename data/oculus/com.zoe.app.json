.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYA_RFH6mmS9mYldTeImc5DcMZwtLkyLZDIhflgT1ULRpQ&oe=66E41C98"}]}, "id": "646488084278854", "locale": "en_US", "screenshots": [{"file_name": "zoe-screenshot_mr-space-1.png", "id": "1343507916598380", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974712_1343507919931713_14240278454461323_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_5g0-ODtWucQ7kNvgFx32rm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYB4jsX6IK1UNTVe1ltT8N0sxn2RjWd03ezg0y6vEtQDvA&oe=66E41909"}, {"file_name": "zoe-screenshot_kawaii-girl-cat.png", "id": "1086880655347229", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1086880662013895_7459296272916914668_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fGm4ve6YMgsQ7kNvgHqsFif&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYDFs_eoz9peStBU3mgBWq39UsPnIeNBKSM9T3QnUE5t1w&oe=66E438C8"}, {"file_name": "zoe-screenshot_mr-treasure-1.png", "id": "978087459960202", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_978087463293535_5093808500715517027_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6S4kCEjGXLsQ7kNvgFUgo-Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYBRYCgtzRWvARTfsgrR03-S8Wwx2cLAetokVrLtBdPZ7A&oe=66E42057"}, {"file_name": "zoe-screenshot_ocean-interaction.png", "id": "2297620400405646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974801_2297620403738979_3835636582606660091_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ygUTGf2oyYcQ7kNvgGLMBqy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYCCruhRM2ZeBwayQqTWElvowgdMpBUEBaZKXy3WfxfX1Q&oe=66E423B6"}, {"file_name": "zoe-screenshot_farm-banana.png", "id": "1229949417734356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422391_1229949421067689_8784062239281917423_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W1yMIX1eb9UQ7kNvgGm_gzZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYAyOj-7pKtw_-Hqvz-tdQ9XF1NV-73Z08uJsNHGumv1uQ&oe=66E415A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Art_Landscape.png", "id": "1359054188017007", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221331_1359054191350340_4019135738094483709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W4OWsdQUdPYQ7kNvgGESRpe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEtuKr_7Vyj8gzuu_jxmqJK&oh=00_AYDsVKao3MNddGucw1JSd2t8m9Wp1DnRVPgb0G6NYDI_Ug&oe=66E4245B"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "*new* Apply to become a Zoe content publisher and start building Mixed Reality experiences today!\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host activities, create learning games, build interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. Visit zoeimmersive.com to learn how you can increase the number of collaborators.\n\nReady to use Templates\nEnvironments\n350+ Local Assets\n1M+ Free Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\n", "short_description": "For ages 13 and up\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_pr