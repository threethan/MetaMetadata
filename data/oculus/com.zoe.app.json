89_8784062239281917423_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JHZk2WiPRlEQ7kNvgEkxVAt&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPTb-mgKn1Lce6X2O5xfLVParpoGbPSzCP56V3ep2_iQ&oe=66DC2CA4"}, {"file_name": "zoe-screenshot_ocean-interaction.png", "id": "2297620400405646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974801_2297620403738979_3835636582606660091_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rScFc-MY_xoQ7kNvgHORPQg&_nc_ht=scontent.oculuscdn.com&oh=00_AYBmKwCjN1P5AXQ1CJonANBcpDEmTcq3TjIetebsknXB_w&oe=66DC3AB6"}, {"file_name": "zoe-screenshot_kawaii-girl-cat.png", "id": "1086880655347229", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1086880662013895_7459296272916914668_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JDTNSIrGoIsQ7kNvgHTs9ez&_nc_ht=scontent.oculuscdn.com&oh=00_AYD7PHV0CvJ6SuNuc1H3e-vWhJ9eas2RFAsBbira2W2dSQ&oe=66DC4FC8"}, {"file_name": "zoe-screenshot_getting-started-1.png", "id": "780571249679575", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_780571253012908_8719949352580884295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XjVQSHaXmzYQ7kNvgEyoMF-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGQmW7193-VGJ5CiqAynRnDl11e1Bo48T5lZuLCDX_ZQ&oe=66DC5472"}, {"file_name": "zoe-screenshot_museum-1.png", "id": "673326570888703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_673326574222036_4230135942755307748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GDG2WXbClrwQ7kNvgGVZ5Sb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQvoQ9qvlSpZddRSDqqDgTALtgLVIQUMLlyh4Tx7S07A&oe=66DC341D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image.png", "id": "1171699586774175", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984439_1171699590107508_3284533899818651734_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5wzHANvBJlQQ7kNvgERFit1&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3VqUhESPM_bU69agHJqWqPnG10iCFD5aphm33b_ULAw&oe=66DC343E"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "Zoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host remote workshops, virtual classrooms, project-based-learning activities, meetups, events and create interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. To purchase more collaborators, head over to www.zoe.com.\n\n7 Launch Templates\n8 Environments\n350+ Local Assets\n1M+ Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\nIf you would like to submit a template you created to be integrated into our next community update, go to zoe.com/templates and fill out the form.\n", "short_description": "For ages 13 and up\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zoe.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zoe Immersive", "support_website_url": "https://docs.zoe.com/", "website_url": "https://www.zoe.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}], "external