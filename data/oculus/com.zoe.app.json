10&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4zM3s46f2CEQ7kNvgGJ37H2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDc9FLBtf5HEtadrzB2wIxaLj3IrTQvWhEKu3de0WjZ5g&oe=66DADE89"}, {"file_name": "zoe-screenshot_kawaii-girl-cat.png", "id": "1086880655347229", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1086880662013895_7459296272916914668_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FtHzek2ei_kQ7kNvgG95roI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNxtd8RGb9nf-j-XcqzdBsnDxM80dXYkpaU7Kjpb4n9g&oe=66DAFE48"}, {"file_name": "zoe-screenshot_mr-treasure-1.png", "id": "978087459960202", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_978087463293535_5093808500715517027_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhlm11MhuS4Q7kNvgECDrhu&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1RiZVeQK5YOzsXYIvsFhgrC67kqwvSMFg-h5MIbrKFQ&oe=66DAE5D7"}, {"file_name": "zoe-screenshot_ocean-interaction.png", "id": "2297620400405646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974801_2297620403738979_3835636582606660091_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yDtJ8NOLcBcQ7kNvgGpIQ8I&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwUgJudrn9jdk5DTrxSCnhFhKhlws79mA-pX7gzkgGeg&oe=66DAE936"}, {"file_name": "zoe-screenshot_farm-banana.png", "id": "1229949417734356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422391_1229949421067689_8784062239281917423_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nydqW-Cb-EoQ7kNvgH10B3m&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPZ7DDjWXFp3O5395kqHeu_OMKGdOlhNVDgA4kjxIQww&oe=66DADB24"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Art_Landscape.png", "id": "1359054188017007", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221331_1359054191350340_4019135738094483709_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=scYZtVLT8xgQ7kNvgF0aVAh&_nc_ht=scontent.oculuscdn.com&oh=00_AYA90n9lKA2ocHSehpTdz9QWv5-MXnABXj0AZaxkrg6qKA&oe=66DAE9DB"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "*new* Apply to become a Zoe content publisher and start building Mixed Reality experiences today!\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host activities, create learning games, build interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. Visit zoeimmersive.com to learn how you can increase the number of collaborators.\n\nReady to use Templates\nEnvironments\n350+ Local Assets\n1M+ Free Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\n", "short_description": "For ages 13 and up\n\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zoeimmersive.com/privacy-policy/", "developer_terms_of_service_url": "https://zoeimmersive.com/terms-of-service/", "publisher_name": "Zoe Immersive", "support_website_url": "https://docs.zoeimmersive.com/", "website_url": "https://zoeimmersive.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1063584910766706"}, {"id": "323450648956687"}], "exte