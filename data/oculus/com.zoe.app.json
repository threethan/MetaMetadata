: "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_780571253012908_8719949352580884295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KeO5gplfr4UQ7kNvgHatrVR&_nc_ht=scontent.oculuscdn.com&_nc_gid=A55FwC0JaXCDCXvlqtBhcYo&oh=00_AYC5Gv8x73xmXOrmxWE0nU3FIx7qb-vaj_O9XilvzGEizw&oe=66E16232"}, {"file_name": "zoe-screenshot_museum-1.png", "id": "673326570888703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_673326574222036_4230135942755307748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k30r5vKCn6sQ7kNvgGqJpGm&_nc_ht=scontent.oculuscdn.com&_nc_gid=A55FwC0JaXCDCXvlqtBhcYo&oh=00_AYChsifvcdvwOSduh79lPSyftB2TgDKdVBan0AYy55NSRA&oe=66E17A1D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image.png", "id": "1171699586774175", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984439_1171699590107508_3284533899818651734_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eOhNsxD4adEQ7kNvgHLKh-l&_nc_ht=scontent.oculuscdn.com&_nc_gid=A55FwC0JaXCDCXvlqtBhcYo&oh=00_AYBe_sjhajYKGmX2rLLlRIXL64_dReXqpdPf8t9JAqTP_w&oe=66E17A3E"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "Zoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host remote workshops, virtual classrooms, project-based-learning activities, meetups, events and create interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. To purchase more collaborators, head over to www.zoe.com.\n\n7 Launch Templates\n8 Environments\n350+ Local Assets\n1M+ Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\nIf you would like to submit a template you created to be integrated into our next community update, go to zoe.com/templates and fill out the form.\n", "short_description": "For ages 13 and up\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zoe.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zoe Immersive", "support_website_url": "https://docs.zoe.com/", "website_url": "https://www.zoe.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "574005527497628"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1569988836793596"}]}, "baseline_offer": {"id": "1569988836793596"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1666890000, "status": "PUBLISHED", "id": "1569988836793596"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test