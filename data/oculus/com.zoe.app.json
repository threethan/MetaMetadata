48_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4dK_vkDrvgQ7kNvgFJIagw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4O-xpp8FNEOYI08GSB7ofTHSyiTP4vbj6ZP-vDnrCIA&oe=6720C21D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image.png", "id": "1171699586774175", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984439_1171699590107508_3284533899818651734_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjerIIJiR3MQ7kNvgGPuHl6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5WC9Q0KvA4BMCQCdkuPlSbhjKLQHdrNXqy72KGVMUbA&oe=6720C23E"}, "display_name": "Zoe", "keywords": ["nocode", "collaboration", "learning", "creation", "social"], "long_description": "Zoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \n\nWhat can I create with Zoe?\n\nWith Zoe you can create anything you have in mind. It has been used to host remote workshops, virtual classrooms, project-based-learning activities, meetups, events and create interactive stories, adventure games, and even mini-games for therapy.\n\nOur free version includes templates, creator tools and multiplayer capabilities for up to 3 members. To purchase more collaborators, head over to www.zoe.com.\n\n7 Launch Templates\n8 Environments\n350+ Local Assets\n1M+ Online Assets Through Sketchfab\n3 Projects and 3 Scenes Per Project\nUnlimited Interactions\n\nIf you would like to submit a template you created to be integrated into our next community update, go to zoe.com/templates and fill out the form.\n", "short_description": "For ages 13 and up\nZoe enables the rapid creation of interactive 3D scenes through a no-code interface and automation. Invite your friends, students, colleagues and clients to collaborate, learn and create together in real-time. \nWhat can I create with Zoe?\nZoe has been used to host immersive workshops, virtual classrooms, project-based-learning activities, meetups, events, interactive art, marketing campaigns, and even mini-games for therapy.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zoe.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zoe Immersive", "support_website_url": "https://docs.zoe.com/", "website_url": "https://www.zoe.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "574005527497628"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1569988836793596"}]}, "baseline_offer": {"id": "1569988836793596"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1666890000, "status": "PUBLISHED", "id": "1569988836793596"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8719775434710410", "version": "0.15.0"}, "id": "372447281630154", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5464660053555314", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8719775434710410"}, "release_status": "RELEASED"}, "binary_rele