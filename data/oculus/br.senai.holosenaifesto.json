gFH5LFb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKyk482T7eifA1b8DkSf288L-Qm076Ts4Ho7DamPZamA&oe=6739C26C"}, {"file_name": "C.png", "id": "996504778681193", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974912_996504782014526_8911171138422543726_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VNSXVA8ykFEQ7kNvgHxOrzh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACoDyOGM2zKxvKRdZuxcA93gyFrGwYQbhczb37MIiR_g&oe=6739C0C0"}, {"file_name": "D.png", "id": "1247637573280639", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001674_1247637576613972_8826749065729267679_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eH2x_QlcgHYQ7kNvgGxWCuN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDico0yT3Wbm4N2mmRJWig9AoCgQO1Zdtq--yFxSXvL-A&oe=6739EAC2"}, {"file_name": "E.png", "id": "387746647283674", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974680_387746650617007_6086186792400307751_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EzdySqQlfXAQ7kNvgE_16nt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlSWS_6Ny_MsueD0A8_9YtoUaeSx4y-sHX64pT3-30hQ&oe=6739DCDB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Shotcut_00_00_07_467.png", "id": "938840754716924", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974471_938840758050257_1603526028084584737_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sagKJCyELAoQ7kNvgGXvmTQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4pQZkSNkXQCQjUw5H-gSpd__mSBpnjX4uQhSjaq0djg&oe=6739EACF"}, "display_name": "HoloSENAI - FESTO", "keywords": [], "long_description": "Dive into the world of pneumatics with our HoloSENAI - FESTO simulator! Perform 4 practical exercises, assemble circuits, and test your knowledge. Upon completing each exercise, unlock two exclusive videos: one of the real workbench in operation, and another showing the detailed simulation of the simulation software. \n\nInteract with the virtual components, modify parameters, and observe how the circuit reacts in real time. With 19 different equipment and instructor tips, you will have a complete and engaging learning experience.", "short_description": "Carry out pneumatic simulations on a virtual FESTO bench"}, {"images": {"nodes": []}, "id": "377835341713303", "locale": "pt_BR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "HoloSENAI - FESTO", "keywords": [], "long_description": "Mergulhe no mundo da pneum\u00e1tica com nosso simulador HoloSENAI - FESTO! Realize 4 exerc\u00edcios pr\u00e1ticos, montando circuitos e testando seus conhecimentos. Ao finalizar cada exerc\u00edcio, desbloqueie dois v\u00eddeos exclusivos: um da bancada real em funcionamento e outro mostrando a simula\u00e7\u00e3o detalhada do software de simula\u00e7\u00e3o. \n\nInteraja com os componentes virtuais, altere par\u00e2metros e observe como o circuito reage em tempo real. Com 19 equipamentos diferentes e dicas do instrutor, voc\u00ea ter\u00e1 uma experi\u00eancia de aprendizado completa e envolvente.", "short_description": "Realize simula\u00e7\u00f5es pneum\u00e1ticas em uma bancada FESTO virtual"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/19lCl9vttXoU53XajcK4fsgkJLRUENHEu/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "SENAI", "support_website_url": null, "website_url": "https://senai.br/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["pt_BR"], "supported_input_devices": ["HAND_TRACKING", "OCU