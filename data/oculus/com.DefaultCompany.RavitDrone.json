102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lme8swnpLUQQ7kNvgH8U8pV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZeKEHL-vXSa84CmWWrHZC13qS0XkNqGJiYxUfvOJ9xQ&oe=66D83B15"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "439470615746789", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982473_439470619080122_2217084565781675473_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ObGbdeD-qh4Q7kNvgGYDaYN&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnTuM2OX8H1ds_RdQtTpkov8EkjulIohkXxSJ9djw7Wg&oe=66D83018"}, "display_name": "Drone Experience", "keywords": [], "long_description": "# Drone Experience\n\nDive into the world of drone piloting with **Drone Experience**, an immersive VR application that puts you in control of a highly responsive drone. This experience focuses on delivering the pure joy of flight in virtual reality, complemented by realistic audio to enhance your immersion.\n\n## Key Features\n\n- **Intuitive VR Controls**: Master drone flight using your Meta Quest controllers for a natural and responsive piloting experience.\n- **Realistic Flight Physics**: Experience authentic drone behavior with accurate physics simulation, providing a genuine sense of flight.\n- **Immersive Audio**: Hear the buzz of propellers and the rush of wind, adding a new dimension to your virtual flight experience.\n- **Freeform Exploration**: Enjoy the freedom to fly wherever you want without constraints or objectives - the sky's the limit!\n- **VR Optimization**: Enjoy smooth performance and crisp visuals optimized for the Meta Quest platform, ensuring a comfortable and engaging experience.\n\n---\n\n**Drone Experience** offers an accessible yet realistic drone flying experience in VR. Whether you're an aspiring drone pilot or simply curious about the sensation of flight, this app provides a unique opportunity to soar through virtual skies.\n\nNo missions, no stress - just pure, unadulterated flight. \n\n> Take to the skies and experience the thrill of drone piloting in VR today!", "short_description": "Experience the freedom of drone flight in virtual reality. Control a drone with intuitive VR controls and immerse yourself in a realistic flying experience with authentic sounds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ravit.dev/privacy-policy/", "developer_terms_of_service_url": "https://www.ravit.dev/terms-and-conditions/", "publisher_name": "Ravit Dev", "support_website_url": "https://www.ravit.dev/", "website_url": "https://www.ravit.dev/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7658765320916701"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330719_8935987423084643_3378165754401342672_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ETfFHE8DiYQQ7kNvgH3QTK2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnp6upz2d-eKRyGVUAOrO3G5N2coQxhsiSa-0dhk8wQA&oe=66D8419A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Drone Experience", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Flying", "id": "388572352490011"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1722470136, "lastRevision": {"nodes": [{"id": "7658765354250031", "rele