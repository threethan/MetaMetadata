8_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6NAhjcAhfn8Q7kNvgGB458T&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD7jPMxh6TWpkLVa8es4LVuPoyZg4BC1W8fhVmDE6BupQ&oe=670F88FA"}]}, "id": "374226112429198", "locale": "en_US", "screenshots": [{"file_name": "fifth.png", "id": "1266070838109783", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75272211_1266070841443116_4118001112899024417_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=75Wlm4vU4MgQ7kNvgG3w3tc&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCUJTO68zCtHSYdZhLesf42nRCvqst6ad-akD5fafB-Vw&oe=670FB9AE"}, {"file_name": "result_result_WhatsApp Image 2024-09-13 at 10..png", "id": "425546786720022", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/86615895_425546790053355_382050259808434173_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3C5NJSEXWO8Q7kNvgF-EFMO&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA0vmrwFVB0v_vnc2-iOhjvv6edtdBbUauNKUxrJ5Uh2A&oe=670F9DE0"}, {"file_name": "second.png", "id": "1015788189947046", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982472_1015788193280379_7491108939402003214_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TYLuDBBvJFEQ7kNvgG55iD3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAoZZ0eat39Grxoudv_jyWnu7AcQxZK3BJ9D1C7kZLGJg&oe=670F9EAB"}, {"file_name": "result_targetSpace.png", "id": "869503631422429", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974456_869503634755762_3839948279626109284_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rwb29lHYWsEQ7kNvgHBVwyw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDfwEo0caOBltssHqtLXAw9guF8OCyCsvLfFWxxoqX38w&oe=670F88F5"}, {"file_name": "result_WhatsApp Image 2024-09-13 at 10.47.02 AM.png", "id": "1279507703052767", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75308617_1279507706386100_3340111357387726511_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rf0glZ0n8kgQ7kNvgGbfjkA&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCXlENINm3AND9SqkXtGFUW1K5q_QjVJem75ae23-9LAQ&oe=670FA344"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "439470615746789", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982473_439470619080122_2217084565781675473_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T_zVinyopT0Q7kNvgFHFRsK&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDe_YMCf_KTes5qJW-xVew1jpsR05Nv65YarlWOPR8i3w&oe=670F8F18"}, "display_name": "Drone Experience", "keywords": [], "long_description": "# Drone Experience\n\nDive into the world of drone piloting with **Drone Experience**, an immersive VR application that puts you in control of a highly responsive drone. This experience focuses on delivering the pure joy of flight in virtual reality, complemented by realistic audio to enhance your immersion.\n\n## Key Features\n\n- **Intuitive VR Controls**: Master drone flight using your Meta Quest controllers for a natural and responsive piloting experience.\n- **Realistic Flight Physics**: Experience authentic drone behavior with accurate physics simulation, providing a genuine sense of flight.\n- **Immersive Audio**: Hear the buzz of propellers and the rush of wind, adding a new dimension to your virtual flight experience.\n- **Freeform Exploration**: Enjoy the freedom to fly wherever you want without constraints or objectives - the sky's the limit!\n- **VR Optimization**: Enjoy smooth performance and crisp visuals optimized for the Meta Quest platform, ensuring a comfortable and engaging experience.\n\n---\n\n**Drone Experience** offers an accessible yet realistic drone flying experience in VR. Whether you're an aspiring drone pilot or simply curious about the sensation of flight, this app provides a unique opportunity to soar through virtual skies.\n\nNo missions, no stress - just pure, unadulterated flight. \n\n> Take to the skies and experience the thrill of drone piloting in VR today!", "short_description": "Experience the freedom of drone flight in virtual reality. Control a drone with intuitive VR controls and immerse yourself in a realistic flying experience with authentic sounds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ravit.dev/privacy-policy/", "developer_terms_of_service_url": "https://www.ravit.dev/terms-and-conditions/", "publisher_name": "Ravit Dev", "support_website_url": "https://www.ravit.dev/", "website_url": "https://www.ravit.dev/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8104383209688241"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75330719_8935987423084643_3378165754401342672_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=copgg0yDThIQ7kNvgHd3x9d&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDjePw-zvV_ZakAhV0ac37biGhxgEie-IT_jjflEdwQGg&oe=670FA09A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Drone Experience", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Flying", "id": "388572352490011"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1722470136, "lastRevision": {"nodes": [{"id": "7658765354250031", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"ap