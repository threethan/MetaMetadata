://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86620689_352169907934003_6649214012577792787_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BnEP1ucmNUIQ7kNvgGFnQdo&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBLe7UtgEb2GqgiQxgh4IzqWICJ0DKB5QTxjtzWI6uByA&oe=67405BEF"}, {"file_name": "second.png", "id": "1015788189947046", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982472_1015788193280379_7491108939402003214_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sYG-IffPJJgQ7kNvgHTOFY4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBgJoyjdqynrC-uy9BDtfkoOuO0XxPRmtv5JpcxMXCZfw&oe=6740662B"}, {"file_name": "first.png", "id": "1006302627863225", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974500_1006302631196558_2111042906153154332_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ITtG7kl5nyQQ7kNvgG7x8Eu&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCp2_FKgD4FXl2JALEkbK9bWtp1ZTd3-JxajOskfhRmtA&oe=67406195"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "439470615746789", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982473_439470619080122_2217084565781675473_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7UD0CTnw3xMQ7kNvgH76baU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDwx7ZJYtXFqcSsV-J80ulAYaXLfZWjIQUpb9oA2xc53g&oe=67405698"}, "display_name": "Drone Experience", "keywords": [], "long_description": "# Drone Experience\n\nDive into the world of drone piloting with **Drone Experience**, an immersive VR application that puts you in control of a highly responsive drone. This experience focuses on delivering the pure joy of flight in virtual reality, complemented by realistic audio to enhance your immersion.\n\n## Key Features\n\n- **Intuitive VR Controls**: Master drone flight using your Meta Quest controllers for a natural and responsive piloting experience.\n- **Realistic Flight Physics**: Experience authentic drone behavior with accurate physics simulation, providing a genuine sense of flight.\n- **Immersive Audio**: Hear the buzz of propellers and the rush of wind, adding a new dimension to your virtual flight experience.\n- **Freeform Exploration**: Enjoy the freedom to fly wherever you want without constraints or objectives - the sky's the limit!\n- **VR Optimization**: Enjoy smooth performance and crisp visuals optimized for the Meta Quest platform, ensuring a comfortable and engaging experience.\n\n---\n\n**Drone Experience** offers an accessible yet realistic drone flying experience in VR. Whether you're an aspiring drone pilot or simply curious about the sensation of flight, this app provides a unique opportunity to soar through virtual skies.\n\nNo missions, no stress - just pure, unadulterated flight. \n\n> Take to the skies and experience the thrill of drone piloting in VR today!", "short_description": "Experience the freedom of drone flight in virtual reality. Control a drone with intuitive VR controls and immerse yourself in a realistic flying experience with authentic sounds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ravit.dev/privacy-policy/", "developer_terms_of_service_url": "https://www.ravit.dev/terms-and-conditions/", "publisher_name": "Ravit Dev", "support_website_url": "https://www.ravit.dev/", "website_url": "https://www.ravit.dev/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes":