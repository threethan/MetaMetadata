c_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C8X11zRzxosQ7kNvgH2oPo9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpJIKOCfyF2_jhA1FvOY2WgMHDxWu2lJ_JDKhWRhDUcw&oe=6705137D"}, {"file_name": "12138835_1682233945350932_58087739_n.png", "id": "1261531801415696", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001660_1261531804749029_8450869964928990167_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7065XrUkBZYQ7kNvgExr-2H&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUg4uYnIPwzNa8xPZUgllDlXgV28ISyk7PeP3lmgIDEA&oe=670523C0"}, {"file_name": "12138840_658065914349379_1225992143_n.png", "id": "1349766259086227", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974807_1349766262419560_134214310981000175_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6WeePo_xlmMQ7kNvgF3IqnF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQ6CDdbfAY-1TuPLrE1-vDQbGOPOnNYCy6M6KtnBAVfA&oe=67050880"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landcape_2560x1440px.png", "id": "210572401394008", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_210572404727341_8241821180130177923_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c6WTDue47LwQ7kNvgH2BJjD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCen5MtyA-bWoAc79lUE3E0U36NQXL-0v4kazJf82HcqA&oe=670508C7"}, "display_name": "Crystal Rift", "keywords": [], "long_description": "A grid-based dungeon-crawler, in classic first person perspective.\n\nCrystal Rift is an inspired by classic dungeon games such as Dungeon Master and Eye of the Beholder with grid-based movement.\n\nIt\u2019s an experiential horror challenge game that takes the player through a series of increasingly mysterious locations. Crystal Rift has 26 levels, with unique styles and settings, to provide many hours of gameplay. The player slowly uncovers the narrative and story through exploration, discovering dark secrets and following the path of those who have come before.\n\nUse the In Game Dungeon Editor to build entirely new adventures and challenges for other players to solve.\n", "short_description": "A grid-based dungeon-crawler, in classic first person perspective. Crystal Rift is an experiential horror challenge game that takes the player through a series of increasingly mysterious locations."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.crystalrift.com/privacy/", "developer_terms_of_service_url": "http://www.crystalrift.com/terms/", "publisher_name": "Psytec Games Ltd", "support_website_url": "http://support.psytecgames.com/", "website_url": "http://www.crystalrift.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1192826961398224"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1001274630864373"}]}, "baseline_offer": {"id": "1001274630864373"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1686524400, "status": "PUBLISHED", "id": "1001274630864373"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6740985132617424", "version": "1.73"}, "id": "1496989150707347", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "i