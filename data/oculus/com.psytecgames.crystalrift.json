gs, to provide many hours of gameplay. The player slowly uncovers the narrative and story through exploration, discovering dark secrets and following the path of those who have come before.\n\nUse the In Game Dungeon Editor to build entirely new adventures and challenges for other players to solve.\n", "short_description": "A grid-based dungeon-crawler, in classic first person perspective. Crystal Rift is an experiential horror challenge game that takes the player through a series of increasingly mysterious locations."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.crystalrift.com/privacy/", "developer_terms_of_service_url": "http://www.crystalrift.com/terms/", "publisher_name": "Psytec Games Ltd", "support_website_url": "http://support.psytecgames.com/", "website_url": "http://www.crystalrift.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1192826961398224"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1001274630864373"}]}, "baseline_offer": {"id": "1001274630864373"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1686524400, "status": "PUBLISHED", "id": "1001274630864373"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6740985132617424", "version": "1.7