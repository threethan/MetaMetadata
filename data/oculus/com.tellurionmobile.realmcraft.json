 and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tGather resources to survive;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft survival game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-policy", "developer_terms_of_service_url": "http://www.tellurionmobile.com/privacy-policy", "publisher_name": "Tellurion mobile", "support_website_url": null, "website_url": "http://www.tellurionmobile.com/games/realmcraft", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "351111299953888"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410271_1771406839789700_3250046403363209216_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GbFB7m26NfcQ7kNvgFlyvtC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkZQi2unvP4gGEEMLUIVG1CtE-y_0SBAQwLhrFsKblOw&oe=67091878"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RealmCraft Survive, Mine & Craft Pro", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1490166000, "lastRevision": {"nodes": [{"id": "1823765827843340", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1222173444494871", "is_fi