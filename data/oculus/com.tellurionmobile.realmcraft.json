YAR9j_25w3aN_v33pTpHme6jPlQQj_PskH4O78FcnTXxA&oe=6731D653"}, {"file_name": "migrated_image.png", "id": "582438155815755", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12410455_1685899575033604_8064572259617996800_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cls04GntGsUQ7kNvgGZn0iS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvaM9-sEvWcjE0UK9BmoA4fJuKJkW_zRGMqHWA3CaFHw&oe=6731F1BA"}, {"file_name": "migrated_image.png", "id": "2986542838072922", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410271_1816492958588938_6237811970142109696_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lOUc0dMtedgQ7kNvgGPP6M6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwu9CFdPK8c5SE4f2nbOzJ3EMWo92QT4RtxiizwaZuJQ&oe=6731F02D"}, {"file_name": "migrated_image.png", "id": "2816675995090111", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12138845_1897605223792843_4617680328188755968_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5K1V7Eshl2sQ7kNvgGnvai1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmPw_Dnvb_Fre6vT80XNoIt9Ac_Rr_PvsWDQHisk8fqA&oe=6731FD1E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RealmCraft Survive, Mine & Craft Pro", "keywords": ["craft", "sandbox", "build", "worldcraft", "mine"], "long_description": "RealmCraft is a sandbox construction game with 3D procedurally generated world. Create and break apart various kinds of blocks, explore the environment, gather resources, craft weapons, build shelter and take part in combat with dangerous opponents.\nThe game offers two modes \u2013 Survival and Creative. In Survival players have to collect resources, construct buildings, fight against enemies, manage hunger and explore the word to survive and prosper. In Creative mode you focus on breaking new grounds of creation by building the most elaborate structures you can dream of.\nRealmcraft is a game for adults and kids, it will entertain you for a long time and earn an unforgettable experience.\n\u2022\t3D Sandbox construction game;\n\u2022\tHuge world to explore;\n\u2022\tCraft and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tGather resources to survive;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft survival game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-policy", "developer_terms_of_service_url": "http://www.tellurionmobile.com/privacy-policy", "publisher_name": "Tellurion mobile", "support_website_url": null, "website_url": "http://www.tellurionmobile.com/games/realmcraft", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "351111299953888"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410271_1771406839789700_3250046403363209216_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=APBfeFQGk1QQ7kNvgF4a2ma&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcTkBPM1K1wsbqRR_BWIAmydg2WVAYfcBal1Eu2ed65g&oe=6731F6F8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RealmCraft Survive, Mine & Craft Pro", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1490166000, "lastRevision": {"nodes": [{"id": "1823765827843340", "release_type": "SCHEDULED", "administrat