7kNvgF8FOBZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad-8tEOgJYnN4IvcPhjCo6H&oh=00_AYAGur1pWOr3p60hmcy9sTAthh7dwItVauwY3kpujXu9VA&oe=66EE99D3"}, {"file_name": "migrated_image.png", "id": "582438155815755", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410455_1685899575033604_8064572259617996800_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RAwl5D2ztLkQ7kNvgExpGuc&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad-8tEOgJYnN4IvcPhjCo6H&oh=00_AYCbUDRTL8iaOPD3TfrD2cXmKhpbDC3JFrm9VNfAa9ML8w&oe=66EEB53A"}, {"file_name": "migrated_image.png", "id": "2986542838072922", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410271_1816492958588938_6237811970142109696_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=90x_9Lffym8Q7kNvgH-Qv8X&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad-8tEOgJYnN4IvcPhjCo6H&oh=00_AYBlWk4-hhZNSaLOWklfu61Dv0xAWcoJ4nFM-Typfs1kyg&oe=66EEB3AD"}, {"file_name": "migrated_image.png", "id": "2816675995090111", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138845_1897605223792843_4617680328188755968_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=79V2vNn_EpUQ7kNvgHE4a2p&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad-8tEOgJYnN4IvcPhjCo6H&oh=00_AYBVsJ8RJSQ9ixRQAyT98hcVB7yNXLcK4yf-A-05c2Fo7A&oe=66EEC09E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RealmCraft Survive, Mine & Craft Pro", "keywords": ["craft", "sandbox", "build", "worldcraft", "mine"], "long_description": "RealmCraft is a sandbox construction game with 3D procedurally generated world. Create and break apart various kinds of blocks, explore the environment, gather resources, craft weapons, build shelter and take part in combat with dangerous opponents.\nThe game offers two modes \u2013 Survival and Creative. In Survival players have to collect resources, construct buildings, fight against enemies, manage hunger and explore the word to survive and prosper. In Creative mode you focus on breaking new grounds of creation by building the most elaborate structures you can dream of.\nRealmcraft is a game for adults and kids, it will entertain you for a long time and earn an unforgettable experience.\n\u2022\t3D Sandbox construction game;\n\u2022\tHuge world to explore;\n\u2022\tCraft and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tGather resources to survive;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft survival game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-policy", "developer_terms_of_service_url": "http://www.tellurionmobile.com/privacy-policy", "publisher_name": "Tellurion mobile", "support_website_url": null, "website_url": "http://www.tellurionmobile.com/games/realmcraft", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "351111299953888"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410271_1771406839789700_3250046403363209216_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E-7DCaSJruYQ7kNvgEzNzvC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ad-8tEOgJYnN4IvcPhjCo6H&oh=00_AYBjGBVO2NbAg-CcX8kNZ0cSzSwfxtTRnlXMekOO2BSUFg&oe=66EEBA78"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RealmCraft Survive, Mine & Craft Pro", "platform": "ANDROID", "context_category": null, "context_topics": [], "relea