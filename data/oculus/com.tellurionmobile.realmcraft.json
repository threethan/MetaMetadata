ctures you can dream of.\nRealmcraft is a game for adults and kids, it will entertain you for a long time and earn an unforgettable experience.\n\u2022\t3D Sandbox construction game;\n\u2022\tHuge world to explore;\n\u2022\tCraft and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tGather resources to survive;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft survival game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-policy", "developer_terms_of_service_url": "http://www.tellurionmobile.com/privacy-policy", "publisher_name": "Tellurion mobile", "support_website_url": null, "website_url": "http://www.tellurionmobile.com/games/realmcraft", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "916370152578241"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1890223727901041"}]}, "baseline_offer": {"id": "1890223727901041"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1490202000, "status": "PUBLISHED", "id": "1890223727901041"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1473514782694068", "version": "1.2.1"}, "id": "1291572097576684", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__ty