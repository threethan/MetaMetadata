dn.com&oh=00_AYD6YTjxn4g6Nkw_w3dri1barmZkCWQExQxHCIckH5l1LA&oe=66F7F09F"}, {"file_name": "scr2.png", "id": "4469263816500261", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974647_4469263823166927_8732767113147487334_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3ZxA7-S0eUUQ7kNvgE9U-wS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDF8zflJV0UqwoIyp8gMcxMYF1fm-vskZ4uu_JN4gHESQ&oe=66F80583"}, {"file_name": "scr3.png", "id": "255066356582771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974647_255066359916104_5144166538512211946_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kTMZU2BK9NUQ7kNvgGmiFN4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9wZaTQasZX5eQ4jeoRAxlAR_sfyJUskp9zr0Rc_CXbw&oe=66F7E166"}, {"file_name": "scr4.png", "id": "6617753894931673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982679_6617753898265006_1890454066605037887_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFSzFetphEEQ7kNvgEOSjae&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4RdR5n236nAy3ZpirR3TQh1uEDll_7VYEyXuwwtWT3w&oe=66F7FF86"}, {"file_name": "scr5.png", "id": "246277687372076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_246277690705409_2473846080075905053_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bow6A8oXVigQ7kNvgHz5VVR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjMl95e5rxdpL59kIJdOEp89eZg_MANxNZ37cX06bEaw&oe=66F7DC5C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "scr1.png", "id": "654714935933991", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_654714939267324_4530836751251932482_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_rTeJ8Zm54oQ7kNvgH7dIS7&_nc_ht=scontent.oculuscdn.com&oh=00_AYD4ys_zwM5K9Fre_Qbhvtat0h24_jOSQfDvfHDpLDmC-A&oe=66F7DD24"}, "display_name": "Neon Kite", "keywords": [], "long_description": "** Neon Kite contains flashing imagery that may be uncomfortable for some users. But I\u2019m currently working on a no-flash mode.\n\n** This game is still in development and the upcoming updates are included.\nIf you are looking for a full game experience, I suggest that you wait for the official Oculus Store release. Your support is greatly appreciated!\n\nNeon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nJoysticks and buttons are not a thing in this game! Use your body to surf, steer, jump, spin, glide, and dive! \nScore points and add time to the timer by passing through the checkpoints with the appropriate board\u2019s color (red and blue, just like BeatSaber!).\nThe Sea is randomly generated, every try is unique!\n\nMusic made (and approved!) by ESCP\nSynthetic, Above The Clouds, Through The Waves, Neonscapes, Sundown, Goodbye Ocean, and Stardrive \nBy | e s c p | https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 Internation", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "338944941436659"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firs