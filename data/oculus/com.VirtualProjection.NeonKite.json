oculuscdn.com&oh=00_AYDZJUbnOse0R_yrP9Nizyy75W_U8TNvvRfI-bIk5xnkiw&oe=6728BBF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vidthumbsnail.png", "id": "962565014397132", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031384_962565017730465_4974300260370899112_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pYFs-BZV6X8Q7kNvgGps3d4&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYD8pC9qFJ3ibimgzeuD0LUfVCK4m_vqQYlwTopLWUEX8g&oe=6728B655"}, "display_name": "Neon Kite", "keywords": [], "long_description": "Neon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nThere are 4 game modes available so far:\nTutorial: Learn the basics.\nChill: Free Play mode with no goal.\nArcade: Hit the goals with the matching color of the board.\nSurvival: Don't get eaten...\n\nEnable Pro Mode for more realistic control.\n\nMusic: \nESCP - https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 International (CC BY 4.0)\nhttps://creativecommons.org/licenses/by/4.0/\n\nAnd Karl Casey @ White Bat Audio\n\nMore details on https://www.neonkitevr.com/music\n\n** Neon Kite may contain flashing imagery. Use the \"Light Mode\" at the beginning of the game for the same experience without flashes.\n\n** This game is still in development and the upcoming updates are included.\nYour support is greatly appreciated!", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459