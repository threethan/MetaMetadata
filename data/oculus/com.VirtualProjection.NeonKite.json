731_551966175910033_4667192882750974593_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KbC2iF10zS0Q7kNvgGmKNZw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBvftBmSJ3efO1TXjcmlybX6QFr27xJe92oYR9-cG7iQA&oe=670FBD1B"}]}, "id": "274444731441304", "locale": "en_US", "screenshots": [{"file_name": "tuto.png", "id": "631467191472740", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75223478_631467194806073_8772225009744351348_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=usdfWGZCaqMQ7kNvgHt8KDw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBlw8JhUibHBjxv3TFhN8lSxEjw7MlSpqKBeBB9KO1KlQ&oe=670F92D2"}, {"file_name": "freeplay.png", "id": "691154335397592", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001687_691154338730925_4607052658135489245_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QU5TN1OJL-QQ7kNvgEYHyEM&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB_kPGCINpiaKvlZuKzXpkn_hMcELdN4n5aCw5SFz_vjw&oe=670FB9CB"}, {"file_name": "darkmode.png", "id": "414389033820739", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982532_414389040487405_5912306278248968853_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qlsMBQrXE2QQ7kNvgEi6uDH&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDq6WGR_UNHVivth0SDjxkWmfNHnRPHG6DDqrmzi8lHbg&oe=670F8EBD"}, {"file_name": "arcade.png", "id": "630014648257746", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974472_630014651591079_7504793165658418968_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EhBhRyNv5ksQ7kNvgGiIFY6&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCWfRMiy4hz5-z61tYYQ_MJPWr8hvjMA3gmUuLM54rIcg&oe=670FBEB8"}, {"file_name": "survival.png", "id": "988436068735862", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75422391_988436072069195_1389652558864199259_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3BcjVYz9uxUQ7kNvgFiR2Uq&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBsoB2lQtDUHcD8JK87tsdZO_esQ5sJGQGWjFEIyESuKw&oe=670FAF73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vidthumbsnail.png", "id": "962565014397132", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031384_962565017730465_4974300260370899112_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWRJvscjGCwQ7kNvgF5BFZw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCqQMIA1k4Bf7iQ1I6pLMot6hXvv7jnhQrgMxYDQIzAww&oe=670FA9D5"}, "display_name": "Neon Kite", "keywords": [], "long_description": "Neon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nThere are 4 game modes available so far:\nTutorial: Learn the basics.\nChill: Free Play mode with no goal.\nArcade: Hit the goals with the matching color of the board.\nSurvival: Don't get eaten...\n\nEnable Pro Mode for more realistic control.\n\nMusic: \nESCP - https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 International (CC BY 4.0)\nhttps://creativecommons.org/licenses/by/4.0/\n\nAnd Karl Casey @ White Bat Audio\n\nMore details on https://www.neonkitevr.com/music\n\n** Neon Kite may contain flashing imagery. Use the \"Light Mode\" at the beginning of the game for the same experience without flashes.\n\n** This game is still in development and the upcoming updates are included.\nYour support is greatly appreciated!", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connecti