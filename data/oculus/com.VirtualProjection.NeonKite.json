dn.com&oh=00_AYCPn_InPTKNI6YNEQjnSM2Ea1XOfZEiu4CfEP2LsJ6VDA&oe=66F3FC1F"}, {"file_name": "scr2.png", "id": "4469263816500261", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974647_4469263823166927_8732767113147487334_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zd39zDLWxQMQ7kNvgFXDgEN&_nc_ht=scontent.oculuscdn.com&oh=00_AYC1PgSvMBHjbPMhToBKKjK41krZxdvgh4WbAeeso4ld6Q&oe=66F3D8C3"}, {"file_name": "scr3.png", "id": "255066356582771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974647_255066359916104_5144166538512211946_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N2poDrdLzc8Q7kNvgEdYMcC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWnnDStNWJymXXECcNwzeJJzL8QancikQnvbeEt11RjQ&oe=66F3ECE6"}, {"file_name": "scr4.png", "id": "6617753894931673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982679_6617753898265006_1890454066605037887_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IQCkpHRjqUwQ7kNvgFzSn0F&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9ZFrowb_TGu50mKb1KyadrSR2S2AQcdhuqSzJpzjCbw&oe=66F40B06"}, {"file_name": "scr5.png", "id": "246277687372076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_246277690705409_2473846080075905053_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HGloJbSVD_gQ7kNvgGOBlo3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDYUPwAkWoxz72GBaJUmehcP8zffEqb5fojM5I-oGpStQ&oe=66F3E7DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "scr1.png", "id": "654714935933991", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_654714939267324_4530836751251932482_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b5OKJF9GRqEQ7kNvgE9w9XC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFC76LVk97p2KNBFWEwUFgVuP4NCOQBVPpPomnWIRy8Q&oe=66F3E8A4"}, "display_name": "Neon Kite", "keywords": [], "long_description": "** Neon Kite contains flashing imagery that may be uncomfortable for some users. But I\u2019m currently working on a no-flash mode.\n\n** This game is still in development and the upcoming updates are included.\nIf you are looking for a full game experience, I suggest that you wait for the official Oculus Store release. Your support is greatly appreciated!\n\nNeon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nJoysticks and buttons are not a thing in this game! Use your body to surf, steer, jump, spin, glide, and dive! \nScore points and add time to the timer by passing through the checkpoints with the appropriate board\u2019s color (red and blue, just like BeatSaber!).\nThe Sea is randomly generated, every try is unique!\n\nMusic made (and approved!) by ESCP\nSynthetic, Above The Clouds, Through The Waves, Neonscapes, Sundown, Goodbye Ocean, and Stardrive \nBy | e s c p | https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 Internation", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "338944941436659"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firs