731_551966175910033_4667192882750974593_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WROymM1RqHAQ7kNvgGrhVU6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOWaE8RyLNVsDiPh2jVh1eFoq3fgQF09y5zd7JSNUjCA&oe=6709259B"}]}, "id": "274444731441304", "locale": "en_US", "screenshots": [{"file_name": "tuto.png", "id": "631467191472740", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_631467194806073_8772225009744351348_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqqBDp3d4EoQ7kNvgF7KTty&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3nTP8YNHeHV_6Sl6ypfOjk1sqeIwsvoqK8tey2NyCMg&oe=6708FB52"}, {"file_name": "freeplay.png", "id": "691154335397592", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_691154338730925_4607052658135489245_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nobhOXkZv3YQ7kNvgHhYuLs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDt8Tj7TpqOT96nCv_rEnmPZ-v0SvAnhiuuJFKpZWmkmg&oe=6709224B"}, {"file_name": "darkmode.png", "id": "414389033820739", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_414389040487405_5912306278248968853_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4VllaABF_sQ7kNvgHX1d4r&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEOAkfWaP0hCyaZcHSpJl63oi-6dE7CSQM2hmr3cOl3A&oe=6708F73D"}, {"file_name": "arcade.png", "id": "630014648257746", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974472_630014651591079_7504793165658418968_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PNsdiI6xZN8Q7kNvgHMbl7q&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAF_9qdSjjuy94Q0F2BLy7ucXyOy6RYbbtP4NiTqEsnw&oe=67092738"}, {"file_name": "survival.png", "id": "988436068735862", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422391_988436072069195_1389652558864199259_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MiqXyKppARAQ7kNvgGYRDAR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzZkTYMi_w4q2cM1KqsA95DOxONh-hcuMBeDXpnA4u8A&oe=670917F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vidthumbsnail.png", "id": "962565014397132", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031384_962565017730465_4974300260370899112_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zzf3zOvdQcEQ7kNvgEw1Zrr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDP1KLM1r9BJC4T0XwhOraWMq45qo5CeePHqBb7wKnQvQ&oe=67091255"}, "display_name": "Neon Kite", "keywords": [], "long_description": "Neon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nThere are 4 game modes available so far:\nTutorial: Learn the basics.\nChill: Free Play mode with no goal.\nArcade: Hit the goals with the matching color of the board.\nSurvival: Don't get eaten...\n\nEnable Pro Mode for more realistic control.\n\nMusic: \nESCP - https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 International (CC BY 4.0)\nhttps://creativecommons.org/licenses/by/4.0/\n\nAnd Karl Casey @ White Bat Audio\n\nMore details on https://www.neonkitevr.com/music\n\n** Neon Kite may contain flashing imagery. Use the \"Light Mode\" at the beginning of the game for the same experience without flashes.\n\n** This game is still in development and the upcoming updates are included.\nYour support is greatly appreciated!", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connecti