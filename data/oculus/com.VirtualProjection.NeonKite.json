NvgE7aKxY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEIojXlqY6gGg-CAIMmhHHL&oh=00_AYDBNo16-aoeZCw_mmlI4I7nwS6v_g0o9xydS80ajeFmiw&oe=66EEA1DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "scr1.png", "id": "654714935933991", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974854_654714939267324_4530836751251932482_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rLEN-E5tu0gQ7kNvgF1wUSk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEIojXlqY6gGg-CAIMmhHHL&oh=00_AYBmHLVhsgFhEe9NxELNl0ERyTxME5wKhp-PEfOY9iJm6Q&oe=66EEA2A4"}, "display_name": "Neon Kite", "keywords": [], "long_description": "** Neon Kite contains flashing imagery that may be uncomfortable for some users. But I\u2019m currently working on a no-flash mode.\n\n** This game is still in development and the upcoming updates are included.\nIf you are looking for a full game experience, I suggest that you wait for the official Oculus Store release. Your support is greatly appreciated!\n\nNeon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nJoysticks and buttons are not a thing in this game! Use your body to surf, steer, jump, spin, glide, and dive! \nScore points and add time to the timer by passing through the checkpoints with the appropriate board\u2019s color (red and blue, just like BeatSaber!).\nThe Sea is randomly generated, every try is unique!\n\nMusic made (and approved!) by ESCP\nSynthetic, Above The Clouds, Through The Waves, Neonscapes, Sundown, Goodbye Ocean, and Stardrive \nBy | e s c p | https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 Internation", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "