731_551966175910033_4667192882750974593_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=caMCqwRICxMQ7kNvgFAV-rA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDu3qh7OGJUjPkYbphKaR66_XVV1ICEYXPGu2UWHWN9rA&oe=6706829B"}]}, "id": "274444731441304", "locale": "en_US", "screenshots": [{"file_name": "tuto.png", "id": "631467191472740", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223478_631467194806073_8772225009744351348_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3FJqVOdsIEMQ7kNvgFmVv8s&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAaNXG9RY7VHPhlvhr8siPnRgEXiC08tVMYNh_dHMoQdA&oe=67065852"}, {"file_name": "freeplay.png", "id": "691154335397592", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_691154338730925_4607052658135489245_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fG__07DEK3EQ7kNvgFw80OW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCksryZqn4R0hUDZ3wXUSJglcXVPTnMnFefW6HgXNMNKg&oe=67067F4B"}, {"file_name": "darkmode.png", "id": "414389033820739", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982532_414389040487405_5912306278248968853_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZrySajRD0G4Q7kNvgEqIjxk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChyFQoVXxduZkojXboJVoyv14-fvxRb24uX93t99ptSg&oe=6706543D"}, {"file_name": "arcade.png", "id": "630014648257746", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974472_630014651591079_7504793165658418968_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02-NfVFiAOQQ7kNvgEp8rgG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBB5sgixfIKL9sMH0vbjGGQMJqa6YuVWTjigkr5DKc33g&oe=67068438"}, {"file_name": "survival.png", "id": "988436068735862", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422391_988436072069195_1389652558864199259_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tu2m01qaA3IQ7kNvgGdSLeC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCr6SgfXtPYJQTVIjcDMG4HX8ApvhOp8gt5-qyCgiG1Ng&oe=670674F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vidthumbsnail.png", "id": "962565014397132", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031384_962565017730465_4974300260370899112_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zzf3zOvdQcEQ7kNvgFwQ52t&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_S3a14wS_yAsg55dUMPD7KEgFwqCG8aMWQg1f0pg5pw&oe=67066F55"}, "display_name": "Neon Kite", "keywords": [], "long_description": "Neon Kite is a VR Arcade Kiteboarding Game inspired by the Synthwave genre.\n\nThere are 4 game modes available so far:\nTutorial: Learn the basics.\nChill: Free Play mode with no goal.\nArcade: Hit the goals with the matching color of the board.\nSurvival: Don't get eaten...\n\nEnable Pro Mode for more realistic control.\n\nMusic: \nESCP - https://escp-music.bandcamp.com\nMusic promoted by https://www.free-stock-music.com\nAttribution 4.0 International (CC BY 4.0)\nhttps://creativecommons.org/licenses/by/4.0/\n\nAnd Karl Casey @ White Bat Audio\n\nMore details on https://www.neonkitevr.com/music\n\n** Neon Kite may contain flashing imagery. Use the \"Light Mode\" at the beginning of the game for the same experience without flashes.\n\n** This game is still in development and the upcoming updates are included.\nYour support is greatly appreciated!", "short_description": "Neon Kite is a VR Arcade Kiteboarding Game."}]}, "developer_name": "Alexis Taillon", "developer_privacy_policy_url": "https://www.neonkitevr.com/privacy-policy", "developer_terms_of_service_url": "https://www.neonkitevr.com/terms-conditions", "publisher_name": "Alexis Taillon", "support_website_url": "https://www.neonkitevr.com/contact", "website_url": "https://www.neonkitevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connecti