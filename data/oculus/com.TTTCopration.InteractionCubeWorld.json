uluscdn.com/v/t64.5771-25/39035397_511883507961998_3206644178773059496_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJs6HT9QWHwQ7kNvgGQa8GS&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBFps1u_2qfsW5jk39IL0MmLO4qKn2gEMViKdjPGdf2HA&oe=671643F9"}, {"file_name": "2560x1440.png", "id": "1538784543729096", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39036669_1538784547062429_4997063347657464920_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_W_SS3tHRlQQ7kNvgHqyb9n&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBtuDFoEMrNBsIHrhcVSNQokfZTYQ8BlvjPiOOW3hCPKw&oe=67163C5A"}, {"file_name": "2560x1440 (1).png", "id": "1225251795505634", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39035428_1225251798838967_8748918207659702919_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fPZ8dhlWHbAQ7kNvgH8EwNX&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAPzlYZ8VDv02QOdGKBPhpEsZAmAQGAfsuM42CgdWT7dQ&oe=6716536F"}, {"file_name": "2560x1440 (2).png", "id": "818952757010626", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75240098_818952763677292_337638963599190306_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1cYcL5jf8CgQ7kNvgFwg0e-&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYB11hKo3W5LGy8YCO8RbL_i-QW07lnXKKAev9puAeUOEQ&oe=67164674"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (2).png", "id": "1300838367963911", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974838_1300838371297244_1125909428722011491_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mEQUZlwBBSIQ7kNvgF1twAP&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYC2DufjT7Ot41T8JO_5bOVPGnqKkDMhj0Zuh6CK4OU1Wg&oe=6716584A"}, "display_name": "Interaction World Cube", "keywords": [], "long_description": "Cube control: Players can grab, move, rotate, and arrange cube blocks in 3D space, creating countless creative possibilities.\nFree movement: Explore the virtual world by moving freely in space, allowing players to approach every angle of the environment.\nDiverse worlds: Each world in the application has its own theme and challenges, ranging from simple to complex environments.\nEnvironmental interaction: Cube blocks can interact with elements in the environment, creating interesting effects and outcomes.\nIn-app purchases (IAP): Players can unlock additional new worlds through the in-app purchase system, expanding their gaming experience and exploration.\nVivid graphics: Sharp 3D images and bright colors create an engaging and vibrant VR world.", "short_description": "Interaction World Cube is an innovative and interactive virtual reality (VR) application designed to provide a unique experience for VR headset users. In this virtual world, players explore and interact with the environment by controlling various cube blocks."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/interaction-world-cube-privacy-policy/08221178-c069-446b-92e7-5084b550f81f/privacy", "developer_terms_of_service_url": "https://doc-hosting.flycricket.io/interaction-world-cube-terms-of-use/559a5238-2fc1-4366-b76f-caf297bbad12/terms", "publisher_name": "Brittany Monique Patton", "support_website_url": null, "website_url": "https://46935909.hubspotpagebuilder.com/en-us/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7521661961272633"}}]}, "scheduled_of