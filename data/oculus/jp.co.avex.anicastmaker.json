5197399853879_5895608049786634442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t1O3WBWrnucQ7kNvgF9SPzu&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbhgFypVaEwN9-BtRmk-ODjUZ4G8_WtzOFbUh_ORoGyQ&oe=66EFF987"}]}, "id": "7170347216340432", "locale": "en_US", "screenshots": [{"file_name": "OculusStoreScreenShots_RiBLAStudio (1).png", "id": "273102968016554", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_273102971349887_779188435355882669_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=74louTDmDboQ7kNvgHCJWnK&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4M8UNh8XZaX8Hv7Vwqim1QRxJ_Yw_yse_Y7l78OPU4A&oe=66F00D6A"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (2).png", "id": "697308874580973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031409_697308877914306_6731253019227858404_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-3623VNQRMQ7kNvgHKAa8S&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTdmublDNKXIuW2N_hwfp7mUnYV7E9PNaI3ChO7rn7sw&oe=66EFFAFA"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (3).png", "id": "1077408826130508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1077408829463841_4948974064407223066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B76Xe7RpuNoQ7kNvgH9BN_A&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxHTh2uD0emi9AVAszwcSZXH6eXwxIGUYTTXroE6PiwQ&oe=66EFF70D"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (4).png", "id": "183450947263662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982714_183450950596995_6879906819951161205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HRIvXcw4_NIQ7kNvgG2mLr2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFWa1Rgwt05Yxu8S0RC6hXrP4tlqUj0NGbfQIpNIAAUQ&oe=66F01160"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (5).png", "id": "190611863145079", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982450_190611866478412_985025045164520959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=InAiTO-zO98Q7kNvgGUZaLa&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJONk-j2-T0MJkXqPIfaecl_T8fPK80mxW82hEgXzq3w&oe=66F00E6C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RiBLA Studio", "keywords": ["animation", "movie", "Illustration", "ribla", "riblastudio"], "long_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nIt comes pre-installed with 2 character models and a variety of props, backgrounds, motions, and songs.\n\nBranded asset packs for a variety of famous games/anime are also available as DLC.\n\nThe videos you make will be stored on your VR device and can be uploaded to your social media.\n\nNote that RiBLA Studio does not have video editing capabilities. If you want to add post-processing or combine the videos you made in the software, please do so on your PC.\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!\n\nNexTone License Number: ID000006972", "short_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!"}, {"images": {"nodes": [{"file_name": "RiBLA_storecover_1008_1440_32bit.png", "id": "1473765199647958", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_1473765202981291_993596309516703346_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0gdXpDbO8pMQ7kNvgHWRSNQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDs-o1pUrRHqik1ZUBgO4gihV6yxDcEttERwX0hAV5yzA&oe=66F0060D"}, {"file_name": "RiBLA_storecover_1080_360_32bit.png", "id": "1000077240559033", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_1000077243892366_4272330064269854710_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrZPTY1P0ocQ7kNvgFIW0Li&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsr8e079drCH_r5naNQbPASCdbk9ep8RdtokR_uttbUQ&oe=66EFE647"}, {"file_name": "RiBLA_pdp_3000_900_32bit.png", "id": "828536017819772", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031593_828536021153105_306459915418415906_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FRKd6dSQW5EQ7kNvgFPXBDX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGVoGE_fVURGS-yvT0HyrMfz2_9uefD27jLlKCS_cqEA&oe=66EFEC89"}, {"file_name": "RiBLA_logo_9000_1440.png", "id": "616363326193822", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_616363329527155_6132443976179137773_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JRJ_WTxCv4oQ7kNvgFBUk8r&_nc_ht=scontent.oculuscdn.com&oh=00_AYA520GJ3SasCwoWCNPHN3r1U20wAC6SgJfEFI1mRvrlVA&oe=66F016DE"}, {"file_name": "RiBLA_icon_512_512.png", "id": "567758624558234", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974876_567758627891567_2723737568588111134_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JY3x83G_-LwQ7kNvgEDRWMp&_nc_ht=scontent.oculuscdn.com&oh=00_AYD34LovqpLlR3EKGbscTbJQuetknnC1Tuhvq9_JC2_zSA&oe=66F019BA"}, {"file_name": "RiBLA_storecover_1440_1440_32bit.png", "id": "295905948605234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_295905951938567_7586026332632706017_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc