MG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86659797_255197399853879_5895608049786634442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q1-XqFma5TIQ7kNvgHJ5PnE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGZVpOc1_XPlSzNbpH94f7zp4PH4JEgpy8OkoucVXveA&oe=671E1E07"}]}, "id": "7170347216340432", "locale": "en_US", "screenshots": [{"file_name": "OculusStoreScreenShots_RiBLAStudio (1).png", "id": "273102968016554", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982459_273102971349887_779188435355882669_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDFMD3bB7rsQ7kNvgE0pFrK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3rIrQFQJ32K9hUHBrQNnlp6OkL6wxpI8eeUg0SOLyQg&oe=671E31EA"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (2).png", "id": "697308874580973", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031409_697308877914306_6731253019227858404_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M87Vv2EntVEQ7kNvgGfqmNT&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZrzVcPUDjjgC4wHbrRaH2lNFnDQ19PkJ65v0H_kuSKg&oe=671E1F7A"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (3).png", "id": "1077408826130508", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974456_1077408829463841_4948974064407223066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jil416Q2v9wQ7kNvgHUMPyo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRVtHTpCBsbOYHHeliM7vWNASxs7XnCgtemVoFG70bCA&oe=671E1B8D"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (4).png", "id": "183450947263662", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982714_183450950596995_6879906819951161205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EZtAMv8Vx-wQ7kNvgEUHBQW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9o0gX8Y3GC8yw5DfAdNvL-FY5nNx7nkL7hie1bRDmaw&oe=671E35E0"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (5).png", "id": "190611863145079", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982450_190611866478412_985025045164520959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nLqT-mihnB8Q7kNvgFFzyqr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATCtmsHAdrAA_eGqljW_rUNgcMA9ZcV2CQLy9MEQRR2A&oe=671E32EC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RiBLA Studio", "keywords": ["animation", "movie", "Illustration", "ribla", "riblastudio"], "long_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nIt comes pre-installed with 2 character models and a variety of props, backgrounds, motions, and songs.\n\nBranded asset packs for a variety of famous games/anime are also available as DLC.\n\nThe videos you make will be stored on your VR device and can be uploaded to your social media.\n\nNote that RiBLA Studio does not have video editing capabilities. If you want to add post-processing or combine the videos you made in the software, please do so on your PC.\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!\n\nNexTone License Number: ID000006972", "short_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!"}, {"image