797_255197399853879_5895608049786634442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xYEbrgq946AQ7kNvgEkbFN6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKaB4t1hg3zkCtKvN8yBWEKinq4zqlu6VDQzyE78LBgA&oe=66D05587"}]}, "id": "7170347216340432", "locale": "en_US", "screenshots": [{"file_name": "OculusStoreScreenShots_RiBLAStudio (1).png", "id": "273102968016554", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_273102971349887_779188435355882669_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDyfgG_khmUQ7kNvgGtyQnE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEjFmAF0EiDO7AekUt5M3ZR3mWy4nnXAd3v6LUbVoYUA&oe=66D0696A"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (2).png", "id": "697308874580973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031409_697308877914306_6731253019227858404_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ev12BKAqmCkQ7kNvgFjPpdF&_nc_ht=scontent.oculuscdn.com&oh=00_AYABsz3dv5nhC2iVOFTKYor4j7yQ3EEEYFDB1Qy1nLoWVQ&oe=66D056FA"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (3).png", "id": "1077408826130508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1077408829463841_4948974064407223066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tj4NYVae92sQ7kNvgFhAWFs&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcJZq-pr5JMLHZhkiVHD-N256dJWAmdVOz1fOD1O64Dw&oe=66D0530D"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (4).png", "id": "183450947263662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982714_183450950596995_6879906819951161205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Q1yXf-ggqQQ7kNvgEUB5bq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtWOcLouaPTtXruO6zJyJHZ3omMRy29-RnlZpo-8e8lg&oe=66D06D60"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (5).png", "id": "190611863145079", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982450_190611866478412_985025045164520959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zmirmwhEprkQ7kNvgF2JDP8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDxTgA8m8yDqxXBKoTXetb-PIaQxGhkz7nSNegEmqz-w&oe=66D06A6C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RiBLA Studio", "keywords": ["animation", "movie", "Illustration", "ribla", "riblastudio"], "long_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nIt comes pre-installed with 2 character models and a variety of props, backgrounds, motions, and songs.\n\nBranded asset packs for a variety of famous games/anime are also available as DLC.\n\nThe videos you make will be stored on your VR device and can be uploaded to your social media.\n\nNote that RiBLA Studio does not have video editing capabilities. If you want to add post-processing or combine the videos you made in the software, please do so on your PC.\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!\n\nNexTone License Number: ID000006972", "short_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!"}, {"images": {"nodes": [{"file_name": "RiBLA_storecover_1008_1440_32bit.png", "id": "1473765199647958", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oc