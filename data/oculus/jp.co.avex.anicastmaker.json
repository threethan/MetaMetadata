5197399853879_5895608049786634442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rv1hU6cw-fwQ7kNvgG7RAmr&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFVhQpzd0JE7rv8iwi8yrBFb8xvtvC018IQ58Q2892ag&oe=66FD2887"}]}, "id": "7170347216340432", "locale": "en_US", "screenshots": [{"file_name": "OculusStoreScreenShots_RiBLAStudio (1).png", "id": "273102968016554", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_273102971349887_779188435355882669_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=duq8cJ_YcLwQ7kNvgFXjG-K&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeU6yT-vkbOC1DK7NVbnOTaVfPcJVHSYb-wY4bxyVCng&oe=66FD3C6A"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (2).png", "id": "697308874580973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031409_697308877914306_6731253019227858404_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nxs1Bxs27wkQ7kNvgHOPCZR&_nc_ht=scontent.oculuscdn.com&oh=00_AYC1ybrnIOKmNw6EoonQNaJ3VZZkBf9w1QRsNcHvbF_HaQ&oe=66FD29FA"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (3).png", "id": "1077408826130508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1077408829463841_4948974064407223066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1aNV_2IlQsoQ7kNvgFD7eP_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRDX1zM19RJDWALHGn1NsADA2hZILWNTbgM1YRpgqk-g&oe=66FD260D"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (4).png", "id": "183450947263662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982714_183450950596995_6879906819951161205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qASPCCqRcEcQ7kNvgFdmrkY&_nc_ht=scontent.oculuscdn.com&oh=00_AYBOHKCbWPPiHee2AThxuWTO5LSM1LZyxx0PUx3uT2qw2g&oe=66FD4060"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (5).png", "id": "190611863145079", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982450_190611866478412_985025045164520959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bx7dHObgdWEQ7kNvgG-OuI9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAvjNcWlcBUW3wVBZbYwOJ0iAJ5Cfnb0WqujRzXOoomg&oe=66FD3D6C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RiBLA Studio", "keywords": ["animation", "movie", "Illustration", "ribla", "riblastudio"], "long_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nIt comes pre-installed with 2 character models and a variety of props, backgrounds, motions, and songs.\n\nBranded asset packs for a variety of famous games/anime are also available as DLC.\n\nThe videos you make will be stored on your VR device and can be uploaded to your social media.\n\nNote that RiBLA Studio does not have video editing capabilities. If you want to add post-processing or combine the videos you made in the software, please do so on your PC.\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!\n\nNexTone License Number: ID000006972", "short_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!"}, {"images": {"nodes": [{"file_name": "RiBLA_storecover_1008_1440_32bit.png", "id": "1473765199647958", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_1473765202981291_993596309516703346_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tJZiY7U8uTAQ7kNvgHEVdYc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzrhQPRMsa5xhcNG4hq3Ky7NJpTa_TmdkkioaxaCEKeg&oe=66FD350D"}, {"file_name": "RiBLA_storecover_1080_360_32bit.png", "id": "1000077240559033", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_1000077243892366_4272330064269854710_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FaqmreAlZ-4Q7kNvgH-VxBI&_nc_ht=scontent.oculuscdn.com&oh=00_AYD44WjF7zCnASmbtG5d_-fCIDxr8WLYdtd1k5oIHzWLuw&oe=66FD4D87"}, {"file_name": "RiBLA_pdp_3000_900_32bit.png", "id": "828536017819772", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031593_828536021153105_306459915418415906_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gVZo8UUH8GAQ7kNvgHEQv5Y&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBDZfXLl1kXtFxCTNrYVYH9IX3q7isDJbqdAg8u25Y7Q&oe=66FD1B89"}, {"file_name": "RiBLA_logo_9000_1440.png", "id": "616363326193822", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_616363329527155_6132443976179137773_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-xU_LxAGZjEQ7kNvgG9CqJk&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsFXW6bjbKU1Ly95U6B_H5cz_jTxu3efgr8H4FsHT8VQ&oe=66FD45DE"}, {"file_name": "RiBLA_icon_512_512.png", "id": "567758624558234", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974876_567758627891567_2723737568588111134_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B0chx_R1w6wQ7kNvgF2zU5y&_nc_ht=scontent.oculuscdn.com&oh=00_AYCylDGRZhtNyCO1okqqcQ1lFHj-xm8tf-gH06lCzze3pA&oe=66FD48BA"}, {"file_name": "RiBLA_storecover_1440_1440_32bit.png", "id": "295905948605234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_295905951938567_7586026332632706017_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc