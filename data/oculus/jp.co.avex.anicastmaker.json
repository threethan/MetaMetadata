44186855829349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_2844186859162682_8085435314957239315_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y2qOMI5dU5MQ7kNvgGq7_ry&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5IusombxWsLXXUt0yXcSSZKjKdvF_ifqMZGsjxtifug&oe=66FD1E2B"}, {"file_name": "OculusStoreScreenShots_AniCastMaker_03.png", "id": "884478222319364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222940_884478225652697_7825539458127569612_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F7jFO-q0cwEQ7kNvgEv8vFv&_nc_ht=scontent.oculuscdn.com&oh=00_AYCO0PRx95xgLBChnWhBVGYrgTZvFUsXzdUhQO63XU4BCg&oe=66FD1D22"}, {"file_name": "OculusStoreScreenShots_AniCastMaker_04.png", "id": "1056975268111382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240104_1056975271444715_1364432754935865733_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ApNx6vbPLXMQ7kNvgHsarpA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCXJUpVq6LPSWmqh4yRfKoGXxfbTP7tViqDdx7m5XhFg&oe=66FD1CC3"}, {"file_name": "OculusStoreScreenShots_AniCastMaker_05.png", "id": "2200996183367187", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974829_2200996186700520_1941599785280498996_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WSk3WsJKuicQ7kNvgG-Nwxq&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_7gsR2jMeVR9aWuoaAxMCjGdMQ9mWWyq_Hx8KXPaVUQ&oe=66FD1D86"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AniCast Maker", "keywords": ["anicast", "anicastmaker", "animation", "movie", "Illustration"], "long_description": "AniCast Maker is the simple and easy way for anybody to make their very own videos in VR.\nBe the actor, be the cameraman, place props and backgrounds, whatever you need to bring your creative dream to life!\n\nThe tool comes with tons of backgrounds, props, and character motions for you to jump right in and make all kinds of animations. You can even upload your videos to social media to get an instant reaction from your audience.\n\nWe'll also be teaming up with famous game, anime, and manga creators to bring their stuff to AniCast, too, as well as creating official contests where you can enter your videos to win! See our official homepage for details.\n\nWe hope you'll enjoy AniCast Maker, the easy way to make animation every day!", "short_description": "AniCast Maker gives you your very own VR recording studio, so you can make your own short animations in VR! Be the actor, be the cameraman, whatever you want to do to make your creative dream come to life. \n\nThe software comes with two 3D character models, as well as plenty of backgrounds, props, and animated motions for you to jump right and in make all kinds of short animations.  Upload what you made to Twitter, Facebook, YouTube, and other social networks, so that others can see your brillian"}]}, "developer_name": "XVI Inc.", "developer_privacy_policy_url": "https://avex.com/jp/en/public/privacy/", "developer_terms_of_service_url": "https://anicast-maker.com/terms", "publisher_name": "Avex Technologies Inc.", "support_website_url": null, "website_url": "https://anicast-maker.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "512296800417392"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "379724129751422"}, {"status": "PUBLISHED", "id": "369838998537567"}]}, "baseline_offer": {"id": "379724129