5197399853879_5895608049786634442_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jY3L7xjIsxsQ7kNvgEiU0q7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSdl4-HXSWp_zX8ocKCSRn01SZPh0RPIrOD9mEOwWGRg&oe=66F69107"}]}, "id": "7170347216340432", "locale": "en_US", "screenshots": [{"file_name": "OculusStoreScreenShots_RiBLAStudio (1).png", "id": "273102968016554", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_273102971349887_779188435355882669_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDOhCMxwa1kQ7kNvgHtBtmB&_nc_ht=scontent.oculuscdn.com&oh=00_AYD169OX1BmgfgR6_jM3tDpJD39BmmV_4xBkX0DvSojQ7g&oe=66F6A4EA"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (2).png", "id": "697308874580973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031409_697308877914306_6731253019227858404_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fpKNv0N_YGUQ7kNvgFz5_RT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCARSIjEYrmwKe5yGzu1kzaREkxZ7LznT0MSZm7ujQGbw&oe=66F6927A"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (3).png", "id": "1077408826130508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1077408829463841_4948974064407223066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aWhBuCV2EOsQ7kNvgFCe2_v&_nc_ht=scontent.oculuscdn.com&oh=00_AYAe5DEp3Fi-KY7849EyrSAaKTVGTF2yY5Sod7bVnlRvuw&oe=66F68E8D"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (4).png", "id": "183450947263662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982714_183450950596995_6879906819951161205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eCO9EoHPL-cQ7kNvgFXewCc&_nc_ht=scontent.oculuscdn.com&oh=00_AYD7AyXYmPUK0BOnmCo3hMkDOErVNeUBCTTXSD92d-UTrw&oe=66F6A8E0"}, {"file_name": "OculusStoreScreenShots_RiBLAStudio (5).png", "id": "190611863145079", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982450_190611866478412_985025045164520959_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s3NZN2QyfW4Q7kNvgEEgYf0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiZD5vwfij3bR6MVira0VJ5eSb1NDSCRc5HL0UgTNJPQ&oe=66F6A5EC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RiBLA Studio", "keywords": ["animation", "movie", "Illustration", "ribla", "riblastudio"], "long_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nIt comes pre-installed with 2 character models and a variety of props, backgrounds, motions, and songs.\n\nBranded asset packs for a variety of famous games/anime are also available as DLC.\n\nThe videos you make will be stored on your VR device and can be uploaded to your social media.\n\nNote that RiBLA Studio does not have video editing capabilities. If you want to add post-processing or combine the videos you made in the software, please do so on your PC.\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!\n\nNexTone License Number: ID000006972", "short_description": "RiBLA Studio is the simple and easy way for anybody to make their very own videos in VR. Be the actor, be the cameraman, whatever you need to bring your creative dream to life!\n\nUse your own 3D models, images, props, motions, and songs to make your very own anime video! RiBLA Studio supports the following asset formats:\n\n\u30fb3D Character Models: VRM\n\u30fbStatic Images: JPG, PNG\n\u30fb3D Prop Models: OBJ\n\u30fbMotions: BVH\n\u30fbMusic: WAV\n\nWe hope you'll enjoy RiBLA Studio, the easy way to make animation every day!"}, {"images": {"nodes": [{"file_name": "RiBLA_storecover_1008_1440_32bit.png", "id": "1473765199647958", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_1473765202981291_993596309516703346_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9ewMbYgUX4Q7kNvgGd5aGR&_nc_ht=scontent.oculuscdn.com&oh=00_AYD48Q_mDUF7PGLmjz3BRh77QQfi0l7AGmfZ4nf-x_SnLw&oe=66F69D8D"}, {"file_name": "RiBLA_storecover_1080_360_32bit.png", "id": "1000077240559033", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_1000077243892366_4272330064269854710_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6-qGfMaRLAIQ7kNvgFqRmzz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfgzQ4ycp1Dh0bRYCM2nANhLVr2379fhctiEWUkSZ4Hg&oe=66F67DC7"}, {"file_name": "RiBLA_pdp_3000_900_32bit.png", "id": "828536017819772", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031593_828536021153105_306459915418415906_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sn8jEyvO9CQQ7kNvgFNJklo&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoHk9vmdHQNBegpAxEZis12qfGK3nsdmgUiMd8z7ghQA&oe=66F68409"}, {"file_name": "RiBLA_logo_9000_1440.png", "id": "616363326193822", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_616363329527155_6132443976179137773_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tKsb77zh49sQ7kNvgEd2CIP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzhU4yoGyeqhHjN51xl5eHlHsZzOAzRxyQrW8vSEPPZA&oe=66F6AE5E"}, {"file_name": "RiBLA_icon_512_512.png", "id": "567758624558234", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974876_567758627891567_2723737568588111134_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8hZ-zDMMSBQQ7kNvgE1fw9Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiS4iDM0_Zjg8wBU7wkFHJ4HeIU-Q8WqmSdrOk-Drc4w&oe=66F6B13A"}, {"file_name": "RiBLA_storecover_1440_1440_32bit.png", "id": "295905948605234", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_295905951938567_7586026332632706017_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc