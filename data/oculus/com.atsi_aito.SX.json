8FcSg5Vwdab8fhJ0xabe7q_7ewo97g&oe=676BF937"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QAA_ehAb1xYQ7kNvgGF65PT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8iGH4Ih1DqIWyltYu2YqGcC6H8_HrTECYLmxAI2A7CQ&oe=676BE528"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJAnGvXpnWsQ7kNvgHKw4A3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDG6qtNI-PXuqFPOdHON9LryW9BvvsPzQIaVxw8zWsevg&oe=676BDAD7"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}, {"images": {"nodes": [{"file_name": "SX_HA2.png", "id": "3000425346762311", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974640_3000425350095644_345006402581541278_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OKjmhznPMDMQ7kNvgGGIMS9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAD31FjAOH2UqP3OtMO8s3qnGTGKgwEzu-ahxlHrq1RZw&oe=676C0238"}, {"file_name": "SX_CA_T.png", "id": "2224180891334863", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974746_2224180894668196_895140125717342456_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TLzeLy1zPFgQ7kNvgHDoXUA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApmJ1NE9xP1X23tHL354VaDKUFHcTVvZ84oH1brB9EQQ&oe=676BDBC6"}, {"file_name": "SX_CA_Y.png", "id": "1340026530594820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974698_1340026533928153_7341861088547730429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kzvDtrij-SkQ7kNvgFG5jsR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdKuKT2xvh_2skqz_8Jnfu9mP_PLLnFb6uSQA7FWG_QQ&oe=676BF067"}, {"file_name": "SX_CA_S.png", "id": "1268504654463382", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_1268504657796715_5860926403406078022_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AQzis8NYSkoQ7kNvgHcyG5b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJe-PkPqyxIupT9wmEF335KKMBqo5vzB3BziELLxLjSw&oe=676BD499"}, {"file_name": "SX_Logo2_App.png", "id": "1026115838000804", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_1026115841334137_3621258998052191638_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wcy10zInq-IQ7kNvgGbERUR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfnGcleCosd_VY-voTilE1OWkHASfgUvZ9TuPyg9NhHg&oe=676BE66E"}, {"file_name": "SX_