4b\u7247\u65b9\u306e\u624b\u304c\u30b0\u30fc\n   \u6575\u306e\u653b\u6483\u3092\u9632\u3050\u76fe\u304c\u51fa\u307e\u3059\u3002\n   \u6575\u306e\u653b\u6483\u304c\u63a5\u8fd1\u3057\u305f\u3089\u3001\u76fe\u3067\u9632\u304e\u307e\u3057\u3087\u3046\u3002\n\n\u30b7\u30ca\u30ea\u30aa\u304c\u9032\u3080\u3068\u3001\u5168\u4f53\u653b\u6483\u304c\u4f7f\u7528\u3067\u304d\u307e\u3059\u3002\n\n\uff08\u30a2\u30a4\u30c6\u30e0\u306e\u8aac\u660e\u306f\u30a6\u30a7\u30d6\u30b5\u30a4\u30c8\u3092\u3054\u53c2\u7167\u304f\u3060\u3055\u3044\u3002\uff09\n\n\u2022 \u30b2\u30fc\u30e0\u306e\u9032\u3081\u65b9\n1.\u30b9\u30bf\u30fc\u30c8\n   \u8d77\u52d5\u3059\u308b\u3068\u3001\u30b7\u30b9\u30c6\u30e0\u306e\u30ca\u30d3\u30b2\u30fc\u30b7\u30e7\u30f3\u304c\u59cb\u307e\u308a\u307e\u3059\u3002\n   \u30b9\u30bf\u30fc\u30c8\u30c7\u30d0\u30a4\u30b9\u306b\u89e6\u308c\u308b\u3068\u30b9\u30bf\u30fc\u30c8\u3057\u307e\u3059\u3002\n2.\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\n   \u5f0f\u795e\u3092\u9078\u629e\u3059\u308b\u3068\u3001\u3057\u3070\u3089\u304f\u3057\u3066\u6226\u95d8\u30b7\u30df\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u304c\u59cb\u307e\u308a\u307e\u3059\u3002\n3.\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\n   \u30c0\u30e1\u30fc\u30b8\u3092\u53d7\u3051\u904e\u304e\u3066\u3001\u300c\u6301\u7d9a\u53ef\u80fd\u6027\u300d\u304c\u300c0\u300d\u306b\u306a\u308b\u3068\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3067\u3059\u3002\n\n\u2022 \u30b9\u30c8\u30fc\u30ea\u30fc\n\u305d\u3053\u306f\u3001\u904e\u53bb\u304b\u672a\u6765\u304b\u73fe\u5728\u304b\u3002\n\u3042\u306a\u305f\u304c\u8d77\u52d5\u3057\u305f\u306e\u306f\u3001\u3044\u3064\u9020\u3089\u308c\u305f\u306e\u304b\u3082\u4e0d\u660e\u306a\u4e00\u3064\u306e\u30b7\u30df\u30e5\u30ec\u30fc\u30bf\u30fc\u3002\n\u305d\u306e\u30b7\u30df\u30e5\u30ec\u30fc\u30bf\u30fc\u306e\u7528\u9014\u3082\u4e0d\u660e\u3002\u5229\u7528\u76ee\u7684\u3082\u4e0d\u660e\u3002\n\u552f\u4e00\u5206\u304b\u3063\u3066\u3044\u308b\u306e\u306f\u3001\u30b7\u30b9\u30c6\u30e0\u306e\u30ca\u30d3\u30b2\u3