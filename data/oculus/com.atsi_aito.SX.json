0314101793_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_SYN-FD0xiAQ7kNvgG9dU5y&_nc_ht=scontent.oculuscdn.com&oh=00_AYBU-lgirleCtBS4nq7WyEKr7OajWop09jGloQpURIqy9g&oe=66D1B9B7"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=83-eHmvpceoQ7kNvgHxDMEv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsWz_RSBsKnwC0LyOsEerIna2lS1Zw5bNXND5RLR_u2w&oe=66D1A5A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OimGpHXItskQ7kNvgGcIJ6x&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdbcuYI_Ln8_e4bG3mmtvvx_EHZkp1YSEi54WnVIa_gw&oe=66D19B57"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_descripti