BeU3s3nr4RhSooWMgvB4p4w5mRPUXg&oe=67601BB7"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iMQnId-nh5kQ7kNvgEK2Ldq&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAa_tiYB3A0H1YX1EWOylrnnlJsdCk83QIj3XUOMHGnNg&oe=676007A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0WzcVCoUJQ4Q7kNvgFEHzFS&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBJXUuHi2BjsNE7BrUGhkE0mOX9l98qcgVf4Jak96BgHw&oe=675FFD57"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}, {"images": {"nodes": [{"file_name": "SX_HA2.png", "id": "3000425346762311", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974640_3000425350095644_345006402581541278_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aiApm72DWYEQ7kNvgGnWkBG&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBqz3uBhIFpciA_e0w-sYeCYnFtllU4mEpYZhanf7Ipig&oe=676024B8"}, {"file_name": "SX_CA_T.png", "id": "2224180891334863", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974746_2224180894668196_895140125717342456_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3aUr3zrLJKQQ7kNvgGqMGwF&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAtyrXasQeD7yehYrw0nS0Cr-47HbdDY6aCJSLPCg2QMA&oe=675FFE46"}, {"file_name": "SX_CA_Y.png", "id": "1340026530594820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974698_1340026533928153_7341861088547730429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c4AH278Zl0wQ7kNvgHMwebV&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD60Vlr14rb6YjhKWCSrEh_gPe0c5oRe1ooktRD6jj3QA&oe=676012E7"}, {"file_name": "SX_CA_S.png", "id": "1268504654463382", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982658_1268504657796715_5860926403406078022_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B3byhMxdbQEQ7kNvgEINqGd&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBaJn7auVzppNhR6zC_J9SLTyAn7Qe4hLGNR76QPA7ebQ&oe=67602F59"}, {"file_name": "SX_Logo2_App.png", "id": "1026115838000804", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974676_1026115841334137_3621258998052191638_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5XyGIqEmaRIQ7kNvgHKxola&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAKCzDxWMSMMbPYOgHoD6J8SvfK7VlL4rY_mSEqBQqA4Q&oe=676008EE"}, {"file_name": "SX_