C743"}, {"file_name": "SS4.png", "id": "754772309021381", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974748_754772312354714_7880261410314101793_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_SYN-FD0xiAQ7kNvgG9dU5y&_nc_ht=scontent.oculuscdn.com&oh=00_AYBU-lgirleCtBS4nq7WyEKr7OajWop09jGloQpURIqy9g&oe=66D1B9B7"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=83-eHmvpceoQ7kNvgHxDMEv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsWz_RSBsKnwC0LyOsEerIna2lS1Zw5bNXND5RLR_u2w&oe=66D1A5A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OimGpHXItskQ7kNvgGcIJ6x&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdbcuYI_Ln8_e4bG3mmtvvx_EHZkp1YSEi54WnVIa_gw&oe=66D19B57"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/simulationx", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "802503011164175"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_261824789459093_1157296341310408568_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CMeE1NPO8CQQ7kNvgF1lhkD&_nc_ht=scontent.oculuscdn.com&oh=00_AYATColx7ARIqZgVdcXbr6kbyuImz4AUY1tsY_Dg971kAA&oe=66D1A41D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Simulation X", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1662163009, "lastRevision": {"nodes": [{"id": "619288542712364", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4377945368976623", "is_first_party": false, "enables_in_app_ads": false, "is_concep