XDUFY63JxN9sODJ87HT9I9Nes_uzxw&oe=6752ECB7"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dd2EF08V0McQ7kNvgE4SKtK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7jiIPFtSJ0VEE_sBMIj-Xa10XI4ZIdBObzC5eGJ_Eew&oe=6752D8A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vq7w4lmlpnUQ7kNvgF10RaX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkgIzwgxPNokLvDb0ru9xfMT06NVKSpbBI22EN8SLOhw&oe=6752CE57"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}, {"images": {"nodes": [{"file_name": "SX_HA2.png", "id": "3000425346762311", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974640_3000425350095644_345006402581541278_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lyJ4Gv4RHQwQ7kNvgE0NnnV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxcC9PPXm9RKO4HCy5lO3hXyrPaRxdxsUp262iAii96A&oe=6752F5B8"}, {"file_name": "SX_CA_T.png", "id": "2224180891334863", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974746_2224180894668196_895140125717342456_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=euE6rDksrF0Q7kNvgHa-HGQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1aPkqI7x5EQyT8v3g7T2iMknP7w2GIfZKwTfRxqObhQ&oe=6752CF46"}, {"file_name": "SX_CA_Y.png", "id": "1340026530594820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974698_1340026533928153_7341861088547730429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Qk4ymY7wFAQ7kNvgF1DtYc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBcNTj_kNLhgT-rM4QOYa4B7fy9-SxXF2PU5oQ2zZItdg&oe=6752E3E7"}, {"file_name": "SX_CA_S.png", "id": "1268504654463382", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_1268504657796715_5860926403406078022_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fAoGQg3VTMAQ7kNvgFTgy5v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD6ar_lCAsJPOdALYm14u_hrPRwSdKeP8i0Eu9Sa_1IOw&oe=67530059"}, {"file_name": "SX_Logo2_App.png", "id": "1026115838000804", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_1026115841334137_3621258998052191638_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LD-EMuxSs1MQ7kNvgEwdNE6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCge5OAm84wRNlAs7GRB098Zhlnk0JlXI1uweaQpwnYfQ&oe=6752D9EE"}, {"file_name": "SX_