me": "SS3.png", "id": "723134115394774", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39031454_723134118728107_4043384121724302618_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WYF6AnfKWk4Q7kNvgEV41E0&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCOQVRVQP-FNhelBj4xkYmKdHQea6s1jHZUUiHjW6Em-Q&oe=671A49C3"}, {"file_name": "SS4.png", "id": "754772309021381", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974748_754772312354714_7880261410314101793_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cjmpWP161OEQ7kNvgFuYuMH&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAmIR0IQpi6796nxfqcbEY4nio2ujGpErAi9HZe2aTP2A&oe=671A3C37"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jvkZSpN_3VIQ7kNvgHaJ5sd&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDkaBaZS-Jn4j-27ofMeUA-frXkTaAWxicBhQ14c2ohtg&oe=671A2828"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2VLVDOI2GwAQ7kNvgE0_enW&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBv5cVzuT6IPwyeqLXMahGeGwQMIsLqNeZ8zV3dAzHe2Q&oe=671A1DD7"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/simulationx", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "802503011164175"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974493_261824789459093_1157296341310408568_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K1MDtSCCk5EQ7kNvgE-804p&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAnkJuudsy4c3UuJxhxGlDTdPzXcnbyejKfCgRYLxH0yg&oe=671A269D"}, "is_concept": false, "is_test": false, "is_trial_off