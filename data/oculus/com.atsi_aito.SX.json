WXacsXdQtMurhll5jryeus92hSmGPw&oe=674EF837"}, {"file_name": "SS5.png", "id": "390055603063549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035320_390055606396882_5049138452910400198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Au00yUKpPYwQ7kNvgEV22gV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfxSkjaW96P2m8CmhCmFQEJgfTaJekK8GBR6xHjRrAjg&oe=674EE428"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "676592056732564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462961_676592060065897_4767015868477364991_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vo8SVOr-3hsQ7kNvgHAeWfR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBirKzopzK5ytyHWsg_OcJ0ks85i4SEtc-YWxkCP6xAmA&oe=674ED9D7"}, "display_name": "Simulation X", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\nAs the scenario progresses, you can use a Bomb Attack.\n\n(Please refer to the website for a description of the items in the game.)\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.\n3.GameOver\nThe game is over when you receive a lot of damage and the \"sustainability\" reaches \"0\".", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}, {"images": {"nodes": [{"file_name": "SX_HA2.png", "id": "3000425346762311", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974640_3000425350095644_345006402581541278_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MXol4DuR6cIQ7kNvgHanqxm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBWM5OGKBgNL3AQd-em3pxRMMe3b4dwIdUBGX4lNkVUgA&oe=674F0138"}, {"file_name": "SX_CA_T.png", "id": "2224180891334863", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974746_2224180894668196_895140125717342456_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8YQXA6f3f6wQ7kNvgH5n8SN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQyJozrpbmViwLgSSXP9Op_uHcTyMAbHl5rCkokFUrVQ&oe=674EDAC6"}, {"file_name": "SX_CA_Y.png", "id": "1340026530594820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974698_1340026533928153_7341861088547730429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fF7upG9w8uEQ7kNvgHx_69D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5cFqBBUCKJNkJTK6-PuZYkA5ckXgbMu0dgoDl2zaybA&oe=674EEF67"}, {"file_name": "SX_CA_S.png", "id": "1268504654463382", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_1268504657796715_5860926403406078022_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CJbAFDCe_S8Q7kNvgFOElH2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAT3De0jvW6tztTBHIvHtsr-kEVT7z7tHZPfbN3sKofUQ&oe=674F0BD9"}, {"file_name": "SX_Logo2_App.png", "id": "1026115838000804", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_1026115841334137_3621258998052191638_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2dJCa_c0w1gQ7kNvgFg5Wrq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBy3DF2bC4k3IG77Z3pmeL8CZhc2L62Dsev59tQG8oN_A&oe=674EE56E"}, {"file_name": "SX_