019s like to be on the field with the Saskatchewan Roughriders, or  hop on stage at the Regina Folk Festival! Love food? Party at the Market Under the Stars with tons of vendors and music, or get up close and personal with a bull at Canadian Western Agribition.", "short_description": "See Regina through the eyes of the locals in this 360 virtual reality experience."}]}, "developer_name": null, "developer_privacy_policy_url": "http://tourismregina.com/terms-of-use/", "developer_terms_of_service_url": "http://tourismregina.com/terms-of-use/", "publisher_name": "http://www.melcher.ca/", "support_website_url": null, "website_url": "http://tourismregina.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPLORATION", "TRAVEL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_CA"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1069157240528894"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "189620864915010"}]}, "baseline_offer": {"id": "189620864915010"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1507741200, "status": "PUBLISHED", "id": "189620864915010"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1441867152517256", "version": "1.0.5"}, "id": "856215457860875", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1432087140161924", "is_concept": false, "late