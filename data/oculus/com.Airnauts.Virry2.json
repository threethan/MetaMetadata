t.oculuscdn.com&_nc_gid=Az532MksS1LL6D57skcfEuj&oh=00_AYCS4-m5UbLpvQpAV6m0bevj4-Y2tqFbtX3Wo-hOj4ZwnA&oe=66E82071"}, {"file_name": "migrated_image.png", "id": "560680867900901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162731_732867726913630_7537884319939821568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0BNnBCGvZgQ7kNvgHKq0cq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az532MksS1LL6D57skcfEuj&oh=00_AYD-DN187zt4FjT2DLQQj1-u4s-Bvs2xwdFo4goimiHisQ&oe=66E807E0"}, {"file_name": "migrated_image.png", "id": "212572443294818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162702_535138243506084_3780100076983025664_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1fK25wnX-0Q7kNvgEtvglN&_nc_ht=scontent.oculuscdn.com&_nc_gid=Az532MksS1LL6D57skcfEuj&oh=00_AYA5NRCIB1y1RXKPfCqNF-aHXhoDljCJUcwFZm-J3i03Lg&oe=66E801F7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Virry Safari 2: Feel the Wild", "keywords": ["animals", "video", "kids", "lion", "best"], "long_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!\n\n\u201cI have seen thousands of spherical videos, and the footage from Virry VR is the most stunning nature scenes I have ever seen in any medium. Seeing a big rhino, in its natural home, from the perspective of a mud puddle inches away, or having a lion literally lick my face to test if I am edible, were among the coolest things I have done in VR to date.\u201d\nJeremy Bailenson, Founding Director of The Virtual Human Interaction Lab, Stanford University.", "short_descri