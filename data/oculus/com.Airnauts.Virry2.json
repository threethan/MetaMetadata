com/v/t64.5771-25/11162716_380404315735500_5291713739500814336_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H1v2_GJi-G0Q7kNvgEf5CcK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBx-DjsWM1eYFLRzjBdWjaUldIlOyiIiOnwbQ5YpJY_7g&oe=67388BF1"}, {"file_name": "migrated_image.png", "id": "231528434908924", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162731_732867726913630_7537884319939821568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxTcHQgdHv4Q7kNvgGjYl89&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDN6m2HeBZ76R_bHVruXonTHqOqND9luGQe1rYV4rhWmw&oe=67387360"}, {"file_name": "migrated_image.png", "id": "212399816653872", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162682_1756596874645581_2822882841732317184_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JkUGGXnrAWIQ7kNvgESU_xD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChJ908pKofe-9hRNrLRFTmbMxWyYUzl7G1TKqcB-nKDw&oe=67389760"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "11162731_874801452683124_8480571075237773312_n.png", "id": "1673110742720080", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162694_1673110746053413_890324910616870912_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SXMpHyx3T40Q7kNvgGYTAxI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBeDFBu3r1tNrJ2ss0a0xHdCpu6KXjNVTet7tHF0nci4w&oe=67389D8D"}, "display_name": "Virry Safari 2: Feel the Wild", "keywords": ["animals", "video", "kids", "lion", "best"], "long_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!\n\n\u201cI have seen thousands of spherical videos, and the footage from Virry VR is the most stunning nature scenes I have ever seen in any medium. Seeing a big rhino, in its natural home, from the perspective of a mud puddle inches away, or having a lion literally lick my face to test if I am edible, were among the coolest things I have done in VR to date.\u201d\nJeremy Bailenson, Founding Director of The Virtual Human Interaction Lab, Stanford University.", "short_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://fnt-resources.s3.amazonaws.com/docs/en/PrivacyPolicy.pdf", "developer_terms_of_service_url": "https://fnt-resources.s3.amazonaws.com/docs/en/ToS.pdf", "publisher_name": "Fountain Digital Labs", "support_website_url": null, "website_url": "http://virryvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "EXPLORATION", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "491757805627330"}}]}, "schedu