270LAcqg&oe=6728B9F1"}, {"file_name": "migrated_image.png", "id": "560680867900901", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/11162731_732867726913630_7537884319939821568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qeV8iEWoaqEQ7kNvgEn2oDY&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAui7YJfyvkrcDvixqhS6g8tIaSmwyjnu2rFVrlfZyX_g&oe=6728A160"}, {"file_name": "migrated_image.png", "id": "212572443294818", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/11162702_535138243506084_3780100076983025664_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_QDQoZr-QJwQ7kNvgG0ygMY&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBYyOvD3qW4HToYjv3UHfGmvQOI42bsL-u-JkhjbJV4Xw&oe=67289B77"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Virry Safari 2: Feel the Wild", "keywords": ["animals", "video", "kids", "lion", "best"], "long_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!\n\n\u201cI have seen thousands of spherical videos, and the footage from Virry VR is the most stunning nature scenes I have ever seen in any medium. Seeing a big rhino, in its natural home, from the perspective of a mud puddle inches away, or having a lion literally lick my face to test if I am edible, were among the coolest things I have done in VR to date.\u201d\nJeremy Bailenson, Founding Director of The Virtual Human Interaction Lab, Stanford University.", "short_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a 