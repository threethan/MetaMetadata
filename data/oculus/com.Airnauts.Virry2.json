LBSQ&oe=67728DF1"}, {"file_name": "migrated_image.png", "id": "560680867900901", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/11162731_732867726913630_7537884319939821568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9iVzUHjcKdsQ7kNvgEojYL-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAeNGar5aECsJNi7Nraf0JX8snYPLg7eQgcmyAepgsaKA&oe=67727560"}, {"file_name": "migrated_image.png", "id": "212572443294818", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/11162702_535138243506084_3780100076983025664_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TxTvm8uAdwkQ7kNvgHNqNaI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAmNPdSkPdfi8n8xHaUF3v7MLKvdhKmcQ_FW0T6XHCRVg&oe=67726F77"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Virry Safari 2: Feel the Wild", "keywords": ["animals", "video", "kids", "lion", "best"], "long_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!\n\n\u201cI have seen thousands of spherical videos, and the footage from Virry VR is the most stunning nature scenes I have ever seen in any medium. Seeing a big rhino, in its natural home, from the perspective of a mud puddle inches away, or having a lion literally lick my face to test if I am edible, were among the coolest things I have done in VR to date.\u201d\nJeremy Bailenson, Founding Director of The Virtual Human Interaction Lab, Stanford University.", "short_description": "Winner of the Webby Award 2017 in \u2018VR: Gaming, Interactive, or Real-time\u2019. Virry VR is a virtual safari filmed in 4K VR at Lewa Wildlife Conservancy, Kenyan home of the most endangered African megafauna: Black and White Rhinos, Lions and African elephants. \n35 min of 8 live-action interactive experiences, where you are really up close while feeding and communicating with wild animals: Zebras, Vervets, Hyena and Leopard, in addition to the ones mentioned above. Also 3 live cameras!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://virryapp.s3.amazonaws.com/docs/en/privacy.pdf", "developer_terms_of_service_url": "https://virryapp.s3.amazonaws.com/docs/en/tos-vr.pdf", "publisher_name": "Fountain Digital Labs", "support_website_url": null, "website_url": "http://virryvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_GB"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "350186850073447"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/11162716_1846498742241744_7495714449832017920_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UFRf2tEYfBsQ7kNvgHDMxOV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAeFkcoH5lbjl0xw_gPxWqM6uQvlXkMk3iyKzEqhvv1tQ&oe=677280CA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Virry Safari 2: Feel the Wild", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1512064800, "lastRevision": {"nodes": [{"id": "1726871