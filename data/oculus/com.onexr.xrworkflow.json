cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4HST_mdFXo0Q7kNvgEMoDcX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBQBY6aPC-aZiP6LdjMRsUQV_IIMSG4ECQmzNi994mm0w&oe=6741D56E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1679571196183084", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982534_1679571199516417_7292601014387023875_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kPWUvbP6w7wQ7kNvgGfgt6p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC26yZCWBq8NOob4yN0Um9o9nWrEPlCmrWoJQfBvYTqXw&oe=6741AA2B"}, "display_name": "XR-Workflow", "keywords": [], "long_description": "Organizations across the world, especially the manufacturing companies, experience difficulty in obtaining expertise for selling & marketing machines digitally, and have to depend on traditional methods of marketing, which result in millions of dollars.\n\nXR-Workflow : VR application enables virtual delivery of contents related to your products for the prospects to help them during the pre-purchase stage, which can work on Meta VR headset devices. It elevates the level of service a user receives without worrying about the impact of geographical boundaries.\n\nXR-Workflow app has various aspects, in several segments of the business such as Remote Auditing, Sales Enablement, Operational Efficacy, Research & Development, On-boarding & Training and  many more.\n\nHighlights of the XR-Workflow App are Product visualization, VR enablement and X-Ray mode simulation.", "short_description": "Redefining immersive product visualization experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://onexr.us/metaapp/privacy-policy/index.html", "developer_terms_of_service_url": null, "publisher_name": "Augray LLC", "support_website_url": null, "website_url": "https://onexr.in/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "