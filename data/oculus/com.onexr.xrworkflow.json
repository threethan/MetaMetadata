aa0Q7kNvgFknEtS&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgI6668fn6CmUcoAAUbBwADlQTmT-FAygNPy4z3o2ZHw&oe=670CFC72"}, {"file_name": "Screenshot4.png", "id": "475352788365462", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974668_475352791698795_6513029807440269328_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pAZAxGCBzdEQ7kNvgHRpogG&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRFtTKwereeNb_1qLd33oUrdgmDtGOUmsi3eP3SMK02A&oe=670D196E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1679571196183084", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982534_1679571199516417_7292601014387023875_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRUjr3w63xYQ7kNvgFXJTZN&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHjmi5Wnpq5B-xqauDrOF_XQK5wWciky9Ie_mgqt4Dzg&oe=670CEE2B"}, "display_name": "XR-Workflow", "keywords": [], "long_description": "Organizations across the world, especially the manufacturing companies, experience difficulty in obtaining expertise for selling & marketing machines digitally, and have to depend on traditional methods of marketing, which result in millions of dollars.\n\nXR-Workflow : VR application enables virtual delivery of contents related to your products for the prospects to help them during the pre-purchase stage, which can work on Meta VR headset devices. It elevates the level of service a user receives without worrying about the impact of geographical boundaries.\n\nXR-Workflow app has various aspects, in several segments of the business such as Remote Auditing, Sales Enablement, Operational Efficacy, Research & Development, On-boarding & Training and  many more.\n\nHighlights of the XR-Workflow App are Product visualization, VR enablement and X-Ray mode simulation.", "short_description": "Redefining immersive product visualization experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/16ckK16yi2MAV_WXHjqlY2TthQ