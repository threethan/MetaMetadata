438299959545_7532312566202638856_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FL4QcazMzL8Q7kNvgEWamqd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBa7UF-6agu0JdWmCzfvDb6-FrpY09IGr5thTwVE4jSyA&oe=673094F2"}, {"file_name": "Screenshot4.png", "id": "475352788365462", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974668_475352791698795_6513029807440269328_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yE_bZND5V5EQ7kNvgFo1zLz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBlxuPVrgfiXI6etBjWZki_aA5NybBAxnBj6r5Kr9eO8w&oe=6730B1EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1679571196183084", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982534_1679571199516417_7292601014387023875_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLCgewCLJbwQ7kNvgHUDF8G&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAcx7XuJxUiPspIc6n-DzckD2yy1NH0bLuzZCj5sNc5yA&oe=673086AB"}, "display_name": "XR-Workflow", "keywords": [], "long_description": "Organizations across the world, especially the manufacturing companies, experience difficulty in obtaining expertise for selling & marketing machines digitally, and have to depend on traditional methods of marketing, which result in millions of dollars.\n\nXR-Workflow : VR application enables virtual delivery of contents related to your products for the prospects to help them during the pre-purchase stage, which can work on Meta VR headset devices. It elevates the level of service a user receives without worrying about the impact of geographical boundaries.\n\nXR-Workflow app has various aspects, in several segments of the business such as Remote Auditing, Sales Enablement, Operational Efficacy, Research & Development, On-boarding & Training and  many more.\n\nHighlights of the XR-Workflow App are Product visualization, VR enablement and X-Ray mode simulation.", "short_description": "Redefining immersive product visualization experience."}]}, "