"file_name": "Screenshot3.png", "id": "1473438296626212", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982651_1473438299959545_7532312566202638856_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XBPWeZy14WYQ7kNvgEv17Se&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYC4Ymbyvol5KnFZgZOgkpIzuvhHmwCcghBHdgWWfK25Eg&oe=671636F2"}, {"file_name": "Screenshot4.png", "id": "475352788365462", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974668_475352791698795_6513029807440269328_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zw0ivzF6FwcQ7kNvgF5uSBB&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBCHYfa-8eVODMbcM_pNW3uU4qEXYZj19nCNED_QTuj2A&oe=671653EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1679571196183084", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982534_1679571199516417_7292601014387023875_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z5E1Nk4niUsQ7kNvgHDZ6ld&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDoynNn25SH1lELPEPERksreNrDjcdewfpsOWoEXktI6Q&oe=671628AB"}, "display_name": "XR-Workflow", "keywords": [], "long_description": "Organizations across the world, especially the manufacturing companies, experience difficulty in obtaining expertise for selling & marketing machines digitally, and have to depend on traditional methods of marketing, which result in millions of dollars.\n\nXR-Workflow : VR application enables virtual delivery of contents related to your products for the prospects to help them during the pre-purchase stage, which can work on Meta VR headset devices. It elevates the level of service a user receives without worrying about the impact of geographical boundaries.\n\nXR-Workflow app has various aspects, in several segments of the business such as Remote Auditing, Sales Enablement, Operational Efficacy, Research & Development, On-boarding & Training and  many more.\n\nHighlights of the XR-Workflow App are Product visualization, VR enablement and X-Ray mode simulation.", "short_description": "Redefining immersive product visualization experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/16ckK16yi2MAV_WXHjqlY2TthQnm9spIUs9UTQdj80zI/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Augray LLC", "support_website_url": null, "website_url": "https://onexr.in/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6876631125761040"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2003496490032735"}]}, "baseline_offer": {"id": "2003496490032735"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727878200, "status": "PUBLISHED", "id": "2003496490032735"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8382214205202717", "version": "1.0.0.15"}, "id": "3659906780890001", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6876631105761042", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8382214205202717"}, "release_status": "RELEASED"