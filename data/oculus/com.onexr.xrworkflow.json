438299959545_7532312566202638856_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kx-lWUL46kgQ7kNvgEst6a6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLqA6WKq7ASvW9sxUsD4zS0kHTQiom7k-VHTRc5-VkqA&oe=671393F2"}, {"file_name": "Screenshot4.png", "id": "475352788365462", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974668_475352791698795_6513029807440269328_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zw0ivzF6FwcQ7kNvgHMRoDW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwU4NVVhMXSSjTCitCUUtd1tN2Xyy32-ucIq3hWtNp9w&oe=6713B0EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1679571196183084", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982534_1679571199516417_7292601014387023875_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z5E1Nk4niUsQ7kNvgHHKFma&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJ2_fX_gJtTTdWcO2dGMlK8xrbHlz9DZDITK4DYTLi0A&oe=671385AB"}, "display_name": "XR-Workflow", "keywords": [], "long_description": "Organizations across the world, especially the manufacturing companies, experience difficulty in obtaining expertise for selling & marketing machines digitally, and have to depend on traditional methods of marketing, which result in millions of dollars.\n\nXR-Workflow : VR application enables virtual delivery of contents related to your products for the prospects to help them during the pre-purchase stage, which can work on Meta VR headset devices. It elevates the level of service a user receives without worrying about the impact of geographical boundaries.\n\nXR-Workflow app has various aspects, in several segments of the business such as Remote Auditing, Sales Enablement, Operational Efficacy, Research & Development, On-boarding & Training and  many more.\n\nHighlights of the XR-Workflow App are Product visualization, VR enablement and X-Ray mode simulation.", "short_description": "Redefining immersive product visualization experience."}]}, "