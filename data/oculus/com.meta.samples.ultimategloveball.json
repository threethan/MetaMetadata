Zpp5-e_heZeYYXpQ53HkJDuVwDiL9a7gPPBNqQ&oe=675837B8"}, {"file_name": "006.png", "id": "2397325750421651", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39001657_2397325753754984_419847898368441538_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jkFMCb0es8AQ7kNvgEwsGH4&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAEvKEJsLzCnDj1N5Nbe7Ju-3d1pAymjBEJdeScEAV1Hw&oe=6758181D"}, {"file_name": "002.png", "id": "804787897483201", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39035448_804787900816534_3876417087229460740_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hyOnr23IbPIQ7kNvgHkUpMB&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAGaq59OJFcmeMcmnbYlYl8BNkC3_BLFacntkAd-udCJQ&oe=67581CE7"}, {"file_name": "005.png", "id": "539452204302194", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75530717_539452207635527_5225632817684849203_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=86pQ5GYnNAIQ7kNvgGt6QsE&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCYJ-PlORoJQHiLlKBkHdCVESJ6IF0y-44b0d7_pujzTQ&oe=6758387E"}, {"file_name": "007.png", "id": "668633428071536", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982547_668633431404869_6728926765491185979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QnDH5d6OppcQ7kNvgHJLm-9&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCs8xX3TrGc-ypSq8vYVoMsx928gl8EeW6kiSuYAh0-5g&oe=67582CFF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultimate Glove Ball", "keywords": [], "long_description": "Charge in and knock 'em out! Party up and hit the court for a three minute match of manic multiplayer dodgeball. You'll be racing to snag ammo, dodge incoming fire, and blast your opponents into the digital afterlife with a well timed orb of electric doom.\n\nEasy to pick up but challenging to master, Ultimate Glove Ball will test your timing, tactics, and tenacity.\n\n- Up to 3v3 Multiplayer\n- Quick 3 minute matches\n- 5 Ball types with unique abilities\n- Furious tactical gameplay\n- Spectator mode\n\nUGB is a showcase project for Meta Quest developers. Source code and assets can be found on GitHub at https://github.com/oculus-samples/Unity-UltimateGloveBall.\n\n- Oculus Social Platform Features (Invites, Group Launch, Group Presence, Blocking flow)\n- Meta Avatar integration\n- Oculus Audio Spatialization\n- Photon VOIP spatialized\n- Multiple Region support\n", "short_description": "Charge in and knock 'em out! Party up and hit the court for a three minute match of manic multiplayer dodgeball. You'll race to snag ammo, dodge incoming fire, and blast your opponents into the digital afterlife with a well timed orb of electric doom.\n\nEasy to pick up but challenging to master, Ultimate Glove Ball will test your timing, tactics, and tenacity.\n\nUGB is a developers showcase project. Source code can be found on GitHub at https://github.com/oculus-samples/Unity-UltimateGloveBall.\n"}]}, "developer_name": "Meta Quest Samples", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Meta Quest", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "882609116087889"}}]}, "scheduled_offers": {"count":