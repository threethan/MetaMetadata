nEbi2qRxCcbjCw&oe=676935DD"}, {"file_name": "migrated_image.png", "id": "831287650717453", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162716_275279759662386_457623242060857344_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=agBKMGSX3wUQ7kNvgE_sKCn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDI-t0iIFBrBRe1QZaV4Nir4P1muvsE-QLv6Kqz7hYlbg&oe=67695F14"}, {"file_name": "migrated_image.png", "id": "1075992626098368", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162754_1926639104018082_5758365492444135424_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UsZ4atFzDP0Q7kNvgFhLyyK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBinsDPJk6asrnPSZ0BqIw7eABSs3SrsBAybKkbnIpYSg&oe=67693402"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "showIt2Me_2.png", "id": "508290726224658", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162717_508290729557991_2462232582461325312_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0A8JZNDNEA8Q7kNvgFfszLb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArAK5DGa4hJ6_wtybbFHeZFXp2452ZB34ON0U9DP1eRw&oe=6769646B"}, "display_name": "Show It 2 Me", "keywords": ["music", "video", "vr", "nightclub", "titmouse"], "long_description": "Show It 2 Me is an interactive VR music video created using Tilt Brush's audio reactive brushes and featuring Night Club's single, \u201cShow It 2 Me.\u201d \n\nShow It 2 Me first debuted at SXSW\u2019s Virtual Cinema 2017. It features art created by Titmouse president and owner Chris Prynoski and Titmouse creative director Antonio Canobbio using the audio reactive brushes in Tilt Brush, Google\u2019s virtual reality app. \n\nWe'll take you on a trippy visual-ride featuring demonic cars, pulsating brains, and disembodied tongue-mouths. Named after the song by Night Club, an electronic music duo from Los Angeles that features Emily Kavanaugh and Mark Brooks, Show it 2 Me is co-directed by Mark Brooks and Dylan Carter. \n\nCheck out Night Club\u2019s music at http://nightclubband.com.", "short_description": "Come take a ride through a retro-futuristic landscape with demons, space cars, crazy head things, and disembodied tongue-mouths. Created in Google\u2019s Tilt Brush with music from Night Club."}]}, "developer_name": "Titmouse Studios", "developer_privacy_policy_url": "http://titmouse.net/", "developer_terms_of_service_url": "http://titmouse.net/", "publisher_name": "Titmouse Studios", "support_website_url": null, "website_url": "http://titmouse.net/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "MUSIC"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4735762176473457"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162763_1922812104651525_6384441543742193664_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f0JsTQ6ItN4Q7kNvgF-UV0x&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZtX-3ezW5nxABx0JhsiEpPyrvTwHrYu39BRkSdDMO9g&oe=67693F9A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Show It 2 Me", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1513274700, "lastRevision": {"nodes": [{"id": "198722737335091", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1416383481777117", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "5