825581358894387635_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HIwWLzTF09oQ7kNvgHqvu9V&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCnnWSmho9stLlLtatZqwz61-dhYIubEmIbTfX6mRnJ0w&oe=675D553B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "850354837072917", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982706_850354840406250_1359752152177583183_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rna1JppUE0kQ7kNvgGVmJZJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCosvMs391BEtGUFP8_0M4v9AtOUGwJBH1i-9T1jhSL1w&oe=675D87A7"}, "display_name": "Modified Bed Bath Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "bath"], "long_description": "The Modified Bed Bath VR Simulator app immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the skills required for providing a proper modified bed bath. This application guides users through each step of the process, including preparing supplies, maintaining patient privacy, and ensuring thorough and gentle cleaning.  \n\n# Learning Objectives:  \n- Remembering the steps and protocols for giving a modified bed bath  \n- Understanding the importance of hygiene and patient comfort \n- Applying the correct techniques for bathing different parts of the body \n- Analyzing the patient's condition to ensure no areas are missed \n- Creating a supportive and respectful environment for patients during the bathing process.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform modified bed baths effectively and compassionately in real-world clinical settings. ", "short_description": "Designed to train CNAs in providing proper modified bath through interactive, hands-on practice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_