120568499714248", "locale": "en_US", "screenshots": [{"file_name": "Bed_Bath_SS_06.png", "id": "1806616533417388", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974895_1806616540084054_8678418741367708207_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1jMah_uATNoQ7kNvgFL32d0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCLSS5ywclEFHPGzDRB3incGRjY2xt5GmxiDEHTpHbVOw&oe=6773E0B7"}, {"file_name": "Bed_Bath_SS_02.png", "id": "873189858299560", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570311_873189861632893_6987843081661096990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pa4exu0rJvsQ7kNvgFk3XZ3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHO9GnCY15IS7R1XHsbrYZHZWxzvJHl70lQJ-p-ePLPw&oe=6773DAEA"}, {"file_name": "Bed_Bath_SS_01.png", "id": "1124362285713318", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031626_1124362289046651_608921263326041405_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O4fhRt38abwQ7kNvgFmnVPe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFQscUqKrCJTt7VFGJphA4BFk32SLstqNjJEV3f_p3Ew&oe=6773C023"}, {"file_name": "Bed_Bath_SS_05.png", "id": "480868555009265", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001701_480868561675931_1317444188374831253_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qbdOumCymuoQ7kNvgGcjA2o&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhH_wLizV9VIPfyg6Zm5mJUkETMbzi-E1IUqgcpPt95A&oe=6773BD3F"}, {"file_name": "Bed_Bath_SS_07.png", "id": "590572690058598", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031417_590572693391931_7662327243515176913_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uqszln28xZsQ7kNvgFoANZi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvfQCqoI-T5dD4q8XE3mnqpLjq9UHqEaPDkFeRO-SYUA&oe=6773E7EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "3756995014550707", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982702_3756995017884040_7148553037508868637_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BxZ6yH1PrDoQ7kNvgG3YKNN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJa3SFrzd8GULwuMqs310rnfRRloUKT2veEtfZjp2xbQ&oe=6773E825"}, "display_name": "Modified Bed Bath Simulator", "keywords": ["CNA", "simulation", "nursing", "Caregiving", "Healthcare"], "long_description": "The Modified Bed Bath VR Simulator app immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the skills required for providing a proper modified bed bath. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n \n# Learning Objectives:  \n- Remembering the steps and protocols for giving a modified bed bath  \n- Understanding the importance of hygiene and patient comfort \n- Applying the correct techniques for bathing different parts of the body \n- Analyzing the patient's condition to ensure no areas are missed \n- Creating a supportive and respectful environment for patients during the bathing process.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform modified bed baths effectively and compassionately in real-world clinical settings.", "short_description": "Master the Modified Bed Bath CNA skill with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publ