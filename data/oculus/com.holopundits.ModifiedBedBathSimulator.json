/scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982440_886823786656816_773730896208641660_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3l-gYJt9SaQQ7kNvgGOziuk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv3u-rAH8a3LGIpF91kQJIu8ZBwm238GdyXjzAH9CWbA&oe=67713DE4"}, {"file_name": "Bed_Bath_SS_04.png", "id": "867045502043952", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974774_867045505377285_2825581358894387635_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QBkITpryIZcQ7kNvgFBdteP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEri2yWVu4RwMAqONXZLGOAhteKq_jpZvPrGHoq0nb2g&oe=67711BBB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "850354837072917", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982706_850354840406250_1359752152177583183_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WCwYVesLwmQQ7kNvgG1xQVJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCrODQl6oRlsE1jRdl1bFR9N1XoMbrMnKGiyGAN8L7duw&oe=67714E27"}, "display_name": "Modified Bed Bath Simulator", "keywords": ["CNA", "nurse", "nursing", "training", "bath"], "long_description": "The Modified Bed Bath VR Simulator app immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the skills required for providing a proper modified bed bath. This application guides users through each step of the process, including preparing supplies, maintaining patient privacy, and ensuring thorough and gentle cleaning.  \n\n# Learning Objectives:  \n- Remembering the steps and protocols for giving a modified bed bath  \n- Understanding the importance of hygiene and patient comfort \n- Applying the correct techniques for bathing different parts of the body \n- Analyzing the patient's condition to ensure no areas are missed \n- Creating a supportive and respectful environment for patients during the bathing process.  \n\nThis comprehensive approach ensures CNAs are well-prepared to perform modified bed baths effectively and compassionately in real-world clinical settings. ", "short_description": "Designed to train CNAs in providing proper modified bath through interactive, hands-on practice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8245859885489530"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1105184447824640"}]}, "baseline_offer": {"id": "1105184447824640"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726243080, "status": "PUBLISHED", "id": "1105184447824640"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8905973886144790", "version": "3.1"}, "id": "1060178635756839", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8245859862156199", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8905973886144790"}, "