2356561510046347202_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XuSKK6VDtM8Q7kNvgFyYZ_q&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_jxQgJMZSaD2GqKMJOAEFm&oh=00_AYAApNJXAU3jIGhfLjEdOoIMHdQZWf56nCABXhTX8HjzNQ&oe=66E6C2F5"}, {"file_name": "Screenshot_5.png", "id": "4425719814182259", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_4425719817515592_6995688504090849862_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tlXtSARZML8Q7kNvgGZNBLU&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_jxQgJMZSaD2GqKMJOAEFm&oh=00_AYCCc_eR-_ol45D8MFiw2sbYXx61uNZqb4QM5WJwbsV6ZQ&oe=66E6D37F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "362364912346462", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_362364922346461_7684992751102397305_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BRgHZoyiVo8Q7kNvgG3pBB2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_jxQgJMZSaD2GqKMJOAEFm&oh=00_AYDk_UA3C90kSfN9zbyE_SeRXs9ziCvqK4ZBU9f74KHvTQ&oe=66E6E0C8"}, "display_name": "XR MANGA  Fist of the North Star", "keywords": [], "long_description": "The immortal masterpiece \"Fist of the North Star\", which has enthusiastic fans all over the world, is now available as the Ultimate Edition (complete set of 18 volumes with color at the beginning of each volume) as XR Manga! Fist of the North Star Ultimate Edition Volume 18 contains all the contents of the standard edition of 27 volumes, plus a large number of additional episodes written by Tetsuo Hara, the creator of the original work.\n\nThis is the first time in the world that the entire story has been released as an e-book in this \"ultimate edition with color pages\". \n\nThere is also a game \"Ore ga Kenshiro\" where you can become Kenshiro, and a \"VR figure\" where you can play with Yuria Kenshiro in any pose you like.\n\nMore features are planned to be added to XR Manga in the future.", "short_description": "The masterpiece \"Fist of the North Star\", which has passionate fans all over the world, is now available in XR manga! The ultimate version (18 volumes in total) is the latest definitive edition, re-edited with additional episodes by the original artist \"Tetsuo Hara\" including full color pages at the beginning of the Manga. This is the first time for this Manga to become an e-book.The space changes according to the story along with the realistic sound of VR.The game \"I am Kenshiro\" and \"VR figure"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xr-manga.com/privacy/", "developer_terms_of_service_url": "https://xr-manga.com/terms/", "publisher_name": "MEDIA DO Co., Ltd.", "support_website_url": null, "website_url": "https://xr-manga.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en_US"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "348435910257016"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569446_578527370136931_6964938043648761768_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=liCloII7pmkQ7kNvgEE-sPF&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_jxQgJMZSaD2GqKMJOAEFm&oh=00_AYAvRuYzpeu7xi_KfBuIbnOnzg-eFKB4lyBFfTIFykDA0A&oe=66E6CF52"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "XR MANGA  Fist of the North Star", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1632442355, "lastRevision": {"nodes": [{"id": "154713070042514", "release_type": "