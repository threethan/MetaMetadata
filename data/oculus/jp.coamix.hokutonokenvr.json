1510046347202_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MW77ev0ipYgQ7kNvgGO3P2g&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARoKKG5aIU_6muH5I3aIkH1&oh=00_AYC8j_rrCilV-5ziivhhnniVdgGC7lY7vkJ0Gqg-YwM2aQ&oe=66EC08F5"}, {"file_name": "Screenshot_5.png", "id": "4425719814182259", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_4425719817515592_6995688504090849862_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bdwI9OfKgYIQ7kNvgH1Tfwp&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARoKKG5aIU_6muH5I3aIkH1&oh=00_AYDvh6aCLKypdNT6_6eSmhOLML0uC1tU7Bm75oPcCGjUaA&oe=66EC197F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "362364912346462", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_362364922346461_7684992751102397305_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ni081JXe97gQ7kNvgF5CO2H&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARoKKG5aIU_6muH5I3aIkH1&oh=00_AYDRNHHE1-gh4WsrWyaLGWKriyPOHeNLSsy7Cm_gOs8keA&oe=66EC26C8"}, "display_name": "XR MANGA  Fist of the North Star", "keywords": [], "long_description": "The immortal masterpiece \"Fist of the North Star\", which has enthusiastic fans all over the world, is now available as the Ultimate Edition (complete set of 18 volumes with color at the beginning of each volume) as XR Manga! Fist of the North Star Ultimate Edition Volume 18 contains all the contents of the standard edition of 27 volumes, plus a large number of additional episodes written by Tetsuo Hara, the creator of the original work.\n\nThis is the first time in the world that the entire story has been released as an e-book in this \"ultimate edition with color pages\". \n\nThere is also a game \"Ore ga Kenshiro\" where you can become Kenshiro, and a \"VR figure\" where you can play with Yuria Kenshiro in any pose you like.\n\nMore features are planned to be added to XR Manga in the future.", "short_description": "The masterpiece \"Fist of the North Star\", which has passionate fans all over the world, is now available in XR manga! The ultimate version (18 volumes in total) is the latest definitive edition, re-edited with additional episodes by the original artist \"Tetsuo Hara\" including full color pages at the beginning of the Manga. This is the first time for this Manga to become an e-book.The space changes according to the story along with the realistic sound of VR.The game \"I am Kenshiro\" and \"VR figure"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xr-manga.com/privacy/", "developer_terms_of_service_url": "https://xr-manga.com/terms/", "publisher_name": "MEDIA DO Co., Ltd.", "support_website_url": null, "website_url": "https://xr-manga.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en_US"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "348435910257016"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569446_578527370136931_6964938043648761768_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pn2kTh-_4GsQ7kNvgFziAzA&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARoKKG5aIU_6muH5I3aIkH1&oh=00_AYAMlsEA5ToxVdk917-eyrLzv1olhmTiGW1qE9W8jWoucQ&oe=66EC1552"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "XR MANGA  Fist of the North Star", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1632442355, "lastRevision": {"nodes": [{"id": "154713070042514", "release_type": "SCHEDU