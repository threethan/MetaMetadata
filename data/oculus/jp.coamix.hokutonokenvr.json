d3-1.oculuscdn.com/v/t64.5771-25/39031375_3819793524912845_4132927554589731675_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QoI-mlTU9UMQ7kNvgGnuAes&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4Ax0QuN9ii5WryEGkohc4QosNWTsK5jhJ3_FdmrDVWA&oe=675598B5"}, {"file_name": "Screenshot_5.png", "id": "4425719814182259", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974672_4425719817515592_6995688504090849862_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfdylFo8f4EQ7kNvgEN-h9d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEorJtsmmS44uwK4mmWqwt9EAyMHivUQKNR2kDLfQbOw&oe=6755917F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1.png", "id": "362364912346462", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974453_362364922346461_7684992751102397305_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YH-5IycdK5sQ7kNvgHxQtp3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwG4eBjVoL4kpfh6vc7h-lzdfLO8Zv2lO4MFWKJMo4pA&oe=67559EC8"}, "display_name": "XR MANGA  Fist of the North Star", "keywords": [], "long_description": "The provision of this app will cease on or around 22 December 2024.\nYou can continue to enjoy the DLed apps as long as the programmes that make up the apps run.\nHowever, re-downloads, version upgrades and support services will cease with the end of the provision of this application.\n--------------------------\n\nThe immortal masterpiece \"Fist of the North Star\", which has enthusiastic fans all over the world, is now available as the Ultimate Edition (complete set of 18 volumes with color at the beginning of each volume) as XR Manga! Fist of the North Star Ultimate Edition Volume 18 contains all the contents of the standard edition of 27 volumes, plus a large number of additional episodes written by Tetsuo Hara, the creator of the original work.\n\nThis is the first time in the world that the entire story has been released as an e-book in this \"ultimate edition with color pages\". \n\nThere is also a game \"Ore ga Kenshiro\" where you can become Kenshiro, and a \"VR figure\" where you can play with Yuria Kenshiro in any pose you like.\n\nMore features are planned to be added to XR Manga in the future.", "short_description": "The provision of this app will cease on or around 22 December 2024.\nYou can continue to enjoy the DLed apps as long as the programmes that make up the apps run.\nHowever, re-downloads, version upgrades and support services will cease with the end of the provision of this application.\n--------------------------\nThe masterpiece \"Fist of the North Star\", "}]}, "developer_name": null, "developer_privacy_policy_url": "https://xr-manga.com/privacy/", "developer_terms_of_service_url": "https://xr-manga.com/terms/", "publisher_name": "MEDIA DO Co., Ltd.", "support_website_url": null, "website_url": "https://xr-manga.com/item/hokuto-no-ken/?utm_source=meta_quest", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en_US"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9268729653249422"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75348039_1241682393612848_1405788366257502503_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YrKbPcjtdRUQ7kNvgFrmgEw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBD_0u3gbCGsOlzaH21vvQXfbiF1xQppJhMBbAI72rU1w&o