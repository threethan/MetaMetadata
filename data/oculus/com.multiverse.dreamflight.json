culuscdn.com/v/t64.5771-25/12448837_1101584653212994_157945009_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KF6Y0gPyLDQQ7kNvgE8zmK_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCrJmk9zIMNgYo53sKAoXdza_iUl1G2XGCx_32o_Gygeg&oe=672B5BAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover2560_updated.png", "id": "463103864080378", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12602128_463103867413711_6033363873220788224_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bezk2tcjW8IQ7kNvgEHB6P2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCooL2fb4m7fn1rWnbC7X7zqUjYnB_FoRgte1WUjlKUVQ&oe=672B65BC"}, "display_name": "Reveries: Dream Flight", "keywords": ["music", "relax", "adventure", "fantasy", "exploration"], "long_description": "\"Beautiful only begins to describe what is easily one of the greatest looking titles out there for the Samsung Gear VR\" - Mobile VR Daily\n\n\"One of the most visually arresting experiences we\u2019ve seen on Gear\" - UploadVR\n\nDream Flight is a beautiful game about exploration and discovery, painstakingly crafted for Gear VR. Learn to guide and collect a variety of magical flight machines, and experience magnificent and ethereal scenery underwritten by a mesmerizing soundtrack.\n\nDream Flight is a hands-free experience. No controller is needed. However, headphones are highly recommended!\n\nThere are many new worlds and soundtracks being crafted at this very moment. Update your Dream Flight version regularly to receive these new updates.", "short_description": "\"Beautiful only begins to describe what is easily one of the greatest looking titles out there for the Samsung Gear VR\" - Mobile VR Daily\n\n\"One of the most visually arresting experiences we\u2019ve seen on Gear\" - UploadVR\n\nDream Flight is a beautiful game about exploration and discovery, painstakingly crafted for Gear VR. Learn to guide and collect a variety of magical flight machines, and experience magnificent and ethereal scenery underwritten by a mesmerizing soundtrack."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.multiverseinc.com/#/dreamflight-privacy-policy", "developer_terms_of_service_url": "https://www.multiverseinc.com/#/term-of-service", "publisher_name": "Multiverse", "support_website_url": null, "website_url": "http://www.multiverseinc.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "MUSIC", "CASUAL", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "609846674298098"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12139263_1709297919337531_532258050_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g7MxvDeT4FIQ7kNvgHuNeVW&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC5VMki1FybBe1AyL_9Ma1HZLPUK5yq0yBLnhYJB2D3-A&oe=672B6FCF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Reveries: Dream Flight", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1465369200, "lastRevision": {"nodes": [{"id": "1168698379815148", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1013248532088752", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "m