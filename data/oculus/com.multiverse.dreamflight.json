}, {"file_name": "migrated_image.png", "id": "2332771570358364", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448837_1101584653212994_157945009_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gk2yI4t_8FMQ7kNvgHL0VS1&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak6ngQfqX4U0wGq2Atv9NOY&oh=00_AYDOp7weamMvTu_Ta8y8Q5sVrlMQ069Cj0g9MfJKNL0RmQ&oe=66EC13AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover2560_updated.png", "id": "463103864080378", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12602128_463103867413711_6033363873220788224_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x5M_qtzagyoQ7kNvgEZeOf4&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak6ngQfqX4U0wGq2Atv9NOY&oh=00_AYBykl8d9--3-Mm_NZpvoYuk4xCsdydsdxciukQxCV5LyA&oe=66EC1DBC"}, "display_name": "Reveries: Dream Flight", "keywords": ["music", "relax", "adventure", "fantasy", "exploration"], "long_description": "\"Beautiful only begins to describe what is easily one of the greatest looking titles out there for the Samsung Gear VR\" - Mobile VR Daily\n\n\"One of the most visually arresting experiences we\u2019ve seen on Gear\" - UploadVR\n\nDream Flight is a beautiful game about exploration and discovery, painstakingly crafted for Gear VR. Learn to guide and collect a variety of magical flight machines, and experience magnificent and ethereal scenery underwritten by a mesmerizing soundtrack.\n\nDream Flight is a hands-free experience. No controller is needed. However, headphones are highly recommended!\n\nThere are many new worlds and soundtracks being crafted at this very moment. Update your Dream Flight version regularly to receive these new updates.", "short_description": "\"Beautiful only begins to describe what is easily one of the greatest looking titles out there for the Samsung Gear VR\" - Mobile VR Daily\n\n\"One of the most visually arresting experiences we\u2019ve seen on Gear\" - UploadVR\n\nDream Flight is a beautiful game about exploration and discovery, painstakingly crafted for Gear VR. Learn to guide and collect a variety of magical flight machines, and experience magnificent and ethereal scenery underwritten by a mesmerizing soundtrack."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.multiverseinc.com/#/dreamflight-privacy-policy", "developer_terms_of_service_url": "https://www.multiverseinc.com/#/term-of-service", "publisher_name": "Multiverse", "support_website_url": null, "website_url": "http://www.multiverseinc.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "MUSIC", "CASUAL", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "609846674298098"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139263_1709297919337531_532258050_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fjKlUWlu8K0Q7kNvgHYRS0U&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak6ngQfqX4U0wGq2Atv9NOY&oh=00_AYANIzyIrxnhBtKEDS200d7vk-qFKLrRYdrfsaYcHWP3SQ&oe=66EC27CF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Reveries: Dream Flight", "platform": "ANDROID", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Flying", "id": "388572