fted for Gear VR. Learn to guide and collect a variety of magical flight machines, and experience magnificent and ethereal scenery underwritten by a mesmerizing soundtrack."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.multiverseinc.com/#/dreamflight-privacy-policy", "developer_terms_of_service_url": "https://www.multiverseinc.com/#/term-of-service", "publisher_name": "Multiverse", "support_website_url": null, "website_url": "http://www.multiverseinc.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "MUSIC", "CASUAL", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "609846674298098"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139263_1709297919337531_532258050_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fjKlUWlu8K0Q7kNvgEwyK9I&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJrFDzpkrcNRFTap9EAO7V&oh=00_AYB12YMLTGcHeFYgBkkwF1nrL56fNDSwEO2DAlW5v_K_VA&oe=66EA9E0F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Reveries: Dream Flight", "platform": "ANDROID", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Flying", "id": "388572