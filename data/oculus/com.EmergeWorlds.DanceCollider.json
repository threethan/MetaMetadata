com&oh=00_AYBnZacAPmpb-1mwJ42NweEuqSJnZzy26hwK5j0yCJu4lQ&oe=67011D26"}, {"file_name": "DCQuest_05.png", "id": "356050808992825", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75295892_356050812326158_6185993198349557241_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H1ANNIZmoHUQ7kNvgHEz019&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBKvZGugARBtprSYlNfY7lUzZsgyYRWp7sSUtGozrApOQ&oe=67013AC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DanceCollider_TrailerCover_Quest.png", "id": "1422429241440537", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75236138_1422429244773870_4796738977918569534_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GX241FoiSdcQ7kNvgHAp8hq&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCmSbN-yPDYNdpwFik-CJiChH4ktb4kAgzvulRKtiYcXA&oe=67013B62"}, "display_name": "Dance Collider", "keywords": [], "long_description": "Experience the ultimate dance workout on Oculus Quest.\n\nEnter a futuristic world where dancers battle in secret underground competitions. Take on 9 characters from around the globe. They\u2019re going to throw down some crazy dance moves so be ready! Harness all your power to rise to the top of the leaderboards. With 45 songs by f-777 and our VR dance editor to master, it\u2019s now time to level up. \n\nFEATURES\n- 45 original songs by f-777\n- 9 Characters from around the world including a new boss character\n- VR Dance Editor\n- Local and global leaderboards so you can compete with friends at home and worldwide\n- New futuristic arenas\n- Easy, Normal, Pro and Extreme difficulties to challenge even the most hardcore players", "short_description": "Experience the ultimate dance workout on Oculus Quest.\n\nIt's your time to become a dance master and take down Uriel! Battle 9 of the best dancers from around the world and compete on global leaderboards. \n\nFeaturing 45 songs by legendary electronic artist f-777 that cross all EDM genres, a VR dance editor to create your own moves and our hardcore mode to challenge the very best players. Dance Collider is the ultimate rhythm game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.dancecollider.com/terms", "developer_terms_of_service_url": null, "publisher_name": "emergeWorlds", "support_website_url": null, "website_url": "https://www.dancecollider.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "345962100711073"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "195519095846094"}, {"status": "PUBLISHED", "id": "698173922222600"}, {"status": "PUBLISHED", "id": "362827498974550"}]}, "baseline_offer": {"id": "698173922222600"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1626077280, "status": "PUBLISHED", "id": "195519095846094"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4371957666229764", "version": "1.0"}, "id": "880288676140923", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3848483328577203", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4371957666229764"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [