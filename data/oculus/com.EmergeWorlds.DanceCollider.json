ardcore mode to challenge the very best players. Dance Collider is the ultimate rhythm game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.dancecollider.com/terms", "developer_terms_of_service_url": null, "publisher_name": "emergeWorlds", "support_website_url": null, "website_url": "https://www.dancecollider.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "345962100711073"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1188798202202399"}, {"status": "PUBLISHED", "id": "195519095846094"}, {"status": "PUBLISHED", "id": "698173922222600"}, {"status": "PUBLISHED", "id": "362827498974550"}]}, "baseline_offer": {"id": "698173922222600"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730314800, "status": "PUBLISHED", "id": "1188798202202399"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4371957666229764", "version": "1.0"}, "id": "880288676140923", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3848483328577203", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4371957666229764"