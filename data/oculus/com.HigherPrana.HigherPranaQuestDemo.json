actice. The music is carefully crafted to help guide you into a deeper state of relaxation and mindfulness, while also stimulating your senses and creating a calming atmosphere. With Higher Prana, you can immerse yourself in a world of sound and sensation that will elevate your meditation and yoga practice to a whole new level.", "short_description": "Higher Prana is a VR meditation app with unique soundscapes that guide you into meditation or yoga practice for mental wellbeing. Experience immersive VR guided meditations and yoga with Higher Prana. Our app offers unique soundscapes that help guide you towards a deeper sense of relaxation and mental wellbeing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://higherprana.com/elementor-22451/", "developer_terms_of_service_url": null, "publisher_name": "Higher Prana LLC", "support_website_url": null, "website_url": "http://www.higherprana.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25592707500345231"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "521240967320007"}, {"status": "PUBLISHED", "id": "457803020045022"}]}, "baseline_offer": {"id": "521240967320007"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727935200, "status": "PUBLISHED", "id": "521240967320007"}]}, "liveChannel": {"nodes": [{"latest_s