e_name": "3dRudder Compo 1008x1440.png", "id": "427914898315370", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982701_427914901648703_7877746939573338125_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4EXFeisIJxwQ7kNvgEJSS6W&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6ZdiS15KH7RuH0yx7o22Fo46FDdxwMfk8GCpy_KB5NA&oe=670A7DA6"}, {"file_name": "3dR_Logo_2019 vh1140.png", "id": "2860356614281644", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031653_2860356617614977_4783248370923982265_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Vmy3mE_auMQ7kNvgEyPYja&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB42-6PJBdnZlM0zfoskbwUtgvZBDePlFfqXeNfocEtNA&oe=670A5119"}]}, "id": "249787713316799", "locale": "en_US", "screenshots": [{"file_name": "3dRudder - Leg position.png", "id": "448970339859704", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75630189_448970343193037_1923969005294620731_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c_0CtxD-MRgQ7kNvgGTD8lg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHwF2S56IEfMi6xv952148R4T7XWodvSYFC8bJ0qt86w&oe=670A6B15"}, {"file_name": "3dRudder - Strafing.png", "id": "5034124696658622", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_5034124713325287_3346940202929580509_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3JXpwJZxVF8Q7kNvgHn_63J&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5FKWpomZQViNb6rnJwqPA3tedkrx0EsSnbpHTsnZTTA&oe=670A7268"}, {"file_name": "3dRudder - Turn movement.png", "id": "451601409421792", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210896_451601412755125_7653260949154147132_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DiPG-jePYNYQ7kNvgHqZBaM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkC5uvw07j-nDpVJrnHl2a2buPB3hlaYfxdW0UC1FM-w&oe=670A6003"}, {"file_name": "3dRudder - Mini experience.png", "id": "1415471922149561", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75488379_1415471932149560_6748285516086168429_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ihI4fkl41gsQ7kNvgHJcNaI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCn7HIszt5f95ZimtBcugcFj1M9x7jQ9ZdXXMR1f2jSgw&oe=670A677C"}, {"file_name": "3dRudder - Exploding a balloon.png", "id": "463002951560087", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297584_463002954893420_510912844357616824_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9JwAHQo5bB8Q7kNvgFP-_VE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJMcptk5iz5iKoaJA4284B_P2yfgNux-NEYDhepzMhSQ&oe=670A7415"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "3dRudder Setup & Tutorial", "keywords": [], "long_description": "The 3dRudder Wireless is a foot motion controller, a new kind of peripheral designed for handling motion at the feet while seated:\n- It offers 4 axes, all progressive and combinable: forward/backward, left/right strafe, left/right turn, up/down,\n- It enables 3 types of locomotion: flat, 3D (ex. Helicopter), and Steering (ex. Airplane piloting),\n- Super intuitive, it lets you achieve in seconds impossible movements like orbiting around a target while shooting at it,\n- It is used seated, providing a relaxing, effortless and secure experience to the user,\n- Anyone can use it, even non gamers, in a matter of seconds,\n- Finally, combined with the hand-tracking features of the Quest, it\u2019s a game changer as the combination provides the users with an experience incredibly close to reality.\n\nThis setup and tutorial app will let you:\n- Pair your 3dRudder with your Quest / Quest 2,\n- Discover each of the 4 individual axis,\n- Use those axes together in 2 experiences.", "short_description": "The 3dRudder Setup & Tutorial app lets you pair your 3dRudder Wireless foot motion controller with your Oculus Quest / Quest 2. It also provides a tutorial to learn how to use your 3dRudder, as well as 2 small experiences where you'll explode balloons with your hands, first on a flat surface, then in a 3D space. Please note, this app may be used entirely in hand tracking mode: only the 2 small experiences require hand tracking as you'll be moving with the feet while acting with your bare hands."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3drudder.com/privacy-statement/", "developer_terms_of_service_url": null, "publisher_name": "3dRudder", "support_website_url": "https://support.3drudder.com/portal/en/kb/english", "website_url": "https://3dRudder.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "331106725680903"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569478_734632903903681_2508055417099375265_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FRBH4GzHvUUQ7kNvgEyb49y&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAh42HVATfjcFcq4fV6Fy380SqlcdozL_9qHYFnd5Z6yA&oe=670A482B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "3dRudder Setup & Tutorial", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1640804504, "lastRevision": {"nodes": [{"id": "437070244203747", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "30863224