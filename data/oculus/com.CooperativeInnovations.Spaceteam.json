_ZQ&oe=66FA7957"}, {"file_name": "migrated_image.png", "id": "261223688218685", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974896_716253932240271_2651300904006844416_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qq36ITtzHNoQ7kNvgHN04Mi&_nc_ht=scontent.oculuscdn.com&oh=00_AYCaUy0w6sXHW0DvAkF5oMpnjQ1j7BcMDKj7qDeJu6SQZg&oe=66FA9E5D"}, {"file_name": "migrated_image.png", "id": "241726573640274", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974727_2534458900206832_2115708367547662336_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FtyZLklgMPIQ7kNvgG0ZCfJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAp4Bedu_fW7JfmHDEXGMp8heN6VgsVwW0m2F3YdDfErg&oe=66FAA399"}]}, "id": "2768548239930303", "locale": "en_US", "screenshots": [{"file_name": "EkIK1G.png", "id": "685478355577728", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974650_685478358911061_6987638261304786944_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gdrvldiGVLsQ7kNvgF9jkuQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfhvURmqialpln6E0eXjhIeiIaknj3VsOwlCOq04XQEg&oe=66FA8B87"}, {"file_name": "ySbXEH.png", "id": "266094234543326", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974900_266094237876659_1687494914046164992_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sGEigsT2FQ8Q7kNvgGDrHxs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeO4rEyBOzJ8lf02qAJnDbpPozp09rlLquxFkcE__qOg&oe=66FA9AA1"}, {"file_name": "VV067w.png", "id": "243763273566981", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_243763276900314_1006843181469270016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=66phr2tBCOcQ7kNvgG4uklz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSzUZgOG2P2QHzhrcl89Q_GdVO8HXAO77Ld1FeW4bzsw&oe=66FA8660"}, {"file_name": "RdYPzg.png", "id": "595364544415883", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001725_595364547749216_2745485697107361792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yn9pkqMBcNsQ7kNvgE7gZCW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUDfYIhVjjbTBM_69DUEfSuixKMaMrQUA6WBTnTJ6J-Q&oe=66FA92BC"}, {"file_name": "y6ePOF.png", "id": "557844284929377", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974647_557844291596043_6844295750730383360_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TBSYEtwSx-YQ7kNvgEqT_9M&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIWhZTGl3pPSzQahaDa1DAhFSadfpidvpsL6yf7hNi-A&oe=66FAA016"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/4Rry3o", "id": "562980484651468", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615890_562980487984801_1590634747162263552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jjyRu-QFHYgQ7kNvgHrd_Cl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrXBGv64ecQqxQSYG8jbO3D5BwTT2ayqhMA0n1EGzqNw&oe=66FA9E7E"}, "display_name": "Spaceteam VR", "keywords": ["cooperative", "party", "multiplayer", "team", "space"], "long_description": "DON'T PANIC!\nEven if this is your first space flight, it's ok, the ship will give you instructions, it's just that they might not apply to a control on the console in front of you. They might be for a control on a teammate's console so you will need to tell them, quickly, and probably loudly.\n \nIf your Spaceteam can complete enough instructions successfully in a sector you will progress to the next, each sector becomes increasingly difficult and as the ship becomes harder to control and eventually, inevitably, you will explode. \n\nThere are 3 ways to play Spaceteam VR:\n\nFULL VR MULTIPLAYER\nUp to 6 players, connected to the internet, in any popular VR headset join in a cooperative game of trying to avoid their binding doom.\n\nFACE TO FACE\nUp to 6 players play locally with at least one VR headset and connected smart devices, this offers an experience much like the original Spaceteam game. \n\nSINGLE PLAYER \nIn Practice Mode you will join 2 of our trusty robots to form a Spaceteam.", "short_description": "A chaotic, cooperative party game on a spaceship! Shout technobabble at your friends. Attempt to follow randomly generated, incorrectly assigned instructions. \nWork together\u2026 as a Spaceteam!"}]}, "developer_name": "Cooperative Innovations", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": "http://spaceteamvr.com/", "website_url": "http://spaceteamvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "SOCIAL", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "3063996147188184"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2696756707101461"}, {"status": "PUBLISHED", "id": "252485870305590"}]}, "baseline_offer": {"id": "252485870305590"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1590080460, "status": "PUBLISHED", "id": "2696756707101461"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5056520151105385", "version": "1.1.5005"}, "id": "717286638737396", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2531338473623578", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5056520151105385"}, "releas