ame": "VV067w.png", "id": "243763273566981", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974548_243763276900314_1006843181469270016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jqCS_IzLJ7sQ7kNvgHJnnwK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIbhE95HSGxiZfidvl4iVSURFhp9jZIfmlME23gdkC1A&oe=67275960"}, {"file_name": "RdYPzg.png", "id": "595364544415883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_595364547749216_2745485697107361792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJYbznQXwpMQ7kNvgE6jAgh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBFYnWuuVIdkSflnm2qosuDmVWeGjErcgLr0OxNJFVq3w&oe=672765BC"}, {"file_name": "y6ePOF.png", "id": "557844284929377", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974647_557844291596043_6844295750730383360_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TZ7AaSRXYdkQ7kNvgGYlrS9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqvrCzJUGgfzDNFaj117Y37xKpSRPnyPwShNyswiemQg&oe=67277316"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/4Rry3o", "id": "562980484651468", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615890_562980487984801_1590634747162263552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DNY_Hrj4iiMQ7kNvgHUl6rD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpnQoVm5RyXH8cauJP-PuM62FpmsUU3p3gt-gIpnbZ5A&oe=6727717E"}, "display_name": "Spaceteam VR", "keywords": ["cooperative", "party", "multiplayer", "team", "space"], "long_description": "DON'T PANIC!\nEven if this is your first space flight, it's ok, the ship will give you instructions, it's just that they might not apply to a control on the console in front of you. They might be for a control on a teammate's console so you will need to tell them, quickly, and probably loudly.\n \nIf your Spaceteam can complete enough instructions successfully in a sector you will progress to the next, each sector becomes increasingly difficult and as the ship becomes harder to control and eventually, inevitably, you will explode. \n\nThere are 3 ways to play Spaceteam VR:\n\nFULL VR MULTIPLAYER\nUp to 6 players, connected to the internet, in any popular VR headset join in a cooperative game of trying to avoid their binding doom.\n\nFACE TO FACE\nUp to 6 players play locally with at least one VR headset and connected smart devices, this offers an experience much like the original Spaceteam game. \n\nSINGLE PLAYER \nIn Practice Mode you will join 2 of our trusty robots to form a Spaceteam.", "short_description": "A chaotic, cooperative party game on a spaceship! Shout technobabble at your friends. Attempt to follow randomly generated, incorrectly assigned instructions. \nWork together\u2026 as a Spaceteam!"}]}, "developer_name": "Cooperative Innovations", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": "http://spaceteamvr.com/", "website_url": "http://spaceteamvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "SOCIAL", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "3063996147188184"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2696756707101461"}, {"status": "PUBLISHED", "id": "252485870305590"}]}, "baseline_offer": {"id": "25248587030559