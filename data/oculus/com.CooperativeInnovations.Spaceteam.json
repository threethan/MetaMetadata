.com&oh=00_AYDztWLL_kJM8WXZXXulDtxiUtWYKqYBO_b02SwCSo4LhA&oe=67728A4B"}, {"file_name": "YKrOu9.png", "id": "238559807374986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974571_238559810708319_5107700925175169024_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_Aul8qWbIoQ7kNvgGwnfgt&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC69KsR5d8p6xJov1uvXV7eNSUp97xhjxTu-b15FRiD3A&oe=677271D7"}, {"file_name": "migrated_image.png", "id": "261223688218685", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974896_716253932240271_2651300904006844416_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wAWxqzwjM5wQ7kNvgFoqy1-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCasjI3jWBLL-TGRC-Ao0hOGITi6JxLwAs61Hnb911_0w&oe=677296DD"}, {"file_name": "migrated_image.png", "id": "241726573640274", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974727_2534458900206832_2115708367547662336_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f8HvKQKJe74Q7kNvgFB3zdO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDYPcvTd3xKDP6riGCsmDow8zPX0PR09mwVPshfb0s6Kw&oe=67729C19"}]}, "id": "2768548239930303", "locale": "en_US", "screenshots": [{"file_name": "EkIK1G.png", "id": "685478355577728", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974650_685478358911061_6987638261304786944_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a26vGHgWkxIQ7kNvgGgSG5f&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCu5QKGIXWLGy6S8nrAeHeFd3aJakLAvms_j18nvOTAAw&oe=67728407"}, {"file_name": "ySbXEH.png", "id": "266094234543326", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974900_266094237876659_1687494914046164992_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gtmvI2IBekQQ7kNvgG5f17X&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCZJzKGSWbej8wo0bXsuQ5slZJdeCdPlfALyFVVFIVLbg&oe=67729321"}, {"file_name": "VV067w.png", "id": "243763273566981", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974548_243763276900314_1006843181469270016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3PhAMm5DEkQ7kNvgGhjojy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCXrZlZYBEgh1V8QMgdCBeaU38k34uaMvm9QOYTDF9aQQ&oe=67727EE0"}, {"file_name": "RdYPzg.png", "id": "595364544415883", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001725_595364547749216_2745485697107361792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uc0KbC00zLsQ7kNvgET74P_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYClPWbYuXzkg0pSDWmtrj6YqXTwiqZjGBlf2OF760x3vw&oe=67728B3C"}, {"file_name": "y6ePOF.png", "id": "557844284929377", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974647_557844291596043_6844295750730383360_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mVEj8LYB2u8Q7kNvgH61ZJg&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCLRxKBtjDBzQix7cD6HgD_rTFkkmrnPegTMLzIMmwKgw&oe=67729896"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/4Rry3o", "id": "562980484651468", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86615890_562980487984801_1590634747162263552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0CisYaNG5ZoQ7kNvgEjuKkO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDq0hhCDe21eH_OWbyl6fEPaMwT-EliW4sCcvyf2Z31zg&oe=677296FE"}, "display_name": "Spaceteam VR", "keywords": ["cooperative", "party", "multiplayer", "team", "space"], "long_description": "DON'T PANIC!\nEven if this is your first space flight, it's ok, the ship will give you instructions, it's just that they might not apply to a control on the console in front of you. They might be for a control on a teammate's console so you will need to tell them, quickly, and probably loudly.\n \nIf your Spaceteam can complete enough instructions successfully in a sector you will progress to the next, each sector becomes increasingly difficult and as the ship becomes harder to control and eventually, inevitably, you will explode. \n\nThere are 3 ways to play Spaceteam VR:\n\nFULL VR MULTIPLAYER\nUp to 6 players, connected to the internet, in any popular VR headset join in a cooperative game of trying to avoid their binding doom.\n\nFACE TO FACE\nUp to 6 players play locally with at least one VR headset and connected smart devices, this offers an experience much like the original Spaceteam game. \n\nSINGLE PLAYER \nIn Practice Mode you will join 2 of our trusty robots to form a Spaceteam.", "short_description": "A chaotic, cooperative party game on a spaceship! Shout technobabble at your friends. Attempt to follow randomly generated, incorrectly assigned instructions. \nWork together\u2026 as a Spaceteam!"}]}, "developer_name": "Cooperative Innovations", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": "http://spaceteamvr.com/", "website_url": "http://spaceteamvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "SOCIAL", "ARCADE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "3063996147188184"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2696756707101461"}, {"status": "PUBLISHED", "id": "252485870305590"}]}, "baseline_offer": {"id": "252485870305590"