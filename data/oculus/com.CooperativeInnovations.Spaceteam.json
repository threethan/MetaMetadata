.com&oh=00_AYBPP9gGzvytLeUOn8XYgaVtlGu81nB2ev5V0ocl3G6-dw&oe=67694FCB"}, {"file_name": "YKrOu9.png", "id": "238559807374986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974571_238559810708319_5107700925175169024_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XjwBA-6nxcMQ7kNvgGjp9-V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDV3WHrDqMT2tWg0-uBlob9tUIzF0D4Dwm8MDcISowQEQ&oe=67693757"}, {"file_name": "migrated_image.png", "id": "261223688218685", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974896_716253932240271_2651300904006844416_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tc45GiJNlHEQ7kNvgEiT0gW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlh27W9r-d0RhKLrxe_WZd5qlwueXYVsNft6_J6uylwA&oe=67695C5D"}, {"file_name": "migrated_image.png", "id": "241726573640274", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974727_2534458900206832_2115708367547662336_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nyw2YCIts2UQ7kNvgFyYSci&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDESxXKLRfM_tPiHnytkb--wqG22wTRjI6aeQg2fEWjHA&oe=67696199"}]}, "id": "2768548239930303", "locale": "en_US", "screenshots": [{"file_name": "EkIK1G.png", "id": "685478355577728", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_685478358911061_6987638261304786944_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xFZ1RKqHkGQQ7kNvgHtybbq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVa11JH8HMuoek9MFfN5l-acwBHof-J7vbcKky24dLaA&oe=67694987"}, {"file_name": "ySbXEH.png", "id": "266094234543326", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974900_266094237876659_1687494914046164992_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L-W1uGAoMAYQ7kNvgEsBKBp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjAHUsYDou8kKbPJbRHso-vO6WtOuXbLCv5U9SPJGs4A&oe=676958A1"}, {"file_name": "VV067w.png", "id": "243763273566981", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974548_243763276900314_1006843181469270016_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yt1JfTLLzLwQ7kNvgG0-Sc9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9RUear8gWvL_PSU4je2ALCmbtBT25lZfw4tQmj7R5JA&oe=67694460"}, {"file_name": "RdYPzg.png", "id": "595364544415883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_595364547749216_2745485697107361792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E0huAJvcL8oQ7kNvgFc7bAg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGfjNHYRkwYcPPnWWlxFzLCkjroRvoVumfloFUfU0YyQ&oe=676950BC"}, {"file_name": "y6ePOF.png", "id": "557844284929377", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974647_557844291596043_6844295750730383360_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pYKSAEyi_BIQ7kNvgFgjIHU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLbA4K6xyQAcpLjSXyjPUyyuHbx3j4yhIjqQI2H9hd6g&oe=67695E16"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/4Rry3o", "id": "562980484651468", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615890_562980487984801_1590634747162263552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9cXxYotHuxUQ7kNvgGNlFyg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtP7ckBZjbA-7QL3h7ca0Bb_GIcjTqXQGw-xle5-Syyg&oe=67695C7E"}, "display_name": "Spaceteam VR", "keywords": ["cooperative", "party", "multiplayer", "team", "space"], "long_description": "DON'T PANIC!\nEven if this is your first space flight, it's ok, the ship will give you instructions, it's just that they might not apply to a control on the console in front of you. They might be for a control on a teammate's console so you will need to tell them, quickly, and probably loudly.\n \nIf your Spaceteam can complete enough instructions successfully in a sector you will progress to the next, each sector becomes increasingly difficult and as the ship becomes harder to control and eventually, inevitably, you will explode. \n\nThere are 3 ways to play Spaceteam VR:\n\nFULL VR MULTIPLAYER\nUp to 6 players, connected to the internet, in any popular VR headset join in a cooperative game of trying to avoid their binding doom.\n\nFACE TO FACE\nUp to 6 players play locally with at least one VR headset and connected smart devices, this offers an experience much like the original Spaceteam game. \n\nSINGLE PLAYER \nIn Practice Mode you will join 2 of our trusty robots to form a Spaceteam.", "short_description": "A chaotic, cooperative party game on a spaceship! Shout technobabble at your friends. Attempt to follow randomly generated, incorrectly assigned instructions. \nWork together\u2026 as a Spaceteam!"}]}, "developer_name": "Cooperative Innovations", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": "http://spaceteamvr.com/", "website_url": "http://spaceteamvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "SOCIAL", "ARCADE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "3063996147188184"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2696756707101461"}, {"status": "PUBLISHED", "id": "252485870305590"}]}, "baseline_offer": {"id": "252485870305590"