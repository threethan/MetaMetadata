culuscdn.com/v/t64.5771-25/39001725_595364547749216_2745485697107361792_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FPCdZn5y7HcQ7kNvgFKr4Vf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOE7Pn9K9eApJ6l9Jxakg8Xo27LDKL0lly7aXVHyX7dA&oe=6741C3BC"}, {"file_name": "y6ePOF.png", "id": "557844284929377", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974647_557844291596043_6844295750730383360_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ivBeqVUi6s0Q7kNvgHJbAcp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJGAdh-RKB9jYK4ffv0iptbVdyZpbaf9rF2xMRRT2FiA&oe=6741D116"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/4Rry3o", "id": "562980484651468", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615890_562980487984801_1590634747162263552_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bN0yjM-SWYQQ7kNvgH6g2Jh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcOmL_9j9FFgfLljutd4nTjyAGwUAHXr6GoSRlAfJBSA&oe=6741CF7E"}, "display_name": "Spaceteam VR", "keywords": ["cooperative", "party", "multiplayer", "team", "space"], "long_description": "A chaotic co-op party shouting game. Things might get heated but always work together as a Spaceteam!\n\nThe ship's computer is out of control, your only chance of surviving longer than one sector is to shout technobabble at your friends!\n\nTry to follow the randomly generated, incorrectly assigned, sometimes impossible to pronounce instructions and steer your ship out of the path of a supernova.\n\nComplete enough instructions successfully and you will progress to the next sector, each more difficult and so the ship becomes harder to control. Dodge asteroids by shaking your maracas, clean up alien goop and disco dance like your life depends on it!\n\nWays to play:\n\nVR MULTIPLAYER\n\nUp to 6 players, in any popular VR headset join in a co-op game trying to avoid their inevitable doom.\n\nFACE TO FACE\n\nUp to 6 players with at least 1 headset and connected smart devices, this feels much like the original Spaceteam game.\n\nSINGLE PLAYER\n\nIn Practice Mode your Spaceteam will be 2 of our trusty robots!", "short_description": "A co-op party game. Work together as a Spaceteam and figure out who should do with that flange!?"}]}, "developer_name": "Cooperative Innovations", "developer_privacy_policy_url": "https://www.coopinnovations.co.uk/privacy/", "developer_terms_of_service_url": "https://www.coopinnovations.co.uk/privacy/", "publisher_name": "Cooperative Innovations", "support_website_url": "http://spaceteamvr.com/", "website_url": "http://spaceteamvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SOCIAL", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "1484662198596046"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974885_144883574226449_5082446249971332393_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2GxewYf_M60Q7kNvgFJDXTz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCtH0leC4jTopbYqfma0cCesCfNQivv00Uz6EnIVgPnyA&oe=6741D114"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spaceteam VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Survival"