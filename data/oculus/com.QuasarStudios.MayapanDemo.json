.com&oh=00_AYBNvag2d7Sjw_egU1sqHuSM1StO-9VPfyroQXH4f75nJA&oe=67349C0D"}, {"file_name": "2021-11-01-23-24-02b.png", "id": "630430719008840", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982528_630430722342173_4759937995037333809_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ASK8Yne9MzcQ7kNvgEUGup_&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBZ2LTGbyL3bQT_zYbX6cD0_Q3YIRb237Sy7hs0RN1s_A&oe=673474FC"}, {"file_name": "2021-11-01-22-55-52.png", "id": "235890266148896", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003251_235890276148895_1273546853283943322_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JaH50IH7L6IQ7kNvgGxeYy6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDpleHsBc9pyrzxFb9lSYjbuOiD66ATX2e534mPlJeIDg&oe=6734799E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_demo.png", "id": "1481300932666968", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86615256_1481300939333634_3221219124994484117_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DqJmERsqJ8MQ7kNvgG70Ffk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDS5UlskBDWcFrAq2C-GpB5K6jn78tAllkXhzmNu3uTjQ&oe=67348D02"}, "display_name": "Mayapan Demo", "keywords": [], "long_description": "Conquer the great pyramid of Mayapan by showing your point and shoot skills. Use two crossbows and clear your way all over to the top. Match colors and make use of special bonuses. Beware, some bonuses are good, others are not! Also, keep track of flying bonuses, those are the special ones.\n\nFeeling good? Try the Survival chamber, at the pyramid's lower level. Resist as long as you can.. or taste the heated lava! \n\nHave local scores for you and your family. Also compete with other Oculus players in the general leaderboard! Be the best!\n\nThis is a Demo version with 3 Campaign levels and unlimited Survival play!\n\nMayapan awaits you!", "short_description": "Conquer the great pyramid of Mayapan by showing your point and shoot skills. Match colors and make use of special bonuses. Feeling good? Try the Survival chamber, at the pyramid's lower level. Resist as long as you can.. or taste the heated lava! Compete with other Oculus players in the general leaderboard! Be the best! This is a Demo version."}]}, "developer_name": null, "developer_privacy_policy_url": "https://quasarstudios.net/privacypolicy/vr-privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Quasar", "support_website_url": null, "website_url": "http://www.quasarstudios.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "377978390272490"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6558395304209692"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982478_675111604685019_4725851832908638153_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cma8SnXT-xQQ7kNvgEA_G5i&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAq9vnHdvV0C-Ekij_znTldyFVCYVJ9eqcnuXuVu-LhYQ&oe=6734967A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mayapan Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Sur