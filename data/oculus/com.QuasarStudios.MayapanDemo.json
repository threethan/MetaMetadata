.com&oh=00_AYAEP4Ssd7dH2eEYzpLHng-GWDlyErPSdZHDFCibGJ_rxQ&oe=6714F80D"}, {"file_name": "2021-11-01-23-24-02b.png", "id": "630430719008840", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982528_630430722342173_4759937995037333809_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EXFlFQLDA7IQ7kNvgEC5vkw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASMt9CakwmRG5azj-YnSSeX5IkEs1Fcv0zWjfKoYUlsw&oe=6715093C"}, {"file_name": "2021-11-01-22-55-52.png", "id": "235890266148896", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003251_235890276148895_1273546853283943322_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sB3TiImu5Z0Q7kNvgFw0ykb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyl1xEB58akHVYAh85Gc_E26OzKGlDbcXmdJ7go-veCw&oe=6714D59E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape_demo.png", "id": "1481300932666968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615256_1481300939333634_3221219124994484117_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G1_BCD8_hTMQ7kNvgHyV33F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBt7C4kmA10nph7up0BEbTvCY1npRRAOB1mbsPieWz7mA&oe=6714E902"}, "display_name": "Mayapan Demo", "keywords": [], "long_description": "Conquer the great pyramid of Mayapan by showing your point and shoot skills. Use two crossbows and clear your way all over to the top. Match colors and make use of special bonuses. Beware, some bonuses are good, others are not! Also, keep track of flying bonuses, those are the special ones.\n\nFeeling good? Try the Survival chamber, at the pyramid's lower level. Resist as long as you can.. or taste the heated lava! \n\nHave local scores for you and your family. Also compete with other Oculus players in the general leaderboard! Be the best!\n\nThis is a Demo version with 3 Campaign levels and unlimited Survival play!\n\nMayapan awaits you!", "short_description": "Conquer the great pyramid of Mayapan by showing your point and shoot skills. Match colors and make use of special bonuses. Feeling good? Try the Survival chamber, at the pyramid's lower level. Resist as long as you can.. or taste the heated lava! Compete with other Oculus players in the general leaderboard! Be the best! This is a Demo version."}]}, "developer_name": null, "developer_privacy_policy_url": "https://quasarstudios.net/privacypolicy/vr-privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Quasar", "support_website_url": null, "website_url": "http://www.quasarstudios.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6558395304209692"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982478_675111604685019_4725851832908638153_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BSGOKI-DZbcQ7kNvgEiSyXK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDp8i-Iajj7jlvrJVREeqDOQ3ULFGQ1p5N1NZgBBELmjQ&oe=6714F27A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mayapan Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1697753254, "lastRevision": {"nodes": [{"id": "6558395310876358", "release_type": "SCHEDULED", "administration