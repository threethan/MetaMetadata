vival play!\n\nMayapan awaits you!", "short_description": "Conquer the great pyramid of Mayapan by showing your point and shoot skills. Match colors and make use of special bonuses. Feeling good? Try the Survival chamber, at the pyramid's lower level. Resist as long as you can.. or taste the heated lava! Compete with other Oculus players in the general leaderboard! Be the best! This is a Demo version."}]}, "developer_name": null, "developer_privacy_policy_url": "https://quasarstudios.net/privacypolicy/vr-privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Quasar", "support_website_url": null, "website_url": "http://www.quasarstudios.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6558395304209692"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_675111604685019_4725851832908638153_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RABPsSDtzlAQ7kNvgG3yRtw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN5W1fatR5hGdrivW3-O7I2&oh=00_AYAzhWxKn3giQIg8FZt0gmEADgLFZmdf5XEmwOsyhWJwgQ&oe=66F2AB7A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mayapan Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}], 