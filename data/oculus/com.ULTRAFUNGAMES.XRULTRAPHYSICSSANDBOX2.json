ng?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kBEdow_m2MMQ7kNvgFe1UPp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBvJlm74gH1e6JNUevs460mE8TASnYL2YT8MUE0ihrCw&oe=6745AC01"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "XR2_resized_2560x1440.png", "id": "924939842785466", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974713_924939846118799_2719880002950578241_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6gi_fPAXpJQQ7kNvgEt3jS_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmXE6emOthz9AKVKPLp4elWeUChquiYj1g3n3SXk4nAg&oe=6745B60E"}, "display_name": "XR ULTRA PHYSICS SANDBOX 2: BATTLE MAYHEM", "keywords": ["sandbox", "physics", "combat", "shooter", "action"], "long_description": "Get ready for intense VR combat with XR Ultra Physics Sandbox 2: Battle Mayhem ! This action-packed sequel builds on the original with 165 weapons, a wide variety of AI bots, and realistic physics-driven battles. Step into a dynamic arena where every shot, every explosion, and every fight feels immersive and real.\n\nIn this game, you'll face off against AI bots with unique combat styles\u2014melee, pistols, rifles, shotguns, snipers, and even boxing bots. With lifelike ragdoll physics, each enemy reacts to your hits, bullets, and explosions, adding intensity to the battlefield. Whether you're up close with swords and shields or taking down enemies from afar with sniper rifles, the action never stops.\n\nThe game will initially feature a basic map and bots, but will grow with future updates, adding new maps and more challenging AI.\n\nThis time you\u2019ll focus on outsmarting and outmaneuvering bots in chaotic battles. And soon, Mixed Reality Mode will allow you to bring the fight into your real-world surroundings for the ultimate VR experience.\n\nXR Ultra Physics Sandbox 2: Battle Mayhem (Alpha) delivers the best in VR combat with stunning visuals, smooth physics, and endless possibilities!", "short_description": "XR Ultra Physics Sandbox 2: Battle Mayhem is an intense XR combat game featuring advanced AI bots, 165 weapons, and dynamic physics-driven battles"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ultrafungames.com/privacy-policy-oculus/", "developer_terms_of_service_url": null, "publisher_name": "Ultra Fun Games", "support_website_url": null, "website_url": "https://www.ultrafungames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7913321052105150"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "431908936670939"}]}, "baseline_offer": {"id": "431908936670939"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727359981, "status": "PUBLISHED", "id": "431908936670939"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8130191217084798", "version": "2.9.7"}, "id": "502978079309243", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7913321042105151", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8130191217084798"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": 