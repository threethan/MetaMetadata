h=00_AYDw4P16tI9zoK-TfLfdPINDTY2FAlcnpQsxdQkrwJwp-Q&oe=66D07885"}, {"file_name": "\u30ea\u30d7\u30ec\u30a4\u30b7\u30fc\u30f302.png", "id": "1594968261307797", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003277_1594968264641130_4705740987765687396_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jT_xBFKhhS0Q7kNvgHxsgZe&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXGf07jIE2m14RgwKiZSUqrN81aJKV8HoOzjV3l9k5ow&oe=66D06BDC"}, {"file_name": "\u30aa\u30f3\u30e9\u30a4\u30f301.png", "id": "730391658875123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003266_730391662208456_8955265094551262484_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-uO7jkuRCVgQ7kNvgHFp9yw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEr7B_cLfrBICMroJG2U_eQPQQhkF98ITYwHhRt1iBlQ&oe=66D05A89"}, {"file_name": "\u30ed\u30d3\u30fc00.png", "id": "929376048584916", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_929376051918249_8542661393386288777_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IXH0NWItUm8Q7kNvgEMjE9i&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWxz9agGBHKruRMWjQAulkD67AjRW5p-NypolwhQlPmw&oe=66D0757F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440.png", "id": "1349991142355797", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371504_1349991145689130_5675624595774220636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uU_M6MxFRLcQ7kNvgHRG8Gp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgPb49mMQXI0BxpD8iQRz_NJeWEiFLsRcBubkPhu6H7Q&oe=66D04AC9"}, "display_name": "ULTIMATE SWING GOLF", "keywords": ["Chat", "ONLINE", "MR", "SPORTS", "SHOT"], "long_description": "Clap Hanz, the beloved golf game developer, presents the definitive golf experience in Ultimate Swing Golf!\n\nThe intuitive shot system recreates the feel and exhilaration of golf in a VR world. Simply swing your controller to adjust your power and the direction of the ball!\n\nNo matter your golfing preference, there's a mode for you. Hit the links in the Free Play and Training modes, clear missions and hone your skills in Challenge mode, or turn your room into a proper golf venue with MR Play mode!\n\nHit a bucket of balls and shoot the breeze with friends from around the world in Online Match mode, where a maximum of 4 players can enjoy a game of golf together, complete with voice chat, quick messages, and emotes!\n", "short_description": "It's like having your very own golf course.\nPlay a round of VR golf anywhere, anytime, and with anybody!\n\nEnjoy the latest VR golf game from Clap Hanz, a beloved golf game developer for the past 25 years!\nPut on your headset to be instantly surrounded by the lush greens and rolling slopes of expansive golf courses\u2014no travel, reservations, or club memberships required.\nWhether you're a beginner or a seasoned golf pro, Ultimate Swing Golf offers an immersive world of golf that everyone can enjoy!"}, {"images": {"nodes": [{"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440jp\u534a\u89d2.png", "id": "339646909090947", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031428_339646912424280_2312519129757564492_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PxpmtJ82WnEQ7kNvgH06oD5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHYgOu9Rk8UmA6KhcKG1noo2yDVdOrtu8crD6pM_Qo9w&oe=66D077A1"}]}, "id": "201306306175709", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440_jp.png", "id": "1099469434669935", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282162_1099469438003268_8173936974024535901_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_H6DfObUrtkQ7kNvgH1vFtP&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvo6v9lDW42dCWzkGfwWbAU0yjBCmeK14tfVzLMH_9WQ&oe=66D0525A"}, "display_name": "\u30a2\u30eb\u30c6\u30a3\u30e1\u30c3\u30c8 \u30b9\u30a4\u30f3\u30b0 \u30b4\u30eb\u30d5", "keywords": ["Chat", "ONLINE", "SPORTS", "MR", "SHOT"], "long_description": "