nc_sid=6e7a0a&_nc_ohc=d2iw7OUU_DYQ7kNvgFegFVb&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au4hjoVcjAKwwX4kB-R-sZX&oh=00_AYCMjTQrdsw9s8e0ffq3Z3PYMvxCkFHE5QgHqV_QSWoQ_g&oe=66E58043"}, {"file_name": "\u30b9\u30af\u30b7\u30e702.png", "id": "1203234357544530", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570294_1203234360877863_9145783152507878137_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-MVNrLAJQPUQ7kNvgHJ0A6F&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au4hjoVcjAKwwX4kB-R-sZX&oh=00_AYDU2yJArFluTvaCgpgcEIbY7IK1u8Nb940OhdaJu5QP-A&oe=66E57277"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE_2560-1440.png", "id": "489125490513451", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75647712_489125493846784_9094694097717540562_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ctG0mqqvnPsQ7kNvgHX4cv8&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au4hjoVcjAKwwX4kB-R-sZX&oh=00_AYB05szhnLLT7-n3E94jPfOrp8Or0PEYb80-3GQWbx5dYQ&oe=66E573BF"}, "display_name": "ULTIMATE SWING GOLF", "keywords": ["Chat", "ONLINE", "MR", "SPORTS", "SHOT"], "long_description": "\u26f3\ufe0fClap Hanz, the beloved golf game developer, presents the definitive golf experience in Ultimate Swing Golf!\ud83c\udfcc\ufe0f\u200d\u2640\ufe0f\n\nThe intuitive shot system recreates the feel and exhilaration of golf in a VR world. Simply swing your controller to adjust your power and the direction of the ball!\n\nNo matter your golfing preference, there's a mode for you. Hit the links in the Free Play and Training modes, clear missions and hone your skills in Challenge mode, or turn your room into a proper golf venue with MR Play mode!\n\nHit a bucket of balls and shoot the breeze with friends from around the world in Online Match mode, where a maximum of 4 players can enjoy a game of golf together, complete with voice chat, quick messages, and emotes!\n", "short_description": "It's like having your very own golf course.\nPlay a round of VR golf anywhere, anytime, and with anybody!\n\nEnjoy the latest VR golf game from Clap Hanz, a beloved golf game developer for the past 25 years!\nPut on your headset to be instantly surrounded by the lush greens and rolling slopes of expansive golf courses\u2014no travel, reservations, or club memberships required.\nWhether you're a beginner or a seasoned golf pro, Ultimate Swing Golf offers an immersive world of golf that everyone can enjoy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://claphanz.com/product/usg/pp_en.html", "developer_terms_of_service_url": null, "publisher_name": "Clap Hanz Limited", "support_website_url": "https://claphanzusg.zendesk.com/hc/en-us", "website_url": "https://claphanz.com/en/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8215911845113546"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982447_1241315840622926_8040016080755830962_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lkkv-PYYtZkQ7kNvgGF0vIz&_nc_ht=scontent.oculuscdn.com&_nc_gid=Au4hjoVcjAKwwX4kB-R-sZX&oh=00_AYCKiVmkyBZcE0oulyy18IRkIZQinDyi78LnuSg_a161Sg&oe=66E57ABE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ULTIMATE SWING GOLF", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics