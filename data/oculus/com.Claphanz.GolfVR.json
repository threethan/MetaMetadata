uluscdn.com&oh=00_AYDIV2Ya0xjSQLc16VE4WiwdG24k2c9SrpJP1k0RjEl7sQ&oe=66E43764"}, {"file_name": "\u30b9\u30af\u30b7\u30e700.png", "id": "773163571411314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_773163574744647_1837069159778179269_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vXZE4jruik0Q7kNvgHgJ65f&_nc_ht=scontent.oculuscdn.com&oh=00_AYDz-hWkHQYobQf9KBYqcYnJHuSAFLqUtuzZ36kTAcePKA&oe=66E4168A"}, {"file_name": "\u4e3b\u89b3\u8996\u70b900.png", "id": "1124599562013630", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035401_1124599565346963_4804926702366139894_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OU-OtiGVrxEQ7kNvgHU7cNn&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGJ_kZIORoVc1hjqN2IKCcqv9und4WonHVbcSCecvLUw&oe=66E4279F"}, {"file_name": "\u3010\u30a2\u30d0\u30bf\u30fc\u3011\u4e0b\u534a\u8eab\u8868\u793a2K.png", "id": "1591040491515800", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_1591040494849133_2136140886031552571_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d2iw7OUU_DYQ7kNvgGFEsUi&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZ3G1cmx02UAzZbqieWSIY0qNMZNpri4MhMJQFhYzLfA&oe=66E42EC3"}, {"file_name": "\u30b9\u30af\u30b7\u30e702.png", "id": "1203234357544530", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570294_1203234360877863_9145783152507878137_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0XdV9f2TrsQ7kNvgG93-g_&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_R7PHk_Bw8IUKeg4ppKNVnz45ioJJoo_XQMcx55wPGw&oe=66E420F7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LANDSCAPE_2560-1440.png", "id": "489125490513451", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75647712_489125493846784_9094694097717540562_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ctG0mqqvnPsQ7kNvgELVjyl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAac2cUr-iZ6yQ_rzrF4ohcJGGwNA09UsHfzItbvXs4Vg&oe=66E4223F"}, "display_name": "ULTIMATE SWING GOLF", "keywords": ["Chat", "ONLINE", "MR", "SPORTS", "SHOT"], "long_description": "\u26f3\ufe0fClap Hanz, the beloved golf game developer, presents the definitive golf experience in Ultimate Swing Golf!\ud83c\udfcc\ufe0f\u200d\u2640\ufe0f\n\nThe intuitive shot system recreates the feel and exhilaration of golf in a VR world. Simply swing your controller to adjust your power and the direction of the ball!\n\nNo matter your golfing preference, there's a mode for you. Hit the links in the Free Play and Training modes, clear missions and hone your skills in Challenge mode, or turn your room into a proper golf venue with MR Play mode!\n\nHit a bucket of balls and shoot the breeze with friends from around the world in Online Match mode, where a maximum of 4 players can enjoy a game of golf together, complete with voice chat, quick messages, and emotes!\n", "short_description": "It's like having your very own golf course.\nPlay a round of VR golf anywhere, anytime, and with anybody!\n\nEnjoy the latest VR golf game from Clap Hanz, a beloved golf game developer for the past 25 years!\nPut on your headset to be instantly surrounded by the lush greens and rolling slopes of expansive golf courses\u2014no travel, reservations, or club memberships required.\nWhether you're a beginner or a seasoned golf pro, Ultimate Swing Golf offers an immersive world of golf that everyone can enjoy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://claphanz.com/product/usg/pp_en.html", "developer_terms_of_service_url": null, "publisher_name": "Clap Hanz Limited", "support_website_url": "https://claphanzusg.zendesk.com/hc/en-us", "website_url": "https://claphanz.com/en/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null