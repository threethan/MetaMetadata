a&_nc_ohc=ih9bV6FRKXsQ7kNvgGvY3iW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAcNCoOe7tPMIY3n-jGw0oU8xY9GqQSFJj3TgSsGKXZIQ&oe=66FD4B85"}, {"file_name": "\u30ea\u30d7\u30ec\u30a4\u30b7\u30fc\u30f302.png", "id": "1594968261307797", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003277_1594968264641130_4705740987765687396_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kePljw2Xdr0Q7kNvgF-OQOg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhqZE108GQlBlYGP1JJJLB1_YDk6G8X1gpkou-rOkWKg&oe=66FD3EDC"}, {"file_name": "\u30aa\u30f3\u30e9\u30a4\u30f301.png", "id": "730391658875123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003266_730391662208456_8955265094551262484_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ib3HRCmpFYAQ7kNvgGxP0YV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBs7vGn6P57t5iGvDhr6uqtOrfOEO_swOfIpJpgQYuYmw&oe=66FD2D89"}, {"file_name": "\u30ed\u30d3\u30fc00.png", "id": "929376048584916", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_929376051918249_8542661393386288777_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Igc1Q2wvV88Q7kNvgFVoqYM&_nc_ht=scontent.oculuscdn.com&oh=00_AYD167eWUtCmDF4rH_zHwEIu0PiDX12fkNw-gn1F7_aroQ&oe=66FD487F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440.png", "id": "1349991142355797", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371504_1349991145689130_5675624595774220636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aab8IiZABoIQ7kNvgEUsj9n&_nc_ht=scontent.oculuscdn.com&oh=00_AYBxX6AF4F8QgU2pPAFA7ru_qBaajq3Y8Kj6VNX0ck_eTw&oe=66FD1DC9"}, "display_name": "ULTIMATE SWING GOLF", "keywords": ["Chat", "ONLINE", "MR", "SPORTS", "SHOT"], "long_description": "Clap Hanz, the beloved golf game developer, presents the definitive golf experience in Ultimate Swing Golf!\n\nThe intuitive shot system recreates the feel and exhilaration of golf in a VR world. Simply swing your controller to adjust your power and the direction of the ball!\n\nNo matter your golfing preference, there's a mode for you. Hit the links in the Free Play and Training modes, clear missions and hone your skills in Challenge mode, or turn your room into a proper golf venue with MR Play mode!\n\nHit a bucket of balls and shoot the breeze with friends from around the world in Online Match mode, where a maximum of 4 players can enjoy a game of golf together, complete with voice chat, quick messages, and emotes!\n", "short_description": "It's like having your very own golf course.\nPlay a round of VR golf anywhere, anytime, and with anybody!\n\nEnjoy the latest VR golf game from Clap Hanz, a beloved golf game developer for the past 25 years!\nPut on your headset to be instantly surrounded by the lush greens and rolling slopes of expansive golf courses\u2014no travel, reservations, or club memberships required.\nWhether you're a beginner or a seasoned golf pro, Ultimate Swing Golf offers an immersive world of golf that everyone can enjoy!"}, {"images": {"nodes": [{"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440jp\u534a\u89d2.png", "id": "339646909090947", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031428_339646912424280_2312519129757564492_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bO5SHblUw3cQ7kNvgGBToge&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8I44K9scCCiKb2IqD5I6yxHfw5sZTlDvPEILzLseR6w&oe=66FD4AA1"}]}, "id": "201306306175709", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440_jp.png", "id": "1099469434669935", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282162_1099469438003268_8173936974024535901_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_9F5zCPC-98Q7kNvgGU4eXX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDl5308kVbx5YnZOy72MuB7-rdov9ULymMNJD9J4liDRg&oe=66FD255A"}, "display_name": "\u30a2\u30eb\u30c6\u30a3\u30e1\u30c3\u30c8 \u30b9\u30a4\u30f3\u30b0 \u30b4\u30eb\u30d5", "keywords": 