2484_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aVZPLtUnEVMQ7kNvgHh8dCP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALZ2bTXkq797lYKDLtDUvWSR_rvXbpfck2sNxRDGiUPA&oe=67597689"}, {"file_name": "\u30ed\u30d3\u30fc00.png", "id": "929376048584916", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974861_929376051918249_8542661393386288777_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XVxtCdyBsgwQ7kNvgGszImz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD75I6kNr3Uv8vaytAP2K14f_nTzd7xV0-fY264M8z2yA&oe=6759917F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440.png", "id": "1349991142355797", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75371504_1349991145689130_5675624595774220636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rdoSBgA1pncQ7kNvgEL4BGw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxaRuZj-m_J8VfTZ5vh-rYMvXePXz4S4E6z6X7NQWXNA&oe=675966C9"}, "display_name": "ULTIMATE SWING GOLF", "keywords": ["Chat", "ONLINE", "MR", "SPORTS", "SHOT"], "long_description": "Clap Hanz, the beloved golf game developer, presents the definitive golf experience in Ultimate Swing Golf!\n\nThe intuitive shot system recreates the feel and exhilaration of golf in a VR world. Simply swing your controller to adjust your power and the direction of the ball!\n\nNo matter your golfing preference, there's a mode for you. Hit the links in the Free Play and Training modes, clear missions and hone your skills in Challenge mode, or turn your room into a proper golf venue with MR Play mode!\n\nHit a bucket of balls and shoot the breeze with friends from around the world in Online Match mode, where a maximum of 4 players can enjoy a game of golf together, complete with voice chat, quick messages, and emotes!\n", "short_description": "It's like having your very own golf course.\nPlay a round of VR golf anywhere, anytime, and with anybody!\n\nEnjoy the latest VR golf game from Clap Hanz, a beloved golf game developer for the past 25 years!\nPut on your headset to be instantly surrounded by the lush greens and rolling slopes of expansive golf courses\u2014no travel, reservations, or club memberships required.\nWhether you're a beginner or a seasoned golf pro, Ultimate Swing Golf offers an immersive world of golf that everyone can enjoy!"}, {"images": {"nodes": [{"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440jp\u534a\u89d2.png", "id": "339646909090947", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031428_339646912424280_2312519129757564492_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oNigoIKMAEUQ7kNvgFTjLgq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDDIUlJznkqetIOwXY50MXqiyoTgLYZNYhgv_ri4R1i0Q&oe=675993A1"}]}, "id": "201306306175709", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PUB_UltimateSwingGolf_Landscape_2560x1440_jp.png", "id": "1099469434669935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75282162_1099469438003268_8173936974024535901_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NVi0Lbtz2oEQ7kNvgFuCCTk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBYA_7r4EmYSK4dassPO-wtHhcFpN4bdI3X1NXuiaw1g&oe=67596E5A"}, "display_name": "\u30a2\u30eb\u30c6\u30a3\u30e1\u30c3\u30c8 \u30b9\u30a4\u30f3\u30b0 \u30b4\u30eb\u30d5", "keywords": ["Chat", "ONLINE", "SPORTS", "MR", "SHOT"], "long_description": "\u9577\u304d\u306b\u308f\u305f\u308a\u30b4\u30eb\u30d5\u30b2\u30fc\u30e0\u3092\u5236\u4f5c\u3057\u3066\u304d\u305f\u30af\u30e9\u30c3\u30d7\u30cf\u30f3\u30ba\u304c\u4e16\u754c\u6700\u9ad8\u5cf0\u306e\u30b4\u30eb\u30d5\u30b2\u30fc\u30e0\u3092\u76ee\u6307\u3057\u305f\u300e\u30a2\u30eb\u30c6\u30a3\u30e1\u30c3\u30c8 \u30b9\u30a4\u30f3\u30b0 \u30b4\u30eb\u30d5\u300f\u767b\u5834\uff01\n\n\u30ea\u30a2\u30eb\u30b4\u30eb\u30d5\u306e\u611f\u899a\u3068\u30b2\u30fc\u30e0\u306e\u723d\u5feb\u3055\u3092\