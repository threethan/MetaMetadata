dn.com/v/t64.5771-25/39031506_757284049684504_5415076928490997642_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F9ctlMVnpZcQ7kNvgHJ70j_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmsPTsGQfseReBzrAKYi2v9nApJ9f7QErXUXOAt5cvZg&oe=67498FC1"}, {"file_name": "PDP.png", "id": "510170831440884", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75280177_510170834774217_6530975145504240461_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wuofeTU16iQQ7kNvgEbwGQL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyRDf77hhmkLQ9dgzC-jZvTH81zIOf0wjZZtrg88Jb7g&oe=6749C0B4"}]}, "id": "1268921604085890", "locale": "en_US", "screenshots": [{"file_name": "ss1.png", "id": "1172731957270033", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568725_1172731960603366_7137655449157269643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rqjAKzehaEQQ7kNvgG9e8hP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdr_9qYnPGZvF7GTRK_3-gAQ7BMzK2RzptqAKsuQJkDQ&oe=6749978C"}, {"file_name": "ss5.png", "id": "1021588309330663", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974465_1021588312663996_7555205763920629203_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nHyrfW-Ygk4Q7kNvgGbhD6S&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBImDKGt8haycvZRMdqO7A8LtLvNN1PJarVNcPQP3kRxA&oe=6749C271"}, {"file_name": "ss2.png", "id": "448788341371442", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223483_448788344704775_629309233119315146_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ejHA9vAIZoEQ7kNvgFu7Wq6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCcDLR2DXRQ44sA-J1vDkMzSSM9AnIju9pW9weTWu74g&oe=6749BDF3"}, {"file_name": "ss3.png", "id": "1695566267856585", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031545_1695566271189918_7563581897204183653_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lwgn5sYbJp0Q7kNvgE1LthR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0MSwqGhfMNzGRpZhK86nK86_Q3bJyLwZllkd4NaYfZQ&oe=6749A33C"}, {"file_name": "ss4.png", "id": "3751167238508534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_3751167241841867_2951941851866511973_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h2PGcLtm0ToQ7kNvgEYxInJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCen6YL2HdWTLsWg9H4eXaefbRezqfYsFCnCKSsNJaqg&oe=6749ABDD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1691892224915749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580056_1691892228249082_8993988736869608245_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R_2l97MSs1AQ7kNvgHr6H_E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAphYqjwX0sYnZdLKWOi3gisQwJCdm2AFc8vegHtt48Dg&oe=6749AD5A"}, "display_name": "Stealthy Swipers", "keywords": [], "long_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience.\n\nGame Features:\n\n    Immersive VR Environment:\n        Experience a meticulously crafted, enormous space brought to life with state-of-the-art VR graphics. The game environment is designed to be visually stunning and deeply immersive, making you feel like you are truly inside a high-tech, futuristic world.\n\n    Stealth and Strategy Gameplay:\n        Engage in challenging stealth gameplay that requires careful planning and quick reflexes. Utilize shadows, create diversions, and use high-tech gadgets to avoid being detected by the vigilant room owner.", "short_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stealthyswipers/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FQWEFWQ Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/stealthyswipers", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749072878519088"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221322_1008179354030516_6024045466327582322_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=smy6EuTS0nkQ7kNvgGcXR_z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAeizjE7ZSHdcOkt1L8jWfwHcnPMhTxIP5TfX64f_Fbmw&oe=6749B514"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Stealthy Swipers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1721145251, "lastRevision": {"nodes": [{"id": "7749072895185753", "release_type": "SCHEDULED", "administration_status": "