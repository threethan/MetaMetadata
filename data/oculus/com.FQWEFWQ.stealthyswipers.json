&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_sDqc9FRJ2KpYT6aZwlDJPx_tZqtuZkcVddxm3fSIuw&oe=6762CA73"}, {"file_name": "ss3.png", "id": "1695566267856585", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031545_1695566271189918_7563581897204183653_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rrv1lNahb2AQ7kNvgGW6Ao-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUEp1Nan79Rcsd3HtJtMaRSmTgOd-AIcay2UozOecFUw&oe=6762AFBC"}, {"file_name": "ss4.png", "id": "3751167238508534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_3751167241841867_2951941851866511973_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NFclq_emjDUQ7kNvgG-DFRs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeqlcp0wdEX_J4fNL5gX4zwsJ75eKY3MmHXVpYRIIIOw&oe=6762B85D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1691892224915749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580056_1691892228249082_8993988736869608245_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V-JPxIiE5AAQ7kNvgFDAxco&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZKDbt8s2uerdBZ-dvPPI1sFplxuhrgwOxeIAFUpLKnA&oe=6762B9DA"}, "display_name": "Stealthy Swipers", "keywords": [], "long_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience.\n\nGame Features:\n\n    Immersive VR Environment:\n        Experience a meticulously crafted, enormous space brought to life with state-of-the-art VR graphics. The game environment is designed to be visually stunning and deeply immersive, making you feel like you are truly inside a high-tech, futuristic world.\n\n    Stealth and Strategy Gameplay:\n        Engage in challenging stealth gameplay that requires careful planning and quick reflexes. Utilize shadows, create diversions, and use high-tech gadgets to avoid being detected by the vigilant room owner.", "short_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stealthyswipers/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FQWEFWQ Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/stealthyswipers", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749072878519088"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7749127415180301", "version": "1.0"}, "id": "2540507282822248", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries