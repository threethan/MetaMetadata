dn.com/v/t64.5771-25/39031506_757284049684504_5415076928490997642_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kzpKVCLhPjAQ7kNvgHyGdu_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoRj3mXyk1_iZpvCIml0SG-6Xb61uBS5WyZj80ZhKyww&oe=67629C41"}, {"file_name": "PDP.png", "id": "510170831440884", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75280177_510170834774217_6530975145504240461_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WthrHw9n4NwQ7kNvgHoBpTT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCOuzNQ02-VuKSpbzDIQZsTg9qkR7YkKWr8n0pQrSUD3g&oe=6762CD34"}]}, "id": "1268921604085890", "locale": "en_US", "screenshots": [{"file_name": "ss1.png", "id": "1172731957270033", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75568725_1172731960603366_7137655449157269643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZtrwzxQ53UwQ7kNvgEj_cbi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDR8QjyfaPty_23zqINFQXfITL7SaWXS7ZDMHhNuZsT8A&oe=6762A40C"}, {"file_name": "ss5.png", "id": "1021588309330663", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974465_1021588312663996_7555205763920629203_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ywTOk3BBgy4Q7kNvgG2wYfB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhQk5jGmHa89u-AlCHm2mo5R0q-jmgLl2_zy_g2x7HYw&oe=6762CEF1"}, {"file_name": "ss2.png", "id": "448788341371442", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223483_448788344704775_629309233119315146_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QaburKyLkb4Q7kNvgF7zefF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_sDqc9FRJ2KpYT6aZwlDJPx_tZqtuZkcVddxm3fSIuw&oe=6762CA73"}, {"file_name": "ss3.png", "id": "1695566267856585", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031545_1695566271189918_7563581897204183653_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rrv1lNahb2AQ7kNvgGW6Ao-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUEp1Nan79Rcsd3HtJtMaRSmTgOd-AIcay2UozOecFUw&oe=6762AFBC"}, {"file_name": "ss4.png", "id": "3751167238508534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_3751167241841867_2951941851866511973_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NFclq_emjDUQ7kNvgG-DFRs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeqlcp0wdEX_J4fNL5gX4zwsJ75eKY3MmHXVpYRIIIOw&oe=6762B85D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1691892224915749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580056_1691892228249082_8993988736869608245_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V-JPxIiE5AAQ7kNvgFDAxco&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZKDbt8s2uerdBZ-dvPPI1sFplxuhrgwOxeIAFUpLKnA&oe=6762B9DA"}, "display_name": "Stealthy Swipers", "keywords": [], "long_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience.\n\nGame Features:\n\n    Immersive VR Environment:\n        Experience a meticulously crafted, enormous space brought to life with state-of-the-art VR graphics. The game environment is designed to be visually stunning and deeply immersive, making you feel like you are truly inside a high-tech, futuristic world.\n\n    Stealth and Strategy Gameplay:\n        Engage in challenging stealth gameplay that requires careful planning and quick reflexes. Utilize shadows, create diversions, and use high-tech gadgets to avoid being detected by the vigilant room owner.", "short_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stealthyswipers/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FQWEFWQ Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/stealthyswipers", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749072878519088"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221322_1008179354030516_6024045466327582322_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sF0OLQTF_rsQ7kNvgFVVJZI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvv12RXp7UWSc2M1wFmaOOEUdcay330M7Ac5upjdi6_w&oe=6762C194"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Stealthy Swipers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1721145251, "lastRevision": {"nodes": [{"id": "7749072895185753", "release_type": "SCHEDULED", "administration_status": "A