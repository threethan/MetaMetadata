.com&oh=00_AYDlnuHupS1D9CHVoV83w7QjaG07gHCwmH9xJkiCxRxKKA&oe=677E5F3C"}, {"file_name": "ss4.png", "id": "3751167238508534", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/39001725_3751167241841867_2951941851866511973_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QxqrZ5MjLwoQ7kNvgG5j4VV&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDxpUAAyYmVZXXEJAUEumCNgZj38Ij1D2B5qAC5CBEcYg&oe=677E67DD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1691892224915749", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75580056_1691892228249082_8993988736869608245_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a1Gt39T3_fsQ7kNvgHd1PWO&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCOu0TYuYHtdMVTWliMbyTQLoco6OUUjoQzEra_rS_9_w&oe=677E695A"}, "display_name": "Stealthy Swipers", "keywords": [], "long_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience.\n\nGame Features:\n\n    Immersive VR Environment:\n        Experience a meticulously crafted, enormous space brought to life with state-of-the-art VR graphics. The game environment is designed to be visually stunning and deeply immersive, making you feel like you are truly inside a high-tech, futuristic world.\n\n    Stealth and Strategy Gameplay:\n        Engage in challenging stealth gameplay that requires careful planning and quick reflexes. Utilize shadows, create diversions, and use high-tech gadgets to avoid being detected by the vigilant room owner.", "short_description": "Description:\nImmerse yourself in the thrilling world of \"Stealthy Swipers,\" a cutting-edge VR game where your mission is to \"borrow\" valuable items from a vast, high-tech environment while evading detection by the colossal room owner. This game combines intense stealth mechanics, strategic gameplay, and a rich, futuristic setting to deliver an unforgettable virtual reality experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stealthyswipers/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "FQWEFWQ Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/stealthyswipers", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749072878519088"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/75221322_1008179354030516_6024045466327582322_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GmhS547SbxoQ7kNvgGhNEs-&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYCFziBZO_OFOJkCVwCFiBZ3gQD-5VJ1ZaPunpo_ah1SWQ&oe=677E7114"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Stealthy Swipers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1721145251, "lastRevision": {"nodes": [{"id": "7749072895185753", "release_type": "SCHEDULED", "administration