x6ddxs8DQ&oe=6730B7C0"}, {"file_name": "cover3.png", "id": "454276110401599", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031493_454276113734932_245637187017579215_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=afmGvbyzu9MQ7kNvgFG3A7K&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBstawshcw8u8Et-HCf39km4A9NtGnVWvlUKBEo21Oihw&oe=6730A804"}]}, "id": "1276046306895358", "locale": "en_US", "screenshots": [{"file_name": "ss1.png", "id": "1049297360053302", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982708_1049297363386635_8548528087422687956_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9UdFzEKml7kQ7kNvgFmwgj4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAS2J9Tu2916m5uM6_V5nekSctdCljV-xQ8knS49jC1zA&oe=67308914"}, {"file_name": "ss3.png", "id": "566890692442113", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974876_566890695775446_4042312219794854383_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NUhP1NXl9QoQ7kNvgGOS-1L&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBK1F2kC_hiAP7VTygNghhS7C0xwm6llbOL1ZiLT_jidw&oe=67308116"}, {"file_name": "ss4.png", "id": "426521363791162", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75339313_426521367124495_4493194802169610459_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XIAGIaxunsQ7kNvgGBZ8hz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB6BueCtZTTBQhTO-xQDI7oe9qG7TjE13jvHn7eG4R3eA&oe=67309FFD"}, {"file_name": "ss5.png", "id": "1700756230719891", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974460_1700756234053224_6195843822788066058_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cHyRs3pjcBQQ7kNvgG-1eNs&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB0mSTYLruCdJF43osu3XxNOlriWawxQxdASArVVynIGQ&oe=67308B38"}, {"file_name": "ss2.png", "id": "1196958141359511", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036675_1196958144692844_5890880082241489579_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tJeOzt2rbAUQ7kNvgFgF6Mj&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAIpEe04jv6LzyIsan-xxybySuvU8FPpJMfSFQQxgt7zQ&oe=6730AD55"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CopiaMaster_VR", "keywords": [], "long_description": "CopiaMaster VR is an innovative software platform that allows users to immerse themselves in a 3D virtual environment and acquire non-verbal skills. By recreating 3D recordings of skilled professionals performing complex tasks, users can relive the experience in a realistic way, enabling them to grasp the details of the techniques and decision-making processes. This learning experience helps users naturally acquire skills and workflows without the need for verbal instruction.\nThe current version of CopiaMaster VR includes tools for endoscopic surgery, allowing medical professionals to refine their skills in a virtual space. The software faithfully recreates the surgical procedures, enabling users to relive the process and gain a deeper understanding of the technical details.\nIn the future, CopiaMaster VR will expand beyond the medical field, with updates planned to add tools for other industries. This will allow the software to be utilized not only by medical professionals but also in various industries where hands-on skill training is essential.", "short_description": "CopiaMaster VR is a software designed to help users acquire non-verbal skills by reliving tasks through 3D recordings of experienced professionals at work. The current version comes with endoscopic surgery tools pre-installed, and future updates will include tools for other industries."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.keisuu.co.jp/applications-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Keisuu Giken", "support_website_url": null, "website_url": "https://www.keisuu.co.jp/", "category": null, "comfort_rating": "COMFOR