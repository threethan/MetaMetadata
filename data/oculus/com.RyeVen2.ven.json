om/v/t64.5771-25/39031545_471066965841192_8536542052622703616_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hhAgJrjN0JUQ7kNvgEiNGZs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATlacZHXdPRJDQPgWUyiNB8OhtTRVB-fYIrEEC5741XQ&oe=676803BE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "RyeVen 2", "keywords": [], "long_description": "RyeVen 2 is an incredibly entertaining and immersive game that offers players the exhilarating experience of swinging through vibrant, dynamic environments using only their arms. Whether you're soaring through the air, navigating challenging obstacles, or exploring breathtaking landscapes, the game provides endless excitement and thrill. Additionally, RyeVen 2 emphasizes social interaction, allowing you to hang out and collaborate with friends, creating unforgettable moments and fostering a sense of community. The combination of its unique gameplay mechanics and social features makes RyeVen 2 a must-play for anyone seeking adventure and camaraderie in a virtual world.", "short_description": "RyeVen 2 Is a very fun game where you can swing around with your arms and hang out with your friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/privacypolicyryeven2/home", "developer_terms_of_service_url": null, "publisher_name": "Venakry", "support_website_url": null, "website_url": "https://sites.google.com/view/ryeven2/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes"