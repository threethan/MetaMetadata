_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qn7UaDbYfPoQ7kNvgF8HTbe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBbdnw-QRc3sdYlXIPEUF3dSJFbZWH6ehmxGDE1E2-pGg&oe=6720D35D"}, {"file_name": "ss4.png", "id": "316338850959536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982551_316338854292869_2640498214962027861_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77iMpP35pVsQ7kNvgGgV_hf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBujH9DEHR-kgX3c7n1xCCGnSUu3NumeMB2-4ImUaLbtw&oe=6720CD37"}, {"file_name": "ss5.png", "id": "849803243253751", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_849803246587084_5779682533541394493_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cf6cIDReMnAQ7kNvgEEt3W4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANpsA90wWW6vUwlp9oVsZUbfCaHWxjjZqxRWu8k71ENA&oe=6720B487"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560.png", "id": "1156220598972503", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035413_1156220602305836_4459261898112997164_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SmfqyjQ2VkQQ7kNvgE_7Dhf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxfjlggyS3kH8uNL0MSGEEMm1fZGYUl6oYTs5ct-VEfw&oe=6720BA7B"}, "display_name": "Motocross Offroad", "keywords": ["motorbike", "motocross", "offroad", "race", "bike"], "long_description": "Physics : \ud83c\udfcd\ufe0f\nDifferent motorbikes with realistic physics without motion sickness. Each motorbike has unique riding experience. \n\nMaps :\ud83c\udf28\ufe0f\u2744\ufe0f\ud83c\udf24\ufe0f\ud83c\udf19\nNavigate rocky canyons, splash through mud pits, and catch air off natural jumps. Feel the rush as you lean into turns, surrounded by towering pine trees and sun-drenched vistas.\n\n\ud83c\udfc1Beat the AI enemies and take the keys of motorbikes! \ud83c\udfc1\n\n", "short_description": "In \u201cMotocross Offroad\u201d riders strap on their virtual reality headsets and become off-road warriors. Picture yourself gripping the handlebars of a rugged dirt bike, the engine growling as you tear through wild landscapes. Whether you\u2019re battling it out in intense races, conquering treacherous trails, or pulling off gravity-defying stunts, this game delivers the full-throttle experience.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ketchygames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8268571356541792"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_417929294625370_2169476768911429308_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nINTO0N5nzYQ7kNvgGRzfUV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxuoY5GCs1GKYg3JH0Sr_QqS-rpVBPcsTg3c1ELqMgxQ&oe=6720C4B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Motocross Offroad", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132