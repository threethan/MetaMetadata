2463447970_618787195227246667_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6P-LmZkQlCMQ7kNvgHn1yl4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnxjSDbNbH63SKUsHhYLSe4BaST5usBbK-U-qysurIAQ&oe=671E2D81"}, {"file_name": "Stilt_CoverArt_HeroCover.png", "id": "502770098604760", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196229_502770105271426_1304135675275595665_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q4sNu07p_NQQ7kNvgEb0wsL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1ooJ2FDPIUnC3JVLYz8zrOoAxx0GluDO9t9FYt9mu4A&oe=671E2683"}]}, "id": "874706153744430", "locale": "en_US", "screenshots": [{"file_name": "ScreenShoot20230222_135400.png", "id": "764663898875681", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974745_764663902209014_1878625030759697156_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ix_sU7ADHIgQ7kNvgEtokwy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9eOadJXTUxQPuWJUl--CduxwAHlxOas82Q8zY-HcVoQ&oe=671E2D15"}, {"file_name": "ScreenShoot20230222_134922.png", "id": "266003373186710", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75508956_266003376520043_2899268225533605783_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IlKAZDATwhIQ7kNvgHmC2Qp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2yBOFosi_mrUhWGezhnaM_ZXYoHLGsLXxwA8RoKv7-Q&oe=671E163F"}, {"file_name": "ScreenShoot20230222_132723.png", "id": "431634869187482", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340712_431634872520815_8679246834621898881_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZckNMA_TjWoQ7kNvgFuP0ph&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKX-39Yzo6ae7JHqpbFUCUTPlmY2J6RoeNbwHidQAQNg&oe=671E3082"}, {"file_name": "ScreenShoot20230222_135054.png", "id": "2138454739837157", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035345_2138454743170490_4003358151422983857_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MH-SzzKvv94Q7kNvgHRGogf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhA0ihpBfsQV6jy0ZH4u1ReExFiai_DlLkt0zopnZ6UA&oe=671E165C"}, {"file_name": "ScreenShoot20230222_132959.png", "id": "945077813683326", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75234369_945077817016659_23140257978207096_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDMkmOGnG8kQ7kNvgEJDUOH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJ0RKxwcCr1Xxz6q62l_siC_49oBkpCJXK-IROKOhJwg&oe=671E2773"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stilt_CoverArt_Landscape.png", "id": "340319788989400", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982609_340319792322733_8679089536552678010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1l_Y0fs3rUYQ7kNvgFAyks8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPAeEap4gvYs3sy851fS-l2kyHxRTzRyU1MG-CSIWyMw&oe=671E2C13"}, "display_name": "Stilt", "keywords": [], "long_description": "Embark on an exciting adventure in a 3D platformer game designed for virtual reality on Oculus Quest. With two stilts/springs attached to each hand, you'll use your unique locomotion skills to jump and run through challenging levels and overcome obstacles. Your mission is to retrieve your stolen spaceship, taken by a giant octopus that lives atop a volcano. As you make your way towards your goal, you'll collect cogwheels scattered throughout the levels to aid you in your journey.\n\nThis game takes inspiration from classic platformers and offers a fresh, immersive experience in virtual reality. You'll be transported to a world filled with danger and excitement, where you must use your quick reflexes and problem-solving skills to progress through the levels. With stunning stylized graphics, smooth controls, and an engaging gameplay experience, this VR platformer is sure to provide hours of entertainment. So put on your Oculus Quest and get ready to experience the thrill of jumping and running through a virtual world like never before.", "short_description": "Jump and run through thrilling levels in a platformer game for VR! Use your stilts to overcome obstacles and collect cogwheels on your quest to retrieve your stolen spaceship from a giant octopus atop a volcano. Classic platforming fun in an immersive 3D world. Get ready to experience the adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stilt-privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Rekt Games", "support_website_url": null, "website_url": "https://stiltgame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1229311244379203"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1034556421472777"}, {"status": "PUBLISHED", "id": "957862852761811"}, {"status": "PUBLISHED", "id": "380727071226796"}]}, "baseline_offer": {"id": "380727071226796"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1034556421472777"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8067397816722072", "version": "1.6.0"}, "id": "1283573515524542", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[New Feature] Added a new multiplayer game mode, Color Splash! Jump around and paint everything in sight. The player who covers the most area before time runs out wins!\n[Improvement] Added a progress counter above doors that open only after enemies are defeated, providing clearer feedback on progress.\n[Improvement] Made the first exit in Level 19 - Lava Mystery easier to locate.\n[Improvement] Adjusted the starting positions of rising platforms in the boss battle to guide players more effectively.\n[Improvement] Reduced how much the game over and score screens are head-locked, improving overall comfort.\n[Improvement] Added a tip suggesting assist mode activation if the player has died multiple times.\n[Improvement] Changed the audio effects for level portals in the overworld and adjusted transitions to fade to black instead of white.\n[Improvement] Added walls around the arena in Floor Pop game mode to prevent early punch outs.\n[Fix] Resolved an issue where players could get stuck inside locked doors.\n[Fix] Fixed icon alignment on level portals\u2014stamp rewards are now properly displayed on the left side with the rest of the stamp information.\n[Fix] Corrected an issue where buttons meant to be pressed once could be activated multiple times.\n[Fix] Portals in levels and gameplay are now triggered only by the player\u2019s head, not the stilts.\n[Fix] Resolved a bug where the sliding puzzle cube could clip into walls.\n[Fix] Fixed issues with cloud platforms in Level - Windmill Hills.\n[Fix] Addressed a bug where the game could appear frozen due to pausing during a loading screen.\n[Fix] Fixed an issue where looping audio persisted between scenes if the game was paused during a scene transition.", "created_date": 1727183393, "id": "8067397816722072", "version": "1.6.0", "version_code": 53, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726669948, "id": "8013003305494857", "version": "1.6.0", "version_code": 52, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726646957, "id": "8010624119066109", "version": "1.6.0", "version_code": 51, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[Improvement] Enabled the ability to reconnect to a multiplayer game after disconnection.\n[Improvement] Ensured the menu consistently faces the player after resetting the VR space in the main menu.\n[Improvement] Made the pause menu accessible during the intro sequence.\n[Improvement] Added a notification when entering multiplayer mode without a network connection.\n[Other] Extended the AFK timer in multiplayer from 60 seconds to 90 seconds.", "created_date": 1721123514, "id": "7620112998117225", "version": "1.5.0", "version_code": 50, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[New Feature] Added Assist Mode, offering a set of customizable settings to enhance your gameplay experience:\n- Unlimited Respawns: Respawn without the need for stamps.\n- Add Assist Elements: Adds extra platforms to make difficult sections easier and provides hints for mandatory puzzles.\n- Highlight Pickup Items: Beams of light will highlight every gift and key, making them easier to find.\n- Timeless Challenges: Removes timers from all time-based challenges.\n- Power-Up Shield: Prevents loss of power-ups when taking damage.\n- Game Over Shop: Choose any power-up from the shop when you die, instead of receiving a random one.\n[New Feature] Added a shooting challenge to the lobby. Shoot all targets and compete for the best time.\n[New Feature] Added musical instruments to the lobby for players to interact with.\n[New Feature] Added a rabbit character that hides somewhere in the lobby. Find it, and it will hide again.\n[Fix] Resolved white noise flickering on edges.\n[Improvement] Redesigned the game over screen button layout for better clarity and usability.\n[Other] Changed the random power-up selection on the game over screen to occur after purchase instead of before.\n[Improvement] Enhanced the random selection process for game sets in the multiplayer arena to ensure a more even distribution of game modes. It now selects three different random game modes first and then chooses random levels that correspond to each mode.\n[Improvement] Minor performance optimization's.\n[Improvement] Added a dynamic refresh rate feature that allows the game to step down from 90Hz to 72Hz in demanding situations, ensuring a stable framerate.", "created_date": 1720190080, "id": "7561435143985011", "version": "1.4.0", "version_code": 49, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}