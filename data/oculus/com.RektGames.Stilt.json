nary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[New Feature] Added a new multiplayer game mode, Color Splash! Jump around and paint everything in sight. The player who covers the most area before time runs out wins!\n[Improvement] Added a progress counter above doors that open only after enemies are defeated, providing clearer feedback on progress.\n[Improvement] Made the first exit in Level 19 - Lava Mystery easier to locate.\n[Improvement] Adjusted the starting positions of rising platforms in the boss battle to guide players more effectively.\n[Improvement] Reduced how much the game over and score screens are head-locked, improving overall comfort.\n[Improvement] Added a tip suggesting assist mode activation if the player has died multiple times.\n[Improvement] Changed the audio effects for level portals in the overworld and adjusted transitions to fade to black instead of white.\n[Improvement] Added walls around the arena in Floor Pop game mode to prevent early punch outs.\n[Fix] Resolved an issue where players could get stuck inside locked doors.\n[Fix] Fixed icon alignment on level portals\u2014stamp rewards are now properly displayed on the left side with the rest of the stamp information.\n[Fix] Corrected an issue where buttons meant to be pressed once could be activated multiple times.\n[Fix] Portals in levels and gameplay are now triggered only by the player\u2019s head, not the stilts.\n[Fix] Resolved a bug where the sliding puzzle cube could clip into walls.\n[Fix] Fixed issues with cloud platforms in Level - Windmill Hills.\n[Fix] Addressed a bug where the game could appear frozen due to pausing during a loading screen.\n[Fix] Fixed an issue where looping audio persisted between scenes if the game was paused during a scene transition.", "created_date": 1727183393, "id": "8067397816722072", "version": "1.6.0", "version_code": 53, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8067397816722072"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726669948, "id": "8013003305494857", "version": "1.6.0", "version_code": 52, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}