SsnxG0OMQ&oe=67220ADC"}, {"file_name": "ScreenShoot20230222_132959.png", "id": "945077813683326", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75234369_945077817016659_23140257978207096_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6k6G0W_kEYYQ7kNvgHSY2tk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAROi4A3o16HrXK1ShbuYdslylqNHNtRcte3vjWJ4AcmA&oe=67221BF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stilt_CoverArt_Landscape.png", "id": "340319788989400", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982609_340319792322733_8679089536552678010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C6eY7V6PWBAQ7kNvgFKlxAR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0MA5qMtN35s-uJ3QUYOA781LEG81Mv1m2Ok291F1XRg&oe=67222093"}, "display_name": "Stilt", "keywords": [], "long_description": "Embark on an exciting adventure in a 3D platformer game designed for virtual reality on Oculus Quest. With two stilts/springs attached to each hand, you'll use your unique locomotion skills to jump and run through challenging levels and overcome obstacles. Your mission is to retrieve your stolen spaceship, taken by a giant octopus that lives atop a volcano. As you make your way towards your goal, you'll collect cogwheels scattered throughout the levels to aid you in your journey.\n\nThis game takes inspiration from classic platformers and offers a fresh, immersive experience in virtual reality. You'll be transported to a world filled with danger and excitement, where you must use your quick reflexes and problem-solving skills to progress through the levels. With stunning stylized graphics, smooth controls, and an engaging gameplay experience, this VR platformer is sure to provide hours of entertainment. So put on your Oculus Quest and get ready to experience the thrill of jumping and running through a virtual world like never before.", "short_description": "Jump and run through thrilling levels in a platformer game for VR! Use your stilts to overcome obstacles and collect cogwheels on your quest to retrieve your stolen spaceship from a giant octopus atop a volcano. Classic platforming fun in an immersive 3D world. Get ready to experience the adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stilt-privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Rekt Games", "support_website_url": null, "website_url": "https://stiltgame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1229311244379203"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1034556421472777"}, {"status": "PUBLISHED", "id": "957862852761811"}, {"status": "PUBLISHED", "id": "380727071226796"}]}, "baseline_offer": {"id": "380727071226796"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1034556421472777"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8067397816722072", "version": "1.6.0"}, "id": "1283573515524542", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "