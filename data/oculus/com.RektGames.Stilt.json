16659_23140257978207096_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WfjWuZNtjWEQ7kNvgFYtnn8&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9eGuGTXSj9XT0WraA_TZSPR-N84G4aujcTxeXgqaJbg&oe=66D45373"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stilt_CoverArt_Landscape.png", "id": "340319788989400", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982609_340319792322733_8679089536552678010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iAUr7wdebqkQ7kNvgF2vGB5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnH7ARFkVYGscfvo4Wj9cU17jyiKIuJdjTi7S8IsrjUA&oe=66D45813"}, "display_name": "Stilt", "keywords": [], "long_description": "Embark on an exciting adventure in a 3D platformer game designed for virtual reality on Oculus Quest. With two stilts/springs attached to each hand, you'll use your unique locomotion skills to jump and run through challenging levels and overcome obstacles. Your mission is to retrieve your stolen spaceship, taken by a giant octopus that lives atop a volcano. As you make your way towards your goal, you'll collect cogwheels scattered throughout the levels to aid you in your journey.\n\nThis game takes inspiration from classic platformers and offers a fresh, immersive experience in virtual reality. You'll be transported to a world filled with danger and excitement, where you must use your quick reflexes and problem-solving skills to progress through the levels. With stunning stylized graphics, smooth controls, and an engaging gameplay experience, this VR platformer is sure to provide hours of entertainment. So put on your Oculus Quest and get ready to experience the thrill of jumping and running through a virtual world like never before.", "short_description": "Jump and run through thrilling levels in a platformer game for VR! Use your stilts to overcome obstacles and collect cogwheels on your quest to retrieve your stolen spaceship from a giant octopus atop a volcano. Classic platforming fun in an immersive 3D world. Get ready to experience the adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/stilt-privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Rekt Games", "support_website_url": null, "website_url": "https://stiltgame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1229311244379203"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "957862852761811"}, {"status": "PUBLISHED", "id": "380727071226796"}]}, "baseline_offer": {"id": "380727071226796"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724353200, "status": "PUBLISHED", "id": "957862852761811"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7620112998117225", "version": "1.5.0"}, "id": "1283573515524542", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7620112998117225"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[Improvement] Enabled the ability to reconnect to a multiplayer game after disconnection.\n[Improvement] Ensured the menu consistently faces the player after resetting the VR space in the main menu.\n[Improvement] Made the pause menu accessible during the intro sequence.\n[Improvement] Added a notification when entering multiplayer mode without a network connection.\n[Other] Extended the AFK timer in multiplayer from 60 seconds to 90 seconds.", "created_date": 1721123514, "id": "7620112998117225", "version": "1.5.0", "version_code": 50, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7620112998117225"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[New Feature] Added Assist Mode, offering a set of customizable settings to enhance your gameplay experience:\n- Unlimited Respawns: Respawn without the need for stamps.\n- Add Assist Elements: Adds extra platforms to make difficult sections easier and provides hints for mandatory puzzles.\n- Highlight Pickup Items: Beams of light will highlight every gift and key, making them easier to find.\n- Timeless Challenges: Removes timers from all time-based challenges.\n- Power-Up Shield: Prevents loss of power-ups when taking damage.\n- Game Over Shop: Choose any power-up from the shop when you die, instead of receiving a random one.\n[New Feature] Added a shooting challenge to the lobby. Shoot all targets and compete for the best time.\n[New Feature] Added musical instruments to the lobby for players to interact with.\n[New Feature] Added a rabbit character that hides somewhere in the lobby. Find it, and it will hide again.\n[Fix] Resolved white noise flickering on edges.\n[Improvement] Redesigned the game over screen button layout for better clarity and usability.\n[Other] Changed the random power-up selection on the game over screen to occur after purchase instead of before.\n[Improvement] Enhanced the random selection process for game sets in the multiplayer arena to ensure a more even distribution of game modes. It now selects three different random game modes first and then chooses random levels that correspond to each mode.\n[Improvement] Minor performance optimization's.\n[Improvement] Added a dynamic refresh rate feature that allows the game to step down from 90Hz to 72Hz in demanding situations, ensuring a stable framerate.", "created_date": 1720190080, "id": "7561435143985011", "version": "1.4.0", "version_code": 49, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7620112998117225"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1720009026, "id": "7550057498456109", "version": "1.4.0", "version_code": 48, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7620112998117225"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1283573515524542"}]}, "change_log": "[New Feature] Added ability to dress up the player with different cosmetic options.\n[New Feature] Added 20 findable cosmetics, one hidden in each level.\n[New Feature] Players' mouths now move to match your voice in multiplayer.\n[Improvement] Enhanced in-game UI interaction: you can now point and shoot at buttons within a certain area, in addition to physically clicking them.\n[Improvement] Rearranged the main menu buttons to reduce clutter.", "created_date": 1716976441, "id": "7376068655854995", "version": "1.3.0", "version_code": 47, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5632444056884139", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7620112998117225"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1716548886, "id": "7353661471429047", "version": "1.3.0", "version_code": 46, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}