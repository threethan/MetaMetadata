sid=6e7a0a&_nc_ohc=mkDDYMjXRYsQ7kNvgF2aJ9i&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWPE00JJ2D9MViaHQ1czd0C8jiCTzAk6sMUZz_Sy8j9A&oe=6713A3EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Swivel_Creative_Landscape.png", "id": "782721247326589", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/427384304_782721250659922_2238916620449805730_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrreqtO2jX4Q7kNvgFa_21_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA48MX9yxmGEgUGu4_5rBts9NDuInnxq4wHjZAYhS_pUA&oe=6713A2FD"}, "display_name": "Swivel", "keywords": ["spin", "ride", "rhythmic", "fitness", "seated"], "long_description": "Swivel is a VR ride through outer space that's jam-packed with music, movement, and excitement.\n\nIn this first-of-its-kind outer space experience, you swivel your way down a cosmic track straight to the dance floor. \n\nWhile you\u2019re swiveling, get ready for a hands-on party - drumming, popping bubbles, opening doors, high-fiving aliens, and collecting music notes.\n\nThe beats? Crafted by the legendary Barry Leitch, these tunes groove with the story and your every move. There are 8 tracks, each with its own style:\n- Fly - pop\n- Love me and leave me- 50s soul\n- Sweet tooth - pop dance\n- Sputnik - dubstep\n- Spin - light metal\n- Winter - classical\n- Wally Beben - retro\n- Ennio Morricone - western\n\nSome rides are swivel-heavy, so be prepared for some serious spinning action. And guess what? There are also secret paths to up the fun factor!\n\n\u2013 Important note \u2013\nPlease take your time easing into the game. After a few days of play, our bodies adjust, and spinning becomes incredibly enjoyable \u2013 it's like tapping into our inner child. \n\n\u2013 Seated game with a minimum play space of 6.5 feet by 6.5 feet \u2013\nSwivel is a seated game that involves turning and making cool moves. Ensure you have at least 3.3ft (1m) of space in all directions.\n\nWe recommend using a \u2018swivel\u2019 chair to make those tricky turns a blast!", "short_description": "Swivel is a VR ride through outer space that's jam-packed with music, movement, and excitement."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.swivelvr.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Dimensional Dilemma", "support_website_url": "https://www.swivelvr.com/contact-us", "website_url": "http://www.swivelvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7774007276038100"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031360_1572910846960835_8224561559878044455_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PI3O7t354xsQ7kNvgHcklCa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvYwGBEaK4jZFYeJGASe9XEN-PaXxmxB3GTxK8gbdb9A&oe=67139138"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Swivel", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1717102740, "lastRevision": {"nodes": [{"id": "7277099832395516", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"