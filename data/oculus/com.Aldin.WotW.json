63265210565748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974616_555608881893659_4295527827886833664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ON_Zk0VZt4Q7kNvgG_DfPG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAT-hNQU7rYkFyp_ELELHdE37o7RIJCgbtzESA-nfO74w&oe=66D066AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/yqePnq", "id": "2144472652514970", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036684_2144472659181636_6421205896860270592_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ciqTDJ2T5BwQ7kNvgFN41NG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCR52b7nLvwZWYIFQxptLUsGD-oXTm3xJqkO6tswd5aGg&oe=66D044D2"}, "display_name": "Waltz of the Wizard: Extended Edition", "keywords": ["Magic", "Wizard", "Waltz", "Introduction", "Fantasy"], "long_description": "Waltz of the Wizard is a joy-filled introduction to VR that anyone can enjoy and a sampler dish of things that make VR unique! Feel what it\u2019s like to have magical powers in this remaster of the original that introduces more spells, interactions and secrets. \n\nCast creative and diverse spells in a fully interactive world, discovering the many details of a world designed to feel real. Combine arcane ingredients into a boiling cauldron with the help of an ancient spirit trapped in a human skull. Travel to new places, finding yourself in mysterious circumstances full of detail and unforgettable atmosphere.\n\n\nFeature Overview\n\n- Brew magical spells & wield creative powers\n- Defeat guards & dodge traps in a labyrinth\n- Interact with strange artifacts & fun objects\n- Play minigames & collect trophies\n- Travel to new places & experience strange situations\n- Discover easter eggs & surprising details", "short_description": "Feel what it\u2019s like to have magical powers! One of the highest rated PC VR experiences comes to Quest in this remaster of the beloved original. Combine arcane ingredients into a boiling cauldron with the help of an ancient talking skull, unleashing diverse wizardry upon a fully interactive and mysterious world."}]}, "developer_name": "Aldin Dynamics", "developer_privacy_policy_url": "https://www.aldin.io/product/privacy-policy.html", "developer_terms_of_service_url": "http://aldindynamics.com/product/wotw-eula.html", "publisher_name": "Aldin Dynamics", "support_website_url": null, "website_url": "http://aldin.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "644450513424858"}}]}, "scheduled_offers": {"count": 43, "nodes": [{"status": "PUBLISHED", "id": "6057361371054451"}, {"status": "PUBLISHED", "id": "687387592777675"}, {"status": "PUBLISHED", "id": "1296714654255149"}, {"status": "PUBLISHED", "id": "1307658566407071"}, {"status": "PUBLISHED", "id": "1308553173117185"}, {"status": "PUBLISHED", "id": "164865822512856"}, {"status": "PENDING", "id": "1985195891814468"}, {"status": "PUBLISHED", "id": "1097337894581239"}, {"status": "PUBLISHED", "id": "549841339197681"}, {"status": "PENDING", "id": "1188098561890739"}, {"status": "PUBLISHED", "id": "558068196455537"}, {"status": "PENDING", "id": "959849062041209"}, {"status": "PUBLISHED", "id": "3080831242222360"}, {"status": "PUBLISHED", "id": "583581436559289"}, {"status": "PENDING", "id": "3454213631530723"}, {"status": "PUBLISHED", "id": "601065964914867"}, {"status": "PUBLISHED", "id": "1559355241128814"}, {"status": "PENDING", "id": "1298558860772122"}, {"status": "CANCELLE