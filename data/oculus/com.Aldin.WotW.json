jEJTOd9IwcA&oe=66D053A5"}]}, "id": "3603773153285578", "locale": "en_US", "screenshots": [{"file_name": "Waltz-Screenshot-4.png", "id": "162133720088569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031532_162133723421902_5993496590922768435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zTF8ftPpjVoQ7kNvgHy9ET7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsBPTgbWWQ94CZrF4T3B8S99JxZdtFheY7JgAxf1M51A&oe=66D05085"}, {"file_name": "Waltz-MR-Mode.png", "id": "857848819273862", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974682_857848822607195_5148366601685990616_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A-5dxkcaKDoQ7kNvgHsJ0zq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAL2WnOXilfxwnF1mvzQU0FgnFNVnVAqrJk-SonmnGkFw&oe=66D05957"}, {"file_name": "Waltz-Screenshot-1.png", "id": "892243278522184", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031327_892243281855517_8970003212715503257_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Q3EMK5RS40Q7kNvgE6Yj7y&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEIKzqr8WmsCu7_6Rw0pIAmDMOhHZqAQEA-D89JQTwyg&oe=66D0527F"}, {"file_name": "Waltz-PSVR2-Shot-09.png", "id": "875665124237907", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86625128_875665127571240_341626551024734121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pYcqVzHYAWUQ7kNvgHpUgMQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAf4-HdJAmemM6i_9k_7dwC5bNb9g9-bxxTEf4vxGdKQw&oe=66D06BD3"}, {"file_name": "Skully-Screenshit.png", "id": "331656419814996", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75481463_331656423148329_1180331378494948372_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zN65mH9xj5sQ7kNvgEZvmkY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoml7PKD2Zq2F2hZ63UdxGR5DecEnaiOBS_tMEPOt04w&oe=66D05F66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Waltz-Title-Landscape-Skully.png", "id": "1141617140388603", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031518_1141617143721936_9196013257287080443_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QzqoYi_ZfWoQ7kNvgGcKzbe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRxXTC7j_NIqHRKMST7mrdTHS-GoqkDcv97g2svMr_pw&oe=66D05E47"}, "display_name": "Waltz of the Wizard", "keywords": ["Voice", "Waltz", "handtracking", "Sim", "Skully"], "long_description": "\ud83c\udfc6 Winner of Best Updated Game - UploadVR\n\ud83c\udfc6 Winner of Best Innovation - NYX Game Awards\n\nExperience awesome magical powers in a world inspired by the atmosphere of classic fantasy fiction! Combine arcane ingredients into a boiling cauldron with the help of your torturable skull assistant\u2014the most interactive character you can find in VR\u2014embarking on an adventure in an absurdly interactive and mysterious world.\n\n\u2b50\ufe0f \u201cAldin helped pioneer VR as we know it today\u201d - Road to VR\n\u2b50\ufe0f \u201cVR already has some exceptionally well-received games, like Waltz of the Wizard\u201d - Rolling Stone Magazine\n\n**Highlight features**\n- Cutting-edge voice, eyes- and gesture interaction abilities\n- Large campaign with storyline, combat and challenges\n- Hundreds of voice interactions (English)\n- Infinite level generation mode for endless fun\n- Eye-tracking interactions with characters and magic (Meta Quest Pro Only)\n- MR Sandbox mode (Meta Quest 3 and Meta Quest Pro Only)\n- Torture your skull assistant, imagination is the only limit", "short_description": "Experience awesome magical powers in a world inspired by the atmosphere of classic fantasy fiction! Combine arcane ingredients into a boiling cauldron with the help of your torturable skull assistant, embarking on an adventure in an absurdly interactive and mysterious world."}]}, "developer_name": "Aldin", "developer_privacy_policy_url": "https://www.aldin.io/privacy-policy", "developer_terms_of_service_url": "https://www.aldin.io/terms-of-use", "publisher_name": "Aldin", "support_website_url": "https://www.waltzofthewizard.com/", "website_url": "http://aldin.io/", "category": "GAMES", "comfo