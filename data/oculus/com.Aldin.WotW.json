//scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556795_452502455469654_5887180014146813952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NHLreBzD1rsQ7kNvgEkST9S&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQ1Av9xrcljVTjTX-2gBjWXtOtTWN9Wd2UJFbw1kN9nA&oe=677F9DE1"}, {"file_name": "migrated_image.png", "id": "633592770773286", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974792_2638462666214036_1337175541475704832_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYMozUbgLBUQ7kNvgHc1wSu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnzFm6ntZozjzQ-wovYynGmpObWoT14Hrp4g-BXlt_qw&oe=677FC04C"}, {"file_name": "migrated_image.png", "id": "537881150482714", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974535_2588653668031688_6222245475358081024_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7YXnFa0sbSgQ7kNvgEQVXWp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8RRYWpcmtTv5k3STzy40_gbmWcC_j8hwF-tnj8zv6tQ&oe=677FAC05"}, {"file_name": "migrated_image.png", "id": "636685530442550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031544_545547256241139_4582153892019568640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CvC8T856vhQQ7kNvgE2baFI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbdbs3BYXihtQQkow3Tpzz7ZNZs8oDUJTMEW5F3ZA60g&oe=677FA511"}, {"file_name": "migrated_image.png", "id": "3163265210565748", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974616_555608881893659_4295527827886833664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Pam5sxzGTcQ7kNvgErl61d&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3VW7Iaww-G9rF4zMcmr3Vz7RcI8X_DQ_wK5m8v7eb3Q&oe=677FBE2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/yqePnq", "id": "2144472652514970", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036684_2144472659181636_6421205896860270592_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d4Hhv8GZSy8Q7kNvgHJ9aqs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5mxkKVSVTfSn229kLjiA3EE_ABjKxIIEwLbbhVdkLyQ&oe=677F9C52"}, "display_name": "Waltz of the Wizard: Extended Edition", "keywords": ["Magic", "Wizard", "Waltz", "Introduction", "Fantasy"], "long_description": "Waltz of the Wizard is a joy-filled introduction to VR that anyone can enjoy and a sampler dish of things that make VR unique! Feel what it\u2019s like to have magical powers in this remaster of the original that introduces more spells, interactions and secrets. \n\nCast creative and diverse spells in a fully interactive world, discovering the many details of a world designed to feel real. Combine arcane ingredients into a boiling cauldron with the help of an ancient spirit trapped in a human skull. Travel to new places, finding yourself in mysterious circumstances full of detail and unforgettable atmosphere.\n\n\nFeature Overview\n\n- Brew magical spells & wield creative powers\n- Defeat guards & dodge traps in a labyrinth\n- Interact with strange artifacts & fun objects\n- Play minigames & collect trophies\n- Travel to new places & experience strange situations\n- Discover easter eggs & surprising details", "short_description": "Feel what it\u2019s like to have magical powers! One of the highest rated PC VR experiences comes to Quest in this remaster of the beloved original. Combine arcane ingredients into a boiling cauldron with the help of an ancient talking skull, unleashing diverse wizardry upon a fully interactive and mysterious world."}]}, "developer_name": "Aldin Dynamics", "developer_privacy_policy_url": "https://www.aldin.io/product/privacy-policy.html", "developer_terms_of_service_url": "http://aldindynamics.com/product/wotw-eula.html", "publisher_name": "Aldin Dynamics", "support_website_url": null, "website_url": "http://aldin.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2