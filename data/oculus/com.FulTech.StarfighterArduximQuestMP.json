0332", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_508447753773665_4491715404484808985_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dxc6KIj6ZxYQ7kNvgHy3KHe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfxMJfN5nqBLzfc4V8CQC1EynG_D3d7MTxIemii_yVHQ&oe=673C61B2"}, {"file_name": "pdp8_2560x1440_2021-05-28_15-34-15.png", "id": "280638297134514", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974654_280638300467847_5559109998864015848_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v6aV3uofOZoQ7kNvgG3ZZBO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDO3uFj4ZJjhjD9VEiIoXJg0HrNqj7ZdU2N0WVJoxKD3A&oe=673C7A6B"}, {"file_name": "screen_2560x1440_2021-07-18_11-37-35.png", "id": "200300765366565", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75307249_200300768699898_5215046548579562888_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D4-mHSinUTIQ7kNvgF7eukY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0oerRH0uYJc6VsvjQgYRSe9sCOI_E58E_M785keeHlQ&oe=673C7531"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pdp8_2560x1440_2021-06-06_11-56-09.png", "id": "2573647642929739", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974750_2573647646263072_5000227285301093937_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c4V-XmHFi3wQ7kNvgGVtfXz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7gEtDx3to_eWKVJWSNqsbZleATXWwqklY-LKA_HaKvQ&oe=673C79B7"}, "display_name": "Starfighter Arduxim Multiplayer", "keywords": [], "long_description": "Strap into the cockpit of your starfighter and take on enemy starships in this first-person tactical space shooter. Fight as part of a team alongside your friends or in free for all battle. Features multiple game modes, ships and weapon load-outs.\n\nControl your ship using Touch controllers, a gamepad, or hand tracking. Players can use the thumb sticks on a physical controller, or for a more immersive experience grab virtual cockpit controls using the Touch controllers or your bare hands.\n\nThe multiplayer of Starfighter Arduxim is free to play and has no micro-transactions or ads.\n\nThe full version available separately includes:\n* A fourteen mission story based campaign covering your first tour of duty on the front lines\n* Practice mode\n* Survival/horde challenge mode with online leader board", "short_description": "Strap into the cockpit of your starfighter and take on enemy starships in this first-person tactical space shooter. Fight as part of a team alongside your friends or in free for all battle. Features multiple game modes, ships and weapon load-outs.\n\nThe multiplayer of Starfighter Arduxim is free to play and has no micro-transactions or ads."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fulby.tech/privacy-policy", "developer_terms_of_service_url": "https://s3.amazonaws.com/arduxim.com/terms.txt", "publisher_name": "Fulby Technologies", "support_website_url": "https://www.reddit.com/r/arduxim/", "website_url": "https://fulby.tech/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SIMULATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7382621805137440"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003229_802927037283902_805371286427412781_n.png