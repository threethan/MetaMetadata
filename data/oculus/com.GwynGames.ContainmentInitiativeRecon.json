43657019808088_2486947651465581524_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7GnRhDvDckQQ7kNvgG76TtE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcN_OiSqbi-aYzAbnmoT_ONIzUt0jsYdvco5mGua2OiA&oe=671E4083"}, {"file_name": "CIRecon_SS_3 2560x1440.png", "id": "610435117841403", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035361_610435121174736_7614005424375505611_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2vc5_i7qAzEQ7kNvgHXflL9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiMOhljNkHjnRas6goeSVZXTpThiiWejA8aCL2sdZ5Jg&oe=671E3D8F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CIRecon_SS_5 2560x1440.png", "id": "120405504445546", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75339313_120405507778879_6926521371564161931_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LbhNV14P7wAQ7kNvgHKkXOX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOWrxtbf2i4JOmWM4h5Ma9vWZKg_HZ-eFrTT4wi-ZYtw&oe=671E1D87"}, "display_name": "Containment Initiative: Recon", "keywords": [], "long_description": "Containment Initiative: Recon is a singleplayer version of Containment Initiative designed for standalone headsets.\n\nRealistic Reloading:\nEach weapon handles and reloads just like it's real world counterpart. Mastering reloading is essential to surviving the horde!\n\nProgression:\nRobust progression system which includes: Unlockable guns, attachments, player upgrades, and more.\n\nMission Types:\nCollect supply crates, defend objectives, or just try to survive the horde.\n\nLoot:\nFind random drops that include exclusive weapon skins, a new melee weapon, and ammo upgrades\n\nDismemberment/Blood:\nHeadshots trigger a slow motion effect so you can behold the carnage!", "short_description": "Containment Initiative: Recon is a singleplayer version of Containment Initiative designed for standalone headsets. Take on the horde with different mission types, loot to collect, and gear to upgrade!"}]}, "developer