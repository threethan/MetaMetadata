 objectives, or just try to survive the horde.\n\nLoot:\nFind random drops that include exclusive weapon skins, a new melee weapon, and ammo upgrades\n\nDismemberment/Blood:\nHeadshots trigger a slow motion effect so you can behold the carnage!", "short_description": "Containment Initiative: Recon is a singleplayer version of Containment Initiative designed for standalone headsets. Take on the horde with different mission types, loot to collect, and gear to upgrade!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://gwyngames.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gwyn Games LLC", "support_website_url": null, "website_url": "https://gwyngames.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2309937129194063"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "2330408834133384"}, {"status": "PUBLISHED", "id": "1480937792559176"}, {"status": "PUBLISHED", "id": "1671061799985968"}]}, "baseline_offer": {"id": "1671061799985968"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "2330408834133384"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6641345259320176", "version": "1.1"}, "id": "3474821136067709",