&oe=66DEF22D"}, {"file_name": "screen_2560x1440_39.png", "id": "279767181389313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_279767184722646_5660730594527875228_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AEmOyDsHh3sQ7kNvgELgGj3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyLSpyIyqlaWX_NL54Kaklg&oh=00_AYBFHESRLfuE2TWdNDeNgGdcuQDtbirzbw7he9Q3f5TGgw&oe=66DEEAA7"}, {"file_name": "screen_2560x1440_43.png", "id": "810298144144211", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221317_810298147477544_3405637395723102503_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6slFLNc4P-AQ7kNvgE9ejMY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyLSpyIyqlaWX_NL54Kaklg&oh=00_AYAAj03bR5TWyCqwz1n-jrgJ7puJ2mS1-jEmD3gOt3L9JQ&oe=66DEF6DE"}, {"file_name": "screen_2560x1440_44.png", "id": "615351700379095", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_615351703712428_4648422416881523525_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3uN7-BrdaZYQ7kNvgFvBCLq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyLSpyIyqlaWX_NL54Kaklg&oh=00_AYDOC0AZMlZePmtEO_YnBE6EWFQxBta4VZSG7KQcwwSkPQ&oe=66DEE8D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover image.png", "id": "623668253052301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_623668256385634_4968901980199422805_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u-oj5VAPEF8Q7kNvgGWqGDF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyLSpyIyqlaWX_NL54Kaklg&oh=00_AYA8o0DYJmJE2NQ4NFFcC8JE9TWwGoWLPAV-_O3dJXcmYg&oe=66DEE57E"}, "display_name": "Move People", "keywords": [], "long_description": "Play through funny levels which will surely make you burst out laughing and have loads of fun for hours. But not only that, you will also need to use your brain and think carefully to solve tricky puzzles by using your intuition. Every level is individually crafted to present a unique experience in which you move people around by their limbs and throw them around like ragdolls to complete a unique goal and make various poses. With the perfect balance of fun and excitement you'll surely fall in love with this game and the people in it!", "short_description": "Move people by dragging their limbs and perform daily tasks. Embark on an amazing love story and join the couple on a journey to find their true love."}]}, "developer_name": null, "developer_privacy_policy_url": "http://paurau.com/privacy/move-people", "developer_terms_of_service_url": null, "publisher_name": "Pau Rau", "support_website_url": null, "website_url": "http://paurau.com/move-people", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1212550902698744"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "624161043007120"}, {"status": "PUBLISHED", "id": "285673357720359"}]}, "baseline_offer": {"id": "285673357720359"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1688168538, "status": "PUBLISHED", "id": "624161043007120"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6780103498689307", "version": "1.0"}, "id": "1565673523931694", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application