-OR3qPIkg&oe=66FA9A27"}, {"file_name": "screen_2560x1440_43.png", "id": "810298144144211", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221317_810298147477544_3405637395723102503_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tehlf3xEDDwQ7kNvgF-Rn4K&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHZyq6CZ6RvuHxPU1Pv2VInfiik81ftoS7BJS8c0Nxqw&oe=66FAA65E"}, {"file_name": "screen_2560x1440_44.png", "id": "615351700379095", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_615351703712428_4648422416881523525_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJYyfD9rMVMQ7kNvgEUs6mD&_nc_ht=scontent.oculuscdn.com&oh=00_AYB7R83xP_NnpXkpfANJs39yuJvRwydKCg-iFTuPOFvuvw&oe=66FA9852"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover image.png", "id": "623668253052301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_623668256385634_4968901980199422805_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i5y-Z6HDBc8Q7kNvgEN5wbz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYhKqpR6HruL6aQm2DcTrdTtB5k7RsyYoPVtLFkVRQKA&oe=66FA94FE"}, "display_name": "Move People", "keywords": [], "long_description": "Play through funny levels which will surely make you burst out laughing and have loads of fun for hours. But not only that, you will also need to use your brain and think carefully to solve tricky puzzles by using your intuition. Every level is individually crafted to present a unique experience in which you move people around by their limbs and throw them around like ragdolls to complete a unique goal and make various poses. With the perfect balance of fun and excitement you'll surely fall in love with this game and the people in it!", "short_description": "Move people by dragging their limbs and perform daily tasks. Embark on an amazing love story and join the couple on a journey to find their true love."}]}, "developer_name": null, "developer_privacy_policy_url": "http://paurau.com/privacy/move-people", "developer_terms_of_service_url":