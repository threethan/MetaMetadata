e people in it!", "short_description": "Move people by dragging their limbs and perform daily tasks. Embark on an amazing love story and join the couple on a journey to find their true love."}]}, "developer_name": null, "developer_privacy_policy_url": "http://paurau.com/privacy/move-people", "developer_terms_of_service_url": null, "publisher_name": "Pau Rau", "support_website_url": null, "website_url": "http://paurau.com/move-people", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1212550902698744"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "624161043007120"}, {"status": "PUBLISHED", "id": "285673357720359"}]}, "baseline_offer": {"id": "285673357720359"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1688168538, "status": "PUBLISHED", "id": "624161043007120"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6780103498689307", "version": "1.0"}, "id": "1565673523931694", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6425191017513892", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6780103498689