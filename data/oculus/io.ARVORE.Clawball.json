": "1119601926261672", "locale": "en_US", "screenshots": [{"file_name": "1920x1080_match-clawball.png", "id": "1071640811342027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003280_1071640814675360_2728197951705023524_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q9v76PKRu38Q7kNvgHqvYTp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAtU21fkPGiydxGymzZtCaU4V2yTM4aJszFG544LYTvg&oe=6720B8FC"}, {"file_name": "Pawball-screenshot-02.png", "id": "1938554669943120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395422_1938554673276453_7839164733116974146_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K-HgAt8bTJwQ7kNvgGwHeg6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgPweZONDl5K4W_RWrnpCmEUtSjUKNj7Srsq8ZnFv0og&oe=6720D435"}, {"file_name": "Pawball-screenshot-04.png", "id": "810901784569926", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974751_810901787903259_7724923915755363401_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FFS2YLSOXnQQ7kNvgH4ejsj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB16NaYNIbAMfrAuVPWiqkJbAmnt0DLaZFYcYWqAeOy-w&oe=6720BA7C"}, {"file_name": "Pawball-screenshots-05.png", "id": "483914511262040", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031325_483914514595373_5640665213809509177_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5CJsNSYVJ1kQ7kNvgE7HxX0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnOojdAEOQ25ZnkT2K7vmtXv_5ry_UJxN2uiJAqwqxzA&oe=6720E6DC"}, {"file_name": "1920x1080_training-clawball.png", "id": "1241505176887057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003283_1241505180220390_4263321879792757472_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pflvwFmud3kQ7kNvgHqdFH-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyI2omdK8Im1vxnTr_tOTdb8zzK0_aOJR7ZD4odVukqw&oe=6720B7A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Clawball-video-cover.png", "id": "1048957033519157", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035471_1048957036852490_2684877143045225821_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7QEhkN01RswQ7kNvgHiOqe9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaYi5fdpZxxvpYWC6kATRTYNE-q8PCygj_r4BKKg9kRw&oe=6720CF75"}, "display_name": "Clawball", "keywords": ["Multiplayer", "Free", "Gorilla", "Soccer", "New"], "long_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive\nYou gotta be quick and strategic to get that sweet score at the end of each match. Being a goalie or a striker, a domestic or an alley cat, in Clawball the main objective is always to have fun!\n- Social interactions at its finest! Play in the lobby to meet other players alike\n- 3v3 online matches\n- Amazing in-match physics\n- Highly customizable character\n- Tons of cosmetics\n\nNo bounds to having fun! You are free to run, climb, and claw your way to victory!\nEasy to share! Stream your Clawball matches everywhere!\n\n{1019937909816095}\n\n{1063884701863486}", "short_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive"}]}, "developer_name": null, "developer_privacy_policy_url": "https://arvore.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE", "support_website_url": null, "website_url": "https