=scontent-iad3-2.oculuscdn.com&oh=00_AYDtLCum8ZsPwrL8faS73f_deQ9dswkqYzI8AwV8yYkVdA&oe=676545A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Clawball-video-cover.png", "id": "1048957033519157", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035471_1048957036852490_2684877143045225821_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QirfMSgayYUQ7kNvgG7u-Fj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNTYIDdbj2Sr5VppYroYxkzyuFNG9mEX_KPwro1RRBVA&oe=67655D75"}, "display_name": "Clawball", "keywords": ["Multiplayer", "Free", "Gorilla", "Soccer", "New"], "long_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive\nYou gotta be quick and strategic to get that sweet score at the end of each match. Being a goalie or a striker, a domestic or an alley cat, in Clawball the main objective is always to have fun!\n- Social interactions at its finest! Play in the lobby to meet other players alike\n- 3v3 online matches\n- Amazing in-match physics\n- Highly customizable character\n- Tons of cosmetics\n\nNo bounds to having fun! You are free to run, climb, and claw your way to victory!\nEasy to share! Stream your Clawball matches everywhere!\n\n{1019937909816095}\n\n{1063884701863486}", "short_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive"}]}, "developer_name": null, "developer_privacy_policy_url": "https://arvore.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE", "support_website_url": null, "website_url": "https://www.clawball.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8359078434140017"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1477225262936300"}]}, "baseline_offer": {"id": "1477225262936300"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729182720, "status": "PUBLISHED", "id": "1477225262936300"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8658379520876572", "version": "1.0"}, "id": "2880848675405903", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7890078401040025", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8658379520876572"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2880848675405903"}]}, "change_log": "* DOUBLE XP\nAs a Christmas gift to all our amazing players, we\u2019re giving you DOUBLE XP until December 19th! We know many of you joined late in the season, so this is your chance to level up quickly and grab those rewards before the season ends. Once they\u2019re gone, they\u2019re gone for good! Don\u2019t miss out!\n\n* Holiday Cheer:\nFestive Christmas decorations have arrived!\n\n* New Fun in the Lobby:\nThe piano is working\u2014play some tunes with your friends!\nCheck out the bell hoops to test your jumping skills!\n\n* Fixes and Optimizations:\nPerformance Improvement in the lobby and during matches.\nFixed a funny bug where the music stopped if the ball hit the cat litter box. Oops!\n\n", "created_date": 1733409809, "id": "8658379520876572", "version": "1.0", "version_code": 275, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7890078401040025", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8658379520876572"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2880848675405903"}]}, "change_log": "New Experimental Feature\n* Now you can pick your team in the Pause Menu\n\nBug Fixes\n* Accessories (like cool hats or glasses) now show up when you\u2019re outside your home!\n* The ball won\u2019t go through the floor when it hits the goalie anymore.\n* The ball won\u2019t start flying off in weird directions at the start.\n* We fixed some crashes so the game runs smoother!\n\nMeows\n* A lot of meows in this update!", "created_date": 1731945768, "id": "8567558393292019", "version": "1.0", "version_code": 254, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7890078401040025", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8658379520876572"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730819049, "id": "8490612490986610", "version": "1.0", "version_code": 206, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7890078401040025", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8658379520876572"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2880848675405903"}]}, "change_log": "* Snap Turn On/Off\n* 1x1 matches now available\n* UI feedbacks\n* Bugs fixes", "created_date": 1729799433, "id": "8413347705379756", "version": "1.0", "version_code": 201, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7890078401040025", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8658379520876572"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2880848675405903"}]}, "change_log": null, "created_date": 1729181854, "id": "8