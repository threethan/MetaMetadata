138_293764187227794854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WvKd3i8O3iwQ7kNvgFWydtv&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBP8IW2WRPOWJumTcVF0x2vLX7EO4XhrTl00RjQY66eyA&oe=675190BE"}, {"file_name": "2560x1440_claws.png", "id": "1289603338869543", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035348_1289603342202876_8512166377963726278_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-gKkrGPnU4Q7kNvgG9hQiT&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYARAD768XR4clXvLT1krQ54B8UsxrUz-ZfIwKE5gD2IVg&oe=6751AC60"}, {"file_name": "2560x1440_lobby.png", "id": "1124194295968823", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974594_1124194299302156_5278838258993128423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8P1kIRI8TeQQ7kNvgGCMQTV&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDRZqqC1qX_OHisNGwrVQMLr81CQZyA06MEbFfujiPUcA&oe=675197E4"}, {"file_name": "2560x1440_training.png", "id": "412983995193415", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57566688_412983998526748_1700669121290146253_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cQkDscbizfYQ7kNvgH00M_6&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDLtZsThtmJyGCYib_TNHBOOUXIsDBaqUYYIt2DMadKMQ&oe=67517B45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Clawball-CoverImageLandscape.png", "id": "554437637373399", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39036686_554437640706732_4968152864562549401_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPxo7oxGu2YQ7kNvgHLmhHl&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDnwEFIP1MTbsugifSRR4vdA5_FR302-pmruBilw1e7Ww&oe=67517E59"}, "display_name": "Clawball", "keywords": ["Multiplayer", "Free", "Soccer", "New", "Cat"], "long_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive\nYou gotta be quick and strategic to get that sweet score at the end of each match. Being a goalie or a striker, a domestic or an alley cat, in Clawball the main objective is always to have fun!\n- Social interactions at its finest! Play in the lobby to meet other players alike\n- 3v3 online matches\n- Amazing in-match physics\n- Highly customizable character\n- Tons of cosmetics\n\nNo bounds to having fun! You are free to run, climb, and claw your way to victory!\nEasy to share! Stream your Clawball matches everywhere!\n\n{1019937909816095}\n\n{1063884701863486}", "short_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive"}]}, "developer_name": "ARVORE", "developer_privacy_policy_url": "https://arvore.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE IMMERSIVE GAMES INC.", "support_website_url": null, "website_url": "https://www.clawball.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_pr