138_293764187227794854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nJzydzfRsWAQ7kNvgGM3q7V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_S2wYpFoHJ9Ld5dIjCpj7tN93TdLb9JhdemrNkb0Bzw&oe=6765573E"}, {"file_name": "2560x1440_claws.png", "id": "1289603338869543", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035348_1289603342202876_8512166377963726278_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UgrL2iNpyacQ7kNvgH0pAJY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4IhC3_26aiVOTjDqZir7HH3G3NbCJRKy_SsQIAN3c6g&oe=676572E0"}, {"file_name": "2560x1440_lobby.png", "id": "1124194295968823", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974594_1124194299302156_5278838258993128423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWICwh5QkMAQ7kNvgF2Gi4t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkavA4RvQWZcPwsRv3N8IiRxYW7EhdLPsH4xXhpk-7Zg&oe=67655E64"}, {"file_name": "2560x1440_training.png", "id": "412983995193415", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566688_412983998526748_1700669121290146253_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DElFPYkNkqwQ7kNvgH67PpA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1kiMLq4rXv8RxlWyuw0vewXUEDXPIB_7oRMgYzZnEIg&oe=676541C5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Clawball-CoverImageLandscape.png", "id": "554437637373399", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036686_554437640706732_4968152864562549401_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hzIf_2WJ3tEQ7kNvgHlDY6t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXX7DoxdZInf3vRD9Jstuy2IAlJnGJvf3iU0T84TU-Mw&oe=676544D9"}, "display_name": "Clawball", "keywords": ["Multiplayer", "Free", "Soccer", "New", "Cat"], "long_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive\nYou gotta be quick and strategic to get that sweet score at the end of each match. Being a goalie or a striker, a domestic or an alley cat, in Clawball the main objective is always to have fun!\n- Social interactions at its finest! Play in the lobby to meet other players alike\n- 3v3 online matches\n- Amazing in-match physics\n- Highly customizable character\n- Tons of cosmetics\n\nNo bounds to having fun! You are free to run, climb, and claw your way to victory!\nEasy to share! Stream your Clawball matches everywhere!\n\n{1019937909816095}\n\n{1063884701863486}", "short_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive"}]}, "developer_name": "ARVORE", "developer_privacy_policy_url": "https://arvore.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE IMMERSIVE GAMES INC.", "support_website_url": null, "website_url": "https://www.clawball.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_pro