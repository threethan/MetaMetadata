7kNvgEqqTzU&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBoh4jOH8jYyzm8DSVdKy6DqJe0-0KLOsGLPprTTmoawg&oe=6724BDBE"}, {"file_name": "2560x1440_claws.png", "id": "1289603338869543", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035348_1289603342202876_8512166377963726278_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TXEGnem2PeEQ7kNvgFIng3V&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDhyaLVQtxoA15arN3zPgFr_SwyEQyrgLeP-iP-NEVR0A&oe=6724D960"}, {"file_name": "2560x1440_lobby.png", "id": "1124194295968823", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974594_1124194299302156_5278838258993128423_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n6ofTbjk5AcQ7kNvgFN46Yz&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB6Q4YdR6nxYA7aHuqa4-X1wQcoO2GIGIvJ15EAlIfv2Q&oe=6724C4E4"}, {"file_name": "2560x1440_training.png", "id": "412983995193415", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566688_412983998526748_1700669121290146253_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6laF3w9TBQQ7kNvgFSxJ1x&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC4Lhb6jd-GWkivXj3xOVNCpy0tFUcLnNZE9tWfhAHmJA&oe=6724A845"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Clawball-video-cover.png", "id": "1048957033519157", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035471_1048957036852490_2684877143045225821_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aQRVhlyjZjkQ7kNvgFq_Srt&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAtpqpai_PzkJorUy5QIGcp5N8h2kPdf49Pi99aKT5naA&oe=6724C3F5"}, "display_name": "Clawball", "keywords": ["Multiplayer", "Free", "Soccer", "New", "Cat"], "long_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive\nYou gotta be quick and strategic to get that sweet score at the end of each match. Being a goalie or a striker, a domestic or an alley cat, in Clawball the main objective is always to have fun!\n- Social interactions at its finest! Play in the lobby to meet other players alike\n- 3v3 online matches\n- Amazing in-match physics\n- Highly customizable character\n- Tons of cosmetics\n\nNo bounds to having fun! You are free to run, climb, and claw your way to victory!\nEasy to share! Stream your Clawball matches everywhere!\n\n{1019937909816095}\n\n{1063884701863486}", "short_description": "Ever wondered how it would be to become a cat and play in frenetic soccer matches? Well, now you have!\n\nIn Clawball, you step into the paws of a soccer-playing cat. Move your hands and push off the ground to run, jump, and maneuver just like a real cat. Invite your friends and come hang out in this exhilarating VR social multiplayer experience! Developed by the creators of the Pixel Ripped Franchise ARVORE Immersive"}]}, "developer_name": null, "developer_privacy_policy_url": "https://arvore.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE", "support_website_url": null, "website_url": "https://www.clawball.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SPORTS", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_