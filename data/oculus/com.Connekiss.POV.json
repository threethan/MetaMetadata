ntent.oculuscdn.com/v/t64.5771-25/39031425_1237658017052887_1764234400149201833_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jL_TUWDHqKkQ7kNvgH6AlGJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCleOuAvYB7VR3__M2wiLpPqYOs5qhavBT_wXCjY_lH1g&oe=66F7F1E0"}, {"file_name": "POV_2560x1440_20220909131325.png", "id": "451495357032980", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566682_451495360366313_4657701678887731149_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MT8PBMfjcZUQ7kNvgHBOO15&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0QU0bzsrckJ2Yej15ff_sTm57fSEpJNYmy-Ys3GRL6Q&oe=66F7DC00"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "POV_\u6a2a\u9577\u30ab\u30d0\u30fc.png", "id": "1158791631724766", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974629_1158791635058099_1538718814688576676_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tw_QAuMg8LUQ7kNvgEQ9eC9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGK3HJUNYjUYRq86wIvqyVnKVHgRDKQy_q4OLokQWlHg&oe=66F7EC7A"}, "display_name": "POV", "keywords": [], "long_description": "Watching live-action 360 video in the POV brings you a special experience\nThe POV is a \"multi-viewpoint VR visual experience\"\n\nUsing the controller to shoot a cube floating in space, your perspective shifts instantly\nYou can move freely between multiple viewpoints\n\nChanging the visual effect, you can enjoy a new visual expression\n\nThe POV can be downloaded for free\n\nLive performance 360 videos are also available for free download and watching!\n\n\nThe POV is an evolution of immersive visual experience.\nThe 360 video is recorded simultaneously by multiple 360 cameras. Viewers can freely move their viewpoints with the controller. You can watch the musicians and performers from anywhere you like. You can experience the same performance over and over again in a fresh way.\nIt's not just immersive like you're there, but you're able to manipulate the visual space yourself. That\u2019s POV!", "short_description": "Watching live-action 360 video in the POV brings you a special experience\nThe POV is a \"multi-viewpoint VR visual experience\"\n\nUsing the controller to shoot a cube floating in space, your perspective shifts instantly\nYou can move freely between multiple viewpoints\n\nChanging the visual effect, you can enjoy a new visual expression\n\nThe POV can be downloaded for free\n\nLive performance 360 videos are also available for free download and watching!"}, {"images": {"nodes": [{"file_name": "POV_\u6a2a\u9577\u30ab\u30d0\u30fc_\u30df\u30cb\u30b5\u30a4\u30ba.png", "id": "3292183281063618", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250455_3292183284396951_1493052847931319548_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QLQlUYwApZYQ7kNvgGm78Bk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmN3DOIoZmZyeybFnjzzXmvU4oGXp8fJaa_L2KPVrreA&oe=66F7FE2C"}, {"file_name": "POV_\u30d2\u30fc\u30ed\u30fc\u30ab\u30d0\u30fc.png", "id": "1241159566427182", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_1241159569760515_8508840820940686062_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ohc22kd7XMQ7kNvgEQe28w&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFhKjxLUZyWweklkMEUfpgpaXu0zDuZfJJbNypGEaNGQ&oe=66F7DEE0"}, {"file_name": "POV_\u6a2a\u9577\u30ab\u30d0\u30fc.png", "id": "1209743122922236", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227814956_1209743126255569_7621081603967209564_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kjjwPaQS1wEQ7kNvgFNe_EH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBj_VHlR9au9HOLmwKpttl0u3iWIbzBtBqnNRM1I8_GeA&oe=66F7EA13"}, {"file_name": "POV_\u6b63\u65b9\u5f62\u30ab\u30d0\u30fc.png", "id": "794628851789063", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210391_794628855122396_2730309623003180851_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-f2kXNUZ1WYQ7kNvgF5Q9Nq&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_6lUfkVmpcIMZhv2sCIOz8Wh3rTz0gHSUTkXYS48s6A&oe=66F80019"}, {"file_name": "POV_\u30a2\u30a4\u30b3\u30f3.png", "id": "652539683049691", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566696_652539686383024_997386192901674421_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SNaDF1ti97EQ7kNvgGxhtE7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWbPdBISAleQz6Ux43wB8kiY-NXMnjP1Q7EprMs3msJA&oe=66F7FB79"}, {"file_name": "POV_\u7e26\u9577\u30ab\u30d0\u30fc.png", "id": "474257814358249", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031605_474257817691582_793102264243398845_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qVhYwKWrAy0Q7kNvgEENPij&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_U8s1Bp9Og9GyBDX2Nhchefe77vKNuJsH4wKe-JAvZQ&oe=66F7D383"}, {"file_name": "POV_\u30ed\u30b4_\u900f\u660e.png", "id": "458149736364648", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982476_458149739697981_7695621301760305320_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zuEm9fjMeNIQ7kNvgG3YtBT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOaXgGkCSJ9bi3-ufSKMsNweK8-oGvEs9lAYHI1tmVlQ&oe=66F7EDEA"}]}, "id": "782161486446522", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "POV", "keywords": [], "long_description": "\u591a\u8996\u70b9VR\u6620\u50cf\u4f53\u9a13\u300ePOV\u300f\n\n\u30fb\u300ePOV\u300f\u306f\u3001\u8907\u6570\u8996\u70b9\u3092\u79fb\u52d5\u3057\u306a\u304c\u3089\u6620\u50cf\u3092\u4f53\u9a13\u3067\u304d\u308b\u300c\u591a\u8996\u70b9VR\u6620\u50cf\u4f53\u9a13\u300d\u3067\u3059\n\u30fb\u8996\u8074\u8005\u306f\u3001MV\u3084\u30e9\u30a4\u30d6\u6620\u50cf\u306a\u3069\u3092\u597d\u307f\u306e\u8996\u70b9\u304b\u3089\u30c0\u30a4\u30ca\u30df\u30c3\u30af\u306b\u8996\u8074\u3067\u304d\u307e\u3059\n\u30fb\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u3067\u7a7a\u9593\u306b\u6d6e\u304b\u3076\u30ad\u30e5\u30fc\u30d6\u3092\u6483\u3064\u3068\u3001\u8996\u70b9\u304c\u77ac\u6642\u306b\u79fb\u52d5\u3057\u307e\u3059\n\u30fb\u30d3\u30b8\u30e5\u30a2\u30eb\u30a8\u30d5\u30a7\u30af\u30c8\u3092\u9078\u629e\u3059\u308b\u3053\u3068\u306b\u3088\u308a\u3001\u6620\u50cf\u306e\u5909\u5316\u3092\u697d\u3057\u3081\u307e\u3059\n\u30fb\u300ePOV\u300f\u306f\u7121\u6599\u3067\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3067\u304d\u307e\u3059\n\u30fb\u30b3\u30f3\u30c6\u30f3\u30c4\u3082\u7121\u6599\u3067\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3001\u8996\u8074\u3067\u304d\u307e\u3059\n\n\u5168\u5929\u7403360\u5ea6\u6620\u50cf\u306f\u3001\u8996\u8074\u8005\u306b2D\u30b9\u30af\u30ea\u30fc\u30f3\u3068\u306f\u7570\u306a\u308b\u3059\u3070\u3089\u3057\u3044\u4f53\u9a13\u3092\u3082\u305f\u3089\u3057\u307e\u3059\u3002\n\u300ePOV\u300f\u306f\u5168\u5929\u7403360\u5ea6\u6620\u50cf\u4f53\u9a13\u3092\u9032\u5316\u3055\u305b\u3001\u8907\u6570\u306e\u5168\u5929\u7403360\u5ea6\u30ab\u30e1\u30e9\u3067\u540c\u6642\u53ce\u9332\u3055\u308c\u305f\u6620\u50cf\u3092\u7528\u3044\u307e\u3059\u3002\n\u8996\u8074\u8005\u306f\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u306b\u3088\u3063\u3066\u81ea\u7531\u81ea\u5728\u306b\u8996\u70b9\u3092\u79fb\u52d5\u3067\u304d\u307e\u3059\u3002\n\u3059\u306a\u308f\u3061\u3001\u597d\u304d\u306a\u3068\u3053\u308d\u304b\u3089\u30df\u30e5\u30fc\u30b8\u30b7\u30e3\u30f3\u30fb\u30d1\u30d5\u30a9\u30fc\u30de\u30fc\u3092\u898b\u308b\u3053\u3068\u304c\u3067\u304d\u308b\u306e\u3067\u3059\u3002\n\u898b\u308b\u8996\u70b9\u3092\u5909\u3048\u308b\u3053\u3068\u306b\u3088\u3063\u3066\u3001\u540c\u3058\u30d1\u30d5\u30a9\u30fc\u30de\u30f3\u30b9\u3092\u4f55\u5ea6\u3067\u3082\u65b0\u9bae\u306b\u5473\u308f\u3048\u307e\u3059\u3002\n\u3055\u3089\u306b\u3001\u5168\u5929\u7403360\u5ea6\u6620\u50cf\u306b\u30d3\u30b8\u30e5\u30a2\u30eb\u30a8\u30d5\u30a7\u30af\u30c8\u3092\u52a0\u3048\u308b\u3053\u3068\u304c\u3067\u304d\u3001\u30a8\u30e2\u30fc\u30b7\u30e7\u30ca\u30eb\u306a\u6f14\u51fa\u3092\u52a0\u3048\u308b\u3053