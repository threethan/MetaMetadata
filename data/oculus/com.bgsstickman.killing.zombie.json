1.oculuscdn.com/v/t64.5771-25/11162754_128764231130716_668736544110018560_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C6ky1n-d43oQ7kNvgH5vBJ4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCr-e8QPMUH25ESodGaWsvJQHjwtnUul1yf-rm9QFUX9g&oe=67505698"}, {"file_name": "migrated_image.png", "id": "537159623606896", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162763_1752785601692326_8355386720023216128_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IfQteVPJhGIQ7kNvgEQb0H-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC94yC7j2zd_GjJf93XlbRuzD4RQw0g-g_PZl_P2HwGxQ&oe=67504352"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videoPreviewPNG.png", "id": "297704410743099", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162708_297704414076432_3991035219493781504_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k4CbxgtR9_8Q7kNvgH7uiT6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyZOPty6yrtjOqVbqy72ydjxGHc8dLSYIzBtzyr2qUlw&oe=6750330D"}, "display_name": "Stickman Killing Zombies VR", "keywords": ["stickman", "killing", "zombie", "zombies", "sword"], "long_description": "You are a stickman! Shoot and kill the stickmen zombie horde and also other enemy survivor stick figures! Find a gun, and start killing anything that is still walking!  Warning: this game contains lots of blood and fun violence!~ \n \nFeatures\n\n- Post apocalyptic 3D world with zombies\n- Easy controls for running and shooting\n- Physics based ragdoll deaths of stickmen \n- Lots of shooting and killing!\n- Death and blood! \n\n \nMusic:dem0lecule-Global-Mechanization", "short_description": "Kill zombies and stickmen in this 3d stickman shooter game - lots of blood!"}]}, "developer_name": "Iurii Nikshych", "developer_privacy_policy_url": "http://bestgamesstudios.coolpage.biz/privacypolicy.html", "developer_terms_of_service_url": "http://bestgamesstudios.coolpage.biz/privacypolicy.html", "publisher_name": "Best Games Studios", "support_website_url": null, "website_url": "http://bestgamesstudios.coolpage.biz/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "ARCADE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "375761694357596"}, "review_messages": ["", "Hello,\n\nI wanted to provide some feedback, as changes are needed to the assets submitted.\n\nYour hero image needs to have your logo centered on the image.\n\nMore information can be found here: (https://static.oculus.com/documents/oculus-store-art-guidelines.pdf)\n\nPlease reach out to submission@oculus.com for any questions.\n\nBest,\n\nThe Oculus Store Team\n", "Hello,\n\nI wanted to provide some feedback, as changes are needed to the new assets submitted.\n\nYour hero image needs your logo centered on the image with room for bleed areas on either side.\nYour screenshots needs to omit any text.  \n\nMore information can be found [here](https://static.oculus.com/documents/oculus-store-art-guidelines.pdf)\n\nAlso, we feel that the price point of #5.99 is too aggressive. A recommended price of $3.99 or lower will encourage higher adoption rates and reach out to more users.\n\nWe have seen trends in our data showing titles that begin with prices too aggressive cause a permanent negative trajectory to their adoption rates even after a later price drop. Please let us know if a lower price point would be acceptable for you.\n\nOnce we've confirm this information, your app will be ready for launch.  Please let me know if you have any questions.\n\nBest,\n\nThe Oculus Store Team", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162701_1712467718826513_856843690629398528_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ot5UdHmcMvoQ7kNvgGVbHj9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfM8n6Guuj9MoEtWnWtKZuzwIcO6zt3N7Mc_cc4mgFqQ&oe=675044EB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Stickman Killing Zombies VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1516816800, "lastRevision": {"nodes": [{"id": "1517055871710201", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1126549040781694", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "135759617196442"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2616089521832922", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12427636_1522101697885023_970921148747350016_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WEegsrcRi_0Q7kNvgHG_09y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDA82J-b5jeTRPLh6BXO6cI3CHE2Ig6rsZ9LpJdBJl68A&oe=67504D71"}, {"file_name": "migrated_image.png", "id": "2606183156319774", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162741_526112764429440_7218791219332120576_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XS6gUgvrhDIQ7kNvgF5BjJM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAVwzw5W-otTosUg-pfGIisUunomTGIyrYdyG2UBVp4w&oe=67505A1F"}, {"file_name": "migrated_image.png", "id": "888959588225803", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410440_886282171548032_1067191848549744640_n.png?_nc_