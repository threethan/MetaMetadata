GG35u4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5O0_RpfT7XqwXmIZ01pPTQFApSbPhPt68qVN8apztkg&oe=67791907"}, {"file_name": "Virtuoso_Screenshot_2.png", "id": "312516640919414", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210893_312516644252747_4152363525646714910_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xVFHvrNDD6UQ7kNvgFmBQjA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAswFvMnhZBmEHIXlHGi2GNba-T5HNmxFUBeVnIX_1UNw&oe=6779206F"}, {"file_name": "Virtuoso_Screenshot_3.png", "id": "336258848397846", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_336258851731179_7548211804606159018_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LSdCZf5M0dYQ7kNvgG-5GQr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAkmzAD3QpEXD6IKDyRWSPGPp2-VYEfk7gPPIecANFWQ&oe=67790308"}, {"file_name": "Virtuoso_Screenshot_4.png", "id": "328154609239757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86621346_328154612573090_5755737741514283752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5pe9PuMTNcQ7kNvgErXo87&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbTBIDNIRL-yP-Ry5CkrhAMoovwJQf0sqF3YdhCULeOA&oe=677932BC"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZI0YFrS7p4Q7kNvgFuQi61&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1KC0JHGMpfLJg88u-2D8_TksHaDhel53d555Ortc66A&oe=6779091E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementVideo_Thumbnail_Logo_2560x1440.png", "id": "604103097341700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031501_604103100675033_604749419717409359_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xfEPwtdjbD0Q7kNvgGiVDBr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBE3Z4bGe6JRoPSwj2-plAO1raGjFopvItPyKMLAoaUoQ&oe=6779077B"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe six instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_RE