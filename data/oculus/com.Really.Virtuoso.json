reenshots": [{"file_name": "Virtuoso_Screenshot_1.png", "id": "759822828331279", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75542960_759822831664612_8109170244715876266_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZfNwI_n4RWgQ7kNvgHD23e-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCw5eTUbW2XEQPWm5k0KrBlKOyeX5C4xZ0GW8Qocmn_yw&oe=674D9787"}, {"file_name": "Virtuoso_Screenshot_2.png", "id": "312516640919414", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210893_312516644252747_4152363525646714910_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dpv7NUEs4dMQ7kNvgFO9sFi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDipGjMkk_NygY9-5jhSbwU0thlXzqjxXjALiUxaop2Vw&oe=674D9EEF"}, {"file_name": "Virtuoso_Screenshot_3.png", "id": "336258848397846", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_336258851731179_7548211804606159018_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b8bQAYoZb04Q7kNvgFfPyl-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1nfDdQw9dm-jMtxVvZMdd0D5ac2Vj6PIV9YsdFw1NSQ&oe=674DB9C8"}, {"file_name": "Virtuoso_Screenshot_4.png", "id": "328154609239757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86621346_328154612573090_5755737741514283752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gcmOdplFMmIQ7kNvgEvso87&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAO0CaZSLNAyKGhuRoFP_wJNrGzZYOvfGX0nVD1YTR6g&oe=674DB13C"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-mUonaKDFIgQ7kNvgGIXnBA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCO-cwbKzvfH22rZekmeBlBtlXCT3p-oUW-eMcgq3NgyQ&oe=674D879E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementVideo_Thumbnail_Logo_2560x1440.png", "id": "604103097341700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031501_604103100675033_604749419717409359_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HtPv-0_DM3oQ7kNvgHcB8CS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3cdVX1zrHF3wgoo9F1qSRqKz-pmctRcog5ZrIhbr3fA&oe=674D85FB"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe six instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {