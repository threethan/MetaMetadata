25646714910_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GsFNgj-EU14Q7kNvgEloGr_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqzrPNaTNYtBF5NObMqjhVHifT7AahQPVJwoL9aanR9w&oe=67597C6F"}, {"file_name": "Virtuoso_Screenshot_3.png", "id": "336258848397846", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_336258851731179_7548211804606159018_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G2nkFxmCqw4Q7kNvgEtbDL_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiM1eXKn7wrekYdCPplaW7TCb-YkGITEjWMvtOzMYoPw&oe=67599748"}, {"file_name": "Virtuoso_Screenshot_4.png", "id": "328154609239757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86621346_328154612573090_5755737741514283752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lmepkO0s9fcQ7kNvgFz1toq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCB2kcOa1-mrmNoORoNelk7q9Oa9FJYrmpwMq8vDWN4Tw&oe=67598EBC"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ysZkJ6Kb7zYQ7kNvgGIza73&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4b0EfdJOlgg7rJ6lnBHrBMO-B55VpDfDr2wgb9WDCtA&oe=6759651E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementVideo_Thumbnail_Logo_2560x1440.png", "id": "604103097341700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031501_604103100675033_604749419717409359_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-XJm-ZJ4PiYQ7kNvgFC6ytr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_u-wJPYuKBcc3FGyuTbTXu9aOM5CSzE60-pVeT3DNaA&oe=6759637B"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe six instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "sup