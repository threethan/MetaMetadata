363525646714910_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X_suPSJ4BocQ7kNvgEPF0fg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnBqMaUsJ0o_w9c6yyI9XxkFLCFEnrJnPvUhun5T9NWg&oe=671B85EF"}, {"file_name": "Virtuoso_Screenshot_3.png", "id": "336258848397846", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_336258851731179_7548211804606159018_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jUaSX_nuSBQQ7kNvgEHIYQ8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByqFzva1AklIQrGz-C7DgnapbtcPD1n1lbg0RYzqIYSg&oe=671B6888"}, {"file_name": "Virtuoso_Screenshot_4.png", "id": "328154609239757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86621346_328154612573090_5755737741514283752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFE3YK2ZrkMQ7kNvgE8s8jF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjHgKtN-kt8BntPxwDAGrAmCU2TqmzFdlKG85c8Do-0g&oe=671B983C"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tDAHWXo_ccYQ7kNvgHsXnwF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBZkMfWammgVmrK1jKhlXHG45Lvf06gjRevJND5wjZrA&oe=671B6E9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementVideo_Thumbnail_Logo_2560x1440.png", "id": "604103097341700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031501_604103100675033_604749419717409359_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LSnhugBEAeYQ7kNvgElfTgE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDONpPCbfzbKrcRm_6DFLdzGLpOPOq_OAtTTyf70myt2Q&oe=671B6CFB"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe six instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes