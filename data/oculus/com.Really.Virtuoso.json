XU9ZJit6QsPdiTRx8CkGZxg&oe=675448BC"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RSym-NbDL7IQ7kNvgGz_v33&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7ljQFJGOYMKeHP7hmY-YQ7ZMv7HBq92zMbrr23U4myg&oe=67541F1E"}, {"file_name": "Virtuoso_Screenshot_6.png", "id": "325506343926900", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031535_325506350593566_2900022331007622192_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AZKFSb-u0k8Q7kNvgHfHdWo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQfZs2-HpqHhdLyUwJNLs1KOL7zRSqW7RBaUKcQK098A&oe=67544A4A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementTrailer_Thumbnail_Main_2560x1440.png", "id": "493858408787112", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_493858415453778_1388767016000051640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NybrrzdU5jUQ7kNvgHQW9wU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgzBYqz3vtOC1zm2ILCN-pQ25uI6x35EcB8Hg-71ha8g&oe=6754354D"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe seven instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8892644174148766"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86636484_351323016823417_8910622515579488370_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NQCztpkk5ZIQ7kNvgEC0CrT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoPBIhqUuXuJwKfzSafFb7xNs4_dcd5peDIXUz8Y8hKA&oe=6754383B"}, "is_concept": false, "is_test": false, "is_trial_offe