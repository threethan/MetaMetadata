QQSJ2YX-blzX3i_b3-Lw1g&oe=673201BC"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BFZpYtYZalEQ7kNvgFsvsxX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDA_TrPs5MmUCzBur2OeZrDEBfeKggRbqJRfAGVL0J7oQ&oe=6731D81E"}, {"file_name": "Virtuoso_Screenshot_6.png", "id": "325506343926900", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031535_325506350593566_2900022331007622192_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HmVmdXFyB3IQ7kNvgHgOcHl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-GUtYfxdsH6dNci81CCfSU_amHtdo7oRbjmi_6PiH0Q&oe=6732034A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementTrailer_Thumbnail_Main_2560x1440.png", "id": "493858408787112", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_493858415453778_1388767016000051640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LFhKem978hcQ7kNvgESvlfo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYyMw3gI2CP7huegPk5zjnxx9S_rRXWbRWVjTrse4CEw&oe=6731EE4D"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe seven instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7757339564345905"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86636484_351323016823417_8910622515579488370_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RdmccBZjJnYQ7kNvgHdmTaQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAN0CUXWQgwCjkPBqYDoxRBg2SLAvOTCYEXakCL4AB9nw&oe=6731F13B"}, "is_concept": false, "is_test": false, "is_trial_offer