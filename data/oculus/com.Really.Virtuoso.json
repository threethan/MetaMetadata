"https://scontent.oculuscdn.com/v/t64.5771-25/86621346_328154612573090_5755737741514283752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TKIEANGXo8wQ7kNvgHIucQe&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5yitg2_9KoJVrVUXSVwDYQdoooyMUVsh0X7n1RfDO5w&oe=66DDA1BC"}, {"file_name": "Virtuoso_Screenshot_5.png", "id": "961314058091610", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86646546_961314061424943_8799712959930446865_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mTdk6qJXxvQQ7kNvgHhxpoz&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlsbOBBuQ9SKtDUcA7q-1mJN9WuKJvmJX3eG_J_5PWTw&oe=66DD781E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Virtuoso_AnnouncementVideo_Thumbnail_Logo_2560x1440.png", "id": "604103097341700", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031501_604103100675033_604749419717409359_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dJ5YGUOqFMUQ7kNvgGNWXRw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAiGlpcevGH0DvTumDdH0zCZyb_0knvG_E5BLSua5JZcw&oe=66DD767B"}, "display_name": "Virtuoso", "keywords": ["virtuoso", "virtuosovr", "music"], "long_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!\n\nBE THE ARTIST OF YOUR DREAMS\nCreate music in real-time using the Looper and easily share it for all to hear! Even if you've never touched an instrument before, features like Tempo Sync and preset scales help you stay in time and on pitch.\n\nMADE-FOR-VR INSTRUMENTS\nThe six instruments of Virtuoso have been created specifically for VR. Set up your own custom drum kit with the Empads and tickle the keys of the three-dimensional Oorgan. You can also add vocals with lush reverb using the virtual microphone!\n\nFROM OPENING ACT TO HEADLINER\nThe interactive tutorial along with intuitive instruments and tools means that everyone, from professional producers to casual music lovers, can become Virtuosos!", "short_description": "Grab an instrument and get ready to jam in Virtuoso, your own virtual music stage! This VR musical sandbox lets anyone play and perform music in new, immersive ways. Explore a range of unique instruments made for VR and share your tracks with the world!"}]}, "developer_name": "Really Interactive AB", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games AB", "support_website_url": null, "website_url": "https://fasttravelgames.com/games/virtuoso", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1049933645567093"}}]}, "scheduled_offers": {"count": 33, "nodes": [{"status": "PUBLISHED", "id": "510810511565896"}, {"status": "PUBLISHED", "id": "409360825425867"}, {"status": "PENDING", "id": "917857499381804"}, {"status": "PENDING", "id": "260987063238157"}, {"status": "PUBLISHED", "id": "708139607448793"}, {"status": "PENDING", "id": "895320178422943"}, {"status": "PENDING", "id": "599720142366703"}, {"status": "PENDING", "id": "252745804123334"}, {"status": "PENDING", "id": "6566941136736250"}, {"status": "PUBLISHED", "id": "697073884992628"}, {"status": "PUBLISHED", "id": "466390065514828"}, {"status": "PENDING", "id": "266178606015145"}, {"status": "PUBLISHED", "id": "1422786134872745