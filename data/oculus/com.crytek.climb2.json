71-25/38974444_288637879385072_6765395979718435664_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6bxrq-jqUmUQ7kNvgEBDm27&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzrbs19J1ass49m2NFNbTjjTnv-BgsVzDJQs1sWvykTA&oe=66D98389"}, {"file_name": "TheClimb2_OculusStore_Screenshot_03.png", "id": "365630371536534", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031483_365630374869867_8354393605089364544_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MWud1dlBNWgQ7kNvgGkh9vz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfZp768012hmcsC6cAkkKjd96xGMnnTSwmiX6CqdNjRQ&oe=66D9928F"}, {"file_name": "TheClimb2_OculusStore_Screenshot_05.png", "id": "823149138295299", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_823149141628632_5864395115535433726_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gdwv9y-AGZAQ7kNvgE3Dif7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjdoZdz1eLzh7jL_8583gPmLbDZ7ELiKJTTtBdgHH7PQ&oe=66D99C69"}, {"file_name": "TheClimb2_OculusStore_Screenshot_04.png", "id": "3806337116110551", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_3806337119443884_6667471315245210603_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BCQEOKdqHnoQ7kNvgFzKDPX&_nc_ht=scontent.oculuscdn.com&oh=00_AYARL9T4icg3DXh65TPpvJ4AsMnTjJ00E0dqmDK6mV_BdQ&oe=66D9B6CA"}, {"file_name": "TheClimb2_OculusStore_Screenshot_01.png", "id": "752191705492083", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984454_752191708825416_8428657749825198175_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sY6HGLjOv9QQ7kNvgG5lAt0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhrquxfbzS0nBisgJtBa5XNY9Ot_ZMPKsfQQyqgCVNdg&oe=66D98642"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Climb 2", "keywords": ["Hauteurs", "Course", "Exploration", "Ville", "Nord"], "long_description": "Le plaisir de l'escalade prend vie avec \u00ab The Climb 2 \u00bb. Explorez un nouvel environnement urbain, ainsi que d'incroyables nouvelles cartes aux paysages sublimes. Gravissez des pics majestueux, explorez de vastes grottes, escaladez des gratte-ciels et d\u00e9couvrez des raccourcis pour grimper au sommet. Affrontez vos amis et dominez les classements dans des modes multijoueurs asynchrones. De l'exploration en montagne \u00e0 l'escalade en ville, faites monter l'adr\u00e9naline en grimpant sans corde et admirez des panoramas magnifiques au fil de vos ascensions.", "short_description": "\u00ab The Climb 2 \u00bb fait revivre le plaisir de l'escalade avec un nouvel environnement urbain, de nouvelles cartes, de nouveaux \u00e9v\u00e9nements et bien plus encore. Gravissez des pics vertigineux, explorez des grottes profondes, escaladez des gratte-ciels et d\u00e9couvrez des raccourcis pour grimper au sommet. Affrontez vos amis en multijoueur et dominez les classements."}, {"images": {"nodes": []}, "id": "654372295700587", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Climb 2", "keywords": ["Alturas", "Competencia", "Explorar", "Ciudad", "Norte"], "long_description": "La emoci\u00f3n del alpinismo cobra vida con \u201cThe Climb 2\u201d - explora un nuevo entorno citadino, adem\u00e1s de nuevos y estimulantes mapas con vistas que te quitar\u00e1n el aliento. Asciende por grandes picos, explora enormes cuevas, escala rascacielos y descubre atajos ocultos mientras encuentras tu camino hacia la cima. Compite con amigos y conquista los marcadores en los modos multijugador asincr\u00f3nicos. Desde explorar monta\u00f1as hasta escalar entornos urbanos, siente el \u00edmpetu de escalar sin cuerdas y experimenta unas vistas espectaculares mientras escalas a nuevas alturas.", "short_description": "\u201cThe Climb 2\u201d le da vida a la emoci\u00f3n del alpinismo con un nuevo entorno citadino, nuevos y emocionantes mapas, nuevos eventos y m\u00e1s. Escala picos \u00e9picos, explora enormes cuevas, escala rascacielos y descubre atajos mientras encuentras tu camino hacia la cima. Compite con amigos en el modo multijugador y conquista los marcadores."}, {"images": {"nodes": [{"file_name": "Store_Cover_art_1008x1440.png", "id": "959233621595690", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031332_959233624929023_4234032516876098142_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hXymDMybIg8Q7kNvgFEHSAD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvYiY9Yb85zQvO1yPmwyknjtU4hNPOmz00wln-lyIXCg&oe=66D9824D"}, {"file_name": "Store_Hero_3000x900.png", "id": "848954669056513", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221330_848954672389846_2106911842827380057_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K0dBrps7tewQ7kNvgHPiH_0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpbftb_9jppmob_uph1sgKR8ExptPv8w0kbDxICzq2kQ&oe=66D99BEA"}, {"file_name": "Store_Cover_art_2560x1440.png", "id": "556304295553572", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001685_556304298886905_7332566867740588926_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2KQLueIy8A4Q7kNvgFSBsim&_nc_ht=scontent.oculuscdn.com&oh=00_AYBoRbUzvqNMUrwr1H0kWxwW6qD_Pbc-_WRcYtb4wBkQQg&oe=66D9A2FC"}, {"file_name": "Store_Cover_art_1080x360.png", "id": "519970865923935", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974775_519970869257268_6858946338716855494_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gkT7Yyu9pYQ7kNvgF0E6u0&_nc_ht=scontent.oculuscdn.com&oh=00_AYA2PGgU7tHIV0nNXFHNa9Om7Lc6QsQi58SPq2NQDMKKBQ&oe=66D983A8"}, {"file_name": "Store_Cover_art_1440x1440.png", "id": "182871430501567", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234373_182871433834900_7287377472780937577_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wiZQQcazbUsQ7kNvgGnu6_S&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3ClbCNNRpmaEqGPlEr1xC8-cxG5c-iM1p0x0SgA_mHQ&oe=66D9A141"}]}, "id": "648011093021519", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Climb 2", "keywords": ["H\u00f6hen", "Rennen", "Erkunden", "Stadt", "Norden"], "long_description": "Mit \u201eThe Climb 2\u201c wird der Nervenkitzel des Kletterns zum Leben erweckt \u2013 erkunde eine neue Stadtumgebung und aufregende neue Karten mit atemberaubenden Aussichten. Erklimme gro\u00dfe Gipfel, bewege dich durch riesige H\u00f6hlen, klettere Wolkenkratzer hinauf und entdecke verborgene Abk\u00fcrzungen auf deinem Weg nach oben. Miss dich mit Freunden und erobere die Bestenlisten in asynchronen Mehrspielermodi. Vom Erkunden von Berglandschaften bis zur Kletterei in st\u00e4dtischen Kulissen kannst du den Rausch des Kletterns ohne Seile sowie atemberaubende Perspektiven erleben, w\u00e4hrend du neue H\u00f6hen erreichst.", "short_description": "\u201eThe Climb 2\u201c erweckt den Nervenkitzel des Kletterns zum Leben mit einer neuen Stadtumgebung, tollen neuen Karten, neuen Events und mehr. Erklimme epische Gipfel, bewege dich durch riesige H\u00f6hlen, klettere Wolkenkratzer hinauf und entdecke Abk\u00fcrzungen auf deinem Weg nach oben. Miss dich mit Freunden im Mehrspielermodus und erobere die Bestenlisten."}, {"images": {"nodes": [{"file_name": "Store_Cover_art_1440x1440.png", "id": "791449705128865", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974444_791449708462198_797527278459507876_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02ch24uePX4Q7kNvgGo0ZQC&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTlm2ypNA_jKuUlLuTg2OAe4OZzLmrtBveYntZEi8osw&oe=66D9A5B9"}, {"file_name": "Store_Cover_art_2560x1440.png", "id": "475257076957802", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974676_475257080291135_1441942720730963073_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DxYmXzqIob8Q7kNvgHAOm3b&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFS6iepV9-Wh9XO64eJeeYc4r3WRKhj2