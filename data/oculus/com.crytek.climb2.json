 thrill of climbing comes alive with The Climb 2 - explore a new city setting and exhilarating new maps with breathtaking views. Ascend grand peaks, navigate vast caves, climb skyscrapers, and discover hidden shortcuts as you find your path to the top. Compete with friends and conquer leaderboards in asynchronous multiplayer modes. From exploring mountain environments to scaling urban settings, feel the rush of climbing without ropes, and experience breathtaking vistas as you scale new heights.", "short_description": "The thrill of climbing comes alive with The Climb 2 - explore a new city setting and exhilarating new maps with breathtaking views. Ascend grand peaks, navigate vast caves, climb skyscrapers, and discover hidden shortcuts as you find your path to the top."}]}, "developer_name": "Crytek", "developer_privacy_policy_url": "http://www.theclimbgame.com/privacy", "developer_terms_of_service_url": "http://www.theclimbgame.com/terms", "publisher_name": "Crytek", "support_website_url": "https://theclimbgame.kayako.com/", "website_url": "http://www.theclimbgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "EXPLORATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_VE", "de", "es_AR", "ko", "es_PE", "en", "fr", "es_PR", "ja", "es_CL", "es_MX", "es_CO"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "360284498930613"}}]}, "scheduled_offers": {"count": 53, "nodes": [{"status": "PUBLISHED", "id": "509547351449374"}, {"status": "PUBLISHED", "id": "1414247309367093"}, {"status": "PENDING", "id": "6999182