-7&_nc_sid=6e7a0a&_nc_ohc=_8Au0CaN80gQ7kNvgHC4-yd&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8PZEklZsiQgKaT0Yh_tlpHWYQrukpKPfyooKQLfesvA&oe=66E16F75"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXMAz7Qq7OIQ7kNvgFwbf9b&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmaprh0DVV1_hqc7595aA6f1Kp2mbPfyKnWUNHnwyXlg&oe=66E17DC8"}, "display_name": "ShopR", "keywords": [], "long_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. \n\nThe current digital shopping experience is boring, with tiles and tiles of product icons on an endlessly scrollable screen. Using VR, we are revolutionizing the way users shop online. ShopR combines the best of both physical and virtual shopping by making it a fun, immersive and social experience. Welcome to the future of experiential shopping. \n\nTry ShopR and prepared to be wowed!", "short_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://shoprvr.com/privacy-policy", "developer_terms_of_service_url": "https://shoprvr.com/terms-of-