-25/39035381_827612058787977_5054337721754302804_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=42htzYatOR0Q7kNvgGZGG_W&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUo0QdgJvxMBOWRLamGfIqr&oh=00_AYA9FgKd93aGKtmW4m6je1a-9MZRThmqox5Rd0Eh1JgmbQ&oe=66E40E23"}, {"file_name": "oie_S0JV0JpPn0bQ.png", "id": "793911408731250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036689_793911412064583_7612239638392130325_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PCP5LKyE4B0Q7kNvgEX2LRs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUo0QdgJvxMBOWRLamGfIqr&oh=00_AYBhcCG7Z4W8dEuhxHvChFtkqistihvliXyGHbE99rIJ7g&oe=66E40A69"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_8Au0CaN80gQ7kNvgGg3WmN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUo0QdgJvxMBOWRLamGfIqr&oh=00_AYBGPu2uTnNBp3Sdh9psl3sYG0p5gDkjUw0eCl10h7Vvuw&oe=66E41275"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qqy_4QTiT5gQ7kNvgEG0ANa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUo0QdgJvxMBOWRLamGfIqr&oh=00_AYAppHkqpwbu65LHo4ZSN6NUQolAaUXe2crbBSLjLPQSIA&oe=66E420C8"}, "display_name": "ShopR", "keywords": [], "long_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. \n\nThe current digital shopping experience is boring, with tiles and tiles of product icons on an endlessly scrollable screen. 