&_nc_sid=6e7a0a&_nc_ohc=_Uy2-G6NzQ8Q7kNvgE38I3Z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA31x5TT9D4PTrqgyTaZuEcttSnp2pz1kuWH7QK5FYiag&oe=670CE8E9"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RttvIcMcdocQ7kNvgFk2BR6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFVlYQXGUCQTpgb8ioGd1_fevEhzP8tmSyVuij_jE91w&oe=670CF0F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3-DDaPhzQIEQ7kNvgH1enc6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQHwp9mmahEQmVJPqRW3TF54W80wg0ZTqf2glVSb3Vcw&oe=670CFF48"}, "display_name": "ShopR", "keywords": [], "long_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience.\n\nThe current digital shopping experience is lackluster, with endless scrolling of product icons. But with VR, ShopR revolutionizes online shopping, blending physical and virtual realms into a fun, immersive, and social adventure. Welcome to the future of experiential retail, where ShopR redefines the shopping journey for buyers and sellers alike!", "short_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience."}]}, "developer_name": null, "developer_privacy_policy_url"