&_nc_sid=6e7a0a&_nc_ohc=93lQU3H6_lgQ7kNvgEqbRhP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIeJBii9obCHAUS4nl6iuUemSPQxBSQ1GUsRLkKg3y8g&oe=671F5DE9"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UA0aGjIjtn4Q7kNvgEO95Ji&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA80tFeSWwbyu2Ac6QovkvWm5FPQP4brlGUvN3R5koo0Q&oe=671F65F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fAaSY_IZdRMQ7kNvgFV4Iz-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3IRiwdWW77n1OmrfQ3pzp0LyksVXwJhgtig2ldKlTZA&oe=671F7448"}, "display_name": "ShopR", "keywords": [], "long_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience.\n\nThe current digital shopping experience is lackluster, with endless scrolling of product icons. But with VR, ShopR revolutionizes online shopping, blending physical and virtual realms into a fun, immersive, and social adventure. Welcome to the future of experiential retail, where ShopR redefines the shopping journey for buyers and sellers alike!", "short_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience."}]}, "developer_name": null, "developer_privacy_policy_url"