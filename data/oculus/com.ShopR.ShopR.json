n.com/v/t64.5771-25/39036689_793911412064583_7612239638392130325_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gTbdQdWDdBsQ7kNvgGNT6Xv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBewkSzTXtAqaAasHWyGtuCjTXMXh9eBUzf6NAc0ulRCQ&oe=671B6969"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wti3670EoIMQ7kNvgE-uTRu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBv56wmbJb96DCUPzGslSPgOxHivxLjbgFcElj2LAqepA&oe=671B7175"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJpmGoU_L-4Q7kNvgH1xHMx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhdyGdX4SvYd8RqQAzIcvXQUg9gu9N0Vr9RGyEpwMm6g&oe=671B7FC8"}, "display_name": "ShopR", "keywords": [], "long_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience.\n\nThe current digital shopping experience is lackluster, with endless scrolling of product icons. But with VR, ShopR revolutionizes online shopping, blending physical and virtual realms into a fun, immersive, and social adventure. Welcome to the future of experiential retail, where ShopR redefines the shopping journey for buyers and sellers alike!", "short_description": "Introducing ShopR: Your immersive mixed reality shopping mall! We connect buyers and sellers in a vibrant social, virtual environment. Buyers explore personalized stores, interact with products, and easily add them to their cart. Sellers craft customized store designs for the best shopping experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://shoprvr.com/privacy-policy", "developer_terms_of_service_url": "https://shoprvr.com/terms-of-use", "publisher_name": "ShopR, Inc.", "support_website_url": null, "website_url": "https://www.shoprvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "877379582865093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8511599082207473"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031463_1252242049013672_1223355477010562118_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=icdE5BKoSZsQ7kNvgGrYO6a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCeFrAxqKntyDRWL44bgCqiilJjzgaTN4zEwD9HGQqt4A&oe=671B8E81"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ShopR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Shopping", "id": "877379582865093"}], "release_date": 1684863965, "lastRevision": {"nodes": [{"id": "6662595600441173", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6662595590441174", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "26