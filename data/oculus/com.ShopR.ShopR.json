t=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93lQU3H6_lgQ7kNvgEqbRhP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIeJBii9obCHAUS4nl6iuUemSPQxBSQ1GUsRLkKg3y8g&oe=671F5DE9"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UA0aGjIjtn4Q7kNvgEO95Ji&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA80tFeSWwbyu2Ac6QovkvWm5FPQP4brlGUvN3R5koo0Q&oe=671F65F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fAaSY_IZdRMQ7kNvgFV4Iz-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3IRiwdWW77n1OmrfQ3pzp0LyksVXwJhgtig2ldKlTZA&oe=671F7448"}, "display_name": "ShopR", "keywords": [], "long_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. \n\nThe current digital shopping experience is boring, with tiles and tiles of product icons on an endlessly scrollable screen. Using VR, we are revolutionizing the way users shop online. ShopR combines the best of both physical and virtual shopping by making it a fun, immersive and social experience. Welcome to the future of experiential shopping. \n\nTry ShopR and prepared to be wowed!", "short_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://shoprvr.com/privacy-policy", "developer_terms_of_service_url": "https://shoprvr.com/terms-of-use", "publisher_name": "ShopR, Inc.", "support_website_url": null, "website_url": "https://www.shoprvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1183690305667806"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1203213873670707"}]}, "baseline_offer": {"id": "1203213873670707"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1684863965, "status": "PUBLISHED", "id": "1203213873670707"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8976597009041009", "version": "12.0.0"}, "id": "1247641529214344", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6662595590441174", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8976597009041009"}, "release_status": "RELEASED"}, "bin