zCAnyiSZOQp6Rw&oe=671B6D23"}, {"file_name": "oie_S0JV0JpPn0bQ.png", "id": "793911408731250", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036689_793911412064583_7612239638392130325_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gTbdQdWDdBsQ7kNvgGNT6Xv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBewkSzTXtAqaAasHWyGtuCjTXMXh9eBUzf6NAc0ulRCQ&oe=671B6969"}, {"file_name": "oie_P9k21B7U8SEy.png", "id": "986094372561683", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986094375895016_3456142005560710456_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wti3670EoIMQ7kNvgE-uTRu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBv56wmbJb96DCUPzGslSPgOxHivxLjbgFcElj2LAqepA&oe=671B7175"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oie_lIOdbjNedBSm.png", "id": "3410584529259024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001658_3410584532592357_5934662866063577661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJpmGoU_L-4Q7kNvgH1xHMx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDhdyGdX4SvYd8RqQAzIcvXQUg9gu9N0Vr9RGyEpwMm6g&oe=671B7FC8"}, "display_name": "ShopR", "keywords": [], "long_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. \n\nThe current digital shopping experience is boring, with tiles and tiles of product icons on an endlessly scrollable screen. Using VR, we are revolutionizing the way users shop online. ShopR combines the best of both physical and virtual shopping by making it a fun, immersive and social experience. Welcome to the future of experiential shopping. \n\nTry ShopR and prepared to be wowed!", "short_description": "ShopR is a VR shopping mall to buy physical goods, the real life stuff. It is a VR native platform that connects buyers and sellers in an immersive and social virtual mall. Buyers will be able to explore the virtual mall, enter a store of their choice, check out products, buy and get them delivered to their home. Sellers will be able to create a customized store design to provide the best shopping experience. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://shoprvr.com/privacy-policy", "developer_terms_of_service_url": "https://shoprvr.com/terms-of-use", "publisher_name": "ShopR, Inc.", "support_website_url": null, "website_url": "https://www.shoprvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "877379582865093"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1183690305667806"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1203213873670707"}]}, "baseline_offer": {"id": "1203213873670707"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1684863965, "status": "PUBLISHED", "id": "1203213873670707"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8976597009041009", "version": "12.0.0"}, "id": "1247641529214344", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary":