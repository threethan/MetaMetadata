.\n\nHave fun -  by competing with other players by setting the highest game score and see who is going to beat it. Enjoy and have fun and prove your battings skills.\n", "short_description": "Play Virtual Real Cricket against International Teams in a limited overs thrilling batting challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://skippyapps.com/privacy.htm", "developer_terms_of_service_url": "https://skippyapps.com/terms.html", "publisher_name": "Skippy Apps", "support_website_url": null, "website_url": "https://skippyapps.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27701824466082968"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348038_312061910567527_7787277845429328689_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BtnwPVdOtl0Q7kNvgEJD4Lk&_nc_ht=scontent.oculuscdn.com&oh=00_AYAB0ZeP1xOq35Arh5FC_A6vAkFVQsGm9rutDanuPLCCqw&oe=66FA9608"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CricVRX Cricket - Virtual Sports", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Arcade", "id": "1592192974313489"}, 