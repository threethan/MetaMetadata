scdn.com&oh=00_AYDeX6PiAhvrHsf1f_ShGIr64wDbK3vRek3Kr8dbS5X2xA&oe=671241E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "565917477755998", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39036706_565917481089331_2547006951943853734_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bEXhUCuX8uIQ7kNvgGKNcAs&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCED8Ta5rhR_OMM4m594e11PL4wjHG6BTiF28UTzMzIhQ&oe=6712658E"}, "display_name": "Unlimited Bowling", "keywords": ["bowling", "bowl", "sports", "strike", "ball"], "long_description": "Feel the joy and excitement of real bowling!\n\n\u2022Real world dynamic ball hook motions and pin actions make you feel the same satisfaction of hitting a perfect strike as playing bowling in real life!\n\n\u2022In total of 9 challenging oil patterns to bowl on! Bowl like a pro, adapt your game and conquer on any lane conditions!\n\n\u2022Online Free Play mode let's you bowl with your friends and others all around the world the way you want it. You can hold a casual bowling party or you can join together for a thrilling stepladder competition!\n\n\u2022Engage in Daily Events to clinch the titles and challenge yourself for the best scores!\n\n\u2022Challenging Versus AI mode to test your bowling skills to the limit!\n\n\u2022Score 300 points or more easily in an action-packed 100-pin game! But scoring a perfect 3000 points game won't be as easy!", "short_description": "Feel the joy and excitement of real bowling!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://unlimited-bowling.web.app/Privacy%20Policy%20of%20Unlimited%20Bowling%20(VR).html", "developer_terms_of_service_url": null, "publisher_name": "SP Software Productions", "support_website_url": null, "website_url": "https://www.facebook.com/Unlimited-Bowling-VR-109255341414550", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_