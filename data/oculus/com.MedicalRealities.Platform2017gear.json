0a&_nc_ohc=MgbtlFGcUi4Q7kNvgG-EtJh&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhWibAM6E8Z_4hTYErq1EkxAVXeGHxP5-Ouhp3BNBQrg&oe=66EC0137"}, {"file_name": "migrated_image.png", "id": "348221809434755", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162702_538183836547135_7849525063878443008_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WCvIlFWXmSkQ7kNvgEB4Syp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDykTC6cVq_W8nU8j-lTUMm_EzZe_k5ftZF4kQzpYkwA&oe=66EC0A11"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Medical Realities Platform", "keywords": ["medical", "surgery", "training", "education", "health"], "long_description": "Register at www.medicalrealities.com to access the Virtual Reality medical training platform Medical Realities.\n\nWhat is Medical Realities?\nMedical Realities is an award-winning Virtual Reality education platform for medical students, surgical trainees, surgeons, and health care professionals. Our mission is to revolutionize surgical training across the globe. \n\nModules\nThe platform offers a comprehensive collection of surgical operations covering key syllabus material and includes assessment. Each module allows immersive learning with full interactive features including anatomy and pathophysiology.\n\n360\u00b0 Video\nWe have captured high-quality 360\u00b0 video of real operations. Immerse yourself as you learn.\n\nInteractive\nOur content is richly interactive allowing you to test yourself and chart your progress.", "short_description": "Medical Realities is an award-winning education platform for surgical trainees."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.medicalrealities.com/", "developer_terms_of_service_url": "http://www.medicalrealities.com/", "publisher_name": "Medical Realities", "support_website_url": null, "website_url": "http://www.medicalrealities.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_