6F7DD06"}, {"file_name": "39036614_502468398013965_548994492148262488_n.png", "id": "536150848528119", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_536150851861452_5440479838385819690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GyguIbFzUIYQ7kNvgGW0IIk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPmWlhoGwtiacGL1XeVhZoUJbyWfNekf1zc1UaZkcl0Q&oe=66F8016F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39035421_2228243200674621_1976871874863166558_n.png", "id": "1555743954873855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031572_1555743958207188_7724975587649524337_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VNUvjrZjWOMQ7kNvgHjnxvF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXvBPYj8EnFJVkZYN7rhe3Ld1TSjdsO9uov1ROAMqgvw&oe=66F7F655"}, "display_name": "Remio", "keywords": [], "long_description": "Gather. Collaborate. Play.\n\n\nRemio is the VR app for fun, engaging meetings. Host private sessions from large-scale all-hands events to intimate team-building discussions with your remote team. Remio\u2019s flexible, secure platform is a great way to collaborate and connect.  Remio - the best meeting of the week. \n\n\nEngage in Interactive Experiences and Games:\n- Team Puzzle Races\n- Paintball\n- Hide-and-Seek\n- Space-Themed Escape Room\n- Archer Tower Defense\n- Disco Room\n- BarVR\n- Pictionary\n- Red-Light Green-Light\n- Zen Room\n- Basketball\n- and many more arcade-style mini-games\n\n\nCollaborate with Effective VR Tools:\n- Whiteboards\n- Presentation Rooms\n- VR Browser\n- Project Planning Boards\n- Sticky Notes\n- Private Rooms\n- Intimate Boardrooms\n- Gallery Room\n- Aurora Auditorium (large conference venue)\n\n\nSee our website for more details: https://www.remiovr.com/ \nJoin our Discord community: https://discord.gg/8rdzcdmPFZ \n\n\nWe appreciate any feedback or suggestions.\n", "short_description": "Gather. Collaborate. Play.\n\nRemio is the VR app for fun, engaging meetings. Host private sessions from large-scale all-hands events to intimate team-building discussions with your remote team.\n\nMost Popular Games:\n- Team Puzzle Races\n- Paintball\n- Space-Themed Escape Room\n- Archer Tower Defense\n- Basketball\n- Disco Room\n\n\nYou can also use our collaboration tools for whiteboarding, project planning, presentations and brainstorming.\n\nSee our website for more details: https://www.remiovr.com/"}]}, "developer_name": "Remio", "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/health-disclaimer", "publisher_name": "Remio", "support_website_url": "https://www.remiovr.com/contact-us", "website_url": "https://www.remiovr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "489453466706146"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "860559885214078"}]}, "baseline_offer": {"id": "860559885214078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674756000, "status": "PUBLISHED", "id": "860559885214078"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7641427932624897", "version": "2.124"}, "id": "1488366588340040", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "