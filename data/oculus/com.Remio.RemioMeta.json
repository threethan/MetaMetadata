974469_1170363790460830_993477189236871003_n.png", "id": "832371198017811", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974825_832371201351144_6827128925294064280_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=If2MZcA2LWQQ7kNvgH3h5pP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmtSLAgaE08rHwozf80B_MaeUhA7WFPyGHyJ1LxY0SBQ&oe=67694C5B"}, {"file_name": "38974748_1161260027979463_5790965634970942838_n.png", "id": "1118621912090778", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974762_1118621918757444_6825627381390338297_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sesKZgWi2C4Q7kNvgFeXJyt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFksJzpqH8PtyUYeRpuOw8nYJ0xQXVew69tsxBoWo0sA&oe=67693E06"}, {"file_name": "39036614_502468398013965_548994492148262488_n.png", "id": "536150848528119", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_536150851861452_5440479838385819690_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yCtC12e3aOIQ7kNvgEIF-Ex&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCky-aEV12cRbEluJJduGKiGYSDJYkFZ_DEe2zcqk3PKQ&oe=6769626F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39035421_2228243200674621_1976871874863166558_n.png", "id": "1555743954873855", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031572_1555743958207188_7724975587649524337_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pi-dIK9I0m0Q7kNvgHVP_9b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5-4Pxj6rBqHRQzGUSc_8YVZOYu9zRZO1o6ED-SMgfdg&oe=67695755"}, "display_name": "Remio", "keywords": [], "long_description": "Gather. Collaborate. Play.\n\n\nRemio is the VR app for fun, engaging meetings. Host private sessions from large-scale all-hands events to intimate team-building discussions with your remote team. Remio\u2019s flexible, secure platform is a great way to collaborate and connect.  Remio - the best meeting of the week. \n\n\nEngage in Interactive Experiences and Games:\n- Team Puzzle Races\n- Paintball\n- Hide-and-Seek\n- Space-Themed Escape Room\n- Archer Tower Defense\n- Disco Room\n- BarVR\n- Pictionary\n- Red-Light Green-Light\n- Zen Room\n- Basketball\n- and many more arcade-style mini-games\n\n\nCollaborate with Effective VR Tools:\n- Whiteboards\n- Presentation Rooms\n- VR Browser\n- Project Planning Boards\n- Sticky Notes\n- Private Rooms\n- Intimate Boardrooms\n- Gallery Room\n- Aurora Auditorium (large conference venue)\n\n\nSee our website for more details: https://www.remiovr.com/ \nJoin our Discord community: https://discord.gg/8rdzcdmPFZ \n\n\nWe appreciate any feedback or suggestions.\n", "short_description": "Gather. Collaborate. Play.\n\nRemio is the VR app for fun, engaging meetings. Host private sessions from large-scale all-hands events to intimate team-building discussions with your remote team.\n\nMost Popular Games:\n- Team Puzzle Races\n- Paintball\n- Space-Themed Escape Room\n- Archer Tower Defense\n- Basketball\n- Disco Room\n\n\nYou can also use our collaboration tools for whiteboarding, project planning, presentations and brainstorming.\n\nSee our website for more details: https://www.remiovr.com/"}]}, "developer_name": "Remio", "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/health-disclaimer", "publisher_name": "Remio", "support_website_url": "https://www.remiovr.com/contact-us", "website_url": "https://www.remiovr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}, {"id": "1990104051447093"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recom