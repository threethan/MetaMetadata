culuscdn.com/v/t64.5771-25/38982654_1143507286846878_252352450397043439_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qMmyr5qimZ0Q7kNvgHplvzl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC3MB92uuvK21mtPUr9b2WzCJ06tuAQOiMEMyRKBqd3Sw&oe=672612B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nursing_coverImage_2560x1440.png", "id": "751224293868148", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974886_751224297201481_7099546317802772565_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GrgGUddbuK0Q7kNvgED4T0e&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDinvUuBrW_BAFKBHr1F7pTJ8JaBirYjUjEkmRT2zbS0g&oe=6726209B"}, "display_name": "AcroXeR NursingVR", "keywords": [], "long_description": "Training system for medication education\n   - Controller system (order output, object picking, drug mixing, patient administration)\n   - Order (medication order) system\n   - Evaluation system (accuracy of operation, time, sequence, drug mix accuracy)\n\u3147 Educational content\n  - Tutorial: VR device operation\n  - Dosage 1.1 General drug administration \n  - Dosage 1.2 High-risk drug administration \n  - Medication 1.3 Emergency medication administration \n\u3147 System development\n   - System advancement (UI/UX creation, medication order system, evaluation items)\n   - Divided into two modes (training mode, challenge mode)\n   - Pharmaceutical and medical device random placement system\n   - Ranking system\n   - Medical device (vial, syringe, IV, etc.) sticker replacement system (brand, capacity, language)\n   - Multilingual system (Korean, English, Bednam)\n ", "short_description": "AcroXeR NursingVR education simulator optimized for the nursing medical environment that can enhance practical experience in various cases for hospitals lacking nursing staff dedicated to education."}]}, "developer_name": "Surgical Mind.Inc", "developer_privacy_policy_url": "https://acroxer.com/bbs/content.php?co_id=privacy", "developer_terms