C/Mac. The content can be played synchronically on all headsets or asynchronically. Showtime VR is designed for business professional presentations, marketing campaigns activations, movie shows - VR theatre solution, kiosk solutions \u2013 little involvement of staff, fair presentations, events - everywhere where you need to have full control over the headsets and the content presented on them, where you have to manage remotely the VR headsets and would like to present the VR content in synchronic way. The 360 Showtime VR player works only with Showtime VR controller application.", "short_description": "Showtime VR helps you manage remotely numerous VR headsets and play synchronically 360/180 degrees videos and 360 graphics/photos on many VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://showtimevr.eu/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Showtime VR", "support_website_url": null, "website_url": "http://showtimevr.eu/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "MEDIA_PLAYER", "UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP"], "id": "341682724532507"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "147905780549265"}]}, "baseline_offer": {"id": "147905780549265"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1616112540, "status": "PUBLISHED", "id": "147905780549265"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_r