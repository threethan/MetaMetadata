snLcJawhuz1A&oe=671F8B10"}, {"file_name": "scr_oculus04.png", "id": "3441374742756740", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207238_3441374746090073_5748831365053551131_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0zOaBvdLimAQ7kNvgFMFADO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3EJ-w4fWbvD4l6BFCdcDt6o-jJ6QMtS7dYCttx0Xm3A&oe=671F7138"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_3 kopia_svr.png", "id": "783288386134899", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566679_783288389468232_7477690739663488588_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K0zjDOMgXCIQ7kNvgFZq2pW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBB8uF--p3-W4wX7JwZKPIQ8Q-3aG5AeRVOP2MB-V4_Lw&oe=671F5C7B"}, "display_name": "Showtime VR", "keywords": [], "long_description": "Showtime VR enables remote management of many VR headsets. The solution includes a 360 player which is installed on the headset and is able to play 360 and 180 degrees videos (2D and 3D) and 360 graphics and photos (panoramas) up to 8192x4096px as a slideshow. The controller application is installed on a tablet or PC/Mac. The content can be played synchronically on all headsets or asynchronically. Showtime VR is designed for business professional presentations, marketing campaigns activations, movie shows - VR theatre solution, kiosk solutions \u2013 little involvement of staff, fair presentations, events - everywhere where you need to have full control over the headsets and the content presented on them, where you have to manage remotely the VR headsets and would like to present the VR content in synchronic way. The 360 Showtime VR player works only with Showtime VR controller application.", "short_description": "Showtime VR helps you manage remotely numerous VR headsets and play synchronically 360/180 degrees videos and 360 graphics/photos on many VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": 