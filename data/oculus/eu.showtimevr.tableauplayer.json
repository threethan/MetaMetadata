DK&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACl-dYsrl3NQGUct_4PU7aa&oh=00_AYA-n_XI_nwNgmIqbxDkPRnTr-oz73bPohuIbp-Omrjpow&oe=66D1C290"}, {"file_name": "scr_oculus04.png", "id": "3441374742756740", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75207238_3441374746090073_5748831365053551131_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A_GT_StDLoMQ7kNvgFr6-2F&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACl-dYsrl3NQGUct_4PU7aa&oh=00_AYBzpEYjzUH9E3MLd1ZX0UlBQFSpiNxm8RaijYoR3gtpyg&oe=66D1A8B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_3 kopia_svr.png", "id": "783288386134899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566679_783288389468232_7477690739663488588_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YS9-N-GP7vMQ7kNvgGB8Bxu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACl-dYsrl3NQGUct_4PU7aa&oh=00_AYBDtjAlQ3wg5TmztBkSH-zfSF9As0iwjjGFaGqNOBCdiQ&oe=66D193FB"}, "display_name": "Showtime VR", "keywords": [], "long_description": "Showtime VR enables remote management of many VR headsets. The solution includes a 360 player which is installed on the headset and is able to play 360 and 180 degrees videos (2D and 3D) and 360 graphics and photos (panoramas) up to 8192x4096px as a slideshow. The controller application is installed on a tablet or PC/Mac. The content can be played synchronically on all headsets or asynchronically. Showtime VR is designed for business professional presentations, marketing campaigns activations, movie shows - VR theatre solution, kiosk solutions \u2013 little involvement of staff, fair presentations, events - everywhere where you need to have full control over the headsets and the content presented on them, where you have to manage remotely the VR headsets and would like to present the VR content in synchronic way. The 360 Showtime VR player works only with Showtime VR controller application.", "short_description": "Showtime VR helps you manage remotely numerous VR headsets and play synchronically 360/180 degrees videos and 360 graphics/photos on many VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://showtimevr.eu/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Showtime VR", "support_website_url": null, "website_url": "http://showtimevr.eu/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}, {"id": "393222478507326"}, {"id": "384928226018505"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "MEDIA_PLAYER", "UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP"], "id": "823586305437989"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_1470493580041364_2898742236980248457_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e_54SJ7XI7IQ7kNvgEuZ0Oy&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACl-dYsrl3NQGUct_4PU7aa&oh=00_AYD7bDVvg1ZaW0Bws4pYtYSizY3xO7CFpGDjfJetUZ9bug&oe=66D1AEC7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Showtime VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Utilities", "id": "393222478507326"}, {"topic_name": "Media & Streaming", "id": "384928226018505"}], "release_date": 1616112524, "lastRevision": {"nodes": [{"id": "3810912408948149", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"appli