Q&oe=67371942"}, {"file_name": "MMRX_Quest_Screenshot_04.png", "id": "708605709975692", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984443_708605713309025_8219504983544124518_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AKCNod1wy5YQ7kNvgGKR3Jm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_HvjLs9VfnbN6rWb85AlO80IuI6oRK1ci7i9ERPWVbg&oe=67374A8E"}, {"file_name": "Go_screenshot_01.png", "id": "567185167282910", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75363518_567185170616243_1547405991502807618_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AmtL_v3ODycQ7kNvgGR2Y64&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxyaCBg-EZjiPKpjiaahTZc5rXGTtmUkj2CH1Q1oh5xg&oe=67373D3D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Thumb_75245820_3016058678450182_3581191190793420800_n.png", "id": "298764581264875", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392233_298764584598208_784885369833003245_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dfmtEb5PmcgQ7kNvgE0aEl1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWbayngs2-AdmdeO6DrK73sNrxregfF6_Bgskuey33mQ&oe=67371B0E"}, "display_name": "Mini Motor Racing X", "keywords": ["racing", "multiplayer", "coop", "combat", "kart"], "long_description": "Welcome to the world of Mini Motor Racing X! Jump into a nitro fuelled world where little cars mean BIG fun! Spanning across reclaimed ruins and scorched outbacks through to rain soaked docks and sun-kissed tropical islands - Mini Motor Racing X will take you on a micro driving journey across the globe like no other.\n\nFEATURES:\n\nHUGE CAREER: Collect dozens of cars and race on over 50 tracks in hundreds of races with vibrant, rich visuals, day and night and in varying weather conditions. \n\nUPGRADE YOUR RIDES: Pump your hard earned winnings into upgrades to help give you the edge.\n\nMULTIPLAYER: Full online multiplayer with up to 4 friends and campaign co-op.\n\nMULTIPLE WAYS TO PLAY: Play from in-car, top-down, track-side or anywhere else that takes your fancy! Packed with comfort and control options including Virtual Wheel, RC Controller, motion controls and more!\n\nBUMPER BALL: Play online with friends and score some goals in this and other frantic party modes.", "short_description": "Welcome to the world of Mini Motor Racing X! Jump into a nitro fuelled world where little cars mean BIG fun! Spanning across reclaimed ruins and scorched outbacks through to rain soaked docks and sun-kissed tropical islands - Mini Motor Racing X will take you on a micro driving journey across the globe like no other."}]}, "developer_name": "The Binary Mill", "developer_privacy_policy_url": "http://www.thebinarymill.com/privacy.php", "developer_terms_of_service_url": "http://www.thebinarymill.com/terms.php", "publisher_name": "Nextgen Reality Ptd. Ltd.", "support_website_url": "https://thebinarymill.zendesk.com/", "website_url": "https://www.thebinarymill.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SHOOTER", "RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "484075813105421"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1048279062285132"}, {"status": "PUBLISHED", "id": "614845775893536"}, {"status": "PUBLISHED", "id": "302548140935969"}, {"status": "PUBLISHED", "id": "2602782999974792"}]}, "baseline_offer": {"id": "302548140935969"}, "is_approved": true, "firstOffer": {"nodes": [{"start_tim