030080935_4490515293578116286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SuvWHinXyDkQ7kNvgHGbFNn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDf5CtRg4-U6BaPcPsZe4xbD0aEJcbm47pPZgwDLpmiIQ&oe=678120E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_2560x1440.png", "id": "189937479815094", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031412_189937483148427_2671574933574822593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-z8KQDJ7RQQ7kNvgEZEbJ8&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDofdXqoXHWmWkICmtWAUJ6iPoe0RJXUkcryiX8oEtB7A&oe=67811C9C"}, "display_name": "HyperTunnel", "keywords": [], "long_description": "HyperTunnel enables frontline workers to summon experts for side-by-side guidance and supervision through a shared immersive digital twin, providing a real-time avatar to mimic operations on site. This grants the supervisor the ability to observe and understand the actions performed by the fronline workers and provide feedback in spatial context.\n\nThe application provides the following capabilities:\n- Generate and distribute immersive Digital Twins of remote worksites.\n- Synchronize physical worksites with immersive Digital Twins.\n- Augment the shared working space by leveraging Computer Vision", "short_description": "HyperTunnel enables frontline workers to summon experts for side-by-side collaboration."}]}, "developer_name": null, "developer_privacy_policy_url": "https://factualvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FactualVR", "support_website_url": "https://factualvr.com/support/", "website_url": "http://www.factualvr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "SIMULATION", "UTILITY"], "has_in_app