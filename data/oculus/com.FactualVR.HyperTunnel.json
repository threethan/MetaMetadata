oXcD6LB-20h_7I5ZR&oh=00_AYAWXifDUYYthLtQkG8N7d64lKhQojVThxKmiip05VrMKw&oe=66E9659B"}, {"file_name": "08_quest_2560x1440.png", "id": "248980026747602", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_248980030080935_4490515293578116286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yf-LQxodIDYQ7kNvgHvGJ-R&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjMBGyoXcD6LB-20h_7I5ZR&oh=00_AYDAmMG-iMuBH0H_Z0KJVnyTWHvHWgNc7BU__rZ6R6AnIg&oe=66E98466"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_2560x1440.png", "id": "189937479815094", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031412_189937483148427_2671574933574822593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A1If9zBtMDMQ7kNvgHlUpPv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjMBGyoXcD6LB-20h_7I5ZR&oh=00_AYA3PHfcUzgZMY9zVZY_V7FazKBhZ4uqqMaBAB38ZejDvg&oe=66E9801C"}, "display_name": "HyperTunnel", "keywords": [], "long_description": "HyperTunnel enables frontline workers to summon experts for side-by-side guidance and supervision through a shared immersive digital twin, providing a real-time avatar to mimic operations on site. This grants the supervisor the ability to observe and understand the actions performed by the fronline workers and provide feedback in spatial context.\n\nThe application provides the following capabilities:\n- Generate and distribute immersive Digital Twins of remote worksites.\n- Synchronize physical worksites with immersive Digital Twins.\n- Augment the shared working space by leveraging Computer Vision", "short_description": "HyperTunnel enables frontline workers to summon experts for side-by-side collaboration."}]}, "developer_name": null, "developer_privacy_policy_url": "https://factualvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "FactualVR", "support_website_url": "https://factualvr.com/support/", "website_url": "http://www.factualvr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_