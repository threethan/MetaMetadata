8974530_5123214591095140_5583917946945894066_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=robVMnwdTe8Q7kNvgGa3E4n&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2O9_s44W-AAV_LnD2OR23r&oh=00_AYDW4mJTjyb5qOIMhJpKXfkI3U-4KlDlYQulodPKXZshnA&oe=66F538E7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_NEW.png", "id": "986489218729347", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572932_986489225396013_2431188837476558669_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-pZVccH4uY4Q7kNvgG5oSVr&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2O9_s44W-AAV_LnD2OR23r&oh=00_AYBwGztPTiwQ_d_zTEW9QFJgOC1No6lBbm0vNaa_5L240A&oe=66F54F9B"}, "display_name": "HyperTunnel", "keywords": [], "long_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins.\n\nWe 3D scan a remote worksite and create an immersive digital twin. We use AI/ML to recognize and match specific objects found at the worksite, and augment the XR shared space with corresponding interactive 3D models. These interactive models are used by the experts, immersed in the VR digital twin, to guide and demonstrate how to perform tasks on-site. We also leverage the digital twins as immersive VR simulators for training.", "short_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins."}]}, "developer_name": "HyperTunnel", "developer_privacy_policy_url": "https://www.hypertunnel.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HyperTunnel", "support_website_url": "https://hypertunnel.com/support/", "website_url": "http://www.hypertunnel.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS