8974530_5123214591095140_5583917946945894066_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0e4JUMRfz4Q7kNvgFGQt4w&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHkPt-i1mxa7MTqTyWj-HmR&oh=00_AYBXHN1Vs8mUC01N8laBc9Jqh8HElz9fXIeklvNXakLU-g&oe=66EAACE7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_NEW.png", "id": "986489218729347", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572932_986489225396013_2431188837476558669_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K6yx4zx6nB0Q7kNvgFyOMYC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHkPt-i1mxa7MTqTyWj-HmR&oh=00_AYCUa_z0KTdu7FaAxg4TfTqHIJj_xTGLhgrwlysPbnC-eA&oe=66EAC39B"}, "display_name": "HyperTunnel", "keywords": [], "long_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins.\n\nWe 3D scan a remote worksite and create an immersive digital twin. We use AI/ML to recognize and match specific objects found at the worksite, and augment the XR shared space with corresponding interactive 3D models. These interactive models are used by the experts, immersed in the VR digital twin, to guide and demonstrate how to perform tasks on-site. We also leverage the digital twins as immersive VR simulators for training.", "short_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins."}]}, "developer_name": "HyperTunnel", "developer_privacy_policy_url": "https://www.hypertunnel.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HyperTunnel", "support_website_url": "https://hypertunnel.com/support/", "website_url": "http://www.hypertunnel.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS