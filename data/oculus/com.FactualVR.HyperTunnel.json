_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=go4lRgnfXI4Q7kNvgEEVMdl&_nc_ht=scontent.oculuscdn.com&oh=00_AYC06PRAH3caucz91aOH4rm_aZ9wTV2NFhJOyxwlDK8E0w&oe=66D3070D"}]}, "id": "708757880715948", "locale": "en_US", "screenshots": [{"file_name": "04_quest_new.png", "id": "1371888653308284", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974629_1371888656641617_2853966035794978230_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sCRb6MbR4tgQ7kNvgGUtDL4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSuNTb8JTlx0807WEO8r3g7Zh8bTmUFwSFxvawAUixzw&oe=66D30FE9"}, {"file_name": "08_quest_new.png", "id": "1079390252932170", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262740_1079390256265503_4067141466324254035_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wVg2lShMJbQQ7kNvgGg-WCG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAugjt2fnZM4Tx86mmt_alJlfCzun6MM8e-3Ygq2O25Qg&oe=66D2F1A9"}, {"file_name": "05_quest.png", "id": "1052425825362288", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974530_1052425828695621_4809201121921211722_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TUuU9eGOixoQ7kNvgHyIpKF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZyDzfM2d4KlGbD7t5upA_Kb7vIsAcKar4nuAomC0JpQ&oe=66D2F366"}, {"file_name": "06_quest.png", "id": "909478490447209", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572932_909478493780542_6172351009248328937_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WTBWdpubDmYQ7kNvgGdl-I5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPS06EpwhVnzoL7grn6iB5ZZ1oXbgPDkVtTa8aq1Y0mw&oe=66D2F90D"}, {"file_name": "07_quest.png", "id": "5123214587761807", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974530_5123214591095140_5583917946945894066_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y2qQksRvzE4Q7kNvgEAHYO1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAINLUGi9MfNQ_fkgn0JO-nCB6rSnRuNWpc8hYuiUi4tQ&oe=66D2F1E7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_NEW.png", "id": "986489218729347", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572932_986489225396013_2431188837476558669_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Um8mLAwkwxIQ7kNvgGdOzAn&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1RzDB9nKUhZ7yQVn_Ub6kBlAxmbaEL-QHd_Bs88lt5A&oe=66D3089B"}, "display_name": "HyperTunnel", "keywords": [], "long_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins.\n\nWe 3D scan a remote worksite and create an immersive digital twin. We use AI/ML to recognize and match specific objects found at the worksite, and augment the XR shared space with corresponding interactive 3D models. These interactive models are used by the experts, immersed in the VR digital twin, to guide and demonstrate how to perform tasks on-site. We also leverage the digital twins as immersive VR simulators for training.", "short_description": "HyperTunnel\u00ae enables multi-dimensional collaboration between frontline workers and experts on demand \u2013 from remote physical worksites to centralized immersive digital twins."}]}, "developer_name": "HyperTunnel", "developer_privacy_policy_url": "https://www.hypertunnel.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "HyperTunnel", "support_website_url": "https://hypertunnel.com/support/", "website_url": "http://www.hypertunnel.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "SIMULATION", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OC