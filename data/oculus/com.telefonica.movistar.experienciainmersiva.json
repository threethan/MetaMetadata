=scontent.oculuscdn.com&oh=00_AYBH1MbE7jNW5DO7wtoACcrNEH0NnuXXfRgvQAvWcF7jXQ&oe=66D2EF21"}, {"file_name": "MEI_ST_01.png", "id": "1901814646827773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031339_1901814650161106_1951514399351707783_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OtngsMQTkqYQ7kNvgGaSlEN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfKTwPCG1cdad8OYzUxFo9SAddU3dNqD-rnuITImYF-A&oe=66D2FF5C"}, {"file_name": "MEI_ST_03.png", "id": "1087459608802478", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001717_1087459612135811_6597245360675162064_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RlK3qtPbgi0Q7kNvgF3-Tsa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmaoi0SZo3JqLldQoV4BUsqyq62fqL3RlpwTMHKYQlcg&oe=66D2EC02"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma parte de los nuevos productos y servicios con los que queremos construir el camino hacia la Web3 y Metaverso.\n\nSi tienes cualquier duda puedes escribirnos a soporte.metaverso@telefonica.com", "short_description": "Sum\u00e9rgete desde casa en Movistar Experiencia Inmersiva y disfruta explorando, aprendiendo, jugando con tus gafas de realidad virtual."}, {"images": {"nodes": []}, "id": "644114173684727", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma parte de los nuevos productos y servicios con los que queremos construir el camino hacia la Web3 y Metaverso.\n\nSi tienes cualquier duda puedes escribirnos a soporte.metaverso@telefonica.com", "short_description": "Sum\u00e9rgete desde casa en Movistar Experiencia Inmersiva y disfruta explorando, aprendiendo, jugando con tus gafas de realidad virtual."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.telefonica.com/en/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Telef\u00f3nica Digital Espa\u00f1a, S.L.U", "support_website_url": null, "website_url": "https://www.telefonica.com/es/sala-comunicacion/telefonica-metaverse-day/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "c