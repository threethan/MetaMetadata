e7a0a&_nc_ohc=STarK7DslkwQ7kNvgHkogSE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBjsj3iDTSyr3kp1m_g6n414sfCuls45iehvUKJs726Kg&oe=6703DB12"}, {"file_name": "MEI_Movistar_09.png", "id": "620108139706198", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982586_620108143039531_4233661063633651236_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oSdSI6CAHJAQ7kNvgHIhjEM&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3c0TwgHiLGi7Uy2z8HDPiAQTt4EQCKAdc8Gf7sHiHJQ&oe=6703D36F"}, {"file_name": "MEI_Movistar_07.png", "id": "809803756700549", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036659_809803763367215_5931630997182381243_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pDwtcAxBGncQ7kNvgGT0DR7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALlNhSqWyuuQjDj74arA5z-SsIyaace-9O2w6ZHpF0xg&oe=6703B6A1"}, {"file_name": "MEI_ST_01.png", "id": "1901814646827773", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031339_1901814650161106_1951514399351707783_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vBVzXIawVgcQ7kNvgHWZ3HM&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD38lc7uNbm3LkMTrOgTngtol3EQxHFmyHRPF80XvieJg&oe=6703C6DC"}, {"file_name": "MEI_ST_03.png", "id": "1087459608802478", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001717_1087459612135811_6597245360675162064_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HijliZe57SUQ7kNvgFXioE7&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBl_UjXTuUMbcAG8xnd9fsx0QdmfYG86xqN5fNRn_eIFg&oe=6703B382"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma parte de los nuevos productos y servicios con los que queremos construir el camino hacia la Web3 y Metaverso.\n\nSi tienes cualquier duda puedes escribirnos a soporte.metaverso@telefonica.com", "short_description": "Sum\u00e9rgete desde casa en Movistar Experiencia Inmersiva y disfruta explorando, aprendiendo, jugando con tus gafas de realidad virtual."}, {"images": {"nodes": []}, "id": "644114173684727", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma par