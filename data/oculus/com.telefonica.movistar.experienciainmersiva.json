5360675162064_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-4wBG5UKBbgQ7kNvgGF3R6u&_nc_ht=scontent.oculuscdn.com&_nc_gid=A1JcI3WJyyiqPspy5Xy3WMn&oh=00_AYA55VolgEUYDZI315MrxbUvF2zMIrwzNjknnG3KnIbckg&oe=66F3E182"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma parte de los nuevos productos y servicios con los que queremos construir el camino hacia la Web3 y Metaverso.\n\nSi tienes cualquier duda puedes escribirnos a soporte.metaverso@telefonica.com", "short_description": "Sum\u00e9rgete desde casa en Movistar Experiencia Inmersiva y disfruta explorando, aprendiendo, jugando con tus gafas de realidad virtual."}, {"images": {"nodes": []}, "id": "644114173684727", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Movistar Experiencia Inmersiva", "keywords": [], "long_description": "Accede a Movistar Experiencia Inmersiva donde descubrir las experiencias y contenidos que hemos preparado para ti. Sum\u00e9rgete desde el sof\u00e1 de tu casa y descubre Movistar como hasta ahora no lo hab\u00edas hecho.\n\n\u00bfQu\u00e9 podr\u00e1s hacer en Movistar Experiencia Inmersiva?\n- Visita el rodaje de La Unidad, una de las series m\u00e1s emocionantes de Movistar Plus+.\n- Descubre el plat\u00f3 de La Resistencia como nunca lo viste.\n- Atr\u00e9vete a parar goles en #LaCasaDelFutbol.\n- Explora y sorpr\u00e9ndete por el colorista universo de Okuda.\n- Visita nuestra Sala Arco\u00edris de Stranger Things para demostrar cuanto sabes de la serie.\n\nY esto es solo el principio.\n\nSeas o no seas cliente de Movistar podr\u00e1s acceder a todo este contenido, porque\u2026 queremos que nos conozcas.\n\nEsta aplicaci\u00f3n est\u00e1 en modo beta y forma parte de los nuevos productos y servicios con los que queremos construir el camino hacia la Web3 y Metaverso.\n\nSi tienes cualquier duda puedes escribirnos a soporte.metaverso@telefonica.com", "short_description": "Sum\u00e9rgete desde casa en Movistar Experiencia Inmersiva y disfruta explorando, aprendiendo, jugando con tus gafas de realidad virtual."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.telefonica.com/en/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Telef\u00f3nica Digital Espa\u00f1a, S.L.U", "support_website_url": null, "website_url": "https://www.telefonica.com/es/sala-comunicacion/telefonica-metaverse-day/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "ART_CREATIVITY", "NEWS_AND_INFORMATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SIT