ted way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other. This package includes collection of 1 experiment.  This application supports two languages, Korean and English."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7267670216651456"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1057149129141104"}, {"status": "PUBLISHED", "id": "1443278506274210"}, {"status": "PUBLISHED", "id": "713810734300921"}, {"status": "PUBLISHED", "id": "415093534813638"}]}, "baseline_offer": {"id": "1057149129141104"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727851801, "status": "PUBLISHED", "id": "1057149129141104"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7443291079089368", "version": "1.3"}, "id":