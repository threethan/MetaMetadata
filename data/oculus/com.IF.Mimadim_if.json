sy-to-use interface for seamless design exploration.\n\n- Wide selection of ceramic tiles and house tiles to choose from.\n\n- Realistic 3D rendering for a true-to-life visualization.\n\n- Customize tile layouts and patterns to suit your preferences.\n\n- Save and share your designs with others for feedback.\n\n- Perfect for homeowners, interior designers, and tile manufacturers.\n\n- Enhance your design process and make confident decisions about tile selection.\n\n- Experience your space in a whole new way with Mimadim Visualize.", "short_description": "Mimadim Visualize is a cutting-edge software that allows you to visualize ceramic tiles and house tiles on your walls in stunning 3D."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.mimadim.co.il/PPolicy_English.html", "developer_terms_of_service_url": null, "publisher_name": "Mimadim - Tiran Naor", "support_website_url": null, "website_url": "http://www.mimadim.co.il/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "he"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8545097775517925"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1532670777646078"}]}, "baseline_offer": {"id": "1532670777646078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716920400, "status": "PUBLISHED", "id": "1532670777646078"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": 