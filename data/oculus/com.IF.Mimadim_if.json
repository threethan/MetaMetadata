lection.\n\n- Experience your space in a whole new way with Mimadim Visualize.", "short_description": "Mimadim Visualize is a cutting-edge software that allows you to visualize ceramic tiles and house tiles on your walls in stunning 3D."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.mimadim.co.il/PPolicy_English.html", "developer_terms_of_service_url": null, "publisher_name": "Mimadim - Tiran Naor", "support_website_url": null, "website_url": "http://www.mimadim.co.il/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "he"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8545097775517925"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1532670777646078"}]}, "baseline_offer": {"id": "1532670777646078"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716920400, "status": "PUBLISHED", "id": "1532670777646078"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8683913984969636", "version": "0.8"}, "id": "895832192312514", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8545097758851260", "is_concept": false, "latest_released_binary": {"__typename": "AndroidB