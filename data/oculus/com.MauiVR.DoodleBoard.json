n.com&oh=00_AYAJQISvoP_oEU4ei9sAKkyBb5DPCjO_FG87iwpAPlQn0w&oe=67850E54"}, {"file_name": "DoodleWordsScreenshot.png", "id": "570013131772090", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031447_570013138438756_2157245059469094949_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cudItbdRgLMQ7kNvgE5mQwG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2lKOWybMiW4tOuv-RD3C4oxs5fpKKI-H73HcYHo5hFw&oe=67851579"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MauiVR Trailer Cover.png", "id": "772966444056584", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036646_772966450723250_6763369787447709840_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=__IeL8ZMrKYQ7kNvgEwW4y5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCr71aFR38seFKygG81SKtrjzaqDaqrDSvNf-K-1RvZA&oe=6784FC92"}, "display_name": "Doodle Board", "keywords": [], "long_description": "Doodle Board is the fastest & simplest way to start doodling! Use triggers on both hands to pick a color and brush width. Many users like it best when they cast Doodle Board to a nearby screen so that a friend or relative can watch along, or call out guidance on what to doodle next.\n\nWith intuitive controls and no complicated submenus, Doodle Board is a great way for novice VR users to begin their VR journey. And with infinite ink & zero cleanup, Doodle Board is a great way to let your imagination go wild, or to idly occupy your hands & eyes while you're daydreaming about a fun idea.", "short_description": "The fastest & simplest way to start doodling! Private, safe, and fun : ) "}]}, "developer_name": null, "developer_privacy_policy_url": "https://mauivr.substack.com/p/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MauiVR", "support_website_url": null, "website_url": "https://mauivr.substack.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"},