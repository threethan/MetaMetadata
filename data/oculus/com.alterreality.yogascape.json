name": "Screenshot3.png", "id": "1008502397537962", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931336_1008502400871295_1206121958939204588_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5TLK_oRvP_UQ7kNvgH0dm00&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2YGJV85qzHctWaNHqoKSYTGqaFnlo9RIAG0t6ts7aCw&oe=6731FA11"}, {"file_name": "Screenshot1.png", "id": "356830833706562", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974758_356830840373228_7136670726977145828_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pZ6C_8Pl-fEQ7kNvgEuvQ_h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAgUws2DPa9HAFGBpvg74Wb6G_LUUB6qETt-pEfyk7nOA&oe=67320574"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "YogaScape", "keywords": [], "long_description": "Welcome to YogaScape, the revolutionary VR yoga app designed to elevate your practice. Step into breathtaking virtual environments, from serene beaches to tranquil mountaintops, and experience yoga like never before. Whether you're a beginner or a seasoned yogi, YogaScape offers a diverse range of sessions led by expert instructors to suit all levels.\n\nYogaScape is more than just a workout; it's a journey to inner peace and well-being. Whether you seek to improve your flexibility, reduce stress, or simply find a moment of calm, YogaScape is your sanctuary. Download YogaScape today and discover the transformative power of virtual reality yoga.\n\nFind your zen in YogaScape. Your path to tranquility starts here.", "short_description": "Immerse yourself in YogaScape, the ultimate VR yoga experience. Practice yoga in stunning virtual environments, guided by expert instructors. Perfect for all levels. Find your zen with YogaScape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/dc3c2ed3-5743-40d6-a202-91a65f2a7f12", "developer_terms_of_service_url": null, "publisher_name": "AlterReality", "support_website_url": null, "webs