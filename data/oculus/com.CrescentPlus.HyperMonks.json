cdn.com&oh=00_AYAK8Qn9TgXCDtUu5pVfArVZc0IcbN1hQbvvmP8VVSvQgg&oe=66FE7325"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hyper Monks 3", "keywords": [], "long_description": "Hyper Monks 3 is an immersive VR game that transports you to an underground Japanese metropolis set in the future. Play as a monkey navigating the vibrant and bustling world of HyperCity, a futuristic city inspired by Tokyo. Experience a variety of activities, from riding the metro transit to exploring the neon-lit streets, shopping in the expansive mall, or playing games in the lively arcade. When hunger strikes, indulge in delectable cuisine at local eateries like the Sushi Shop, Ramen Shop, and cozy cafes. Embrace the freedom to follow your own path and discover the way of the Hyper Monk in this dynamic and captivating virtual world.", "short_description": "Hyper Monks 3 is a thrilling VR game where you embody a monkey exploring a futuristic underground Japanese metropolis, HyperCity. Ride the metro, play arcade games, shop in a massive mall, and savor delicious cuisine from sushi to ramen. Discover your own path as you immerse yourself in this dynamic world full of adventure and surprises!"}]}, "developer_name": "HyperLabs", "developer_privacy_policy_url": "https://hypermonks-com.webnode.page/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Peeled", "support_website_url": null, "website_url": "https://hypermonks-com.webnode.page/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en