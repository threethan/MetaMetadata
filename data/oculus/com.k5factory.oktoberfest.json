_name": "Oktoberfest", "keywords": [], "long_description": "The world's most famous and oldest folk festival - the Munich Oktoberfest - is all about fun and socializing. Munich Oktoberfest - The Official Game brings these aspects into virtual reality as the worlds first social VR fun fair. Here it is possible to explore a virtual version of the festival together with friends and players from all over the world.\n\nJoin the virtual Oktoberfest to interact with other players, play hilarious multiplayer games and experience the true atmosphere of the Oktoberfest. Have fun working as a beer hall employee to earn your place in the hall of fame as quickest bartender or experience the spectacular motion rides together with your friends.\n\nOf course authentic dressing in Bavarian costumes for your virtual Oktoberfest visit is also possible! So get your Lederhosen or Drindl ready and join the fun today!", "short_description": "The world's most famous and oldest folk festival - the Munich Oktoberfest - is all about fun and socializing. Munich Oktoberfest - The Official Game brings these aspects into virtual reality as the worlds first social VR fun fair. Here it is possible to explore a virtual version of the festival together with friends and players from all over the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oktoberfest.game/en/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory", "support_website_url": null, "website_url": "https://www.oktoberfest.game/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_proces