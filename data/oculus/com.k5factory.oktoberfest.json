OSlYvPRrmYwakshuseGdQ&oe=6752DEFE"}, {"file_name": "AlpinaBahn.png", "id": "871471758433220", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982518_871471761766553_7516419959061080131_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WuWneDtL7vYQ7kNvgFKKIsh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHKsy_8NGi-VPcEy8TIOi2ZastQHgsEw5z7gpvS9xW_g&oe=6752C942"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "1198000661523621", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575358_1198000664856954_4543690135708053962_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W4XmC6Q-yXMQ7kNvgFK0kMm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1RWCSF0qPbAd5_UJKnW4YYztkkoDS9z5syAYY-3P15A&oe=6752DF30"}, "display_name": "Oktoberfest", "keywords": ["party", "multiplayer", "funfair", "minigames", "customization"], "long_description": "New Update is Here!\n\n\ud83c\udf89 Support Oktoberfest and unlock exclusive rewards\nHelp bring more attractions and features to life! With gems, you can access exclusive clothing items, like the diamond outfit. Your support directly helps us grow and improve the game!\n\n\ud83d\udc52 New hats \nChoose from classic styles like the cowboy hat or builder\u2019s helmet, festive sombreros and stocking caps, or quirky picks like the propeller cap, bunny ears, and adorable animal companions.\n\n\ud83c\udfae Improved Player-to-Player Games\nConnecting with friends is easier than ever! Approach a player, click the dice icon near their nametag, and choose between \u201cClap It\u201d or \u201cRock-Paper-Scissors.\u201d\n\n\ud83c\udf1f Discord exclusive silver outfit\nChat, invite, and boost our server to earn XP. Reach Level 10 to unlock the stylish silver outfit and show your dedication!\n\nStep into the world of Oktoberfest, enjoy exciting new content, and help shape the future of the game! \n\nDon\u2019t forget to join our Discord for exclusive perks https://discord.com/invite/bFVrUEM9Cq ", "short_description": "New update: discover the exciting content we\u2019ve crafted just for you!\n\n\ud83d\udc57 New Outfits & Hats \nShine with the Diamond outfit, stay sleek in the Tuxedo, or stand out in the Mushroom outfit. Plus, quirky hats like bunny ears and festive caps!\n\ud83c\udfae P2P Games\nStart \u201cClap It\u201d or \u201cRock-Paper-Scissors\u201d with ease.\n\ud83d\udc8e Support & Shine\nUnlock exclusive outfits with gems to help Oktoberfest grow!\n\nPlay now and join our Discord for unique rewards! \ud83c\udf89\nhttps://discord.com/invite/bFVrUEM9Cq "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oktoberfest.game/en/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.oktoberfest.game/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8798758566872987"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974821_3882114092103890_4910323915422210709_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GyhT-mVS_L0Q7kNvgFl9UXb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjSU1SbXSNUOmF5omQWOyqFt71OnP377gL16Y3oUYY-w&oe=6752DD1A"}, "is_concept": false, "is_test": false, "is_trial_