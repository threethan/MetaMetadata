i": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974796_1040534940894749_3919982509523642003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bbWur1r5YhoQ7kNvgHkFwM0&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCpTr_nH57VGSHA2YBl3QtE8kw00vuTxNnJTp7OQm5CQg&oe=672627E1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "1198000661523621", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57575358_1198000664856954_4543690135708053962_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rmeqrTWI9tgQ7kNvgHaMDgl&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDmI2tmUmwUu_XR7SKuBBs2mZB9133Qb-7KViEtOvuRkw&oe=67260C30"}, "display_name": "Oktoberfest", "keywords": ["party", "multiplayer", "funfair", "minigames", "customization"], "long_description": "EARLY ACCESS\n\nDive into the ultimate VR fun fair game, bringing the excitement and social buzz of the original Munich Oktoberfest right to your home. Be among the first to explore this virtual wonderland!\n\nKey Features:\n\ud83c\udfaf Fairground Games: Engage in gun shooting, ball throwing, and catapult games.\n\ud83c\udfa2 Virtual Motion Rides: Experience thrilling rides with realistic motion effects.\n\ud83d\udc55 Avatar Customization: Personalize your look with traditional Bavarian outfits and accessories.\n\ud83d\udee0\ufe0f Physics-Based Interactions: Enjoy realistic interactions with objects and games.\n\ud83c\udfa4 Social Game: Communicate with other players through integrated voice chat and enjoy new 2-player rhythm games.\n\ud83c\udfba Trombone Simulator: Show off your musical skills and start own in-game band.\n\ud83c\udf79 Bartending Game: Test your time management skills in an exciting bartending game.\n\nGame Modes:\n\ud83d\udd79\ufe0f Single-Player: Enjoy the festival at your own pace.\n\ud83c\udfae Multiplayer: Join others in real-time for shared fun and competition.\nProgression and Rewards:\n\ud83c\udfc5 Leaderboards: Compete for the highest scores and see how you stack up against others.\n\ud83c\udfc6 Achievements: Unlock rewards for your accomplishments.\n\ud83c\udf81 Avatar Item Rewards: Earn unique items to further customize your avatar.\n\nSo, gear up, explore the bustling fairgrounds, and let the festivities begin! Join the closed beta today and be a part of the fun and socializing at Oktoberfest - The Official Game! \n\nSocials & webpage https://linktr.ee/oktoberfestgame \n", "short_description": "EARLY ACCESS\n\nDive into the ultimate VR fun fair game, bringing the excitement of Munich\u2019s Oktoberfest to your home! \ud83c\udfaf Play fairground games, experience thrilling virtual rides, customize your avatar with Bavarian outfits, and enjoy realistic physics-based interactions. Join single or multiplayer modes, compete on leaderboards, and earn rewards. Gear up and let the festivities begin at Oktoberfest - The Official Game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oktoberfest.game/en/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.oktoberfest.game/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8573528079396038"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.co