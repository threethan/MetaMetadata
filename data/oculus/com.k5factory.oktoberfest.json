_name": "AlpinaBahn.png", "id": "871471758433220", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982518_871471761766553_7516419959061080131_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ul1jb_8I1VkQ7kNvgElnZRB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAQBsDPDPM8aus0kfVbCZBt5iy7GRtnxZp_UYLAbIOtow&oe=67405442"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "1198000661523621", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57575358_1198000664856954_4543690135708053962_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TRYM82Uy2kIQ7kNvgFnk9a0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA3xs5Pnn3mL_hXSML5cKb419I6txGq-rokwRHWa2iu3g&oe=67406A30"}, "display_name": "Oktoberfest", "keywords": ["party", "multiplayer", "funfair", "minigames", "customization"], "long_description": "Dive into the ultimate VR funfair experience and bring the excitement of Munich's Oktoberfest to life right from your home. Get ready for a fresh update packed with new adventures and rewards!\n\nWhat\u2019s New:\n\ud83c\udfa2 New Ride - Alpina Bahn\nTake on thrilling twists and turns in this brand-new ride, just added!\n\ud83c\udfb6 2 New Songs in Brass Band Hero\nKeep the music going with our latest song additions for even more rhythm challenges.\n\ud83d\udc55 Community Choice T-Shirt\nCheck your owned items for an exclusive T-shirt, designed by player votes.\n\nKey Features:\n\ud83c\udfaf Fairground Games\nTest your skills with gun shooting, ball throwing, and catapult games.\n\ud83c\udfa2 Virtual Motion Rides\nFeel the thrill of realistic motion on various rides.\n\ud83d\udc55 Avatar Customization\nDress your avatar in Bavarian outfits and unique, unlockable items.\n\ud83d\udee0\ufe0f Physics-Based Interactions\nExperience realistic gameplay with lifelike object handling.\n\ud83c\udfa4 Social Game\nConnect with friends or meet new players through integrated voice chat and two-player rhythm games.\n\ud83c\udfba Brass Band Hero\nJoin the band or go solo in our trombone simulator.\n\ud83c\udf79 Order Rush\nTest your bartending skills in a fast-paced game of service.\n\nPlay solo to explore the festival at your own pace, or jump into multiplayer for fun with others! Join our Discord to connect, share tips & tricks, and unlock exclusive rewards https://discord.com/invite/bFVrUEM9Cq ", "short_description": "New Update: Oktoberfest Fun Awaits!\n\nBring the thrill of Munich\u2019s Oktoberfest to your home in VR! Enjoy the latest update, packed with fresh rides, games, and exclusive rewards:\n\n\ud83c\udfa2 New Ride - Alpina Bahn: Feel the excitement on this thrilling addition!\n\ud83c\udfb6 Brass Band Hero: Jam to 3 new songs in the rhythm game.\n\ud83d\udc55 Community Choice T-Shirt: Rock the new shirt design p by our players.\n\nPlay solo or join friends for a shared experience, and don\u2019t miss our Discord for exclusive rewards and tips! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oktoberfest.game/en/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "K5 Factory GmbH", "support_website_url": null, "website_url": "https://www.oktoberfest.game/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8660761224006056"}, "review_messages": [""]}]}, "cover_square_image": {"uri":