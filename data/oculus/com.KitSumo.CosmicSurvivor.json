6296279_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Na7Ly8IxousQ7kNvgEgGJMQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhDtL9WZo1Jei1h9buQ_xEv-g9EY9Cg0_zPyM4VAwmtw&oe=6714EF21"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CosmicSurvivorGlimpse1080_Moment.png", "id": "1174756509926194", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031425_1174756513259527_6009818579401571909_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ub0Szga95ckQ7kNvgHltgHG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXfU7RUuWUB0E2idTk8UrgzbZPEv2hMForDwbmS7DXJg&oe=6714F369"}, "display_name": "Cosmic Survivor", "keywords": [], "long_description": "It's a classic arcade game but built for VR. Simple thumbstick movement controls your ship. Auto-fire by default, the trigger and grip perform specials.\n\nHorde like gameplay where the enemy becomes more challenging over time. Collect power-ups to stay ahead. Target game length is five minutes but infinite play possible.\n\nThis is a concept demo. It's envisioned a final game would have unlockable ships, roguelike upgrades, regional high-scores, music and an art pass. ", "short_description": "Retro horde/survival arcade game set in SPACE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kitsumogames.com/home/privacy-policy-cosmic-survivor", "developer_terms_of_service_url": null, "publisher_name": "Kit Sumo", "support_website_url": null, "website_url": "https://www.kitsumogames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "suppo