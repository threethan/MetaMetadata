": "1963088224082487", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982601_1963088230749153_1014626379170200780_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qi74RZsmlc0Q7kNvgFoHN0J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfd-uZOl4vpuODsR7ThbCR5GX4gGF4OvyTkZYgL8R2ow&oe=6745AD76"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImageC904.png", "id": "683843556446030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974459_683843559779363_3640918360946738207_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tcw573USHWAQ7kNvgFR3UcL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3oKXbXSv4EH_OkoIiG4ouxlqCf9Q9orr594p_WmT__w&oe=6745AFD8"}, "display_name": "Cosmic Survivor", "keywords": [], "long_description": "Blast the polygon alien horde and claim your place in the Hall of Heroes! Cosmic Survivor is an intense, survival shoot 'em up with roguelite elements, where your skill is on trial and the horde is always waiting.\n\nSit in comfort and play with a single controller as the game world surrounds you. Features a short game loop with rising intensity. Learn the best survival strategy or upgrade your ship over time to climb the global leaderboard.", "short_description": "A brutal, roguelite, arcade shoot 'em up with kick-ass 8bit beats."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kitsumogames.com/home/privacy-policy-cosmic-survivor", "developer_terms_of_service_url": null, "publisher_name": "Kit Sumo", "support_website_url": null, "website_url": "https://www.kitsumogames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection":