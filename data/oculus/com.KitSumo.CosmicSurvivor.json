736296279_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fBFXg-bdBNYQ7kNvgE6N2uU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCOF90Li7fgMzxfAGwseJeNEmbeVmxoZ_r6B4dEYK9qkw&oe=67810A21"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CosmicSurvivorGlimpse1080_Moment.png", "id": "1174756509926194", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031425_1174756513259527_6009818579401571909_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mJAbmC4DTD4Q7kNvgHTbipW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDTm-dyGEQ3gy65g1oLppfbE1fyWltCu_ebRmdyAb99PA&oe=67810E69"}, "display_name": "Cosmic Survivor", "keywords": [], "long_description": "It's a classic arcade game but built for VR. Simple thumbstick movement controls your ship. Auto-fire by default, the trigger and grip perform specials.\n\nHorde like gameplay where the enemy becomes more challenging over time. Collect power-ups to stay ahead. Target game length is five minutes but infinite play possible.\n\nThis is a concept demo. It's envisioned a final game would have unlockable ships, roguelike upgrades, regional high-scores, music and an art pass. ", "short_description": "Retro horde/survival arcade game set in SPACE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kitsumogames.com/home/privacy-policy-cosmic-survivor", "developer_terms_of_service_url": null, "publisher_name": "Kit Sumo", "support_website_url": null, "website_url": "https://www.kitsumogames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb":