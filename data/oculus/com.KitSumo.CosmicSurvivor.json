230749153_1014626379170200780_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BlrwgQBimNEQ7kNvgF0cJZo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABKMqA-U-JC3MymajwBVdKYMoy9-9c5oy_WXhcm_wjwQ&oe=67066576"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImageC904.png", "id": "683843556446030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974459_683843559779363_3640918360946738207_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Knn3-nD1HbcQ7kNvgGWB_NJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSAMuxaT0tNsfOk-VNjgztce7AoDuj-iF80-D-jaQJpQ&oe=670667D8"}, "display_name": "Cosmic Survivor", "keywords": [], "long_description": "Blast the polygon alien horde and claim your place in the Hall of Heroes! Cosmic Survivor is an intense, survival shoot 'em up with roguelite elements, where your skill is on trial and the horde is always waiting.\n\nSit in comfort and play with a single controller as the game world surrounds you. Features a short game loop with rising intensity. Learn the best survival strategy or upgrade your ship over time to climb the global leaderboard.", "short_description": "A brutal, roguelite, arcade shoot 'em up with kick-ass 8bit beats."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kitsumogames.com/home/privacy-policy-cosmic-survivor", "developer_terms_of_service_url": null, "publisher_name": "Kit Sumo", "support_website_url": null, "website_url": "https://www.kitsumogames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended