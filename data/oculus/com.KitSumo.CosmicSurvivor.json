isplay_name": "Cosmic Survivor", "keywords": [], "long_description": "It's a classic arcade game but built for VR. Simple thumbstick movement controls your ship. Auto-fire by default, the trigger and grip perform specials.\n\nHorde like gameplay where the enemy becomes more challenging over time. Collect power-ups to stay ahead. Target game length is five minutes but infinite play possible.\n\nThis is a concept demo. It's envisioned a final game would have unlockable ships, roguelike upgrades, regional high-scores, music and an art pass. ", "short_description": "Retro horde/survival arcade game set in SPACE"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.kitsumogames.com/home/privacy-policy-cosmic-survivor", "developer_terms_of_service_url": null, "publisher_name": "Kit Sumo", "support_website_url": null, "website_url": "https://www.kitsumogames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "739194897456715"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1321188458681340"}, {"status": "PENDING", "id": "370609094867348"}]}, "baseline_offer": {"id": "1321188458681340"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1670522400, "status": "PUBLISHED", "id": "1321188458681340"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"n