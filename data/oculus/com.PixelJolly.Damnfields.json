8755386997252617318_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JUjNQRAu8sQQ7kNvgFH6_NB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANVrtUP4H1jifqApGpWT4r9&oh=00_AYAo34r_s-lpTzS8mVaMOF7g6DR7NVH9GuDyfu8BeclEag&oe=66E020BB"}, {"file_name": "damnfields_screenshot_4.png", "id": "695355846136537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223483_695355849469870_4916025199314149793_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o1cu9YCY9V4Q7kNvgEi_oar&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANVrtUP4H1jifqApGpWT4r9&oh=00_AYDPMaGl3OY3x5LRRWnndmiOLKPksOm6F-jF5WELnNY_ew&oe=66E01866"}, {"file_name": "damnfields_screenshot_5.png", "id": "754811223260508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_754811229927174_1775564479522726241_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XenH9GOBjK4Q7kNvgFaogvE&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANVrtUP4H1jifqApGpWT4r9&oh=00_AYAy4QlqhIaRSt9xrVCFjc51jm414QNJcg2WqpK1nae4Nw&oe=66E01A5F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Damnfields", "keywords": [], "long_description": "With Damnfields you will get lost in a fun, engaging and challenging action/puzzle game, where you will have to use your head alone to complete all the levels.\n\nMaster all the four game modes (Defuse, Antagonists, Maze and Nature) before entering the DAMNfields, which you will have to complete before the time expires!\n\nAnd if you manage to complete the game, you will unlock something that will make you want to play it again!\nIn fact, Damnfields is perfect to challenge yourself and to speedrun!\n\nThis game is a love letter to the 80s and 90s golden era of videogames: if you enjoy challenging games and/or you are a fan of pixel-art and chiptune music, this game is definitely for you!\n\nDamnfileds was picked from stellar judges (including the legendary John Carmack) as one of the finalists in the Oculus Mobile VR Jam, in 2015.", "short_description": "The 2015 Mobile VR Jam finalist is back on Quest 3!\n\nImmerse yourself in pixel-art and chiptune music with this addictive action/puzzle game, where you will have to gaze your way around challenges in order to escape...the Damnfields!"}]}, "developer_name": "Marco Colombo", "developer_privacy_policy_url": "https://www.pixeljolly.com/damnfields-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Marco Colombo", "support_website_url": null, "website_url": "https://www.facebook.com/damnfields", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7338558826205436"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "400863022468474"}]}, "baseline_offer": {"id": "400863022468474"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1708108080, "status": "PUBLISHED", "id": "400863022468474"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7340180599376592", "version": "1.07"}, "id": "368698272545522", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7307131949348124", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7340180