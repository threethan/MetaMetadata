ding.\n- Prepare for an emotional ride. The story is full of heart-warming and uplifting moments.", "short_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 25-30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset.\nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lunavrstory.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "N/A", "support_website_url": null, "website_url": "https://www.lunavrstory.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "238737061781735"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "284480616898778"}]}, "baseline_offer": {"id": "284480616898778"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1637168400, "status": "PUBLISHED", "id": "284480616898778"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8636604683080450", "version": "1.0.6"}, "id": "189634766606793", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "bi