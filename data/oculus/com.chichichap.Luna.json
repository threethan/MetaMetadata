ailer": null, "video_trailer_thumbnail": {"file_name": "Luna EP1 Cover Landscape v2.png", "id": "821544355823057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974734_821544359156390_3704906447816136634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJXp-SjM6k0Q7kNvgFTYnfC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNxI_9PQUAeCTm-Zz6DuTSl_QthgTGA2eZxG7EBpozBw&oe=6707CC48"}, "display_name": "Luna: Episode 1 - Left Behind", "keywords": [], "long_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset.\nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?\n\nFeatures:\n- Talk to the characters. LUNA uses speech recognition to help you immerse in the story and connect with the characters. \n- Dialogue options will guide you through the story while letting you make meaningful decisions that impact the ending.\n- Prepare for an emotional ride. The story is full of heart-warming and uplifting moments.\n\nOfficial Selection - Cannes XR 2022          \nOfficial Selection - Kaohsiung Film Festival 2022\nRanked #7 in Best Rated Quest Games in App Lab by RoadToVR", "short_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset. \nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lunavrstory.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "N/A", "support_website_url": null, "website_url": "http