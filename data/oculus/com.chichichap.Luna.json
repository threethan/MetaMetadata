svgQ7kNvgGTf7P8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxHZFThmzh9mHZbrjYRrLaq&oh=00_AYA0yZrpCWY6Fwz74xHjhVaM3Q-BAgc8fpE6fmEJZ7gGBg&oe=66F3F791"}, {"file_name": "5.png", "id": "448664973344454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_448664976677787_7874428069256012100_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-o57vIebGYQ7kNvgFU4a9y&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxHZFThmzh9mHZbrjYRrLaq&oh=00_AYCnvscHbwuqSFJjuN0I4IgsBkSgMZu_CXXa9r2ceRGsGQ&oe=66F3E601"}, {"file_name": "4.png", "id": "387006086415763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001668_387006089749096_4480503597991377979_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0gubabpDTFcQ7kNvgE6uejP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxHZFThmzh9mHZbrjYRrLaq&oh=00_AYCgPXuT5IX4ylXDhhyZFYS7IyyhfmRtBElzyFqJGXKeeQ&oe=66F3E2A0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Luna EP1 Cover Landscape.png", "id": "2120245951456670", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_2120245954790003_5966831534778103198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbwUNsBqV7oQ7kNvgHnFOWD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxHZFThmzh9mHZbrjYRrLaq&oh=00_AYB5US61LHj0P9kf6M52yL3MeyeUhEF1yV16cLrhvFV76w&oe=66F3E8E6"}, "display_name": "Luna: Episode 1 - Left Behind (DEMO)", "keywords": [], "long_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 25-30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset.\nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?\n\nFeatures:\n- Talk to the characters. LUNA uses speech recognition to help you immerse in the story and connect with the characters. \n- Dialogue options will guide you through the story while letting you make meaningful decisions that impact the ending.\n- Prepare for an emotional ride. The story is full of heart-warming and uplifting moments.", "short_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 25-30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset.\nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lunavrstory.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "N/A", "support_website_url": null, "website_url": "https://www.lunavrstory.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "238737061781735"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "284480616898778"}]}, "baseline_offer": {"id": "284480616898778"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1637168400, "status": "PUBLISHED", "id": "284480616898778"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8636604683080450", "version": "1.0.6"}, "id": "189634766606793", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidB