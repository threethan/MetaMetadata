79_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o5Lms4n3jHEQ7kNvgE8PmK8&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i4o4PS-Jrp2Xk22LH_Yve&oh=00_AYCzPU-FodcD6fryYHZlxyAM2zoWyhOpqG4F9PnnxlkZTg&oe=66ED4B20"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Luna EP1 Cover Landscape v2.png", "id": "821544355823057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_821544359156390_3704906447816136634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5WKrYIyZv3oQ7kNvgHD1K47&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i4o4PS-Jrp2Xk22LH_Yve&oh=00_AYC5pLpoK9tDgryG0dLcOnn2c_d6b3Slg0Md4Pxf0KILBw&oe=66ED6E48"}, "display_name": "Luna: Episode 1 - Left Behind", "keywords": [], "long_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset.\nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?\n\nFeatures:\n- Talk to the characters. LUNA uses speech recognition to help you immerse in the story and connect with the characters. \n- Dialogue options will guide you through the story while letting you make meaningful decisions that impact the ending.\n- Prepare for an emotional ride. The story is full of heart-warming and uplifting moments.\n\nOfficial Selection - Cannes XR 2022          \nOfficial Selection - Kaohsiung Film Festival 2022\nRanked #7 in Best Rated Quest Games in App Lab by RoadToVR", "short_description": "LUNA: EPISODE 1 - LEFT BEHIND is a 30 minute interactive VR story about an android and a little girl trying to survive an AI apocalypse. The machines seem to be after only one goal: to exterminate its creators. \n\u200b\nYou, a small commercial droid, wake up and find your system to be reset. \nCan you, a droid with no combat capabilities, protect Luna? Can humanity be saved?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lunavrstory.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "N/A", "support_website_url": null, "website_url": "https://www.lunavrstory.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26347205301593782"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982530_555311359927364_7411979958589393225_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sctB9XB0OiUQ7kNvgHmDdzj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i4o4PS-Jrp2Xk22LH_Yve&oh=00_AYBRkLg9l7JvOxorck_QFTmIDkERaYwO7X_Az5R_zry8oA&oe=66ED78A1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Luna: Episode 1 - Left Behind", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Interactive Story", "id": "3771364559549515"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1637168400, "lastRevision": {"nodes": [{"id": "1290797201354200", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6034707799936831", "is_first_party": false, "enable