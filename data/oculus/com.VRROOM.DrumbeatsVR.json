=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBQu3AsJGtx6mtS4xp0btr7CDDjoQ0lbUK92js-6HmRYA&oe=67581740"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailerprev.png", "id": "978077019671638", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982441_978077023004971_2328662040582874456_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1MF_1_JqiAQ7kNvgEv6ayr&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBf4-4O5nXJBP7ppEaABDGpuc2sBW9Pzu-CtilYznVFqw&oe=67583E36"}, "display_name": "DrumBeats VR", "keywords": ["Drum", "Beat", "Rhythm"], "long_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! \n\nYour driving rhythm makes you the heartbeat of every song you play. With a setlist of sixteen tracks and more on the way, you can jam along to your favorite tunes and feel like a true member of the band.\n\nPlay in **epic** scenes that will transport you to otherworldly locations.\nFrom the comfort of your own home, you can play in a Studio, descend into Hell, explore the depths of the ocean floor, brave the frozen tundra of Antarctica, and even drum on the moon!\n\n\n# Scenes:\n- Haunted Asylum\n- Drum Studio\n- Antarctica\n- Hell\n- Bottom of the Ocean\n- The Moon\n- Synthwave\n\n# Drum kits:\n- Rock Kit (it's setup is fully customizable)\n- Lefty Rock Kit  (it's setup is fully customizable)\n- Metallica (sound and setup)\n- The Rolling Stones (sound and setup)\n\n\n# Game Modes:\n**Arcade**\n\nPlay along with our custom made songs\n\n\n**Free play**\n\nPlay on the drum kits and environments listed above however you like\n\n**Custom**\n\nYou can import custom songs into the game so you can expand the setlist with your own songs.", "short_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! With your driving rhythm you become the backbone of every song you play. With a setlist of twelve songs and more on the way, you can play along to your favorite tunes and feel like you're part of the band.\n"}]}, "developer_name": "Marcel Eissens || VRROOM", "developer_privacy_policy_url": "https://drumbeatsvr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "MESHm", "support_website_url": null, "website_url": "https://www.drumbeatsvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27567986679513969"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974721_1979982168822893_6236178335275796574_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xH7v9HZv_5UQ7kNvgFey_ES&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD7hMHChenXQWdeX_rUaLudV44ZAaGbHzJDA9U5wFO1Yw&oe=67581AEA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DrumBeats VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Rhythm", "id": "1672577396871977"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1638226800, "lastRevision": {"nodes": [{"id": "2649381722029948", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "59371