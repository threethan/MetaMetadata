er": null, "video_trailer_thumbnail": {"file_name": "Trailerprev.png", "id": "978077019671638", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982441_978077023004971_2328662040582874456_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O26VZBTwASMQ7kNvgHDq8iW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAYrx18rPtzbXU7_oQhhk1QwpVGhyJGcL9tREGX6lDt_g&oe=67013B36"}, "display_name": "DrumBeats VR", "keywords": [], "long_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! With your driving rhythm you become the backbone of every song you play. With a setlist of twelve songs and more on the way, you can play along to your favorite tunes and feel like you're part of the band.\n\nPlay in epic scenes that will transport you to otherworldly locations.\nFrom the comfort of your own home, you can play in a Studio, descend into Hell, explore the depths of the ocean floor, brave the frozen tundra of Antarctica, and even drum on the moon!\n\nScenes:\nDrum Studio\nAntarctica\nHell\nBottom of the ocean\nThe moon\n\nDrum kits:\nBasic Rock Kit\nMetallica (sound and setup)\nThe Rolling Stones (sound and setup)\n\nFree play\nPlay on the drum kits and environments listed above however you like\n\nArcade\nPlay along with our custom made songs\n\nCustom\nYou can import custom songs into the game so you can expand the setlist with your own songs (guide on applab).", "short_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! With your driving rhythm you become the backbone of every song you play. With a setlist of twelve songs and more on the way, you can play along to your favorite tunes and feel like you're part of the band.\n"}]}, "developer_name": "Marcel Eissens || VRROOM", "developer_privacy_policy_url": "https://drumbeatsvr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "MESHm", "support_website_url": null, "website_url": "https://w