=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApzyRmGND8aRmLrM7r_K1vbNAAXqf0T64Fh3Tje3-uKw&oe=678398C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "quest-update.png", "id": "9578478005544344", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_9578478015544343_4355011210598936222_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T0Y892icFzsQ7kNvgEuM6Uu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-R8ITH4S42n26pl1gO8iCbeFnXBPUH_3Tjiax8-33ag&oe=67838FAD"}, "display_name": "DrumBeats VR", "keywords": ["Drum", "Beat", "Rhythm"], "long_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! \n\nYour driving rhythm makes you the heartbeat of every song you play. With a setlist of 21 tracks and more on the way, you can jam along to your favorite tunes and feel like a true member of the band.\n\nPlay in **epic** scenes that will transport you to otherworldly locations.\nFrom the comfort of your own home, you can play in a Studio, descend into Hell, explore the depths of the ocean floor, brave the frozen tundra of Antarctica, and even drum on the moon!\n\n\n# Scenes:\n- Haunted Asylum\n- Drum Studio\n- Antarctica\n- Hell\n- Bottom of the Ocean\n- The Moon\n- Synthwave\n\n# Drum kits:\n- Rock Kit (it's setup is fully customizable)\n- Lefty Rock Kit  (it's setup is fully customizable)\n- Metallica (sound and setup)\n- The Rolling Stones (sound and setup)\n\n\n# Game Modes:\n**Arcade**\n\nPlay along with our custom made songs\n\n\n**Free play**\n\nPlay on the drum kits and environments listed above however you like\n\n**Custom**\n\nYou can import custom songs into the game so you can expand the setlist with your own songs.", "short_description": "DrumBeats VR is a drumming music game for VR. Play on iconic drumkits and play in epic scenes! With your driving rhythm you become the backbone of every song you play. With a setlist of 21 songs and more on the way, you can play along to your favorite tunes and feel like you're part of the band.\n"}]}, "developer_name": "Marcel Eissens || VRROOM", "developer_privacy_policy_url": "https://drumbeatsvr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "MESHm", "support_website_url": null, "website_url": "https://www.drumbeatsvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27939566375689329"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974721_1979982168822893_6236178335275796574_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t7qcpK5a7MAQ7kNvgE2sitM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCW3gVSsTdGnCjRW3mEostKUNGfTlQ5LEt7yx7Bnzh-RA&oe=67839C6A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DrumBeats VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Rhythm", "id": "1672577396871977"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1638226800, "lastRevision": {"nodes": [{"id": "2649381722029948", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "593713865969