ay on the drum kits and environments listed above however you like\n\nArcade\nPlay along with our custom made songs", "short_description": "DrumBeatsVR is a VR drumming music game. You can drum to songs to unleash your inner drummer! In DrumBeatsVR you can practice on different drum kits, including Metallica and The Rolling Stones and you can play in five different environments (more to be added later)."}]}, "developer_name": "Marcel Eissens || VRROOM", "developer_privacy_policy_url": "https://vrroom.nl/drumbeats-privacy-txt/", "developer_terms_of_service_url": null, "publisher_name": "I Love Company BV", "support_website_url": null, "website_url": "https://www.vrroom.nl/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "231542869184769"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1197929304686313"}, {"status": "PUBLISHED", "id": "414382800329794"}]}, "baseline_offer": {"id": "414382800329794"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1197929304686313"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26540079465638034", "version": "1.73g"}, "id": "535333144229479", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary",