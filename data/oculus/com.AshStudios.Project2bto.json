0E6632"}, {"file_name": "2560 1440.png", "id": "921692919690953", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75388630_921692923024286_1397563986481519451_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HcgL0qMI9SkQ7kNvgFhiQK6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCc7icH52ntDVwTuBTGjRtvTWybDp15cdd25DMrGVpirg&oe=670E4314"}, {"file_name": "2560 1440.png", "id": "1214728906626153", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982510_1214728909959486_5640181462421353944_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sbvgDbjJ0fMQ7kNvgFmzPRg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3mgkd8bU2wYgwCF76hWg3fCiSBb0fYUvVHSIYKiwp5Q&oe=670E5DDB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 1440.png", "id": "2514107282132999", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75580056_2514107285466332_578651576974335053_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ctRX7mEWzMcQ7kNvgHmnM7l&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEbWycntEBBtYu9ONtz5vPxwocglOoCjqsUCpZ0NM4fA&oe=670E4D79"}, "display_name": "Project 2bto", "keywords": ["gorilla", "tag", "project", "2bto", "monkey"], "long_description": "Embrace your primal side.\n\nExperience running, climbing, and jumping in VR with a revolutionary locomotion system that relies solely on your hand and arm movements. No buttons, no joysticks, no teleportation. Propel yourself off surfaces to jump and use both hands to grip and climb.\n\nExplore four distinct game modes: classic Tag for up to three players, infection mode for groups of four or more, and The Hunt where you track a unique target.\n\nFlee from other gorillas or outmaneuver your peers to catch them. Scale trees and cliffs to evade capture or hunt down your prey. Enjoy the freedom of a virtual jungle, either with random players or in private rooms with friends. With low stakes, you can relax, chat, or invent your own games. The movement system is intuitive yet challenging to master, and you can play across platforms with PC users.\n\nDiscover six diverse levels, each featuring unique terrains and obstacles for endless fun.\n\nCheck out our City store, offering a rotating selection of items to purchase, play with, and wear to showcase your true monke spirit.\n\nTransform into a Gorilla.", "short_description": "Embrace your primal side.\n\nExperience running, climbing, and jumping in VR with a revolutionary locomotion system that relies solely on your hand and arm movements. No buttons, no joysticks, no teleportation. Propel yourself off surfaces to jump and use both hands to grip and climb.\n\nExplore four distinct game modes: classic Tag for up to three players, infection mode for groups of four or more, and The Hunt where you track a unique target.\n\nFlee from other gorillas or outmaneuver your peers to "}]}, "developer_name": "Ash", "developer_privacy_policy_url": "https://sites.google.com/view/privacy-policy-2bto/home", "developer_terms_of_service_url": null, "publisher_name": "Ash", "support_website_url": null, "website_url": "https://sites.google.com/view/project-2bto/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8015662101810574"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "812788537658504"}]}, "baseline_offer": null, "is_a