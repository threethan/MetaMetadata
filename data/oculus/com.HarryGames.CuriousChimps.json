ontent-iad3-2.oculuscdn.com&oh=00_AYDYmK-dVL44xqGgBjOq2wTVHIqlOAL1_pzTYYMwfZWFgw&oe=6735E79C"}, {"file_name": "png.png", "id": "202193189081219", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982543_202193192414552_3927611314600845508_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yCCZ9HhXUyEQ7kNvgGsk0tp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACa68QiATpLXaVj3Fl3UIxA0z2U-GHwFSIpbsWLcSpPA&oe=6735E4E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fbi open up.png", "id": "901652134489482", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974885_901652141156148_8256750132629386093_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ChFFlCDpqwQ7kNvgEKxDjR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVAXz6oiy0nlxJlxgC0KrzXahuZP816k0Eahip5d7-rg&oe=6735CECD"}, "display_name": "Curious Chimps", "keywords": [], "long_description": "A game inspired by Gorilla Tag.\n\nReturn to Chimp.\n\nExplore the multiple environments your natural home has to offer. Run, jump and climb using only your arms, no thumbsticks, touchpads or anything. Stack on top of each other to reach new heights. Climb trees and swing around the forest. Climb walls, run on the ground, jump from branch to branch around different trees. Swim through Zero Gravity, escape Dad, fly, launch, and grapple around in the Mechanic Playground, and put your mind to the test and find out which branches are real and fake, be careful though, time is ticking and lava is rising! Why not a little adventure to satisfy that Chimp curiosity? If you aren't feeling up for it, hang out with other monkeys in the snow or forest map. And whatever you do, do NOT go to the mines.\n\nNo more hooman.", "short_description": "Gorillas, Orangutans, Gibbons, and Monkeys are pretty cool, but what about our closest relative -- chimps? Explore a reality, where chimps with futuristic technology rule the world in this free VR game."}]}, "developer_name": null, "developer_priva