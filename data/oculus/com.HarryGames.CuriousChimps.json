8599993_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbJtaKCVLVUQ7kNvgF7Rh6u&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwBP6hO2jS_FoLG6Jh62MHuF4s4oR4c82jmyt-_Qn7MQ&oe=672B5B9C"}, {"file_name": "png.png", "id": "202193189081219", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982543_202193192414552_3927611314600845508_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8aHMCMIAcpsQ7kNvgG7WbC6&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBGtVWCfkFA4ByvAVHUzcdaN_T3yAPCPeW3zsV2SQ4Yog&oe=672B58E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fbi open up.png", "id": "901652134489482", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974885_901652141156148_8256750132629386093_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LggqckkpTmgQ7kNvgH1hL83&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYABc5KVhzaKoHF9pvs13fDp-RqegpbuNEF3eq2Ekpe0aw&oe=672B42CD"}, "display_name": "Curious Chimps", "keywords": [], "long_description": "A game inspired by Gorilla Tag.\n\nReturn to Chimp.\n\nExplore the multiple environments your natural home has to offer. Run, jump and climb using only your arms, no thumbsticks, touchpads or anything. Stack on top of each other to reach new heights. Climb trees and swing around the forest. Climb walls, run on the ground, jump from branch to branch around different trees. Swim through Zero Gravity, escape Dad, fly, launch, and grapple around in the Mechanic Playground, and put your mind to the test and find out which branches are real and fake, be careful though, time is ticking and lava is rising! Why not a little adventure to satisfy that Chimp curiosity? If you aren't feeling up for it, hang out with other monkeys in the snow or forest map. And whatever you do, do NOT go to the mines.\n\nNo more hooman.", "short_description": "Gorillas, Orangutans, Gibbons, and Monkeys are pretty cool, but what about our closest relative -- chimps? Explore a reality, where chimps with futuristic technology rule the world in this free VR game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/curiouschimps/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "HarryDog", "support_website_url": null, "website_url": "https://sites.google.com/view/curiouschimps/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "751969239978747"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6586868764739886", "version": "1.2.8"}, "id": "439693478358966", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5743680589058712", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6586868764739886"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1718126469, "id": "7760603004033117", "version": "1.86", "version_code": 65, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count"