c_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LjgRT6wtb1cQ7kNvgHVNCGN&_nc_ht=scontent.oculuscdn.com&_nc_gid=APhrmYmXS164JG8sTxwlFnC&oh=00_AYCm-ORw8swLN0dJj11vyJZSAUVXeGbkw5QN5aAw2cm1QQ&oe=66EEB69C"}, {"file_name": "png.png", "id": "202193189081219", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982543_202193192414552_3927611314600845508_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4I-RWf-1W2MQ7kNvgHngOsk&_nc_ht=scontent.oculuscdn.com&_nc_gid=APhrmYmXS164JG8sTxwlFnC&oh=00_AYC-8XU2GjQTY4_PgNFolu1EV6uUvpLKYxrQuECcphDYYw&oe=66EEB3E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fbi open up.png", "id": "901652134489482", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974885_901652141156148_8256750132629386093_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tsYMtC9Qd80Q7kNvgG38eH-&_nc_ht=scontent.oculuscdn.com&_nc_gid=APhrmYmXS164JG8sTxwlFnC&oh=00_AYDOJCXCmtgrQLAWgnnw77X9Lz-z8ydWu8MR7seVGmFw5w&oe=66EE9DCD"}, "display_name": "Curious Chimps", "keywords": [], "long_description": "A game inspired by Gorilla Tag.\n\nReturn to Chimp.\n\nExplore the multiple environments your natural home has to offer. Run, jump and climb using only your arms, no thumbsticks, touchpads or anything. Stack on top of each other to reach new heights. Climb trees and swing around the forest. Climb walls, run on the ground, jump from branch to branch around different trees. Swim through Zero Gravity, escape Dad, fly, launch, and grapple around in the Mechanic Playground, and put your mind to the test and find out which branches are real and fake, be careful though, time is ticking and lava is rising! Why not a little adventure to satisfy that Chimp curiosity? If you aren't feeling up for it, hang out with other monkeys in the snow or forest map. And whatever you do, do NOT go to the mines.\n\nNo more hooman.", "short_description": "Gorillas, Orangutans, Gibbons, and Monkeys are pretty cool, but what about our closest relative -- chimps? Explore a reality, where chimps with futuristic technology rule the world in this free VR game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/curiouschimps/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "HarryDog", "support_website_url": null, "website_url": "https://sites.google.com/view/curiouschimps/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "751969239978747"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003257_2345268968984264_8649661498621749646_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ifhFNU8dIhcQ7kNvgFQiSZp&_nc_ht=scontent.oculuscdn.com&_nc_gid=APhrmYmXS164JG8sTxwlFnC&oh=00_AYCVGqnhyhZkpuGaApTN63C8OZ6ilAv4sb56a4NXFJXWAw&oe=66EEA6A8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Curious Chimps", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1679091071, "lastRevision": {"nodes": [{"id": "5743680635725374", "release_type": "SCHEDULED", "administration_status": "APPROVED", "