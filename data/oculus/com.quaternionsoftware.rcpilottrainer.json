549_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ywdfZ_NZWicQ7kNvgH1VzDP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8Z_eziQ_Sdb7H-a-I0_J2s6zSymj00XDfzUFt00BJfA&oe=673F1315"}, {"file_name": "screenshot5.png", "id": "1615880172670232", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974654_1615880176003565_6785098010747412553_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9nQxzKIu_hUQ7kNvgGC3CrR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHUason1h0JsspwkRhs_UNpAOyrVCqdDY-llwQuvJiNQ&oe=673F2EF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "hero_image.png", "id": "1085410726145099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57575353_1085410729478432_2797027628537688374_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DSx8xysb2w0Q7kNvgElHTkv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIgVmJCSpKVvXneDaOqoW92oLHEJFQohuKUmHR7jp-5w&oe=673F353F"}, "display_name": "RC Pilot Trainer", "keywords": ["rc", "simulator", "airplane", "flightsim"], "long_description": "Experience the thrill of R/C airplane flying! \nThis demo puts you in control of a highly realistic airplane in a beautifully rendered environment, recreating the precision and excitement of line-of-sight flying. Perfect for beginners and seasoned pilots alike, this VR experience offers a unique way to enjoy R/C flight\u2014rain or shine.\n\nSeasoned pilots can use it to keep their skills sharp when the weather isn\u2019t ideal, while newcomers will find it an accessible way to practice fundamental maneuvers. With its true-to-life controls and immersive visuals, this app lets you soar as if you were really at the field, guiding your plane through the sky with skill and precision.\n\nOptionally use a gamepad or connect your actual R/C transmitter over USB for ultimate realism. \n\nWe\u2019d love your feedback to make this experience even better! So grab your headset, take to the skies, and let us know what you think.", "short_description": "Experience the thrill of flying a realistic R/C airplane!\nThis demo captures the excitement and challenge of line-of-sight flying in a beautifully rendered environment, making it perfect for practice and enjoyment\u2014even when the weather outside isn\u2019t cooperating. Optionally use a gamepad or connect your actual R/C transmitter over USB for ultimate realism. \nTry it out and share your feedback to help shape the future of VR R/C flight!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/89d4ec56-d0e2-4795-8e6f-f9e5aab85470", "developer_terms_of_service_url": null, "publisher_name": "Quaternion Software", "support_website_url": null, "website_url": "https://quaternionsoftware.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8588773487843174"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3700488986948149"}]}, "baseline_offer": {"id": "3700488986948149"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731001200, "status": "PUBLISHED", "id": "3700488986948149"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8595796843807505", "version": "0.2"}, "id": "1436705133686456", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": f