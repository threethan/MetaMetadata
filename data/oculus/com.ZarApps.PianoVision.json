974611_322929430246652_3553247235235466316_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q5suGpDEnegQ7kNvgGoM6N7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnyWhSCizT4Fzvt_bN_ttNgmhs2lpSB8J-t1P5dCHH_g&oe=67066B51"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EPqnnuwSsRMQ7kNvgFnyIUc&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdYWcKCxmM9OfDQNVtyq6Vhc88f0oVFYpvQh-N_1gDpg&oe=6706692F"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w1WxcFqvQ4EQ7kNvgHPAe9v&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtdC3mGxuEzMalKhxP4ZfTnnXfA-nT327ta3X6pywmvA&oe=67065043"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8XT_NZo4bggQ7kNvgGArySz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDc50W6fEkMnEItpV2BXKwbHgkEM4a8LRhnK6dM-Q_OjQ&oe=6706805C"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrxJ4RQHS38Q7kNvgFsxNqm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBCw2OvFjY6bFYj4dsMp7DBQvQodyEhkZlY6jerIEB3Q&oe=6706661D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t96Y6K4CdSgQ7kNvgHk33UT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5nQG2JlKNWZA6o5ZBke1UDc0vaSQQ8QX0Bs1hgnEhyg&oe=67067EF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AO9JMOnlRsQ7kNvgF7ySEM&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDD6MWrPCimKldzkSiBAqHyNkUmwlLbFw-b9bdrITCPSA&oe=670681A2"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "d