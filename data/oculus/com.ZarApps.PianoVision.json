0a&_nc_ohc=tgvQ-wig-NgQ7kNvgG2RGRS&_nc_ht=scontent.oculuscdn.com&oh=00_AYD4YrZ7AsRACgm8ivsSod4dCK7rdtsOoadigBvLlW2iiw&oe=66D05DD1"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8NKHyv-ssx4Q7kNvgF-3g6O&_nc_ht=scontent.oculuscdn.com&oh=00_AYAt4bko5BKqj3nk4aXji7xm6l9S9r1cztrMEUh6_2OcGQ&oe=66D05BAF"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sP6MsFxox-UQ7kNvgHXo0Q4&_nc_ht=scontent.oculuscdn.com&oh=00_AYDq5E3EVrNFPxIOzYx186wzPew2Av82gu-UAtgdXrXEOg&oe=66D042C3"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a_jVW4AFkp0Q7kNvgHNSpIG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBxBiFBAC1stzxVyOGcjSAQfLSImFMjFDTml7PzEWEQZg&oe=66D072DC"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tzuELL3FHiYQ7kNvgEUqEPY&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-9L-wMSYnRczpVL_RAKoBP6s1hD4IjHT6mgtb-PeD4g&oe=66D0589D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiFzz1lwFiMQ7kNvgGWJInz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgDjcFyh4_abiBPbHFOaltSG1Lp5aV_Vbp4o3Nx-G2DQ&oe=66D07173"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wya3NOwm53UQ7kNvgFGC5Bc&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1rjm9tz8CH85Ih_ZPNskbTwM0JatVq1Yyzb3veHqNaA&oe=66D07422"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.c