5/38974611_322929430246652_3553247235235466316_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kLAfu-W9LZIQ7kNvgEnirzq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7L39w5EjzVM-d62n-B25Vpog7P0fCEe2234-hQj1I8Q&oe=670D02D1"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lEzSlqPukBEQ7kNvgGYxGsa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJi39dmbcVmKDMqZLGt5Sz3QCWWiKGqwWj2nt4G7DdGQ&oe=670D00AF"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nWUNee-un3IQ7kNvgG-bEDP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlSpUt-VbbqdQ2hb2XjCr-mF7-BbcK6NEdkakV1GXAWw&oe=670CE7C3"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=suhNPVM9R5EQ7kNvgHn_jFL&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAz-LGrMXE2y7taaJ7ADGP0zs73VD8YGQCpqsEjHO1ZrA&oe=670D17DC"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aOIEZ5jS4-wQ7kNvgFECNHm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0K0_1R-2zyQCMtLZNKSX07O8ohLPvPgz6sN8YaSVlEQ&oe=670CFD9D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=InR-ym3UGQUQ7kNvgES_1pk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCiWBpIV3k3OeHg8tETf4tv7K6hj-MLHj_JDle3acMIQ&oe=670D1673"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9J-tjN6bAMQ7kNvgEcYaWp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCM1xtmfaNVefDkVPB7HA5N-CJxaxcrnJ0m0wRG_O_S8Q&oe=670D1922"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}