": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974611_322929430246652_3553247235235466316_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YPSGhyjFF50Q7kNvgE90MT2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkS7LewcPLF14sQK0n_xFhWJfLZOzYD-qVoPrwNjfxtA&oe=6749A7D1"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bwEooNnzYLUQ7kNvgFhE28V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDs2o5UddJj5kvkcbMlqMdH9WMke-QxDNdfXLK_p2uZQw&oe=6749A5AF"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7GGvKMxkKO4Q7kNvgHyEaWK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCA_Cu1VFi0bFKrru5K4lpWejVTFInqAnCIy6ulwfcM7Q&oe=6749C503"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I8NWIwOoSa8Q7kNvgEiILnn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBP--dkTIx4W_-p-rDfD1zUVrA4bwvld01XtKaxNK6IbA&oe=6749BCDC"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kaVmLOHakKAQ7kNvgFr7SLu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQkcnAqdrsN5jWwEnY8aa_bzZ0qfFyNuvRUc-s5m6YAA&oe=6749A29D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yvaONneMyyoQ7kNvgGSUeR6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAV2Dg0OzQbpcolQR0SRZ_y9cIHddmoXw18IITLX3o9gw&oe=6749BB73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B7kWHtFcphYQ7kNvgHnS1Ln&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA158YHOTlV4ZlJb0TqwX0wLZ71eGcjkCTBSuejlSSXZQ&oe=6749BE22"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.com/terms-and-conditions", "publisher_name": "ZarApps", "support_website_url": null, "website_url": "http://www.pianovision.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8391246534238724"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974567_1295775384417191_3947732466729687280_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pp6ogFyGaukQ7kNvgE4G2Qc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDImlZDPMFHeJhb6z9DZEf-nIZA03Gl3t5s7Cv285vEQA&oe=6749B92A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PianoVision", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Hands-On Training", "id": "514087707868786"}], "release_date": 1696957140, "lastRevision": {"nodes": [{"id": "695834464731241", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadat