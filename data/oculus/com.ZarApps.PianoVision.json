_ohc=YUTss4iQC0MQ7kNvgEmUKw-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCb5PLY8rfmRa43R_t5NZihrLxw-cFdQkC-zOcvaPeXQA&oe=66F7EAD1"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_-4t8RhzHUAQ7kNvgFxM5c2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCX5EdmCLIGYcrtRp7I1QkLIXe8O3arrgO9APCndCOXaw&oe=66F7E8AF"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XVApqlZy-aUQ7kNvgHAQfeL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBP-d7E4MfbgfRa2H4Mfk3LuEghpMbjSZtt8VotGpdQnw&oe=66F7CFC3"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J5KcZcT9_QkQ7kNvgGeyt0V&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkXA5PDePB7LE4wSOuLX9EXXhU94N3SofOkpGZv-kKqw&oe=66F7FFDC"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ezLDLTMOnUsQ7kNvgHZtZPg&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNt_IGkyrDp_FTmFBoUa45Ay18VO1-YJXmUl3QZYZO6w&oe=66F7E59D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n5WJNApDxqcQ7kNvgHv8qNy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCE6RGLl2H4-LWqqiDQVigluan35r3XAxwOSsA31f-AbQ&oe=66F7FE73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w7THKUUM3YIQ7kNvgH4_iaV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZ1Lg2dUoqp2lwHe7Z4q-ctQ8LJyl1rSSu1l7Bl9VzRg&oe=66F80122"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.com/ter