0a&_nc_ohc=7qroHiACQZIQ7kNvgHbwtQ1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBD4leF7dcPmMP5jPZJMtdboEDzbu92YVghPIDYK0gwTw&oe=66D6F551"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oU211xip8GYQ7kNvgF3iREJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2LBWLEZAmQxvh36PKBLDqKR-XDGCjUERQPodik3RTSA&oe=66D6F32F"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pqCLokfxy_oQ7kNvgHbznUQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfXa-1gsBVw95rauSic8m9you2XHRtn2oWkaLdtHulRA&oe=66D6DA43"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OTW124kJI_AQ7kNvgFHjCkd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCT_CG2-wI2p-MvJaeGIBkD3hiTNE2uw_I4em41QDFevQ&oe=66D70A5C"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SeZ2vAcBcVkQ7kNvgHTztaq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzMNn7rPKnZuw6l2ywUsyQzZh1AHsDg9AdrigdaCQmdA&oe=66D6F01D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbcTyiVOjTIQ7kNvgE8734i&_nc_ht=scontent.oculuscdn.com&oh=00_AYARlsisaWm6_qcFMOMA8XQ-w5GCYuS_AdueSK6CHbqDvQ&oe=66D708F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kdY4Ye4utcUQ7kNvgGgmbVF&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-YHyCt1aUibI3fzwqN3wotwey_PRa49-ufqV8eggh8g&oe=66D70BA2"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.c