kNvgE3raik&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdpQSxGAIumRnjVY46eVnf9gZFKm445ULRU2M5I0w7dA&oe=6707B79D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RtnMUFNoN84Q7kNvgGzSHTq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsPTPwlHSNkoSnsGk8DZ0BB2WQzgErYmLzVtJb1r5E7Q&oe=6707A768"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VBppeoDcqjUQ7kNvgFvhd1L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEFqWcIXdGJf8Epwzi1JKNZO8GXIV3cLW-cFph9DM2Cw&oe=6707AEEB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9fwRouZDkxIQ7kNvgHv21fO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEl_NbPcPhctJW5K5-OFC-jV1Bul3QQThh94sIXaakzQ&oe=6707AF69"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App", "short_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight\n- MIDI keyboard connectivity\n- Air Piano\n- Upload custom songs with the Desktop App\n- Multiplayer Concerts\n- Multiplayer Music Instruction\n- VR Music Hall\n- Finger indicators for select songs\n- Built in Courses"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.app/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.app/pianovision-terms-and-conditions", "publisher_name": "ZarApps", "support_website_url": null, "website_url": "http://www.pianovision.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "5397994193589392"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1186068805836696"}, {"status": "PUBLISHED", "id": "3168537856732150"}, {"status": "PUBLISHED", "id": "1103553187689931"}, {"status": "PENDING",