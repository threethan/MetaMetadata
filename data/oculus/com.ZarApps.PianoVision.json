c_ohc=zVKVgHo2WJkQ7kNvgEt2c2B&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC8UqXtbXxoEYeFltfuKR7ouSX-cQuilU897gZON-xVHw&oe=6724B89D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VL34dq9WKpIQ7kNvgFvjeiG&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQlEcgpHtI1t_s2BpQqba0_3F6hZipv1hrodwECENG0w&oe=6724A868"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ey38Mrc85rQQ7kNvgHUOwzH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBIOLJaEo96yfAHn82yBQxRJnZZZ8yXpRI75TFB9_dmew&oe=6724AFEB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2A_kC8cD-LkQ7kNvgFJgda4&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAqAuTKxBEjYkzWolojLSOn0TicXfucyJWPkyIM2HqtDw&oe=6724B069"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable 