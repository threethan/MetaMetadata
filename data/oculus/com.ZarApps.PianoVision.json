iad3-1.oculuscdn.com&oh=00_AYBQYe65QB4dlHPuddIvu1On5fahmP32UwOZNPVmla-5xQ&oe=6718F3F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9aRzu-TR48gQ7kNvgG48JG9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByEqkXIbB9Q-STLoJ1mv-ETgByW0itb6IWf0C3f423lA&oe=6718F6A2"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.com/terms-and-conditions", "publisher_name": "ZarApps", "support_website_url": null, "website_url": "http://www.pianovision.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "384928226018505"}, {"id": "323450648956687"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8391246534238724"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974567_1295775384417191_3947732466729687280_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cKmh6xKpQ5YQ7kNvgERfqgV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnJGu7sNYxqK8v0puIjLrWI4vJgCOW8Ksp7AnOw-WpLw&oe=6718F1AA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PianoVision", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Relaxation & Meditation", "id": "1067126693731825"}, {"topic_name": "Media & Streaming", "id": "384928226018505"}, {"topic_name": "Creativity & Design"