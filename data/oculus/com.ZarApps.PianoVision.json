c_ohc=Ts44hqbFpSsQ7kNvgFHBsuv&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDwKfQLBx13fJvUHZfM7Ww_AhKQXWbeIEL_sco6IdhLEg&oe=67348A9D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bB94_sA322IQ7kNvgGrmemg&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB9l_wEDh1awT4ijm8F3-8vlY9NN2tJELMrP7eXLqiibA&oe=67347A68"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o-YCMoG8CdkQ7kNvgHRPyXL&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDHGmwTcwIOqXceywGwmlhQnJuHFZfxGHm5Xb-qtGadAQ&oe=673481EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=26EpLYKusU8Q7kNvgGAuNz3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYADx9VGiPwhisilkFUoHR5WXXuZeV2pDS-N7e7uu8zUiQ&oe=67348269"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable 