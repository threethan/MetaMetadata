0a&_nc_ohc=jzpUZgtsqr8Q7kNvgGD-Jcn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJ8OTNgW00VOiPTB5qgv1HC4buc6xfSYByQR_AZReRTg&oe=66DC3B51"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MAxt4EnzeQcQ7kNvgGNOL2J&_nc_ht=scontent.oculuscdn.com&oh=00_AYDl5YFlMqd85NQAazZLeCF2-lTmklORleSa2afkadZogw&oe=66DC392F"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mXbAK8kgsHYQ7kNvgFg6R1G&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaISxTo969H0c8Hy6XSdE7BvYm-vQycWVJpz5gcrBFnA&oe=66DC2043"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=js06HNVt66kQ7kNvgHFgNEb&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuhSsFHJkFoB0xuOr-SwmPyYgzZ9KchCxO0FSferzaaA&oe=66DC505C"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p_t_3WK60YIQ7kNvgG-aFWr&_nc_ht=scontent.oculuscdn.com&oh=00_AYALf0XPkeE3rgfmPEU5EzeAzQsuIftAw0ENQJXb6fmxYQ&oe=66DC361D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C-2OtyScXXsQ7kNvgEKLLWy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBbNd5M1y8SY-zQHWiIwwKl4cIJGZPGdA6QOccmPljqg&oe=66DC4EF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=44Hn9Z764MgQ7kNvgHoeaCp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYtjLX1AdR9eF0-wXv-mJ635vcccAnPhHc1oSoK9-0-g&oe=66DC51A2"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.c