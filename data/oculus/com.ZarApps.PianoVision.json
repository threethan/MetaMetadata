c_ohc=g_OF_1_5sncQ7kNvgHYRgfX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBdv6UESZoUTMNqcyBMmNbitTUXlN0L8CCPr8Kc-LW0eg&oe=6740681D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xFxmTss9zuYQ7kNvgGgha25&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBGxBES2EHKnlAdbWfeyjHswP_e2LN5jp8oAEPAZDZMFw&oe=674057E8"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qsKhjYdqKHEQ7kNvgFDHzk4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBc99Kikm6bnskok4mdDNP_GMA8COWkQr9vfCLgkqCIYQ&oe=67405F6B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EG1pS-4CpFcQ7kNvgFZUTol&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCGfxYLkRlrGIsgQJI2fS9My2-_SCNa3wC3Z5fj6yNsbw&oe=67405FE9"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable 