_ohc=rJHjEc5BTCgQ7kNvgFSy1in&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOSoQPmul942Rgb5BsmXHGZ1_t1JzcOuADO3jeqLpSbw&oe=6765521D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5t4LZX9YzoAQ7kNvgGz9m5J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuH2cGUyCARPMoXledu8RS8ZNJ2XyXIOOE4qOG8EVI6Q&oe=676541E8"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Jd1Rj_R9pEQ7kNvgH8tJo5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATO869pncaq4OXn5_pChVUl8bmavVFx1ZkcKLXwOLnnQ&oe=6765496B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5mGRs6PuIrkQ7kNvgE8wQAk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDN5x6-0aQS2NfD55zq1PTOWoh2MMxM3Z4PS8Qj9HJZcA&oe=676549E9"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App", "short_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight\n- MIDI keyboard connectivity\n- Air Piano\n- Upload custom songs with the Desktop App\n- Multiplayer Concerts\n- Multiplayer Music Instruction\n- VR Music Hall\n- Finger indicators for select songs\n- Built in Courses"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.app/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.app/pianovision-terms-and-conditions", "publisher_name": "ZarApps", "support_website_url": null, "website_url": "http://www.pianovision.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "MUSIC"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "5397994193589392"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1186068805836696"}, {"status": "PUBLISHED", "id": "31685378567321