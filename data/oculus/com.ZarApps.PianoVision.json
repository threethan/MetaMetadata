c_ohc=nTsABcAP8BcQ7kNvgG7L86u&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyPoOSNWOfaY-esGmNsOlxpnkL_UhCGtgCeinvWyhlLA&oe=672F449D"}, {"file_name": "SS1_sheet.png", "id": "1191048865081494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75250461_1191048868414827_2830744228950414513_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kBe54zH5mrQQ7kNvgHWR1B7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-w940YDlSqIZ-58s72WQD1qXZu0q3jzj4Y1fDyf4iEg&oe=672F3468"}, {"file_name": "SS1_hall.png", "id": "1278143049647950", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982584_1278143052981283_1443330906120181286_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hS5iZX1iSDsQ7kNvgGoJ0Pv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3YcvYHEVfkZYAZMCOsSlrNJL1NkvMfzpbtUgut0C4mA&oe=672F3BEB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LS_Cover.png", "id": "532773961937166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982476_532773965270499_3003478798918590979_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mUpoPegZDxMQ7kNvgEh3FZV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKmDqDA6MSqyQMcdJj1TJIjEnsy1psZsgt1jFi3Y3FXg&oe=672F3C69"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary. The next evolution of the world's most popular instrument.\n\nPianoVision accelerates your piano learning using Passthrough AR and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Air Piano!\n\nPianoVision Features\n- Sheet Music Insight to learn sight-reading\n- Multiplayer Concerts\n- MIDI keyboard connectivity\n- Air piano for those without physical pianos\n- Upload custom songs using the Desktop App\n- Multiplayer Music Instruction\n- PianoVision Music Hall in VR (and more halls to come!)\n- Indicators to show you what fingers to play with for select songs\n- Built in Courses\n\nHow to connect your MIDI keyboard:\n1. A USB cable 