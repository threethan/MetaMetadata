0a&_nc_ohc=jfchr4oXa4kQ7kNvgGJ2gQu&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEG-Ixw2_TxJa1ICR4iufxOSEfKlJx_5DXzl6OUL-aJg&oe=66DD8CD1"}]}, "id": "1369355380380092", "locale": "en_US", "screenshots": [{"file_name": "2_virtual.png", "id": "237008789320308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_237008792653641_6257404813322429167_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MAxt4EnzeQcQ7kNvgFSFVyz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTmDZjbpKZMnr5Uiqs81x29ByWeBTUILuPJ4Ng0qNfQw&oe=66DD8AAF"}, {"file_name": "1_midi.png", "id": "813488174112057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_813488177445390_2438928603620216115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mXbAK8kgsHYQ7kNvgHnMkab&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNENp-3ARgndJJyW7a4LVyL-caTxT2SWTn7TPQCXej3g&oe=66DD71C3"}, {"file_name": "3_menu.png", "id": "1413872602521920", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363516_1413872605855253_4408040147330652600_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=js06HNVt66kQ7kNvgEFc4nC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPRi_ce_4lGBDygsePvjQBPiEt9XYde5_lGadEGVh7qA&oe=66DDA1DC"}, {"file_name": "SS1_concert.png", "id": "1913933552131925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1913933555465258_1734153295057358444_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GhSAPVWGKBQQ7kNvgGMxJdI&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1DBB7iWCz0CJayo6ig8bUrHAmZOM0JeJofUGBOoIXAQ&oe=66DD879D"}, {"file_name": "4_sheet.png", "id": "867055657674845", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974510_867055661008178_6153817951733342228_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C-2OtyScXXsQ7kNvgHgvH4U&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgAz9lg6sPS-Gx0hsQ8Jga9hUgH-Ycg6U16aU12P7dXQ&oe=66DDA073"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "318278590778590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572753_318278594111923_8217457249153592232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=44Hn9Z764MgQ7kNvgEq7-As&_nc_ht=scontent.oculuscdn.com&oh=00_AYD4g4WV_SI2M-jKQW7FlR3z_72YRvzvVYPNzbCzeCP8lw&oe=66DDA322"}, "display_name": "PianoVision", "keywords": [], "long_description": "Become a PianoVisionary with the world's premiere VR Music Teacher.\n\nPianoVision accelerates your piano learning using Mixed Reality and hand tracking. Connect a MIDI keyboard or play on a flat surface with the Virtual Piano!\n\nNote: Quest hand tracking is new and always improving. For now, with the Virtual Piano, we recommend sticking to the 100 songs at Level 0 specifically designed for the Virtual Piano and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI and Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Custom sectioning and fingerings\n- 120 instrument sounds\n- Record music\n- Multiplayer concerts and instruction\n- VR Music Hall\n\nHow to connect your MIDI keyboard:\n1. A USB cable from the keyboard to the Quest\n2. Or, you can download the Desktop App from http://www.pianovision.app, connect your keyboard to your PC via USB, and connect the PC to the Quest using the WiFi Connect Code inside the PianoVision Quest App\n\nContact zac@pianovision.app or join the Discord if you have issues.", "short_description": "Become a PianoVisionary with the world's premiere VR Music Teacher. Use a MIDI keyboard or the Virtual Piano!\n\nNote: With the Virtual Piano, we recommend sticking to the 100 songs at Level 0 and avoiding freestyle. \n\nPianoVision Features\n- 1400+ songs and exercises, 13+ hours\n- MIDI/Virtual pianos\n- Upload custom songs\n- Sheet Music\n- Learning and Memory engines\n- Sectioning and fingerings\n- 120 instruments\n- Multiplayer"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pianovision.com/pianovision-privacy-policy", "developer_terms_of_service_url": "https://www.pianovision.c