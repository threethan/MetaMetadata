IVE", "id": "4813686315319191"}]}, "change_log": null, "created_date": 1649066266, "id": "5568616619819780", "version": "1.3", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5129239140424199", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5627701973911244"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4813686315319191"}]}, "change_log": "Version 1.2 has been developed and released in response to early feedback.\n\n-Improvements\n*New Weapons!  You can now choose between taking on the enemy with a Light-Cannon, or dual wielding Plasma Pistols.\n*New Powerups!  To best serve our new weapons we also have some new powerups to be gained.\n*Improved power up Ammo collection.  Ammo can still be picked up as in previous versions, alternatively you can simply walk over it to get the powerup.\n*Improved Grenade pickup.  Grenades will now float around chest height making them easier to grab in the heat of battle.\n*More frantic gameplay.  The levelling system has been adjusted; things will ramp up far quicker than before.\n\n-Bug Fixes\n*Game bounds.  It is no longer possible to hide from the enemy by sitting outside their reach.", "created_date": 1643726444, "id": "5388115514536559", "version": "1.2", "version_code": 3, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "51292391404241