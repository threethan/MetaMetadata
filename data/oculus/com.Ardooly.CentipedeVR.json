6"}, {"file_name": "SS5.png", "id": "292859659388973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_292859662722306_3522045381542535379_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tv0PhPiSpoUQ7kNvgH1rCFV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMacqXjBcsVCarrotdGe3WD&oh=00_AYAdBxJDuoAkK_Vo58fLHvXXHk44x_qIHiYNXXJEeRJ3rg&oe=66E02203"}, {"file_name": "SS1.png", "id": "1053963585451314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_1053963588784647_8601396913389740785_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=66K7CwuGVQYQ7kNvgEHn5US&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMacqXjBcsVCarrotdGe3WD&oh=00_AYDElrOlbBdu0L5ifbx0dJStQksc-diWYluoeMHbGPHi5Q&oe=66E04512"}, {"file_name": "SS6.png", "id": "419887433144933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974874_419887436478266_1179043312655928430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sBFjt-ree0EQ7kNvgGI2ZRl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMacqXjBcsVCarrotdGe3WD&oh=00_AYCWCOGzyL4c4ugwYBXgejAr9r7ucIvmENOviJt5zHYynA&oe=66E01CEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerTitleCover.png", "id": "3133844923494703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75278190_3133844926828036_1067455481482784372_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LA9ypg0jMX0Q7kNvgF5H8rQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMacqXjBcsVCarrotdGe3WD&oh=00_AYDReVcu_J6v9XHIUJgXONSO38WtKfkGjXzAa5Y3fhuDvg&oe=66E0432D"}, "display_name": "Centipede", "keywords": [], "long_description": "Ever wondered what it would be like if video games came to life?  Wonder no more!  In a game that feels like it's come straight out of the movies you pit your wits against wave after wave of terrifying digital insects.\n\nSpot the patterns, plan your strategy and blast away.  Those who survive the longest and destroy the most will be crowned king of the world on the high scores board.  Are you the greatest centipede exterminator ever?  Only one way to find out; grab a Light Cannon and get out there!\n\nYou are the Wonder Kid...", "short_description": "Aliens are attacking using some of our much loved classic video games as their weapon of choice.  Grab a light cannon and fend off wave after wave of centipedes, as you prove you have what it takes to defend us.  Compete against the world as you try to put the highest score on the scoreboard.\n\nPlaying this game will make you feel like you've stepped inside a video game, or perhaps even a movie."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "233746908952733"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5627701973911244", "version": "1.4"}, "id": "4813686315319191", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5129239140424199", "is_concept": false, "latest_released_binary": {"__typename"