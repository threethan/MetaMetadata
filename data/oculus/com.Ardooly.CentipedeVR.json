_ohc=Hftv5fjBOfYQ7kNvgFVDibx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJ-0dS8ZeLFf02mEPdZlfTedwfIfUZd37xu367NNnAJQ&oe=673B1983"}, {"file_name": "SS1.png", "id": "1053963585451314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974493_1053963588784647_8601396913389740785_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v1gFP3d_tr8Q7kNvgErUn1i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRXjdeP8Up5pS6uZaI2P7QiKCaUo-8rOZHdBlZiqgq0A&oe=673B3C92"}, {"file_name": "SS6.png", "id": "419887433144933", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974874_419887436478266_1179043312655928430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WaXYr_6zc10Q7kNvgG99dBH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-4SYNge_nBTIRaacBcaM-6rXsdtcro9vV9OZCWtjj2A&oe=673B146E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerTitleCover.png", "id": "3133844923494703", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75278190_3133844926828036_1067455481482784372_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6z31C6lT2EYQ7kNvgFzzwmU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJSv6pEoHmcfWCPW7YpkYUHMOBaSwAf3YtDwVAankBLA&oe=673B3AAD"}, "display_name": "Centipede", "keywords": [], "long_description": "Ever wondered what it would be like if video games came to life?  Wonder no more!  In a game that feels like it's come straight out of the movies you pit your wits against wave after wave of terrifying digital insects.\n\nSpot the patterns, plan your strategy and blast away.  Those who survive the longest and destroy the most will be crowned king of the world on the high scores board.  Are you the greatest centipede exterminator ever?  Only one way to find out; grab a Light Cannon and get out there!\n\nYou are the Wonder Kid...", "short_description": "Aliens are attacking using some of our much loved classic video games as their weapon of choice.  Grab a light cannon and fend off wave after wave of centipedes, as you prove you have what it takes to defend us.  Compete against the world as you try to put the highest score on the scoreboard.\n\nPlaying this game will make you feel like you've stepped inside a video game, or perhaps even a movie."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "233746908952733"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5627701973911244", "version": "1.4"}, "id": "4813686315319191", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5129239140424199", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5627701973911244"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4813686315319191"}]}, "change_log": null, "created_date": 1650968421, "id": "562770197391124