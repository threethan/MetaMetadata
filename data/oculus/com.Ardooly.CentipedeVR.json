"file_name": "SS5.png", "id": "292859659388973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982512_292859662722306_3522045381542535379_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NiN7w18QEJUQ7kNvgHehij7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKC6PJiq1ZW8WzWjsID2R&oh=00_AYB4RJU8EsR_Yhaci266FLf1CFWz-Il-mDZ2ENnXrs5AzQ&oe=66F14583"}, {"file_name": "SS1.png", "id": "1053963585451314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_1053963588784647_8601396913389740785_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ImpPwI_R0NIQ7kNvgEGQAk3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKC6PJiq1ZW8WzWjsID2R&oh=00_AYDnBe_9asBiaO0V3meg_XYLwIUGtTEYJr6jSeLHz3Paxw&oe=66F16892"}, {"file_name": "SS6.png", "id": "419887433144933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974874_419887436478266_1179043312655928430_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6-u3QTM2O18Q7kNvgEHAWiI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKC6PJiq1ZW8WzWjsID2R&oh=00_AYBcs8rCL0nZMN7odQ_LJtoSM3y1pLjv3xazX4fhjZ9ydg&oe=66F1406E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerTitleCover.png", "id": "3133844923494703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75278190_3133844926828036_1067455481482784372_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=efzQJRhulEIQ7kNvgF04YOs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKC6PJiq1ZW8WzWjsID2R&oh=00_AYBlzU0dqYnJI0QWVG7YRjGc_CP6TnjU5XmIFDiq17yMwA&oe=66F166AD"}, "display_name": "Centipede", "keywords": [], "long_description": "Ever wondered what it would be like if video games came to life?  Wonder no more!  In a game that feels like it's come straight out of the movies you pit your wits against wave after wave of terrifying digital insects.\n\nSpot the patterns, plan your strategy and blast away.  Those who survive the longest and destroy the most will be crowned king of the world on the high scores board.  Are you the greatest centipede exterminator ever?  Only one way to find out; grab a Light Cannon and get out there!\n\nYou are the Wonder Kid...", "short_description": "Aliens are attacking using some of our much loved classic video games as their weapon of choice.  Grab a light cannon and fend off wave after wave of centipedes, as you prove you have what it takes to defend us.  Compete against the world as you try to put the highest score on the scoreboard.\n\nPlaying this game will make you feel like you've stepped inside a video game, or perhaps even a movie."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.ardooly.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ardooly", "support_website_url": null, "website_url": "http://www.ardooly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "233746908952733"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5627701973911244", "version": "1.4"}, "id": "4813686315319191", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5129239140424199", "is_concept": false, "latest_released_binary": {"__typename": "And