6OhZnbYvRzzaI9dzb95ffPO5Iw&oe=6739C499"}, {"file_name": "2.png", "id": "1028061178925402", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982478_1028061182258735_806085083011662824_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9kw1XLMhWJ4Q7kNvgGudoQJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8tuxMfio19df0yzFMldftbhSqvUw5ewWt8VjWFfdwqA&oe=6739E603"}, {"file_name": "3.png", "id": "1053713469455167", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974913_1053713472788500_4282508811264385237_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IvVlIfC79vkQ7kNvgFOekcM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAtk748fwh3pYlWSzf0JKdJR86-463RiRKDcDbg7bMIg&oe=6739CF08"}, {"file_name": "4.png", "id": "2131032660599877", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75443246_2131032663933210_8463432866804183648_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MPQ2zcD0ra0Q7kNvgF_kou3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApWLQaL-d1cOZ_Jpdx4emYTILV_P-_6UAVcdafXWAYCg&oe=6739D1E7"}, {"file_name": "5.png", "id": "1181528099752712", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982479_1181528103086045_7790722138044798626_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L33LUpVF8ckQ7kNvgGstWTS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLBBxJPEo0YW91DFfWR8M-pw4ze78OoeocjlX6zPVrTQ&oe=6739CA57"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Bowling Alley", "keywords": ["Bowling"], "long_description": "Set yourself up and experience the best bowling game on your device. \nThis additive virtual bowling game will compel you to spend your maximum time on the game for a long time. Whether you are a pro player or playing it for the first time, this game is for everyone. \nPick the ball and win the battle, check the LIVE score, and get your name on the list of top players.\nKey features \nOffline play support\nScoreboard to analyze the score \nSingle-user play mode\nGame user manual for better understanding\nVR remote control for taking the correct direction\nThere are three different playing levels: Easy, Medium, and Hard\nHigh-quality graphics to experience the realistic scenario\nReset option to reset all your scores\n\n\n\nLet's see how many strikes you can score consecutively.  Relax your mind in your leisure time. \nDownload it now!", "short_description": "The Bowling Game app is a realistic platform to enjoy the bowling experience anytime. Feel the bowling adventure and get the thrill of achieving the perfect strike. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.moonapps.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Moon Technolabs", "support_website_url": null, "website_url": "https://www.moonapps.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8606345966056277"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2752850914882770"}]}, "baseline_offer": {"id": "2752850914882770"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726465620, "status": "PUBLISHED", "id": "2752850914882770"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9072591629431706", "version": "2.1"}, "id": "410325635487603",