a0a&_nc_ohc=QBd4DT1I_bEQ7kNvgHplcNq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAsQ0uwMt272YzSOpeGYoWEVl3q3KTF3kBVcufh2jJnaQ&oe=672603D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "507649608794919", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001662_507649612128252_593145744885098558_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AKauP4WcSG8Q7kNvgEki2XH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA-MF8SDF6fWqwjqavSh1Yd9HfKPWbNRai5E8YFvrIJRQ&oe=67263895"}, "display_name": "Bowling Alley", "keywords": ["Bowling"], "long_description": "Set yourself up and experience the best bowling game on your device. \nThis additive virtual bowling game will compel you to spend your maximum time on the game for a long time. Whether you are a pro player or playing it for the first time, this game is for everyone. \nPick the ball and win the battle, check the LIVE score, and get your name on the list of top players.\nKey features \nOffline play support\nScoreboard to analyze the score \nSingle-user play mode\nGame user manual for better understanding\nVR remote control for taking the correct direction\nThere are three different playing levels: Easy, Medium, and Hard\nHigh-quality graphics to experience the realistic scenario\nReset option to reset all your scores\n\n\n\nLet's see how many strikes you can score consecutively.  Relax your mind in your leisure time. \nDownload it now!", "short_description": "The Bowling Game app is a realistic platform to enjoy the bowling experience anytime. Feel the bowling adventure and get the thrill of achieving the perfect strike. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.moonapps.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Moon Technolabs", "support_website_url": null, "website_url": "https://www.moonapps.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [],