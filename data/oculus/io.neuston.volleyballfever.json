0173762053", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3858203824244597", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5489542257777404"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "214260173762053"}]}, "change_log": "Daily challenges, new hand graphics, and new soundtrack.", "created_date": 1659098490, "id": "5489542257777404", "version": "1.7.0", "version_code": 3, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3858203824244597", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5489542257777404"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "214260173762053"}]}, "change_log": "Revamped online mode to allow hosting and joining rooms with up to 4 players in co-op and versus modes.\n\nAdded faster movement speed.\n\nAdded smooth jump.\n\nAdded smooth turn.\n\nAdded HUD scoreboard to make it easier to see the score.\n\nOptimized performance for improved framerate and battery time.\n\nMade ball explode and disappear when no longer in play.\n\nFixed audio issue that caused symptoms such as the ball getting stuck.\n\nImproved splash screen texture filtering.\n\nTweaked bot set behavior: Moved set target 0.5 m from the player's head position along the center line towards the middle of the court. Moved set target slightly higher (at 0.5 m instead of 0.3). Moved set target slightly out from the net (0.4 m instead of 0.3). I