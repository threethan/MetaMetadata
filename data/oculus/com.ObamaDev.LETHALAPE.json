cape the dread?", "short_description": "\n\"Bro, you're trapped in this messed-up facility, and it's like a total nightmare. No solving puzzles or anything, just straight-up survival mode. The vibe is insane \u2013 flickering lights, creepy corridors, and these two horrifying monsters on your tail. You gotta outsmart 'em, find hiding spots, and just pray you make it out in one piece. It's like being stuck in a horror movie, but you're the star, and the monsters are hunting you down. Good luck, you'll need it to survive this freaky facility!\""}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/lethal-ape/policy", "developer_terms_of_service_url": null, "publisher_name": "SaucerTheDev", "support_website_url": null, "website_url": "https://sites.google.com/view/lethal-ape/policy", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7383354021694909"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "336165339250724"}]}, "baseline_offer": {"id": "336165339250724"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1704927266, "status": "PUBLISHED", "id": "336165339250724"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8054018804628424", "version": "105"}, "id": "90181569