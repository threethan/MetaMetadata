px.png", "id": "2148870118821928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_2148870122155261_5528309106342538177_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OStLD-C3BfsQ7kNvgEpP-80&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB91hS9foHnIUbTN9hvpHvZRKM2yAe8lJvY3oiO-DBq2w&oe=677A75EC"}, {"file_name": "SoftSkills-EN_Screenshot-5_2560x1440px.png", "id": "983025489961540", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982526_983025493294873_8193329196680814937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V_IMbXX8I6cQ7kNvgEb4l37&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOMehNpX5J16NC7M6hrR9poR_sAgkz3puH13_3oUpa9w&oe=677A8D4A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "802213135371789", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982672_802213138705122_4667017097399142221_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=edbpc5cc9fYQ7kNvgGGdZCh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGsqRbylj0sxgvsbZQWIrzjpOd908F9UxKz6F3Sv9y-g&oe=677A8B36"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Transform your potential and excel in your career!\nDiscover the simulator designed to enhance your \"Soft Skills\" through 5 essential training capsules with which you will be able to: \n\n1\ufe0f\u20e3 Self-assess your transversal competencies that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech in front of an audience to improve your communication and public speaking skills.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work as part of a team to foster collaboration and group efficiency.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! \n\nComposed of 5 training capsules to: \n1\ufe0f\u20e3 Self-assess your transversal competences.\n2\ufe0f\u20e3 Improve your communication and public speaking skills.\n3\ufe0f\u20e3 Defend a commercial speech.\n4\ufe0f\u20e3 Speed up decision making.\n5\ufe0f\u20e3 Promote teamwork.\n\nIdeal for professionals looking to improve their interpersonal skills in an immersive, interactive and effective way!"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DsXAaWrh14EQ7kNvgEUAOui&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGcN91GZt0T4qi-5mEs247LYwQWsy9lOYYVwmdmK4t0Q&oe=677A6FE9"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sV-lyUcztS8Q7kNvgFhN_5O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqhm04u7zXM-0ot4IffwoqljZkxWeFbKw84byhvPOSig&oe=677A88AF"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pff3DVe4i_IQ7kNvgGTfxDF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_uE7xCwzWWyA5DibVEPCb6Z1DPqvhB8Z3ErI9zfQjLw&oe=677A7DF3"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5n0ybpxoJngQ7kNvgFaqvHS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6XbGYreScQdOIr1mJfS6Qhy0xZNHvPLlX3smul2Jg-g&oe=677A65C5"}, {"file_name"