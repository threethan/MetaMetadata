=1-7&_nc_sid=6e7a0a&_nc_ohc=lSmOoUpJ0FQQ7kNvgFmmKe1&_nc_ht=scontent.oculuscdn.com&oh=00_AYCudtVAaEBycUrwC4nNCF6AuGSMTGU9thnCq3EPOvr4bw&oe=66D8293E"}, {"file_name": "SoftSkills-EN_Screenshot-3_2560x1440px.png", "id": "2473411132852856", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75549075_2473411139519522_3111694022313373892_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dnJOUOppGPQQ7kNvgFt1Mk3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBX9-XF5ceGCYNagsLGZ1wFgm8uA5uBMfXU283S-YFFrw&oe=66D8343E"}, {"file_name": "SoftSkills-EN_Screenshot-4_2560x1440px.png", "id": "2148870118821928", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974891_2148870122155261_5528309106342538177_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jyHGKWyzxjkQ7kNvgFj0mK0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGjc7Mzc9vJWk5nAqd8KTJh0PuFBLhLm5HoNd6lzY3gw&oe=66D84D6C"}, {"file_name": "SoftSkills-EN_Screenshot-5_2560x1440px.png", "id": "983025489961540", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982526_983025493294873_8193329196680814937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w4wBsaYLcCoQ7kNvgFqqx4R&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo1GLuG6xsY07rdgnWjEtmUEPrQNP5VxKXAo-BlErmFA&oe=66D82C8A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "802213135371789", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982672_802213138705122_4667017097399142221_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g2y3x2l2fFEQ7kNvgG8Y0M9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfg1H9LwKeHwzgGmX7VKk3zrTzUNIuifNhKJq6Pm4_4Q&oe=66D82A76"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Transform your potential and excel in your career!\nDiscover the simulator designed to enhance your \"Soft Skills\" through 5 essential training capsules with which you will be able to: \n\n1\ufe0f\u20e3 Self-assess your transversal competencies that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech in front of an audience to improve your communication and public speaking skills.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work as part of a team to foster collaboration and group efficiency.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! \n\nComposed of 5 training capsules to: \n1\ufe0f\u20e3 Self-assess your transversal competences.\n2\ufe0f\u20e3 Improve your communication and public speaking skills.\n3\ufe0f\u20e3 Defend a commercial speech.\n4\ufe0f\u20e3 Speed up decision making.\n5\ufe0f\u20e3 Promote teamwork.\n\nIdeal for professionals looking to improve their interpersonal skills in an immersive, interactive and effective way!"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sv1p4kOHOgsQ7kNvgFMhVoA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkbmQKwMOWopAw_87TuBUhCicmfFGvhz511Dz8rd2leA&oe=66D84769"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sjw-hjNv6GgQ7kNvgEKbgnM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrkBg71OHM-Qf9yru8EaKU0ESCT7fE8-LzitN8xayWmg&oe=66D8602F"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o8yuqDhP_34Q7kNvgHSYf4C&_nc_ht=scontent.oculuscdn.com&oh=00_AYA_Lt8pnHooa4Q_poX9hXECC9jSREMMF5uKGYCetsiJSg&oe=66D855