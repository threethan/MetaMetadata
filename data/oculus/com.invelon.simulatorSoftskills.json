29RTV79cAN9y9qhrrAsEXTd7w1VUtvW8v1ZRJ91w&oe=6735FD36"}, "display_name": "Simulator Soft Skills", "keywords": [], "long_description": "Transform your potential and stand out in your career!\nDiscover the simulator designed to enhance your \"Soft Skills\" through various essential training capsules with which you will be able to:\n\n1\ufe0f\u20e3 Self-assess your transversal competences that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech before an audience to improve your communication and public speaking.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work in a team to encourage collaboration and group efficiency.\n6\ufe0f\u20e3 Prepare to successfully conduct a job interview.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! Ideal for professionals looking to improve their interpersonal skills in an immersive, interactive and efective way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.auroracloud.app/terms/view/site-terms/", "developer_terms_of_service_url": "https://www.auroracloud.app/terms/view/site-terms/", "publisher_name": "Invelon Technologies", "support_website_url": null, "website_url": "https://invelon.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ca", "es", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_mod