_nc_ohc=DNbjGzr3gZsQ7kNvgHcdjKV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC-h6NrGIDUpH52JR2EeUTJKBuOcGOwBdKdDHu-yhFfpQ&oe=675D6210"}, {"file_name": "SoftSkills-IT_Screenshot-4_2560x1440px.png", "id": "466990229364879", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974719_466990232698212_429966222944110534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nb0dYRi0nW8Q7kNvgEr_iLr&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCH9Zm9Omq4vikui0tUCoZaOi9LDX2qa_kWFJH_M-E-Ag&oe=675D7189"}, {"file_name": "SoftSkills-IT_Screenshot-5_2560x1440px.png", "id": "1025636505558868", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982727_1025636508892201_430688725369663184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q0G9QepeA_sQ7kNvgHWSXNt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB5xkANRjdp81RqwsCV6jD_bW7Bz3YgmQh6WV_-18fkWA&oe=675D6991"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "1630730634427910", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982566_1630730637761243_9068074757253837847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DvjegwcrgsEQ7kNvgH2Xbab&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCxvSvQ5Nf8sf022crF3vjRytw_JXYdWUncR9HGjfLNqQ&oe=675D76F3"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Trasforma il tuo potenziale e distinguiti nella tua carriera!\nScopri il simulatore pensato per migliorare le tue \"Soft Skills\" attraverso diverse capsule formative essenziali con le quali potrai:\n\n1\ufe0f\u20e3 Autovaluta le tue competenze trasversali che ti aiuteranno ad adattarti a diversi ambienti lavorativi.\n2\ufe0f\u20e3 Difendi un discorso davanti a un pubblico per migliorare la tua comunicazione e parlare in pubblico.\n3\ufe0f\u20e3 Allena i tuoi punti di forza in un discorso commerciale.\n4\ufe0f\u20e3 Prendi decisioni per sviluppare le tue capacit\u00e0 strategiche e analitiche.\n5\ufe0f\u20e3 Lavorare in squadra per promuovere la collaborazione e l'efficienza del gruppo.\n6\ufe0f\u20e3 Preparati a svolgere con successo un colloquio di lavoro.", "short_description": "Potenzia le tue \"Soft Skills\" con il nostro simulatore di realt\u00e0 virtuale! Ideale per i professionisti che desiderano migliorare le proprie competenze interpersonali in modo immersivo e interattivo."}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HTLaYZeEz8MQ7kNvgFRloq8&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA6iJEDdYhzb7h0t5MFe7CTCEOKMACLHQgjWMLoJfxFjQ&oe=675D6EE9"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0DW65sUL2XMQ7kNvgHUnv6R&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB04iv6HwQX1TwRNFnhT5zbSpiz2t_fLTuN35oeCWz4Tw&oe=675D87AF"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Sc0gJsFHtQQ7kNvgETL1zx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBz7QIoXEkcBKn73PwupvVtjkEXd-M8R0Ra9Dt6STq2tA&oe=675D7CF3"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UxWP-nA5MRsQ7kNvgGY6F4I&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB1LosJDz