0px.png", "id": "2148870118821928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_2148870122155261_5528309106342538177_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fmAgmyHVVx4Q7kNvgEX4DlF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5kad0RTgcYSrZqMMjKwnbb0SLW1-AmVOK-bufbDhW7g&oe=673DD0EC"}, {"file_name": "SoftSkills-EN_Screenshot-5_2560x1440px.png", "id": "983025489961540", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982526_983025493294873_8193329196680814937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QLM3YDAZAeEQ7kNvgEwobmY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVPHtiXPn7pIxAy16XMM-bJwjoon25Tw2SALIrxxSehg&oe=673DB00A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "802213135371789", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982672_802213138705122_4667017097399142221_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qGXgCbRVBnAQ7kNvgEg9xrH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvd1ZNizsY_o1ImTVMsZFeeIWSCDwyYPhWILHZhbGzLg&oe=673DE636"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Transform your potential and excel in your career!\nDiscover the simulator designed to enhance your \"Soft Skills\" through 5 essential training capsules with which you will be able to: \n\n1\ufe0f\u20e3 Self-assess your transversal competencies that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech in front of an audience to improve your communication and public speaking skills.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work as part of a team to foster collaboration and group efficiency.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! \n\nComposed of 5 training capsules to: \n1\ufe0f\u20e3 Self-assess your transversal competences.\n2\ufe0f\u20e3 Improve your communication and public speaking skills.\n3\ufe0f\u20e3 Defend a commercial speech.\n4\ufe0f\u20e3 Speed up decision making.\n5\ufe0f\u20e3 Promote teamwork.\n\nIdeal for professionals looking to improve their interpersonal skills in an immersive, interactive and effective way!"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8YkIdzU8ha4Q7kNvgGF-_tY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjHv2FnhlRcBf9PWRQGdE1t0zVMbSVNj2jLxGsiLpzzg&oe=673DCAE9"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AzNOZkymTcUQ7kNvgEoHK-Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIzYfVzZhSfWQ-HkNSLCvkB2aNF6Y46ZZhbWAjwIgh-w&oe=673DE3AF"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=01CCMjh1b7cQ7kNvgGak0NG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDzFHbs4dsxkg1O7qJcKj2Dn98DodReWM23B3E6CiIkAg&oe=673DD8F3"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WCa-u-IB37EQ7kNvgHEGQjB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGZSkhoiOKbgDstIo34vB-uipo54kp2xLE7qrn9ZD9Cg&oe=673DC0C5"}, {"file_name