7&_nc_sid=6e7a0a&_nc_ohc=LPC8cCTSUAgQ7kNvgGc6MpD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaMIfPUWr44-P0h9veGrK58tbOWB-DH4UwHj6lCPw7ww&oe=66CC7117"}, {"file_name": "SoftSkills_Screenshot-3_2560x1440px.png", "id": "1524409768114391", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036653_1524409771447724_7763908285405873360_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zOwoLVi5nbIQ7kNvgEjL5Ky&_nc_ht=scontent.oculuscdn.com&oh=00_AYDeocSELNAtREuSy4rEZOe05WJVSzxN6I5OrMZn_GxTfw&oe=66CC587B"}, {"file_name": "SoftSkills_Screenshot-4_2560x1440px.png", "id": "314658221614549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974910_314658224947882_3855311909724896821_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1cGdtCFiFLEQ7kNvgHI2zyQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6yDvXh9J6cwr0FHWTqHd8kDAIFfaU5iXd8QfoXfxWRg&oe=66CC668D"}, {"file_name": "SoftSkills_Screenshot-5_2560x1440px.png", "id": "1623928748388173", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569461_1623928751721506_1551295081848351591_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=biAW3kjqcCUQ7kNvgG6gLjw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDF7s_Qqhj_E7ebhsRPsp1IxC1D_Cbqy0QiYDgywU1-Pw&oe=66CC811E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "458376827132242", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_458376833798908_5317755352769288190_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ytfY7YYqFosQ7kNvgGKeMgo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrDUlGxFazprXmUKRdwxX7yCLYr-hxiRexPls_5Lho4g&oe=66CC7930"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "\u00a1Transforma tu potencial y destaca en tu carrera!\nDescubre el simulador dise\u00f1ado para potenciar tus \"Soft Skills\" a trav\u00e9s de 5 c\u00e1psulas formativas esenciales con las que podr\u00e1s: \n\n1\ufe0f\u20e3 Autoevaluar tus competencias transversales que te ayudar\u00e1n a adaptarte a diferentes entornos laborales.\n2\ufe0f\u20e3 Defender un discurso ante una audiencia para mejorar tu comunicaci\u00f3n y oratoria.\n3\ufe0f\u20e3 Entrenar tus puntos fuertes en un discurso comercial.\n4\ufe0f\u20e3 Tomar decisiones para desarrollar tus habilidades estrat\u00e9gicas y anal\u00edticas.\n5\ufe0f\u20e3 Trabajar en equipo para fomentar la colaboraci\u00f3n y la eficiencia en grupo.", "short_description": "\u00a1Potencia tus \"Soft Skills\" con nuestro Simulador de Realidad Virtual! \n\nCompuesto por 5 c\u00e1psulas formativas para: \n1\ufe0f\u20e3 Autoevaluar tus competencias transversales.\n2\ufe0f\u20e3 Mejorar tu comunicaci\u00f3n y oratoria.\n3\ufe0f\u20e3 Defender un discurso comercial.\n4\ufe0f\u20e3 Agilizar la toma de decisiones.\n5\ufe0f\u20e3 Fomentar el trabajo en equipo.\n\n\u00a1Ideal para profesionales que buscan mejorar sus habilidades interpersonales de manera inmersiva, interactiva y efectiva!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.auroracloud.app/terms/view/site-terms/", "developer_terms_of_service_url": "https://www.auroracloud.app/terms/view/site-terms/", "publisher_name": "Invelon Technologies", "support_website_url": null, "website_url": "https://invelon.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ca", "es", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "26717517957847390"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "ht