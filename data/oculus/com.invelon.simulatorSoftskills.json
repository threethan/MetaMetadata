-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4CBoH311tq_HKDgIPZfq4JiNI4Ci_ItH_18OliXjxgw&oe=670D000D"}, {"file_name": "SoftSkills_Screenshot-5_2560x1440px.png", "id": "1623928748388173", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569461_1623928751721506_1551295081848351591_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KIc6iz7bxrUQ7kNvgE4eXNm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyjAc6gZ1StrCSMowEylged4U2ex2bjg7tPteuM9RHlQ&oe=670D1A9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "458376827132242", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_458376833798908_5317755352769288190_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iN2P7IMtBqsQ7kNvgH8Ewc3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAaLzP2CYLSjitCHK8e5rrRblYE0CU89ZgFh3jZp3Mmyw&oe=670D12B0"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "\u00a1Transforma tu potencial y destaca en tu carrera!\nDescubre el simulador dise\u00f1ado para potenciar tus \"Soft Skills\" a trav\u00e9s de 5 c\u00e1psulas formativas esenciales con las que podr\u00e1s: \n\n1\ufe0f\u20e3 Autoevaluar tus competencias transversales que te ayudar\u00e1n a adaptarte a diferentes entornos laborales.\n2\ufe0f\u20e3 Defender un discurso ante una audiencia para mejorar tu comunicaci\u00f3n y oratoria.\n3\ufe0f\u20e3 Entrenar tus puntos fuertes en un discurso comercial.\n4\ufe0f\u20e3 Tomar decisiones para desarrollar tus habilidades estrat\u00e9gicas y anal\u00edticas.\n5\ufe0f\u20e3 Trabajar en equipo para fomentar la colaboraci\u00f3n y la eficiencia en grupo.", "short_description": "\u00a1Potencia tus \"Soft Skills\" con nuestro Simulador de Realidad Virtual! \n\nCompuesto por 5 c\u00e1psulas formativas para: \n1\ufe0f\u20e3 Autoevaluar tus competencias transversales.\n2\ufe0f\u20e3 Mejorar tu comunicaci\u00f3n y oratoria.\n3\ufe0f\u20e3 Defender un discurso comercial.\n4\ufe0f\u20e3 Agilizar la toma de decisiones.\n5\ufe0f\u20e3 Fomentar el trabajo en equipo.\n\n\u00a1Ideal para profesionales que buscan mejorar sus habilidades interpersonales de manera inmersiva, interactiva y efectiva!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.auroracloud.app/terms/view/site-terms/", "developer_terms_of_service_url": "https://www.auroracloud.app/terms/view/site-terms/", "publisher_name": "Invelon Technologies", "support_website_url": null, "website_url": "https://invelon.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ca", "es", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "26717517957847390"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1297081994601130"}]}, "baseline_offer": {"id": "1297081994601130"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719993474, "status": "PUBLISHED", "id": "1297081994601130"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27320816624184184", "version": "1.6.1"}, "id": "492403613350151", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "26717517934514059", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27320816624184184"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "492403613350151"}]}, "change_log": "A\u00f1adido\n\nTraducciones a la web integrada a todos los idiomas soportados.\nExperiencia de Entrevista laboral a\u00f1adida en la web integrada.\nA\u00f1adido hasta 53 preguntas a la c\u00e1psula de Entrevista Laboral.\nA\u00f1adido sistema de guardado persistente entre reinicios para nuestras evaluaciones, ahora tambi\u00e9n se guarda la \u00faltima presentaci\u00f3n .pdf en memoria.\nA\u00f1adido Mixed Reality a \"Toma de decisiones\" y subida la altura de la mesa con la maqueta.\nNueva c\u00e1psula de Entrevista Laboral.\nNuevo mapa de oficina para Comunicaci\u00f3n y Oratoria.\nNuevo onboarding en la subida del .pdf en Comunicaci\u00f3n y Oratoria.\nCapacidad de seleccionar el tiempo disponible para Comunicaci\u00f3n y Oratoria.\nOrdenador en el Lobby mostrando la IP de la interfaz web.\n\nCambiado\n\nSistema de reinicio del minijuego en Trabajo en Equipo, donde es m\u00e1s r\u00e1pido y no hace falta reiniciar el mapa entero, evitando desconexiones inesperadas.\nRework de Trabajo en Equipo y Toma de decisiones al nuevo core.\nLimpiadas todas las dependencias al core antiguo, el proyecto ya est\u00e1 totalmente pasado a la \u00faltima versi\u00f3n del core.\nBajado el peso del app unos 300mb.\nMejoras de UX en todas las experiencias. Como retoques en la interfaz, introducciones m\u00e1s entendedoras y mejoras en las secuencias de animaciones.\nPantalla de introducci\u00f3n en algunas c\u00e1psulas.\nMen\u00fa de selecci\u00f3n de nivel actualizado.\n\nArreglado\n\nDetecci\u00f3n de la visi\u00f3n en las experiencias de Comunicaci\u00f3n.\nCorrecciones en traducciones y textos.\n", "created_date": 1723813364, "id": "27320816624184184", "version": "1.6.1", "version_code": 6, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files"