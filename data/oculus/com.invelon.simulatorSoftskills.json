_nc_ohc=4AJWqvGoyo8Q7kNvgH7pI5q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdSGxH-_Uiuto21mwALpIWnss4uzmVTYTNsi6B-gCmvQ&oe=677A6310"}, {"file_name": "SoftSkills-IT_Screenshot-4_2560x1440px.png", "id": "466990229364879", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_466990232698212_429966222944110534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RsibFglewMEQ7kNvgFneKH8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDj1ny-hnu6F01a73eaZ95bxU0dj2eXA0qUxuN_x8CO6w&oe=677A7289"}, {"file_name": "SoftSkills-IT_Screenshot-5_2560x1440px.png", "id": "1025636505558868", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982727_1025636508892201_430688725369663184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kSgL3OgkjXkQ7kNvgH3uIFf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrHyVGPBoFimQkh7f3ypm23jjgyv4jgkk4rXpr8rS4ug&oe=677A6A91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "1630730634427910", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982566_1630730637761243_9068074757253837847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iutu8T4JnpgQ7kNvgGQx7_z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAYIsj9eUB4_BCMiCe6CEIcDoAFGLmHlp1fL9-aJvb5YA&oe=677A77F3"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Trasforma il tuo potenziale e distinguiti nella tua carriera!\nScopri il simulatore pensato per migliorare le tue \"Soft Skills\" attraverso diverse capsule formative essenziali con le quali potrai:\n\n1\ufe0f\u20e3 Autovaluta le tue competenze trasversali che ti aiuteranno ad adattarti a diversi ambienti lavorativi.\n2\ufe0f\u20e3 Difendi un discorso davanti a un pubblico per migliorare la tua comunicazione e parlare in pubblico.\n3\ufe0f\u20e3 Allena i tuoi punti di forza in un discorso commerciale.\n4\ufe0f\u20e3 Prendi decisioni per sviluppare le tue capacit\u00e0 strategiche e analitiche.\n5\ufe0f\u20e3 Lavorare in squadra per promuovere la collaborazione e l'efficienza del gruppo.\n6\ufe0f\u20e3 Preparati a svolgere con successo un colloquio di lavoro.", "short_description": "Potenzia le tue \"Soft Skills\" con il nostro simulatore di realt\u00e0 virtuale! Ideale per i professionisti che desiderano migliorare le proprie competenze interpersonali in modo immersivo e interattivo."}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DsXAaWrh14EQ7kNvgEUAOui&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGcN91GZt0T4qi-5mEs247LYwQWsy9lOYYVwmdmK4t0Q&oe=677A6FE9"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sV-lyUcztS8Q7kNvgFhN_5O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqhm04u7zXM-0ot4IffwoqljZkxWeFbKw84byhvPOSig&oe=677A88AF"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pff3DVe4i_IQ7kNvgGTfxDF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_uE7xCwzWWyA5DibVEPCb6Z1DPqvhB8Z3ErI9zfQjLw&oe=677A7DF3"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5n0ybpxoJngQ7kNvgFaqvHS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6XbGYre