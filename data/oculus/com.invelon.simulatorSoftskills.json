_nc_ohc=9N4RVrn4qDcQ7kNvgFBGram&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAf61yXjWjV4Ob4AbP-E5I1mN3XZUbUSHycOGHO36FTtg&oe=67615690"}, {"file_name": "SoftSkills-IT_Screenshot-4_2560x1440px.png", "id": "466990229364879", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974719_466990232698212_429966222944110534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jQCyMQvNNzIQ7kNvgEFeahR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCmGbcCNZB6MbcuPwgf4Xv05OVf8CrZvtp_NYuVJEGVrA&oe=67616609"}, {"file_name": "SoftSkills-IT_Screenshot-5_2560x1440px.png", "id": "1025636505558868", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982727_1025636508892201_430688725369663184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lpFsWOEAYbkQ7kNvgF9Uvxb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCahcKf7HV2iAUNhzmmRTiHZWwCQCPsixPHiXJwD5vWew&oe=67615E11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "1630730634427910", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982566_1630730637761243_9068074757253837847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9IfoxZ3vWakQ7kNvgGbSiJc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAA177fZYiqHhpzq9hzoHQh65xZcVMU4maRARkhh3XObA&oe=67616B73"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Trasforma il tuo potenziale e distinguiti nella tua carriera!\nScopri il simulatore pensato per migliorare le tue \"Soft Skills\" attraverso diverse capsule formative essenziali con le quali potrai:\n\n1\ufe0f\u20e3 Autovaluta le tue competenze trasversali che ti aiuteranno ad adattarti a diversi ambienti lavorativi.\n2\ufe0f\u20e3 Difendi un discorso davanti a un pubblico per migliorare la tua comunicazione e parlare in pubblico.\n3\ufe0f\u20e3 Allena i tuoi punti di forza in un discorso commerciale.\n4\ufe0f\u20e3 Prendi decisioni per sviluppare le tue capacit\u00e0 strategiche e analitiche.\n5\ufe0f\u20e3 Lavorare in squadra per promuovere la collaborazione e l'efficienza del gruppo.\n6\ufe0f\u20e3 Preparati a svolgere con successo un colloquio di lavoro.", "short_description": "Potenzia le tue \"Soft Skills\" con il nostro simulatore di realt\u00e0 virtuale! Ideale per i professionisti che desiderano migliorare le proprie competenze interpersonali in modo immersivo e interattivo."}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CTeDlHRnfaUQ7kNvgEfn0bh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxa3Sv7T0yD2VcjdqCtoNot_mtth1j3b2Mu3xyIoVQAg&oe=67616369"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Ybkx9a_TrgQ7kNvgFyxJYp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSvQiLxrYv6qhFBDiwV7hGVxkZvunpnoZJ16qLqRLcgQ&oe=67617C2F"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Db7GNdbUCSsQ7kNvgFubh7u&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdBQZ0MVRguNNkktW-jO80ckFD0D3F_J1ipgkde7CSdg&oe=67617173"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HzcIYUUvOqcQ7kNvgGzrthI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6TiyBW2