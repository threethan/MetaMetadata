0px.png", "id": "2148870118821928", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974891_2148870122155261_5528309106342538177_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pjj-xUDr25IQ7kNvgEzMzcU&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBd-4H2r9xSextXqcl-SAchYMpdwJCCwjdITy_m5jA-nQ&oe=67582EEC"}, {"file_name": "SoftSkills-EN_Screenshot-5_2560x1440px.png", "id": "983025489961540", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982526_983025493294873_8193329196680814937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xlkRguwFd0gQ7kNvgESLmto&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBqh8rMsLW_ALpZV56Dbcyh0wcxf1jk8_uxyn8bPMAcWA&oe=67580E0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "802213135371789", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982672_802213138705122_4667017097399142221_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G9RJMEaePuwQ7kNvgF5u0I2&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCbYBoilsAMHAazfGgaEybsXPyV1ASHos86QmHeHxegFg&oe=67584436"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Transform your potential and excel in your career!\nDiscover the simulator designed to enhance your \"Soft Skills\" through 5 essential training capsules with which you will be able to: \n\n1\ufe0f\u20e3 Self-assess your transversal competencies that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech in front of an audience to improve your communication and public speaking skills.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work as part of a team to foster collaboration and group efficiency.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! \n\nComposed of 5 training capsules to: \n1\ufe0f\u20e3 Self-assess your transversal competences.\n2\ufe0f\u20e3 Improve your communication and public speaking skills.\n3\ufe0f\u20e3 Defend a commercial speech.\n4\ufe0f\u20e3 Speed up decision making.\n5\ufe0f\u20e3 Promote teamwork.\n\nIdeal for professionals looking to improve their interpersonal skills in an immersive, interactive and effective way!"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1158856758691457", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974786_1158856762024790_8351105602424236604_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2N_SxX7OhSYQ7kNvgGx36Vj&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYByi3aNoFHfdDvzsIK4biASCRkzvxeglzPZs_gU6T1KCg&oe=675828E9"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1001238441075007", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031591_1001238447741673_2783185145492224256_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2lZIDQU3DgEQ7kNvgEgVzKt&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDZ7x35dRZFIInH8QS-xtTT5Qq3bWvaCpipG2DDg_q5ew&oe=675841AF"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "837105901661785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75476759_837105904995118_1711704673161247418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WCiqVUCJox0Q7kNvgHU-G0j&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDSCzj3eGz7oYjktVJ97G3JCe5WZkECpBVDxquYy_z73A&oe=675836F3"}, {"file_name": "SoftSkills_Hero-cover_3000x900px.png", "id": "436545955954692", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974777_436545959288025_6494250809818469750_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tMtw1iHIj8YQ7kNvgEtBSHW&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYD4p2D2hqzElzeykwr9_uCI62d92YXLk4pcpuhPmniAQw&oe=67581EC5"}, {"file_name