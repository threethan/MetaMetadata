&_nc_ht=scontent.oculuscdn.com&oh=00_AYBP_3MhediCbNAIYsB36OBkP_mfzjq0j71sz5o_JefaDQ&oe=66F53B90"}, {"file_name": "SoftSkills-IT_Screenshot-4_2560x1440px.png", "id": "466990229364879", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_466990232698212_429966222944110534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LXEy0xYMDBcQ7kNvgGX3TMI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZ5wD0RYjF7orDpujEjTc5LpujjHEUfv1ZZWw3wTAI4w&oe=66F54B09"}, {"file_name": "SoftSkills-IT_Screenshot-5_2560x1440px.png", "id": "1025636505558868", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_1025636508892201_430688725369663184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zh4f2nfOalwQ7kNvgEqXx79&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsZdjs2ik0dDGDs6pu3MU5X1QG7Wxw4mWm0vqjMzA5DA&oe=66F54311"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "1630730634427910", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982566_1630730637761243_9068074757253837847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=adchlOLm1tUQ7kNvgFTYgbX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVoMbAroT0-DcLipiPR3pqLcap_jHtan_FNegI9JwOJQ&oe=66F55073"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Trasformate il vostro potenziale ed eccellete nella vostra carriera!\nScoprite il simulatore progettato per potenziare le vostre \"Soft Skills\" attraverso 5 capsule formative essenziali con le quali potrete: \n\n1\ufe0f\u20e3 Autovalutare le vostre competenze trasversali che vi aiuteranno ad adattarvi a diversi ambienti di lavoro.\n2\ufe0f\u20e3 Difendere un discorso davanti a un pubblico per migliorare le vostre capacit\u00e0 di comunicazione e di public speaking.\n3\ufe0f\u20e3 Esercitate i vostri punti di forza in un discorso commerciale.\n4\ufe0f\u20e3 Prendere decisioni per sviluppare le vostre capacit\u00e0 strategiche e analitiche.\n5\ufe0f\u20e3 Lavorare in gruppo per favorire la collaborazione e l'efficienza del gruppo.", "short_description": "Potenziate le vostre Soft Skills con il nostro simulatore di realt\u00e0 virtuale! \n\nComposto da 5 capsule di formazione per: \n1\ufe0f\u20e3 Autovalutare le vostre competenze trasversali.\n2\ufe0f\u20e3 Migliorare le vostre capacit\u00e0 di comunicazione e di parlare in pubblico.\n3\ufe0f\u20e3 Difendere un discorso commerciale.\n4\ufe0f\u20e3 Accelerare il processo decisionale.\n5\ufe0f\u20e3 Incoraggiare il lavoro di squadra.\n\nIdeale per i professionisti che desiderano migliorare le proprie capacit\u00e0 relazionali in modo coinvolgente, interattivo ed efficace"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1994020534333698", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974910_1994020537667031_8688105079957652849_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2D8dVlBB4-QQ7kNvgGivE_b&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-An9hLDicW-rbxYAoNrnt4xvdoiuqdmUPkuKV5iDiJw&oe=66F556C3"}, {"file_name": "SoftSkills_Cover-square_1440x1440px.png", "id": "1247184912914732", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035311_1247184916248065_2567077078745571082_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dXlUaHyhkMEQ7kNvgFtz-Ap&_nc_ht=scontent.oculuscdn.com&oh=00_AYCW1Vgnpi2bJQjFyP5ncvGRABxWX5azbV6GZkqGENL7ag&oe=66F564F3"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "1187254515612530", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974888_1187254518945863_7395065576696775988_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsS_K_PMUL8Q7kNvgGI27JV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiyKdoC1dNVolmHRy0beMJL8iAbf8rjEffCujxcq480g&oe=66F55540"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1151595012723300", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982662_115159501