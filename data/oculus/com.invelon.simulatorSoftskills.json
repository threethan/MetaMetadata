-assess your transversal competences that will help you adapt to different work environments.\n2\ufe0f\u20e3 Defend a speech before an audience to improve your communication and public speaking.\n3\ufe0f\u20e3 Train your strengths in a commercial speech.\n4\ufe0f\u20e3 Make decisions to develop your strategic and analytical skills.\n5\ufe0f\u20e3 Work in a team to encourage collaboration and group efficiency.\n6\ufe0f\u20e3 Prepare to successfully conduct a job interview.", "short_description": "Boost your \"Soft Skills\" with our Virtual Reality Simulator! Ideal for professionals looking to improve their interpersonal skills in an immersive, interactive and efective way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.auroracloud.app/terms/view/site-terms/", "developer_terms_of_service_url": "https://www.auroracloud.app/terms/view/site-terms/", "publisher_name": "Invelon Technologies", "support_website_url": null, "website_url": "https://invelon.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ca", "es", "it"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "27358723887060124"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035311_1247184916248065_2567077078745571082_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QWNYMUx-Ey4Q7kNvgFT8ttU&_nc_ht=scontent-iad3-2.oculuscdn.com&o