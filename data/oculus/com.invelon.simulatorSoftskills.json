&_nc_ht=scontent.oculuscdn.com&oh=00_AYApiFeWOi4DYyVk2r-4EtbpzfBnyIL1bUm0aQF5STO2gg&oe=66E95E10"}, {"file_name": "SoftSkills-IT_Screenshot-4_2560x1440px.png", "id": "466990229364879", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_466990232698212_429966222944110534_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6RgBdIdu0YkQ7kNvgG0D24W&_nc_ht=scontent.oculuscdn.com&oh=00_AYBY-7E5Vom1Er_MYuEFxUmqB8ezN6BPbJD1ZFHLVMEV3Q&oe=66E96D89"}, {"file_name": "SoftSkills-IT_Screenshot-5_2560x1440px.png", "id": "1025636505558868", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_1025636508892201_430688725369663184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bs_iptmjZn0Q7kNvgG98jYB&_nc_ht=scontent.oculuscdn.com&oh=00_AYAI84f7boXeli_6fSWL7CBY-M0PRvGbAE-GF8orIwM7KA&oe=66E96591"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SoftSkills_Cover-Landscape_2560x1440px.png", "id": "1630730634427910", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982566_1630730637761243_9068074757253837847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6aymhISHSb4Q7kNvgGCEUKd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCcRb7qplqo5vkGebRN_B4IL9NN5wHsGdkqUbb198mUqg&oe=66E972F3"}, "display_name": "Simulador Soft Skills", "keywords": [], "long_description": "Trasformate il vostro potenziale ed eccellete nella vostra carriera!\nScoprite il simulatore progettato per potenziare le vostre \"Soft Skills\" attraverso 5 capsule formative essenziali con le quali potrete: \n\n1\ufe0f\u20e3 Autovalutare le vostre competenze trasversali che vi aiuteranno ad adattarvi a diversi ambienti di lavoro.\n2\ufe0f\u20e3 Difendere un discorso davanti a un pubblico per migliorare le vostre capacit\u00e0 di comunicazione e di public speaking.\n3\ufe0f\u20e3 Esercitate i vostri punti di forza in un discorso commerciale.\n4\ufe0f\u20e3 Prendere decisioni per sviluppare le vostre capacit\u00e0 strategiche e analitiche.\n5\ufe0f\u20e3 Lavorare in gruppo per favorire la collaborazione e l'efficienza del gruppo.", "short_description": "Potenziate le vostre Soft Skills con il nostro simulatore di realt\u00e0 virtuale! \n\nComposto da 5 capsule di formazione per: \n1\ufe0f\u20e3 Autovalutare le vostre competenze trasversali.\n2\ufe0f\u20e3 Migliorare le vostre capacit\u00e0 di comunicazione e di parlare in pubblico.\n3\ufe0f\u20e3 Difendere un discorso commerciale.\n4\ufe0f\u20e3 Accelerare il processo decisionale.\n5\ufe0f\u20e3 Incoraggiare il lavoro di squadra.\n\nIdeale per i professionisti che desiderano migliorare le proprie capacit\u00e0 relazionali in modo coinvolgente, interattivo ed efficace"}, {"images": {"nodes": [{"file_name": "SoftSkills_Logo_8100x1296px.png", "id": "1994020534333698", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974910_1994020537667031_8688105079957652849_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=io63W8AzwLcQ7kNvgGQWkU7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZUnPQtjHUTI6EiS-J80GA46hSsPejqXcg3Ury_49lBQ&oe=66E97943"}, {"file_name": "SoftSkills_Cover-square_1440x1440px.png", "id": "1247184912914732", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035311_1247184916248065_2567077078745571082_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vSgX89C-8lsQ7kNvgGBEA83&_nc_ht=scontent.oculuscdn.com&oh=00_AYDe5MVEyv-qekHYjfxsl0eLQWXs5Vp6ASN28RXJx2PfIg&oe=66E94F33"}, {"file_name": "INVELON_Icon-512x512px.png", "id": "1187254515612530", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974888_1187254518945863_7395065576696775988_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YEMQNapybdYQ7kNvgHhHQVY&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5cmQLctjBO0xN1urKQWlBAirlP2t-ehw91AeBiR3KqA&oe=66E977C0"}, {"file_name": "SoftSkills_Cover-portrait_1008x1440px.png", "id": "1151595012723300", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982662_115159501