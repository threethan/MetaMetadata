 and even Oculus Rift apps. \n\nIf you would like to learn more about creating and viewing VR tours with theViewer, visit theViewer.co/getstarted"}]}, "developer_name": "theConstruct", "developer_privacy_policy_url": "https://theconstruct.io/theviewer/privacypolicy", "developer_terms_of_service_url": "http://theConstruct.co/theviewer/terms-of-service", "publisher_name": "theConstruct", "support_website_url": "https://theviewer.co/", "website_url": "https://theViewer.co/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY", "UTILITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "526023561956651"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162814_1246993885399024_9042037920617201664_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lD4l0rMnxyMQ7kNvgFjOv1k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCb11nV2xh5uoo42X_f-3QdcvrAmsmeJ9mC1LtkDhPLmQ&oe=6745A341"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "theViewer", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1481702400, "lastRevision": {"nodes": [{"id": "492739717582120", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "955859367860314", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_