c_ohc=3qXaFDfOu6IQ7kNvgFLrosB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Axf_YBRJ3jj6ngOVgFSOxvk&oh=00_AYAcg2PFm7Om-uRwiF1OD4VIF_sFbUvezNvoVUrMrpnCcA&oe=66E2D1F8"}, {"file_name": "migrated_image.png", "id": "768306283695105", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974768_771400883324779_6141997975687135232_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FLI7zAW888kQ7kNvgGtG082&_nc_ht=scontent.oculuscdn.com&_nc_gid=Axf_YBRJ3jj6ngOVgFSOxvk&oh=00_AYATYg0qHERiSXwc7MlAIGE6JNb0NJbcEKkMh45DW5wgTQ&oe=66E2CBC1"}, {"file_name": "migrated_image.png", "id": "212896809791666", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139431_152317575263210_6335788124148334592_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gbusHclvkSoQ7kNvgGkZe2_&_nc_ht=scontent.oculuscdn.com&_nc_gid=Axf_YBRJ3jj6ngOVgFSOxvk&oh=00_AYAWxiZrPrOh5rQ0BweciA3qyIibEZuNDLDLK1X9XaGppA&oe=66E2C1E5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/LEgCS3", "id": "3782308705143148", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974611_3782308708476481_2451469145309446144_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rgvN1UQOUskQ7kNvgERA1x2&_nc_ht=scontent.oculuscdn.com&_nc_gid=Axf_YBRJ3jj6ngOVgFSOxvk&oh=00_AYAZd2TEJr7VD3rPB0AXd8xSoCkWSX2QHegmIsgL2z4T2A&oe=66E2B743"}, "display_name": "theViewer", "keywords": ["360", "Panorama", "Picture", "Archviz", "Architecture"], "long_description": "There is no Better Way to Create VR Tours than theViewer. \n\nNo matter if you are an architect or an amateur photographer, with theViewer you can create VR tours from 360 images in minutes and immediately view them via Android, iOS, GearVR and even Oculus Rift apps. \n\nVisit theViewer.co to find out more about special features like : \n- magic links \n- shared experience \n- embedded VR \nand many more .\n\nImages provided by The Boundary.", "short_description": "There is no Better Way to Create VR Tours than theViewer. \n\nNo matter if you are an architect or an amateur photographer, with theViewer you can create VR tours from 360 images in minutes and immediately view them via Android, iOS, GearVR and even Oculus Rift apps. \n\nIf you would like to learn more about creating and viewing VR tours with theViewer, visit theViewer.co/getstarted"}]}, "developer_name": "theConstruct", "developer_privacy_policy_url": "https://theconstruct.io/theviewer/privacypolicy", "developer_terms_of_service_url": "http://theConstruct.co/theviewer/terms-of-service", "publisher_name": "theConstruct", "support_website_url": "https://theviewer.co/", "website_url": "https://theViewer.co/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY", "UTILITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "526023561956651"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162814_1246993885399024_9042037920617201664_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FGNhPd3upUIQ7kNvgFEyXqZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Axf_YBRJ3jj6ngOVgFSOxvk&oh=00_AYDG_P0AjBLopfsV0c5DaPpcefElZ-pmlNxbFUbp5AaxUg&oe=66E2C2C1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "theViewer", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1481702400, "lastRevision": {"nodes": [{"id": "492739717582120", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US"