c_ohc=diJmGm8ixScQ7kNvgF1MHzi&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLOeOcxPa7sZA9nX46uoHO&oh=00_AYBavtN8FqcjEW2dU9uV02k7jy2iZuzr3d5zBNB_4-QALg&oe=66E6C678"}, {"file_name": "migrated_image.png", "id": "768306283695105", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974768_771400883324779_6141997975687135232_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oouyNWMAC0QQ7kNvgFXpNTX&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLOeOcxPa7sZA9nX46uoHO&oh=00_AYCZUM8vJAQd9axI9-_POnBsNf4WJrSRws7pdXJG4JL0cw&oe=66E6C041"}, {"file_name": "migrated_image.png", "id": "212896809791666", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139431_152317575263210_6335788124148334592_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IXqeoLh7YzoQ7kNvgFbomvW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLOeOcxPa7sZA9nX46uoHO&oh=00_AYDjDS5lUcgwTDLLeBrXWkW37Nm_mCfZy1_5KEZXsFZFDw&oe=66E6B665"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/LEgCS3", "id": "3782308705143148", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974611_3782308708476481_2451469145309446144_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HR31kmotCkYQ7kNvgGeFE4_&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLOeOcxPa7sZA9nX46uoHO&oh=00_AYClD5XYAyBaDrQeK_RsFfdxvCDxoKDuhZZlTFWGHoHWpw&oe=66E6ABC3"}, "display_name": "theViewer", "keywords": ["360", "Panorama", "Picture", "Archviz", "Architecture"], "long_description": "There is no Better Way to Create VR Tours than theViewer. \n\nNo matter if you are an architect or an amateur photographer, with theViewer you can create VR tours from 360 images in minutes and immediately view them via Android, iOS, GearVR and even Oculus Rift apps. \n\nVisit theViewer.co to find out more about special features like : \n- magic links \n- shared experience \n- embedded VR \nand many more .\n\nImages provided by The Boundary.", "short_description": "There is no Better Way to Create VR Tours than theViewer. \n\nNo matter if you are an architect or an amateur photographer, with theViewer you can create VR tours from 360 images in minutes and immediately view them via Android, iOS, GearVR and even Oculus Rift apps. \n\nIf you would like to learn more about creating and viewing VR tours with theViewer, visit theViewer.co/getstarted"}]}, "developer_name": "theConstruct", "developer_privacy_policy_url": "https://theconstruct.io/theviewer/privacypolicy", "developer_terms_of_service_url": "http://theConstruct.co/theviewer/terms-of-service", "publisher_name": "theConstruct", "support_website_url": "https://theviewer.co/", "website_url": "https://theViewer.co/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY", "UTILITY", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "526023561956651"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162814_1246993885399024_9042037920617201664_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zo-llJ-LZUwQ7kNvgGrhwM5&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLOeOcxPa7sZA9nX46uoHO&oh=00_AYBo4od7FrAF60UlvJRNQ_8gF1SmrXFSPWjFuxNut-aRfQ&oe=66E6B741"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "theViewer", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1481702400, "lastRevision": {"nodes": [{"id": "492739717582120", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US"