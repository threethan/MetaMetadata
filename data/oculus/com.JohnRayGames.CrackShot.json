a&_nc_ohc=tfid-K5i0XcQ7kNvgFSRSk7&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBlHwZV-mW1HaledDbex0ZFrmzvyHZIyb27LSMuHX2zwg&oe=671246F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "897295084973730", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75435289_897295088307063_5635641879931495254_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fyFEKqO5wGwQ7kNvgHCyh35&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBCUH7DztCe6VdcCp_l-NU1aHeU-IS9b6UnV-P9c43hjw&oe=671259E7"}, "display_name": "Crack Shot: Farm Frenzy Showdown", "keywords": ["Arcade", "clasic", "retro", "shooting", "animals"], "long_description": "Dang those varmints! Your peaceful farm is under siege, and it\u2019s up to you to defend your livestock from these pesky intruders. Armed with a trusty pump-action shotgun, you\u2019ll stand your ground on your porch and protect your territory.\n\nInspired by classic light gun games of the '80s, \"Crack Shot\" brings nostalgic shooting gallery fun to VR. As varmints and livestock pop up across your land, you have just 5 seconds to identify and eliminate the threats. Remember, don't shoot the livestock\u2014they're your pride and joy!\n\nHow quick is your draw? Sharpen your reflexes and prove your skills in this thrilling VR shooter.", "short_description": "Dang those varmints! Your peaceful farm is under siege, and it\u2019s up to you to defend your livestock from these pesky intruders. Armed with a trusty pump-action shotgun, you\u2019ll stand your ground on your porch and protect your territory."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/crackshot", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category"