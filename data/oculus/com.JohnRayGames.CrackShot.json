m/v/t64.5771-25/39031628_1945146275684116_3826679853630214683_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g9Y9e-V-EQUQ7kNvgFcBt4O&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOFkJYdwyxSvFbFuIZhDV5y&oh=00_AYD4ufR-Uyz8b1PRfbMPt_Ix_RhkU6CxzqyMVeNLIMS27Q&oe=66F2A2F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "897295084973730", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75435289_897295088307063_5635641879931495254_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RCYzRt8RRiAQ7kNvgHIdkFA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOFkJYdwyxSvFbFuIZhDV5y&oh=00_AYCr79_HloLcx1llz42uwzyWM_6RRbouVBXbCKs2uYKl9w&oe=66F2B5E7"}, "display_name": "Crack Shot: Farm Frenzy Showdown", "keywords": ["Arcade", "clasic", "retro", "shooting", "animals"], "long_description": "Dang those varmints! Your peaceful farm is under siege, and it\u2019s up to you to defend your livestock from these pesky intruders. Armed with a trusty pump-action shotgun, you\u2019ll stand your ground on your porch and protect your territory.\n\nInspired by classic light gun games of the '80s, \"Crack Shot\" brings nostalgic shooting gallery fun to VR. As varmints and livestock pop up across your land, you have just 5 seconds to identify and eliminate the threats. Remember, don't shoot the livestock\u2014they're your pride and joy!\n\nHow quick is your draw? Sharpen your reflexes and prove your skills in this thrilling VR shooter.", "short_description": "Dang those varmints! Your peaceful farm is under siege, and it\u2019s up to you to defend your livestock from these pesky intruders. Armed with a trusty pump-action shotgun, you\u2019ll stand your ground on your porch and protect your territory."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/crackshot", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wi