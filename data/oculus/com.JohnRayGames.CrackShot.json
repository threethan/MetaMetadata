gECzihZ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_qqUVpwUu0aJTc4DzthQBQ0vyI8_8IDQhNRXH8dlYDQ&oe=670517F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "897295084973730", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75435289_897295088307063_5635641879931495254_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DN2p5WOVi_IQ7kNvgEl3lMm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6jgzp_MB1GZOOn30jXNcbZahxkdrURVJJFlQzLx-sMw&oe=67052AE7"}, "display_name": "Crack Shot", "keywords": [], "long_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out.\n\nCrack Shot is a shooting gallery like the old light gun games of the 80's.  It's everything classic console kids loved!\n\nYou are a farmer armed with a pump action shot gun.  Standing on your porch, overlooking your land, varmints will pop-up along with livestock.  You have 5 seconds to identify the varmints and \"Git 'Em!\"\n\nDon't shoot the livestock.  They are your pride and joy.  \n\nHow quick is your draw?", "short_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/crackshot", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCAD