ontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031628_1945146275684116_3826679853630214683_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-DjTEiRvRoQ7kNvgEt558G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAx93UiD05Es2Ulh8vbfM0O54_Ds9hhCgnih3i69HTP4A&oe=6745B178"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "897295084973730", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75435289_897295088307063_5635641879931495254_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TLbWkjEMvwAQ7kNvgFsyh06&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDatiDpBirX6NNTvuxbOucR2x2c19XKRlaKyXzptkCEPw&oe=6745C467"}, "display_name": "Crack Shot", "keywords": [], "long_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out.\n\nCrack Shot is a shooting gallery like the old light gun games of the 80's.  It's everything classic console kids loved!\n\nYou are a farmer armed with a pump action shot gun.  Standing on your porch, overlooking your land, varmints will pop-up along with livestock.  You have 5 seconds to identify the varmints and \"Git 'Em!\"\n\nDon't shoot the livestock.  They are your pride and joy.  \n\nHow quick is your draw?", "short_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/crackshot", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAME