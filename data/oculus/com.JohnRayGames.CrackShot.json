Q7kNvgFZ6E13&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtD9toGexHRpXBqsYYIxowaxbMKX9pVqtq1A5UJIYnfg&oe=66FE9367"}, "display_name": "Crack Shot", "keywords": [], "long_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out.\n\nCrack Shot is a shooting gallery like the old light gun games of the 80's.  It's everything classic console kids loved!\n\nYou are a farmer armed with a pump action shot gun.  Standing on your porch, overlooking your land, varmints will pop-up along with livestock.  You have 5 seconds to identify the varmints and \"Git 'Em!\"\n\nDon't shoot the livestock.  They are your pride and joy.  \n\nHow quick is your draw?", "short_description": "Dang these varmints!  Your farm has some unwanted visitors and you must get rid of them before they eat your livestock.  Armed with your pump action shotgun, its time to clear 'em out."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/crackshot", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": [