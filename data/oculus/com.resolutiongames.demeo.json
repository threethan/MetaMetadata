CKo-G0B706YDg9Gr5L6i6OycV3w&oe=670E6DB5"}, {"file_name": "screenshot_4.png", "id": "172713377912571", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974730_172713381245904_8730668830560331749_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=flkWs3c3Bi8Q7kNvgGfikTy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6KSsQlqBDXd-LI14Eqvw2UWj5YuMpfV2GlfWAn6Tp8w&oe=670E5B70"}, {"file_name": "screenshot_5.png", "id": "479270489785045", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974853_479270493118378_1762075908437022446_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FHb7lgOoPVoQ7kNvgF7BJx_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLnSLL9MbDYD1p-t3VYDiR3VsmHbY8m72FWNFFMPGOaw&oe=670E6399"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DEMEO HERO ART NEW.png", "id": "2755632404736706", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982701_2755632411403372_1433407816910889392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CWDWulHtUO8Q7kNvgFmShQU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCIH4kHdcFfxr5g2J-nYGED5KymMFUJDRb8lyJVjHfcuQ&oe=670E4FE5"}, "display_name": "Demeo", "keywords": [], "long_description": "RPG fans, it\u2019s time to unite\u2026 and add Demeo to your Wishlist!\n\nA dark force has taken over the underworld in Resolution Games\u2019 upcoming RPG dungeon crawler, Demeo, and it\u2019s a world you\u2019re not likely to survive alone. Terrors and treasure await as you and your band of warriors come together for a virtual game night to brave the corrupted catacombs of Demeo and delve into the most immersive role-playing experience available in VR. \n\nWithin the fantasy roguelike game of Demeo, up to four players assume the role of eagle-eyed hunter, mystical sorcerer, deadly assassin or protective guardian. But choose your champions wisely in this cooperative virtual tabletop adventure, for once you have ventured into the Elven Necropolis, players must work together to vanquish the unholy armies of The Mad Elven King and set him free... or die trying.\n\nThe ultimate outcome depends on your choices, and whether the die is rolled in your favor\u2026\n", "short_description": "Gather your friends and brave the unhallowed catacombs of Resolution Games\u2019 RPG dungeon crawler, Demeo. Add to your Wishlist now!\n\nTerrors and treasure await as you and up to three friends unite in this cooperative turn-based game to combat the forces of evil and vanquish the armies of The Mad Elven King. \n\nBut choose your champions wisely in this virtual tabletop game; once you have ventured into the necropolis, you and your band of warriors must conquer the nether floors... or die trying. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.resolutiongames.com/privacy", "developer_terms_of_service_url": "https://www.resolutiongames.com/terms-of-use", "publisher_name": "Resolution Games", "support_website_url": "https://www.resolutiongames.com/support", "website_url": "https://www.resolutiongames.com/demeo", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "RPG", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "ja", "de", "fr", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "331506928878955"}}]}, "scheduled_offers": {"count": 43, "nodes": [{"status": "PUBLISHED", "id": "1195906178325020"}, {"status": "PUBLISHED", "id": "1468281767101495"}, {"status": "PUBLISHED", "id": "