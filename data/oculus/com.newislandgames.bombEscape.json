scdn.com/v/t64.5771-25/12138943_1811838785694781_5877118756903190528_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-fDuB5hMrYQ7kNvgHK16Jz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXQRTFeC_0a4tf0cgRBjHDU&oh=00_AYCpC2tnHXAysWjmJLyr6IKY61w9DobfKO1c-bmG2CgTxw&oe=66DD94D3"}, "display_name": "Escape!VR", "keywords": ["Escape", "Puzzle", "Room", "Indie", "Difficult"], "long_description": "Escape!VR is an escape room puzzle game for the Gear VR. The player is trapped in a room, and must use only their wits to make it out alive.\n\nEscape!VR's first room features a time bomb waiting to explode. in order to save yourself, you'll need to figure out how to defuse the bomb, and not have it explode in your face!\n\nEscape!VR features an extra movement system for those who experience motion sickness, accessible from the main menu.\n\nIn the future, we are hoping to release additional rooms as DLC.", "short_description": "Trapped in a room with no exit, your only hope is to solve the puzzles surrounding you. You'll need to act quickly to escape with your life.\n\nDo you have what it takes to survive?"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.newislandstudios.com/privacy/", "developer_terms_of_service_url": "http://www.newislandstudios.com/tos/", "publisher_name": "New Island Studios", "support_website_url": null, "website_url": "http://www.newislandstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PUZZLE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "358332365814262"}}]