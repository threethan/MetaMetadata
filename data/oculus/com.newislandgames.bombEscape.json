0485256192_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hnoq0njrnLcQ7kNvgH9tTqq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXQRTFeC_0a4tf0cgRBjHDU&oh=00_AYDN_GbnE0sZ8tkmp1XZ6WyBwPEC3T_hObqod5SUTrUiZA&oe=66DD8736"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Escape!VR", "keywords": ["Escape", "Puzzle", "Room", "Indie", "Difficult"], "long_description": "Escape!VR is an escape room puzzle game for the Gear VR. The player is trapped in a room, and must use only their wits to make it out alive.\n\nEscape!VR's first room features a time bomb waiting to explode. in order to save yourself, you'll need to figure out how to defuse the bomb, and not have it explode in your face!\n\n\"The Yacht\" is now available for purchase! In our newest room, you are a spy on board an enemy ship. Left to die as it sinks, you'll need to figure out how to contact your agency for evacuation before you drown!\n\nIf you cant figure out any of the puzzles in Escape!VR, you can find the solutions at bit.ly/EscapeVRSolutions", "short_description": "Trapped in a room with no exit, your only hope is to solve the puzzles surrounding you. You'll need to act quickly to escape with your life.\n\nDo you have what it takes to survive?"}]}, "developer_name": "New Island Studios", "developer_privacy_policy_url": "http://www.newislandstudios.com/privacy/", "developer_terms_of_service_url": "http://www.newislandstudios.com/tos/", "publisher_name": "New Island Studios", "support_website_url": null, "website_url": "http://www.newislandstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "sup