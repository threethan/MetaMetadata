c_sid=6e7a0a&_nc_ohc=qI_TdqBN4QUQ7kNvgEd1FPE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxoQJMP7RAIbp20uKGjXmhr7xUQ6ykpy2vBMO0e5bWlA&oe=66FBD8FE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "595470604898250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_595470611564916_2866895790321003534_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tRlACHRfIK0Q7kNvgEJ6btr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmQcSLg-2UrFGxp40Wv5saDYUgwtGCencY92-tUPTZ8A&oe=66FBC9A0"}, "display_name": "Lost in Place", "keywords": [], "long_description": "Dear Volunteer,\nThanks for accepting our invitation to run through these challenging trials. We'll be testing your cognitive and motor functions as you pilot a little ship around a variety of environments. The ship is very touchy, quite expensive, and it will break on just about everything. Don't worry though, you'll only be graded on your performance! We've established strict metrics to stimulate your competitive spirit and get your blood pumping. You can even compare yourself to other volunteers to see how well you are doing. Just a little friendly competition, nothing nefarious on our end. On that note, please do your very best and try to have fun. ", "short_description": "Pilot a delicate little ship through a variety of environments.\nCollect the coins, compete with friends, and try not to crash!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://llcbrightcorners.wixsite.com/bright-corners-llc/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bright Corners LLC", "support_website_url": null, "website_url": "https://llcbrightcorners.wixsite.com/bright-corners-llc", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "ADVENTURE"], "has_in_app_