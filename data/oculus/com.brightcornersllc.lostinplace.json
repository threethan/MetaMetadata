scdn.com&oh=00_AYC2IbOJclhRoLzk2dKcxmHuujIsq3xCZKhQbkkW2cpQMg&oe=674451B2"}, {"file_name": "5.png", "id": "1049883949143458", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003280_1049883952476791_1397821982617140448_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpa4jx_77P0Q7kNvgHG0CbU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVBv0ia5h8BFgRjc_1VLx5wC53M7jNVhBgtktaHFuBNA&oe=67445B7E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "595470604898250", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031463_595470611564916_2866895790321003534_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ppxrldEnBbMQ7kNvgEQOdOT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXActXcLAz2mgn2qxaeMD6-qNQp7DF9bLCV7m_NRsVcQ&oe=67444C20"}, "display_name": "Lost in Place", "keywords": [], "long_description": "Dear Volunteer,\nThanks for accepting our invitation to run through these challenging trials. We'll be testing your cognitive and motor functions as you pilot a little ship around a variety of environments. The ship is very touchy, quite expensive, and it will break on just about everything. Don't worry though, you'll only be graded on your performance! We've established strict metrics to stimulate your competitive spirit and get your blood pumping. You can even compare yourself to other volunteers to see how well you are doing. Just a little friendly competition, nothing nefarious on our end. On that note, please do your very best and try to have fun. ", "short_description": "Pilot a delicate little ship through a variety of environments.\nCollect the coins, compete with friends, and try not to crash!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://llcbrightcorners.wixsite.com/bright-corners-llc/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bright Corners LLC", "support_website_url": null, "website_url": "https://llcbrightcorners.wixsite.