e=670272E9"}, {"file_name": "Screenshots_Meta_04.png", "id": "1136017874278129", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75278189_1136017884278128_1362407361388834626_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vh0atMGYaJAQ7kNvgHTNTvC&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCwv3zvFYWID_phe_Q4vG-lJAJr-ifQ3P30QGTPIQAwcA&oe=6702871D"}, {"file_name": "Screenshots_Meta_05.png", "id": "7333723780090696", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75294236_7333723783424029_5291761923753772822_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_rlmQRNusb4Q7kNvgHZY67v&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBRSLQSZaiOU7PzckR5vksVFSR-CKKxMU2vAZz-LQAgug&oe=67026AF6"}, {"file_name": "Screenshots_Meta_02.png", "id": "1513357192621784", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982516_1513357195955117_6174693129875413070_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nTasrAf_F14Q7kNvgF1p4nW&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCPOL3kJDL0yZLCIH2qYSKOlQ8qYQEsq5oQTZPfmpD8Bw&oe=67028353"}, {"file_name": "Screenshots_Meta_03.png", "id": "1181435812887846", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75593951_1181435819554512_877949554879432256_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x5N8VqpWCfIQ7kNvgFimmOn&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCPqcOWbdFSkjslPtjnsASqGKMJbvu-ltfMuLv91SBXwg&oe=670284D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover_Img_001.png", "id": "2187345501600076", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/86855014_2187345508266742_5199150707683997454_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oDkB7Fyljp8Q7kNvgHRJT7d&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYA3raazPbwDjdEBCZeX6No8Yb0jFN_9way6KPgZCgdPXw&oe=67027D56"}, "display_name": "VR Singing Club", "keywords": [], "long_description": "VR Singing Club is a virtual reality experience where people can share in wonder and joy through the medium of singing! Socialize with others in fun, interactive environments,  choose from a variety of classic songs and get ready to sing your heart out!\n\n\"Happiness is singing together when day is through, and happiness is those who sing with you\"\n-- Clark Gesner\n\nSocial Singing Club:\nConnect with friends, select a track and hit those high notes together for an immersive and gleeful experience.\n\nSomething For Everyone:\nThanks to the power of VR, anyone can join a choir from the comfort of their own armchair. VR Singing Club is simple, accessible and built to be inclusive.\n\nSing With Melody and Mike:\nWant a little practise on the side? Or playing a solo session and need someone to harmonize with? Our NPCs are voiced by professional singers and are ready to be the Sonny to your Cher!\n\nVR Worlds That Come Alive with Song:\nEdith Piaf said: \"Singing is a way of escaping. It's another world. I'm no longer on Earth.\" \n\nWe agree! This makes VR the perfect pairing. In VR Singing Club you will visit unique and interactive environments designed to elevate, immerse, and entertain.\n\nA Dedicated and Growing Team of VR Veterans:\nDevelopment is on-going, and our team of passionate song birds have big plans for VR Singing Club. Expect future updates, big events and new features in the months ahead.\n\nSo what are you waiting for? Grab a microphone and jump in!", "short_description": "VR Singing Club is a virtual reality experience where people can share in wonder and joy through the medium of singing! Socialize with others in fun, interactive environments,  choose from a variety of classic songs and get ready to sing your heart out!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrtogether.us/vrsc-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VRTogether Company", "support_website_url": null, "website_url": "https://www.vrtogether.us/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_cate