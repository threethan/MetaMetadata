_v8.png", "id": "1037781791290676", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39001658_1037781794624009_6624192729511668284_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4MTqEsPuoy4Q7kNvgGQs2JS&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD69726oZu8bYOvN_ao4ukEIjBHl620eUKhoFtCESRL1g&oe=67028EDF"}, {"file_name": "Meta_Cover_Portrait_1008x1440_v8.png", "id": "873260627943650", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974757_873260631276983_5773174081535201774_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xl8VdwRPY9wQ7kNvgGLH1z3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBV1kogtbtxMsA6xqN3LeLkl2Vl19LCZu01rGFFLXxLSQ&oe=670262D8"}, {"file_name": "Meta_Cover_Landscape_2560x1440_v8.png", "id": "805053138247288", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/86610706_805053144913954_8465819034112164789_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mMD8kB7TLMwQ7kNvgELGL_O&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAPaK-TJycppOEQGN0GqVWICWQzUdXP6jCMQF7MmWVnvg&oe=6702816A"}, {"file_name": "Meta_ICON_512x512_v2_0.0.3.2.png", "id": "518975387404689", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982518_518975394071355_6549199507368947138_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2wnm5NTFJvEQ7kNvgGPzUOF&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAVbpJmyYlOTle2-fkq-FpaJ47R27ukE1ayF87AG8thmQ&oe=67027D63"}, {"file_name": "Meta_Cover_PDP_3000x900_v9.png", "id": "469360195743831", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75272207_469360199077164_4295844705400901964_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BQTdZ6j05ecQ7kNvgG_toAx&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYA3guwu4HZA6MB8fYYZxC-0DmdvZQzb_vZmLT8qp6bahA&oe=67027BA9"}, {"file_name": "Meta_Cover_Mini_1080x360_v8.png", "id": "453989500568976", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75207242_453989503902309_6735568882120842662_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azWh9yStH8EQ7kNvgGy3sJ4&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDn6n1BtVNsPSY4kuoh7Q4RSMtHvcUPtUgOnGAbyC2PjQ&oe=67028755"}]}, "id": "1000029502168438", "locale": "en_US", "screenshots": [{"file_name": "Screenshots_Meta_v2_0.0.3.2_0000_Screenshot_Meta_v2_0.0.3.2_007.png", "id": "1535708610401265", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/43997716_1535708613734598_2781462110890257670_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jS8rvJVNQh4Q7kNvgGJAQI2&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCFkNFDETy3hHqd2sbG-VZJ8Uep4wSP-kobenF9aP897g&oe=67027087"}, {"file_name": "Screenshots_Meta_v2_0.0.3.2_0001_Screenshot_Meta_v2_0.0.3.2_006.png", "id": "1223943632392078", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39035329_1223943635725411_8998183825703661115_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PedjzRn7syYQ7kNvgEOw1Fp&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB2HBStc8Du7sexZzSqa1WqPDC6VpUzhYGQZg3KOSNl5g&oe=670261E6"}, {"file_name": "Screenshots_Meta_v2_0.0.3.2_0002_Screenshot_Meta_v2_0.0.3.2_005.png", "id": "541603388385608", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035349_541603391718941_4953557008165082670_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLA2SdtOEGQQ7kNvgHfWgJQ&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCjsvxoIHAfZdE15r7XX3JhFnhnlln0p3X0hSPqc4e93Q&oe=67027E85"}, {"file_name": "Screenshots_Meta_v2_0.0.3.2_0003_Screenshot_Meta_v2_0.0.3.2_004.png", "id": "550679744067661", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031378_550679747400994_6575069865437499429_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gT_MqSsDDy8Q7kNvgFlBxpj&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB-bBH82W2ZgMJxF6sgSoSwMZDLFJsw-YC9Eq36yu6Ibg&oe=670282F9"}, {"file_name": "Screenshots_Meta_v2_0.0.3.2_0006_Screenshot_Meta_v2_0.0.3.2_001.png", "id": "534068012369340", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982526_534068019036006_2067380021066630160_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JjfidqUW2ykQ7kNvgGf2MZn&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCQgsBwug7gv3qRj768StFsGKjRsPR4nxF2KczHF9zjBg&oe=67028C60"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover_v2_0.0.3.2_001.png", "id": "1090721142773355", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982619_1090721146106688_4151963782195874473_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GoKOYU3vGTYQ7kNvgFG1qMk&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCrZdJQ6Qoq8M5E18OnfcznHZt6ozEgrdxjz3a_Bg784Q&oe=67026D5C"}, "display_name": "VR Singing Club", "keywords": [], "long_description": "VR Singing Club is a social singing experience where people can connect through the medium of singing!\n\n\"Happiness is singing together when day is through, and happiness is those who sing with you\" -- Clark Gesner\n\nA Growing List of Songs\nAn ever growing selection of officially licensed and well-known chart toppers to choose from, for a range of musical tastes.\n\nSing with a Pro\nHave you ever wanted to duet with a professional? Now\u2019s your chance! Our Mike and Melody NPC characters have been voiced by professional musicians and are ready to sing their hearts out in Duet Mode.\n\nConnect with Others\nWe think that singing is great, but singing together is even better! So we have dedicated ourselves to solving the technical hurdles that come with singing over the internet. As we work towards eliminating lag and making it a possibility, we are exploring lots of exciting ideas for making you feel immersed and connected. In VR Singing Club, you can join a friend and sing alongside them in a social singing experience. \n\nMore to Come\u2026\nDevelopment is on-going, and our team of passionate song birds have big plans for VR Singing Club. We are currently building unique and joyful singing experiences that you haven\u2019t seen before. \n\nWe\u2019d love to hear from you! Join our discord to be part of the discussion.\n", "short_description": "VR Singing Club is a social singing experience where people can connect through the medium of singing!\n\nMore to Come\u2026\nDevelopment is on-going, and our team of passionate song birds have big plans for VR Singing Club. We are currently building unique and joyful singing experiences that you haven\u2019t seen before. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrtogether.us/vrsc-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "VRTogether Company", "support_website_url": null, "website_url": "https://www.vrtogether.us/vrsc", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "668538087410124"}, {"id": "548013192910304"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8401250973294820"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39001658_1037781794624009_6624192729511668284_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4MTqEsPuoy4Q7kNvgGQs2JS&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYASd4JX0rEgX3SOHbR-6_WRar_z-litvpWibzq6lkzEyQ&oe=67028EDF"}, "is_concept": false, "is_test": fals