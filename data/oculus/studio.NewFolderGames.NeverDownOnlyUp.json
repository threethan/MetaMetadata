ng", "id": "703418071657871", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982457_703418074991204_3474156294011672162_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xhG6bl68cGoQ7kNvgGDT1uo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AA2uE1fkUYiEtmZId5P-J4Q&oh=00_AYDunWXtb-bGHnRCZy1FnReVAo9RkV_TeqlzZA8xC_iQwg&oe=66E81FF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 never down.png", "id": "696514919178135", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035431_696514922511468_61247615820750078_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0YpVZNzqhK8Q7kNvgGr3Jud&_nc_ht=scontent.oculuscdn.com&_nc_gid=AA2uE1fkUYiEtmZId5P-J4Q&oh=00_AYDyvYBf7WwI1imUkgV6clYTkip0R4wSX9FRf0VM33QB6A&oe=66E81CCB"}, "display_name": "Never Down - Only Up", "keywords": [], "long_description": "UPDATE IS NOW AVAILABLE! \n\nTry the game and support us and beat the records of other players!\n\nIn this addictive game you have to climb up by jumping and pushing off the floor. You need to be fast and agile to get to the top. The game offers many levels of varying difficulty that will allow you to upgrade your skills and become a real climbing master. In addition, the game has beautiful graphics and sound that will immerse you in the exciting world of the game.\n\nIn this game you will test your climbing skills. You must jump and push off the floor to get to the top. The game offers many levels of varying difficulty that will allow you to upgrade your skills and become a real climbing master.\n\nYou will experience a real adrenaline rush as you climb walls and jump from one platform to another. The game offers many unique tasks and levels of varying difficulty that will make you feel like a real hero.\n\nEnjoy addictive gameplay and become the best climber! Don't miss the opportunity to experience real adrenaline and become a real climbing master!\n\nNEW SOUNDS AND MUSIC WILL BE ADDED SOON!", "short_description": "Try to rise above the rest and beat the record!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "605163178388189"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1593658054895443"}, {"status": "PUBLISHED", "id": "1206114813868355"}, {"status": "PUBLISHED", "id": "1061042785257021"}]}, "baseline_offer": {"id": "1061042785257021"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725386400, "status": "PUBLISHED", "id": "1593658054895443"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6698200800277538", "version": "1.0.8"}, "id": "234475935574230", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6244747015622921", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6698200800277538"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_n