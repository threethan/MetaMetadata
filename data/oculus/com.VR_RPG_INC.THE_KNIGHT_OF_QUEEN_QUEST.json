48747467_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1qaFEdolsJEQ7kNvgEfIicr&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAHgXkoR1MVJfvu_TCuLMZ7YvgXhmqn8MhMDrsPcF2I9A&oe=6728C1AD"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": [], "long_description": "Once sealed in time by the legendary Hero, the Devil King broke free, and the world is on the brink of the chaos once again. \nAs the knight of the queen, you will depart on a mission to fight the Devil King and restore peace.\nCan you defeat the Devil King and save the world?\n\nThe battle system uses a one-to-one turn-based command input.\nWith a familiar old-school system, you can start playing right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR!\n\nYou can walk through fields and dungeons with a 360-degree view. The game gives you a more realistic feeling compared to the 2D experience on a TV or smartphone.", "short_description": "\u3010Turn-Based VR RPG\u3011\nDive into the world of an old-school RPG in VR !! \n\nBecome the Hero of his majesty the Queen, by explore the world to defeat the vicious Devil King, and bring peace for the people !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://www.vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "website_url": "https://www.theknightofqueen.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], 