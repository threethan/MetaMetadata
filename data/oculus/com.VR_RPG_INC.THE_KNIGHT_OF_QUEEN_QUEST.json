ent-sea1-1.oculuscdn.com&oh=00_AYDHyBe-tJZC5OA6IZQT42i2gtiGyFqYanB0qIjbdYB1Pw&oe=6710DED1"}, {"file_name": "SS1_EN.png", "id": "446937713154240", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974524_446937716487573_4416804926913257435_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Hd6mNiMVbYQ7kNvgFKsyD1&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCJyJdI0tzbJczSEq2gOGu3P-Psju577j9NUQioQwdnrg&oe=6710E45B"}, {"file_name": "SS4_EN.png", "id": "182975900248557", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031622_182975903581890_2732049728403921425_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IPdn3U3e7eUQ7kNvgEWaFII&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDYhUXGaoKA-_D7xc4QAIwcd1EbUjQA1LeXl4O8LImxbQ&oe=6710FCAC"}, {"file_name": "SS3_EN.png", "id": "179038630318961", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035320_179038633652294_3822399642803749135_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e2p49gK4y4cQ7kNvgGjjtwe&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAnzPl52_uG8JM4IIucbwAgaQ6fywRwjzssYygi0_SeyQ&oe=6710F926"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_main.png", "id": "1580567332330969", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003273_1580567335664302_3537293144248747467_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzjfRe_2h4kQ7kNvgHzUyg_&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAi8YaeVoEBHqho2xpfiUD2D61UlF-71EUwIX_PIuR1lg&oe=671106AD"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": [], "long_description": "Once sealed in time by the legendary Hero, the Devil King broke free, and the world is on the brink of the chaos once again. \nAs the knight of the queen, you will depart on a mission to fight the Devil King and restore peace.\nCan you defeat the Devil King and save the world?\n\nThe battle system uses a one-to-one turn-based command input.\nWith a familiar old-school system, you can start playing right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR!\n\nYou can walk through fields and dungeons with a 360-degree view. The game gives you a more realistic feeling compared to the 2D experience on a TV or smartphone.", "short_description": "\u3010Turn-Based VR RPG\u3011\nDive into the world of an old-school RPG in VR !! \n\nBecome the Hero of his majesty the Queen, by explore the world to defeat the vicious Devil King, and bring peace for the people !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://www.vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "website_url": "https://www.theknightofqueen.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1005805633612875"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "849385162572073"}]}, "baseline_offer": {"id": "849385162572073"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1616348400, "status": "PUBLISHED", "id": "849385162572073"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5748388848520475", "version": "1.2.6"}, "id": "458886025270326", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary",