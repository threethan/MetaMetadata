luscdn.com&oh=00_AYAmq-ncq0JIPDqRgKowWgQfB5OqumCDDodb_7PsE0fIjA&oe=66FD362C"}, {"file_name": "SS3_EN.png", "id": "179038630318961", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_179038633652294_3822399642803749135_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9d0vLxAu4o4Q7kNvgFoAi9t&_nc_ht=scontent.oculuscdn.com&oh=00_AYApWdsnLSs1-bzxxyCqKMPgmNXps64Ih5CtMGg6AE6mTA&oe=66FD32A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_main.png", "id": "1580567332330969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_1580567335664302_3537293144248747467_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tdr1aLFeLlkQ7kNvgENYZDn&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXtmflH0oSvLQ4PotxiJqNoOgDL2c5onYLMa9HQ4iC6w&oe=66FD402D"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": [], "long_description": "Once sealed in time by the legendary Hero, the Devil King broke free, and the world is on the brink of the chaos once again. \nAs the knight of the queen, you will depart on a mission to fight the Devil King and restore peace.\nCan you defeat the Devil King and save the world?\n\nThe battle system uses a one-to-one turn-based command input.\nWith a familiar old-school system, you can start playing right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR!\n\nYou can walk through fields and dungeons with a 360-degree view. The game gives you a more realistic feeling compared to the 2D experience on a TV or smartphone.", "short_description": "\u3010Turn-Based VR RPG\u3011\nDive into the world of an old-school RPG in VR !! \n\nBecome the Hero of his majesty the Queen, by explore the world to defeat the vicious Devil King, and bring peace for the people !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://www.vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "websit