.com&oh=00_AYCrrCHy2khsOj0WyUWBGMpuicCea2DLiH8ZE-_iF0B5cQ&oe=66E4115B"}, {"file_name": "SS4_EN.png", "id": "182975900248557", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031622_182975903581890_2732049728403921425_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCxiBsZL3lcQ7kNvgGn15PM&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9kySRK1f0nMH7-zJkOEZDbJp6id_JftB5dvIrFHMs3w&oe=66E429AC"}, {"file_name": "SS3_EN.png", "id": "179038630318961", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_179038633652294_3822399642803749135_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SGHNgl6H3sEQ7kNvgFIkVjn&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQ66SNACCtUEI57uw2wzo25r9mL2wKjEnipsm74V88Dg&oe=66E42626"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_main.png", "id": "1580567332330969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_1580567335664302_3537293144248747467_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SAiGdB8OcTYQ7kNvgGuk7OG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKk9TKmijU0RDVy4iAQlxUGGzj7-68eWlRtuPiGDiVPA&oe=66E433AD"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": [], "long_description": "Once sealed in time by the legendary Hero, the Devil King broke free, and the world is on the brink of the chaos once again. \nAs the knight of the queen, you will depart on a mission to fight the Devil King and restore peace.\nCan you defeat the Devil King and save the world?\n\nThe battle system uses a one-to-one turn-based command input.\nWith a familiar old-school system, you can start playing right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR!\n\nYou can walk through fields and dungeons with a 360-degree view. The game gives you a more realistic feeling compared to the 2D experience on a TV or smartphone.", "short_description": "\u3010Turn-Based VR RPG\u3011\nDive into the world of an old-school RPG in VR !! \n\nBecome the Hero of his majesty the Queen, by explore the world to defeat the vicious Devil King, and bring peace for the people !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://www.vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "website_url": "https://www.theknightofqueen.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1005805633612875"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_409617396813704_9214597668375379969_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L1rc1TJxatIQ7kNvgFp7eE_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAcJfQvQZDuy-wVapeSi3YX50PmkT8EZpRaU9VzaTregQ&oe=66E43057"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "THE KNIGHT OF QUEEN", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1616348391, "lastRevision": {"nodes": [{"id": "708454763178794", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5734211583271535", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "460158368194183"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "KQ_1080*360.png", "id": "78606