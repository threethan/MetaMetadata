.com&oh=00_AYA0j9bD5fA8LT8vvsT8W8xi5wSSfEUXPNxN9n4nlEO4Gg&oe=66D590DB"}, {"file_name": "SS4_EN.png", "id": "182975900248557", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031622_182975903581890_2732049728403921425_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ApdwvG2SnoQ7kNvgHVAEI0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAq8nPVfsaCbQUCrRhrAAz2AQgpW1uYSZgT7Fl2y9ArTg&oe=66D5A92C"}, {"file_name": "SS3_EN.png", "id": "179038630318961", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035320_179038633652294_3822399642803749135_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1V9MWZ4HvvoQ7kNvgEXDO2U&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEo3X9pHwn70NjUNMyEVhLhq7M8sHE7L9_PC_FMa7xwg&oe=66D5A5A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KQ_main.png", "id": "1580567332330969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_1580567335664302_3537293144248747467_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T2BVqm-nT9wQ7kNvgGZK6-F&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvm1E1H_YPcy1drIAh50xoGyPG_FCWWtikPhgn8qhiNw&oe=66D5B32D"}, "display_name": "THE KNIGHT OF QUEEN", "keywords": [], "long_description": "Once sealed in time by the legendary Hero, the Devil King broke free, and the world is on the brink of the chaos once again. \nAs the knight of the queen, you will depart on a mission to fight the Devil King and restore peace.\nCan you defeat the Devil King and save the world?\n\nThe battle system uses a one-to-one turn-based command input.\nWith a familiar old-school system, you can start playing right away, without any learning. Relive your imagination in your youth, 'Diving into the imaginary world' with VR!\n\nYou can walk through fields and dungeons with a 360-degree view. The game gives you a more realistic feeling compared to the 2D experience on a TV or smartphone.", "short_description": "\u3010Turn-Based VR RPG\u3011\nDive into the world of an old-school RPG in VR !! \n\nBecome the Hero of his majesty the Queen, by explore the world to defeat the vicious Devil King, and bring peace for the people !!"}]}, "developer_name": "VR RPG INC.", "developer_privacy_policy_url": "https://www.vrrpginc.com/en/privacy_policy", "developer_terms_of_service_url": null, "publisher_name": "VR RPG INC.", "support_website_url": null, "website_url": "https://www.theknightofqueen.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1005805633612875"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_409617396813704_9214597668375379969_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y3V2L8GslxUQ7kNvgGQaxfG&_nc_ht=scontent.oculuscdn.com&oh=00_AYDey7vR4Ups_i8JbAbWaI8f_D6BiOIaJYJiVovJ7i2J3A&oe=66D5AFD7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "THE KNIGHT OF QUEEN", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1616348391, "lastRevision": {"nodes": [{"id": "708454763178794", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5734211583271535", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "460158368194183"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "KQ_1080*360.png", "id": "78606