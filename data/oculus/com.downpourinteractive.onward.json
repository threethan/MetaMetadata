l locomotion will push your combat survival skills to their limit as you engage in infantry combat across a large variety of maps and combat situations.", "short_description": "Become fully immersed in the firefight! Onward is a Mil-sim multiplayer first person shooter built for virtual reality. Work closely with your team in the heat of battle and engage in the most realistic combat experience available in gaming today."}]}, "developer_name": "Downpour Interactive", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Coatsink", "support_website_url": "https://www.downpourinteractive.com/", "website_url": "https://www.downpourinteractive.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "1133971124017914"}}]}, "scheduled_offers": {"count": 49, "nodes": [{"status": "PUBLISHED", "id": "2420291231636063"}, {"status": "PUBLISHED", "id": "393292586145796"}, {"status": "PUBLISHED", "id": "1639852693193222"}, {"status": "PENDING", "id": "1401887330365384"}, {"status": "PUBLISHED", "id": "441066470957837"}, {"status": "PUBLISHED", "id": "5544862408935130"}, {"status": "PUBLISHED", "id": "389391327047759"}, {"status": "CANCELLED", "id": "229289972562358"}, {"status": "PENDING", "id": "690242829547765"}, {"status": "PUBLISHED", "id": "9411802