=6e7a0a&_nc_ohc=K3FG6lAKh9IQ7kNvgGrRMXF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM4aAP_KUHrfDDCXBRxenO7&oh=00_AYDH2fRk1mJVhKrlwsDXoUEOQoM5pK1eABHKo6EFmpPUjA&oe=66EFF216"}, {"file_name": "Bazaar_2560x1440.png", "id": "1354969538595878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_1354969545262544_3540638909545622039_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PivvpHX-wYoQ7kNvgGHAsC3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM4aAP_KUHrfDDCXBRxenO7&oh=00_AYCcKVHCZoflq1DdwqcJyjAzIc7zrKeafYbvr8O9Cv9G5Q&oe=66EFF727"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "onward_cover_landscape_1pt14_2560x1440_no_text.png", "id": "1040013507065071", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_1040013510398404_3405753826375285068_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=44FOr0CWJ5AQ7kNvgE1JVCZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM4aAP_KUHrfDDCXBRxenO7&oh=00_AYDVmD3AFsYIIdgyLf6dpfV4VxAn8SoKEcwgrtw8_cP2HQ&oe=66F005FD"}, "display_name": "Onward", "keywords": ["shooter", "FPS", "games", "multiplayer", "gun"], "long_description": "In Update 1.13 we are introducing more ways to play. For night mode we have made some major adjustments to NVG and Night Accessories. One new map (FOB Bassett) and one new variant map (Cargo Night). FOB Bassett will be released for Free Roam and Social game modes. Cargo Night has updated textures throughout, and new roof with directional lighting. Drastic improvements to our AI for our PVE modes. The AI has had a complete refactor done, making it feel like a whole new experience.\n\nAdditional Update Features: \n- Updates to Co-Op Game Mode \n- Updates for Quest 3 - Updated Tutorial & Training \n- Updates to Environment Graphics & Parity \n- Updates to Fire Fight Game Mode\n\nThe most immersive tactical first person VR shooter game. Join your squad for a wide variety of competitive PvP, co-op PvE, and solo game modes, including intense multiplayer battles or 4-player co-op missions.  Realistic weaponry and combat mechanics will push your survival and combat skills to their limit as you engage in gritty infantry combat across a large variety of maps and combat situations, with platform cross-play fully supported.  The only way is Onward.    \n\nThis is the hardcore multiplayer VR game you\u2019ve been looking for. To succeed on the battlefield, you must communicate, coordinate, and strike with your squad.  Defeat may be swift, but victory is sweet.  Challenge yourself and your friends with the most realistic infantry combat game.", "short_description": "In Update 1.13 we are introducing more ways to play. For night mode we have made some major adjustments to NVG and Night Accessories. One new map (FOB Bassett) and one new variant map (Cargo Night). FOB Bassett will be released for Free Roam and Social game modes. Cargo Night has updated textures throughout, and new roof with directional lighting. Drastic improvements to our AI for our PVE modes. The AI has had a complete refactor done, making it feel like a whole new experience."}]}, "developer_name": "Downpour Interactive", "developer_privacy_policy_url": "http://www.onwardthegame.com/privacy-policy/", "developer_terms_of_service_url": "http://www.onwardthegame.com/terms-of-service/", "publisher_name": "Downpour Interactive", "support_website_url": "https://www.onwardthegame.com/", "website_url": "https://www.onwardthegame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_i