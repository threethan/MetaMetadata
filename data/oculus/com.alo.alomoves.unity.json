name": "Screenshot 2  2560x1440px.png", "id": "2696766540475088", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75221331_2696766543808421_2593539058595962166_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wFE8E1kGOIYQ7kNvgGYpzwU&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAWTYmKcNxOTdbZjW6H9GIxYRzVvjhGGxEl23eQ5nLUiw&oe=6728B53F"}, {"file_name": "Screenshot 3  2560x1440px.png", "id": "2845570238941487", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/57569444_2845570245608153_268596645994255236_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wCe9hqVF-gkQ7kNvgErxjJZ&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCdEJVZT-Hn3sMJoH73DKMrgmKKtbtwpsIwBnRF7dJiRQ&oe=6728B9AC"}, {"file_name": "Screenshot 4  2560x1440px.png", "id": "1840108836490822", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974547_1840108839824155_1839831048900896906_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eY_V7llgvdQQ7kNvgGuOg-g&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAY8LAibi_mnyNQFQodpzt0YhGlMtX9Mc8pi06lFk0jYQ&oe=6728A510"}, {"file_name": "Screenshot 5  2560x1440px.png", "id": "825138912375626", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39035370_825138915708959_6729527716816302866_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WOOi09OG3koQ7kNvgFfpAnu&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAspzWneSf_fk5toEXECIkGn9jJQhJzUQJodUlwRea6Aw&oe=6728AAD0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Alo Moves XR", "keywords": [], "long_description": "Welcome to a new world of wellness.\nAlo Moves is the first-ever wellness sanctuary that seamlessly blends your space with immersive natural landscapes. Move, breathe, and relax with top instructors in yoga, Pilates, and mindfulness wherever you are.\n\nFEEL-GOOD GAMING\n\nChallenge your fitness with yoga and Pilates or hack your mindset with energy-shifting meditations and sound baths. You'll watch your strength, flexibility, and balance improve with classes from 5 to 30 minutes.\n\nLIKE IRL, BUT BETTER\n\nOur virtual studio maps your real surroundings for a next-level workout experience. Want to improve your form? Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. \n\nREDUCE YOUR STRESS\n\nHeadset on, distractions out. Block out the noise and quiet your thoughts with ambisonic audio-guided meditations and sound baths set in elevated environmental landscapes. You can even change your backdrop to match your mood and stay in the environment long after class ends. \n\nCREATE HEALTHY HABITS\n\nMeet a daily wellness routine you\u2019ll look forward to. Slip on the headset, step into a class, and see your strongest self come to life.\n", "short_description": "Welcome to a new world of wellness. Alo Moves is a virtual sanctuary that seamlessly blends your space with immersive natural landscapes. Move and relax with yoga, Pilates, and mindfulness wherever you are. Our studio maps your real surroundings for a next-level workout experience. Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. Slip on the headset, step into a class, and see your strongest self come to life."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "https://www.alomoves.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Meta", "support_website_url": null, "website_url": "https://www.alomoves.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": nu