": "981563030047379", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974924_981563033380712_5939035335806690736_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TjEk0C_RsyEQ7kNvgEpCA-1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_zFTW4U3jisiuN123ylClSCybb_aR0D8LiSgX7reUUQ&oe=671B775D"}, {"file_name": "Cover Art 1  1440x1440px_v2.png", "id": "479030501211158", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974507_479030504544491_9198170525780480936_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OpoMSpX9lxoQ7kNvgFYsa5V&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARSsr0sIkiuVPnuPe8Zd8Itvsx4f2cDJKMFEjNWPIZ8Q&oe=671B803F"}, {"file_name": "Hero Cover 3000x900px_v2.png", "id": "434825702744102", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001659_434825706077435_6023403879667516096_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZHvKhJNeQ2kQ7kNvgFoQA8_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiXIHGPByPqC3jgbymJRts028g2FcFOgzcft6B0tuA4w&oe=671B9F0F"}, {"file_name": "Cover Art 3  2560x1440px.png", "id": "393695783656862", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031602_393695786990195_6314484242064480240_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2WpazA79n8Q7kNvgGBafgW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC2s29fVAZkcpOfqiHQDvRG0STlMw079H50DXt7sG32-A&oe=671B970A"}]}, "id": "1329217244577480", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 1  2560x1440px.png", "id": "458910123495377", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031443_458910126828710_219216421186827978_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xrCfROLXhWsQ7kNvgF7twe5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACuxXX0IbMHQPaCmthSCxKCL6wL9zmED_e1Nr3702QNw&oe=671B6943"}, {"file_name": "Screenshot 2  2560x1440px.png", "id": "2696766540475088", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221331_2696766543808421_2593539058595962166_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8XSZGzW25AIQ7kNvgGM1uC1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBw7--1ao7dX9Ej5wxKbwFu-0vaIpelUDHbd8VNecmARQ&oe=671B863F"}, {"file_name": "Screenshot 3  2560x1440px.png", "id": "2845570238941487", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569444_2845570245608153_268596645994255236_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t9H1jiESCQYQ7kNvgEWS7FZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyXODhm2sPLvUQ8gh3-vpKxaEk54nVvLjyJILPugenJA&oe=671B8AAC"}, {"file_name": "Screenshot 4  2560x1440px.png", "id": "1840108836490822", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974547_1840108839824155_1839831048900896906_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jLIwdEbtCWUQ7kNvgFxLfI6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXUr3KUlsvenzonx1U9o5aSMumtR6GvdxCgyfWkmHxHQ&oe=671B7610"}, {"file_name": "Screenshot 5  2560x1440px.png", "id": "825138912375626", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035370_825138915708959_6729527716816302866_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P7cUxxYuHrUQ7kNvgF53X7M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBnEh3EwlynFKs2M8PLujtOgUWc0NvEO4dxYeUJ1YBjQ&oe=671B7BD0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Alo Moves XR", "keywords": [], "long_description": "Welcome to a new world of wellness.\nAlo Moves is the first-ever wellness sanctuary that seamlessly blends your space with immersive natural landscapes. Move, breathe, and relax with top instructors in yoga, Pilates, and mindfulness wherever you are.\n\nFEEL-GOOD GAMING\n\nChallenge your fitness with yoga and Pilates or hack your mindset with energy-shifting meditations and sound baths. You'll watch your strength, flexibility, and balance improve with classes from 5 to 30 minutes.\n\nLIKE IRL, BUT BETTER\n\nOur virtual studio maps your real surroundings for a next-level workout experience. Want to improve your form? Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. \n\nREDUCE YOUR STRESS\n\nHeadset on, distractions out. Block out the noise and quiet your thoughts with ambisonic audio-guided meditations and sound baths set in elevated environmental landscapes. You can even change your backdrop to match your mood and stay in the environment long after class ends. \n\nCREATE HEALTHY HABITS\n\nMeet a daily wellness routine you\u2019ll look forward to. Slip on the headset, step into a class, and see your strongest self come to life.\n", "short_description": "Welcome to a new world of wellness. Alo Moves is a virtual sanctuary that seamlessly blends your space with immersive natural landscapes. Move and relax with yoga, Pilates, and mindfulness wherever you are. Our studio maps your real surroundings for a next-level workout experience. Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. Slip on the headset, step into a class, and see your strongest self come to life."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "https://www.alomoves.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Meta", "support_website_url": null, "website_url": "https://www.alomoves.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_la