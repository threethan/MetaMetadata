5783438592931729_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dcTj210F5MUQ7kNvgFEnISr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2PnZQv9B-4iics7wZQ4w0vj9x8CFHhzfvbCzktlnJ4Q&oe=671B9793"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Cover_Image_bianca_instructor.png", "id": "513593204615304", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348045_513593207948637_4914459878139936309_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BMHy7G4lep8Q7kNvgH3lbfq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbI9wC9A-CBx62IdvboKB6sjjihSo0lWQgXJMHSmUY1g&oe=671B6D58"}, "display_name": "Alo Moves XR", "keywords": [], "long_description": "Welcome to a new world of wellness.\nAlo Moves is a virtual sanctuary that seamlessly blends your space with immersive and inspiring environments. Move, breathe, and relax with top instructors in yoga, Pilates, and mindfulness wherever you are.\n\nFEEL-GOOD GAMING\n\nChallenge your fitness with yoga and Pilates or hack your mindset with meditations and sound baths. You'll level up your strength, flexibility, and balance with classes from 5 to 30 minutes. Unlock achievements for weekly and monthly class streaks.\n\nLIKE IRL, BUT BETTER\n\nOur virtual studio maps your real surroundings for a next-level workout experience. Want to improve your form? Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. \n\nREDUCE YOUR STRESS\n\nHeadset on, distractions out. Block out the noise and quiet your thoughts with ambisonic audio-guided meditations and sound baths set in elevated environmental landscapes. You can even change your backdrop to match your mood and stay in the environment long after class ends. \n\nCREATE HEALTHY HABITS\n\nMeet a daily wellness routine you\u2019ll look forward to. Slip on the headset, step into a class, and see your strongest self come to life.", "short_description": "Welcome to a new world of wellness. Alo Moves is a virtual sanctuary that seamlessly blends your space with immersive and inspiring environments. Move and relax with yoga, Pilates, and mindfulness wherever you are. Our studio maps your real surroundings for a next-level workout experience. Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. Slip on the headset, step into a class, and see your strongest self come to life."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "https://www.alomoves.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Alo, LLC", "support_website_url": null, "website_url": "https://www.alomoves.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8143225609138671"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003241_944659781037681_4329370579994926768_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3jOoSvdh73QQ7kNvgHfBXGL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDy1NC87uGNBlKd18SyjZ-65Gae2xOmREwwOIm5oHQ_A&oe=671B6CB0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Alo Moves XR", "platform": "ANDROID_6