953490", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_414311881286823_114045479859786261_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZD1aIOo758Q7kNvgGh8qai&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANzc3r5S12zNH5hi0ZPwYzp07ZBECb0q_n_X5ipEBNgg&oe=6783944D"}]}, "id": "1408131606770247", "locale": "en_US", "screenshots": [{"file_name": "screenshot_ashley_portal.png", "id": "1299346584587238", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659801_1299346587920571_7768063035353543907_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5M8qSVF_7fsQ7kNvgHYCB6N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIvu2pl4SArL0tn6rjnHrJ22WMOZOHQs0EsfFxKiu5MA&oe=6783AAD0"}, {"file_name": "screenshot_water_meditation.png", "id": "3838478983090202", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269590_3838478986423535_1923587337267328072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qUwNj_yoTjUQ7kNvgG66qF5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnEW-iOJqgcYRQQiGIvV2x-UWpPkI7FvKgD0gBF6oaXg&oe=6783B10F"}, {"file_name": "ALO_MENU_2560.png", "id": "1185792389171882", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974750_1185792392505215_2511869326354523459_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nh4AQtiO5oYQ7kNvgGOw3j_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAE_Qja2BgASQUT8Vnef5rMP5lXvJMTC0BE2-AAG1sWYw&oe=6783BB36"}, {"file_name": "Image Sequence_sitting_ashley_2560.png", "id": "1557842821821841", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974458_1557842825155174_2295400135303086384_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huLdqH13x2AQ7kNvgEMMisu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLO3eXqlbjYkPhk87opVNwU0OzO2_wt5Fk5mI3V-FtGQ&oe=6783A8B0"}, {"file_name": "Image Sequence_leg_up_bianca_02_2560.png", "id": "741694578083084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982679_741694581416417_6855783438592931729_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YfLWfxLrySIQ7kNvgEsnxbq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0Ozqe0vkL_NAyzUG-R9bNFAQFNbCGO38GZQHS3J8lfA&oe=6783BE13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Cover_Image_bianca_instructor.png", "id": "513593204615304", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348045_513593207948637_4914459878139936309_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JLks1cU05EIQ7kNvgFPhSL9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABpTjTCE5v3cLjvA3yrTSXilxPvg7jW1j2ZqzD_9iMGQ&oe=678393D8"}, "display_name": "Alo Moves XR", "keywords": ["wellness", "yoga", "pilates", "meditation", "workouts"], "long_description": "Welcome to a new world of wellness. Explore yoga, Pilates, and mindfulness in mixed reality with new classes added monthly to inspire your journey.\n\nWant to practice by the beaches of Spain or the fjords of Norway? Our luxe virtual studio seamlessly blends your space with immersive environments for an experience unlike any other.\n\nLIKE IRL, BUT BETTER\nOur virtual studio maps your real surroundings for a next-level workout experience. Want to improve your form? Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide.\n\nFEEL-GOOD GAMING\nChallenge your fitness with yoga and Pilates or hack your mindset with meditations and sound baths. You\u2019ll level up your strength, flexibility, and balance with classes from 5 to 30 minutes. Unlock achievements for weekly and monthly class streaks.\n\nREDUCE YOUR STRESS\nHeadset on, distractions out. Block out the noise and quiet your thoughts with ambisonic audio-guided meditations and sound baths set in elevated environmental landscapes. You can even change your backdrop to match your mood and stay in the environment long after class ends.\n\nCREATE HEALTHY HABITS\nMeet a daily wellness routine you\u2019ll look forward to. Slip on the headset, step into a class, and see your strongest self come to life.", "short_description": "Welcome to a new world of wellness. Alo Moves is a virtual sanctuary that seamlessly blends your space with immersive and inspiring environments. Move and relax with yoga, Pilates, and mindfulness wherever you are. Our studio maps your real surroundings for a next-level workout experience. Walk up to your personal 3D trainer to view each move from all angles or look over at your mini-instructor avatars as a guide. Slip on the headset, step into a class, and see your strongest self come to life."}]}, "developer_name": "Magnopus", "developer_privacy_policy_url": "https://www.alomoves.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Alo, LLC", "support_website_url": null, "website_url": "https://www.alomoves.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8320348908093006"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003241_944659781037681_4329370579994926768_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrHWYWeBp5IQ7kNvgHRQCdJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUuTgtADjlUsb_6UJHobggASYTjjDhptn9EaAphc2RtQ&oe=67839330"}, "is_concept"