0", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392876_781731770798943_7524934239906729170_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5b88wlIteWEQ7kNvgEr4cBk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCH63TlhH7CpWJyWKzsaMBGsdbDn89XHKFy1E6qaD5lWQ&oe=6783C2E5"}, {"file_name": "PnS_Screen_4.png", "id": "888017739841757", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982458_888017743175090_7655612419219817957_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OcmR4indWmkQ7kNvgHqDG7f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAOd5INIaQbpkl3IrOBwJIz8ADByA_5z13r9RvH7UjFg&oe=6783B9FC"}, {"file_name": "PnS_Screen_5.png", "id": "1047790816766549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031586_1047790820099882_6601680007287048467_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VXAco1GmJe4Q7kNvgGlJRCB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCipkuS2LGWaRqu0rxbLhDzfXiDi-qev6zX8GsPluHh_Q&oe=67839C6E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KeyArt_Landscape.png", "id": "608163188217701", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031341_608163191551034_683210639577823358_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M891fLghSJ4Q7kNvgGGgAq0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9kBg8n5u-1FQFHRmBxYDaySLRfLWsID_OxKFfMdOXCw&oe=67838FB2"}, "display_name": "Pets & Stuff", "keywords": ["cat", "animal", "kids", "cute", "shave"], "long_description": "**Pets & Stuff** \u2013 a cute, fun and relaxing game where you become a skilful groomer and veterinarian. Help little friends in trouble, make them happy, pampered, clean, well-fed, and don't forget to add a pinch of chic. Let your imagination run wild! \nEnjoy a fully responsive and polished gameplay, make the best trims, feel the fur at the end of your fingertips and capture the best photoshoots of your creations. \n\n\nCuteness overload and furrrr everywhere guaranteed!\n\n\n**KEY FEATURES:**\n\n\n- There are so many **lovely animals** here! Cats, dogs, raccoons, foxes, deer, and so many more.\n- A variety of products and tools available to **treat and care** for your little friends.\n- A wide range of cool accessories for the most **stylish pets** of all.\n- Multiple **locations**, with the ability to upgrade your clinic into the best of the best.\n", "short_description": "Pets & Stuff \u2013 a cute, fun and relaxing game where you become a skilful groomer and veterinarian using a variety of tools, meds and stylish accessories. Let your imagination run wild! \n\nHelp little friends in trouble, make them happy, pampered, clean, well-fed, and while on it - feel free to add a pinch of chic. Enjoy a fully responsive and polished gameplay with different locations to explore, many adorable pets and lots of creativity boosting gadgets to play with."}]}, "developer_name": "HyperVR Games", "developer_privacy_policy_url": "https://hypervr.games/privacy/petsnstuff.html", "developer_terms_of_service_url": null, "publisher_name": "HyperVR Games", "support_website_url": null, "website_url": "https://hypervr.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1990104051447093"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9997038076989920"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/3