0Q7kNvgFBqg7T&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDR5hbsqTx83emJJ-7y06XczhncTrf4L8osC0Ih2RvTCg&oe=671E367C"}, {"file_name": "PnS_Screen_5.png", "id": "1047790816766549", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031586_1047790820099882_6601680007287048467_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vrcr9NqWCHcQ7kNvgGkJol2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBykLUCaL93S5uTLsDkup2IE-qDuu_p8Ym8SRgf4qsBAg&oe=671E18EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KeyArt_Landscape.png", "id": "1025633815892262", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974595_1025633819225595_8571818881906031885_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QtlYu6tiWx8Q7kNvgFW62kU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkQUpgeXJvDmdTWmVDLRBp4OFus4yQdBFm8ogbIbBBmA&oe=671E337D"}, "display_name": "Pets & Stuff", "keywords": ["cat", "animal", "kids", "cute", "shave"], "long_description": "**Pets & Stuff** \u2013 a cute, fun and relaxing game where you become a skilful groomer and veterinarian. Help little friends in trouble, make them happy, pampered, clean, well-fed, and don't forget to add a pinch of chic. Let your imagination run wild! \nEnjoy a fully responsive and polished gameplay, make the best trims, feel the fur at the end of your fingertips and capture the best photoshoots of your creations. \n\n\nCuteness overload and furrrr everywhere guaranteed!\n\n\n**KEY FEATURES:**\n\n\n- There are so many **lovely animals** here! Cats, dogs, raccoons, foxes, deer, and so many more.\n- A variety of products and tools available to **treat and care** for your little friends.\n- A wide range of cool accessories for the most **stylish pets** of all.\n- Multiple **locations**, with the ability to upgrade your clinic into the best of the best.\n", "short_description": "Pets & Stuff \u2013 a cute, fun and relaxing game where you become a skilful groomer and veterinarian using a variety of tools, meds and stylish accessories. Let your imagination run wild! \n\nHelp little friends in trouble, make them happy, pampered, clean, well-fed, and while on it - feel free to add a pinch of chic. Enjoy a fully responsive and polished gameplay with different locations to explore, many adorable pets and lots of creativity boosting gadgets to play with."}]}, "developer_name": "HyperVR Games", "developer_privacy_policy_url": "https://hypervr.games/privacy/petsnstuff.html", "developer_terms_of_service_url": null, "publisher_name": "HyperVR Games", "support_website_url": null, "website_url": "https://hypervr.games/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8838115399548866"}, "review_messages": ["Approved for release"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974640_1999452093805069_8626144657291127679_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gR42fij1ZuAQ7kNvgF9qpbD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB3twWriOGK6xP5bCCcgfI-EMpj7Gsf0VoN9e59TQ6ilQ&oe=671E2773"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pets & Stuff", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "3948130815144