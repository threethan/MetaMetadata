102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6VvqXmlIgn8Q7kNvgH54GGN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AW3WxATuRBhdNxYCA2m1fgJ&oh=00_AYCu_EjR_Xip0dw9r7mS7hMrp-0U7hXI7wgt3GscodUCBA&oe=66F6AAA6"}, {"file_name": "migrated_image.png", "id": "666198050821628", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974452_1021181251405275_4692343451251900416_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WJGu0rg8d-0Q7kNvgH5VCuU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AW3WxATuRBhdNxYCA2m1fgJ&oh=00_AYBt5kWM7qTxEDTYBQerXq0o8nn0Rg3PFJTW1K6b1qbUxA&oe=66F6B1FC"}, {"file_name": "migrated_image.png", "id": "204110164147349", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031385_288758082021821_5519258791855521792_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kZiak6JAO5kQ7kNvgGDglrw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AW3WxATuRBhdNxYCA2m1fgJ&oh=00_AYBQNxGFlObNXbxwIKG1XuwEF_qYPpUxX9f_zvnjyK_uUg&oe=66F6AA1C"}, {"file_name": "migrated_image.png", "id": "201469581191062", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974501_480734769365407_7765128630094528512_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NHSkK2Y-VAoQ7kNvgFtGUdz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AW3WxATuRBhdNxYCA2m1fgJ&oh=00_AYB2cjitod0EbzX2W_5cq77huObNsowFtLdGkD9CSDO_Zw&oe=66F6950C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Jigsaw 360", "keywords": ["puzzle", "jigsaw", "relax", "meditation", "relaxing"], "long_description": "Relax while completing beautifully detailed spherical jigsaws. The new way to experience a traditional puzzle. Suitable for all ages with between 8 and 162 pieces. Choose from 10 scenes or add your own.\n\nOnly possible in VR. Find yourself stood inside the jigsaw. Use your controllers to precisely place your pieces as you build the spherical puzzle. Rotate the jigsaw and scene to see it from different angles. Traditional flat jigsaws are also included. \n\n***What to expect***\nBe relaxed by the music\nCalmed by the sounds of nature, rain or waves (headphones recommended)\nGrab and manipulate pieces with ease\n\n***Add Photos***\nAdd custom scenes - thousands freely available online:\nSee: www.JumbliVR.com/photos\nCustom scenes should be saved as .png or .jpg files. For 360 degree jigsaws use equirectangular photos sized at 4096 x 2048.\nIf your photos aren't listed, ensure you've enabled \"Storage\" permission via the Oculus app page.", "short_description": "Relax while completing beautifully detailed spherical jigsaws. The new way to experience a traditional puzzle. Suitable for all ages with between 8 and 162 pieces. Add custom scenes - thousands freely available online."}]}, "developer_name": "JumbliVR", "developer_privacy_policy_url": "http://www.jumblivr.com/privacy", "developer_terms_of_service_url": "http://www.jumblivr.com/terms/", "publisher_name": "Head Start Design", "support_website_url": "http://www.jumblivr.com/21_connect/", "website_url": "http://www.jumblivr.com/519_jigsaw_360/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1125336501614607"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003260_332898330892360_2195494785299513344_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r8E6qLh4_vUQ7kNvgGhK2Ph&_nc_ht=scontent.oculuscdn.com&_nc_gid=AW3WxATuRBhdNxYCA2m1fgJ&oh=00_AYB_SEHpbwHsHQJ5jIzTeABao5mws3BXmYqaSqNRKKwHfQ&oe=66F6A3FE"}, "is_concept": false, 