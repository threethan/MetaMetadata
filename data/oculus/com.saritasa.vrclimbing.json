25/75330716_904482174292661_7100902642789623426_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VB4A2bFM5JsQ7kNvgF7rJXl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AneK2WbTF3j0yc_Wpw2m8IG&oh=00_AYBHZqFdd8mZTjytDPv0A2EyukORDODtWuBK1uGvIVNXTQ&oe=66F2AEC6"}, "display_name": "VR Tower Climbing", "keywords": [], "long_description": "Challenging skyscraper climbing.\nExperience the thrill as you climb from one floor of a building to another by utilizing your surroundings as a guide through intricate architecture.\nUse our leaderboards to see how fast you can get to the top and compare your performance to your friends.\n\nFeatures:\n\n- Variability: reach the top of the skyscraper using different routes;\n\n- Leaderboards: upload your highscores to Oculus Leaderboard and compare them with your friends;\n\n- Tutorial: learn about game mechanics on a special training ground and practice them to perfection.\n\n-  Fun: exercise your body and thrill your nerves substantially by climbing atop a skyscraper.\n\nDeveloped by Saritasa.", "short_description": "Challenging skyscraper climbing.\nExperience the thrill as you climb from one floor of a building to another by utilizing your surroundings as a guide through intricate architecture.\nUse our leaderboards to see how fast you can get to the top and compare your performance to your friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/a3c389bf-b853-4539-9b01-840dd37d7716", "developer_terms_of_service_url": null, "publisher_name": "Saritasa", "support_website_url": null, "website_url": "https://www.saritasa.com/3d-development", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIR