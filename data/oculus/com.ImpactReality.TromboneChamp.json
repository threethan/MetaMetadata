=1-7&_nc_sid=6e7a0a&_nc_ohc=5KyiQxbmW9AQ7kNvgHibAbB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4BbLijKDrcGPMgtM5CmmTWahgmAHCbwJ-WowIZzKAtg&oe=67559AD3"}, {"file_name": "CardsImage0.png", "id": "364054776756050", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982495_364054780089383_5863707563115779683_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XA7SlQvb3LYQ7kNvgHGa-cM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgcWwdbxFz5OGeAfZ04_0g-uBAumT3DbOovrdADbEKHg&oe=67557982"}, {"file_name": "Background0.png", "id": "1045587010066707", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982669_1045587013400040_8791289915897112597_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5tX_z5EHQ48Q7kNvgEncSSu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8Jc1OPQRdtGjDGojP9_-jyVAEWEWrVRSZPuwEctbcBg&oe=67559D16"}, {"file_name": "Gameplay0.png", "id": "434188785632030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003255_434188788965363_2258136696212981760_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6e82qj_i1V0Q7kNvgE1HeD3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7EUUHriDKhTvqy9tKSPtRv_iDyAGPl_Bq0e92jwVucw&oe=6755A3E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TCU_Meta_2560x1440.png", "id": "484832004325846", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43997708_484832010992512_6891411827692122990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bz41aJvwLvUQ7kNvgGrqQti&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvQgcG28WDkzkuZv1UsVBo_rnILSW815sq7S0jIVHaqA&oe=67557516"}, "display_name": "Trombone Champ: Unflattened", "keywords": [], "long_description": "Trombone Champ: Unflattened will take the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs, all within a vibrant and dynamic 3D space. \n\nCore Features at Launch:\nSingle Player Campaign Mode: Embark on a solo journey to become the ultimate Trombone Champ, mastering tracks and uncovering the mysteries of the Trombiverse.\n50+ Songs: A diverse soundtrack that spans anthems, marches, classical pieces, electronica, folk classics, and more.\nUnique 3D Environments: Play in various animated 3D spaces designed to complement the musical experience, with each environment adding a unique visual flavor to the tracks.\nAnimated Background Videos: Each song comes with its own animated background, making every performance a new visual treat.\nTrombone Cards: Collect and unlock trombone cards as you progress, each adding new layers of gameplay and customization.\nCollectible Trombones: Start with 10 trombones and unlock an additional 40 as you play, each with its own distinctive style and sound.\nCustomizable Trombones: Personalize your trombone to match your style, offering a truly unique musical experience.\n\nWhether you\u2019re a long-time fan of the original Trombone Champ or new to the world of trombone-based rhythm games, Trombone Champ: Unflattened promises to deliver a unique, immersive, and endlessly hilarious experience.", "short_description": "Trombone Champ: Unflattened takes the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs."}]}, "developer_name": "Flat2VR Studios, Holy Wow Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1JMV2MCP_sz2CD3GrpfVIovagwTrUOHBbpMD9tb27kis/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://flat2vrstudios.com/projects/trombone-champ-unflattened/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_cate