=1-7&_nc_sid=6e7a0a&_nc_ohc=spE5YXEfDWQQ7kNvgEMgo1o&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBEStQaO_sPZv0CZuCoyD-xG8gaOQpdxQK4xzFNhbW6aQ&oe=675D83D3"}, {"file_name": "CardsImage0.png", "id": "364054776756050", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982495_364054780089383_5863707563115779683_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNaT8MAwIMsQ7kNvgGusQKW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCuOeYlktVEJqJUJ0l1-pr_MPiBk7EtBTCmAxvBRyPYbg&oe=675D6282"}, {"file_name": "Background0.png", "id": "1045587010066707", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982669_1045587013400040_8791289915897112597_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DmUgOZIhox8Q7kNvgF_NslY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAawilbewk4jAx30opq8YcxS-KKaR7aY_KYzTA6IgAbPQ&oe=675D8616"}, {"file_name": "Gameplay0.png", "id": "434188785632030", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003255_434188788965363_2258136696212981760_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y6-c0dNbDUcQ7kNvgGkgAwJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDOzPNHbZOyEJnNYbcb7PTOSunLybGU1R3yamqkOVPl6g&oe=675D54A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TCU_Meta_2560x1440.png", "id": "484832004325846", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/43997708_484832010992512_6891411827692122990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZqDiceS2M1wQ7kNvgHIfW3L&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD39Mk6Q3BNNOeN1f-Qy1dfR9gNT_fPsjZo8gTHD-W0Qw&oe=675D5E16"}, "display_name": "Trombone Champ: Unflattened", "keywords": [], "long_description": "Trombone Champ: Unflattened will take the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs, all within a vibrant and dynamic 3D space. \n\nCore Features at Launch:\nSingle Player Campaign Mode: Embark on a solo journey to become the ultimate Trombone Champ, mastering tracks and uncovering the mysteries of the Trombiverse.\n50+ Songs: A diverse soundtrack that spans anthems, marches, classical pieces, electronica, folk classics, and more.\nUnique 3D Environments: Play in various animated 3D spaces designed to complement the musical experience, with each environment adding a unique visual flavor to the tracks.\nAnimated Background Videos: Each song comes with its own animated background, making every performance a new visual treat.\nTrombone Cards: Collect and unlock trombone cards as you progress, each adding new layers of gameplay and customization.\nCollectible Trombones: Start with 10 trombones and unlock an additional 40 as you play, each with its own distinctive style and sound.\nCustomizable Trombones: Personalize your trombone to match your style, offering a truly unique musical experience.\n\nWhether you\u2019re a long-time fan of the original Trombone Champ or new to the world of trombone-based rhythm games, Trombone Champ: Unflattened promises to deliver a unique, immersive, and endlessly hilarious experience.", "short_description": "Trombone Champ: Unflattened takes the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs."}]}, "developer_name": "Flat2VR Studios, Holy Wow Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1JMV2MCP_sz2CD3GrpfVIovagwTrUOHBbpMD9tb27kis/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://flat2vrstudios.com/projects/trombone-champ-unflattened/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_cate