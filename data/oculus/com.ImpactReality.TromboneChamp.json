_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDF594A0nj05lvs-xH7qnLzZgbqrNmzGwxTsN37QHhK2Q&oe=67503144"}]}, "id": "438075412667337", "locale": "en_US", "screenshots": [{"file_name": "PUB_TromboneChamp_Screenshot_03.png", "id": "586084787130032", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240103_586084790463365_4570950646169663893_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aeQ9h8uPTYsQ7kNvgGXON6b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCeiAnrQU7ViqGH9_sMc0_ilWPVFTKlqb8J-5QM3reD2A&oe=67504E72"}, {"file_name": "screenshot 5.png", "id": "902958158675882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031314_902958162009215_5333592717636922876_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_OULrgSzZ8Q7kNvgFUDmPi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBy4oS7ETKpGeX280-H5pmFBWEXLLo2gk5hNVUoL-yaUQ&oe=6750345F"}, {"file_name": "PUB_TromboneChamp_Screenshot_02.png", "id": "549148717899326", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395422_549148721232659_33502692142141502_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=blxxuow84OEQ7kNvgE3AKL4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7avGT11y0VX_TH8q67BfK_gzTll8lDOJsrIn4vcharw&oe=67502C54"}, {"file_name": "PUB_TromboneChamp_Screenshot_04.png", "id": "593754099758132", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974907_593754103091465_4145961814603496039_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P0ntHCavML0Q7kNvgGWLAZF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCTkS_6yn2Fpf5qx1pzo9kKO9weLf5X62W6MqKRA5K_Pg&oe=67503067"}, {"file_name": "screenshot 1.png", "id": "1092376378601410", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451791_1092376385268076_1246829612541042356_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Of9UGjXlEAQ7kNvgH1DuKu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZDUl5k-yuMySp9K_ZpCfUnzg_gXjZXpcCSVvzKwf9-g&oe=67503452"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape 2560 x 1440.png", "id": "2324757321250034", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75223483_2324757324583367_2238022061574316843_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mBvJEktmAzMQ7kNvgGz07a2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyEDn-CGFy5X8uC2mrFLbuOB3kG0A0qlqWQ6F6ueFwIw&oe=67504D2A"}, "display_name": "Trombone Champ: Unflattened!", "keywords": ["music", "comedy", "casual", "funny", "competitive"], "long_description": "Trombone Champ: Unflattened, the BAFTA-nominated viral sensation, is back with a fully reimagined VR experience that\u2019s all about letting you take center stage.\n\n\n\n# **FIND YOUR GROOVE**\n\n\n\nPlay the trombone your way\u2014every note, every slide, every majestic honk is yours to control. You\u2019re not just keeping up with the rhythm; you are the rhythm.\n{943593027833360}\n\n\n\n# **A ROAD PAVED IN BRASS**\n\n\nToot your way through an all-new campaign packed with surprises, unlock fresh challenges, and climb the leaderboards on your way to glory.\n{1381878602790644}\n\n\n# **HOARD OF HORNS**\n\n\nAmass a treasure trove of trombones, each one wilder than the last. With 20 unique designs at launch and plenty more on the horizon, there\u2019s always another horn to hunt!\n{1087777463358179}\n\n\n# **IF YOU PLAY YOUR CARDS RIGHT\u2026** \n\n\nBuild your ultimate deck with 50 Tromboner Cards packed with absurd trivia and legendary trombone lore.\n{1096169051559404}\n\n# **KEEPING IT REAL**\n\n\nThe whole world's a stage in mixed reality mode, letting your trombone \u201cskills\u201d shine, right in your own space.\n{1896165561190403}\n\n\n\n\n\nTrombone Champ: Unflattened! lets you wield your virtual trombone across over 50 tracks, spanning anthems, marches, classical bangers, and folk classics. Each piece is handcrafted to keep you honking and sliding to your heart\u2019s content, with plenty of surprises and unlockables along the way to keep you coming back for more.\n", "short_description": "The BAFTA-nominated sensation is back, now fully reimagined for VR! In Trombone Champ: Unflattened, every note, slide and toot is yours to command. With over 50 tracks, an all-new campaign, collectible Tromboner Cards, and wild trombones to unlock, you\u2019re not just keeping up with the beat\u2014you\u2019re creating it!"}]}, "developer_name": "Flat2VR Studios, Holy Wow Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1JMV2MCP_sz2CD3GrpfVIovagwTrUOHBbpMD9tb27kis/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://tc.flat2vrstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1990104051447093"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27686114177700918"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982501_918524866464555_2642534623743947890_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rNP9dkiyBl0Q7kNvgEBY2BI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVcsIHvNCeijBKwJF3GdieNh_WnnlTK2B1gMz6SZqNcQ&oe=675043D4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Trombone Champ: Unflattened!", "platform": "A