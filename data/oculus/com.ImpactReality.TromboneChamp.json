tps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75485579_1611522762912868_5976971611780237991_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DKJ5nXwFFSQQ7kNvgG1Ch8J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7nBP8mCgKM8fytl26cCUGx6ErrjEYhqs3LL0ROWpeuw&oe=675054D3"}, {"file_name": "CardsImage0.png", "id": "364054776756050", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982495_364054780089383_5863707563115779683_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JUe4i-ZHaVoQ7kNvgEjCUoC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4BPcgXn7c9SnXPGlfwmslEJSQRrjMuTAgyXteUaHJkg&oe=67503382"}, {"file_name": "Background0.png", "id": "1045587010066707", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982669_1045587013400040_8791289915897112597_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ws7HM9dm3TwQ7kNvgGN3ulD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABh6coAjorf3_mHllxcw_lZquBTKIIpV-T0t-Q_hO09g&oe=67505716"}, {"file_name": "Gameplay0.png", "id": "434188785632030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003255_434188788965363_2258136696212981760_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Is5Z-EhWfNsQ7kNvgFblfZs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7wv7lihg8j6x9ZhMMj7KXbh2N45-zUk3vtmaVhJbLIw&oe=675025A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TCU_Meta_2560x1440.png", "id": "484832004325846", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43997708_484832010992512_6891411827692122990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bnB-9ui_A5sQ7kNvgGThcjo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7p7uBzqWuDX5pxSpfs7eBqI9lbANZEcMerDpC6T78tA&oe=67502F16"}, "display_name": "Trombone Champ: Unflattened", "keywords": [], "long_description": "Trombone Champ: Unflattened will take the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs, all within a vibrant and dynamic 3D space. \n\nCore Features at Launch:\nSingle Player Campaign Mode: Embark on a solo journey to become the ultimate Trombone Champ, mastering tracks and uncovering the mysteries of the Trombiverse.\n50+ Songs: A diverse soundtrack that spans anthems, marches, classical pieces, electronica, folk classics, and more.\nUnique 3D Environments: Play in various animated 3D spaces designed to complement the musical experience, with each environment adding a unique visual flavor to the tracks.\nAnimated Background Videos: Each song comes with its own animated background, making every performance a new visual treat.\nTrombone Cards: Collect and unlock trombone cards as you progress, each adding new layers of gameplay and customization.\nCollectible Trombones: Start with 10 trombones and unlock an additional 40 as you play, each with its own distinctive style and sound.\nCustomizable Trombones: Personalize your trombone to match your style, offering a truly unique musical experience.\n\nWhether you\u2019re a long-time fan of the original Trombone Champ or new to the world of trombone-based rhythm games, Trombone Champ: Unflattened promises to deliver a unique, immersive, and endlessly hilarious experience.", "short_description": "Trombone Champ: Unflattened takes the charming and quirky gameplay of the original Trombone Champ and bring it to life in a fully immersive virtual reality environment. In this reimagined version, players will honk, blow, and toot their way through over 50 unique songs."}]}, "developer_name": "Flat2VR Studios, Holy Wow Studios", "developer_privacy_policy_url": "https://docs.google.com/document/d/1JMV2MCP_sz2CD3GrpfVIovagwTrUOHBbpMD9tb27kis/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Flat2VR Studios", "support_website_url": null, "website_url": "https://flat2vrstudios.com/projects/trombo