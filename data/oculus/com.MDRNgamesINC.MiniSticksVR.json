_ohc=a1ckiQoleTsQ7kNvgHnS9ia&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_MhoJEQy4hxC-WgHM48As3ri8TjYhKEidppxyeADAKg&oe=676AB9D8"}, {"file_name": "ScreenShot4.png", "id": "810692424581277", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974919_810692427914610_8565142942479320347_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eZE4sKFnbSgQ7kNvgGVdqPd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0xcnIZwVhK-6YijtY_2PQBNPp0Hwp6ExwSN2rzO8AMA&oe=676AB6A6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Hockey+", "keywords": ["hockey", "sports", "simulation", "multiplayer", "olympics"], "long_description": "\nHockey+ VR is the biggest online hockey experience in the world\u2014no joke, eh? Whether you're hitting the ice for intense 99-player lobbies or kicking back with friends in one of our many arenas, this game has everything a hockey fan could dream of and more.\n\nStep into 2 full-sized rinks, a half rink, and 4 ministicks arenas for non-stop action. Need a breather? Try out the air hockey tables or challenge your buddies to a game of chess. It's not just about playing hockey\u2014it's about living it.\n\nAnd it doesn't stop there. Hockey+ VR immerses you in the vibe with live video feeds from Toronto, festive Christmas webcams, and a real-time hockey news feed to keep you in the loop. This isn\u2019t just a game\u2014it\u2019s a celebration of hockey culture.\n\nWhether you\u2019re skating, passing, scoring, or just chilling with friends, Hockey+ VR is your ultimate hockey destination. Grab your stick, hit the ice, and give 'er, eh! It\u2019s as Canadian as it gets.", "short_description": "Hockey+ VR is the ultimate online hockey experience! Play in massive 99-player lobbies across 2 rinks, 4 ministicks arenas, air hockey, chess, and more. Featuring live Toronto feeds, hockey news, and endless fun. Grab your stick and give 'er, eh!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://md