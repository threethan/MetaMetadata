UIs9mLg&oe=671A2708"}, {"file_name": "Medieval_Dynasty_Screenshots_002.png", "id": "871258294644021", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974513_871258297977354_2655077428417410809_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rUQS2g_on34Q7kNvgGhwe8B&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYD8d2ICuJx9jeE64MbriU1Dh-x5TELOSGbZSDlE6hVEQg&oe=671A1E65"}, {"file_name": "Medieval_Dynasty_Screenshots_004.png", "id": "375184161705271", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031474_375184165038604_3740063892031940403_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-bQL9LPAUvgQ7kNvgGI3HfX&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCX2kyy78WcvPtqbn_kAeyrsi9GpMudM3tHymvxzVqYpg&oe=671A417A"}, {"file_name": "Medieval_Dynasty_Screenshots_003.png", "id": "1384891392385308", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75203616_1384891395718641_8072408402862795028_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BNm2L7lkwH0Q7kNvgEOzpyj&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDTRBZdEJI_Lm2fpnQSag3ZzIre3s9surE2V-dMzj6q_g&oe=671A4686"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Medieval_Dynasty_Landscape.png", "id": "3783983028594211", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974745_3783983031927544_2715084954474762571_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxerj-BB5YIQ7kNvgF3bGoZ&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBDg8XEoA_gt3jtSFtqHkmkIikdsAMpMBG1oIYyg27xpQ&oe=671A1BEE"}, "display_name": "Medieval Dynasty New Settlement", "keywords": ["Survival", "Sandbox", "simulation", "adventure", "building"], "long_description": "Dive into the rich tapestry of medieval life with 'Medieval Dynasty New Settlement', an exhilarating VR game that seamlessly blends role-playing, simulation, and exploration. Set against the backdrop of a meticulously crafted medieval landscape, the player is tasked with the monumental challenge of founding and nurturing a thriving settlement and then starting their dynasty.\n \nAs the protagonist your primary focus will be on the challenges of survival, resource gathering, and the ambitious task of creating a lasting dynasty. Utilizing the immersive capabilities of VR technology, you will physically engage in the construction of buildings, cooking, hunting, and cultivating fertile fields. Doing all of this and much more will ensure experiencing the gratification of watching your settlement rise from humble beginnings to a majestic medieval hub.\n \nVenture beyond the safety of your lands to explore the vast and enchanting landscapes, stumbling upon quests, challenges, and hidden treasures that add depth to the narrative. Encounter characters with unique personalities and stories, that will become a part of your settlement destiny\n\nNotably, 'Medieval Dynasty New Settlement' stands as a VR spin-off of the highly successful flat version game, Medieval Dynasty, featuring a fresh map, new quests, and innovative VR mechanics that elevate the gaming experience to new heights.\n", "short_description": "Embark on a fascinating journey with 'Medieval Dynasty New Settlement', a captivating game that brings players into a vibrant realm. Immerse yourself in the art of survival, construction, and dynasty-building as you strive to flourish in the face of daunting challenges. Dive into the richly woven tapestry of the medieval era and carve your path to success in this captivating odyssey. Experience the thrill of shaping the environment in this virtual reality sandbox adventure.\nThe dynasty awaits!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spectralgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Spectral Games SA", "support_website_url": null, "website_url": "https://spectralgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "274