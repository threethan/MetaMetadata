a0a&_nc_ohc=l7SFxCzc_C4Q7kNvgHtcK4L&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBnLGuP9vGTha4d_xbV-mn1GlKD5zQUhSl-6MiOx65jnA&oe=671A4526"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Medieval_Dynasty_Landscape_Halloween_2024.png", "id": "1084371979942348", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38982651_1084371986609014_7809150151212018885_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T28-5yfzH28Q7kNvgGM1zZF&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCh6QS_8Rydy2nGwGaCISrQuMZp_z7FKvFvjd-D-bqPFw&oe=671A4849"}, "display_name": "Medieval Dynasty New Settlement", "keywords": ["Survival", "Sandbox", "simulation", "adventure", "building"], "long_description": "Dive into the rich tapestry of medieval life with 'Medieval Dynasty New Settlement', an exhilarating VR Spin-off game that seamlessly blends sandbox, role-playing, simulation, and exploration. Set against the backdrop of a meticulously crafted medieval landscape, the player is tasked with the monumental challenge of founding and nurturing a thriving settlement and then starting their dynasty.\n \nAs the protagonist your primary focus will be on the challenges of survival, resource gathering, and the ambitious task of creating a lasting dynasty. Utilizing the immersive capabilities of VR technology, you will physically engage in the construction of buildings, cooking, hunting, and cultivating fertile fields. Doing all of this and much more will ensure experiencing the gratification of watching your settlement rise from humble beginnings to a majestic medieval hub.\n \nVenture beyond the safety of your lands to explore the vast and enchanting landscapes, stumbling upon quests, challenges, and hidden treasures that add depth to the narrative. Encounter characters with unique personalities and stories, that will become a part of your settlement destiny.\n", "short_description": "A VR Spin-off of the highly successful flat version game, Medieval Dynasty, featuring a fresh map, new quests and innovative VR mechanics that elevate the gaming experience to new heights.\n"}, {"images": {"nodes": []}, "id": "1189452435477352", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Medieval Dynasty New Settlement", "keywords": ["sandbox", "survival", "building", "simulation", "adventure"], "long_description": "Tauche ein in die reiche Vielfalt des mittelalterlichen Lebens mit \u201eMedieval Dynasty New Settlement\u201c, einem aufregenden VR-Spin-off-Spiel, das Sandbox, Rollenspiel, Simulation und Erkundung nahtlos miteinander verbindet. Vor dem Hintergrund einer sorgf\u00e4ltig gestalteten mittelalterlichen Landschaft steht der Spieler vor der monumentalen Herausforderung, eine bl\u00fchende Siedlung zu gr\u00fcnden und zu pflegen und dann seine Dynastie zu gr\u00fcnden.\n \nAls Protagonist liegt dein Hauptaugenmerk auf den Herausforderungen des \u00dcberlebens, des Sammelns von Ressourcen und der ehrgeizigen Aufgabe, eine dauerhafte Dynastie zu gr\u00fcnden. Mit Hilfe der immersiven F\u00e4higkeiten der VR-Technologie wirst du dich physisch am Bau von Geb\u00e4uden, am Kochen, an der Jagd und an der Bewirtschaftung fruchtbarer Felder beteiligen. Wenn du all dies und noch viel mehr tust, wirst du die Genugtuung erleben, zu sehen, wie deine Siedlung von bescheidenen Anf\u00e4ngen zu einem majest\u00e4tischen mittelalterlichen Zentrum heranw\u00e4chst.\n \nWagt euch \u00fcber die Sicherheit eures Landes hinaus, um die weiten und bezaubernden Landschaften zu erkunden, und sto\u00dft dabei auf Quests, Herausforderungen und verborgene Sch\u00e4tze, die der Geschichte Tiefe verleihen. Begegnet Charakteren mit einzigartigen Pers\u00f6nlichkeiten und Geschichten, die Teil des Schicksals eurer Siedlung werden.", "short_description": "Ein VR-Spin-off des \u00e4u\u00dferst erfolgreichen Flachbildschirm-Spiels \u201eMedieval Dynasty\u201c mit einer brandneuen Karte, Quests und innovativer VR-Mechanik, die das Spielerlebnis auf ein neues Level hebt!"}, {"images": {"nodes": []}, "id": "853481616990690", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Medieval Dynasty New Settlement", "keywords": ["survival", "sandbox", "simulation", "adventure", "building"], "long_description": "Plongez dans la riche tapisserie de la vie m\u00e9di\u00e9vale avec \u00ab Medieval Dynasty New Settlement \u00bb, un jeu d\u00e9riv\u00e9 VR exaltant qui m\u00e9lange harmonieusement bac \u00e0 sable, jeu de r\u00f4le, simulation et exploration. Avec pour toile de fond un paysage m\u00e9di\u00e9val m\u00e9ticuleusement con\u00e7u, le joueur se voit confier le d\u00e9fi monumental de fonder et d'entretenir une colonie prosp\u00e8re, puis de fonder sa dynastie.\n \nEn tant que protagoniste, vous vous concentrerez principalement sur les d\u00e9fis de la survie, de la collecte de ressources et sur la t\u00e2che ambitieuse de cr\u00e9er une dynastie durable. En utilisant les capacit\u00e9s immersives de la technologie VR, tu t'engageras physiquement dans la construction de b\u00e2timents, la cuisine, la chasse et la culture de champs fertiles. En faisant tout cela et bien d'autres choses encore, tu auras la satisfaction de voir ta colonie s'\u00e9lever d'humbles d\u00e9buts \u00e0 un majestueux centre m\u00e9di\u00e9val.\n \nAventurez-vous au-del\u00e0 de la s\u00e9curit\u00e9 de vos terres pour explorer des paysages vastes et enchanteurs, en tombant sur des qu\u00eates, des d\u00e9fis et des tr\u00e9sors cach\u00e9s qui ajoutent de la profondeur \u00e0 la narration. Rencontrez des personnages aux personnalit\u00e9s et aux histoires uniques qui feront partie du destin de votre colonie.", "short_description": "Un spin-off VR du jeu \u00e0 succ\u00e8s sur \u00e9cran plat, Medieval Dynasty, avec une toute nouvelle carte, des qu\u00eates et des m\u00e9canismes VR innovants qui \u00e9l\u00e8vent l'exp\u00e9rience de jeu \u00e0 un niveau sup\u00e9rieur !"}, {"images": {"nodes": []}, "id": "422275267269422", "locale": "pl_PL", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Medieval Dynasty New Settlement", "keywords": ["survival", "sandbox", "symulacja", "budowanie", "przygoda"], "long_description": "Zanurz si\u0119 w \u015bwiecie \u015bredniowiecznego \u017cycia dzi\u0119ki \u201eMedieval Dynasty New Settlement, ekscytuj\u0105cej grze ze znanego i lubianego uniwersum Medieval Dynasty, tym razem w Wirtualnej Rzeczywisto\u015bci! Gra \u0142\u0105czy w sobie rozgrywk\u0119 sandbox, role-playing, symulacj\u0119 i eksploracj\u0119.Na tle pieczo\u0142owicie stworzonego \u015bredniowiecznego krajobrazu gracz staje przed monumentalnym wyzwaniem za\u0142o\u017cenia i piel\u0119gnowania dobrze prosperuj\u0105cej osady, a nast\u0119pnie za\u0142o\u017cenia w\u0142asnej dynastii.\n \nJako protagonista skupisz si\u0119 przede wszystkim na wyzwaniach zwi\u0105zanych z przetrwaniem, gromadzeniem zasob\u00f3w i ambitnym zadaniem utrzymania trwa\u0142ego rodu. Wykorzystuj\u0105c wci\u0105gaj\u0105ce mo\u017cliwo\u015bci technologii VR, b\u0119dziesz fizycznie anga\u017cowa\u0107 si\u0119 w budow\u0119 budynk\u00f3w, gotowanie, polowanie i upraw\u0119 \u017cyznych p\u00f3l. Robi\u0105c to wszystko i wiele wi\u0119cej, do\u015bwiadczysz satysfakcji z obserwowania, jak twoja osada wznosi si\u0119 od skromnych pocz\u0105tk\u00f3w do majestatycznego \u015bredniowiecznego centrum.\n \nWyjd\u017a poza bezpieczne granice swoich ziem, aby odkrywa\u0107 rozleg\u0142e i urzekaj\u0105ce krajobrazy, natykaj\u0105c si\u0119 na zadania, wyzwania i ukryte skarby, kt\u00f3re dodaj\u0105 g\u0142\u0119bi narracji. Spotkaj postacie o wyj\u0105tkowych osobowo\u015bciach i historiach, kt\u00f3re wp\u0142yn\u0105 na los twojej osady.", "short_description": "VR spin-off popularnej gry komputerowej, Medieval Dynasty, zawieraj\u0105cy zupe\u0142nie now\u0105 map\u0119, zadania i innowacyjn\u0105 mechanik\u0119 VR, kt\u00f3ra przenosi rozgrywk\u0119 na nowy poziom!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://spectralgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Spectral Games SA", "support_website_url": null, "website_url": "https://spectralgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "SIMULATION", "RPG"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pl", "de", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9280561881958797"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/75210396_1109205524121685_8069199684017141238_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Icypdz276EgQ7kNvgEbZwri&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDcsDQ5z5Nj-i0I2TI3oBQZW9njnUiLwu4uX9Moa1dKqg&oe=671A4094"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Medieval Dynasty New Settlement", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "RPG (Role Playing Games)", "id": "961172191044986"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1711645200, "lastRevision": {"nodes": [{"