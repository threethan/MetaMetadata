1863105804106545_1637081606194542588_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jk_OJ5TYJeYQ7kNvgFvaxgL&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCfpOUpQZKmd0T_xdNBjKH7zW3z7xPc2mMxjvSPuIp0tQ&oe=6729FB38"}, {"file_name": "shop pic.png", "id": "1058339575392411", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982570_1058339578725744_8788914558406902534_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zIjAdocalFIQ7kNvgFbusv6&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCUrjKdHslrLmqUHzn1mJw6ng6io8PMNKImxreCkfg0og&oe=6729F2DF"}, {"file_name": "forest pic.png", "id": "368907862626621", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75240103_368907865959954_8897534893596198854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nXY-g7HR0ywQ7kNvgHRi-wo&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAsVRTttOm85XzFLLx6AruLvqw5v3cnwRjCTzS9FtT8Lg&oe=672A1CE6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ape Walk", "keywords": [], "long_description": "Welcome to Ape Walk , where you'll experience the thrill of hanging out with your primate buddies in stunning virtual reality environments. Explore lush forests, bustling shops, serene gyms, and even zero gravity arenas as you kick back and relax with your monkey pals.\n\nEngage in leisurely activities like swinging through the trees, playing games, or simply chilling out together. But it's not all about relaxation \u2013 challenge your friends to thrilling player-versus-player matches for some competitive fun.\n\nImmerse yourself in a virtual world where the line between reality and fantasy blurs, and the bond with your monkey friends feels as genuine as ever. Ape Walk  brings the joy of camaraderie and adventure right to your fingertips.", "short_description": "Dive into Ape Walk  and explore lush forests, bustling shops, serene gyms, and even zero gravity arenas with your primate buddies. Relax, swing through trees, or challenge friends in thrilling PvP matches. Immerse yourself in a world where friendship and adventure collide."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/7bf20958-7d6c-498a-b724-4e9a513e08e1", "developer_terms_of_service_url": null, "publisher_name": "Abdyy", "support_website_url": null, "website_url": "https://sites.google.com/view/apewalk/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7669840346373037"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1467676790450027"}]}, "baseline_offer": {"id": "1467676790450027"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710180000, "status": "PUBLISHED", "id": "1467676790450027"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8946764845347241", "version": "110.0"}, "id": "944710986868134", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7669840339706371", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8946764845347241"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "944710986868134"}]}