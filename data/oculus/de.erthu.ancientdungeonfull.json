uluscdn.com&oh=00_AYBu_7QIf1x-HClwCW7vFRHPSS_uZrbelvYhwpQjc9lAWQ&oe=6724D7CA"}, {"file_name": "doomshroom_1.png", "id": "602572987843892", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003274_602572994510558_41958639708839421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NIrB1kP7YUIQ7kNvgHU-b9q&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBww4hrOVLYP3mxRim--2wDMayq41W53V6_y8O9MpuJVw&oe=6724B0D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "advr_splash_2560x1440.png", "id": "972728230121650", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75422388_972728236788316_2115788474998368449_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H3iw4WZlpdIQ7kNvgEaGaT1&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBbZA91Y2it9-ECt6yn_FallaWWQ-GF09YCuZMLwn4yMA&oe=6724C5F0"}, "display_name": "Ancient Dungeon", "keywords": ["roguelike", "fighting", "exploration", "fantasy", "adventure"], "long_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, 4 player co-op, and 20+ hours of content. \n\nDelve into an ever-shifting labyrinth of treasures and terrors in an attempt to escape with the dungeon\u2019s riches in tow! Discover 125+ powerful relics to help you along the way, unearth lost knowledge to gain Insight into the dungeon\u2019s secrets, and lay claim to the blood of The Beast to refine your weapons.\n\nPlay together with up to 4 people. Team up, explore, and enjoy the adventure together.\n\nWhether you succeed or fail, every attempt increases your next adventurer\u2019s chance to escape unscathed, weaken The Beast, and uncover the long-lost history of The Ancient Dungeon.", "short_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, and 20+ hours of content and 4 player coop multiplayer."}]}, "developer_name": null, "developer_privacy_policy_url": "https://erthu.git