7_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UE6hrresOQoQ7kNvgGtAX-O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpSXA4DDEgfyLEgwsVURfGe3ALEuQ06iRl16Szb4Gobg&oe=6783991D"}, {"file_name": "Screenshot 2024-05-28 1135dfd55_LE_digital_art_custom.png", "id": "1431846660789767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86594842_1431846664123100_842511221130740333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m2OZhFUuvfAQ7kNvgGXPRnS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdj3r5i03WLY-TvnoqC9TXZEBRqkYZN7AT4otPdJCsEg&oe=6783B90D"}, {"file_name": "shop_1.png", "id": "414534963451946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982695_414534970118612_3905745942158329259_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LN8iBs6SPO8Q7kNvgGnqGyx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAL05Q29VR8Uf9ih1mt2az7FKgaI1lPIZUIXC2VwMasgQ&oe=6783AC7A"}, {"file_name": "luminous_mines_1.png", "id": "1600328527002860", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1600328530336193_7933613731383701358_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E9EfWCp_OSAQ7kNvgHu9nNG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr1ZQq4YB2kX_AlOVYwNTyFWX9dMxZboq6k0woqtAdtw&oe=6783C3CA"}, {"file_name": "doomshroom_1.png", "id": "602572987843892", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003274_602572994510558_41958639708839421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R7qYryyJfIAQ7kNvgGjQ1Vc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpqd5J7jnAir6_7-hi9os6uEDMFCeH07psQvJ6hzMJ4Q&oe=67839CD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "advr_splash_2560x1440.png", "id": "972728230121650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422388_972728236788316_2115788474998368449_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhhrlqP1L3cQ7kNvgGGFwRG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVOIU6eP2fOToHLqNA7vc7XvAs5zYgxskPeq3eK9Zs3A&oe=6783B1F0"}, "display_name": "Ancient Dungeon", "keywords": ["roguelike", "fighting", "exploration", "fantasy", "adventure"], "long_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, 4 player co-op, and 20+ hours of content.\n\nThe Ancient Dungeon is known throughout the land; a place of malice and danger to all but a few brave souls. Many enter the dungeon in pursuit of legendary fortunes and objects of immense power, all believing themselves more capable than those who have gone before...but few return.\n\n\n# Play Solo or Coop!\nPlay together with up to 4 people. Team up, explore, and enjoy the adventure together.\n{3857582051165519}\n\n\n# Randomly Generated Dungeons\n{539201698467983}\nEvery dungeon is randomly generated, filled with traps, secrets, and a variety of loot. As you delve deeper, environments and enemies become more and more dangerous.\n\n\n# Tons of different enemies!\n{893268059390682}\nFace a wide array of enemies unique to each dungeon type\u2014wights, slimes, skeletons, wisps, flying skulls, and champion foes. Experience satisfying physics-based combat with both melee and ranged attacks.\n\n\n# Upgrade your character and aid the research of The Grand Library\n{2468487553337076}\n\n# An interactable world\n{1621744095439041}\nUse the environment to your advantage, cut your way through grass realistically, destroy pots and throw or drink potions.\n\n# Tons of different item upgrades\n{1962880807493485}\nCollect and unlock over 100 different upgrades, such as companion wisps to gamechanging upgrades such as exploding, homing, throwing knives. Create crazy item synergies if you know what you are doing!\n\n\n\n\n\n\n", "short_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, and 20+ hours of content and 4 player coop multiplayer."}]}, "developer_name": null, "develop