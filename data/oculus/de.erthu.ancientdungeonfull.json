517_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NmLbjQkRTu4Q7kNvgFAMBdz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTtspSPpLfkGkZMd88xEZ-jW2IAZHkzWFsPSxUQtvFhA&oe=6752D19D"}, {"file_name": "Screenshot 2024-05-28 1135dfd55_LE_digital_art_custom.png", "id": "1431846660789767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86594842_1431846664123100_842511221130740333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wdfx_oyxUNAQ7kNvgFGoZhL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCykNnRzibzqr74nC0mEDmExGdgA7Aa1P9iywlwoQAFw&oe=6752F18D"}, {"file_name": "shop_1.png", "id": "414534963451946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982695_414534970118612_3905745942158329259_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SMFcQG-S_twQ7kNvgHY9bhT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_bGlc6POudtudmKAHSVE9CEsJuk-DI7pnMOAADSazfw&oe=6752E4FA"}, {"file_name": "luminous_mines_1.png", "id": "1600328527002860", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1600328530336193_7933613731383701358_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yb1gEY8mBHIQ7kNvgHekGl8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_kbeHauAWSdzTNH1ILIQgdB6ndb2tX4BedupVc83mTw&oe=6752FC4A"}, {"file_name": "doomshroom_1.png", "id": "602572987843892", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003274_602572994510558_41958639708839421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bzm7Fz4PWCgQ7kNvgHzndY3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEHUz9GpkByJ3ZSwMdIMdtvO3XiSHQ60DpKg_eBbDpAw&oe=6752D555"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "advr_splash_2560x1440.png", "id": "972728230121650", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422388_972728236788316_2115788474998368449_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=epDqtiHx-w8Q7kNvgEURdnx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4-4de2e6NCAB84NBbWrDToPGgw4XFwAFmALilCDkcag&oe=6752EA70"}, "display_name": "Ancient Dungeon", "keywords": ["roguelike", "fighting", "exploration", "fantasy", "adventure"], "long_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, 4 player co-op, and 20+ hours of content.\n\nThe Ancient Dungeon is known throughout the land; a place of malice and danger to all but a few brave souls. Many enter the dungeon in pursuit of legendary fortunes and objects of immense power, all believing themselves more capable than those who have gone before...but few return.\n\n\n# Play Solo or Coop!\nPlay together with up to 4 people. Team up, explore, and enjoy the adventure together.\n{3857582051165519}\n\n\n# Randomly Generated Dungeons\n{539201698467983}\nEvery dungeon is randomly generated, filled with traps, secrets, and a variety of loot. As you delve deeper, environments and enemies become more and more dangerous.\n\n\n# Tons of different enemies!\n{893268059390682}\nFace a wide array of enemies unique to each dungeon type\u2014wights, slimes, skeletons, wisps, flying skulls, and champion foes. Experience satisfying physics-based combat with both melee and ranged attacks.\n\n\n# Upgrade your character and aid the research of The Grand Library\n{2468487553337076}\n\n# An interactable world\n{1621744095439041}\nUse the environment to your advantage, cut your way through grass realistically, destroy pots and throw or drink potions.\n\n# Tons of different item upgrades\n{1962880807493485}\nCollect and unlock over 100 different upgrades, such as companion wisps to gamechanging upgrades such as exploding, homing, throwing knives. Create crazy item synergies if you know what you are doing!\n\n\n\n\n\n\n", "short_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, and 20+ hours of content and 4 player coop multiplayer."}]}, "developer_name": null, "developer_privacy_policy_url": "https://erthu.github.io/pp_advr", "developer_terms_of_service_url": null, "publisher_name": "ErThu", "support_website_url": null, "website_url": "https://erthu.github.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "27188451297464903"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031656_837461380491330_3967194081975748381_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=frOD1PfzoMsQ7kNvgHVQrF1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtHm7GTg0fAXipx0Rqf_xLlg_SdbYA-IITIYB17Vt7ZA&oe=6752E443"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ancient Dungeon", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Role Playing", "id": "821934236779161"}], "release_date": 1663261140, "lastRevision": {"nodes": [{"id": "1792173640959909", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5138511912885491", "