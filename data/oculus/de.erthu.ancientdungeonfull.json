109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J76utkxmPiAQ7kNvgFQ2EOo&_nc_ht=scontent.oculuscdn.com&oh=00_AYAa7PEpCB6oyY-XFqujfxFSNe4u9Ad5aVwl18M5davJpA&oe=66CEFF55"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "advr_splash_2560x1440.png", "id": "972728230121650", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422388_972728236788316_2115788474998368449_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wp5GeL7Xh8AQ7kNvgHsnwFe&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCnUrAqr_hj2jJv-NBEdd5wfUdPzR6ttJhC0tEzbsiug&oe=66CF1470"}, "display_name": "Ancient Dungeon", "keywords": ["roguelike", "fighting", "exploration", "fantasy", "adventure"], "long_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, 4 player co-op, and 20+ hours of content. \n\nDelve into an ever-shifting labyrinth of treasures and terrors in an attempt to escape with the dungeon\u2019s riches in tow! Discover 125+ powerful relics to help you along the way, unearth lost knowledge to gain Insight into the dungeon\u2019s secrets, and lay claim to the blood of The Beast to refine your weapons.\n\nPlay together with up to 4 people. Team up, explore, and enjoy the adventure together.\n\nWhether you succeed or fail, every attempt increases your next adventurer\u2019s chance to escape unscathed, weaken The Beast, and uncover the long-lost history of The Ancient Dungeon.", "short_description": "Ancient Dungeon is a rogue-lite dungeon crawler featuring physics-based combat, procedurally-generated layouts, and 20+ hours of content and 4 player coop multiplayer."}]}, "developer_name": null, "developer_privacy_policy_url": "https://erthu.github.io/pp_advr", "developer_terms_of_service_url": null, "publisher_name": "ErThu", "support_website_url": null, "website_url": "https://erthu.github.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_