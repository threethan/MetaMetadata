content-iad3-1.oculuscdn.com/v/t64.5771-25/75367595_614808336690914_8709922739410994730_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_bRBRAtjIJsQ7kNvgFt8iEV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAkkA2eRzxC4H-v-dvqfrPRpyvyClZ7XTfD5CzNb9ediA&oe=672226B5"}, {"file_name": "Screenshot2.png", "id": "830107978355425", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75314846_830107981688758_708232131660660581_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ssGd6CkIJUEQ7kNvgG-yOe8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVfuApMgYn2i6bl_WUtPQSdACChibNpFllGdBhwMjiDQ&oe=67220AC6"}, {"file_name": "Screenshot3.png", "id": "363846782482585", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003244_363846785815918_4504657108639784316_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-X89oGMJWvcQ7kNvgEb4cvB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_WtD32loBbEupkjNTqNcjW3k074xbCGLhUyGuQsE3Wg&oe=672218FD"}, {"file_name": "Screenshot4.png", "id": "615936303418693", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974457_615936306752026_1145098500816248758_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z9X9YmghpZUQ7kNvgGIBDel&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxXt_9JftDxc5KiTq2MP_LhXsgGGtbaRT8FzYXpHGAxw&oe=672232F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "461601282560023", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031402_461601285893356_7581554104634840885_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kbCXzJ-sJlIQ7kNvgF6OJff&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzjmHdEIVNscF4dl6ofZZNDdaywuG4EXBZ9gm1Du5LPw&oe=6722131C"}, "display_name": "3D scan of a forest", "keywords": [], "long_description": "Move like a pedestrian in a forest, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 800m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a forest, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held camera (Garmin Virb 360) and by walking about 800 meters in a forest."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "988384362558220"}