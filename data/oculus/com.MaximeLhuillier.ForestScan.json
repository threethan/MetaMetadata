oh=00_AYBVHId0QohstZxJAuau9sKE3TJhZIlvcAmP0A4iqanTwQ&oe=66F00DB5"}, {"file_name": "Screenshot2.png", "id": "830107978355425", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75314846_830107981688758_708232131660660581_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2L5i7wzP4L4Q7kNvgFk0oIn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUKdoSj4xVPZgkQ8IFkKMwD4TULYjjlXySsg7dUs8WvQ&oe=66EFF1C6"}, {"file_name": "Screenshot3.png", "id": "363846782482585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_363846785815918_4504657108639784316_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=thZdECjLvD4Q7kNvgH8i9xL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUuZ4cWmxhOfmyk9h3fwiL_KsJdkTASCh3NAQryOFc-g&oe=66EFFFFD"}, {"file_name": "Screenshot4.png", "id": "615936303418693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974457_615936306752026_1145098500816248758_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o_T38-wquY4Q7kNvgG63NjX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAnQIZvrpBO5qMx5kW6bSWLxUN0akTy01ulAEjGgPKFWw&oe=66F019F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "461601282560023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031402_461601285893356_7581554104634840885_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0nxT8hta9QwQ7kNvgEKL4rM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEZEuAEGRZpfuIgWB36-i0LZjjW0eVVbE04PSQwEcN4w&oe=66EFFA1C"}, "display_name": "3D scan of a forest", "keywords": [], "long_description": "Move like a pedestrian in a forest, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 800m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a forest, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held camera (Garmin Virb 360) and by walking about 800 meters in a forest."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "988384362558220"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250458_751923672547617_638713737026394932_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nR5JxntdwQgQ7kNvgFPn-oN&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVsqJ2TpJS_SrkNJZaRrINWZMLyDPSxIIC