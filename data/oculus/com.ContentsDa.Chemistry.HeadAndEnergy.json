t=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAJu0M6pOyMIt_aiI3ui_ZgqOi2U-YnhPD9c3rg4bBpw&oe=67387782"}]}, "id": "1758874004934890", "locale": "en_US", "screenshots": [{"file_name": "ApplicationFrameHost_brZxptDfjb.png", "id": "2372214126455387", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974698_2372214129788720_8385689491114100284_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4k-Wdh8qoTUQ7kNvgHGUMg6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDngiDmx35sczinSzQ8TAfeFo83ThchbqIScTVdwMdEHQ&oe=67388F63"}, {"file_name": "ApplicationFrameHost_rkfAXX2AfU.png", "id": "2229827617404395", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974860_2229827620737728_2529912783792071491_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JPzTAIMoubEQ7kNvgG4crVk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkHr2FXy7TwcXxHCfmM00LU98JRCzpuL5Dj0E9uUhf3A&oe=67386728"}, {"file_name": "ApplicationFrameHost_XUCIy5LudH.png", "id": "487364951005932", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031383_487364954339265_4749504547257173479_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1ULY3ZjTK8Q7kNvgHdbBZA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_sx3TJzfI2N0zU7s9rM_REldXfGu3phfKjdlj67D_fw&oe=67388FCE"}, {"file_name": "ApplicationFrameHost_eQY6y50OsS.png", "id": "940978601420510", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974767_940978604753843_4439732616684215065_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hh1UB_yZgMEQ7kNvgE9RrLQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdYUUHz0Y5e4y8DdtRbMRaRYMPz4xSN4-55c3TsG-LCA&oe=673895A9"}, {"file_name": "ApplicationFrameHost_qEZSVp2Qam.png", "id": "1069229461086405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031541_1069229464419738_2789796330285648637_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pC32KFIVTPUQ7kNvgEa7jBy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnuAqgpME9aDQ97vV2kAuLpoSTkNcquOAs_ZEGCpqA8w&oe=6738884B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Heat and Energy_Landscape.png", "id": "914090700331938", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75330716_914090703665271_5745583449124777395_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XN9XvJG6MNoQ7kNvgFTQYgf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM_KHHaUdj2-IJJO3zN493mMz36f5B0wR68wL5CaSevg&oe=673876F2"}, "display_name": "Heat and Energy - ContentsDa Science Experiment", "keywords": ["experiment", "chemistry", "school", "science", "contentsda"], "long_description": "1. Place a digital thermometer in a black aluminum cup with a lid.\n2. Place the wood film about 30 cm away from the infrared light.\n3. Place the black aluminum cup on top of the wood film.\n4. Turn on the infrared light and measure the temperature in the cup every 2 minutes and record it in a table.\n5. Graph the temperature change in the black aluminum cup over time at 2-minute intervals.\nWhy the temperature of the air in the aluminum cup does not continue to increase: Over time, the aluminum\n\nthe amount of radiant energy absorbed by the aluminum cup equals the amount of radiant energy emitted by the aluminum cup.\nradiative equilibrium.\n\nWhy the average temperature of the Earth remains constant even though it continues to absorb solar radiation: The amount of solar radiation absorbed by the Earth is the same as the amount of solar radiation emitted by the Earth. radiative equilibrium.", "short_description": "Delve into the dynamic world of thermodynamics. Explore how heat transfers between objects and how it influences energy changes. This hands-on experiment is a fascinating journey through the principles of energy conservation and thermodynamics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher