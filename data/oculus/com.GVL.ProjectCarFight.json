ogo.png", "id": "473086724995985", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003253_473086728329318_6631269976326757755_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TIhN7fHZTqYQ7kNvgG_l2aQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSlHHa4yuihbV2wvv0OmwFBXtJXUODpyACOkcgacg4fA&oe=66D2E387"}]}, "id": "476948161186453", "locale": "en_US", "screenshots": [{"file_name": "Logo 2560x1440.png", "id": "3259392307659188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035380_3259392314325854_4561453295168031898_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C2tCybziy-MQ7kNvgHkFIUq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxKOh4jvGhmMJIZwjH487zNcwtL6vnB_FZOITN04isIA&oe=66D301AD"}, {"file_name": "2560x1440.png", "id": "562491948572774", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001670_562491951906107_5438795925896298948_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ns0dA-auLUQ7kNvgGFf4Wy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDzoxiJ6tHv4e0ZSiV6Rw8XjGwMCMDMP59LotZBYXacdg&oe=66D2F832"}, {"file_name": "Car Fight Promote 3.png", "id": "1384357815436784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974908_1384357818770117_3122814705967085492_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NCEpF4N-IpYQ7kNvgF33-mb&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8eDXkMLSZ3KcM5MZ5qsqxD9ciG836HolkOpcSqay0gA&oe=66D2F6E9"}, {"file_name": "Car Fight Promote 1.png", "id": "3020421981591527", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974526_3020421984924860_4042118153302074534_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DkVP2AYxF1MQ7kNvgHsp3HZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCc5NlbpyuINygjTe2vTVeyhxf_ss50bMB0GmaDX2hwiQ&oe=66D2E6E5"}, {"file_name": "Car Fight Promote 2.png", "id": "1380830419351603", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982607_1380830422684936_2200746347422390_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lIy32CUkKy4Q7kNvgGdG9cO&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9sb3mvllgWxj5xxQbA4x7GjBbXi03aB63hO0r-G9J5Q&oe=66D2FB11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "848606113030627", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031446_848606116363960_568583884091115488_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aznNvT_gld0Q7kNvgHdNlBd&_nc_ht=scontent.oculuscdn.com&oh=00_AYA1SaOY0q8KSYAB-tp3GAbblD2NTOBbg1Osw89vBAw5xg&oe=66D307A4"}, "display_name": "Car Fight", "keywords": [], "long_description": "Features:\n- Multiple players (network required).\n- First-person cockpit viewpoint: an immersive gaming experience.\n- Fair combat mechanics: players obtain various upgrades as each game progresses.\n- Fast-paced game: in a tight game rhythm, every second counts.\nFREE.\n\nEA version:\n- The EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gameplay of this game and develop more game experiences around the core gameplay.\n\nJoin the discord at https://discord.gg/2UqhEjfEAj to more friends or just talk about the game.", "short_description": "A VR First-person cockpit game. EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gameplay of this game and develop more game experiences around the core gameplay."}]}, "developer_name": null, "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscriptio