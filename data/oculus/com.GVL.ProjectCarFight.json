_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBV_hDwxrLo8B6SuB-BNSTIpp7klO97meQ_aRen2X2wow&oe=67752AB1"}, {"file_name": "GamePhoto-(Xavier-Grubb)_Photo3_Version1.png", "id": "920810779942386", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75435286_920810783275719_8347291101075520485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wr-qrtZrnZ8Q7kNvgEWu25q&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCJQfbl3TqtMWhSeRM6sKYvl2u1rlgwG4nqVAt0tQxTJQ&oe=67751F70"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BoN_New_CoverArt(Landscape) Xavier Grubb(New).png", "id": "1036575221547817", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75287554_1036575224881150_6585878648986016439_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1F9PlXv7I2MQ7kNvgFHodFi&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBB7SuXBgh2H4E2DTv0qXii7yZRFjDs53zao6ke6634eg&oe=677511CD"}, "display_name": "Battle of Nowhere", "keywords": [], "long_description": "Free demo is available https://www.meta.com/experiences/6411035082333525/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": "Great Victory Legends, Inc.", "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9464172920263799"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569430_1254338722363987_3173897638868826051_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5cF8Hrxq8n0Q7kNvgHGD_Km&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBHnVcYDEzBGRC_WJ5oIaJkvCpMj0ZskKpLHUgU_Z8NPg&oe=67753A3A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Battle of Nowhere", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1671647233, "lastRevision": {"nodes": [{"id": "6448853235129131", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6448853188462469", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"