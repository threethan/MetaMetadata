981591527", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974526_3020421984924860_4042118153302074534_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VuyE0OScobAQ7kNvgGyIDPo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCE3SiW2J2taYL1_LffWDBTxc_G5OyZ_AyQX_gXFNu4TQ&oe=675300A5"}, {"file_name": "Car Fight Promote 2.png", "id": "1380830419351603", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982607_1380830422684936_2200746347422390_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qRVCaQ8v0lYQ7kNvgFGl8AC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBWJVXySV27ka-_bugjLWpbrU2JC6VvEDn3k0Hz3qytoQ&oe=6752DC91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "848606113030627", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031446_848606116363960_568583884091115488_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0uJiOPPqMBAQ7kNvgFn5SJX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtxX1rIncr2QnPeNkI1d6VMp081zd0PERd32Xq5DD9lg&oe=6752E924"}, "display_name": "Car Fight", "keywords": [], "long_description": "Features:\n- Multiple players (network required).\n- First-person cockpit viewpoint: an immersive gaming experience.\n- Fair combat mechanics: players obtain various upgrades as each game progresses.\n- Fast-paced game: in a tight game rhythm, every second counts.\nFREE.\n\nEA version:\n- The EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gameplay of this game and develop more game experiences around the core gameplay.\n\nJoin the discord at https://discord.gg/2UqhEjfEAj to more friends or just talk about the game.", "short_description": "A VR First-person cockpit game. EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core game