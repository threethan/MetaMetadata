_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDKeQ9lr0RWMrT0yzwfaF-ukbDGfw7qWCtvDMBVELaeaw&oe=675EC131"}, {"file_name": "GamePhoto-(Xavier-Grubb)_Photo3_Version1.png", "id": "920810779942386", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75435286_920810783275719_8347291101075520485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=opPzwkNg7tAQ7kNvgF2iJsZ&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYA5FMRNz8kxEBSFS5JSjuwwVSGL8n-nZx1H_D-P6cBESg&oe=675EB5F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BoN_New_CoverArt(Landscape) Xavier Grubb(New).png", "id": "1036575221547817", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75287554_1036575224881150_6585878648986016439_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F7li4nJL1OMQ7kNvgHfGg0d&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBH7E-Qgzz3SiDonqw73sWZI_9sOSyIqOAU90m2pZ0rlQ&oe=675EA84D"}, "display_name": "Battle of Nowhere", "keywords": [], "long_description": "Free demo is available https://www.meta.com/experiences/6411035082333525/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": "Great Victory Legends, Inc.", "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9464172920263799"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57569430_1254338722363987_3173897638868826051_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VIuq44TVr6gQ7kNvgHEoAGd&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCJ83gjkdJrANgP9FX4S52gO15d1twRz4x3uSZB9a7zbg&oe=675ED0BA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Battle of Nowhere", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1671647233, "lastRevision": {"nodes": [{"id": "6448853235129131", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6448853188462469", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"