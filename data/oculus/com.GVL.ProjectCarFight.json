81591527", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974526_3020421984924860_4042118153302074534_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jj0ymBEpIEgQ7kNvgEESyQ_&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCGoVqxeRqkLLqF_KK1AY5_DZbBes-Z99qWPCodACl2lA&oe=675EDE25"}, {"file_name": "Car Fight Promote 2.png", "id": "1380830419351603", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982607_1380830422684936_2200746347422390_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GpLEvE1kIcUQ7kNvgH13NZz&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBjM74UV1hkhdgy8rdV0tD15cjZJX_h2O_muDcPSw_5Ew&oe=675EBA11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "848606113030627", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031446_848606116363960_568583884091115488_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x5pdlJtliyoQ7kNvgGHNPH8&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBVObW0GW5qgrEmA4FK8y5Pwrwn5l2OGdyqd_yhZHattQ&oe=675EC6A4"}, "display_name": "Car Fight", "keywords": [], "long_description": "Features:\n- Multiple players (network required).\n- First-person cockpit viewpoint: an immersive gaming experience.\n- Fair combat mechanics: players obtain various upgrades as each game progresses.\n- Fast-paced game: in a tight game rhythm, every second counts.\nFREE.\n\nEA version:\n- The EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gameplay of this game and develop more game experiences around the core gameplay.\n\nJoin the discord at https://discord.gg/2UqhEjfEAj to more friends or just talk about the game.", "short_description": "A VR First-person cockpit game. EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gamep