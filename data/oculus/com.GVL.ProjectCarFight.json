81591527", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974526_3020421984924860_4042118153302074534_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vaXOjwvz5w4Q7kNvgGjcBnb&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBpspwMBXfSL_L16A8RpH0owcUJFwa2YSawQISoubdfBw&oe=678632E5"}, {"file_name": "Car Fight Promote 2.png", "id": "1380830419351603", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982607_1380830422684936_2200746347422390_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AUuUmTHJpA8Q7kNvgGAqt73&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBrwfM6NnOfoAkFFJjV4E2mkbD5_Us6xQm1WJLVRiW6Kg&oe=67864711"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "848606113030627", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031446_848606116363960_568583884091115488_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwtU3li5cUwQ7kNvgEKPe7-&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD1-86fpYWS_TrH4XEOE6fY4jBOgjE-c5unvNKAG7yjPg&oe=678653A4"}, "display_name": "Car Fight", "keywords": [], "long_description": "Features:\n- Multiple players (network required).\n- First-person cockpit viewpoint: an immersive gaming experience.\n- Fair combat mechanics: players obtain various upgrades as each game progresses.\n- Fast-paced game: in a tight game rhythm, every second counts.\nFREE.\n\nEA version:\n- The EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gameplay of this game and develop more game experiences around the core gameplay.\n\nJoin the discord at https://discord.gg/2UqhEjfEAj to more friends or just talk about the game.", "short_description": "A VR First-person cockpit game. EA version is designed to test the game's core gameplay: multiplayer, cockpit experience, combat, upgrade, and other core functions. We will continue to improve the core gamep