iad3-1.oculuscdn.com&oh=00_AYBJVO_sA0q-6ja0rfs2tXEoOiy39Bf2tY6Tg2uQCtQAbQ&oe=673204BE"}, {"file_name": "Screenshot 2024-06-17 201254.png", "id": "992962552614058", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210390_992962555947391_7678786125143090132_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HH3sEsdlgicQ7kNvgEUw5cZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn-kw_cI8dXKkkL6uJWPi2M__x8IUc1nVuziotp_D5sA&oe=6731ECF6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BoN_New_CoverArt(Landscape) Xavier Grubb(New).png", "id": "1036575221547817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75287554_1036575224881150_6585878648986016439_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bAGOxrJAsFAQ7kNvgHT7aNV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZ6hJoZBBdIbVxJZCpmDLg2M8N9htMvIdvKwHnmXBXIQ&oe=6731D54D"}, "display_name": "Battle of Nowhere", "keywords": [], "long_description": "Free demo is available https://www.meta.com/experiences/6411035082333525/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": "Great Victory Legends, Inc.", "dev