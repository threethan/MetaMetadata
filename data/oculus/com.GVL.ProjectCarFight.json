8&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kdi53oJVMIMQ7kNvgFlYUni&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCArOdSZRZuCQKjuh9hq5t0aQvSEvhcdDlgZo4_04vcg&oe=66D45276"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BoNCoverArt(Landscape)8-24 Carlin Jasper.png", "id": "862681071873718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86653847_862681075207051_2295940539398946235_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XfrItVp6_9MQ7kNvgF9pf7D&_nc_ht=scontent.oculuscdn.com&oh=00_AYDl1gVZ4fmQBS6v_ZXp8XQgNtLbzY5w0jcCkaJm8DpK7w&oe=66D44D0A"}, "display_name": "Battle of Nowhere", "keywords": [], "long_description": "Free demo is available https://www.meta.com/experiences/6411035082333525/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": "Great Victory Legends, Inc.", "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": nul