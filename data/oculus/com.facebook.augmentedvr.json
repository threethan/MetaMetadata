gY5Zz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2FcVxa-XTUThSqdv-0NSFJlOhrsVP_jLgL8LogatQjA&oe=670505E3"}, {"file_name": "03_Meta_spark_ar_player.png", "id": "662141478759999", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75416838_662141482093332_4013439942271365489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whkPh_nkHZMQ7kNvgGRLgn9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0FPs-O_-5oSi5J7u0se6PIGDd1mxchss5OfvMGR2yPQ&oe=67051805"}, {"file_name": "04_Meta_spark_ar_player.png", "id": "615660286962606", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031327_615660290295939_4208192044245677522_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=81Nn0YHkmh4Q7kNvgHTODUF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1crXOzBS6y6dMbtX9Y9BQ8rtbprOHq3N9I_9c0OlwhQ&oe=670521E6"}, {"file_name": "05_Meta_spark_ar_player.png", "id": "398227562497805", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210893_398227565831138_8716680436825151186_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z1LK1dcQXO8Q7kNvgHf7z-D&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5k-2CJM0ZMRY7UpCAfDm72GUtCuyTmh1FAdDd5Unejg&oe=67050279"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meta Spark Player", "keywords": ["spark", "ar"], "long_description": "Meta Spark Player is a testing ground for virtual objects, a type of interactive, world-facing AR experience. Use the app to interact with ready-made demo objects or send your own virtual objects directly from Meta Spark Studio. \n\n- Connect to Meta Spark Studio and send virtual objects directly to the app. \n- Take a tutorial to understand how to control virtual objects with your Meta Quest device controllers.\n- Manipulate virtual object position, scale and rotation.  \n- Test inputs to see virtual objects in different states.\n- Use demo objects to explore what\u2019s possible. ", "short_description": "Use Meta Spark Player to see your virtual objects come to life.\n\nThe v