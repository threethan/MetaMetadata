7710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3ZTv_i-7sk4Q7kNvgF135zZ&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBoGq8L0wqGeAtb0HYeKatmaf9GA7w613c0zh3Y1gGmJA&oe=6710E363"}, {"file_name": "03_Meta_spark_ar_player.png", "id": "662141478759999", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75416838_662141482093332_4013439942271365489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3bWozuY-m7EQ7kNvgHp9opc&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDUrKzS_Svu1uYUKnMl1nBiebLCXdoa66hTiHamLthFsQ&oe=6710F585"}, {"file_name": "04_Meta_spark_ar_player.png", "id": "615660286962606", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031327_615660290295939_4208192044245677522_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zfPaXEC4tfwQ7kNvgGfLiXA&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD4WThe68xV-CUkH3TV_5RQjUNy85cOXcSZ7dzGiiav3g&oe=6710FF66"}, {"file_name": "05_Meta_spark_ar_player.png", "id": "398227562497805", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75210893_398227565831138_8716680436825151186_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wHilnVv6IGAQ7kNvgFbWf8p&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBW-LC-_vinq51VwX5UkV9xWlNlQbki-AUV0S8d0IpwmQ&oe=6710DFF9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meta Spark Player", "keywords": ["spark", "ar"], "long_description": "Meta Spark Player is a testing ground for virtual objects, a type of interactive, world-facing AR experience. Use the app to interact with ready-made demo objects or send your own virtual objects directly from Meta Spark Studio. \n\n- Connect to Meta Spark Studio and send virtual objects directly to the app. \n- Take a tutorial to understand how to control virtual objects with your Meta Quest device controllers.\n- Manipulate virtual object position, scale and rotation.  \n- Test inputs to see virtual objects in different states.\n- Use demo objects to explore what\u2019s possible. ", "short_description": "Use Meta Spark Player to see your virtual objects come to life.\n\nThe virtual objects you create in Meta Spark Studio can be sent directly to Meta Spark Player. See and interact with your virtual objects in your surroundings using Passthrough on your Meta Quest device.  "}]}, "developer_name": "Meta Platforms, Inc", "developer_privacy_policy_url": "https://www.facebook.com/about/privacy", "developer_terms_of_service_url": "https://sparkar.facebook.com/ar-studio/terms/", "publisher_name": "Meta Platforms, Inc", "support_website_url": null, "website_url": "https://sparkar.facebook.com/ar-studio/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "783066696356143"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75295751_952423296149544_6248543502049458911_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AV43J8RcnLIQ7kNvgGtfGkI&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCYRy6XCN-vep9SJBlICnjAIQTp5mmsvQfM5a39IWazBg&oe=6710F196"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Meta Spark Player", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1611870940, "lastRevision": {"nodes": [{"id": "1202201326826028", "release_type": "S