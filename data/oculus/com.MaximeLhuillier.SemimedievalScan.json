, {"file_name": "Screenshot1.png", "id": "1079721616244715", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036690_1079721622911381_2025426547054885093_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iZ57Jyek6O0Q7kNvgHqQnq2&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7KH18UJjTEITwv8FDmrVs&oh=00_AYBbVVMmKOZHc-xdAuG94yI9xBYIoCfrB6gNl_C1-85lDQ&oe=66F003F4"}, {"file_name": "Screenshot3.png", "id": "617397003109784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031458_617397006443117_1774695430560020032_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zEr6Dd210sQ7kNvgHPTyk1&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7KH18UJjTEITwv8FDmrVs&oh=00_AYAU9ANSQwZNku30Dj5TpPe7LiWwdyGmO0otuWZrWp0xCA&oe=66EFE38B"}, {"file_name": "Screenshot2.png", "id": "482401670377841", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75580070_482401673711174_747670155297192185_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=boZjaA1unjUQ7kNvgGb5zh7&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7KH18UJjTEITwv8FDmrVs&oh=00_AYBkdrWwUdOpgJjyz7TGc7-ydEsWNChmpAjv4Lick72vNA&oe=66EFF7A4"}, {"file_name": "Screenshot4.png", "id": "484817489765699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031458_484817493099032_3228411915693974550_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4MWZkAbwQ28Q7kNvgHuJFYr&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7KH18UJjTEITwv8FDmrVs&oh=00_AYCsdSlUTC41GTH1BnpV3BT4ktqwnDCzVcgh_DLpsl5dfw&oe=66F01960"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1775139299488526", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610702_1775139302821859_7160853561334559601_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t9qEdrE1wtMQ7kNvgFMRVUD&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak7KH18UJjTEITwv8FDmrVs&oh=00_AYCVGWDpncp1F2pssUR0s5V7xsHLpEU2eav87hz7z2RndQ&oe=66EFE3BC"}, "display_name": "3D scan of a semi-medieval town", "keywords": [], "long_description": "Move like a pedestrian in a semi-medieval town, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 1km long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a semi-medieval town, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by walking about 1km in a town (Montpeyroux, in France)."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_