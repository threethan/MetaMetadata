25/38982495_165207395409006_7079079192133666548_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DMp3GywfQh4Q7kNvgEKl6nW&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYC3nT1DwuuoiicJSHUvGKv4pfvqo4YmbiNI2mGXkT_xLw&oe=670BAB34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1049872652172517", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38984472_1049872655505850_9035876489653876993_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nJIxydYves0Q7kNvgGx9lWv&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCnQfDe5qKatk73w72_9z_K8jUonE79Pp8hZXzmgMBJ3Q&oe=670BB795"}, "display_name": "Racket: Nx Demo", "keywords": [], "long_description": "Racket: Nx is a new kind of game that challenges the limits of what you can do with a racket and ball in VR. \n\nThe game features:\n- 2 single player modes - a campaign and an endless runner!\n- Versus & Co-op multiplayer supporting cross platform and multiple devices with the same user!\n- A sick original soundtrack and the option to play your own music in game!\n\nThe game is played inside a giant glass dome, the walls of which light up with targets you must destroy with the ball.\n\nBut this is no ordinary ball!\n\nHit it with force and it will slam into the wall, rolling across it and bulldozing everything in its path!\n\nUse your racket's tractor beam to pull it back, or simply to line up your next shot exactly where you want it. \n\nBe quick and plan your shots well. Learn to control the ball to perfection.", "short_description": "Racket: Nx is new kind of game that challenges the limits of what you can do with a racket and ball in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://racketnx-config.s3-us-west-1.amazonaws.com/racket-nx-privacy.html", "developer_terms_of_service_url": "https://onehamsa.com/", "publisher_name": "One Hamsa", "support_website_url": "https://racketnx.com/", "website_url": "https://racketnx.com/", "category": "GAMES", "comfort_rating"