ng", "id": "3931807113538723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974483_3931807116872056_4086830938543199693_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5K7NUXNynaMQ7kNvgEM4FbP&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae8ckTBDgfn5R6kdeKgPOxP&oh=00_AYB0qVZNkGeuxWcLS9r64LeDpzeCJoFgHEweeD0RAj5nUw&oe=66EEA60D"}, {"file_name": "Screenshot_05.png", "id": "165207392075673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_165207395409006_7079079192133666548_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wDWqH4Nbe4Q7kNvgF0fTn3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae8ckTBDgfn5R6kdeKgPOxP&oh=00_AYDr759fx07JQAuze4X14T47RTwdty3vbr1MI4_vofMcUQ&oe=66EEAA34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1049872652172517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_1049872655505850_9035876489653876993_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Z2f52JUJlgQ7kNvgEFj-FX&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae8ckTBDgfn5R6kdeKgPOxP&oh=00_AYCTlwdzOwQz6Yf9mcTK3HvOlFNWPPHdj7Dr0EB0tbCJqg&oe=66EEB695"}, "display_name": "Racket: Nx Demo", "keywords": [], "long_description": "Racket: Nx is a new kind of game that challenges the limits of what you can do with a racket and ball in VR. \n\nThe game features:\n- 2 single player modes - a campaign and an endless runner!\n- Versus & Co-op multiplayer supporting cross platform and multiple devices with the same user!\n- A sick original soundtrack and the option to play your own music in game!\n\nThe game is played inside a giant glass dome, the walls of which light up with targets you must destroy with the ball.\n\nBut this is no ordinary ball!\n\nHit it with force and it will slam into the wall, rolling across it and bulldozing everything in its path!\n\nUse your racket's tractor beam to pull it back, or simply to line up your next shot exactly where you want it. \n\nBe quick and plan your shots well. Learn to control the ball to perfection.", "short_description": "Racket: Nx is new kind of game that challenges the limits of what you can do with a racket and ball in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://racketnx-config.s3-us-west-1.amazonaws.com/racket-nx-privacy.html", "developer_terms_of_service_url": "https://onehamsa.com/", "publisher_name": "One Hamsa", "support_website_url": "https://racketnx.com/", "website_url": "https://racketnx.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "ja", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "650303413056407"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "182021790376553"}]}, "baseline_offer": {"id": "182021790376553"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1621609980, "status": "PUBLISHED", "id": "182021790376553"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4025536927525945", "version": "2.2.10"}, "id": "1867794283389806", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3774393822640258", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBina