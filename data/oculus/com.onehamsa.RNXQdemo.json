00_AYD7oPxX4S1MJB2Wxqi9-Q0khOudie9T351mojQ9WGzbXQ&oe=66F1490D"}, {"file_name": "Screenshot_05.png", "id": "165207392075673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_165207395409006_7079079192133666548_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wDWqH4Nbe4Q7kNvgE7XcH4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwEmVzqaqjFrlchTAz6wP7D&oh=00_AYCpopubUk5GFVI_-F3MHTow01CCQMfCAfU6WFlJdKvDVA&oe=66F14D34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1049872652172517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_1049872655505850_9035876489653876993_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N3db1o284S0Q7kNvgFhm6yw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AwEmVzqaqjFrlchTAz6wP7D&oh=00_AYDLE9ZU1x_C4BIrQ3aPcmWotuWLYYj9K7F32IENXalm2Q&oe=66F15995"}, "display_name": "Racket: Nx Demo", "keywords": [], "long_description": "Racket: Nx is a new kind of game that challenges the limits of what you can do with a racket and ball in VR. \n\nThe game features:\n- 2 single player modes - a campaign and an endless runner!\n- Versus & Co-op multiplayer supporting cross platform and multiple devices with the same user!\n- A sick original soundtrack and the option to play your own music in game!\n\nThe game is played inside a giant glass dome, the walls of which light up with targets you must destroy with the ball.\n\nBut this is no ordinary ball!\n\nHit it with force and it will slam into the wall, rolling across it and bulldozing everything in its path!\n\nUse your racket's tractor beam to pull it back, or simply to line up your next shot exactly where you want it. \n\nBe quick and plan your shots well. Learn to control the ball to perfection.", "short_description": "Racket: Nx is new kind of game that challenges the limits of what you can do with a racket and ball in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://racketnx-public.s3.us-west-1.amazonaws.com/racket-nx-privacy.html