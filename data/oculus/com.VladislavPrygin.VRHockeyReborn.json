527799368_107471335851124969_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7OUzoHUQwVEQ7kNvgE3Pzax&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8snkPRkGxbjmLk4PRwJ1YWeLA-0ugHMYDLy8AS_o75Q&oe=67615AA3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Trailer.png", "id": "1234117440458633", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210889_1234117443791966_1316267769628043711_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xADFtC_tUOMQ7kNvgFHUgeU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnzyjB9XyZmYUpMf6dVReYB4JcZ6YyjoNuiMaypCjBoA&oe=67615281"}, "display_name": "VR Hockey Reborn", "keywords": [], "long_description": "VR Hockey Reborn was carefully created by a former hockey player. Our main goal is to create best experience for players who never tried play hockey, and to fit the requirements of all hockey players across the globe.\n\nExperiment with physics, feel the pleasure of the realism of puck possession, score goals in different ways.\n\nThe game is also suitable for beginners in hockey. You can even play with one hand.\n\n- Full control Multiplayer with ability to play for goalie \n- The feeling of being on the hockey rink\n- Attention to detail\n- Realistic puck possession physics\n- Animated pads going to butterfly and RVH depends on your movement\n- Tested by real hockey players", "short_description": "VR Hockey is here. Meet one of the most realistic VR hockey experiences."}]}, "developer_name": "Vladislav Prygin", "developer_privacy_policy_url": "https://pryginvl.wixsite.com/vr-hockey-reborn/privacypolicy", "developer_terms_of_service_url": "https://pryginvl.wixsite.com/vr-hockey-reborn/termsofuse", "publisher_name": "Vladislav Prygin", "support_website_url": null, "website_url": "http://npc-games.com/en", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542