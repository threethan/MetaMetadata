i": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295292_796281469314286_6466220068730746066_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pFfEsBCdpEUQ7kNvgGzHkTk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_vhsO3ftifOhyp3XGXfTbPpowJWiXiS7POElV4AYLAg&oe=671B7D80"}, {"file_name": "IntoBlack_Keyart_1008x1440_revision.png", "id": "361680063290692", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003285_361680066624025_3478730673622421955_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mf6C-vdWO7IQ7kNvgEwyejH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdrHNeENDNPf08dqS1lHKwvpvoRSKkVZiTOucQrNA7Yw&oe=671B78D3"}]}, "id": "1057232628220140", "locale": "en_US", "screenshots": [{"file_name": "IntoBlack_screenshot_02.png", "id": "512041828076397", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982629_512041831409730_8667121257851023223_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TX78HVU74zkQ7kNvgFOVLGC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOjMqM0C8FxMYe5YDNXD0Qia7saFpl8K62AfDcPlQy4A&oe=671B9B49"}, {"file_name": "IntoBlack_screenshot_04.png", "id": "1684549512298292", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75557068_1684549515631625_7815578555210982451_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hKZ1W9jYiVkQ7kNvgHLaXFO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCp3_EwfZFh6Ke6VySLGa4TErxIzFsuh2xC_jVRz7lRPQ&oe=671B9446"}, {"file_name": "IntoBlack_screenshot_03.png", "id": "1074821844060035", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974871_1074821847393368_7409911914039091070_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v2WL-WF6eL8Q7kNvgEuxNBE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAe4WMkWecNi5BYcfa7VwV4WDfA9kKUOsKuHNJ-gO-XpA&oe=671B719A"}, {"file_name": "IntoBlack_screenshot_05.png", "id": "378028485335043", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203627_378028488668376_8020467403486384968_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6xiNWm0g5EkQ7kNvgE-BKjs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDX9yM8kqPvrATYH3MQ91OHG5ZFa8A56fALHhZUhyqc-Q&oe=671B952D"}, {"file_name": "IntoBlack_screenshot_01.png", "id": "1566309294295349", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974581_1566309297628682_5760016102495610657_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RiBZuV9SSJ8Q7kNvgH-RGrs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDsB_mrxTi_3B9fZnUMu_UQkKtCUnSPapgElBF9eKa2NA&oe=671B71DB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "IntoBlack_Keyart_2560x1440_revision.png", "id": "1200724771233145", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974483_1200724774566478_7283999429197145403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=StjY1Hv7agYQ7kNvgFJbqxd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnZVny3azBQHjDvLzyCxaCCbiUTs_bvz8s6kXcr7Z74w&oe=671B7516"}, "display_name": "Into Black", "keywords": [], "long_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\n**Into Black** is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off alien beasts as you try to repair your ship and escape.\n\nDesigned for Meta Quest and leveraging the power of Quest 3, featuring a rich story, multiple game modes, and solo or co-op gameplay.\n\n# Features\n- **Single or Co-op action:** Play the entire campaign with up to 3 friends, or just jump in for an epic solo adventure.\n\n- **Fully voice-acted campaign:** Follow deep space scavenger Ben Mitchell and his hapless assistant droid as they are drawn into a mystery at the heart of the universe.\n\n- **Explore 20+ levels across multiple unique biomes:** Navigate magma chambers, sunken caves, labyrinthine tunnels, alien nests, and more. \n\n- **Gather resources & upgrade tools:** Mine, scavenge, loot, and fish as you gather the resources you need to upgrade your character and repair your ship. \n\n- **Fight to survive:** Deadly alien creatures lurk in the darkness; to survive you'll have to master an array of powerful weapons.\n\n- **\"Singularity\" PvPvE mode:** Face off against up to 11 other players in this online competitive mode. Forge uneasy alliances as you navigate an ever-shrinking maze. Gather as much loot as you can, but get too greedy and you may not make it out at all\u2026", "short_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\nInto Black is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off deadly alien beasts as you try to repair your ship and escape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thebinarymill.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "The Binary Mill", "support_website_url": "https://thebinarymill.zendesk.com/hc/en-us", "website_url": "https://www.thebinarymill.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "366974712128603"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "761792176073404"}, {"status": "PUBLISHED", "id": "819199703576992"}, {"status": "PUBLISHED", "id": "510046171718321"}]}, "baseline_offer": {"id": "761792176073404"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728579600, "status": "PUBLISHED", "id": "761792176073404"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8774461205947163", "version": "1.1.01.261"}, "id": "1023186325301715", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8774461205947163"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1023186325301715"}]}, "change_log": "Into Black - Patch #1\nv 1.1.01.261.2410141809\n\nImprovements:\n\n*   Balance pass on resource cost amounts\n*   More intense teleport extraction fights\n*   General combat and enemy AI improvements\n*   Improved late game boss encounters\n*   Golem now has better hand-eye coordination\n*   Pickaxe throwing refinements\n*   Added gyros to later levels\n*   Boosted enemy health at higher difficulties\n*   Improved Quest 2 stability\n\nAudio:\n\n*   New player level up SFX\n*   New tool level up SFX\n*   New teleport beacon SFX\n*   New hive extractor SFX\n*   Improved UI hover SFX\n*   Resource impact improvements\n\nBug Fixes:\n\n*   Fixed sequencing issues around the Mission 3 anomaly, can now breach / scan in any order and it shouldn't break\n*   Fixed issue where some schematics were not dropping correctly (upgrades for health, grenades etc)\n*   Fixed issue with some upgrades not displaying correctly in skill tree\n*   Fixed orb drops not occurring on some enemy variants\n*   Fixed Sticky Flares not working\n*   Fixed a bug where damage numbers didn't show on hammer throws\n*   Fixed a bug where golem would lose aggro after player death\n*   Optimized boss music and reduced likelihood of start/stops\n*   Fixed an issue where some impact sounds were using the ship hull surface instead of body\n*   Fixed icon orientation in fabricator\n*   Repairing the drive core now visually repairs it in the ship\n*   Fixed wrist UI bug where pickaxe could disappear\n*   Fixes for final boss room fog\n*   Correctly un-hover devices in the objectives tab, stopping them from stealing crafting input when not focused (Breacher ghost crafting fix)\n*   Fixed chest game not allowing minimum contraction and fixed pop delay\n*   Fixed shark(s) not spawning\n*   Fixed player level cap (now correctly capping at 20)\n*   Fixed several instances of 'floating' resources\n*   Several cave and ship lighting fixes\n\nQoL Improvements:\n\n*   Schematics at the fabricator now clearly display which tool/weapon the upgrade is for\n*   Added tooltips to recipe ingredients in the fabricator\n*   Added inline crafting to recipe ingredients that have their own recipes in the fabricator\n*   Colored material owned shown in red if not enough for recipe fabrication\n*   Added Upgrade Terminal \u2018Help\u2019 button with Tutorial\n*   Added \u2018whip to platform\u2019 schematic to Mission 5 cave\n*   Add non-head based movement options\n*   Increased the range of the teleport arc in anomaly to help navigate more easily\n*   Made the vortex sphere pop-up more informative\n*   Added extractor warning when players are attempting to leave before the mission objective is complete\n*   Added menu option to throw pickaxe with grip\n*   Loading tip updates with more useful information\n\nMisc:\n\n*   Reduced laser wasp health\n*   Various VO additions and tweaks\n*   Added credits to options menu\n*   Prevented XP gain on minables that you can't damage\n*   Updated pistol texture\n\n\nJoin the Into Black community on Discord at https://discord.gg/intoblack\n", "created_date": 1728894302, "id": "8774461205947163", "version": "1.1.01.261", "version_code": 261, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8774460165947267"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8774461205947163"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728891610, "id": "8774293542630596", "version": "1.0.15.260", "version_code": 260, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8774292935963990"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8774461205947163"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728885222, "id": "8773869519339665", "version": "1.0.14.259", "version_code": 259, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8773868622673088"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8774461205947163"}, 