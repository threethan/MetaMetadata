zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsax62haJ9sEAq4rLGFGowUfUbDDS1Hh9180CNoxwL8g&oe=67274F1A"}, {"file_name": "IntoBlack_screenshot_05.png", "id": "378028485335043", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203627_378028488668376_8020467403486384968_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LmpPuytLYMoQ7kNvgF30hRA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAn58zy8qaooC-GS-ruamjd_xK0Fhneh_azkrlGilWC6w&oe=672772AD"}, {"file_name": "IntoBlack_screenshot_01.png", "id": "1566309294295349", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974581_1566309297628682_5760016102495610657_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rHVi4IQ3SjEQ7kNvgGMigQM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvpuz1aMX6gKQ-3OyY3OxEmVgWuhoxS3frCNxucWFF-w&oe=67274F5B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "IntoBlack_Keyart_2560x1440_revision.png", "id": "1200724771233145", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974483_1200724774566478_7283999429197145403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tk6pR94XPNAQ7kNvgE10YkN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7EMkR9QJRZoQv_QcPRaXNkldmjFGZfzRb-UztO5rNOQ&oe=67275296"}, "display_name": "Into Black", "keywords": [], "long_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\n**Into Black** is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off alien beasts as you try to repair your ship and escape.\n\nDesigned for Meta Quest and leveraging the power of Quest 3, featuring a rich story, multiple game modes, and solo or co-op gameplay.\n\n# Features\n- **Single or Co-op action:** Play the entire campaign with up to 3 friends, or just jump in for an epic solo adventure.\n\n- **Fully voice-acted campaign:** Follow deep space scavenger Ben Mitchell and his hapless assistant droid as they are drawn into a mystery at the heart of the universe.\n\n- **Explore 20+ levels across multiple unique biomes:** Navigate magma chambers, sunken caves, labyrinthine tunnels, alien nests, and more. \n\n- **Gather resources & upgrade tools:** Mine, scavenge, loot, and fish as you gather the resources you need to upgrade your character and repair your ship. \n\n- **Fight to survive:** Deadly alien creatures lurk in the darkness; to survive you'll have to master an array of powerful weapons.\n\n- **\"Singularity\" PvPvE mode:** Face off against up to 11 other players in this online competitive mode. Forge uneasy alliances as you navigate an ever-shrinking maze. Gather as much loot as you can, but get too greedy and you may not make it out at all\u2026", "short_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\nInto Black is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off deadly alien beasts as you try to repair your ship and escape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thebinarymill.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "The Binary Mill", "support_website_url": "https://thebinarymill.zendesk.com/hc/en-us", "website_url": "https://www.thebinarymill.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "366974712128603"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "761792176073404"}, {"status": "PUBLISHED", "id": "819199703576992"}, {"status": "PUBLISHED", "id": "510046171718321"}]}, "baseline_offer": {"id": "761792176073404"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728579600, "status": "PUBLISHED", "id": "761792176073404"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8828094057250544", "version": "1.2.001.266"}, "id": "1023186325301715", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8828094057250544"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1023186325301715"}]}, "change_log": "*v1.2.001.266.2410231721*\n\n**Improvements:**\n\n*  More enemy balance, pathing and AI improvements\n*  Added \u2018Controller based\u2019 movement option\n*  Multiplayer netcode improvements making other players and enemies smoother \n*  Added a \u2018Low memory\u2019 mode to help with Quest 2 crashes (default set to \u2018on\u2019 for Quest 2 devices)\n\n**Bug Fixes:**\n\n*  Pick axe should no longer freakout uncontrollably\n*  Pesky \u2018ghost bugs\u2019 should now be exterminated\n*  Fixed infinite flight/swim through (most) waterfalls \n*  Fixed player footsteps appearing to sound from behind \n*  Fixed a host of underwater teleporting issues\n*  Fixed issue where Helion could only be mined with \u2018Pickaxe Power 1\u2019 equipped. Subsequent power levels now also work\n*  Resource count now correctly reflects when full\n*  Fabricator UI fix where incorrect items would sometimes display for recipes\n*  Wrist UI storage will now correctly display and not break out of the UI\n*  Blue flyer nerfed (no longer fires infinite death-ray) \n*  Added teleport cool-down\n*  Various typo fixes\n\n**Mission Fixes:**\n\n*  M4 (Whispers in the Dark): Fixed objective updating to return to ship after finding second of three beacons \n*  M5 (Titanium): Wrist UI objective tab correctly reflects players have Titanium before instructing them to return to ship\n*  M7 (Dark Energy): Added additional breacher safety checks to ensure mission progression\n*  M8 (The Professor): The \u2018proceed warning\u2019 popup no longer displays when completing all objectives correctly \n*  M9 (Royalty): Added more safety checks around end of mission ensuring it will register as completed\n*  M13 (Hidden City): Fixed mesh & collision issues \n*  M16 (The Descent): Fixed mesh & collision issues ", "created_date": 1729668711, "id": "8828094057250544", "version": "1.2.001.266", "version_code": 266, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8828092907250659"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289374691122516", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8828094057250544"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1729665235, "id": "8827860017273948", "version": "1.1.103.265", "version_code": 265, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id":