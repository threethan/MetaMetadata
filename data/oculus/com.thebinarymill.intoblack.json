": "1650553535516425", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974591_1650553538849758_1638948881924077644_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Me2PPbD4W9cQ7kNvgHJlNai&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTvV9qwfJEOzTl4JnpjwCkLviRfX3lmYXriJKfUyIQXQ&oe=672760A9"}, {"file_name": "IntoBlack_screenshot_02.png", "id": "512041828076397", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982629_512041831409730_8667121257851023223_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m754rZa3eZcQ7kNvgFzh0yq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGngubsAoBxDOnWLIzQNCRAjZXG_tDIcdMb1hEalhA7g&oe=672778C9"}, {"file_name": "IntoBlack_screenshot_04.png", "id": "1684549512298292", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75557068_1684549515631625_7815578555210982451_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mnp1KKFjfYYQ7kNvgEaCn3R&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBjtmabOzaZGfi7hINwts8nMdYI2zn6G_8VkpFI2PYdQQ&oe=672771C6"}, {"file_name": "IntoBlack_screenshot_03.png", "id": "1074821844060035", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974871_1074821847393368_7409911914039091070_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KVbaw687hP0Q7kNvgHKjsn6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsax62haJ9sEAq4rLGFGowUfUbDDS1Hh9180CNoxwL8g&oe=67274F1A"}, {"file_name": "IntoBlack_screenshot_06.png", "id": "2327028964304216", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035308_2327028967637549_3896354194298482574_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SYUSGSI41S0Q7kNvgEnn_f8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDd27c_91Lwp5UY0tFZrOs9rNlNN8RVp_W-O7t_Ee3l5w&oe=672750E5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "IntoBlack_Keyart_2560x1440_revision.png", "id": "1200724771233145", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974483_1200724774566478_7283999429197145403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tk6pR94XPNAQ7kNvgE10YkN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7EMkR9QJRZoQv_QcPRaXNkldmjFGZfzRb-UztO5rNOQ&oe=67275296"}, "display_name": "Into Black", "keywords": [], "long_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\n**Into Black** is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off alien beasts as you try to repair your ship and escape.\n\n{1177670523327594}\n\nDesigned for Meta Quest and leveraging the power of Quest 3, featuring a rich story, multiple game modes, and solo or co-op gameplay.\n\n# Features\n- **Single or Co-op action:** Play the entire campaign with up to 3 friends, or just jump in for an epic solo adventure.\n\n- **Fight to survive:** Deadly alien creatures lurk in the darkness; to survive you'll have to master an array of powerful weapons.\n\n{550964510785172}\n\n- **Fully voice-acted campaign:** Follow deep space scavenger Ben Mitchell and his hapless assistant droid as they are drawn into a mystery at the heart of the universe.\n\n- **Explore 20+ levels across multiple unique biomes:** Navigate magma chambers, sunken caves, labyrinthine tunnels, alien nests, and more. \n\n- **Gather resources & upgrade tools:** Mine, scavenge and loot as you gather the resources you need to upgrade your character and repair your ship. \n\n{507022245462960}\n\n- **\"Singularity\" PvPvE mode:** Face off against up to 11 other players in this online competitive mode. Forge uneasy alliances as you navigate an ever-shrinking maze. Gather as much loot as you can, but get too greedy and you may not make it out at all\u2026\n\n{1888508874972980} ", "short_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\nInto Black is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off deadly alien beasts as you try to repair your ship and escape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thebinarymill.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "The Binary Mill", "support_website_url": "https://thebinarymill.zendesk.com/hc/en-us", "website_url": "https://www.thebinarymill.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "8654657684594183"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295292_796281469314286_6466220068730746066_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cn0LAbo57T8Q7kNvgExB_VK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1cEEALMu1bEHHyAQtLdVXnMx9p23wNWQgXh4ghLU3eg&oe=67275B00"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Into Black", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Role Playing", "id": "821934236779161"}, {"topic_name": "Action", "id": "459781504968480"}], "release_