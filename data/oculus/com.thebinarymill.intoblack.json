_1638948881924077644_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVjSpWu009EQ7kNvgGzo-Ez&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAz-wwjXupgLNfAoIC-rkDCKd_3T0WKQm1Lg_gvnzrbng&oe=671B8329"}, {"file_name": "IntoBlack_screenshot_02.png", "id": "512041828076397", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982629_512041831409730_8667121257851023223_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TX78HVU74zkQ7kNvgFOVLGC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOjMqM0C8FxMYe5YDNXD0Qia7saFpl8K62AfDcPlQy4A&oe=671B9B49"}, {"file_name": "IntoBlack_screenshot_04.png", "id": "1684549512298292", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75557068_1684549515631625_7815578555210982451_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hKZ1W9jYiVkQ7kNvgHLaXFO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCp3_EwfZFh6Ke6VySLGa4TErxIzFsuh2xC_jVRz7lRPQ&oe=671B9446"}, {"file_name": "IntoBlack_screenshot_03.png", "id": "1074821844060035", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974871_1074821847393368_7409911914039091070_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v2WL-WF6eL8Q7kNvgEuxNBE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAe4WMkWecNi5BYcfa7VwV4WDfA9kKUOsKuHNJ-gO-XpA&oe=671B719A"}, {"file_name": "IntoBlack_screenshot_06.png", "id": "2327028964304216", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035308_2327028967637549_3896354194298482574_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VL9I8YkJE6MQ7kNvgGIXJyQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKjO1DmTLphHyhtoz22nSb0CC5rpPUKnQQ92BSM2yV3w&oe=671B7365"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "IntoBlack_Keyart_2560x1440_revision.png", "id": "1200724771233145", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974483_1200724774566478_7283999429197145403_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=StjY1Hv7agYQ7kNvgFJbqxd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnZVny3azBQHjDvLzyCxaCCbiUTs_bvz8s6kXcr7Z74w&oe=671B7516"}, "display_name": "Into Black", "keywords": [], "long_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\n**Into Black** is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off alien beasts as you try to repair your ship and escape.\n\n{1177670523327594}\n\nDesigned for Meta Quest and leveraging the power of Quest 3, featuring a rich story, multiple game modes, and solo or co-op gameplay.\n\n# Features\n- **Single or Co-op action:** Play the entire campaign with up to 3 friends, or just jump in for an epic solo adventure.\n\n- **Fight to survive:** Deadly alien creatures lurk in the darkness; to survive you'll have to master an array of powerful weapons.\n\n{550964510785172}\n\n- **Fully voice-acted campaign:** Follow deep space scavenger Ben Mitchell and his hapless assistant droid as they are drawn into a mystery at the heart of the universe.\n\n- **Explore 20+ levels across multiple unique biomes:** Navigate magma chambers, sunken caves, labyrinthine tunnels, alien nests, and more. \n\n- **Gather resources & upgrade tools:** Mine, scavenge and loot as you gather the resources you need to upgrade your character and repair your ship. \n\n{507022245462960}\n\n- **\"Singularity\" PvPvE mode:** Face off against up to 11 other players in this online competitive mode. Forge uneasy alliances as you navigate an ever-shrinking maze. Gather as much loot as you can, but get too greedy and you may not make it out at all\u2026\n\n{1888508874972980} ", "short_description": "A lone wanderer on the edge of space, a mystery as old as the universe itself, and one little robot who just wants to make the tea.\n\nInto Black is a First-Person action adventure that takes you into the depths of a mysterious alien planet. Explore the endless darkness, mine valuable resources, and fight off deadly alien beasts as you try to repair your ship and escape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://thebinarymill.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "The Binary Mill", "support_website_url": "https://thebinarymill.zendesk.com/hc/en-us", "website_url": "https://www.thebinarymill.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "8654657684594183"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295292_796281469314286_6466220068730746066_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pFfEsBCdpEUQ7kNvgGzHkTk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyywJ1WeTsIH3KHSanHzMx-_neQhb7Jo_KkmSfbb8bAA&oe=671B7D80"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Into Black", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1728579600, "lastRevision": {"nodes": [{"id": "5186140534775308", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"