/v/t64.5771-25/38984462_116368243719529_6207788087315804527_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzsU9eiud5gQ7kNvgFvpnuq&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCT94-1XDA3vV_P3LJ2yTe0TxqrYy6w7ZbOQbDQB3Ui9A&oe=6758228C"}, {"file_name": "PB_SS_5.png", "id": "228193502187597", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57568674_228193505520930_3731636703315603604_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q7gI8p8C_tAQ7kNvgG17U-i&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAMCyXpaYETe4luUmT5QtxItrrWReSuVaQ75h4Hn-sSWw&oe=67584288"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pacebreaker Beta", "keywords": [], "long_description": "FEATURES:\n- 4-Player Co-op multiplayer\n- Intuitive gameplay that's easy to pick up, effortless to continue\n- Testing game for AI-Perfected Exercise, and lab-based fitness ideas\n- Ongoing development by the VR Health Institute\n- Full featured demo (until out of Alpha and Beta development)\n\nPacebreaker is developed by the VR Health Institute & our sister org, The Healthy Empire. Pacebreaker is our testing ground of our next-gen exercise concepts in VR. Help us test A.I. Perfected & Responsive Exercise, gameplay that changes on the fly for optimized, less-sucky exercise.\n\nPacebreaker is made by a small team of students, developers, researchers, and other people that love the possibility of exercise in VR and AR. Come help us build the (someday) most advanced demonstration of the potential of AI, VR, and AR combined.\n\nNote: This is a full-featured demo of Pacebreaker, freely available during public testing of the game.", "short_description": "VR is not just fun exercise. It's the first exercise equipment capable of meaningful bio-feedback that's useful for someone trying to stay healthy, painlessly. Pacebreaker: An Experiment in A.I.-Perfected Exercise is the VR Health Institute's testing ground for research-based next-gen exercise in VR.\n\nNote: This is a full-featured demo of Pacebreaker, freely available until we leave alpha & beta development of the game."}]}, "developer_name": "VR Health Institute / The Healthy Empire", "developer_privacy_policy_url": "http://alvios.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Alvios, Inc.", "support_website_url": null, "website_url": "https://vrhealth.institute/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "425330489341245"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974806_371309661460078_2376015038392975801_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fMhZolNwYAMQ7kNvgEWoSpb&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAkV72P4c8FVVC8EOlzMSmZ_wFza0AVIN5Dl-TLTiAh6A&oe=67582D30"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pacebreaker Beta", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "release_date": 1619458445, "lastRevision": {"nodes": [{"id": "5331001686924952", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "437