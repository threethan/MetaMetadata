ng", "id": "371309658126745", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974806_371309661460078_2376015038392975801_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zab0UrDDkdMQ7kNvgF_Ru3I&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYC49JP6OPpOx4q_kcOnYYewolGUII6VF6GbhaV8joht1Q&oe=670BB630"}, {"file_name": "Cover-Portrait.png", "id": "329568308591427", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974808_329568311924760_8736278824275669674_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BxGENho8ipQQ7kNvgE71fqQ&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBHKyAU-P3FCAMT98aXoVrsD-G-6A12sPpt38d-f1PyRQ&oe=670BB741"}]}, "id": "1099569480805558", "locale": "en_US", "screenshots": [{"file_name": "PB_SS_1.png", "id": "239119281156972", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974891_239119284490305_2665879685669064449_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mitbxdKsNu0Q7kNvgF6Bunb&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAnMgfH6bYYJJYIJcODLSZ7dCLdczJSA7TVytjp86xt9w&oe=670BBF54"}, {"file_name": "PB_SS_2.png", "id": "424014872017903", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75422374_424014875351236_7819920644855449800_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4af2Dt3VMUgQ7kNvgFnGa-d&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCo1Dq3qxg_ogzYpH_upKcDPr5Ai1KfgWPqNg85844bUQ&oe=670BB7F9"}, {"file_name": "PB_SS_3.png", "id": "1388534484815640", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75435285_1388534488148973_4466565987122987367_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L4f4F9INmYQQ7kNvgFmEcT5&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDkf28N71MKw6j1Fbg92_bG3GybRNuW8PhgPtegkEIlkg&oe=670BBE6F"}, {"file_name": "PB_SS_4.png", "id": "116368240386196", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38984462_116368243719529_6207788087315804527_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nP4m07QiMc4Q7kNvgEpN_fR&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCIYHm0GN7gKapBeBlGl1XJHebHALqA1_jbHUuQNygkOQ&oe=670BAB8C"}, {"file_name": "PB_SS_5.png", "id": "228193502187597", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57568674_228193505520930_3731636703315603604_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TGpX7HsIKj8Q7kNvgHabk3f&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBA6pJCRMMKVPLepP4JQSbGd8RDEt-Q-y79eQrrsrgvSA&oe=670BCB88"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pacebreaker Beta", "keywords": [], "long_description": "FEATURES:\n- 4-Player Co-op multiplayer\n- Intuitive gameplay that's easy to pick up, effortless to continue\n- Testing game for AI-Perfected Exercise, and lab-based fitness ideas\n- Ongoing development by the VR Health Institute\n- Full featured demo (until out of Alpha and Beta development)\n\nPacebreaker is developed by the VR Health Institute & our sister org, The Healthy Empire. Pacebreaker is our testing ground of our next-gen exercise concepts in VR. Help us test A.I. Perfected & Responsive Exercise, gameplay that changes on the fly for optimized, less-sucky exercise.\n\nPacebreaker is made by a small team of students, developers, researchers, and other people that love the possibility of exercise in VR and AR. Come help us build the (someday) most advanced demonstration of the potential of AI, VR, and AR combined.\n\nNote: This is a full-featured demo of Pacebreaker, freely available during public testing of the game.", "short_description": "VR is not just fun exercise. It's the first exercise equipment capable of meaningful bio-feedback that's useful for someone trying to stay healthy, painlessly. Pacebreaker: An Experiment in A.I.-Perfected Exercise is the VR Health Institute's testing ground for research-based next-gen exercise in VR.\n\nNote: This is a full-featured demo of Pacebreaker, freely available until we leave alpha & beta development of the game."}]}, "developer_name": "VR Health Institute / The Healthy Empire", "developer_privacy_policy_url": "http://alvios.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Alvios, Inc.", "support_website_url": null, "website_url": "https://vrhealth.institute/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "425330489341245"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974806_371309661460078_2376015038392975801_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zab0UrDDkdMQ7kNvgF_Ru3I&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBw54rBHB8k8IQBF897al7AMZyX_nGSqA0VDNDPHF89hQ&oe=670BB630"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pacebreaker Beta", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1619458445, "lastRevision": {"nodes": [{"id": "5331001686924952", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4371208409572886", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "134316375205411"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_na