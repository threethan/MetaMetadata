content-lhr6-2.oculuscdn.com/v/t64.5771-25/39031573_278773211779643_8335208640497279867_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TP04Dx_ZeZMQ7kNvgGcxjRh&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBObFK7MjrWHVLU3MzToFL4GibGokPforXu0X2asrh8Kg&oe=671252C1"}, "display_name": "Lone Echo", "keywords": ["Lone", "Echo"], "long_description": "The Lone Echo edition you are using is being streamed from Meta's Cloud, which is currently undergoing Beta testing. In Lone Echo\u2019s single player story, you\u2019ll be transported to an advanced mining facility within the rings of Saturn, complete with a detailed space station, expansive outer-space environments, and interactive space equipment. Taking on the role of Jack\u2014an advanced artificial intelligence with a state-of-the-art synthetic body\u2014you\u2019ll help Captain Olivia Rhodes solve an increasingly threatening mystery as you use futuristic tools, clever problem solving, and interactive dialogue to engage with the world around you. Taking advantage of the Oculus Quest controllers and full 360\u00b0 gameplay, Lone Echo lets you take a hands-on approach to exploring space unlike anything you\u2019ve ever played before.", "short_description": "The Lone Echo edition you are using is being streamed from Meta's Cloud, which is currently undergoing Beta testing. In Lone Echo\u2019s single player story, you\u2019ll be transported to an advanced mining facility within the rings of Saturn, complete with a detailed space station, expansive outer-space environments, and interactive space equipment."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.meta.com/legal/quest/games-terms-of-service/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "https://www.oculus.com/lone-echo", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": 