3-1.oculuscdn.com&oh=00_AYA4n5jw0LV6vBbLK2pMdZdrnVuwxxSgR7Pct2oQM_RD3Q&oe=67751A0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "1208089050237971", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031574_1208089053571304_6140142419520203578_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tmYHzP1MtFEQ7kNvgGS76Cf&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCCZdkpYOgu6JW2Cn768pSW6kC3BYwwgQmLCJ3kDVCfSQ&oe=67750FFB"}, "display_name": "Induction Motors training", "keywords": [], "long_description": "Induction Motors Training is an educational app designed to teach students the fundamentals of induction motors and advanced fault diagnosis techniques. Through interactive simulations, users learn to identify faults in induction motors using Motor Current Signature Analysis (MCSA) and thermography for detecting issues in kinematic chains. This tool allows students to grasp the basic principles of motors, practice diagnostic techniques in a safe environment, and apply their knowledge in virtual lab scenarios, enhancing their ability to diagnose and troubleshoot real-world problems.", "short_description": "This simulator allows students Induction motor basics training, MCSA to detect faults in induction motors and Thermography for the detection of faults in kinematic chains"}]}, "developer_name": "XRAI Lab", "developer_privacy_policy_url": "https://xrailab.es/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRAI Lab", "support_website_url": null, "website_url": "https://xrailab.es/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null,