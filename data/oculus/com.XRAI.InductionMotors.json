42419520203578_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fgj55RgO0P0Q7kNvgH7dmhF&_nc_ht=scontent.oculuscdn.com&oh=00_AYArnU6o26bs5FP1T9Ls7d71qBpVDljkzR4flM12mBWECg&oe=66F7D17B"}, "display_name": "Induction Motors training", "keywords": [], "long_description": "Induction Motors Training is an educational app designed to teach students the fundamentals of induction motors and advanced fault diagnosis techniques. Through interactive simulations, users learn to identify faults in induction motors using Motor Current Signature Analysis (MCSA) and thermography for detecting issues in kinematic chains. This tool allows students to grasp the basic principles of motors, practice diagnostic techniques in a safe environment, and apply their knowledge in virtual lab scenarios, enhancing their ability to diagnose and troubleshoot real-world problems.", "short_description": "This simulator allows students Induction motor basics training, MCSA to detect faults in induction motors and Thermography for the detection of faults in kinematic chains"}]}, "developer_name": "XRAI Lab", "developer_privacy_policy_url": "https://xrailab.es/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRAI Lab", "support_website_url": null, "website_url": "https://xrailab.es/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2692554303