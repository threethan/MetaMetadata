_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KpzsjxoVnUYQ7kNvgH0SX8Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASk8oZbrMjngHEIeykg5nHB&oh=00_AYDJCi7VsVb7T2V0DwgKqlONSAF6JmyEFsJ1hT99WWov4A&oe=66E95B0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "1208089050237971", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031574_1208089053571304_6140142419520203578_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9uB60rd3pvgQ7kNvgFcC0wf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASk8oZbrMjngHEIeykg5nHB&oh=00_AYD0IyvY_Aab4Ymj2VMF2K5kHJd2hNAg-PA26ueZ7zUS_g&oe=66E950FB"}, "display_name": "Induction Motors training", "keywords": [], "long_description": "Induction Motors Training is an educational app designed to teach students the fundamentals of induction motors and advanced fault diagnosis techniques. Through interactive simulations, users learn to identify faults in induction motors using Motor Current Signature Analysis (MCSA) and thermography for detecting issues in kinematic chains. This tool allows students to grasp the basic principles of motors, practice diagnostic techniques in a safe environment, and apply their knowledge in virtual lab scenarios, enhancing their ability to diagnose and troubleshoot real-world problems.", "short_description": "This simulator allows students Induction motor basics training, MCSA to detect faults in induction motors and Thermography for the detection of faults in kinematic chains"}]}, "developer_name": "XRAI Lab", "developer_privacy_policy_url": "https://xrailab.es/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRAI Lab", "support_website_url": null, "website_url": "https://xrailab.es/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "in