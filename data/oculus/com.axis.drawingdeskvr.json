B173"}, {"file_name": "screenshot_4.png", "id": "444852107397367", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_444852110730700_6974583543637001144_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rql6LP5ae6gQ7kNvgE4AltE&_nc_ht=scontent.oculuscdn.com&oh=00_AYBD63hvV3kSyCR6-pgWE1o0aBbyzk-GPkt9TlzVsyN9Hg&oe=66CDC943"}, {"file_name": "screenshot_6.png", "id": "1504143956654379", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035360_1504143959987712_6275816449024562344_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2XYAfZYHn0Q7kNvgFSAtT4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsbqjan9DUxCK5OQ-bzGEgvKlZMpz3ubbRe8VR1xIqEg&oe=66CDB79B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "641266307090675", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_641266310424008_5319154705626428011_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pnvEZYmgIPwQ7kNvgFnQ8m8&_nc_ht=scontent.oculuscdn.com&oh=00_AYATVo8A123VOcHPjMUjLVY3ZL39CRgu9vBs2uTIKEbGsg&oe=66CDCAF0"}, "display_name": "Drawing Desk", "keywords": [], "long_description": "Escape into an immersive art portal with Drawing Desk VR. Capture your imagination in 2D painting and 3D coloring in the heart of a beautiful world designed to perk your creativity. \n\nHand in hand with a wand and palette, roam around and unveil the lands of your coloring realm. Whisk away colors of solid and gradient to liven up your surroundings. Grab, scale and change the position of objects in your landscape environment. \n\nTogether with the wonders of soundscapes, experience a realistic drawing experience like no other. Express your artistry with a beautiful color wheel and a pack of flawless creation tools - spray, marker, pencil, pen, watercolor, eraser. Teleport yourself to any expansive scene in your art space in a matter of seconds. \n\nTraverse, explore and discover your artistic talents in a hypnotising space dedicated especially for you! Come, draw, color and paint to experience it all in one world of art!", "short_description": "Step into a timeless artspace with Drawing Desk VR.\n\nSubmerge in bursts of your creativity in an immersive world of art and color. Live in the heart of a coloring book. Or create lively art in your very own digital space. \n\nBringing you closer to the canvas with realistic soundscapes, create 2D paintings with a beautiful color wheel and a feature-rich tool kit.\n\nWith a palette and wand in hand, walk around in a 3D coloring realm. Express yourself with a unique blend of gradient and solid colors."}]}, "developer_name": null, "developer_privacy_policy_url": "https://4axissolutions.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "4Axis", "support_website_url": null, "website_url": "https://drawingdesk.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "324759356351524"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "25361436733471573"}, {"status": "PUBLISHED", "id": "3428074274082478"}, {"status": "PUBLISHED", "id": "933172697913292"}, {"status": "PUBLISHED", "id": "888412216072063"}, {"status": "PUBLISHED", "id": "686894239432736"}]}, "baseline_offer": {"id": "25361436733471573"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1713996720, "status": "PUBLISHED", "id": "25361436733471573"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_re