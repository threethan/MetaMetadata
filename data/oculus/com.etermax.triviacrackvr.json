796_4372001089709259594_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Cz1oxtH-A0Q7kNvgG47xcf&_nc_ht=scontent.oculuscdn.com&oh=00_AYBi204JzBmME46cvgFXonr9q0ZhHCagGtyTKV2PzUR9PQ&oe=66F7DBF9"}, {"file_name": "Screenshot_04.png", "id": "246168094945182", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_246168098278515_6834420738412965333_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uw5JLfEM5coQ7kNvgGslaZw&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6cOx5bLbUHdt4eumjsnK6PArRFZW09VWer4m1wXoMBg&oe=66F7DAB9"}, {"file_name": "Screenshot_05.png", "id": "110879318744142", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031579_110879322077475_4403889434671879300_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PnFCfr7OnR8Q7kNvgHdIXUu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAE_POREYSrgsUwXOVT1TDYv0r-QBlK60_fUxUQpzgvA&oe=66F7F6F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "9770455516361619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003247_9770455523028285_4235187193067408494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I52FauiYxxcQ7kNvgELEhwr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEnf90i9BoDE-FjreRyRFrp6x12d0_JI4CwwjlxUYbxw&oe=66F7E744"}, "display_name": "Trivia Crack VR", "keywords": [], "long_description": "Welcome to Trivia Crack VR! \n\nTrivia Crack VR is a virtual amusement park, built by Willy to share his knowledge with the world across different dimensions. He is accompanied by his friends Tito, Hector, Tina, Albert, Pop, and Bonzo, that help him manage the park.\n\nThis is a place full of fun and curiosity, where you can share your knowledge with others and prove that you are worthy of becoming the future director of the park. You'll be able to compete in trivia matches and mini-games with people from all around the world or play on your own and beat your own high scores.\n\nAnswer questions as fast as you can, remove obstacles, and block your opponents' path. To win, you'll need wit, precision, and speed!\n\nSoon, you'll be able to earn tickets and coins in each match and exchange them for special prizes to customize your appearance and your own section of the park.\n\nAlso, the park is expanding! Don't miss out on the upcoming news: the opening of new sections to explore, new game modes, and more fun accessories.\n\nCome and be a part of the adventures in Trivia Crack VR!\n", "short_description": "Trivia Crack VR is a unique and immersive experience, where you can play with others or by yourself in exciting matches that combine trivia and fun mini games. Compete, meet new people, and let your curiosity reign!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.etermax.com/privacy/", "developer_terms_of_service_url": "https://www.etermax.com/terms/", "publisher_name": "Etermax", "support_website_url": "https://www.etermax.com/support/", "website_url": "https://triviacrack.com/trivia-crack-vr", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "879473995923081"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "224056987275389"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "3494846444137752"}, {"status": "PUBLISHED", "id": "1158560025581431"}, {"status": "PUBLISHED", "id": "567418578772227"}]}, "baseline_offer": {"id": "1158560025581431"}, "is_approved": true, "firstOffer": {"nodes": [{"start