657549150592_9084133421503538669_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KMRIyP7dAZsQ7kNvgH0kFRx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBoFzF8ycnCV_rUHQh0FTZNy5ddduBIM5t-jDS5norZAQ&oe=67727BAE"}, {"file_name": "screenshot5.png", "id": "894905578797895", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75269157_894905582131228_448450545322347244_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E8bTJV630-EQ7kNvgFyNOp_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDjfVC4OdRJkmDSc6UN7Rw9gM7M8lWdUsXt2xaZf5p2xQ&oe=67727D4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FirstFrame.png", "id": "347211281466264", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982708_347211284799597_2383655566166517173_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gEduUJuqpOoQ7kNvgGHcpU0&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAzTVFr0oIji9XcpGnHhyiHieX2mV54aRw4gbDkUJl8-w&oe=67729A86"}, "display_name": "TableBall", "keywords": [], "long_description": "TableBall is a physical therapy game specifically designed for arm-hand training during brain injury rehabilitation. With a quick setup, the patient can enjoy an understandable and easy to learn game, while unconsciously training. \n\nTableBall makes use of a complex set of parameters constantly tweaked based on the performance of the player. With these parameters the game is able to assess the capabilities of the player and change gameplay accordingly. Thus making sure each player is training on their own level.\n\n**(!) Tableball is part of the HoloMoves rehabilitation package. This package includes many games for physical rehabilitation. Get a personal license and learn more at www.holomoves.nl/en**\n", "short_description": "TableBall is a physical therapy game specifically designed for arm-hand training during brain injury rehabilitation. With a quick setup, the patient can enjoy an understandable and easy to learn game, while unconsciously training. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://holomoves.nl/en/privacy/", "developer_terms_of_service_url": null, "publisher_name": "HoloMoves B.V.", "support_website_url": null, "website_url": "https://holomoves.nl/en/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl", "nl_BE"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8666990460046423"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974521_976582714074080_1356851658336440168_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GMJaypgwdOgQ7kNvgEhnVDN&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBkD-VmQApuIl-dRUv2LQNC1WiTTLbV0OlWPHz87bFu8A&oe=67728B6F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TableBall", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Medical", "id": "478089301798119"}], "release_date": 1708964700, "lastRevision": {"nodes": [{"id": "7123283704417114", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7123283674417117", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DO