657549150592_9084133421503538669_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fwk8aJzgsAoQ7kNvgHxKglb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChjVFemBcMQloHOZsZq4f-XJopfafwcm6ApwtocLTAqg&oe=677FAAAE"}, {"file_name": "screenshot5.png", "id": "894905578797895", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269157_894905582131228_448450545322347244_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-e9NaAuurO4Q7kNvgHVqhWd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAq9uy3NXNTOEsOhroV66g3_o12i-ZnTBI8MS_188LNjw&oe=677FAC4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FirstFrame.png", "id": "347211281466264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982708_347211284799597_2383655566166517173_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bd_T53DzW1cQ7kNvgEqLtyu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABJ8mQ5t1tjOB8PKHweAoAvOa00x_D10tsku0gzAn4RA&oe=677FC986"}, "display_name": "TableBall", "keywords": [], "long_description": "TableBall is a physical therapy game specifically designed for arm-hand training during brain injury rehabilitation. With a quick setup, the patient can enjoy an understandable and easy to learn game, while unconsciously training. \n\nTableBall makes use of a complex set of parameters constantly tweaked based on the performance of the player. With these parameters the game is able to assess the capabilities of the player and change gameplay accordingly. Thus making sure each player is training on their own level.\n\n**(!) Tableball is part of the HoloMoves rehabilitation package. This package includes many games for physical rehabilitation. Get a personal license and learn more at www.holomoves.nl/en**\n", "short_description": "TableBall is a physical therapy game specifically designed for arm-hand training during brain injury rehabilitation. With a quick setup, the patient can enjoy an understandable and easy to learn game, while unconsciously training. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://holomoves.nl/en/privacy/", "developer_terms_of_service_url": null, "publisher_name": "HoloMoves B.V.", "support_website_url": null, "website_url": "https://holomoves.nl/en/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nl", "nl_BE"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8666990460046423"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974521_976582714074080_1356851658336440168_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfXylUJ28sUQ7kNvgHs_q9J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDcLPG0CdzAdSb9uZ3S0TMb8We41taUwdhLKhd06g0aQ&oe=677FBA6F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TableBall", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Medical", "id": "478089301798119"}], "release_date": 1708964700, "lastRevision": {"nodes": [{"id": "7123283704417114", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7123283674417117", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DO