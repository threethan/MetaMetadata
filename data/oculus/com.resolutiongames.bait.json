13", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12138833_432446190298708_515750356_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hr_VfEl86IkQ7kNvgFE6LcT&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBYvuQPy9lB0hiP9LAZfpqBqz3sFIswq1NTl5I6ikYuNg&oe=67348250"}, {"file_name": "migrated_image.png", "id": "203490957550276", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12138836_1541982866102630_1346682544_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yb9ep2I84z4Q7kNvgHrqTMT&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD_jAEqSnD8FTtfY0_3tUnfVFpkRq6FshYn8VCsxXY51g&oe=67349A73"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Bait!", "keywords": ["collect", "explore", "fish", "fishing", "free", "game", "games", "lake", "ocean", "top"], "long_description": "Join the more than 3 million players who already enjoy Bait! \n\n\u201cIt\u2019s definitely the next game I\u2019m getting my mom to try.\u201d - The Verge\n\n\u201cIt\u2019s amazing. Bait! had an almost instantaneous relaxation effect. Once you get started and cast your first line, everything else in life disappears and you\u2019re truly in the moment \u2013 I bet my pulse even went down.\u201d - Maarten Noyons, founder of IMGA \n\n\u201cBait! is one of those pleasant games for everyone.\u201d - VRScout\n\nYou\u2019re invited to Bait! Island to help your boss catch a rare fish, and thereby save the struggling aquarium where you work.\n\nDuring the game, you will catch a lot of different fish and make friends with the locals. But, will you be able to keep your loyalties both to your new friends and to your boss?\n\nGameplay spans four different lakes, each with a distinct style and its own unique set of fishes. Can you catch them all?", "short_description": "Join the more than 3 million players who already enjoy Bait! \n\n\u201cBait! is one of those pleasant games for everyone.\u201d - VRScout\n\nYou\u2019re invited to Bait! Island to help your boss catch a rare fish, and thereby save the struggling aquarium where you work.\n\nDuring the game, you will catch a lot of different fish and make friends with the locals. But, will you be able to keep your loyalties both to your new friends and to your boss?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.resolutiongames.com/privacy", "developer_terms_of_service_url": "http://www.resolutiongames.com/", "publisher_name": "Resolution Games", "support_website_url": "https://www.resolutiongames.com/support", "website_url": "http://www.resolutiongames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "fr", "fr_BE", "fr_CA", "de_CH", "it", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE", "zh_CN"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "682040769699775"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12504696_209349959527778_6345410856641101824_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XmCWg_4xr_AQ7kNvgEh9xBL&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCCHrPnKKvHUAfTXwt7JRTTU75FNT_j1fL6SMrfuLzX4Q&oe=67347BE0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bait!", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1458716400, "lastRevision": {"nodes": [{"id": "1015094841895645", "release_type": "SCH