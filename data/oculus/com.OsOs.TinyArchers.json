8557027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575362_1456537571890360_4996879409752074773_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VK4sMwxiomIQ7kNvgGJMTkA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVq0GVq1pph0neR3sGmT6JWnX8KiJiSc54GdliWczrpg&oe=674D8CFB"}, {"file_name": "01424.png", "id": "1059963221832099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210389_1059963228498765_5304813755297612496_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nRwiiZ42lfgQ7kNvgGJxAUs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAZqkvtPfq8CU6DC8pDDoQ6MCgWCDMqMjpXzeXg5tfyfg&oe=674D84E1"}, {"file_name": "01210.png", "id": "865760981778040", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974893_865760985111373_2389712068106132522_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F0lFvBmNjvEQ7kNvgF6xWeF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXTfQySSdCFwxhMo2RkhQ-eElzPEFnJKOXhROM9kSg3w&oe=674D923A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Tiny Archers \u2013 EARLY ACCESS", "keywords": [], "long_description": "WAR IS COMING!\n\nDraw your bow and defend the Northern Kingdom in this immersive VR tower defense archery game! Step into the role of the realm's finest archer as you face waves of attacks from cunning goblins and ruthless orcs.\n\nKey Features:\n* Engage in epic battles across diverse landscapes during a 24-day onslaught.\n* Defend your land with precision in a 360-degree battlefield as enemies close in from all directions.\n* Face a wide range of foes, from nimble scouts to heavily armored goblins, skilled archers and explosive kamikaze warriors.\n* Immerse yourself in a gripping adventure complete with a compelling storyline and engaging side quests. (Note: Side Quest are not present in the EARLY ACCESS version.)\n* Strategize and prioritize targets to maximize your score with an advanced scoring system.\n* Hone your archery skills with a range of bows and craft special arrows.\n* Compete for glory on the leaderboards and conquer the challenging HARD mode campaign.\n* Collect achievements as you progress and showcase your mastery as a sharpshooter.\n* Engage in the LAST STAND mode for an ongoing challenge with never-ending waves of enemies.\n\nJoin the Community:\nShare your feedback, be part of the ongoing evolution of this thrilling VR tower defense bow and arrow adventure. We continuously enhance the game, incorporating user suggestions and adding exciting new features!", "short_description": "WAR IS COMING!\n\nDraw your bow and defend the Northern Kingdom in this immersive VR tower defense archery game! Step into the role of the realm's finest archer as you face waves of attacks from cunning goblins and ruthless orcs. Test your skills, compete on leaderboards, and be part of the evolving VR tower defense community!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.1der-ent.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "1DER Entertainment s.r.o.", "support_website_url": null, "website_url": "http://www.1der-ent.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6251986228236846"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "106