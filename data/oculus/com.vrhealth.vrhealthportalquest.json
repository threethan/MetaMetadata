t=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB-F4DIAIHN3zZ5PFvKUJakllkTH5XUHIQHRc3--2aUBQ&oe=6786351C"}, {"file_name": "image (12) (1).png", "id": "350524578108373", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57570314_350524581441706_6483345684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2s_lnJqFn3MQ7kNvgHJW08N&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCgPfjdfNA4wd-uaVtfJgRfpU0RxnU0VlCrYi15eO2Wfw&oe=67864124"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3P6bhYFvdyoQ7kNvgGA7Vqj&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAb5WAZ_mVjbfNqwW6RFaGKlmVvtDVQk8FKosHPqvrFaw&oe=67864826"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": ["XRHealth", "Physical", "Therapy", "Cognitive", "Health"], "long_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy.\n\nXRHealth offers an engaging way to participate in physical and occupational therapy sessions, allowing you to explore virtual therapeutic environments under the guidance of your therapist. \n\nHere\u2019s how XRHealth works in 3 simple steps: \n\nStep 1: Sign up, tell us a little about what you\u2019re going through. We\u2019ll match you with a licensed clinician. \n\nStep 2: Meet your therapist in a live, online video appointment. Your therapist will conduct a clinical assessment and create a customized care plan.  \n\nStep 3: Feel better! Show up to your telehealth appointments and complete your therapy sessions with the VR Telehealth Kit.  \n\nSign up at: https://xrhealth-us.clientsecure.me/ ", "short_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy."}]}, "developer_name": "XRHealth", "developer_privacy_policy_url": "https://www.xr.healt