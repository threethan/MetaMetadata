24867628212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yVZJUBlvbJMQ7kNvgEgLl-I&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0CLcPSl-3Ttisv4gTPs8Su&oh=00_AYA3aMiLRpIKvuRw5VPec0Phyky7tyCktWlvrGA41DIQNw&oe=66DEC69C"}, {"file_name": "image (12) (1).png", "id": "350524578108373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570314_350524581441706_6483345684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kMvhZc4ZAXEQ7kNvgGK_ctn&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0CLcPSl-3Ttisv4gTPs8Su&oh=00_AYDEYP1UwzhDrFWWlyxNpESTHLQTUFjv5hi_2GayAFyCAw&oe=66DED2A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5TLj5tu2NZAQ7kNvgGJEXce&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0CLcPSl-3Ttisv4gTPs8Su&oh=00_AYAQg1HhMmDZrj2aHHWkCno-sGIi52HDYSc7h9IHqU91lA&oe=66DED9A6"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": [], "long_description": "Discover the XRHealth Physical & Cognitive Space, a VR platform designed to boost physical and cognitive well-being through immersive exercises. \n\nFor patients, this app allows you to actively participate in therapy, exploring virtual environments and activities alongside your therapist, whether you're meeting in person or remotely. \n\nWhile using the applications, performance data is collected and analyzed, providing the user with performance insights for progress tracking.  \n\nProviders can track and share progress data with patients, enabling more personalized and effective treatment plans. This allows clinicians and patients to review improvements and adjust therapies as needed.\n", "short_description": "Discover the XRHealth Physical & Cognitive Space, a VR platform designed to boost physical and cognitive well-being through immersive exercises. "}]}, "developer_name": "XRHealth", "developer_privacy_policy