&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDlxrO1umcG9QHJOpZLy_TdMzFB9C6_UxwtzgTSUQB70g&oe=67289A9C"}, {"file_name": "image (12) (1).png", "id": "350524578108373", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/57570314_350524581441706_6483345684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sq0vLSA8HvEQ7kNvgGOpjYv&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCSlSXIYXow9J8SeTdH2zHd0xbpD1r4h8Mv15pnWlKTQg&oe=6728A6A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOaeUXn8MEoQ7kNvgEidUmU&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYC-Q-4aEa4r14kZT9bfFrA4qortJAKKua-HeYoPxoa9zw&oe=6728ADA6"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": ["XRHealth", "Physical", "Therapy", "Cognitive", "Health"], "long_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy.\n\nXRHealth offers an engaging way to participate in physical and occupational therapy sessions, allowing you to explore virtual therapeutic environments under the guidance of your therapist. \n\nHere\u2019s how XRHealth works in 3 simple steps: \n\nStep 1: Sign up, tell us a little about what you\u2019re going through. We\u2019ll match you with a licensed clinician. \n\nStep 2: Meet your therapist in a live, online video appointment. Your therapist will conduct a clinical assessment and create a customized care plan.  \n\nStep 3: Feel better! Show up to your telehealth appointments and complete your therapy sessions with the VR Telehealth Kit.  \n\nSign up at: https://xrhealth-us.clientsecure.me/ ", "short_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy."}]}, "developer_name": "XRHealth", "developer_privacy_policy_url": "https://www.xr.health/vrhealth-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRHealth", "support_website_url": null, "website_url": "https://www.xr.health/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9112262868805749"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974686_8039043819489888_5094951920229160663_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YH9y1VOusqwQ7kNvgGbfsZI&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAr0hyK2eKN7IitCUgU4Mutvdr7prA_8p7L0Wr6JZBg3A&oe=6728B689"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "XRHealth Physical & Cognitive Space", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}, {"topic_name": "Medical", "id": "478089301798119"}], "release_date": 1723798732, "lastRevision": {"nodes": [{"id": "8713830141982359", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8713830088649031", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "2830284