45684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZ_YDWU275sQ7kNvgHyaR0O&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaA2pjkm_F36w56hkEqIU_6S5ZZxFW6JU1jd4pTlZ6hA&oe=66F68DA4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRf2252_c3sQ7kNvgFfTQz9&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5MtHyq6_rjR3vwvbq5JVeWrm223xOwK5BoIHpo_nKkA&oe=66F694A6"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": [], "long_description": "XRHealth Mental Health Space is a virtual reality platform for physical therapy.  \n\nXRHealth offers an engaging way to participate in physical and occupational therapy sessions, allowing you to explore virtual therapeutic environments under the guidance of your therapist. \n\nHere\u2019s how XRHealth works in 3 simple steps: \n\nStep 1: Sign up, tell us a little about what you\u2019re going through. We\u2019ll match you with a licensed clinician. \n\nStep 2: Meet your therapist in a live, online video appointment. Your therapist will conduct a clinical assessment and create a customized care plan.  \n\nStep 3: Feel better! Show up to your telehealth appointments and complete your therapy sessions with the VR Telehealth Kit.  \n\nSign up at: https://xrhealth-us.clientsecure.me/ ", "short_description": "XRHealth Mental Health Space is a virtual reality platform for physical therapy. "}]}, "developer_name": "XRHealth", "developer_privacy_policy_url": "https://www.xr.health/vrhealth-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRHealth", "support_website_url": null, "website_url": "https://www.xr.health/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "336254229044964