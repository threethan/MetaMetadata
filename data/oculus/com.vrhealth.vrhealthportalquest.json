6_6483345684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n1byCQh2BoEQ7kNvgHytQTO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBz4MpnauJO5ODksRkqFw2hF-YXSALi8xTfLV6lpZ4_bg&oe=66D6E9A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SBQX4ZEJt_cQ7kNvgEAPHoG&_nc_ht=scontent.oculuscdn.com&oh=00_AYC50FD_vIf-ZbI89HsEBNdteY7s4P18Yf9jd-BC7-8Bdw&oe=66D6F0A6"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": [], "long_description": "Discover the XRHealth Physical & Cognitive Space, a VR platform designed to boost physical and cognitive well-being through immersive exercises. \n\nFor patients, this app allows you to actively participate in therapy, exploring virtual environments and activities alongside your therapist, whether you're meeting in person or remotely. \n\nWhile using the applications, performance data is collected and analyzed, providing the user with performance insights for progress tracking.  \n\nProviders can track and share progress data with patients, enabling more personalized and effective treatment plans. This allows clinicians and patients to review improvements and adjust therapies as needed.\n", "short_description": "Discover the XRHealth Physical & Cognitive Space, a VR platform designed to boost physical and cognitive well-being through immersive exercises. "}]}, "developer_name": "XRHealth", "developer_privacy_policy_url": "https://www.xr.health/vrhealth-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "XRHealth", "support_website_url": null, "website_url": "https://www.xr.health/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "106712669