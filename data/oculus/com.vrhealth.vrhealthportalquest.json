t=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC46tBkoCiKmugtQ09eKgsyDPG-v16CQM9opGVxrUR6Hw&oe=674AE19C"}, {"file_name": "image (12) (1).png", "id": "350524578108373", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570314_350524581441706_6483345684963408915_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gYVs3iyR77QQ7kNvgHgvyS5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBygPJ1lxnX-8iDWPAGW_p3XylUgErjj4Pv8tCk3yB5QQ&oe=674AEDA4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main.png", "id": "497977659842667", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982544_497977663176000_8757830213700921902_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kCekY2iTHkAQ7kNvgHLI4X5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwuOR3vDBb115FKKmrgmcGI-kEoaEsJ-DIswMOntf4gA&oe=674AF4A6"}, "display_name": "XRHealth Physical & Cognitive Space", "keywords": ["XRHealth", "Physical", "Therapy", "Cognitive", "Health"], "long_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy.\n\nXRHealth offers an engaging way to participate in physical and occupational therapy sessions, allowing you to explore virtual therapeutic environments under the guidance of your therapist. \n\nHere\u2019s how XRHealth works in 3 simple steps: \n\nStep 1: Sign up, tell us a little about what you\u2019re going through. We\u2019ll match you with a licensed clinician. \n\nStep 2: Meet your therapist in a live, online video appointment. Your therapist will conduct a clinical assessment and create a customized care plan.  \n\nStep 3: Feel better! Show up to your telehealth appointments and complete your therapy sessions with the VR Telehealth Kit.  \n\nSign up at: https://xrhealth-us.clientsecure.me/ ", "short_description": "XRHealth Physical & Cognitive Space is a virtual reality platform for physical therapy."}]}, "developer_name": "XRHealth", "developer_privacy_policy_url": "https://www.xr.healt