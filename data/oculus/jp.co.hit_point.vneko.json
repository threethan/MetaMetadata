ontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974886_1016471292837864_6268008024192618569_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kuvcCPaedY4Q7kNvgET-E9Z&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBNp6s8FnROpZrHVvEEiDQHv2jPlJIgt5jxYDovTH40kA&oe=67025EDF"}, {"file_name": "ss05.png", "id": "734986471802140", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974919_734986475135473_4521351746943961456_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o3PVHd08tR4Q7kNvgEpnx-G&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC_dldg47OFMsEjhO3qZx60oy9C16_jD5a66WZ-AXOVfQ&oe=670287AB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss.png", "id": "1321452848730605", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38984460_1321452852063938_1545472134744314356_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcTWR_oE620Q7kNvgGbH3yE&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBBCF1Tgtm32FMmUpYXaoznUfOXOW6xNmisL10IzxHMew&oe=67026E75"}, "display_name": "Neko Atsume Purrfect", "keywords": ["NekoAtsume", "Cat", "animal", "Simulation", "Purrfect"], "long_description": "Get Closer to the World of Cats!\n\n\"Neko Atsume Purrfect\" is a simulation game featuring a whopping 46 different types of cats.\nIn this game, you can do more than just leisurely observe free-spirited cats; you can play with them using a cat teaser, stroke their bellies, and even pick them up for a cuddle.\nAt the delightful yard location, home to uniquely charming cats like \"Calico cat,\" \"Odd-eyed cat,\" and \"Big fat cat,\" you are sure to encounter your purrfect feline companion.\nEnjoy the uninterrupted \"Life with Cats\" to the fullest.", "short_description": "Get Closer to the World of Cats!\n\n\"Neko Atsume Purrfect\" is a simulation game featuring a whopping 46 different types of cats.\nIn this game, you can do more than just leisurely observe free-spirited cats; you can play with them using a cat teaser, stroke their bellies, and even pick them up for a cu