r": null, "video_trailer_thumbnail": {"file_name": "new thumbnil.png", "id": "3787550558157468", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003273_3787550561490801_325224082568552045_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dHuIa10dk2kQ7kNvgEDhLGV&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBy3DI2GpBshl1_bf_rAEWqw5kHTfLo00h4IDuhMX26Hg&oe=67178394"}, "display_name": "The Show VR", "keywords": ["theshowvr", "minigames", "multiplayer", "parkour", "freetoplay"], "long_description": "# Enter The World Of Multiplayer Minigames In VR!\n\nCompete with up to *15 other players & friends* across dozens of the best minigames!\n\n# Our Awesome Minigames - \n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n{1020597909744327}\n\n- **Last Runner**: Who will be the first to reach the end?\n{1545133332789034}\n\n- **Snowball Fight**: Join the snowball fight, but don't build a snowman!\n{559043966662664}\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n{522630213560941}\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course!\n{1187320605922214}\n\n- **Falling Stones**: The stones will floor under you, try not to fall.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n# Will you win the show?\n{488153610605539}\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!\n", "short_description": "Welcome to The Show VR, a unique multiplayer game that brings you and up to 15 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Kissi Studio", "support_website_url": null, "website_url": "https://www.theshowvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8169507083141182"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982638_2181564622230749_6575832927902026854_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YdNYa2vOapgQ7kNvgHzmpI_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrofj4-fN8-FrFOLDuzgqVD0sw4jz6WLyYg2luXHDQdQ&oe=67179BF0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Show VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1720720800, "lastRevision": {"nodes": [{"id": "7481234405301790", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"d