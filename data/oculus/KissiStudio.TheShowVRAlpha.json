d=6e7a0a&_nc_ohc=vC9YQqy9-6QQ7kNvgESfNn1&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3_dcVt5Ww-y_GYtDcyBt78eN7TPIbrvP3w1j5lJGj0g&oe=66EC1F50"}]}, "id": "1412110966130863", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "992212615987498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_992212619320831_803158597365582032_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kFcaivqag-YQ7kNvgHsdVbJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1YM1fzki50AW_qkYoM6YndmhPz6C0RLjDfwc85teYMQ&oe=66EC0561"}, {"file_name": "4.png", "id": "1959550141137742", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001733_1959550144471075_6422465095606848999_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=skSIvw3Y0e0Q7kNvgHCYZR2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkv3gLFKlj49LRqbnv00w2JxqGGzmkyKZ-E9JsxV1UKQ&oe=66EC293B"}, {"file_name": "2.png", "id": "395913140275951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_395913143609284_8071434360653314861_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yN09XFAicvIQ7kNvgHiZEf1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxDPnJgDm8WfcK-Q2HQRn5kPGrXOqmUigz5nD0vmBUAw&oe=66EC1F02"}, {"file_name": "applab screenshot.png", "id": "1726218227785230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612010_1726218231118563_5953171904919180739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DV5QvqWdfzQQ7kNvgFa-Q4S&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrTtj8ZDX7ez2-fma89hLv9NWSfNu9w4gFB8epKa4snw&oe=66EC060F"}, {"file_name": "applab screenshot3.png", "id": "983022023606598", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982619_983022030273264_4990515898292565542_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sq47TYyNWwYQ7kNvgFWmZx1&_nc_ht=scontent.oculuscdn.com&oh=00_AYC4Wd0Ll9urseBWGfTXS1lkXXrZkvaypY_gc6yUBH4xMg&oe=66EC079E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "applab cover art4.png", "id": "853878013362884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569460_853878016696217_3826144807804450217_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vmik0CMFPmcQ7kNvgG566zw&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAIXqME6tvMzeOXJMgx7O6Ny31uJz_k-z2-J9SiP6Fww&oe=66EBFF2C"}, "display_name": "The Show VR", "keywords": ["theshowvr", "minigames", "multiplayer", "parkour", "freetoplay"], "long_description": "# Enter the world of minigames in VR!\n\n*First of a kind multiplayer game that allows you to be part of The Show!*\n\n# Our Awesome Minigames - \n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n{1020597909744327}\n\n- **Last Runner**: Who will be the first to reach the end?\n{1545133332789034}\n\n- **Snowball Fight**: Join the snowball fight, but don't build a snowman!\n{559043966662664}\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n{522630213560941}\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course!\n{1187320605922214}\n\n- **Falling Stones**: The stones will floor under you, try not to fall.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n# Will you win the show?\n{488153610605539}\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!\n", "short_description": "Welcome to The Show VR, a unique multiplayer game that brings you and up to 15 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy"