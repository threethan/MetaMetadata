d=6e7a0a&_nc_ohc=k7HP58BkOHcQ7kNvgG_nfCX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCw37bECjz4ZFPdMd6ew_Q1KsaMfbz-DE8YKkkTp-1j8Q&oe=66FE9450"}]}, "id": "1412110966130863", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "992212615987498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_992212619320831_803158597365582032_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xmsO1tz6wuAQ7kNvgF__4Kp&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgaR4DXGfcgah1eKh3Wy-KRk78Rfd0lBpf0WYm3Ew2ng&oe=66FE7A61"}, {"file_name": "4.png", "id": "1959550141137742", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001733_1959550144471075_6422465095606848999_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kUvo7aiuck0Q7kNvgHMFCS6&_nc_ht=scontent.oculuscdn.com&oh=00_AYD6PfePkM5uXfiAJMKOZn4cB35NMqqj9_cRmikvHfRwWA&oe=66FE9E3B"}, {"file_name": "2.png", "id": "395913140275951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_395913143609284_8071434360653314861_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TepzoCkzZcgQ7kNvgHV1Vle&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgcOQ9gTDhoUjxafpUUqnC4KxNASkrrdGIj51PVZJ5NQ&oe=66FE9402"}, {"file_name": "applab screenshot.png", "id": "1726218227785230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75612010_1726218231118563_5953171904919180739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GSQx1S_fKBAQ7kNvgFUh7WO&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8IjUErI3_Q8uLT0_A0nLbdscOUm9o9jhSAkue9B3MTg&oe=66FE7B0F"}, {"file_name": "applab screenshot3.png", "id": "983022023606598", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982619_983022030273264_4990515898292565542_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=18WsOXcs6PcQ7kNvgE-MgbY&_nc_ht=scontent.oculuscdn.com&oh=00_AYChgPCO4mYnkjHeWC0FlYEnLq3DfZCUDyBiKVM-99ndIQ&oe=66FE7C9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "applab cover art4.png", "id": "853878013362884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569460_853878016696217_3826144807804450217_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h4NQUof_QokQ7kNvgEw-aVa&_nc_ht=scontent.oculuscdn.com&oh=00_AYBC3c5-Ihar_fDOxx4D43VKJPf59i9vbMaMHfxzMrIKYA&oe=66FE742C"}, "display_name": "The Show VR", "keywords": ["theshowvr", "minigames", "multiplayer", "parkour", "freetoplay"], "long_description": "# Enter the world of minigames in VR!\n\n*First of a kind multiplayer game that allows you to be part of The Show!*\n\n# Our Awesome Minigames - \n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n{1020597909744327}\n\n- **Last Runner**: Who will be the first to reach the end?\n{1545133332789034}\n\n- **Snowball Fight**: Join the snowball fight, but don't build a snowman!\n{559043966662664}\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n{522630213560941}\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course!\n{1187320605922214}\n\n- **Falling Stones**: The stones will floor under you, try not to fall.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n# Will you win the show?\n{488153610605539}\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!\n", "short_description": "Welcome to The Show VR, a unique multiplayer game that brings you and up to 15 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy"