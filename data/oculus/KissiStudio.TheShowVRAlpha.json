597365582032_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mcHfrTAROHsQ7kNvgGbFFbM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCxgInEIi2uUhrcP_RAmCoMrwRoHS0ru-Y0sVvsziKr0A&oe=67654F61"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Show Game New Logo.png", "id": "1248202016419665", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003266_1248202019752998_2048887004209505196_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xnzZU-9WF3YQ7kNvgF7tiJG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDDwrlYp1mR2o3iB8fJVusuu-hR6B5HUwKmsASdftipw&oe=67655606"}, "display_name": "Show Game", "keywords": ["minigames", "multiplayer", "freetoplay", "PartyGame", "ShowGame"], "long_description": "# FREE TO PLAY FULL RELEASE DOWNLOAD NOW!\n\nEnter the world Of **Multiplayer Minigames In VR!** compete with up to **14 other players & friends across** dozens of the best minigames!\n\nDefinitely not based on any online streaming pop culture korean tv shows, as that would get us in legal trouble, so we're certainly not doing that.\n\n# Our Awesome Minigames - \n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n{3740688119514556}\n\n- **Last Runner**: Who will be the first to reach the end?\n{2028298994307806}\n\n- **Snowball Fight**: Join the snowball fight, but don't build a snowman!\n{547421568038349}\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n{529147256630979}\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course!\n{538353858968491}\n\n- **Falling Stones**: The stones will floor under you, try not to fall.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n# Will you win the show?\n{479752444434936}\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!\n", "short_description": "Welcome to Show Game, a FREE TO PLAY VR multiplayer game that brings you and up to 14 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Kissi Studio", "support_website_url": null, "website_url": "https://www.theshowvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8659525917472627"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982510_446725838052360_7705362856421108130_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jBd2ok3JIX8Q7kNvgFJRGMe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyFbRY9U5cyRGBWg-PUA-9x56NaJHu5O6HkDDQR7hRVg&oe=676541E3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Show Game", "platform": "ANDROID_6DOF"