cDWTHqKbd_5vofrkQ&oe=6728C86E"}, {"file_name": "applab screenshot.png", "id": "1726218227785230", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75612010_1726218231118563_5953171904919180739_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7l4CmOwSzxsQ7kNvgGCJL_h&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYC6Z4tGyb9bGPjiqYV1teVtDwqLV44abwEah8Cf6inZ4w&oe=6728AB0F"}, {"file_name": "applab screenshot3.png", "id": "983022023606598", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38982619_983022030273264_4990515898292565542_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l3SIEnKOTYUQ7kNvgEOtMnm&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAzI3URLk3yEIERVl0j-WvhQhXNvDuqp06tfeXfb112fQ&oe=6728AC9E"}, {"file_name": "applab screenshot5.png", "id": "1695435504594666", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75392232_1695435511261332_6659533633796777977_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sa-J8hqV_ncQ7kNvgFKO7pG&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYD_SZ8paQTs-ITvxfJhDO2bwTWZ_6RX3CQS8USAi8cKmA&oe=6728A854"}, {"file_name": "applab screenshot4.png", "id": "1000185934751185", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75303838_1000185938084518_794172045269513713_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQsvA77lxtQQ7kNvgHT4PMQ&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCwLc_kNL7qa853QFTzSFBGtwSTLHn9sWev2lWlmzUVdQ&oe=6728BCEF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "applab trailer thumbnail.png", "id": "465887202733268", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39001688_465887206066601_699368569488131784_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vAdQVA77b4Q7kNvgGKx9Fx&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDauMdZdmWjkuJTUQgV5ZaG14sby1qcPc1xG6IwQR6Neg&oe=672897DB"}, "display_name": "The Show VR - Multiplayer Minigames", "keywords": [], "long_description": "# Enter the world of minigames in VR!\n\n*First of a kind multiplayer game that allows you to be part of The Show!*\n\nThis is a pre-alpha version of the game, please give us feedback. our site - www.theshowvr.com\n\nOur Current Minigames:\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n- **Snowball Fight**: Engage in epic snowball battles with realistic physics for an immersive experience.\n\n- **Falling Stones**: Dodge the falling obstacles and be the last one standing.\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course set on a treacherous green mountain.\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!", "short_description": "Welcome to The Show VR, a unique multiplayer game that brings you and up to 15 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Kissi Studio", "support_website_url": null, "website_url": "https://www.theshowvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in