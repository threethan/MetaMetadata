_ht=scontent.oculuscdn.com&_nc_gid=AQXzXEXZzUZBYFYzzEtUEYY&oh=00_AYBKcuXC_On03OcdfKVXK5AbekJjAad0ExaTwtAdKuaA5g&oe=66EAB48F"}, {"file_name": "applab screenshot3.png", "id": "983022023606598", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982619_983022030273264_4990515898292565542_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sq47TYyNWwYQ7kNvgHbDbvj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQXzXEXZzUZBYFYzzEtUEYY&oh=00_AYCm_-Geh8PpbJ4aKH9zB5AQNn76cBvGVnndo3K2LUC1OA&oe=66EAB61E"}, {"file_name": "applab screenshot5.png", "id": "1695435504594666", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392232_1695435511261332_6659533633796777977_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0EK4KpYaoDYQ7kNvgHMgEXw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQXzXEXZzUZBYFYzzEtUEYY&oh=00_AYDs6ghI2Vo5emFqC20SVDqyHEsxiP-J7LXBVaq_NcUhqw&oe=66EAB1D4"}, {"file_name": "applab screenshot4.png", "id": "1000185934751185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303838_1000185938084518_794172045269513713_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QWh3Sq-x6gYQ7kNvgFFyJgB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQXzXEXZzUZBYFYzzEtUEYY&oh=00_AYAuyTLuwE_gTNW10qSXY9h0wAq-b65_X6sjTA_qtjRn6g&oe=66EAC66F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "applab trailer thumbnail.png", "id": "465887202733268", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001688_465887206066601_699368569488131784_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lHWVShHiAKQQ7kNvgExYgKZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQXzXEXZzUZBYFYzzEtUEYY&oh=00_AYBQcbTlA9VvItEat-9Gd4OBx7VHy5zFUOBzubbA9kSkPA&oe=66EAA15B"}, "display_name": "The Show VR - Multiplayer Minigames", "keywords": [], "long_description": "# Enter the world of minigames in VR!\n\n*First of a kind multiplayer game that allows you to be part of The Show!*\n\nThis is a pre-alpha version of the game, please give us feedback. our site - www.theshowvr.com\n\nOur Current Minigames:\n\n- **Green Light, Red Light**: Test your reflexes and strategy in this classic stop-and-go game.\n\n- **Snowball Fight**: Engage in epic snowball battles with realistic physics for an immersive experience.\n\n- **Falling Stones**: Dodge the falling obstacles and be the last one standing.\n\n- **Sky Fall**: Navigate through the skies and avoid obstacles in this aerial challenge.\n\n- **Green Mountain Obstacle Course**: Race against others in a thrilling obstacle course set on a treacherous green mountain.\n\n- **Bomb Tag**: Pass the bomb to other players to avoid getting blown up in this fast-paced game of tag.\n\n- **Stepping Glass**: Carefully step on the correct glass tiles without falling through in this nerve-wracking challenge.\n\n- **The Wall**: Are you ready to climb? Be the first to reach the top!\n\n**Minimum 2 players are required to start a match, please give us any feedback on discord & our site at www.theshowvr.com**\n\nOur goal is to make the funniest community multiplayer minigames game on VR :)\n\nThank you for trying out the game at an early stage!", "short_description": "Welcome to The Show VR, a unique multiplayer game that brings you and up to 15 other players into a world of fun minigames! Inspired by the best minigames in shows/games!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.theshowvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Kissi Studio", "support_website_url": null, "website_url": "https://www.theshowvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "suppor