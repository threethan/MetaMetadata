video_trailer": null, "video_trailer_thumbnail": {"file_name": "Project Demigod Art - 2560x1440.png", "id": "1424577327984168", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569423_1424577331317501_5878905771002281500_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULyL2eeB96AQ7kNvgG9e9x2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAy1n0Rw9yj2TnenVG4FSXc2PFwbcxkE0mSQ_0Rmo0oaA&oe=675C1DBE"}, "display_name": "Project Demigod", "keywords": [], "long_description": "Become the Hero of your dreams, as you combine multiple fantastic superpowers in unique ways and take on Ninjas, Robots, Agents, and more!\n\nFight, fly, swing, shoot, and smash your way through physics-based ragdoll enemies! Physical weapons with full stabbing physics! Collect new abilities, weapons, and items to develop your own personal combat style! Switch power sets on the fly to create an infinite number of unique combos! Grab an enemy Robot, throw it into the air, jet boost after him, and then punch him through a wall, before grappling him back to you for another round! Destructible Objects! Use the environment to smash your enemies through walls, floors, and a ton of breakable items. Future updates will include additional powers, enemies, levels, challenges, storylines, events, and more!\n\nProject Demigod is currently in Early Access, and will continue to receive constant updates.", "short_description": "Project Demigod is a Physics-Based, Superpower, Combat-Heavy, VR Game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.omnifariousstudios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Omnifarious Studios LLC", "support_website_url": null, "website_url": "https://www.omnifariousstudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "821934236779161"}], "ext