d3-2.oculuscdn.com&oh=00_AYAMMJOqqpUmE5BuXfYaHfdLvQBAKQHTZD-6qk_UihHjuA&oe=670513F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Wordle_Trailer-cover-2560x1440.png", "id": "1306273927446537", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974526_1306273934113203_1008158098595189779_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UiJnqTP2ezAQ7kNvgFgd46m&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_rNawHRTaBSE06aAWBRef4mKTUM7y2wjqbkoQoExkhQ&oe=67051489"}, "display_name": "Wordle", "keywords": [], "long_description": "Play the original Wordle from New York Times Games. Guess the 5-letter word in 6 tries or less. A new puzzle is released daily.\n\nHow to play\nGuess the daily Wordle in 6 tries or less. Each guess must be a valid 5-letter word. Each time you guess, the color of the tiles will change to show how close your guess was to the word.\n\nShare your result with friends on Quest, Instagram, Facebook and WhatsApp. For an added challenge, try hard mode: Any revealed hints need to be used in subsequent guesses.\n\nHigh contrast mode available with colorblindness improvements.", "short_description": "Play the original Wordle from New York Times Games. Guess the 5-letter word in 6 tries or less. A new puzzle is released daily."}]}, "developer_name": null, "developer_privacy_policy_url": "https://help.nytimes.com/hc/en-us/articles/10940941449492-The-New-York-Times-Company-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "The New York Times Company", "support_website_url": null, "website_url": "https://www.nytimes.com/crosswords/apps", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEME