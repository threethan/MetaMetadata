5422373_1182145323031515_459592733005980000_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dgw-nfZq8cUQ7kNvgEaqO6o&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAwDIS0YrbS9QQGuPvDFwxinkWOZ8R9622hJ6F7bmKYOQ&oe=6729FDF9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Wordle_Trailer-cover-2560x1440.png", "id": "1306273927446537", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974526_1306273934113203_1008158098595189779_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UAoqx03hyn8Q7kNvgHo-peW&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDfUTt2-tatOGeatc9PYxQMaSeQty7Ixd1kcnS7cZyQvg&oe=6729FE89"}, "display_name": "Wordle", "keywords": [], "long_description": "Play the original Wordle from New York Times Games. Guess the 5-letter word in 6 tries or less. A new puzzle is released daily.\n\nHow to play\nGuess the daily Wordle in 6 tries or less. Each guess must be a valid 5-letter word. Each time you guess, the color of the tiles will change to show how close your guess was to the word.\n\nShare your result with friends on Quest, Instagram, Facebook and WhatsApp. For an added challenge, try hard mode: Any revealed hints need to be used in subsequent guesses.\n\nHigh contrast mode available with colorblindness improvements.", "short_description": "Play the original Wordle from New York Times Games. Guess the 5-letter word in 6 tries or less. A new puzzle is released daily."}]}, "developer_name": null, "developer_privacy_policy_url": "https://help.nytimes.com/hc/en-us/articles/10940941449492-The-New-York-Times-Company-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "The New York Times Company", "support_website_url": null, "website_url": "https://www.nytimes.com/crosswords/apps", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscri