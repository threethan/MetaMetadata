ted_image.png", "id": "216891552717005", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162678_243960662790390_4422797552932356096_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OOmnkIWMpBMQ7kNvgFovWO8&_nc_ht=scontent.oculuscdn.com&_nc_gid=Areplf916Ss6YD3Dz1-_7Ii&oh=00_AYCFzN-bFXfTWwngrkgvw88mBhRw8kYOZklfv8yEg4jUOA&oe=66DD7457"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumb_01.png", "id": "120924438518435", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162731_120924441851768_1476883766688350208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Pb9oJ56mIsQ7kNvgG-X2DB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Areplf916Ss6YD3Dz1-_7Ii&oh=00_AYC0eIT7mS8fS8xFOvCUcWBcA9kcGKnwh4ggVWJ9gz4b9w&oe=66DD9BC8"}, "display_name": "Fantasy Pets", "keywords": ["Pet", "Friend", "Cute", "Simulation", "Fantasy"], "long_description": "Learn to take care of your pet, make sure it does not go hungry, and play with toys to keep it entertained! Visit it often and make sure it doesn\u2019t get sick. Don\u2019t worry if it gets dirty playing \u2026 It loves to bathe!\nYou can also shoot some hoops or watch TV while it sleeps or if you need a break.\n\nComplete missions for incredible rewards! With them you\u2019ll unlock new colors, patterns and accessories with which to decorate your pet; funny hats, glasses, and much more!\nDo not miss any opportunity to unlock all the packs and equip your favorite!\n\nWe recommend using headphones.\n\nGame features:\n- Lovely pet with realistic behaviour.\n- Stunning 3D graphics.\n- Different ways to take care of your pet.\n- Growth and evolution of your pet.\n- Beautiful and big environment in which to play with your pet.\n- Lots of variation in pet customization.", "short_description": "Fantasy Pets is a Pet Simulator in which you have to take care of  a cute pet, play with it, customize it and more in a beautiful environment. You\u2019ll start off with an egg, and after hatching it you\u2019ll learn how to take care of your newborn pet.\nThere are differents ways to customize it, from the color and patterns of its skin to accessories that it can wear."}]}, "developer_name": null, "developer_privacy_policy_url": "http://demiumgames.com/privacy.html", "developer_terms_of_service_url": "http://demiumgames.com/privacy.html", "publisher_name": "Pyrolite Games", "support_website_url": null, "website_url": "http://pyrolitegames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1081958082365326"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162676_102770777021317_4232814708295467008_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d0ZopPyJhNgQ7kNvgGCdVqQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Areplf916Ss6YD3Dz1-_7Ii&oh=00_AYAuYU5lxYB56oSWRBDjDtPyA9s7tqPOmc6D2tQ0eCDasw&oe=66DD85E6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Fantasy Pets", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1499897853, "lastRevision": {"nodes": [{"id": "1934249336820909", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1546529198754283", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "321439921602777"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes"