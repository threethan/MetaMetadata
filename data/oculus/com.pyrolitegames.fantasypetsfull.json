.oculuscdn.com&oh=00_AYAv8uGLjcbUZB6CrK_4rKrdaBOZP_7QoLHmdjBVzU-x4A&oe=671A24A5"}, {"file_name": "migrated_image.png", "id": "154317689089912", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/11162711_262530014224786_2316404711751680000_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ca4ot_TbmYQ7kNvgEiGrUA&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCxtPuzvhIi8t4D8PyEz7Z2Z0Zx1SKNLLKvCjX7wqG3sA&oe=671A1C07"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fantasy Pets", "keywords": ["Pet", "Friend", "Cute", "Simulation", "Fantasy"], "long_description": "Try out Fantasy Pets!\nEnjoy playing with your cute pet, but be careful, don\u2019t throw anything at its body or it will get angry!\nTry to score some points playing basketball with your pet. \nRefill the food bowl with its favourite food. If you see or hear it cry, it might be because there\u2019s no food left in the bowl, so just refill to cheer it up! \nTurn on the TV for your little friend to enjoy its favourite programs.\n\nWe recommend using headphones.\nEasy control, just tap on the touchpad to interact with any element.\n\nGame features:\nPet with realistic behaviour.\nAmazing 3D graphics.\nGorgeous environment where you play with your pet.\nGrowth and evolution of your pet.", "short_description": "Fantasy Pets is a pet simulator where you take care of your creature and play with it in a beautiful environment made for it."}]}, "developer_name": null, "developer_privacy_policy_url": "http://demiumgames.com/privacy.html", "developer_terms_of_service_url": "http://demiumgames.com/privacy.html", "publisher_name": "Pyrolite Games", "support_website_url": null, "website_url": "http://pyrolitegames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED"