ind a way out while the butcher is hunting you. Don't let him get close by shooting him or using your axe. \nYour main task is to survive at any cost.\n\nKey Features\n- Support Oculus Quest 2 & 3\n- Two types of weapons\n- Many different puzzles\n- Free Movement\n- Smooth motion and framerate\n", "short_description": "House of the Butcher is a virtual reality escape the room style game with shooter elements."}]}, "developer_name": "Yurii Kaplunov", "developer_privacy_policy_url": "https://raptorsreality.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Raptor`s Games", "support_website_url": null, "website_url": "https://raptorsreality.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7364704096963690"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035334_742700036987844_6596355488257219503_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5lkLKUZqrLwQ7kNvgH3lvEb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDjQqf4XqwvhKLIElGKu3MqkvoU9a3pMbfZw3AUN83lgg&oe=6724BA17"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "House of the Butcher", "platform": "ANDROID_6DOF", "context_category": {"context_categor