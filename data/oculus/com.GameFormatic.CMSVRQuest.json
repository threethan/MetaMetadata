ent-lga3-2.oculuscdn.com/v/t64.5771-25/75443239_1046923332896013_5905198331107088222_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b3ekzny7RVgQ7kNvgFhWMkc&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCAVCErOMZobPM2tgqgBswED5dgR4J8fCqrMgB2Suj45A&oe=675ECB75"}, {"file_name": "3.png", "id": "816419579764171", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982708_816419583097504_4926272453059697278_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KpyAw2CPigwQ7kNvgFWlu3z&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCyt0TDS25AJLsvX8v3Mqtz3iwgtVgaLxsdWfLvNgNY1Q&oe=675EDAD2"}, {"file_name": "01_4K_UHD.2560x1440.20220722143921856.png", "id": "2176303689212137", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974824_2176303692545470_295426122590301121_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SxbDAXy_aJYQ7kNvgFq3y2g&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAIoIn76wUb5xwIOlRMqcih_JsndNwZ3XqLC06imd_3YA&oe=675EB26E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CMS-Quest-trailer-2560x1440.png", "id": "1495108120907786", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974892_1495108124241119_2464964191470840905_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pvt-0XwpHboQ7kNvgEj-otq&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBl_UwsinhJRgYV69BCNrafCmeOrzBZhUlyiZK02cjDUQ&oe=675EBF04"}, "display_name": "Car Mechanic Simulator", "keywords": ["fixing", "renovating", "repairing", "tools", "relaxing"], "long_description": "Become a true master of the craft in this virtual reality simulation game. As a professional mechanic your skills will be tested as you strive to meet your clients\u2019 expectations. Immerse yourself in realistic gameplay as you prove your skills with the many available tools and car parts. Diagnose, repair, paint, and renovate highly detailed cars in your very own auto shop.\n\n \n\nFeatures:\n\n    10 distinctive cars\n    Over a dozen different tools to use\n    Hundreds of unique car parts and options", "short_description": "Repair, paint, and renovate cars in a immersive 3D world. Become a professional car mechanic and enjoy realistic gameplay as you prove your skills with the many available tools and car parts. Meet your clients\u2019 expectations, diagnose their cars, and repair them in the most detailed automobile simulation VR game for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/polityka-prywatnosci/", "developer_terms_of_service_url": null, "publisher_name": "PlayWay, Titan GameZ", "support_website_url": null, "website_url": "https://gameformatic.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3826116900946719"}}]}, "scheduled_offers": {"count": 17, "nodes": [{"status": "PUBLISHED", "id": "525947280315027"}, {"status": "PUBLISHED", "id": "828737236101589"}, {"status": "PUBLISHED", "id": "3863215490566650"}, {"status": "PENDING", "id": "819267289715335"}, {"status": "PUBLISHED", "id": "1665757140534661"}, {"status": "PENDING", "id": "2347377822093159"}, {"status": "PENDING", "id": "903795467492401"}, {"status": "PUBLISHED", "id": "1188577211741248"}, {"status": "PENDING", "id": "878419636767481"}, {"status": "PUBLISHED", "id": "953457559522854"}, {"status": "PENDING", "id": "1415952342274615"}, {"status": "PUB