779949783", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974457_778503786616449_4356179687039225465_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07laGde6z2MQ7kNvgHokmon&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDd_pj-VhO7wM8u-33rlPcE6pnvCcjqbcsZ3n6GY_J7kw&oe=67237A00"}, {"file_name": "01_4K-UHD.2560x1440-11.png", "id": "1046923329562680", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75443239_1046923332896013_5905198331107088222_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SYJeVIoi66gQ7kNvgGk3eWq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4TJdD7LM_CmzroAc4poYIKrno96230VbiuFjjP_de9A&oe=672377F5"}, {"file_name": "3.png", "id": "816419579764171", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982708_816419583097504_4926272453059697278_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-zpdZHSrRNgQ7kNvgEtDfQ4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-29lOb_ixfnnfgxfqG2y40X-65SprlPZAYJwIY8NPnQ&oe=67238752"}, {"file_name": "01_4K_UHD.2560x1440.20220722143921856.png", "id": "2176303689212137", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974824_2176303692545470_295426122590301121_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I0rb4KWgOtUQ7kNvgFPShHz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVsXzOQCqF1azw4cRJoxhCUpymnpzWdmXGFX3NA0YHMA&oe=67235EEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CMS-Quest-trailer-2560x1440.png", "id": "1495108120907786", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974892_1495108124241119_2464964191470840905_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B8Erum92SnoQ7kNvgEad8qe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwtjmQHwywLDOzdkSULcrsk3klfZzCU1dZPRwrbsBitA&oe=67236B84"}, "display_name": "Car Mechanic Simulator", "keywords": ["fixing", "renovating", "repairing", "tools", "relaxing"], "long_description": "Become a true master of the craft in this virtual reality simulation game. As a professional mechanic your skills will be tested as you strive to meet your clients\u2019 expectations. Immerse yourself in realistic gameplay as you prove your skills with the many available tools and car parts. Diagnose, repair, paint, and renovate highly detailed cars in your very own auto shop.\n\n \n\nFeatures:\n\n    10 distinctive cars\n    Over a dozen different tools to use\n    Hundreds of unique car parts and options", "short_description": "Repair, paint, and renovate cars in a immersive 3D world. Become a professional car mechanic and enjoy realistic gameplay as you prove your skills with the many available tools and car parts. Meet your clients\u2019 expectations, diagnose their cars, and repair them in the most detailed automobile simulation VR game for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gameformatic.com/polityka-prywatnosci/", "developer_terms_of_service_url": null, "publisher_name": "PlayWay, Titan GameZ", "support_website_url": null, "website_url": "https://gameformatic.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3826116900946719"}}]}, "scheduled_offers": {"count": 16, "nodes": [{"status": "PUBLISHED", "id": "828737236101589"}, {"status": "PUBLISHED", "id": "3863215490566650"}, {"status": "PENDING", "id": "819267289715335"}, {"status": "PUB