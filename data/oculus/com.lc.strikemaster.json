EABB7E"}, {"file_name": "ss3.png", "id": "865151022235805", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974912_865151025569138_1526032060872620185_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GMwo9zfHmJQQ7kNvgFuOh0U&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyMjO2l10Y5xUm2Z7WeUHq4&oh=00_AYAEjDua4ZxsW8lPLVOPQsjdGd9wWxAq2rUy9SdLrLl7Fw&oe=66EAAE4C"}, {"file_name": "ss5.png", "id": "2801516019998099", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_2801516023331432_973229975872388981_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ryY45qlqyQ8Q7kNvgED7f-Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyMjO2l10Y5xUm2Z7WeUHq4&oh=00_AYDfsacDuQH9tEK8ZtbV8s28TW0SYQ4gm4rJdijbFbf5pQ&oe=66EACCFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1450189568960094", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75458102_1450189572293427_321153024598500436_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5qCnDKVsxeEQ7kNvgEvErbb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyMjO2l10Y5xUm2Z7WeUHq4&oh=00_AYA_F3vTqq-BMHyk8-iT7WWCMScbz_LQFW84y_ElXbc4SA&oe=66EACD7B"}, "display_name": "Strike Master", "keywords": [], "long_description": "Strike Master: The Ultimate VR Bowling Experience\n\nWelcome to \"Strike Master,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Get ready to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Strike Master\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Strike Master\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Strike Master: The Ultimate VR Bowling Experience\n\nWelcome to \"Strike Master,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Get ready to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Strike Master\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/strike-master-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "LC Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/strike-master-vr", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8115321295156217"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8134805506541129", "version": "2.1"}, "id": "799813049003000", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_ap