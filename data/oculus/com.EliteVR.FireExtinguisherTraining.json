{"file_name": "Screenshot 5.png", "id": "303120494512173", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984454_303120497845506_2452761154206930018_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TUhRIQ_B_9YQ7kNvgFNsYD_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB1_cxGg-M4hdUJ5cQ69_h7Cf2lhubhqKB_4I3HrSTovA&oe=67865D60"}, {"file_name": "Screenshot 4.png", "id": "2903451106580758", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974558_2903451113247424_7913425504099588068_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2SpYlB66qE0Q7kNvgHG9IC6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBeh388jatW93f6sxTuNa1cbCzW9sXCfSp0QgZzcrQAVg&oe=678661C5"}, {"file_name": "Screenshot 2.png", "id": "193944275725453", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974453_193944279058786_6160766380495093563_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kie2N7rsae8Q7kNvgELN1Pc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBLz_pBdRevo8fI2e_s1Z0mf5inN6SIuMHvQzknaY1nMQ&oe=67864AFA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail_FEVR_Cover Landscape.png", "id": "1012494679156483", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982447_1012494682489816_8716830647569091301_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_4xax7IKLDEQ7kNvgE53S1D&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBuWkT_gZ4sFq30dcA0LTl5jJB8bNHvOscuKFll3sZ5Kw&oe=67863190"}, "display_name": "FEVR Fire Extinguisher Training", "keywords": [], "long_description": "In this immersive VR training simulation, the learner will engage in a full OSHA 1910.157 fire extinguisher training course. All five types of fire extinguishers are covered, Types A, B, C, D, & K with unique experiences for each of them. It also covers pull stations, PASS (Pull, Aim, Squeeze, and Sweep), fire extinguisher components, fire classifications with each characteristic explained, and a randomized fight or flight scenario. This training can be used to fulfill your annual portable fire extinguisher training requirements as required by OSHA. www.elitevrtraining.com", "short_description": "In this immersive VR training simulation, the learner will engage in a full OSHA 1910.157 fire extinguisher training course. All five types of fire extinguishers are covered with unique experiences for each of them. It also covers pull stations, PASS, fire extinguisher components, fire classifications, as well as fight or flight. www.elitevrtraining.com"}]}, "developer_name": "Elite VR Training", "developer_privacy_policy_url": "https://elitevrtraining.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Elite VR Training", "support_website_url": null, "website_url": "https://www.elitevrtraining.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION", "EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "923882978771196"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1123534412518509"}, {"status": "PUBLISHED", "id": "578487327429983"}]}, "baseline_offer": {"id": "1123534412518509"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1736108520, "status": "PUBLISHED", "id": "1123534412518509"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6494627757217238", "vers