5_1050200263278744_2536765123562298486_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yKGWBH1hi2YQ7kNvgGgxvwt&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBTgAhg5AEizsyP4IxdnI9s_AH7xVFcLGar8Fea8sZj_Q&oe=670FB1CB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Level - Tilted 2560x1440.png", "id": "1253462735677317", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974547_1253462742343983_8818318723270229370_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=81ycSvdDffAQ7kNvgGeYQIV&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDQW45PFgHluCtvaEA93Yi6lT8scNIlCOWEk68t5j_pQg&oe=670F9120"}, "display_name": "Close Encounters Demo", "keywords": ["Breakout", "UFO", "Paddle", "Ball", "Space"], "long_description": "Use your controller thumb sticks to deflect one or more balls to targets for collection.\n\nEach planet presents a challenging array of targets that must be collected to the waiting UFO above.\n\nPower-ups become available to assist in the collection process:\n- Extra Ball = Additional ball added to total balls available\n- Multi-Ball = Additional ball launched at location of power up\n- Power Ball = Blows through targets.  Lasts for 30 seconds.\n- Extra Time = Adds 60 to level timer\n\nBall speed increases and paddle size decreases as you progress through each challenge.\n\nTimed Demo Version: Play specific levels for about 60 seconds to get a feel for this game.\n", "short_description": "Timed Demo Version of Close Encounters.\n\nLightning-fast reflexes are required to collect samples from each world and upload them to the hovering UFO."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.abbynormalproductions.net/privacy-policy-close-encounters", "developer_terms_of_service_url": "https://www.abbynormalproductions.net/terms-of-service", "publisher_name": "Abby Normal Productions, LLC", "support_website_url": null, "website_url": "https://www.abbynormalproductions.net/", "category": null, "comfort_rating": "COMF