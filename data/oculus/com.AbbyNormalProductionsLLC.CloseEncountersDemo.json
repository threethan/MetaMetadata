.\n\nLightning-fast reflexes are required to collect samples from each world and upload them to the hovering UFO."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.abbynormalproductions.net/privacy-policy-close-encounters", "developer_terms_of_service_url": "https://www.abbynormalproductions.net/terms-of-service", "publisher_name": "Abby Normal Productions, LLC", "support_website_url": null, "website_url": "https://www.abbynormalproductions.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8167124973372116"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "521066623841606"}]}, "baseline_offer": {"id": "521066623841606"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726077540, "status": "PUBLISHED", "id": "521066623841606"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8191067080977905", "version": "1.0.1"}, "id": "478537885164273", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8167124943372119", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8191067080977905"}, "release_status": "R