okTf7c-4lAEaDGgafr0cqFG8heUmWrTe0Xc-Tlw&oe=67386E18"}, {"file_name": "SS5.png", "id": "4406444542781815", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240096_4406444546115148_1397662786867152630_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8OEDLC7ceV0Q7kNvgHiJkuD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB6n5KHDmKHI22RA9FVyGPXOMPHzfmQAKxwoITOT9Jj2w&oe=67387EC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "2647069528935416", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974523_2647069532268749_6297400513680957855_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YvkGstnthT4Q7kNvgE4ITeW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcao5wqnwJodfjdrLZZR1RqwxhHLM9aQOL-mrckVrW3g&oe=67388BEB"}, "display_name": "EC ARMS", "keywords": [], "long_description": "\u30a8\u30cd\u30eb\u30ae\u30fc\u53ce\u96c6\u578b\u30b7\u30e5\u30fc\u30c6\u30a3\u30f3\u30b0\u30b2\u30fc\u30e0\u3002\n\u884c\u304f\u624b\u3092\u963b\u3080\u6575\u304b\u3089\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u96c6\u3081\u3066\u9032\u3093\u3067\u3044\u304d\u307e\u3059\u3002\n\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3059\u308b\u969b\u306e\u723d\u5feb\u611f\u3092\u76ee\u6307\u3057\u307e\u3057\u305f\u3002\n\u305c\u3072\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3059\u308b\u6c17\u6301\u3061\u826f\u3055\u3092\u4f53\u9a13\u3057\u3066\u304f\u3060\u3055\u3044 !\n\n\u2022 \u64cd\u4f5c\u65b9\u6cd5\n\u30cf\u30f3\u30c9\u30c8\u30e9\u30c3\u30ad\u30f3\u30b0\u5c02\u7528\u3067\u3059\u3002\n\u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n2\u3064\u306e\u64cd\u4f5c\u3067\u57fa\u5730\u304b\u3089\u306e\u8131\u51fa\u3092\u76ee\u6307\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n1.\u653b\u6483\u30e2\u30fc\u30c9 - \u3069\u3061\u3089\u304b\u7247\u65b9\u306e\u624b\u304c\u30d1\u30fc\n   \u30dd\u30a4\u30f3\u30bf\u30fc\u304c\u51fa\u307e\u3059\u3002\n   \u30dd\u30a4\u30f3\u30bf\u30fc\u3092\u5f53\u3066\u308b\u3053\u3068\u3067\u30b9\u30bf\u30fc\u30c8\u3084\u6575\u306b\u653b\u6483\u304c\u3067\u304d\u307e\u3059\u3002\n   \u653b\u6483\u3057\u3066\u6575\u304b\u3089\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u51fa\u3057\u307e\u3057\u3087\u3046\u3002\n2.\u5438\u53ce\u30e2\u30fc\u30c9 - \u4e21\u624b\u304c\u30d1\u30fc\n   \u30b7\u30fc\u30f3\u306b\u30a8\u30cd\u30eb\u30ae\u30fc\u304c\u51fa\u3066\u3044\u308b\u5834\u5408\u3001\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3057\u307e\u3059\u3002\n   \u305f\u304f\u3055\u3093\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u96c6\u3081\u307e\u3057\u3087\u3046\u3002(\u4e00\u5b9a\u8ddd\u96e2\u96e2\u308c\u308b\u3068\u5438\u53ce\u3067\u304d\u307e\u305b\u3093\u3002)\n\n\u2022 \u30b2\u30fc\u30e0\u306e\u9032\u3081\u65b9\n1.\u30b9\u30bf\u30fc\u30c8\n   \u8d77\u52d5\u3059\u308b\u3068\u3001\u52a9\u624b\u306b\u3088\u308b\u30ca\u30d3\u30b2\u30fc\u30b7\u30e7\u30f3\u304c\u59cb\u307e\u308a\u307e\u3059\u3002\n   START\u30a2\u30a4\u30b3\u30f3\u304c\u73fe\u308c\u305f\u3089\u3001\u7d042\u79d2\u307b\u3069\u653b\u6483\u30e2\u30fc\u30c9\u3067\u30dd\u30a4\u30f3\u30bf\u30fc\u3092\u5f53\u3066\u3066\u304f\u3060\u3055\u3044\u3002\n   START\u30a2\u30a4\u30b3\u30f3\u306e\u30b2\u30fc\u30b8\u304c\u305f\u307e\u3063\u305f\u3089\u30b9\u30bf\u30fc\u30c8\u3067\u3059\u3002\n2.\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\n   \u30b9\u30bf\u30fc\u30c8\u3057\u305f\u3089\u79fb\u52d5\u306f\u81ea\u52d5\u3067\u3059\u3002\n   2\u3064\u306e\u64cd\u4f5c\u3092\u4f7f\u3044\u5206\u3051\u3066\u3001\u8131\u51fa\u307e\u3067\u306b\u305f\u304f\u3055\u3093\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u96c6\u3081\u3066\u4e0b\u3055\u3044\u3002\n   \u6575\u306e\u5f3e\u306b\u5f53\u305f\u308b\u3068\u30a8\u30cd\u30eb\u30ae\u30fc\u304c\u6e1b\u308a\u307e\u3059\u3002(0\u4ee5\u4e0b\u306b\u306f\u306a\u308a\u307e\u305b\u3093\u3002)\n3.\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\n   \u5236\u9650\u6642\u9593\u307e\u3067\u306b\u8131\u51fa\u3067\u304d\u306a\u3051\u308c\u3070\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3067\u3059\u3002\n4.\u30af\u30ea\u30a2\n   \u5236\u9650\u6642\u9593\u307e\u3067\u306b\u6249\u3092\u629c\u3051\u305f\u3089\u30b2\u30fc\u30e0\u30af\u30ea\u30a2\u3067\u3059\u3002\n\n\u2022 \u30b9\u30c8\u30fc\u30ea\u30fc\n\u5c11\u3057\u5148\u306e\u672a\u6765\u3002\n\u30a8\u30cd\u30eb\u30ae\u30fc\u8cc7\u6e90\u306e\u67af\u6e07\u306f\u4eba\u985e\u3092\u82e6\u3057\u3081\u3066\u3044\u305f\u3002\n\u5404\u56fd\u306e\u7814\u7a76\u8005\u306f\u5354\u529b\u3057\u3001\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5b9f\u4f53\u5316\u30fb\u53ce\u96c6\u3059\u308b\u30b7\u30b9\u30c6\u30e0\u306e\u958b\u767a\u306b\u7740\u624b\u3057\u305f\u3002\nN\u56fd\u306e\u4e3b\u4eba\u516c\u306f\u3001\u3068\u3046\u3068\u3046\u305d\u306e\u30b7\u30b9\u30c6\u30e0\u306e\u958b\u767a\u306b\u6210\u529f\u3002\u4eba\u985e\u306f\u6551\u308f\u308c\u305f\u304b\u306b\u601d\u308f\u308c\u305f\u3002\n\u3060\u304c\u3001N\u56fd\u306f\u305d\u306e\u30b7\u30b9\u30c6\u30e0\u3092\u72ec\u5360\u3059\u3079\u304f\u3001\u4e3b\u4eba\u516c\u3092\u5e7d\u9589\u3057\u305f\u3002\n\u4e3b\u4eba\u516c\u306f\u3001\u5e7d\u9589\u3055\u308c\u305f\u7814\u7a76\u6240\u3067\u305d\u306e\u30b7\u30b9\u30c6\u30e0\u3092\u6271\u3046\u30c7\u30d0\u30a4\u30b9\u3092\u69cb\u7bc9\u3002\n\u30a2\u30f3\u30c9\u30ed\u30a4\u30c9\u306e\u52a9\u624b\u3068\u5171\u306b\u8131\u51fa\u3092\u8a66\u307f\u308b\u306e\u3060\u3063\u305f\u3002\u3002\u3002", "short_description": "\u30a8\u30cd\u30eb\u30ae\u30fc\u53ce\u96c6\u578b\u30b7\u30e5\u30fc\u30c6\u30a3\u30f3\u30b0\u30b2\u30fc\u30e0\u3002\n\u884c\u304f\u624b\u3092\u963b\u3080\u6575\u304b\u3089\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u96c6\u3081\u3066\u9032\u3093\u3067\u3044\u304d\u307e\u3059\u3002\n\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3059\u308b\u969b\u306e\u723d\u5feb\u611f\u3092\u76ee\u6307\u3057\u307e\u3057\u305f\u3002\n\u305c\u3072\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u5438\u53ce\u3059\u308b\u6c17\u6301\u3061\u826f\u3055\u3092\u4f53\u9a13\u3057\u3066\u304f\u3060\u3055\u3044 !"}, {"images": {"nodes": [{"file_name": "ECA_CA_T.png", "id": "1909003666290128", "image_type": "APP_IMG_COV