t=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YYG5DUVGxT8Q7kNvgGzSzvd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBaPFXCvVrPN4hSLoyKAPg0a_uI3hLo8IJa0NcOn9P1rA&oe=6707D652"}, {"file_name": "SS5.png", "id": "411302063697425", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003249_411302067030758_3628480977844434449_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m8ixGRS7GcAQ7kNvgH_5do4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0xsrvJKWhx75BeOuBSl8ORuKTpns5U1ol7L_lRknffg&oe=6707A4B5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "903752467203527", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982530_903752470536860_7264819481473567_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eOGkgq9M-14Q7kNvgGh7PqY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqr1lWQUsMYhL9RvBzJGUFbMnrZ_mDuN9YXCoHgiI2UA&oe=6707BDAA"}, "display_name": "EC ARMS", "keywords": [], "long_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!\n\n\u2022 Method of operation\nFor hand tracking only.\nThe move is automatic.\nAim to escape from the base with two operations:\n1.Attack mode - Either hand is a Paper\nThe pointer will come out. You can start or attack the enemy by hitting the pointer. Attack and get energy from your enemies.\n2.Absorption mode - Both hands are Paper\nIf there is energy in the scene, it will absorb the energy. Collect a lot of energy.\n(It cannot be absorbed after a certain distance.)\n\n\u2022 How to proceed with the game:\n1.Start\nStart when the gauge of the START icon is full.\n2.GamePlay\nOnce started, the move is automatic. When hit by an enemy bullet, the energy is reduced.\n3.GameOver\nIf you cannot escape by the time limit, the game is over.\n4.GameClear\nThe game is cleared if you pass through the door by the time limit.", "short_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/ecarms", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1564647620564911"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974523_289747486304901_7190563071694216961_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=muDXjbcgB-UQ7kNvgFcUK3c&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsx-jJFF6hO1CYiDgIWZDznYWnxyNxwMXNsZTuYzu7Tg&oe=6707C150"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "EC ARMS", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1633467355, "lastRevision": {"nodes": [{"id": "545514230089796", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6231755493531351", "is_first_party": false, "enables_in_app_ads": false, "is_conc