974523_2975583332768459_4876848584461000911_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UbDxszb2k7sQ7kNvgEERhVN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXGTMQiqoxnlyyoXzm1xfy&oh=00_AYBIZFYk-07p-k23xoI2vFirnA__RQ_sJ-jeL0zJua28SQ&oe=66F68F96"}, {"file_name": "SS4.png", "id": "184634680428060", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641339_184634683761393_2675350997552393899_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VRgI70TOCH0Q7kNvgFYEaVm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXGTMQiqoxnlyyoXzm1xfy&oh=00_AYCpmzU9WRdWeCUlhZdZeFy9u-h2-_yikVhV2zDg42rRbQ&oe=66F6B2D2"}, {"file_name": "SS5.png", "id": "411302063697425", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003249_411302067030758_3628480977844434449_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BduRJ01bgL4Q7kNvgHjTIb4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXGTMQiqoxnlyyoXzm1xfy&oh=00_AYBr4QQf5CqjnJXHwQlAI-4q85WKpOE1tx4_Adkb0pbEuA&oe=66F68135"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "903752467203527", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982530_903752470536860_7264819481473567_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g8wsKFw_g64Q7kNvgFgTSaH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXGTMQiqoxnlyyoXzm1xfy&oh=00_AYDBwLavVyo7m-pPoQok0LSOiIAZgHUozYj7bXhfWNXqTg&oe=66F69A2A"}, "display_name": "EC ARMS", "keywords": [], "long_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!\n\n\u2022 Method of operation\nFor hand tracking only.\nThe move is automatic.\nAim to escape from the base with two operations:\n1.Attack mode - Either hand is a Paper\nThe pointer will come out. You can start or attack the enemy by hitting the pointer. Attack and get energy from your enemies.\n2.Absorption mode - Both hands are Paper\nIf there is energy in the scene, it will absorb the energy. Collect a lot of energy.\n(It cannot be absorbed after a certain distance.)\n\n\u2022 How to proceed with the game:\n1.Start\nStart when the gauge of the START icon is full.\n2.GamePlay\nOnce started, the move is automatic. When hit by an enemy bullet, the energy is reduced.\n3.GameOver\nIf you cannot escape by the time limit, the game is over.\n4.GameClear\nThe game is cleared if you pass through the door by the time limit.", "short_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/ecarms", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1564647620564911"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_289747486304901_7190563071694216961_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sMnaM1rikuoQ7kNvgG0PymF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjXGTMQiqoxnlyyoXzm1xfy&oh=00_AYBnsWIQuTrVamQdtPbi0SYv8P1wMwIdc7bkzCO1VJKT