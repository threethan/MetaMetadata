qIb-Hp3Ywua-LsxWqE3X58Ew&oe=67333496"}, {"file_name": "SS4.png", "id": "184634680428060", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75641339_184634683761393_2675350997552393899_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdC_EnbnO0UQ7kNvgH4WLVP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1ye6pLC_LXwx0gWjeO88iujcgEWsni6o3utkKCP8EGw&oe=673357D2"}, {"file_name": "SS5.png", "id": "411302063697425", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003249_411302067030758_3628480977844434449_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WI1u2hGrC_oQ7kNvgHvdmAk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCH1FtvwVjXDYQKmzMkt8_2aOtDTAByofPEbZIJeWPMlA&oe=67332635"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_Y.png", "id": "903752467203527", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982530_903752470536860_7264819481473567_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mi1ty-pl3roQ7kNvgHCGHfV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv7KMkVhzeV5LE5XaiMljBdB-0c3rsB1AjFn6phnQA9A&oe=67333F2A"}, "display_name": "EC ARMS", "keywords": [], "long_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!\n\n\u2022 Method of operation\nFor hand tracking only.\nThe move is automatic.\nAim to escape from the base with two operations:\n1.Attack mode - Either hand is a Paper\nThe pointer will come out. You can start or attack the enemy by hitting the pointer. Attack and get energy from your enemies.\n2.Absorption mode - Both hands are Paper\nIf there is energy in the scene, it will absorb the energy. Collect a lot of energy.\n(It cannot be absorbed after a certain distance.)\n\n\u2022 How to proceed with the game:\n1.Start\nStart when the gauge of the START icon is full.\n2.GamePlay\nOnce started, the move is automatic. When hit by an enemy bullet, the energy is reduced.\n3.GameOver\nIf you cannot escape by the time limit, the game is over.\n4.GameClear\nThe game is cleared if you pass through the door by the time limit.", "short_description": "An energy-collecting shooting game.\nYou collect energy from enemies that block your path.\nWe aimed for a feeling of exhilaration when absorbing energy.\nPlease experience the comfort of absorbing energy!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/ecarms", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1564647620564911"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974523_289747486304901_7190563071694216961_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5CH_21W8l5kQ7kNvgF0NN0w&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkrjdvh1qPAX-RZrFW7ASYIg7omPq6CBFxEwB7SsVDTQ&oe=673342D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "EC ARMS", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"