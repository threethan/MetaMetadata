": "MAP_2560x1440.png", "id": "350169066297244", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001723_350169069630577_8053892652444302572_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-3_FKIJ7a-AQ7kNvgEZ5H7C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKFVnt9p75l1HJRx3KYadUc52xUHLEW-PMP33MXrMjNw&oe=671F8698"}, {"file_name": "Mountain_2560x1440.png", "id": "3390076871086816", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036642_3390076877753482_4847008245855033837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w7Qs3_rikBcQ7kNvgGGXf2i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDRs3eZcPeK9JQ6eTnrXvlHqSBTy2O4adDhEOng-bLaA&oe=671F6667"}, {"file_name": "Narration_2560x1440.png", "id": "265976671253841", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001723_265976674587174_8546037945784069924_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EqBcDowZ7NsQ7kNvgHS9ccC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBCIswvyeBvu_stNr0rRrUjoWu_IwSVEMXWbemJI65zXA&oe=671F62EC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "StarShamanTrailerThumb.png", "id": "1672389429606070", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974727_1672389439606069_7198504558235010583_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lo-IR8TYvDgQ7kNvgE3FnXe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8G1KWLrg4xZKI-qnSyr4-8bq21WELpaT5SuwiLieWZw&oe=671F6AF8"}, "display_name": "Star Shaman", "keywords": ["star", "shaman", "roguelite", "adventure"], "long_description": "Cast spells using the Shaman Sphere to invoke a wide range of weapons and fight your way through spectacularly looking galaxies to the beat of a French Touch soundtrack.\n\nHop from planet to solar system in a stunningly beautiful and procedurally generated universe where no playthrough is ever the same.\n\nFall, try again and unlock powerful new weapons and abilities to find your playstyle. Invoke them using a unique and ultra-satisfying motion-based spellcasting system that will soon make you feel invincible.\n\nBattle armadas of deadly mechanical enemies until you reach epic boss fights that block your path to new solar systems. Along the way, you will meet a quirky roster of characters.\n\nAnd don't forget to admire the finer details of the extraordinary life forms you're bringing back to life as you chase the corrupt Architects of Entropy to the most remote corners of their cubic universe.\n\nFor you are a STAR SHAMAN, a champion of biodiversity and the galaxy's last resort.", "short_description": "Become a STAR SHAMAN and embark on an epic adventure to bring the funk of life back into a universe whose existence has been depleted to boring cubes by the Architects of Entropy. Travel through enchanting, futuristic galaxies to funky french-touch music.\n\nSTAR SHAMAN is an active VR adventure with touches of roguelite."}]}, "developer_name": "Ikimasho", "developer_privacy_policy_url": "http://starshaman.games/Star_shaman_EULA.html", "developer_terms_of_service_url": null, "publisher_name": "Ikimasho", "support_website_url": null, "website_url": "http://www.starshaman.games/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1402996616824034"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PENDING", "id": "29536343