39036621_908563686757648_5766878142044206530_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=js8hoHNJUoAQ7kNvgGbWbyN&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9P_v_6MxWXri_wI6c7WGde&oh=00_AYBJU9un3aD6E58T1YZxGUXd3o0gtDdcX8mHa_k61Zu5nQ&oe=66F3DCF5"}, "display_name": "Vortex VR", "keywords": [], "long_description": "Vortex VR is an immersive investigation and an narrative experience : You explore the universe of the VORTEX series. Help the commissioner (played by Tomer Sisley) to solve the crime !\n\n As a Detective, you can inspect the crime scene: hurry up! You'll only have 20 minutes to collect all the clues and solve the crime before the tide covers the evidence.\n\nFeatures: \n- Controlling time\n - Exploring and manipulating clues \n- Interactive narration \n- Actor Tomer Sisley in motion capture \n\nOnly available in French", "short_description": "An immersive investigation in the world of the TV show \"VORTEX\" : you have 20min to solve the crime ! \n\nA Narrative driven game \nONLY IN FRENCH - TEXT AND SPEECH "}, {"images": {"nodes": []}, "id": "685392029919376", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Vortex VR", "keywords": [], "long_description": "Vortex VR est une enqu\u00eate immersive o\u00f9 vous explorez l\u2019univers de la s\u00e9rie VORTEX. \u2028\u2028\n\nDans la peau d\u2019un detective vous pourrez inspecter la sc\u00e8ne de crime : d\u00e9p\u00eachez-vous ! \n\nVous n\u2019aurez que 20 minutes pour r\u00e9cup\u00e9rer tous les indices et \u00e9lucider le crime avant que la mar\u00e9e ne recouvre les preuves. \u2028\u2028\n\nFeatures : \n\u2028-Contr\u00f4ler le temps\u2028\n- Explorer et manipuler les indices\u2028\n- Narration interactive \n\u2028- Acteur Tomer Sisley en motion capture\u2028\u2028\n\nUniquement disponible en version fran\u00e7aise", "short_description": "Une exp\u00e9rience interactive o\u00f9 vous m\u00e8nerez l'enqu\u00eate au coeur de l'univers de la nouvelle s\u00e9rie VORTEX de France TV.\n\nAu c\u00f4t\u00e9 de Tomer Sisley, r\u00e9solvez l'enqu\u00eate en VR !"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chipoyjuan.com/engagements-de-confidentialite-vortex-vr/", "developer_terms_of_service_url": null, "publisher_name": "UNITY", "support_website_url": null, "website_url": "https://www.chipoyjuan.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "650593276544588"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "5564677316961358"}, {"status": "PUBLISHED", "id": "823158486260310"}]}, "baseline_offer": {"id": "823158486260310"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1671041580, "status": "PUBLISHED", "id": "5564677316961358"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6080585985377945", "version": "2.7"}, "id": "699045804782967", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5028656553904232", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "60805859