uluscdn.com/v/t64.5771-25/38982443_2237682463046837_4066551747371076286_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3JBGZJscJoQ7kNvgEQZJDj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtvl6aY9eek2ItbYhj3V1YoE_NGDpCXdNwRu__G0EOYQ&oe=66DDA1D6"}, {"file_name": "3.png", "id": "1138020400110318", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569433_1138020403443651_6729724910235364740_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tvT0J-1a7rQQ7kNvgHvIV5z&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXxYCAhBqtUKP2sWF5b8TfBzoPx_H1Tdi_Gb5_Uvo0Cg&oe=66DD9618"}, {"file_name": "4.png", "id": "560723175732043", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001698_560723179065376_1986450388414960360_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QsOJT24AL5IQ7kNvgGxd9uj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAb92n2k5QWqDtiU7ZOvLA5O6XDDP610LanW7CwRUtcQg&oe=66DD7528"}, {"file_name": "5.png", "id": "598736331667680", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031531_598736335001013_4405675035268347176_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q1FiK2AfEVoQ7kNvgFnE7vU&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8Unz8X707LSa0ZdYxoO7qkB0Dazsmo8tG6KlVwt2rbg&oe=66DD7168"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MatchFighter", "keywords": [], "long_description": "The best casual Match-Three game during your spare time, start your camping trip in the forest!\n\nThe Match Fighter forest lies a rich variety of treasures, and when you step out of your tent, you'll find that even at home you can experience the full atmosphere and joy of camping. If you look carefully at the treasure lot hiding in the bush, you will soon find two identical one! While playing, you can explore the forest and get in touch with nature, or you can return to the tent for a short nap, and grab the decorations in the room and you may have a surprise discovery.\n\nKey Features:\n- Immersive camping themed forest scenes, you can explore the surroundings while playing\n- A warm and exquisite tent just for you, touch the items inside and you may find something unexpected\n- A variety of matching models: cute animals, sweet food, cool toys & beautiful accessories\n- You will win a surprise reward if you pass the level within the time limit\n\nCome on, have you found the same items?", "short_description": "The best casual Match-Three game during your spare time, start your camping trip in the forest! When you step out of your tent, you can experience the full atmosphere and joy of camping! If you look carefully at the treasure lot hiding in the bush, you will soon find two identical one! \n\nFeatures:\n- Immersive camping themed forest scenes\n- A variety of matching models: cute animals, sweet food & cool toys \n- A warm and exquisite tent just for you, try to touch the items inside\n\nDownload it now!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://matchfightervr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "SUPLIFE PTE", "support_website_url": null, "website_url": "http://matchfightervr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "STRATEGY", "FOOD"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "459088022243334"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "5178976488880281"}, {"status": "PUBLISHED", "id": "3139654349619585"}]}, "baseline_offer": {"id": "3139654349619585"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1