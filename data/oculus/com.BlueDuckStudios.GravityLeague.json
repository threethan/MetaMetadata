612654_7336224501328013434_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRK_abNdvtEQ7kNvgFIuTYh&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASKwRWPlWhi8B21GLcS96aw&oh=00_AYANKBuqqvfdAUQu81bVNgYp8tgBWm4NaIYIIU8HgthHDg&oe=66E42116"}, {"file_name": "New Screenshot 6.png", "id": "994997358957760", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035383_994997362291093_6456362402046759002_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZMVicJfyAA8Q7kNvgFnutc3&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASKwRWPlWhi8B21GLcS96aw&oh=00_AYBMGXN0cLbd79I_5NZj2l0iK7rjyJE7urecsqpAjAugkw&oe=66E42E77"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Asset Landscape New 2.0.png", "id": "1417069628997019", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974621_1417069635663685_7375261956130428337_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vI1fpjePChcQ7kNvgGwgtFe&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASKwRWPlWhi8B21GLcS96aw&oh=00_AYB05Ic9-GQ5slI17zmXTV2PhajYtUveoZwVGSzhyMPYMA&oe=66E430FF"}, "display_name": "Gravity League", "keywords": ["tennis", "racket", "ball", "sport", "fitness"], "long_description": "# Welcome to the future of ball games!\n\nIn a world where gravity is no longer a limitation, the Gravity League has become the ultimate test of skill and endurance for athletes from all corners of the galaxy.\n\n**The rules are simple: 2 players, 1 ball, zero gravity - the first player to 11 goals wins.**\n\n- Compete online with opponents from across the galaxy\n- Play with your friends and compete in custom private matches\n- Explore all our wacky party modes\n- Make your way to the top in the epic Solo Campaign mode\n- Customize your gear with gloves in all shapes and sizes\n- Mix and match gloves to find the best playstyle for you\n- Unlock unique new athletes, balls, gloves, and stadiums\n- Team up with your friends for a 2v2 action\n\n\n**So strap on your Gravity Gloves and get ready to take on the competition!**", "short_description": "Welcome to the future of ball games! \n\nIn a world where gravity is no longer a limitation, the Gravity League has become the ultimate test of skill and endurance for athletes from all corners of the galaxy.\n\nThe rules are simple: 2 players, 1 ball, zero gravity - the first player to get 11 goals wins.\n\nSo strap on your Gravity Gloves and get ready to take on the competition!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://blue-duck-studios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Blue Duck Studios Ltd.", "support_website_url": null, "website_url": "https://blue-duck-studios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8413454788665288"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568683_3696532473919460_4710687887490255141_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z7eSnxpxH0gQ7kNvgE36luC&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASKwRWPlWhi8B21GLcS96aw&oh=00_AYAQUkwelu2OX33GOlgiltGS1QtNxkKlHlKS8Gr-QAv0tA&oe=66E42F87"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gravity League", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_t