uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035323_404298952370685_7359303556243195810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HAdotjUGwQ8Q7kNvgFu5dt2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKFFA9op32j79WWsTf46nCHOGe4izgEDcdoga3uRLFhw&oe=6720B81E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store Asset Landscape New 2.0.png", "id": "1242634573539896", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43931338_1242634576873229_3474418078564945004_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wk4OzeO2bJ4Q7kNvgFmmw-F&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCX8NRIquIXCZHh2f46vxvdXrqfiBjxDB5uJh4Mk57jQ&oe=6720CBF4"}, "display_name": "Gravity League", "keywords": ["tennis", "racket", "ball", "sport", "fitness"], "long_description": "# Welcome to the future of ball games!\n\nIn a world where gravity is no longer a limitation, the Gravity League has become the ultimate test of skill and endurance for athletes from all corners of the galaxy.\n\n**The rules are simple: 2 players, 1 ball, zero gravity - the first player to 11 goals wins.**\n\n- Compete online with opponents from across the galaxy\n- Play with your friends and compete in custom private matches\n- Explore all our wacky party modes\n- Make your way to the top in the epic Solo Campaign mode\n- Customize your gear with gloves in all shapes and sizes\n- Mix and match gloves to find the best playstyle for you\n- Unlock unique new athletes, balls, gloves, and stadiums\n- Team up with your friends for a 2v2 action\n\n\n**So strap on your Gravity Gloves and get ready to take on the competition!**", "short_description": "Welcome to the future of ball games! \n\nIn a world where gravity is no longer a limitation, the Gravity League has become the ultimate test of skill and endurance for athletes from all corners of the galaxy.\n\nThe rules are simple: 2 players, 1 ball, zero gravity - the first player to get 11 goals wins.\n\nSo strap on your Gravity Gloves and get ready to take on the competition!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://blue-duck-studios.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Blue Duck Studios Ltd.", "support_website_url": null, "website_url": "https://blue-duck-studios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8551875774823188"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75223483_2781988435300127_8718940128927237516_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=id30f1Vp0tQQ7kNvgHjXv7J&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuyIAM1UnVfonkAFi-Yal9h6uongIwP2bdbqfSbcZDzw&oe=6720CBBC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gravity League", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1722531600, "lastRevision": {"nodes": [{"id": "5934280506582741", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5934280436582748", "is_first_party": false, "e