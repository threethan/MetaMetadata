ZFHSOMM0Q7kNvgEMhHwe&_nc_ht=scontent.oculuscdn.com&_nc_gid=A06fWG4AzK3hgAR6Z1LwhFu&oh=00_AYBAVzR67B_T5Y5qgRk8DE-LCGlSyANhi1oj5Yr3lHlDcw&oe=66F5563F"}, {"file_name": "2.png", "id": "3683146305232029", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75292490_3683146308565362_5831197800896111586_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wb8MipInGaYQ7kNvgFFiVgV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A06fWG4AzK3hgAR6Z1LwhFu&oh=00_AYBJlaBglcOEzC3mWF5Y7g_zK6QNusUU8EbqsmsTbO9Juw&oe=66F5366E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CARAL PER\u00da", "keywords": [], "long_description": "From anywhere in the world, it transports you to ancient Peru, South America, 5000 years ago, 4400 years before the Inca Civilization, to get in touch with the recovered social history of the important archaeological heritage of the Caral Civilization. Ideal for students, travelers, and history enthusiasts, this app is your gateway to Caral, recognized as one of the oldest civilizations in the world. Get ready for a fascinating journey back in time!", "short_description": "Immersive and interactive EDUCATIONAL experience inspired by the values of the Caral Civilization, the oldest in the Americas."}, {"images": {"nodes": []}, "id": "1175094040282755", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CARAL PER\u00da", "keywords": [], "long_description": "Desde cualquier parte del mundo, te traslada al antiguo Per\u00fa, Am\u00e9rica del Sur, 5000 a\u00f1os atr\u00e1s, 4400 a\u00f1os antes de la Civilizaci\u00f3n Inca, para ponerte en contacto con la historia social recuperada del importante patrimonio arqueol\u00f3gico de la Civilizaci\u00f3n Caral. Ideal para estudiantes, viajeros y entusiastas de la historia, esta app es tu puerta de entrada a Caral, reconocida como una de las civilizaciones m\u00e1s antiguas del mundo. \u00a1Prep\u00e1rate para un fascinante viaje en el tiempo!", "short_description": "Experiencia EDUCATIVA inmersiva e interactiva inspirada en los valores de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica. "}]}, "developer_name": "Zona Arqueol\u00f3gica Caral", "developer_privacy_policy_url": "https://www.artemar.net/politicas-de-privacidad-zona-caral/", "developer_terms_of_service_url": null, "publisher_name": "Zona Arqueol\u00f3gica Caral", "support_website_url": null, "website_url": "https://www.gob.pe/caral", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_PE", "en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8185576888153588"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982647_340053819124606_7455289090314279902_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6fLcZX1-2MUQ7kNvgGk3Azx&_nc_ht=scontent.oculuscdn.com&_nc_gid=A06fWG4AzK3hgAR6Z1LwhFu&oh=00_AYCyFpBVQksYnHkaDnCcIZolDLHdDbdrq4HxrKqJI5YzKg&oe=66F554A2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CARAL PER\u00da", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}], "release_date": 1715876400, "lastRevision": {"nodes": [{"id": "7768251709886110", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"defa