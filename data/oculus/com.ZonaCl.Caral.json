, "short_description": "Experiencia EDUCATIVA inmersiva e interactiva inspirada en los valores de la Civilizaci\u00f3n Caral, la m\u00e1s antigua de Am\u00e9rica. "}]}, "developer_name": "Zona Arqueol\u00f3gica Caral", "developer_privacy_policy_url": "https://www.artemar.net/politicas-de-privacidad-zona-caral/", "developer_terms_of_service_url": null, "publisher_name": "Zona Arqueol\u00f3gica Caral", "support_website_url": null, "website_url": "https://www.gob.pe/caral", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_PE", "en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8185576888153588"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982647_340053819124606_7455289090314279902_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_WXVsE6OqlsQ7kNvgF1PQHl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWRwY6lPy7tBivJ7lIzW_tf&oh=00_AYBlLOcy8CwbQrfOGyeBg7ZZhZlLkZXpOX3VI9yr40tePA&oe=66E825A2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CARAL PER\u00da", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}], "release_date": 1715876400, "lastRevision": {"nodes": [{"id": "7768251709886110", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"appl