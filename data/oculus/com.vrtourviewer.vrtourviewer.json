66E56477"}, {"file_name": "Screenshot-Houten-01.png", "id": "754917135427131", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75549075_754917138760464_7167773432900640253_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fEl2GXnV6T4Q7kNvgG0ITz8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdcAKcYiPIcn8M0KhfVoGIiqnGbFnFiNJmcz_KpuX1Ig&oe=66E58DED"}, {"file_name": "Screenshot-Menu-01.png", "id": "128397392483898", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75488382_128397395817231_4481716845080667972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7dEJi5oO4N4Q7kNvgGCwsud&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWcUusrAKAr3uN9w1mU4AfUk5EB_lN7cSZulO258KHBw&oe=66E58BCF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Tourviewer", "keywords": [], "long_description": "VR Tourviewer can handle tours exported with HTML5 output from Pano2VR. \nBrowse the featured tours, add your own online URLs or show tours stored locally on your device for offline use.\n\nSupported features: monoscopic and stereoscopic tours, hotspot navigation, image and video overlays, surround sound and 360 panorama videos. Skins and scripts aren't supported. As extra feature, you can easily add falling leaves, snow or rain to your panoramas for an even more immersive experience!\n\nA version without watermarks or a customized/white label version is available from https://www.vrtourviewer.com\n\nDeveloped by 3DV - The Netherlands. \nNote that 3DV is not affiliated with Garden Gnome, the creator of Pano2VR.", "short_description": "Use VR Tourviewer to experience virtual reality tours created with Pano2VR, online and offline."}]}, "developer_name": "Ruud van Reenen - 3DV", "developer_privacy_policy_url": "https://www.vrtourviewer.com/privacy-policy-vr-tourviewer/", "developer_terms_of_service_url": "https://www.vrtourviewer.com/terms-of-service/", "publisher_name": "3DV Netherlands", "support_website_url": "https://www.vrtourviewer.com/knowledge-base/", "website_url": "