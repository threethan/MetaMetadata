367_505177420418144386_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=88xHmBcEBNMQ7kNvgEjjMhD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXAx1pO73nd80IgZb8aXNhAFewj2md0f73JaFLFBxv4w&oe=676FDC9B"}, {"file_name": "Screenshot-Villa-int-01.png", "id": "894375968040890", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75280981_894375971374223_2741295397217328438_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HR_s3psocpsQ7kNvgGWX9HM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxH_Bg2-QxDvxCGNGeXS2xDbV9wx8ZVGoXrcl413dcxA&oe=676FD1F7"}, {"file_name": "Screenshot-Houten-01.png", "id": "754917135427131", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75549075_754917138760464_7167773432900640253_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AI2QoU1nQtcQ7kNvgEQW7Tu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_1B_tGgC_1Ai1K2AHV0NtE3iv0__Bo4jXyaNN4Y5-Iw&oe=676FFB6D"}, {"file_name": "Screenshot-Menu-01.png", "id": "128397392483898", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75488382_128397395817231_4481716845080667972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sml2cP9zn-AQ7kNvgGjPP-e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBrYAp9hJZ56CL4qnPcWh04HXxOlxIcKNiN3k_p0V4h3A&oe=676FF94F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Tourviewer", "keywords": [], "long_description": "VR Tourviewer can handle tours exported with HTML5 output from Pano2VR. \nBrowse the featured tours, add your own online URLs or show tours stored locally on your device for offline use.\n\nSupported features: monoscopic and stereoscopic tours, hotspot navigation, image and video overlays, surround sound and 360 panorama videos. Skins and scripts aren't supported. As extra feature, you can easily add falling leaves, snow or rain to your panoramas for an even more immersive experience!\n\nA version without watermarks or a customized/white label version is available from https://www.vrtourviewer.com\n\nDeveloped by 3DV - The Netherlands. \nNote that 3DV is not affiliated with Garden Gnome, the creator of Pano2VR.", "short_description": "Use VR Tourviewer to experience virtual reality tours created with Pano2VR, online and offline."}]}, "developer_name": "Ruud van Reenen - 3DV", "developer_privacy_policy_url": "https://www.vrtourviewer.com/privacy-policy-vr-tourviewer/", "developer_terms_of_service_url": "https://www.vrtourviewer.com/terms-of-service/", "publisher_name": "3DV Netherlands", "support_website_url": "https://www.vrtourviewer.com/knowledge-base/", "website_url": "http://www.vrtourviewer.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "EXPLORATION", "UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1101831810603503"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1114383845748381"}]}, "baseline_offer": {"id": "1114383845748381"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1617684900, "status": "PUBLISHED", "id": "1114383845748381"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7912587392136497", "version": "1.4.503"}, "id": "103108355043675", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBina