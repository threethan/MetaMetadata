e virtual reality tours created with Pano2VR, online and offline."}]}, "developer_name": "Ruud van Reenen - 3DV", "developer_privacy_policy_url": "https://www.vrtourviewer.com/privacy-policy-vr-tourviewer/", "developer_terms_of_service_url": "https://www.vrtourviewer.com/terms-of-service/", "publisher_name": "3DV Netherlands", "support_website_url": "https://www.vrtourviewer.com/knowledge-base/", "website_url": "http://www.vrtourviewer.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "EXPLORATION", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1101831810603503"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1114383845748381"}]}, "baseline_offer": {"id": "1114383845748381"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1617684900, "status": "PUBLISHED", "id": "1114383845748381"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7912587392136497", "version": "1.4.503"}, "id": "103108355043675", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3829092873819323", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7912587392136497"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name"