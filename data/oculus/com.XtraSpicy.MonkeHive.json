25/38974632_1170914783995923_7715511273648534964_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RyaOSm50sOQQ7kNvgEKsADI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAAHokD0l9f36u_4bGLa2wg7tpQOK64yUbwMDGO_ACJ5g&oe=67349698"}, "display_name": "Monke Hive", "keywords": ["Monkey", "Monke", "MonkeHive"], "long_description": "Monke Hive is a game that has Gorilla Tag movement. There is a lot to explore and a lot to do. Spawn and set your name and change your color of your Monke. Buy cosmetics with your honey and look nice and dripped out. Go play some amazing looking maps such as Forest, a nice and big map where all the Monkes can hang out and enjoy the forest. Go play gamemodes like PVP and more! Download Monke Hive to experience the life as a small Monke and feel like Monke!", "short_description": "Monke Hive is a gorilla tag fan game created by the ultimate spicy Jalapeno and ArrowVR!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/monke-hive/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/monke-hive/terms-of-service", "publisher_name": "Jalapeno and Arrow", "support_website_url": null, "website_url": "https://sites.google.com/view/monke-hive", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8870342526331350"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1