ng", "id": "569944126949705", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974485_1956756354421473_8431680320046104576_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kF9ORvwyQw4Q7kNvgE1_Cwa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDlipPPoJeWlGyyI4yefD1QDCtXBuabrdKWzOq1Wenyg&oe=66F6B4D2"}, {"file_name": "migrated_image.png", "id": "226896995033987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974842_514783348997303_1299368937233842176_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UR38gfB5AJoQ7kNvgHZE8d3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZjgaOtURSlj2ORV2CGDvU6S2S7g2_5-JJrIFwlBMOgQ&oe=66F6B038"}, {"file_name": "migrated_image.png", "id": "225262792002354", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974616_581521202304948_2844948661417279488_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sAtJfFsDK_oQ7kNvgG_rSt5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBo6qPogz60ESVRt9R4vmyhjV6744tX5kl9eNXThhDz7A&oe=66F6B57B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/bhFV0w", "id": "2094325244198480", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001676_2094325247531813_2271249431351263232_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u-JZP8TO9FEQ7kNvgEaDLzj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCW4UoF_UFublHU3F67KqTxzYfwHNtM94ogMEzlWyk0Og&oe=66F684CD"}, "display_name": "Void Racer", "keywords": ["race", "racing", "speed", "bikes", "motorbikes"], "long_description": "The thrill of racing at its most intense! Not for the faint-hearted!\n\nRev up your hover bike and fight AI opponents for the sharpest lines and the quickest times.\n\nTest your racing skills to the limit; this exhilarating gaming experience delivers pure unadulterated speed.\n\nFeatures:\n- 8 tracks to master, from the smooth and fast to the twisted and devious\n- 3 bikes with unique handling characteristics\n- 8 bonus items to wield\n- 3 game modes to beat\n- 4 weapons to punish your opponents\n- Learn and unlock new stages in career mode\n- Compete against your friends on the leaderboards to get the fastest lap times\n- Prove yourself in the weekly leaderboard challenge\n\nFollow @CoplanarGames to get news about new tracks and features coming soon!", "short_description": "The thrill of racing at its most intense! Not for the faint-hearted!\n\nTest your racing skills to the limit; this exhilarating gaming experience delivers pure unadulterated speed.\n\n8 tracks, from the smooth and fast to the twisted and devious\n3 bikes to master\n8 bonus items to wield\n3 game modes to beat\n4 weapons to punish with\nUnlock new stages in career mode\nBeat friends on the leaderboards to get the fastest laps\nProve yourself in the weekly leaderboard challenge"}]}, "developer_name": "Coplanar Games", "developer_privacy_policy_url": "http://coplanargames.com/voidracer/privacypolicy.html", "developer_terms_of_service_url": "http://coplanargames.com/voidracer/tos.html", "publisher_name": "Coplanar Games", "support_website_url": null, "website_url": "http://coplanargames.com/voidracer.html", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1106334610204940"}}]}, "scheduled_offers": {"count": 15, "nodes": [{"status": "PUBLISHED", "id": "1199197947121299"}, {"status": "PUBLISHED", "id": "603949656682365"}, {"status": "PUBLISHED", "id": "371591806761147"}, {"status": "PUBLISHED", "id": "257439478491147"}, {"status": "PUBLISHED", "id": "1833470206756488"}, {"status": "PUBLISHED", "id": "282963989083633