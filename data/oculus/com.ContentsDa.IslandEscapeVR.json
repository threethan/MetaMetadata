05.png", "id": "731923352222764", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035468_731923358889430_2247651461107134769_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H_GP5xnr2hgQ7kNvgG-_Apt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB08iSDQWYrLSmT0tJ7RdiMs7u9ixfuhF9t8M7nna0mGA&oe=6731E802"}, {"file_name": "Island Escape VR_Screenshot06.png", "id": "401681748914665", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001655_401681752247998_1398502126920734381_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CYjfGctIe2AQ7kNvgEA6u3B&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtFuvXxdssespBYyfwQ-X6CwTODE_swXmhe-QIGkBNVQ&oe=6731FE94"}, {"file_name": "Island Escape VR_Screenshot07.png", "id": "1330016981041406", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395592_1330016984374739_5361419578974070101_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tp5naVxVmn0Q7kNvgGPFXN9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAei9HLJNsgbJq1uc0Y0idvR1KKVF7Z79kKQkZHeeSNqA&oe=6731E67A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Island Escape_Landscape.png", "id": "1515471865898190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974668_1515471869231523_4510089248881648284_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ujhj9ei7srMQ7kNvgEgCIdx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQbJ-gm5gOy3MlbSH1zY6lsuiIzFxG2NOjK4hYUSm5ww&oe=6731E2E0"}, "display_name": "Island Escape VR - ContentsDa Science Experiment", "keywords": ["story", "island", "escape", "science", "contentsda"], "long_description": "1. Secure: From the airplane door, use the axe to take a leafless tree to make firewood, then place it in the marked location.\n2. Build a fire: Use the newspaper to place on top of the firewood and use the tinder to light it.\n3. Build a shelter: Find a nearby cave and build your own house to provide a safe space from animals.\n4. Repel mosquitoes: Use plastic bottles and a knife to make mosquito repellent and place it around your home to protect it from mosquitoes.\n5. Secure drinking water: Collect seawater in a pot and use it with cups to boil over a campfire.\n6. Gather food: Use the axe to follow the red light into the forest to gather fruit and fish.\n7. Salt making: Use water from the ocean to make salt to preserve food. \n8. Sending a distress signal: Send an international distress signal by creating a triangle signal and SOS letters in marked locations by lighting a fire.\n9. Generate electricity: Make light bulbs to light up your home and survive in challenging environments.\n10. Raft building: Chop down a tree with an axe, use rope to build a raft, and row across the ocean for a successful escape.\n11. Sea Rescue: Hone your survival skills in environments like Antarctica while waiting for rescue, and take on new challenges to escape.", "short_description": "Immerse yourself in a virtual reality adventure on a deserted island. Solve puzzles and learn survival skills in this interactive and educational experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_track