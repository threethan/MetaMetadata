5i7Bxc6B2CbHbQC3Fw&oe=67386FA8"}]}, "id": "1971617273338852", "locale": "en_US", "screenshots": [{"file_name": "ApplicationFrameHost_q074CcCttp.png", "id": "2353090925034175", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974663_2353090928367508_9127981151118356997_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BKZWc7-poCcQ7kNvgEWmhz2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChwLfZYQ71HQPSrwlycqsW-WSCxjA5fw_tDK7m3n60fw&oe=67387382"}, {"file_name": "ApplicationFrameHost_pYT27I1Qpx.png", "id": "9123430021021473", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86629762_9123430027688139_3601798344649351120_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-UnVofq1jUQ7kNvgEWFHJz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkRwp9Cv6L5SS2JNrPgGvhOr-MjTKsC7CTODvoW7kH4g&oe=67389816"}, {"file_name": "ApplicationFrameHost_QpNYFXB5dh.png", "id": "1074961070935466", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974521_1074961074268799_6076192810840255095_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JSwQzfrPdi8Q7kNvgFH8hlP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhTqdMH-Bz-xgTznlyKbStFppEq7EQv17M-kU9-2fQPA&oe=67388B3F"}, {"file_name": "ApplicationFrameHost_5dFGNxdM82.png", "id": "2208224916223553", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031360_2208224922890219_3883200071597463546_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tAiTFpzzY5UQ7kNvgGER2iC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVY5Eg0ttg-ADrBii0qGjTwWFnJwq7xZ27f-T8PUr1-g&oe=6738760D"}, {"file_name": "ApplicationFrameHost_WzGsUDeTiu.png", "id": "860402652843971", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572945_860402656177304_2269817979898965800_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GDsLl1VEg8QQ7kNvgEn8OrI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwgV5BlWivUFR99Lk4nM_o4qFx-3kWVGgoLkQ-awgiIg&oe=67387AD1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Island Escape_Landscape.png", "id": "1515471865898190", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974668_1515471869231523_4510089248881648284_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ava5FEp6RWYQ7kNvgH7M8Vt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYRAPt1WtwTSBhUOwZnNxPnYbdzpMmJ4bgkvm9vSL3iw&oe=67387A60"}, "display_name": "Island Escape VR - ContentsDa Science Experiment", "keywords": ["story", "island", "escape", "science", "contentsda"], "long_description": "1. Secure: From the airplane door, use the axe to take a leafless tree to make firewood, then place it in the marked location.\n2. Build a fire: Use the newspaper to place on top of the firewood and use the tinder to light it.\n3. Build a shelter: Find a nearby cave and build your own house to provide a safe space from animals.\n4. Repel mosquitoes: Use plastic bottles and a knife to make mosquito repellent and place it around your home to protect it from mosquitoes.\n5. Secure drinking water: Collect seawater in a pot and use it with cups to boil over a campfire.\n6. Gather food: Use the axe to follow the red light into the forest to gather fruit and fish.\n7. Salt making: Use water from the ocean to make salt to preserve food. \n8. Sending a distress signal: Send an international distress signal by creating a triangle signal and SOS letters in marked locations by lighting a fire.\n9. Generate electricity: Make light bulbs to light up your home and survive in challenging environments.\n10. Raft building: Chop down a tree with an axe, use rope to build a raft, and row across the ocean for a successful escape.\n11. Sea Rescue: Hone your survival skills in environments like Antarctica while waiting for rescue, and take on new challenges to escape.", "short_description": "Immerse yourself in a virtual reality adventure on a deserted island. Solve puzzles and learn survival skills in this interactive and educational experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8420975171343713"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572923_1424039911798210_4153306417758650590_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3esLlXfhNZsQ7kNvgEuC8J7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOIQ6v8ET5QBvilViI3vPyWOy_oM9WtyaaQoz7yeX7OA&oe=673867C9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Island Escape VR - ContentsDa Science Experiment", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1699915623, "lastRevision": {"nodes": [{"id": "6094542410653679", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6094542407320346", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "ia