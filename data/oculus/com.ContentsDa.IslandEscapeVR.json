.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FsUmrA7fLEEQ7kNvgH7XYQu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVilfqzLIaQus5lkhLPX4v-zy8hw6Ixwg87QBusRtLCg&oe=6731ED54"}, "display_name": "Island Escape VR", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other. This package includes collection of 1 experiment.  This application supports two languages, Korean and English."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_T