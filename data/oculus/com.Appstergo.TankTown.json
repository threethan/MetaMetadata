": "367944129620672", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65397209_367944132954005_7032217925041916_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpteE8_fyaQQ7kNvgHL35r0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSgUDlkhElkkaOV7YD5pAX8IkICyS3Y05RcOw4Zg6cJg&oe=67596FCD"}, {"file_name": "HighresScreenshot00001.png", "id": "1048900393282398", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982464_1048900396615731_7369046601627020849_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-PXwwEww6uQQ7kNvgFsa0o-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6dqQE__FjTWJV_cDIqjYOGYIQyt8bpED01TflOeVvGA&oe=675992FE"}, {"file_name": "HighresScreenshot00002.png", "id": "3761736190821123", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003258_3761736194154456_4236457750807178398_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6v2ZnUL2gwYQ7kNvgFgZQxW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUnFjvAX-rM8W7-kiwUnjuIQ9gUcGmsFOxVQZ08SOicA&oe=675990EC"}, {"file_name": "HighresScreenshot00010.png", "id": "1099494831590362", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974713_1099494834923695_717256504208724278_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vzQrGudnNHcQ7kNvgGxVFl3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv3_zpPTwoyoprGt6I4AhN7JNdZoFfqRDNpQxOCdKfew&oe=67596C1A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Tank Town VR", "keywords": [], "long_description": "Step into a thrilling virtual reality experience inspired by classic titles like BattleCity and Tank Battalion. This VR game puts you in the driver\u2019s seat of a tank, pitting you against waves of enemy tanks with diverse abilities. With 50 intense battles across three difficulty levels, you\u2019ll engage in various modes such as base attack, base defense, and capture the flag. As you fight for survival, collect power-ups to enhance your tank and gain an edge in battle.\n\nChallenge yourself to beat the game on its highest difficulty\u2014a feat no one has yet accomplished. Whether you play as a guest in non-ranked battles or log in with your Appstergo account to climb the ranks, the challenge is always intense. Best of all, future updates will bring exciting new features, including multiplayer and cooperative gameplay, so you can team up or face off with friends.", "short_description": "Immerse yourself in a retro-inspired VR tank battle game! Take control of a tank and engage in 50 challenging battles, with varying difficulty levels and gameplay modes like base attack, defense, and capture the flag. Unlock power-ups, face off against enemy tanks with unique traits, and push your skills to the limit. No one has conquered the highest difficulty\u2014yet. Play as a guest or rank up with an Appstergo account. Multiplayer and co-op modes coming soon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://appstergo.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Appstergo", "support_website_url": null, "website_url": "https://appstergo.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8467251360037899"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1195761905047189"}]}, "baseline_offer": {"id": "1195761905047189"}, "