png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zs4Ce4BDmekQ7kNvgEISfho&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDEj68ZdBzdfEjoPtRkfaM8eL-AEtLo-Oo-p9dU8zoh9g&oe=6730AAAC"}, {"file_name": "Undercover_Screenshots_05.png", "id": "743045670695496", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974602_743045674028829_4316921965278868238_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=31vYhAKhuDUQ7kNvgGS9Irk&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCIE-KWffa0kko-QOKpRUXqnxEMBNDSgJRChwgWmoHR9w&oe=673097C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Undercover_MRUpdate_Landscape_2560x1440.png", "id": "373812651999851", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86655527_373812658666517_8384652531129662568_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LUXRvY6BTKYQ7kNvgGbuV4v&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDZKsA_9so7O5uG0f5gSgTWkgWLTh10Kyu4DIH7DG5PoA&oe=6730B75C"}, "display_name": "Under Cover", "keywords": ["FPS", "arcade", "action", "guns", "shooter"], "long_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too badass to stay undercover - in the action-packed buddy-cop campaign.\n\nYour mission: infiltrate evil megacorp Infinidyne, take down CEO Pax Harrison, and shut down his mind-control technology before he turns billions into cybernetic meat puppets.\n\n\u2022 Classic lightgun arcade action, made for VR.\n\u2022 Take on Infinidyne solo with an AI partner or co-op with an online friend.\n\u2022 Reload and dodge enemy fire like an action hero with the Active Cover System.\n\u2022 Over-the-top cinematic action with explosions, bullet time, and environmental destruction.\n\u2022 Retro score system rewards aim, speed, and chained kills.\n\u2022 Use your skills, the environment, and a wide variety of special weapons to take out goons, advanced enemies, and Infinidyne bosses.\n\nAre you ready to go Under Cover?", "short_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\n\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too badass to stay undercover - in the action-packed buddy-cop campaign."}]}, "developer_name": "Sigtrap", "developer_privacy_policy_url": "http://www.sigtrapgames.com/home/under-cover-terms-of-service-and-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Coatsink", "support_website_url": null, "website_url": "https://coatsink.com/games/undercover", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP"], "id": "573262264449939"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "823923203228011"}, {"status": "PUBLISHED", "id": "3759642907651867"}, {"status": "PUBLISHED", "id": "7948186891861056"}, {"status": "PUBLISHED", "id": "1533709337408516"}]}, "baseline_offer": {"id": "1533709337408516"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "823923203228011"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []},