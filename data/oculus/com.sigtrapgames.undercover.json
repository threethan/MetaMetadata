.com/v/t64.5771-25/38982727_407655761596166_2860581410574744450_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d3_L6xQ_tEwQ7kNvgGUDvjv&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYD_OOc0LnkXYlRCy_9tuopKaoDO8jBVbjE_gOMRWxUJHw&oe=66EC0173"}, {"file_name": "Undercover_Screenshots_02.png", "id": "344343141710918", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_344343145044251_5862912704555799591_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kNH83t197D8Q7kNvgH0_YfT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYDSrm34yyRZ3wsZK2SvLFlHNitZxno5HAZxO-Fm1TALog&oe=66EC08BD"}, {"file_name": "Undercover_Screenshots_03.png", "id": "343588211960361", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_343588215293694_8094110177139039118_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N73adQpz0ZQQ7kNvgHeka8i&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYDDr-BHPStwQPipwgWkrMXnkPATUtax7OkCe0bhjt0P8g&oe=66EBFB5A"}, {"file_name": "Undercover_Screenshots_04.png", "id": "720210893537540", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031399_720210896870873_1607751032437242072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OZJvtX1GF0gQ7kNvgFxTD2J&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYBY4zg4hymyNY0htZM3ZrP7CGqbqG8wHL_AMxQ47nXOvQ&oe=66EC1CAC"}, {"file_name": "Undercover_Screenshots_05.png", "id": "743045670695496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974602_743045674028829_4316921965278868238_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8BDApasgwL4Q7kNvgHZmMRt&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYDS_MKrFIpuaLy4XPCs-yg8LIFU85mOHWdUdRm_yrqDfg&oe=66EC09C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Undercover_MRUpdate_Landscape_2560x1440.png", "id": "373812651999851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655527_373812658666517_8384652531129662568_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JIHFM6q8Q8MQ7kNvgFYU7Ik&_nc_ht=scontent.oculuscdn.com&_nc_gid=Al8FlYKagmIBwGEtQBaxvFR&oh=00_AYBRITr7Sd7gp8x41UMEQ3g3ZonXc5CdW3WSzsNPmh1QXA&oe=66EC295C"}, "display_name": "Under Cover", "keywords": ["FPS", "arcade", "action", "guns", "shooter"], "long_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too cool to stay undercover - in the action-packed buddy-cop campaign.\n\nYour mission: infiltrate evil megacorp Infinidyne, take down CEO Pax Harrison, and shut down his mind-control technology before he turns billions into cybernetic meat puppets.\n\n\u2022 Classic lightgun arcade action, made for VR.\n\u2022 Take on Infinidyne solo with an AI partner or co-op with an online friend.\n\u2022 Reload and dodge enemy fire like an action hero with the Active Cover System.\n\u2022 Over-the-top cinematic action with explosions, bullet time, and environmental destruction.\n\u2022 Retro score system rewards aim, speed, and chained kills.\n\u2022 Use your skills, the environment, and a wide variety of special weapons to take out goons, advanced enemies, and Infinidyne bosses.\n\nAre you ready to go Under Cover?", "short_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\n\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too cool to stay undercover - in the action-packed buddy-cop campaign."}]}, "developer_name": "Sigtrap", "developer_privacy_policy_url": "https://coatsink.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Coatsink", "support_website_url": null, "website_url": "https://coatsink.com/games/undercover", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id"