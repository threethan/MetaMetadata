ame": "Undercover_Screenshots_04.png", "id": "720210893537540", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031399_720210896870873_1607751032437242072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c0D7iDy68V4Q7kNvgG9iUH-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR6VMTKWR-QBnuIpDUFigY9&oh=00_AYAYgpLdp_9PjHobriKicO4IfRpCMZYNRvyjuMoNDvFKMQ&oe=66F162AC"}, {"file_name": "Undercover_Screenshots_05.png", "id": "743045670695496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974602_743045674028829_4316921965278868238_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iWsXRBWssqQQ7kNvgEbetMD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR6VMTKWR-QBnuIpDUFigY9&oh=00_AYAqVP_5Z27O5JbwNfn_tAhZziN0Bf_BWt2iRk6ykiEfdQ&oe=66F14FC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Undercover_MRUpdate_Landscape_2560x1440.png", "id": "373812651999851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655527_373812658666517_8384652531129662568_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kbpdbJysf28Q7kNvgG56dHX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR6VMTKWR-QBnuIpDUFigY9&oh=00_AYArGj1YZQ5pV_OXE2jURmiFda4TeYmJHBYMF0gj-sElRg&oe=66F1371C"}, "display_name": "Under Cover", "keywords": ["FPS", "arcade", "action", "guns", "shooter"], "long_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too badass to stay undercover - in the action-packed buddy-cop campaign.\n\nYour mission: infiltrate evil megacorp Infinidyne, take down CEO Pax Harrison, and shut down his mind-control technology before he turns billions into cybernetic meat puppets.\n\n\u2022 Classic lightgun arcade action, made for VR.\n\u2022 Take on Infinidyne solo with an AI partner or co-op with an online friend.\n\u2022 Reload and dodge enemy fire like an action hero with the Active Cover System.\n\u2022 Over-the-top cinematic action with explosions, bullet time, and environmental destruction.\n\u2022 Retro score system rewards aim, speed, and chained kills.\n\u2022 Use your skills, the environment, and a wide variety of special weapons to take out goons, advanced enemies, and Infinidyne bosses.\n\nAre you ready to go Under Cover?", "short_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\n\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too badass to stay undercover - in the action-packed buddy-cop campaign."}]}, "developer_name": "Sigtrap", "developer_privacy_policy_url": "http://www.sigtrapgames.com/home/under-cover-terms-of-service-and-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Coatsink", "support_website_url": null, "website_url": "https://coatsink.com/games/undercover", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP"], "id": "573262264449939"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "823923203228011"}, {"status": "PUBLISHED", "id": "3759642907651867"}, {"status": "PUBLISHED", "id": "7948186891861056"}, {"status": "PUBLISHED", "id": "1533709337408516"}]}, "baseline_offer": {"id": "1533709337408516"}, "is_approved": true, "