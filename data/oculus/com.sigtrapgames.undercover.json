zycAEQ7kNvgEVR1d3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsN39AQXyW144pc6Sooj7rWgkQDt7qwbY6J56iCP8noA&oe=67090273"}, {"file_name": "Undercover_Screenshots_02.png", "id": "344343141710918", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_344343145044251_5862912704555799591_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQ0cwtc0r00Q7kNvgEPl0mT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDoXRgZcUhDzQvA6L2nAIjUpKtNp2QSsdfruz0Fs3b8WA&oe=670909BD"}, {"file_name": "Undercover_Screenshots_03.png", "id": "343588211960361", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036657_343588215293694_8094110177139039118_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HgfRjcnbFOEQ7kNvgFcL8pI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChg2muUZVSgm427Q3_S0Vk6rFwT3KMc0wRsvav2f2B9A&oe=6708FC5A"}, {"file_name": "Undercover_Screenshots_04.png", "id": "720210893537540", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031399_720210896870873_1607751032437242072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MeKbIJw83k4Q7kNvgFSN1bh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcWanj434YiUZyYzzHx-IFXDzQOJqHYdJfjaTfBeuP-A&oe=67091DAC"}, {"file_name": "Undercover_Screenshots_05.png", "id": "743045670695496", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974602_743045674028829_4316921965278868238_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aRisRCt-_uUQ7kNvgGZclDO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmujoLYoeJXa2R_TOd3UjqVTWm-WofJNyzaVcpE0Yayw&oe=67090AC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Undercover_MRUpdate_Landscape_2560x1440.png", "id": "373812651999851", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86655527_373812658666517_8384652531129662568_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YclUzP6-UQcQ7kNvgEJOt3P&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACWD96B4CsdWLI5XDg0SnFPuFw2ffArkp3UQDVMVTJzw&oe=67092A5C"}, "display_name": "Under Cover", "keywords": ["FPS", "arcade", "action", "guns", "shooter"], "long_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too cool to stay undercover - in the action-packed buddy-cop campaign.\n\nYour mission: infiltrate evil megacorp Infinidyne, take down CEO Pax Harrison, and shut down his mind-control technology before he turns billions into cybernetic meat puppets.\n\n\u2022 Classic lightgun arcade action, made for VR.\n\u2022 Take on Infinidyne solo with an AI partner or co-op with an online friend.\n\u2022 Reload and dodge enemy fire like an action hero with the Active Cover System.\n\u2022 Over-the-top cinematic action with explosions, bullet time, and environmental destruction.\n\u2022 Retro score system rewards aim, speed, and chained kills.\n\u2022 Use your skills, the environment, and a wide variety of special weapons to take out goons, advanced enemies, and Infinidyne bosses.\n\nAre you ready to go Under Cover?", "short_description": "Under Cover: a Lightgun Cover Shooter inspired by arcade classics.\n\nDuck to reload with the groundbreaking Active Cover System. Rack up solo or co-op high scores as Red-Eye or Magnum - two undercover agents too cool to stay undercover - in the action-packed buddy-cop campaign."}]}, "developer_name": "Sigtrap", "developer_privacy_policy_url": "https://coatsink.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Coatsink", "support_website_url": null, "website_url": "https://coatsink.com/games/undercover", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": f