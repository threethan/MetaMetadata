U throttling values, and the number of tears and stale frames per second."}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/documentation/mobilesdk/latest/concepts/mobile-ovrmetricstool/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "671371111438494"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "901544967604917"}]}, "baseline_offer": {"id": "901544967604917"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1687539600, "status": "PUBLISHED", "id": "901544967604917"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8331897876869854", "version": "6.0.0.0.264"}, "id": "639589076503727", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2372625889463779", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8331897876869854"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 17255