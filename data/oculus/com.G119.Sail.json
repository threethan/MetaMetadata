o2.png", "id": "138053021789418", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001692_138053025122751_2501752079125746246_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jG0oO-l_FlUQ7kNvgHmLLOq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjPGdBXmgCRAAkU1OO2nZw5K01Z7DKRV7lQ33xJC9t4Q&oe=66DC4E0E"}]}, "id": "301803319370444", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "3248487278809983", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974837_3248487285476649_4356503903890829041_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-W6BwZJQu60Q7kNvgFyYjl-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHHLDlfmbo34wzZiRDbcKI5IClflNGJtNU19YAvCNQOQ&oe=66DC3D3B"}, {"file_name": "2.png", "id": "542952624198138", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223477_542952627531471_4751007705742668270_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wKUSAOTX4LoQ7kNvgFULjdZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJjsS_7nRWNO3ZSVavWEnI6Zja1qZtY23-WEm52FHwMA&oe=66DC2C39"}, {"file_name": "3.png", "id": "717122002732032", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_717122006065365_6886394787173543160_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tTEdD5z_UaEQ7kNvgGnpiTo&_nc_ht=scontent.oculuscdn.com&oh=00_AYA35qAthmRPckwBCocnJwZVBUC9DffuoCnGVqID7uKdUQ&oe=66DC2BD1"}, {"file_name": "4.png", "id": "759226668767753", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_759226672101086_4654991774101485944_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sj-Y92PwBEUQ7kNvgEmyAJ6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJZGY_BlmeJb-A6KRT-x4v_l0gGxWVgnSsWFaQvv6-CA&oe=66DC27F4"}, {"file_name": "5.png", "id": "5125891664146319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303837_5125891667479652_8512781975491820540_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-CMAp6y6UsQQ7kNvgETNrxv&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbBgzA3FyoNh5I8CGM_PwgPqGa8LqnRJr5A9gHJSEB4Q&oe=66DC2215"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sail logo5.png", "id": "356739772677881", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031340_356739776011214_4752399952396963553_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LdhLIUv-fGAQ7kNvgF9yqMo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrJDBvV2lGtRU-VcNxbXWWBnzBebN9Kh7ATKjFH2qgQQ&oe=66DC338F"}, "display_name": "Sail Single Player", "keywords": [], "long_description": "UNLEASH your Inner Pirate in SAIL the Open World VR Pirate game!!!\n\nEarn your Pirate reputation through EPIC voyages where you'll test yourself by collecting as much treasure as possible and bringing it back safely to your Pirate hideout.\n\nBUT BE WARNED . . .\n\nYou're not the only Pirate seeking fortune on the seas.\n\nFight off Pirate enemies on land with your Pirate weapon of choice\n\n- OR -\n\n Battle them on the seas using your ship's cannons and VOICE COMMANDS!\n\nPut your plunder to good use and use your riches to equip yourself with the best weapons and ships a Pirate could ask for.\n\nWith an Open World filled with Treasure, Mysterious Islands and limitless possibilities there's only one question to ask . . .\n\nArrrrgh you ready to set SAIL ???\n\nPLEASE NOTE: This is game is Early Access so it is not perfect and still a work in progress. We appreciate any and all feedback so leave it in a review or JOIN THE DISCORD and let us know there!\n\nTHANK YOU FOR SUPPORTING SAIL!!!", "short_description": "Open World VR Pirate Game - FREE Single Player Experience"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sail-vr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Red Team Interactive", "support_website_url": null, "website_url": "https://www.sail-vr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172