601292185075_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ojKZ-oWUgYIQ7kNvgFES_b0&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_h9o1dv-mYp05ve_5TQKRz&oh=00_AYA7431SyQVaNuIDiO9gqmT47pAQa1ECw-cepAnMMwmNCw&oe=66D707BF"}, {"file_name": "FB_IMG_1597466510323.png", "id": "248859486696769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_248859490030102_4028107096488140680_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OwUCiorxd4cQ7kNvgH5R7RJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_h9o1dv-mYp05ve_5TQKRz&oh=00_AYALZOz1Qt9UhnY0LGUzZqeUlXnj6bKBqNkezEBvfyzA7g&oe=66D6E2AC"}, {"file_name": "FB_IMG_1597466530398.png", "id": "999274193814165", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_999274197147498_8786232739591824076_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yy0nbpOr9vEQ7kNvgGQ6cV-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_h9o1dv-mYp05ve_5TQKRz&oh=00_AYDRaQ_qBuK8_gO-jbLCTqBfTlppuofpBfWWg0NUF5FYpw&oe=66D70C37"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SAILBANNERSQ (1) (2).png", "id": "1129169390876827", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_1129169394210160_2035722361615596698_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BptwBRCsbAEQ7kNvgHhdT7f&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_h9o1dv-mYp05ve_5TQKRz&oh=00_AYCfsyGfL-_TQi3kK0wclSmMLv-zZB35YrnI6rVP-Acobg&oe=66D70836"}, "display_name": "SAIL ", "keywords": [], "long_description": "Ready to set sail?\nCurrent version of SAIL allows you explore islands, sail a ship and look for loot, fight skeletons, find lost treasure and climb monolithic cliffs. It's VR so feel free to walk around the deck, fire the cannon and adjust the sails. You will also find weapons hidden around the map, if you're having a hard time finding them try breaking those crates you see lying around.\n\nThe map keeps expanding and currently there are 4 areas to explore.\n\nShipwreck Cove\nFool's Paradise\nMonolith Cliffs\nIsla Fortuna \n\nSAIL is the start of a VR universe G119 (developer) has wanted to make for years. The game is in PRE-ALPHA and is not much yet but there are big plans and an awesome community backing the project. So download the game and join us on the journey. As for specific features here are a few things in the works for SAIL:\n\nBosses\n\nOnline Multiplayer\n\nTreasure hunts\n\nEnemy ships, pirates, forts, etc.\n\nMoney system\n\nPlayer cosmetics\n\nShip cosmetics\n", "short_description": "Open World VR Pirate Advemture"}]}, "developer_name": null, "developer_privacy_policy_url": "https://garett-cook.com/index.php/sail-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "garett-cook", "support_website_url": null, "website_url": "https://garett-cook.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3173912349599688"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "330098562181049"}]}, "baseline_offer": {"id": "330098562181049"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1624992660, "status": "PUBLISHED", "id": "330098562181049"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7542837759061976", "version": "1.0.23j"}, "id": "769142350641644", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBina