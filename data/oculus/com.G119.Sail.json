E9AA"}, {"file_name": "SAILOGO.png", "id": "122237623046599", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982607_122237626379932_5653050829403186399_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZO0D-n4ZFoEQ7kNvgH1UbDU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEYPfBVOxpeGifcVR70FlzS7zS6Z36uaOSu6BPPwoO8A&oe=66D31896"}]}, "id": "878438842943611", "locale": "en_US", "screenshots": [{"file_name": "FB_IMG_1597466497125 (1).png", "id": "135174638433867", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_135174641767200_5469559239691573680_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=goR0qlClDzsQ7kNvgFoOeYj&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0TBPVz_KWGVehCIRMIwZDNhDPUjTXvjwHIjv2QbSq3g&oe=66D2FB18"}, {"file_name": "FB_IMG_1597466510323.png", "id": "399255381371124", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982670_399255384704457_574020719630739880_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cyQactMn3UoQ7kNvgHmIRXV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBk5hyqP1PIvsLbpPEVJOICBv9NiihBo-jYFTPop7eJjA&oe=66D319D8"}, {"file_name": "FB_IMG_1597466519158 (1).png", "id": "478730126845726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_478730130179059_4296388601292185075_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvJIwNxeAewQ7kNvgF0LGTZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCK2FiZGr79fiCLJ30gRzb8wfIbuT35Ez8WCMzaZBlR4A&oe=66D3133F"}, {"file_name": "FB_IMG_1597466510323.png", "id": "248859486696769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_248859490030102_4028107096488140680_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gjyJyW6wficQ7kNvgEd_-Bu&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrBGnvAq_VJIvm0FdEZppPthk1qxpBEZAhlnVvbBX8xA&oe=66D2EE2C"}, {"file_name": "FB_IMG_1597466530398.png", "id": "999274193814165", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982699_999274197147498_8786232739591824076_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Or-jbDmctt4Q7kNvgFFjjPP&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0wihPGHvm5rPDNovxmUK-_DkAaRGif5WsdAzFgaO_0w&oe=66D317B7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SAILBANNERSQ (1) (2).png", "id": "1129169390876827", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_1129169394210160_2035722361615596698_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ne5XOw2TMeQQ7kNvgFdf6RQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDA5JMg1h8whD1xdcANTvWyDV-uxPmPBmzcVrvlk7iN_Q&oe=66D313B6"}, "display_name": "SAIL ", "keywords": [], "long_description": "Ready to set sail?\nCurrent version of SAIL allows you explore islands, sail a ship and look for loot, fight skeletons, find lost treasure and climb monolithic cliffs. It's VR so feel free to walk around the deck, fire the cannon and adjust the sails. You will also find weapons hidden around the map, if you're having a hard time finding them try breaking those crates you see lying around.\n\nThe map keeps expanding and currently there are 4 areas to explore.\n\nShipwreck Cove\nFool's Paradise\nMonolith Cliffs\nIsla Fortuna \n\nSAIL is the start of a VR universe G119 (developer) has wanted to make for years. The game is in PRE-ALPHA and is not much yet but there are big plans and an awesome community backing the project. So download the game and join us on the journey. As for specific features here are a few things in the works for SAIL:\n\nBosses\n\nOnline Multiplayer\n\nTreasure hunts\n\nEnemy ships, pirates, forts, etc.\n\nMoney system\n\nPlayer cosmetics\n\nShip cosmetics\n", "short_description": "Open World VR Pirate Advemture"}]}, "developer_name": null, "developer_privacy_policy_url": "https://garett-cook.com/index.php/sail-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "garett-cook", "support_website_url": null, "website_url": "https://garett-cook.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": 