DYf2ucpQ&oe=66EFEE74"}, {"file_name": "5.png", "id": "5125891664146319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303837_5125891667479652_8512781975491820540_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-3VFpcNsZgQ7kNvgGwoRpE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2IMi1B1v0hb55Y4Pea9kcw&oh=00_AYBa0HYaXh4khUPlY7vF8a5nnTx9Fny3V3JC2B5EnA0SpQ&oe=66EFE895"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sail logo5.png", "id": "356739772677881", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031340_356739776011214_4752399952396963553_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_bD_5xJ4MkQ7kNvgHcgH5s&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2IMi1B1v0hb55Y4Pea9kcw&oh=00_AYA4PhiEPCbrDAT1X54VAmGDUBKEkYIbe7jAF0qKci8P0g&oe=66EFFA0F"}, "display_name": "Sail Single Player", "keywords": [], "long_description": "UNLEASH your Inner Pirate in SAIL the Open World VR Pirate game!!!\n\nEarn your Pirate reputation through EPIC voyages where you'll test yourself by collecting as much treasure as possible and bringing it back safely to your Pirate hideout.\n\nBUT BE WARNED . . .\n\nYou're not the only Pirate seeking fortune on the seas.\n\nFight off Pirate enemies on land with your Pirate weapon of choice\n\n- OR -\n\n Battle them on the seas using your ship's cannons and VOICE COMMANDS!\n\nPut your plunder to good use and use your riches to equip yourself with the best weapons and ships a Pirate could ask for.\n\nWith an Open World filled with Treasure, Mysterious Islands and limitless possibilities there's only one question to ask . . .\n\nArrrrgh you ready to set SAIL ???\n\nPLEASE NOTE: This is game is Early Access so it is not perfect and still a work in progress. We appreciate any and all feedback so leave it in a review or JOIN THE DISCORD and let us know there!\n\nTHANK YOU FOR SUPPORTING SAIL!!!", "short_description": "Open World VR Pirate Game - FREE Single Player Experience"}]}, "developer_name": null, "developer_privacy_policy_