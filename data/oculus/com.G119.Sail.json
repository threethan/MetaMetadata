=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-_Sy6_PQZSgQ7kNvgEaOgZL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDz6N76fT94CRzYksbFvM0eSAKePEzK85k9NeD-vn4LLg&oe=6759672C"}, {"file_name": "FB_IMG_1597466530398.png", "id": "999274193814165", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982699_999274197147498_8786232739591824076_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NV56iDNb-y0Q7kNvgGOQx-k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA18B_vVH3CimSSzciXAR5N45gDCTz6qpOyTFyJ3gYswg&oe=675990B7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SAILBANNERSQ (1) (2).png", "id": "1129169390876827", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_1129169394210160_2035722361615596698_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kfZ23N3EVZ0Q7kNvgE80C1g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBL7oSi0DCIC4eDDnqk12wF-fknoi4376v1RDxtKdj4mg&oe=67598CB6"}, "display_name": "SAIL ", "keywords": [], "long_description": "Ready to set sail?\nCurrent version of SAIL allows you explore islands, sail a ship and look for loot, fight skeletons, find lost treasure and climb monolithic cliffs. It's VR so feel free to walk around the deck, fire the cannon and adjust the sails. You will also find weapons hidden around the map, if you're having a hard time finding them try breaking those crates you see lying around.\n\nThe map keeps expanding and currently there are 4 areas to explore.\n\nShipwreck Cove\nFool's Paradise\nMonolith Cliffs\nIsla Fortuna \n\nSAIL is the start of a VR universe G119 (developer) has wanted to make for years. The game is in PRE-ALPHA and is not much yet but there are big plans and an awesome community backing the project. So download the game and join us on the journey. As for specific features here are a few things in the works for SAIL:\n\nBosses\n\nOnline Multiplayer\n\nTreasure hunts\n\nEnemy ships, pirates, forts, etc.\n\nMoney system\n\nPlayer cosmetics\n\nShip cosmetics\n", "short_description": "Open World VR Pirate Advemture"}]}, "developer_name": null, "developer_privacy_policy_url": "https://garett-cook.com/index.php/sail-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "garett-cook", "support_website_url": null, "website_url": "https://garett-cook.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3173912349599688"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "330098562181049"}]}, "baseline_offer": {"id": "330098562181049"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1624992660, "status": "PUBLISHED", "id": "330098562181049"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7542837759061976", "version": "1.0.23j"}, "id": "769142350641644", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4092537967425323", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7542837759061976"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "769142350641644"}]}, "change_log": null, "created_date": 17044