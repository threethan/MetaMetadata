-1.oculuscdn.com/v/t64.5771-25/11162730_1910848052515468_5682976013101826048_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O6ZPM9ISG10Q7kNvgGXEHGl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0NKAc8wtjia_Ro3IZQTigiv_2XO1eIS0hZ4HJvttOyA&oe=6745BF52"}, {"file_name": "migrated_image.png", "id": "231999381268586", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162732_176990779513771_706897530398441472_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEZW-ofV4f8Q7kNvgHLbdCP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0uVvwXoqSbTCptaZ0EUR6PfPBpWEytm4Ek_9e3A86_w&oe=6745A19B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Flappy VR - Arcade Game", "keywords": ["flappy", "bird", "arcade", "game", "minecraft"], "long_description": "Flappy VR puts a new spin on the original hit game 'Flappy Bird'. In Flappy VR, you get to play from the perspective of the bird in virtual reality. Earn points by passing through the pipes and unlock new pipes and maps by earning medals!  This new perspective truly brings back the initial excitement of 'Flappy Bird'. Ultimately, if you enjoyed the original 'Flappy Bird', you will love Flappy VR. In fact, if you are currently reading this right now, you will love Flappy VR.\n\nHappy flapping!", "short_description": "Flappy VR puts a new spin on the original hit game 'Flappy Bird' with new features and a new perspective. In Flappy VR, you get to play from the perspective of the bird in virtual reality.\nEarn points and win medals, which you can use to unlock new maps and pipes!\nUltimately, if you enjoyed the original 'Flappy Bird', you will love Flappy VR. In fact, if you are currently reading this right now, you will love Flappy VR.\n\nHappy flapping!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.beyondvr.ca/privacypolicy", "developer_terms_of_service_url": "https://www.beyondvr.ca/terms-and-conditions", "publisher_name": "Peg Games", "support_website_u