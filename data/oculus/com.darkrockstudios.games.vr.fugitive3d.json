771-25/38984454_440158367219986_5081739348623505343_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RUoy83mAzDwQ7kNvgG48c4P&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7pdiUNeIvi9L39IsLvC1d-&oh=00_AYDbTkxW5bZvEy9aDkehBVGdmiUJUPFeFga-wJtd6U0Ueg&oe=66EBF68F"}, {"file_name": "screenshot_05.png", "id": "813056236086867", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003239_813056239420200_1661077816866897120_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qp8mHvCLwb8Q7kNvgEurWzD&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7pdiUNeIvi9L39IsLvC1d-&oh=00_AYDX2-c3YbcuC3mQaNrvy9KWLjXbgSw-o84GhdkZSTTQLg&oe=66EBF8F0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fugitive 3D", "keywords": [], "long_description": "Features:\n    - Cross-platform! VR and Flat players can play together.\n    - Server browser: Find a game quickly from any platform!\n    - Positional VOIP: hear the fugitives whispering in the bushes as you search for them.\n    - Watch the Replay: At the end of the round talk with everyone about how close they were to catching you as you all watch a replay over the round!\n    - Free and Open Source!\n    - Even runs on Android phones, so your one lame friend with no VR and no PC can still join in on the fun :P", "short_description": "Multiplayer, objective based, Hide & Seek! Cross-play between Flat and VR!\n\nPlay hide and seek with your friends on a warm summer night. Hide behind bushes as the Cops search for you. Make your way to the end zone without getting caught! If you're friend gets frozen by the police, you have to decide if it's worth trying to go rescue them. Or be the Cops, and drive around in your cop car shinning your flashlight into dark corners."}]}, "developer_name": "Stumpy Dog Studios", "developer_privacy_policy_url": "https://fugitivethegame.online/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Stumpy Dog Studios", "support_website_url": null, "website_url": "https://stumpy-dog-studios.itc