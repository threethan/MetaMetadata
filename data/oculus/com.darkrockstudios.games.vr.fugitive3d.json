cdn.com/v/t64.5771-25/39003239_813056239420200_1661077816866897120_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=axGqVJ_-RIQQ7kNvgHP1fYw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdUVJFff21mXzOY0fBs76Gs_yPQg9MNGnnMBzCf-tuCg&oe=66DD7870"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Fugitive 3D", "keywords": [], "long_description": "Features:\n    - Cross-platform! VR and Flat players can play together.\n    - Server browser: Find a game quickly from any platform!\n    - Positional VOIP: hear the fugitives whispering in the bushes as you search for them.\n    - Watch the Replay: At the end of the round talk with everyone about how close they were to catching you as you all watch a replay over the round!\n    - Free and Open Source!\n    - Even runs on Android phones, so your one lame friend with no VR and no PC can still join in on the fun :P", "short_description": "Multiplayer, objective based, Hide & Seek! Cross-play between Flat and VR!\n\nPlay hide and seek with your friends on a warm summer night. Hide behind bushes as the Cops search for you. Make your way to the end zone without getting caught! If you're friend gets frozen by the police, you have to decide if it's worth trying to go rescue them. Or be the Cops, and drive around in your cop car shinning your flashlight into dark corners."}]}, "developer_name": "Stumpy Dog Studios", "developer_privacy_policy_url": "https://fugitivethegame.online/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Stumpy Dog Studios", "support_website_url": null, "website_url": "https://stumpy-dog-studios.itch.io/fugitive-3d", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor