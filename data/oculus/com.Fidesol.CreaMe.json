ornos inmersivos y experiencias virtuales. Desarrollo r\u00e1pido de entornos y experiencias virtuales inmersivas.\nProporciona flexibilidad y dinamismo al sistema, facilitando lo m\u00e1ximo posible, en tiempo y conocimiento, la creaci\u00f3n de experiencias inmersivas en realidad virtual.", "short_description": "Experiencias inmersivas de r\u00e1pida implantaci\u00f3n\nCapacitaci\u00f3n y formaci\u00f3n con experiencias inmersivas"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.openingenius.com/creame-privacy-policy/", "developer_terms_of_service_url": "https://www.openingenius.com/aviso-legal/", "publisher_name": "Open Ingenius", "support_website_url": "https://www.openingenius.com/contacto/", "website_url": "https://www.openingenius.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24763658389916902"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568680_797043618221762_6067586666700852844_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ndhPoSUrvBEQ7kNvgFUvUoZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXwLQMkenCrneGjakfg1i5AIMZg7EuByumtu15VJTPIA&oe=6746ECC6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "C