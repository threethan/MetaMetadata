culuscdn.com/v/t64.5771-25/39031336_1045636922695599_2498278490991162659_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O598gTy0Tm4Q7kNvgF7GnkH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9hUpnv0gC-k-GeAZUrUO9w&oh=00_AYCUttDIN5ZkP1dtYV73yWHAA8F9MKpWg2kAatU9AAtgXw&oe=66F3E9B8"}, {"file_name": "2022-02-08_17-33-25cameraCapture.png", "id": "648425589733123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001667_648425593066456_7032027644576020047_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S87EtgzPuD8Q7kNvgEHKbvK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9hUpnv0gC-k-GeAZUrUO9w&oh=00_AYDCEm0PSMvaEP2pO7O0FZ3prgdZINHtkLa11zX5dZfGJg&oe=66F3E1D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Creas_Portada.png", "id": "288119779319137", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982617_288119785985803_4634091910208668339_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vdmZJ2NZ1NIQ7kNvgGhwaXV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9hUpnv0gC-k-GeAZUrUO9w&oh=00_AYDoY6FQvgycC8sfMxoN5Q2aSxYevgf80Ew2UT4ReMEnuw&oe=66F3F9B5"}, "display_name": "CreaMe", "keywords": [], "long_description": "Application for Oculus Quest intended for the execution of training and education experiences carried out through the Creame platform.\n\nTool for generating immersive environments and virtual experiences. Rapid development of immersive virtual environments and experiences.\nIt provides flexibility and dynamism to the system, facilitating as much as possible, in terms of time and knowledge, the creation of immersive experiences in virtual reality.", "short_description": "Quick-to-deploy immersive experiences\nTraining and education with immersive experiences\n"}, {"images": {"nodes": []}, "id": "709339981326795", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CreaMe", "keywords": [], "long_description": "Aplicaci\u00f3n para Oculus Quest destinada a la ejecuci\u00f3n de experiencias de capacita