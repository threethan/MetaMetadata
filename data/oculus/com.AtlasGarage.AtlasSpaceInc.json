_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nQDoN3lTxlYQ7kNvgG2VvRL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlC4FZ0qrQd9PnViIUa8DOC&oh=00_AYBVdKPXztdq9HoxwXkJ_qTEvDd-ZK1YQ9MNeGeGlCeNSA&oe=66E9610C"}, {"file_name": "Screenshot_05.png", "id": "2434692316920652", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974513_2434692320253985_723688201503393264_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lkSyJ658_pEQ7kNvgGimnyM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlC4FZ0qrQd9PnViIUa8DOC&oh=00_AYBkTsnPK-2lyTvT5M307oql8YcdmeRWrhIAvF0Gyhl65g&oe=66E951C3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "358751863705633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974637_358751867038966_3130478979094307821_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTJWci1qWiQQ7kNvgHrr2zu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlC4FZ0qrQd9PnViIUa8DOC&oh=00_AYAoM8fz5h5KIVB0e4cvDM_FI7SXfN4lkbOVIDbJNU_Dsg&oe=66E96D96"}, "display_name": "Atlas Space", "keywords": [], "long_description": "Atlas Space offers a multiplayer experience in a creative and engaging setting, blending adventure with social interaction across VR, Web, Mobile and Console.\n\nAtlas Space merges immersive virtual worlds with rich multiplayer experiences by offering players an unparalleled level of customization, community building, and interactive exploration. Atlas Space not only allows players to create and customize their own spaces but also to engage in meaningful social interactions, adventures, and in-game economy culture within a vast, ever-evolving universe.\n\nThe blend of creativity, interaction, and personal expression within a shared digital space is what makes Atlas Space a compelling experience across the platforms.", "short_description": "Atlas Space offers a multiplayer experience in a creative and engaging setting, blending adventure with social interaction across VR, Web, Mobile and Console."}]}, "developer_name": null, "developer_privac