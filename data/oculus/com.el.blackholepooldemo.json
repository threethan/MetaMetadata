scdn.com&oh=00_AYAtDsPLqevG2Yhu79rtYUxeG3rZIIm_ZUHzbgZnym8n7w&oe=67656A3B"}, {"file_name": "BHP_meta_newrackversion_screenshot_3.png", "id": "220578004072676", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_220578007406009_4320468645137911720_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WsfqeFU2NzMQ7kNvgF1aZ_P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0Hc-RgKHEkGYE_2B2orgFhLE0dSHml8UXtuHdnImwiw&oe=67655C2E"}, {"file_name": "BHP_meta_newrackversion_screenshot_4.png", "id": "2503215546521807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031350_2503215549855140_9057702552890219758_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OZg_ZyFl1hEQ7kNvgGstXIS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBipkU1rA9THg_dPjvkZh7ughDlMz8xpeiYJjzSghV1Yg&oe=67655886"}, {"file_name": "BHP_meta_newrackversion_screenshot_5.png", "id": "779840363694049", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982714_779840367027382_3428333798691697316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ApqxMFdaN5kQ7kNvgEnmOdt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYABLcWlwiXUTxIvUHJtD1z-CLQYIM-p49QZlNTP3H7HoQ&oe=6765574E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BHP_meta_cover_newupdate_2560x1440 (1).png", "id": "646030724084541", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031542_646030727417874_4237318855295311944_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BbWd7KyTHd4Q7kNvgEpQKkl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6bjO5QfIYEwRpfs0k8wabTw7c3E515_-mzCDgSrvt2g&oe=67654CC8"}, "display_name": "Black Hole Pool", "keywords": [], "long_description": "Are you ready to smash some balls in VR? Black Hole Pool is the ultimate Pool/Billiard VR experience with the most accurate physics and great graphics. \n\nThere are many ways to enjoy the beautiful world of Pool.\n\nRELEASE YOUR INNER HUSTLER!\nThe Hustle Bar is a social place where players from all around the world meet to play for virtual stakes. Collect coins and spend them on cool accessories.\n\nBE THE BEST!\nAre you feeling competitive? you can play for ELO points in the Ranked Room against randomly matched opponents. Collect ELO points to climb the leaderboard and be the best.\n\nHANG OUT WITH FRIENDS!\nFinally, the band splits up tonight. The VIP Room is an invite-only place for you and your friends. Chill with your friends, shoot some balls, and enjoy your favorite videos together on a huge TV.\n\nDO YOU WANT SOME SOLITUDE?\nPractice alone or play against an AI opponent while watching your favorite movies in the Private Room.\n\nEXPRESS YOURSELF!\nCollect experience points (XP) to unlock cool accessories like cues, ball sets, and felts. Customize the experience as you like.\n\nThe only thing missing is you. See you at the table.", "short_description": "Are you ready to smash some balls in VR? Black Hole Pool is the ultimate Pool/Billiard VR experience with the most accurate physics and great graphics. "}]}, "developer_name": "Pixel Works", "developer_privacy_policy_url": "https://gamend.io/pp/bhp_pp.html", "developer_terms_of_service_url": null, "publisher_name": "Pixel Works", "support_website_url": null, "website_url": "https://www.facebook.com/blackholepool", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes"