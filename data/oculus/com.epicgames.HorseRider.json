ga3-2.oculuscdn.com/v/t64.5771-25/39031604_1970435123369213_8837165626680431926_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RkzEhRQLkAQ7kNvgHInPJw&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBa29Q_tooO45a0jS7kKQji7AR1KqrV-QO_xOL4hCsWOw&oe=675826A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover25601440.png", "id": "8087853684571699", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974574_8087853687905032_5755058043460285112_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t_9U7d-3edMQ7kNvgEe-_lA&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBWR9Ingu-1lR0OTGbafECLxiNs7ffo1Kq_FhVzhcwG7A&oe=675826D8"}, "display_name": "Horse Rider", "keywords": ["horse", "ride", "adventure", "rpg", "simulator"], "long_description": "Prancing through the vast Central Continent, through the blockade of undead hordes, bandits and rebels, helping the lords deliver letters, supplies or legendary weapons as fast as possible!\n## \n# About Horse Rider VR and Monduz\nHorse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides.\n\nIn the future, we'll be expanding the map to more areas of the Monduz world, adding NPCs and other escorts, introducing more quest types and prop horses, and beginning to tell a compelling main story!\n\n##\n# DEMO V11 Update:\n\n## Gameplay\n- **NEW: Single-Hand Horse Control** Easier riding, no alignment needed!\n- **NEW: Single-Hand Turning & Jumping** More flexible control!\n- **UPDATE: Improved Dual-Hand Controls** Smoother acceleration & jumping!\n- **UPDATE: Simplified Deceleration & Reverse**\n\n## Visuals\n- **UPDATE: Enhanced Turning Speed** Faster steering!\n- **NEW: Acceleration Icon** Indicates active acceleration!\n- **NEW: Rock & Cliff Details** More detail added!\n\n## Quest 2\n- **UPDATE: Optimization** Removed fog, improved LOD, increased frame rates!\n\n## Bug Fixes\n- **FIX: Vegetation Placement** Corrected misplaced vegetation.\n- **FIX: Eagle Disappearing** Resolved issue with disappearing eagle.", "short_description": "Horse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.monduz.com/hrPrivacy.html", "developer_terms_of_service_url": null, "publisher_name": "Monduz Games", "support_website_url": null, "website_url": "https://www.facebook.com/profile.php?id=100088044019561", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "FIGHTING", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7170082346449749"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75395590_2324296301261190_6810111919605113622_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jbGQ4oXnBcgQ7kNvgF4N_Xg&_nc_zt=3&_nc_ht=scontent-lga3