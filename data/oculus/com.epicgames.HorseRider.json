-1.oculuscdn.com/v/t64.5771-25/39031604_1970435123369213_8837165626680431926_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lt_RJfhj4ZUQ7kNvgEQ6cnS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvNbRnd5Az9XcvyIUD4Gqm-5EiqUrXUiYKDcVi1L-cvA&oe=673B25A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover25601440.png", "id": "8087853684571699", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974574_8087853687905032_5755058043460285112_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nafeM7H3ROoQ7kNvgFFimRK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEFrlqlGb-YqKyB0mvW69h1UxgtwBdqVedNOOlDXx2Gw&oe=673B25D8"}, "display_name": "Horse Rider", "keywords": ["horse", "ride", "adventure", "rpg", "simulator"], "long_description": "Prancing through the vast Central Continent, through the blockade of undead hordes, bandits and rebels, helping the lords deliver letters, supplies or legendary weapons as fast as possible!\n## \n# About Horse Rider VR and Monduz\nHorse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides.\n\nIn the future, we'll be expanding the map to more areas of the Monduz world, adding NPCs and other escorts, introducing more quest types and prop horses, and beginning to tell a compelling main story!\n\n##\n# DEMO V9 is a Major Update!\n# 1. Gameplay\n- **New Quest System:** Includes adventure and delivery quests, some requiring you to gather key items before starting timed deliveries.\n- **New NPC System:** Now, NPCs are available to assign quests.\n\n- **New Item System:** Horses now have dedicated storage bags, a letter pouch, and a shield holder. Item weight affects horse speed!\n# 2. Graphics\n- **Upgraded Graphics System**Supports diverse terrain, more detailed trees, and buildings.\n\n- **Revamped Stables**  \n\n- **New Menus**\n- **Enhanced Night Ambience:** Featuring torches and lighting.\n- **Improved Road Signs**\n- **New Village and Town Layouts**\n# 3. Economy\n- **Revamped Item Rewards:** Quest items and rewards have been adjusted.\n# 4. Other\n- **Musics**\n- **Over 40 Bug Fixes**", "short_description": "Horse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.monduz.com/hrPrivacy.html", "developer_terms_of_service_url": null, "publisher_name": "Monduz Games", "support_website_url": null, "website_url": "https://www.facebook.com/profile.php?id=100088044019561", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "FIGHTING", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7050805488377436"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974574_1242637160287679_751184371630525579_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&