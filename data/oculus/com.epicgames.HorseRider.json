sjc3-1.oculuscdn.com/v/t64.5771-25/39031604_1970435123369213_8837165626680431926_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WqSsH1mZ_CoQ7kNvgGAMiMC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDBK2cKDYO2-c4pginKuPDhuuVN9fvpfhOac9BdsbqeMA&oe=677284A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover25601440.png", "id": "8087853684571699", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974574_8087853687905032_5755058043460285112_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-u-ZINp-JG4Q7kNvgG699MV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAgEY5ClE0y0EgWUHwv2G5INfztGJCi7y2UYYFPc-dNBQ&oe=677284D8"}, "display_name": "Horse Rider", "keywords": ["horse", "ride", "adventure", "rpg", "simulator"], "long_description": "Prancing through the vast Central Continent, through the blockade of undead hordes, bandits and rebels, helping the lords deliver letters, supplies or legendary weapons as fast as possible!\n## \n# About Horse Rider VR and Monduz\nHorse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides.\n\nIn the future, we'll be expanding the map to more areas of the Monduz world, adding NPCs and other escorts, introducing more quest types and prop horses, and beginning to tell a compelling main story!\n\n##\n# DEMO v12 Update Logs  \n\n## Gameplay  \n- **NEW: Merchant NPCs**: Merchants sell items.  \n- **NEW: Quality Purchases**: Spend more gold for better items.  \n- **NEW: Stables Support Consumables**: Use items at stables.  \n- **NEW: Horse Buffs**: Temporary buffs boost attributes.  \n\n## Content  \n- **NEW: Apple Farmer**: Buy apples in GlenVille, with chances for premium ones.  \n- **NEW: Wild Apples**: Find apples in the wild.  \n- **NEW: Apple Buff**: Apples boost speed; premium ones last longer.  \n- **NEW: Stable at White Tower**: Added for faster recovery.  \n\n## Graphics  \n- **NEW: Buff Icon**: Buffs visible on the speed panel.  \n- **UPDATE: Cave Visuals**: Enhanced cave graphics.  \n- **UPDATE: Terrain**: Improved paths between mountains and caves.  \n\n\n", "short_description": "Horse Rider VR is designed for players who love adventurous horseback riding in an open world.\n\nComplete delivery quests, collect gold, and purchase items and horses. Explore diverse locations like mountains, canyons, bridges, islands, caves, villages, and towns within a seamless day/night cycle. Level up your horses and gain random upgrade points during your rides."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.monduz.com/hrPrivacy.html", "developer_terms_of_service_url": null, "publisher_name": "Monduz Games", "support_website_url": null, "website_url": "https://www.facebook.com/profile.php?id=100088044019561", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "FIGHTING", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7266979746760008"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75395590_2324296301261190_6810111919605113622_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_