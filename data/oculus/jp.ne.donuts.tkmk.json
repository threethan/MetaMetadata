ication that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tkmk.live/help/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "DONUTS VR", "support_website_url": null, "website_url": "https://tkmk.live/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3281341681961503"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "508605631390724"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1620288418437596"}]}, "baseline_offer": {"id": "1620288418437596"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1681711200, "status": "PUBLISHED", "id": "1620288418437596"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6011387495605791", "version": "1.1.5"}, "id": "1537132226800196", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5750564015021475", "is_concept": false, "latest_released_binary