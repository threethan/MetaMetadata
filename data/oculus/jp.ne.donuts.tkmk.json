r": null, "video_trailer_thumbnail": {"file_name": "\u4e88\u544a\u7de8\u30ab\u30cf\u3099\u30fc\u753b\u50cfA.png", "id": "1112973946767418", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974828_1112973953434084_1995615483707272991_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cX-PDuFzriAQ7kNvgEJVZtD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLabY91ZNiAtnAG-17IG_mt4V53OaNWElrYFrxamD-pQ&oe=671F70E2"}, "display_name": "Tokimeki VR", "keywords": [], "long_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!\n\nSupported devices\nHTC VIVE (VIVE READY PC recommended)\nOculus Go \u30fbOculus Quest\nOculus Quest 2\niPhone (iOS 10.0 or later and A7 chip or later)\nAndroid 6.0 or higher\n\nPayment method\nCredit card payment\n\nInquiries\nEmail: tkmk_vr@donuts.ne.jp\nPhone: 050-5306-4189\nIn principle, we reply to inquiries by e-mail. We appreciate your cooperation.", "short_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tkmk.live/help/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "DONUTS VR", "support_website_url": null, "website_url": "https://tkmk.live/", "category": null, "comfort_rating": 