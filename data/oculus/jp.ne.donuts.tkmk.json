_1995615483707272991_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FfAEtwwAR3wQ7kNvgEUKj9e&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAkcmSfR40WWO8PicS6XSf-xJMDWOmNQDvjnm0zSTeVdA&oe=670A58E2"}, "display_name": "Tokimeki VR", "keywords": [], "long_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!\n\nSupported devices\nHTC VIVE (VIVE READY PC recommended)\nOculus Go \u30fbOculus Quest\nOculus Quest 2\niPhone (iOS 10.0 or later and A7 chip or later)\nAndroid 6.0 or higher\n\nPayment method\nCredit card payment\n\nInquiries\nEmail: tkmk_vr@donuts.ne.jp\nPhone: 050-5306-4189\nIn principle, we reply to inquiries by e-mail. We appreciate your cooperation.", "short_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tkmk.live/help/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "DONUTS VR", "support_website_url": null, "website_url": "https://tkmk.live/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "3281341681961503"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_