t64.5771-25/38974828_1112973953434084_1995615483707272991_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d9_z_xGg3i8Q7kNvgHXySrf&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDKB8IktQ4RQxosQGjdWtcrQQRD2TTZH42zZJIzjTcvcQ&oe=675D6762"}, "display_name": "Tokimeki VR", "keywords": [], "long_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!\n\nSupported devices\nHTC VIVE (VIVE READY PC recommended)\nOculus Go \u30fbOculus Quest\nOculus Quest 2\niPhone (iOS 10.0 or later and A7 chip or later)\nAndroid 6.0 or higher\n\nPayment method\nCredit card payment\n\nInquiries\nEmail: tkmk_vr@donuts.ne.jp\nPhone: 050-5306-4189\nIn principle, we reply to inquiries by e-mail. We appreciate your cooperation.", "short_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tkmk.live/help/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "DONUTS VR", "support_website_url": null, "website_url": "https://tkmk.live/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NO