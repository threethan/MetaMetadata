i": "https://scontent.oculuscdn.com/v/t64.5771-25/39031346_555717036505010_287602479130943305_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8anoLq_LkjMQ7kNvgFRIqJv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AX6PcOp07SyWlZJA7YrUAXr&oh=00_AYALEPCeUvq4KCZk3QtUPBeorQXuy_E_AHYPXVOzzPh-sA&oe=66E2B808"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u4e88\u544a\u7de8\u30ab\u30cf\u3099\u30fc\u753b\u50cfA.png", "id": "1112973946767418", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974828_1112973953434084_1995615483707272991_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cbDrL4BiJUoQ7kNvgEJ5Qlz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AX6PcOp07SyWlZJA7YrUAXr&oh=00_AYBbwYQJxWJnFEYGtZlbwIEyxiBavLmu2zuyvTMILyy-KQ&oe=66E2CBE2"}, "display_name": "Tokimeki VR", "keywords": [], "long_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!\n\nSupported devices\nHTC VIVE (VIVE READY PC recommended)\nOculus Go \u30fbOculus Quest\nOculus Quest 2\niPhone (iOS 10.0 or later and A7 chip or later)\nAndroid 6.0 or higher\n\nPayment method\nCredit card payment\n\nInquiries\nEmail: tkmk_vr@donuts.ne.jp\nPhone: 050-5306-4189\nIn principle, we reply to inquiries by e-mail. We appreciate your cooperation.", "short_description": "Experience the distance between you and a VTuber!\nTokimeki VR is a communication application that allows you to enjoy one-on-one private talks with your favorite VTubers, so you can enjoy a virtual room date with just the two of you at any time.\nYou can freely change the direction of the VTuber, so you can view the 3D model from various angles.\nTalk a lot with your favorite VTuber and let them get to know you too!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tkmk.live/help/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "DONUTS VR", "support_website_url": null, "website_url": "https://tkmk.live/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "3281341681961503"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "508605631390724"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1620288418437596"}]}, "baseline_offer": {"id": "1620288418437596"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1681711200, "status": "PUBLISHED", "id": "1620288418437596"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6011387495605791", "version": "1.1.5"}, "id": "1537132226800196", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5750564015021475", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6011387495605791"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1537132226800196"}]}, "change_log": null, "created_date": 1680686483, "id": "6011387495605791", "version": "1.1.5",