F6A973"}, {"file_name": "migrated_image.png", "id": "668476670569937", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482153_1858067167798991_7217008734889836544_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R2ewjBkSCM0Q7kNvgFXQQBh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSNz7b8H6699TPOwiqheddqqqLo6k_oHSYMCEBorbZWw&oe=66F6A371"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FlowForBreathVR", "keywords": ["Relax", "Meditation", "Calm", "Flow"], "long_description": "Flow for Breath VR is a mobile VR app that will help center your thoughts and calm your mind through deep breathing exercises. \n\nDeep breathing is a natural tranquilizer and, practiced in an all immersive environment, it has far reaching benefits. The practice of deep breathing has the following benefits:\n\n1. increases serotonin and calms the mind\n2. helps expel damaging toxins\n3. lowers heart and respiratory rates\n4. lowers blood pressure\n5. enhances mood\n\nChoose any one of five state settings:\n1. Happiness\n2. Calm\n3. Focus\n4. Energize\n5. Core breathing\n\nIt was researched and created by a clinical hypnotherapist and mindfulness coach to bring you a quick and efficient method to shift into a state of balance, flow, health and focus with ease.\n\nChoose your path and be on your way to deeper breathing effortlessly. Like sitting in a hot tub with mineral spring water and soaking in whole body wellness inside and out.", "short_description": "Flow for Breath VR will help center your thoughts and calm your mind."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.CoreReboot.com/", "developer_terms_of_service_url": "http://www.CoreReboot.com/", "publisher_name": "CoreReboot ", "support_website_url": null, "website_url": "http://www.CoreReboot.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EDUCATIONAL", 