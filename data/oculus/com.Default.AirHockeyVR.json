_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2WATm2DLJ70Q7kNvgGpoxnX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAFJI2WGo2Kz_Ns0pdeInK13GqXAhES3Zjwf6Z3UANDWQ&oe=6756C178"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5260\u04451440 (1) (1).png", "id": "1122673882449395", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001670_1122673885782728_2090955290681552906_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1HV2lOV6Kb0Q7kNvgGjUDq0&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDsT1jnKaBeXfhJWhyFXeX32nS7JhOQPt2ANT_yGLLBWw&oe=6756D85D"}, "display_name": "Ultimate Air Hockey VR", "keywords": [], "long_description": "**Ultimate Air Hockey VR** brings the excitement of scoring the winning goal! With incredibly realistic physics, the game brings the exhilarating sensation of playing Air Hockey to life. Feel the satisfying thud of the puck as it glides across the table and experience the thrill of making precise shots and strategic moves.\n\n# Master the Table in Solo or Multiplayer Action!\n\nPlay solo against AI or compete with friends in multiplayer mode for up to 4 players. Challenge your skills and see who can become the ultimate Air Hockey champion!\n\n# Unleash Your Style\n\nCustomize your experience with cosmetic options for paddles and pucks. Personalize your game with different colors, patterns, and designs to make it uniquely yours. \n\n# Explore Exciting Arenas\n\nExplore a variety of locations, from sunny beaches to futuristic airships. Immerse yourself in different environments and enjoy the thrill of playing Air Hockey in stunning virtual worlds.\n \n# Air Hockey Action in Your Own Space\n\nSet up an Ultimate Air Hockey table right at home in MR Mode. Bring the fun to your living room and feel the joy of scoring the winning goal!", "short_description": "Ultimate Air Hockey VR delivers arcade excitement with intuitive controls and realistic physics. Play intense matches solo or with friends. Smooth gameplay makes it straightforward fun."}]}, "developer_name": "SA-WD", "developer_privacy_policy_url": "https://fragments.dmentor.online/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fragments World ", "support_website_url": null, "website_url": "https://fragments.dmentor.online/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru", "de", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "26142133882101565"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982715_1421287811915473_900849852164549331_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f9MpkBl0kqQQ7kNvgGWmVlT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB996VdzV1f0mx6Rna73uYBXlmmV6v8mybKW7m7BEQ-Rg&oe=6756DF26"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ultimate Air Hockey VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1624929599, "lastRevision": {"nodes": [{"id": "269786507839444", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "i