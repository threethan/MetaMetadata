arcade excitement with intuitive controls and realistic physics. Play intense matches solo or with friends. Smooth gameplay makes it straightforward fun."}]}, "developer_name": "SA-WD", "developer_privacy_policy_url": "https://fragments.dmentor.online/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fragments World ", "support_website_url": null, "website_url": "https://fragments.dmentor.online/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru", "de", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "26142133882101565"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982715_1421287811915473_900849852164549331_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YoNs_nBQ6DEQ7kNvgHbzni7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARsH77CK3_mo5JorsBauJrX&oh=00_AYCsrUXq1-TwcPxWzs0hCehZpA0LakJ4W2EvMf7S2qZPDw&oe=66DC43A6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ultimate Air Hockey VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Casual", "id": "394813081514456"}], "