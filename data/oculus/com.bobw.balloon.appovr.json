457375_3629357227774897069_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DBPJu0g3VUIQ7kNvgFY6wZq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIeYwXvnLpMwlIYSjcHzwNY&oh=00_AYA5svh-O7irDZ6iV45NzkS5F3Ft-WlqYVLGotM4e4bk1Q&oe=66F6956E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "splash_2560_1440.png", "id": "457596205652723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395601_457596208986056_7544284973903613144_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=250B81Hdl4oQ7kNvgGbVsvO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIeYwXvnLpMwlIYSjcHzwNY&oh=00_AYBb3nji505KV8mkZWIuxjGk_gy3z4AN9-tie-rqgt9P3A&oe=66F695BC"}, "display_name": "Balloon Gunner", "keywords": [], "long_description": "The islands of your Empire have been invaded, and only you and your war balloon can save them!!\n\nFly your war balloon through an array of different missions and enemies. Use cannons, missiles and bombs to blast and pop your way to victory!\n\nFeatures:\n* Simple, fun, addictive gameplay - just point and shoot!\n* 40 varied and challenging levels.\n* A wide range of enemy/target types, including 10 aerial adversaries.\n* Play seated, standing, or however you like.\n* Tiny file size!\n\nBEFORE YOU PLAY:\n* Note that you steer using the Oculus controller (the right by default), not by turning your head.\n* If you're left-handed, you can switch to the left controller in Options.\n", "short_description": "A fun, retro shoot-'em-up with a steampunk flavor.  Back-to-basics blasting!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.languagebug.com/games/Common/Privacy/PrivacyPolicyMobileApp.htm", "developer_terms_of_service_url": null, "publisher_name": "LanguageBug", "support_website_url": null, "website_url": "https://www.languagebug.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_