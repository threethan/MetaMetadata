gEBD94r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD43msAsNNMS7CoN-JSj9PIOIVan1RUAzirx792HHwdZg&oe=673F17EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "splash_2560_1440.png", "id": "457596205652723", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395601_457596208986056_7544284973903613144_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z1aHJq19n-wQ7kNvgFxbsUH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgFMyFb3NRw7AJGHcUWnA7A4qnJT5BWBf2tjnJ0v_TbQ&oe=673F183C"}, "display_name": "Balloon Gunner", "keywords": [], "long_description": "The islands of your Empire have been invaded, and only you and your war balloon can save them!!\n\nFly your war balloon through an array of different missions and enemies. Use cannons, missiles and bombs to blast and pop your way to victory!\n\nFeatures:\n* Simple, fun, addictive gameplay - just point and shoot!\n* 40 varied and challenging levels.\n* A wide range of enemy/target types, including 10 aerial adversaries.\n* Play seated, standing, or however you like.\n* Tiny file size!\n\nBEFORE YOU PLAY:\n* Note that you steer using the Oculus controller (the right by default), not by turning your head.\n* If you're left-handed, you can switch to the left controller in Options.\n", "short_description": "A fun, retro shoot-'em-up with a steampunk flavor.  Back-to-basics blasting!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.languagebug.com/games/Common/Privacy/PrivacyPolicyMobileApp.htm", "developer_terms_of_service_url": null, "publisher_name": "LanguageBug", "support_website_url": null, "website_url": "https://www.languagebug.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING", "SHOOTER"], "has_in_app_ads": false, "internet_co