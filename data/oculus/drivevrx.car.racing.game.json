288906871945_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUm4yf4Fy1EQ7kNvgEnIGtW&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCG6y1zIonuEnBu1r-MudhoQBnKsxWe_OGGJN41C1Yew&oe=66FD4CDC"}, {"file_name": "vlcsnap-2023-02-23-17h17m29s289.png", "id": "921335742226567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031418_921335745559900_2475651066751710437_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YMKKqn0Cc90Q7kNvgFkMmx2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDppg_A2np1vCKsSBN7PFZGtvjCWqJQ8doiIcd33sqEzA&oe=66FD1F2D"}, {"file_name": "vlcsnap-2023-02-23-17h14m39s258.png", "id": "618983690061385", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556790_618983696728051_7272955250205501191_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JdXo2qNjKl4Q7kNvgHSngU7&_nc_ht=scontent.oculuscdn.com&oh=00_AYB39-wCTzPXGDFUYiL_5rTTrhFPgFSRSLLWeoMllpbI5w&oe=66FD14FE"}, {"file_name": "vlcsnap-2023-02-23-17h22m45s205.png", "id": "533199905616837", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_533199908950170_1473457797399012005_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9cyDmZyufs0Q7kNvgEYYj2p&_nc_ht=scontent.oculuscdn.com&oh=00_AYBL9uq5c10ZKKKdXTtHTWpgm_lB4wRiK85gFit1sTmXog&oe=66FD1EDE"}, {"file_name": "vlcsnap-2023-02-23-17h19m45s081.png", "id": "877209856845528", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375083_877209860178861_3645029825146837830_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yQM7WPTxhdsQ7kNvgHMW5vZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFKIBiFW5qIsm6Gk_hBHK50Ev5seqyiRvJJjRFfEOPjw&oe=66FD4572"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DriveVRX- Car Racing Game & Car Driving Game", "keywords": [], "long_description": "\"Drive VRX\" is a Thrilling virtual reality racing game that will take you on a high-speed journey through some of the world's most challenging and breathtaking race tracks. With its stunning graphics and immersive gameplay, this game will transport you to a world of high-performance vehicles and heart-pounding competition.\nFrom the moment you put on your VR headset, you'll be fully immersed in the world of \"Drive VRX.\" And with its realistic physics engine, \"Drive VRX\" delivers a true-to-life racing experience that will leave you breathless.\nBut \"Drive VRX\" isn't just about racing. It's also about customization and strategy. You'll also need to strategize and plan your race, making split-second decisions about when to brake, when to accelerate, and how to navigate through hairpin turns and treacherous obstacles.\n", "short_description": "\"Driving VRX\" puts you in the driver's seat of high-performance vehicles, allowing you to experience high-speed racing in an interactive and fully realized manner. With stunning graphics and realistic physics, navigate challenging tracks and compete against other racers to experience what it's like to be in the driver's seat."}]}, "developer_name": null, "developer_privacy_policy_url": "https://abstron.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Abstron Pvt Ltd", "support_website_url": null, "website_url": "https://abstron.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "893308808397205"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "594741756003650"}]}, "baseline_offer": {"id": "594741756003650"}, "is_approved": true, "firstOffer": 