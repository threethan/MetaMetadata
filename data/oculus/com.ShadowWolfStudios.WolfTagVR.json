res": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "8163429090348287"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "285963634010325"}]}, "baseline_offer": {"id": "285963634010325"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721875229, "status": "PUBLISHED", "id": "285963634010325"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9248427498515102", "version": "0.2.2"}, "id": "1890976404631088", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6676585659032645", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9248427498515102"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1890976404631088"}]}, "change_log": "Bug Fixes:\n\nBans:\n - Banning was broken and didn't show reasons/times. FIXED\n\nReporting:\n - If reported user didn't have a name set the report was useless. \n   Name is now required upon game start in-order to play.\n\nLighting:\n - Lighting was a bit dark so it has been modified and made \n   slightly brighter for better visibility.\n\nAdditions:\n\nMod Vents:\n - Moderators now have access to security cameras of each map \n   to see activity by players which can be used to give bans to \n   players.\n\nName Requirement:\n - Looping back to the Reporting, It is now required that before a \n   player can leave the Den (Starting Area), a name must be set \n   for online play.", "created_date": 1735441914, "id": "9248427498515102", "version": "0.2.2", "version_code": 20, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6676585659032645", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9248427498515102"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1890976404631088"}]}, "change_log": "Patch Notes for V0.2.1:\n\nHey gamers! I\u2019m back with part 2 of the Christmas 24\u2019 update! This is also combined with, drum roll pleaseeee, The Bouncy update!!! Now I was thinking about doing this separately but I figured why not make it your Christmas present! Well, I hope everyone has had a great december, has a great christmas, and I\u2019ll be back once more this year with a smaller update for New Years.  With that said, let's get on with the patch notes!\n\nI\u2019ve brought on a completely new revamp to all the maps and the game itself! Now the forest is essentially the same, just slightly bigger and things are placed a little differently. I\u2019ve completely remodeled the Den, Shop, Zero G, and added a new map! I also redid the entire lighting system. New gameplay system too!\n\n- Forest:\n     - Revamp!\n     - Slightly bigger\n     - Rearranged all items in the Forest\n\n- Shop:\n     - Revamp!\n     - 10x Bigger\n     - Changed the lighting\n     - Added paths to 2 maps (ZeroG, Bounce House)\n     - Changed up the mirror\n     - 2 New Cosmetics\n\n- ZeroG:\n     - Revamp!\n     - Made Map Bigger\n\n- Bounce House:\n     - New Map!\n     - Located in Shop\n     - Slide to enter\n     - Jump on anything to bounce around!\n     - Kiddie Birthday Party themed bounce pad!\n\n- Lighting:\n     - Revamp!\n     - More \u201cLife Like\u201d\n     - Some places are darker, might be adjusted\n\n- Gameplay:\n     - Using a new Tag system\n     - New Tag system is infection at this time.\n\n- Cosmetics:\n     - Snail Collection Start!\n     - Edible Chocolate Bar called the Wolf Bar\n\n- Next Plans:\n     - Possibly another new map\n     - More cosmetics", "created_date": 1735094199, "id": "9227546113936574", "version": "0.2.1", "version_code": 19, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6676585659032645", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9248427498515102"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1890976404631088"}]}, "change_log": "Hey gamers! Sorry for the late update. I know I missed Halloween and Thanksgiving. A lot has happened and I just went through major surgery on my leg a few weeks ago. I haven't been able to test in VR mode so if something is wrong please let me know by emailing me at: wolfbromail@gmail.com. Anyways, lets get to it!\n\nChristmas Update 1!!!!!!!\n\nDen:\n\n- Re-Detailed and added some more stuff for Christmas!\n- MOTD Board!\n- Alerts Tab on Computer\n\nForest:\n\n- Re-detailed Forest for Wintery/Christmas Vibes.\n- Added Santa with a free Santa Hat cosmetic.\n- Reindeer across the Forest\n- Santa Sleigh with presents (nothing special but can be fun to play in)\n\nShop:\n\n- Added a Cart System!\n  - Now when shopping for cosmetics you can add them to a cart \n    instead of instantly buying them. Now you have time to \n    hesitate! Plan to add a try on feature later!\n- Reindeer shopping too? What's that about?\n\nZero G:\n\n- WHY IS A REINDEER FLOATING AROUND?! HELP HIM!", "created_date": 1734295129, "id": "9174212469269939", "version": "0.2", "version_code": 18, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6676585659032645", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9248427498515102"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1890976404631088"}]}, "change_log": "Added Map loaders back, Join room trigger so your always in a lobby, ZeroG Zone, Lighting in the den, and 2 more Cosmetics. Time to work on the fall update!", "created_date": 1727097370, "id": "8606915689332956", "version": "0.17", "version_code": 17, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6676585659032645", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9248427498515102"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1890976404631088"}]}, "change_log": "Reworked entire game systems. Zero Grav and Lava Parkour will be back in future updates.", "created_date": 1727063302, "id": "8603109109713614", "version": "0.16", "version_code": 16, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}