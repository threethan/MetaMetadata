/v/t64.5771-25/39031326_847240709279462_9081410908319983688_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRCph-TaZcYQ7kNvgGt6gBg&_nc_ht=scontent.oculuscdn.com&_nc_gid=A83KPW9NCtfkALGbxszoUeo&oh=00_AYDr7_U86u5vGd7h8NQ7cqOYk82wGoZMaSdPth2vG-PJuA&oe=66EE9642"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031634_1087287328757588_3306708653632800721_n1.png", "id": "271303151978100", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75617324_271303155311433_2777910031919682358_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XENN3PRBuUQ7kNvgFmtb1L&_nc_ht=scontent.oculuscdn.com&_nc_gid=A83KPW9NCtfkALGbxszoUeo&oh=00_AYD28IwUuj6e9l4Wh5Nh-8i-sxLQYhKnn50QOU2_R4SLOA&oe=66EEBDCF"}, "display_name": "First Person Tennis - The Real Tennis Simulator", "keywords": ["tennis", "table", "racket", "simulator", "pong"], "long_description": "Welcome to the First Person Tennis, the first tennis simulator developed for VR.\n\nFirst Person Tennis uses the most innovative physics engine to reproduce the real tennis shots in VR. Thanks to the support of a big community and professional tennis players, the game is in an endless development to reach an incredible level of realism.  \n\nFirst Person Tennis is for all ages and tennis players, the simulator has different levels of difficulty and options for any need.\n\nJoin First Person Tennis Discord to find friends, opponents and play online tournaments every months with big prizes.\nhttps://discord.gg/9rtH7VuwSd\n\nFeatures: \n- Arcade and Simulation mode.\n- Online Multiplayer.\n- Mixed Reality.\n- 3 different ways to run through the court: Teleport, Run in Place, Sliding Run.\n- One handed serve.\n- 7 different court surfaces: clay, grass, hard, blue-green hard, classic synthetic, indoor hard and indoor synthetic.\n- 13 tournaments: 4 Slam and 9 Masters. \n- Global Leaderboard. \n- Fully customizable 3D characters. ", "short_description": "Welcome to the First Person Tennis, the first tennis simulator developed for VR.\n\nFirst Person Tennis uses the most innovative physics engine to reproduce the real tennis shots in VR. Thanks to the support of a big community and professional tennis players, the game is in an endless development to reach an incredible level of realism.  \n\nFirst Person Tennis is for all ages and tennis players, the simulator has different levels of difficulty and options for any need."}]}, "developer_name": "Mikori Games", "developer_privacy_policy_url": "https://sites.google.com/view/fptprivacypolicy/home-page", "developer_terms_of_service_url": null, "publisher_name": "Mikori Games", "support_website_url": null, "website_url": "https://mikorigames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "en", "pt_BR", "it", "fr", "es", "ja", "zh_CN", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "24002620582719076"}, "review_messages": ["Approving for immediate release."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003242_605361211601302_6044225904691496999_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TKvY93K7aXAQ7kNvgGkmTaK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A83KPW9NCtfkALGbxszoUeo&oh=00_AYCAcx96vVpzA8dW_S18Yh-hYBGA_JXx_UMC_NmyzJKy4Q&oe=66EE9457"}, "is_concept": false, "is_test": false, "is_trial_offer_