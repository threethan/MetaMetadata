name": "3.png", "id": "379064010595825", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031440_379064013929158_562566670393182718_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YdQ5G0pGkPkQ7kNvgEpuATc&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBNyYwpwaDKQaU61DuZlzUteFy3MYtbaJIVwlgD868_DA&oe=675ED0E2"}, {"file_name": "4.png", "id": "847240705946129", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031326_847240709279462_9081410908319983688_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KP2FNBiZIkcQ7kNvgFbebED&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBsfwRh2x-vrNQLzRWuOTVIMPvC3V92sQNSsY6L8mXQ8Q&oe=675EDE02"}, {"file_name": "5.png", "id": "2404697546328669", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57572936_2404697549662002_6744001405025737672_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lM9DIvovyJQQ7kNvgHq7LpG&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD1nkCZT0Y3VjG6yjLxwMDaAs0LWTZvXXu-8eDpM8q2uA&oe=675ECF33"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "578040073613401", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39001713_578040076946734_8153214829952110504_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYS9uX7V3ccQ7kNvgGKvyjJ&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAv5txCitEzRMbDkb-5mMBDE3iK5_ZvLuXDEhd06KuBxQ&oe=675ED7CE"}, "display_name": "First Person Tennis - The Real Tennis Simulator", "keywords": [], "long_description": "First Person Tennis is the first tennis simulator developed for VR.\n\nNow, you can play on a real tennis court and face professional tennis players. \nYou'll have to show all your technical and tactical skills.\n\nVR Controls:\nHold the controller/racket and play tennis.\n\nFeatures: \n- Arcade and Simulation mode.\n- Online Multiplayer.\n- 3 different ways to run through the court: Teleport, Run in Place, Sliding Run.\n- One handed serve.\n- 7 different court surfaces: clay, grass, hard, blue-green hard, classic synthetic, indoor hard and indoor synthetic; each with a specific rebound. \n- 13 tournaments: 4 Slam and 9 Masters. \n- Full ranking system. \n- Fully customizable 3D male player. ", "short_description": "First Person Tennis is the first tennis simulator developed for VR. Now, you can play on a real tennis court and face professional tennis players. You'll have to show all your technical and tactical skills."}]}, "developer_name": "Mikori Games", "developer_privacy_policy_url": "https://sites.google.com/view/fptprivacypolicy/home-page", "developer_terms_of_service_url": "https://www.facebook.com/MikoriGames/", "publisher_name": "Mikori Games", "support_website_url": null, "website_url": "https://www.facebook.com/Firstpersontennis", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "ACTION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "en", "pt_BR", "it", "fr", "es", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "3168313566780415"}}]}, "scheduled_offers": {"count": 38, "nodes": [{"status": "PUBLISHED", "id": "1049626860183162"}, {"status": "PUBLISHED", "id": "1187353675903654"}, {"status": "PUBLISHED", "id": "882421170344557"}, {"status": "PUBLISHED", "id": "1147047383289987"}, {"status": "PUBLISHED", "id": "602151027929264"}, {"status": "PENDING", "id": "515302120671224"}, {"status": "PUBLISHED", "id": "3421891088078951"}, {"status": 