471013575226740", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86641452_471013578560073_4490523273369143876_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIkXcLOobIMQ7kNvgF22Epe&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBPyRqPqOjGnYQ4xHIeeufzEC7NtP6cRXqebZpbCdNKEA&oe=67407C58"}]}, "id": "1858324004915956", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "551629552583232", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57569471_551629555916565_636126810253215336_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cHuhfLNsgN4Q7kNvgHe10qc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA3Ti47vG3preLrMRPNU44t9nJWZ9VeCNuYPJixmntF3g&oe=67408598"}, {"file_name": "5.png", "id": "2404697546328669", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57572936_2404697549662002_6744001405025737672_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8r6Z5V33F-AQ7kNvgFPIuZ7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD0IxoK8BASOPftYftx3J5N5y3mRwf-U8dnDh35ax_NcA&oe=67407CB3"}, {"file_name": "2.png", "id": "2201883056618944", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75223480_2201883059952277_7552061268357601174_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GndZ3glw2YQQ7kNvgFT0909&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB4jYgxKjruqJ1IP5080OeDuKPtAChs6TsKIiEz0I_9fA&oe=674087EB"}, {"file_name": "3.png", "id": "379064010595825", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031440_379064013929158_562566670393182718_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XoyeMRGTyIEQ7kNvgGPP-v0&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD3D99m_dHgNjVr0DNE6bH7kI17ncnXrJkFWNjkrUPOOw&oe=67407E62"}, {"file_name": "4.png", "id": "847240705946129", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031326_847240709279462_9081410908319983688_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lMkjytToMdIQ7kNvgFJmipb&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAkD45h5MsyShWsNLR1mdX_832fJJy5fQCH36CRk9QrZg&oe=67405342"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-min.png", "id": "921068409406360", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57570314_921068412739693_4732083157252736500_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lMcSbqkFC2kQ7kNvgEr_GbN&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBFEiUqEW0xozI4oyFrlmTtUX-nXbERVG8mx_TZmUPo9w&oe=67406F46"}, "display_name": "First Person Tennis - The Real Tennis Simulator", "keywords": ["tennis", "padel", "pickleball", "badminton", "pong"], "long_description": "Welcome to the First Person Tennis, the first tennis simulator developed for VR.\n\nFirst Person Tennis uses the most innovative physics engine to reproduce the real tennis shots in VR. Thanks to the support of a big community and professional tennis players, the game is in an endless development to reach an incredible level of realism.  \n\nFirst Person Tennis can be played by both tennis players and non-players, the simulator has different levels of difficulty and options for any need.\n\nJoin First Person Tennis Discord to find friends, opponents and play online tournaments every months with big prizes.\nhttps://discord.gg/9rtH7VuwSd\n\nFeatures: \n- Arcade and Simulation mode.\n- Online Multiplayer.\n- Mixed Reality.\n- 3 different ways to run through the court: Teleport, Run in Place, Sliding Run.\n- One handed serve.\n- 7 different court surfaces: clay, grass, hard, blue-green hard, classic synthetic, indoor hard and indoor synthetic.\n- 13 tournaments: 4 Slam and 9 Masters. \n- Global Leaderboard. \n- Fully customizable 3D characters. ", "short_description": "Welcome to the First Person Tennis, the first tennis simulator developed for VR.\n\nFirst Person Tennis uses the most innovative physics engine to reproduce the real tennis shots in VR. Thanks to the support of a big community and professional tennis players, the game is in an endless development to reach an incredible level of realism.  \n\nFirst Person Tennis can be played by both tennis players and non-players, the simulator has different levels of difficulty and options for any need."}]}, "developer_name": "Mikori Games", "developer_privacy_policy_url": "https://sites.google.com/view/fptprivacypolicy/home-page", "developer_terms_of_service_url": null, "publisher_name": "Mikori Games", "support_website_url": null, "website_url": "https://mikorigames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "en", "pt_BR", "it", "fr", "es", "ja", "zh_CN", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "27421553797492387"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003242_605361211601302_6044225904691496999_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1rm00f8SMbgQ7kNvgHXxsm7&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBAZ__MUac3d_vKuD3-mfiKpyL5tsC0gjFxtgFV_GnArg&oe=67408997"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "First Person Tennis - The Real Tennis Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name"