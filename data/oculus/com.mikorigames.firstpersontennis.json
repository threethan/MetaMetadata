me": "3.png", "id": "379064010595825", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031440_379064013929158_562566670393182718_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dIPkI2HTwUAQ7kNvgEkRjA-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEwJuJwjWgxC-sKpX1yvlrs3X0jauj8RrYKmFp7aXLnw&oe=677D2362"}, {"file_name": "4.png", "id": "847240705946129", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031326_847240709279462_9081410908319983688_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7uZz_O0SWXEQ7kNvgHoNh3_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1E_cgCQfsJ2EH-ZnPSDnldqvWab09-deUrLaqHJk-8Q&oe=677CF842"}, {"file_name": "5.png", "id": "2404697546328669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572936_2404697549662002_6744001405025737672_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hZb9e_cRGl4Q7kNvgEgZpWE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFhax78B2c8tgyXGP8S_7EXVIFEOW-TetunosnUUs0wg&oe=677D21B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "578040073613401", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001713_578040076946734_8153214829952110504_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GOjoSY4qJN4Q7kNvgHMyFD-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5tgTGD0Cuxv2tcRHaSqeB1DeTEfzz1RVL4ZtCOyQaGQ&oe=677D2A4E"}, "display_name": "First Person Tennis - The Real Tennis Simulator", "keywords": [], "long_description": "First Person Tennis is the first tennis simulator developed for VR.\n\nNow, you can play on a real tennis court and face professional tennis players. \nYou'll have to show all your technical and tactical skills.\n\nVR Controls:\nHold the controller/racket and play tennis.\n\nFeatures: \n- Arcade and Simulation mode.\n- Online Multiplayer.\n- 3 different ways to run through the court: Teleport, Run in Place, Sliding Run.\n- One handed serve.\n- 7 different court surfaces: clay, grass, 