plication": {"is_concept": false, "latest_released_pdp_metadata": {"id": "660325955228287"}, "release_status": "RELEASED", "id": "1852276078160450"}, "id": "660325955228287", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1852276078160450", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "151821565767973"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "592535411335169", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u94f6\u6cb3\u57ce (Galaxity) \u6d4b\u8bd5\u7248", "keywords": ["\u72ec\u7acb", "\u793e\u4f1a", "\u591a\u91cd\u6e38\u620f", "\u548c\u670b\u53cb"], "long_description": "\u521b\u5efa\u89d2\u8272\n\u6211\u4eec\u6709\u5404\u79cd\u5934\u53d1\u3001\u76ae\u80a4\u3001\u8863\u670d\u548c\u989c\u8272\u9009\u9879\u4f9b\u60a8\u5bf9\u81ea\u5df1\u7684\u89d2\u8272\u8fdb\u884c\u81ea\u5b9a\u4e49\u3002\u53ef\u4ee5\u5728\u865a\u62df\u4e16\u754c\u4e2d\u5411\u670b\u53cb\u5c55\u793a\u60a8\u7684\u4e2a\u6027\u3002\n\n\u4e0e\u4eba\u4ea4\u8c08\uff0c\u7ed3\u4ea4\u670b\u53cb\n\u94f6\u6cb3\u57ce (Galaxity) \u63d0\u4f9b\u8bed\u97f3\u804a\u5929\u529f\u80fd\u3002\u60a8\u53ef\u4ee5\u4f7f\u7528\u81ea\u5df1\u7684\u58f0\u97f3\u4e0e\u4eba\u6c9f\u901a\uff0c\u6216\u4f7f\u7528\u5404\u79cd\u89d2\u8272\u8868\u60c5\u6765\u4e0e\u4e0d\u540c\u56fd\u5bb6\u7684\u4eba\u4ea4\u6d41\u3001\u6210\u4e3a\u670b\u53cb\u3002 \n\n\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u7cbe\u5f69\u4e0d\u65ad\n\u6211\u4eec\u4e3a\u60a8\u63d0\u4f9b\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u5982\u8db3\u7403\u3001\u68d2\u7403\u548c\u591a\u4eba\u751f\u5b58\u6e38\u620f\u6a21\u5f0f\u3002\u4e0e\u670b\u53cb\u4eec\u4e00\u8d77\u7545\u4eab\u5feb\u4e50\u65f6\u5149\u3002\u6211\u4eec\u5c06\u6301\u7eed\u66f4\u65b0\u4e0d\u540c\u7684\u6e38\u620f\u6a21\u5f0f\uff0c\u4e30\u5bcc\u60a8\u548c\u670b\u53cb\u4eec\u7684\u5a31\u4e50\u751f\u6d3b\u3002 \n\n\u53c2\u89c2\u5267\u9662\n\u60a8\u53ef\u4ee5\u521b\u5efa\u81ea\u5df1\u7684\u7535\u5f71\u9662\uff0c\u4f9b\u670b\u53cb\u4eec\u5728 YouTube \u4e0a\u64ad\u653e\u548c\u89c2\u770b\u3002\u51c6\u5907\u597d\u7206\u7c73\u82b1\u548c\u62ab\u8428\u5427\uff01\n\n\u5176\u4ed6\n\u60a8\u5728\u865a\u62df\u4e16\u754c\u4e2d\u91c7\u53d6\u7684\u884c\u52a8\u8d8a\u591a\uff0c\u60a8\u53ef\u4ee5\u6536\u96c6\u7684\u8d44\u91d1\u5c31\u8d8a\u591a\u3002\u6709\u4e86\u8fd9\u7b14\u8d44\u91d1\uff0c\u60a8\u53ef\u4ee5\u4ece\u5546\u5e97\u8d2d\u4e70\u6f02\u4eae\u7684\u670d\u88c5\uff0c\u5e76\u628a\u5b83\u5c55\u793a\u7ed9\u670b\u53cb\u4eec\u3002\u4f60\u4e5f\u53ef\u4ee5\u8d2d\u4e70\u70ab\u5f69\u70df\u82b1\uff0c\u751a\u81f3\u7528\u7279\u6b8a\u7269\u54c1\u6539\u53d8\u4f60\u7684\u53d1\u578b\u548c\u670d\u88c5\u3002\u6211\u4eec\u5f00\u53d1\u7684\u5404\u79cd\u4efb\u52a1\u4f1a\u4f7f\u60a8\u7684\u865a\u62df\u4e16\u754c\u751f\u6d3b\u66f4\u52a0\u6109\u60a6\u3002\n\n\u6d4b\u8bd5\u7248\u6d4b\u8bd5\u670d\u52a1\n\u6211\u4eec\u5df2\u7ecf\u5f00\u59cb\u8fdb\u884c\u516c\u5f00\u6d4b\u8bd5\uff0c\u4ee5\u4f7f\u6211\u4eec\u7684\u94f6\u6cb3\u57ce\u53d8\u5f97\u66f4\u52a0\u5b8c\u5584\u3002\u8be5\u670d\u52a1\u5668\u5c06\u5728 2018 \u5e74 11 \u6708 30 \u65e5\u4e4b\u524d\u5f00\u653e\u3002\u4f46\u5177\u4f53\u65e5\u671f\u5c06\u6839\u636e\u73a9\u5bb6\u60c5\u51b5\u8fdb\u884c\u8c03\u6574\u3002", "short_description": "\u94f6\u6cb3\u57ce (Galaxity) \u662f\u4e00\u4e2a\u795e\u5947\u7684\u865a\u62df\u4e16\u754c\u3002\u5728\u8fd9\u4e2a\u6e38\u620f\u4e2d\uff0c\u60a8\u53ef\u4ee5\u521b\u5efa\u4e00\u4e2a\u89d2\u8272\u5e76\u901a\u8fc7\u5404\u8272\u670d\u88c5\u5f70\u663e\u4e2a\u6027\u3002\u60a8\u8fd8\u53ef\u4ee5\u4e0e\u4ed6\u4eba\u4ea4\u8c08\u5e76\u7ed3\u4ea4\u670b\u53cb\u3002\u52a0\u5165\u94f6\u6cb3\u57ce (Galaxity)\uff0c\u4e00\u8d77\u7545\u4eab\u5404\u79cd\u5c0f\u6e38\u620f\u548c\u7cbe\u5f69\u7684\u89c6\u9891\u5427\uff01"}, {"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2654799108086678", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974865_1693668350734120_5958761330671353856_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYi0BC-2e5YQ7kNvgG_mKVr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AK9GthKiMAXulCydmMPsxwR&oh=00_AYCB3nANMtoqStOBrgYjsGSmveshQwxL0gIQ0_51XJh9Cw&oe=66EFF7AA"}, {"file_name": "migrated_image.png", "id": "607366603176907", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_2296081687288362_7695527263428673536_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7gRh_KBLGiwQ7kNvgEMM7C0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AK9GthKiMAXulCydmMPsxwR&oh=00_AYDwm7za0J5b_0a5RLHq3GEyGmRPnYp1nPm4W1PqpS_TKw&oe=66EFFF2A"}, {"file_name": "migrated_image.png", "id": "579939126064427", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984451_629300784201346_3970688374569697280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m3qhpHPC6u8Q7kNvgF7GnbC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AK9GthKiMAXulCydmMPsxwR&oh=00_AYAyKwK0T28IxMULhnmQxs7_JZ9io7RgSBMoZY9nIYcHRw&oe=66F005EF"}, {"file_name": "migrated_image.png", "id": "547691462520898", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031309_2054091108219984_2779026707334561792_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lw2jwkIKtpUQ7kNvgHanZqy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AK9GthKiMAXulCydmMPsxwR&oh=00_AYAtGmyRiCUHpe4oB7ij9wEuAGGM7FNnCl4BKcT8Dk8H-w&oe=66EFEE0E"}, {"file_name": "migrated_image.png", "id": "507861860124388", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001717_467593527339835_2393586949098045440_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kZmyc-9EaPQQ7kNvgEVqZZ7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AK9GthKiMAXulCydm