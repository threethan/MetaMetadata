plication": {"is_concept": false, "latest_released_pdp_metadata": {"id": "660325955228287"}, "release_status": "RELEASED", "id": "1852276078160450"}, "id": "660325955228287", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": 1582826044, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1852276078160450", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "151821565767973"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "592535411335169", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u94f6\u6cb3\u57ce (Galaxity) \u6d4b\u8bd5\u7248", "keywords": ["\u72ec\u7acb", "\u793e\u4f1a", "\u591a\u91cd\u6e38\u620f", "\u548c\u670b\u53cb"], "long_description": "\u521b\u5efa\u89d2\u8272\n\u6211\u4eec\u6709\u5404\u79cd\u5934\u53d1\u3001\u76ae\u80a4\u3001\u8863\u670d\u548c\u989c\u8272\u9009\u9879\u4f9b\u60a8\u5bf9\u81ea\u5df1\u7684\u89d2\u8272\u8fdb\u884c\u81ea\u5b9a\u4e49\u3002\u53ef\u4ee5\u5728\u865a\u62df\u4e16\u754c\u4e2d\u5411\u670b\u53cb\u5c55\u793a\u60a8\u7684\u4e2a\u6027\u3002\n\n\u4e0e\u4eba\u4ea4\u8c08\uff0c\u7ed3\u4ea4\u670b\u53cb\n\u94f6\u6cb3\u57ce (Galaxity) \u63d0\u4f9b\u8bed\u97f3\u804a\u5929\u529f\u80fd\u3002\u60a8\u53ef\u4ee5\u4f7f\u7528\u81ea\u5df1\u7684\u58f0\u97f3\u4e0e\u4eba\u6c9f\u901a\uff0c\u6216\u4f7f\u7528\u5404\u79cd\u89d2\u8272\u8868\u60c5\u6765\u4e0e\u4e0d\u540c\u56fd\u5bb6\u7684\u4eba\u4ea4\u6d41\u3001\u6210\u4e3a\u670b\u53cb\u3002 \n\n\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u7cbe\u5f69\u4e0d\u65ad\n\u6211\u4eec\u4e3a\u60a8\u63d0\u4f9b\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u5982\u8db3\u7403\u3001\u68d2\u7403\u548c\u591a\u4eba\u751f\u5b58\u6e38\u620f\u6a21\u5f0f\u3002\u4e0e\u670b\u53cb\u4eec\u4e00\u8d77\u7545\u4eab\u5feb\u4e50\u65f6\u5149\u3002\u6211\u4eec\u5c06\u6301\u7eed\u66f4\u65b0\u4e0d\u540c\u7684\u6e38\u620f\u6a21\u5f0f\uff0c\u4e30\u5bcc\u60a8\u548c\u670b\u53cb\u4eec\u7684\u5a31\u4e50\u751f\u6d3b\u3002 \n\n\u53c2\u89c2\u5267\u9662\n\u60a8\u53ef\u4ee5\u521b\u5efa\u81ea\u5df1\u7684\u7535\u5f71\u9662\uff0c\u4f9b\u670b\u53cb\u4eec\u5728 YouTube \u4e0a\u64ad\u653e\u548c\u89c2\u770b\u3002\u51c6\u5907\u597d\u7206\u7c73\u82b1\u548c\u62ab\u8428\u5427\uff01\n\n\u5176\u4ed6\n\u60a8\u5728\u865a\u62df\u4e16\u754c\u4e2d\u91c7\u53d6\u7684\u884c\u52a8\u8d8a\u591a\uff0c\u60a8\u53ef\u4ee5\u6536\u96c6\u7684\u8d44\u91d1\u5c31\u8d8a\u591a\u3002\u6709\u4e86\u8fd9\u7b14\u8d44\u91d1\uff0c\u60a8\u53ef\u4ee5\u4ece\u5546\u5e97\u8d2d\u4e70\u6f02\u4eae\u7684\u670d\u88c5\uff0c\u5e76\u628a\u5b83\u5c55\u793a\u7ed9\u670b\u53cb\u4eec\u3002\u4f60\u4e5f\u53ef\u4ee5\u8d2d\u4e70\u70ab\u5f69\u70df\u82b1\uff0c\u751a\u81f3\u7528\u7279\u6b8a\u7269\u54c1\u6539\u53d8\u4f60\u7684\u53d1\u578b\u548c\u670d\u88c5\u3002\u6211\u4eec\u5f00\u53d1\u7684\u5404\u79cd\u4efb\u52a1\u4f1a\u4f7f\u60a8\u7684\u865a\u62df\u4e16\u754c\u751f\u6d3b\u66f4\u52a0\u6109\u60a6\u3002\n\n\u6d4b\u8bd5\u7248\u6d4b\u8bd5\u670d\u52a1\n\u6211\u4eec\u5df2\u7ecf\u5f00\u59cb\u8fdb\u884c\u516c\u5f00\u6d4b\u8bd5\uff0c\u4ee5\u4f7f\u6211\u4eec\u7684\u94f6\u6cb3\u57ce\u53d8\u5f97\u66f4\u52a0\u5b8c\u5584\u3002\u8be5\u670d\u52a1\u5668\u5c06\u5728 2018 \u5e74 11 \u6708 30 \u65e5\u4e4b\u524d\u5f00\u653e\u3002\u4f46\u5177\u4f53\u65e5\u671f\u5c06\u6839\u636e\u73a9\u5bb6\u60c5\u51b5\u8fdb\u884c\u8c03\u6574\u3002", "short_description": "\u94f6\u6cb3\u57ce (Galaxity) \u662f\u4e00\u4e2a\u795e\u5947\u7684\u865a\u62df\u4e16\u754c\u3002\u5728\u8fd9\u4e2a\u6e38\u620f\u4e2d\uff0c\u60a8\u53ef\u4ee5\u521b\u5efa\u4e00\u4e2a\u89d2\u8272\u5e76\u901a\u8fc7\u5404\u8272\u670d\u88c5\u5f70\u663e\u4e2a\u6027\u3002\u60a8\u8fd8\u53ef\u4ee5\u4e0e\u4ed6\u4eba\u4ea4\u8c08\u5e76\u7ed3\u4ea4\u670b\u53cb\u3002\u52a0\u5165\u94f6\u6cb3\u57ce (Galaxity)\uff0c\u4e00\u8d77\u7545\u4eab\u5404\u79cd\u5c0f\u6e38\u620f\u548c\u7cbe\u5f69\u7684\u89c6\u9891\u5427\uff01"}, {"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2654799108086678", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974865_1693668350734120_5958761330671353856_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TF7wZH6iqiUQ7kNvgGpdbK8&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_kEBOHPMRLqef1eApyxgP6J6LBJIeEzqa-_wlmxYc4g&oe=66D4482A"}, {"file_name": "migrated_image.png", "id": "607366603176907", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_2296081687288362_7695527263428673536_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rLxAEUCa5CAQ7kNvgEmvzVM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoK8CodDLGbHD3nAxQOXLa4WJ5DsiTzrVO7wjZ6FXAug&oe=66D44FAA"}, {"file_name": "migrated_image.png", "id": "579939126064427", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984451_629300784201346_3970688374569697280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e8U38LKIwhoQ7kNvgGl29Pn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPyAvKPiyXsbNlzF9zi9TSJBOKGUoupeai9Sh4pM8tOg&oe=66D4566F"}, {"file_name": "migrated_image.png", "id": "547691462520898", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031309_2054091108219984_2779026707334561792_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjkK0gPfhEMQ7kNvgHACl3p&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdvVMCAWUpTkm_2WAegFI0RWeLd7w5egRFKwtwTnHPUw&oe=66D43E8E"}, {"file_name": "migrated_image.png", "id": "507861860124388", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001717_467593527339835_2393586949098045440_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r4h0gdJrN-8Q7kNvgE7vcXO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDn-7RF0O2fEGvWhllAISUuSlZ4rnQbfA0wWx-7P66c_g&oe=66D46040"}, {"file_name": "migrated_image.png", "id": "241186003682423", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_606823119726679_8638233698266775552_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q4qZ2aNO5dUQ7kNvgFnKtWx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXu7ekJ7rtCyNPpA7ydT4ShY5GWAEUEezf-JNmSQQnqg&oe=66D43C0C"}, {"file_name": "migrated_image.png", "id": "149638862989949", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974729_440373223426977_611531114485383168_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M9fFEMk4RUYQ7kNvgGbVwZg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDG2tBeOGOfYWH-QU0YgFFFshT3igfVGDlqVOuCapP3LA&oe=66D44C84"}]}, "id": "517651908896805", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "232305934557605", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982634_463383337522395_7046506405913690112_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pQYfv_EjpAgQ7kNvgE0NhQ1&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_RhhfHIGqlVBPuRZNhGdVAXI9BjfnLpPir9LkLHfUyg&oe=66D43D29"}, {"file_name": "migrated_image.png", "id": "1032722363779956", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974727_298146017720119_8665599687983628288_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6yKc_mOlJHgQ7kNvgHnfrr_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNlqMAaIrAVIWaY40zA4qhcgTL7wXi922XOTcmeFTtkA&oe=66D455C7"}, {"file_name": "migrated_image.png", "id": "856360128170907", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974756_1471757992957648_2845304112910696448_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kk3tu_Nu1ccQ7kNvgH0tEYJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfejrTqdEpyfedvaDEBIpiJDXUJqZ7wBubvruUmMTr4w&oe=66D443F7"}, {"file_name": "migrated_image.png", "id": "914567398962003", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974637_2383721068367162_3223429808130097152_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=86OOMyQ5RiIQ7kNvgHP1-E8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCaEp6c0gPj2X68jQRi7_idRG6ObIlzdW12X0OTE1GHXA&oe=66D45799"}, {"file_name": "migrated_image.png", "id": "2478904725772577", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_735844253482591_4466757844582006784_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EXP0Fm2jlpQQ7kNvgFjjPRq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVHzanAZecxrZEXSLBs8-LjnEX0ZS6l6RdjR7u9gjXcw&oe=66D4623E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Galaxity", "keywords": ["Galaxity", "Indie", "Social", "Multi", "Friends"], "long_description": "Create your avatar\nWe have a variety of hair, skin, clothing and color options for you to customize your avatar. Show your creativity avatar to friends in the virtual world.\n\nTalk to people and make friends\nGalaxity provides a voice chat feature. You can communicate with people using your own voice or use various character expressions to communicate and become a friend with people from different nations. \n\nPlay various mini-games\nWe offer you a variety of mini-games, such as soccer, baseball, and multiple survival modes. Have fun with your friends. We will continue to update different game modes for you to play with your friends. \n\nVisit the theater\nYou can create your own movie theater for your friends to play and watch on YouTube. Prepare popcorn and pizza!", "short_description": "Galaxity is a wonderful virtual world. In this game, you can create an avatar and customize it with a variety of costumes. You can also talk to people and become friends with them. Join Galaxity, and enjoy various mini-games and fun videos together!"}]}, "developer_name": "MAMMOSSIX Co., Ltd.", "developer_privacy_policy_url": "https://www.galaxity.net/privacy-policy", "developer_terms_of_service_url": "https://www.galaxity.net/terms-of-service", "publisher_name": "MAMMOSSIX Co., Ltd.", "support_website_url": "http://www.galaxity.net/", "website_url": "https://www.galaxity.net/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_t