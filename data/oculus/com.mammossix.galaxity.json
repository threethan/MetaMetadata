=scontent.oculuscdn.com&oh=00_AYCcR2pAVd78FtAGQ_GsZWccmUacxXc6mUHoT7gHJkvn9w&oe=66D469A4"}]}, "id": "678561872906666", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "207309027166969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974464_1940693479357209_8221476662005465088_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7QpySphK3UQ7kNvgHgrE8W&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkvxZ1NApJ9mN64DqgZWBQfE7iIp6QVe6yfncg10By4w&oe=66D454C9"}, {"file_name": "migrated_image.png", "id": "2326654537636519", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_1206315826184520_1189863544816926720_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yjR8XJDfrdAQ7kNvgGyIRq1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsN9nBB9oI9GJYzGwLbP9C39AHYVpLAsNuzceM74vWfg&oe=66D4645C"}, {"file_name": "migrated_image.png", "id": "494983677838669", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031450_1877551029033114_6116568569544179712_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfSJpS5G4q0Q7kNvgF0lLip&_nc_ht=scontent.oculuscdn.com&oh=00_AYChMkxU_c7Mol95ME0YtOjKxaM9GsJSrTqo77jlEUYOdg&oe=66D441AC"}, {"file_name": "migrated_image.png", "id": "2367068440060117", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974751_250197319181968_5017245718465740800_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uM2Trn4Vrq8Q7kNvgGZBn-Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHVRliq8EIqL1mqG3d8cPWKU53Sh6v7eihLPXgE225aw&oe=66D4467A"}, {"file_name": "migrated_image.png", "id": "223903002349289", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982485_326100368171638_8593810486452027392_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r43k7QWnN4EQ7kNvgF_XAF_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVhVsx3VT0KuzKqxl2qolDuef1ExEddyTdZH5sbZED6g&oe=66D44740"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/eV4tnU", "id": "351800288713433", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974496_351800292046766_6534266010369785856_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-wCQLqExjykQ7kNvgGWpB0-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzmdflui7iBSd_lvIR-L7xXNtTx_8P3jQIBHi9km_h5g&oe=66D455CD"}, "display_name": "Galaxity", "keywords": ["Galaxity", "Indie", "Social", "Multi", "Friends"], "long_description": "Sign in with Facebook\nDo you have your Facebook account? If you connect to a virtual city with your Facebook account, your data will be stored and you can play at any other VR devices.\n\nCreate your avatar\nWe have a variety of hair, skin, clothing and color options for you to customize your avatar. Show your creativity avatar to friends in the virtual world.\n\nTalk to people and make friends\nGalaxity provides a voice chat feature. You can communicate with people using your own voice or use various character expressions to communicate and become a friend with people from different nations. \n\nPlay various mini-games\nWe offer you a variety of mini-games, such as soccer, baseball, and multiple survival modes. Have fun with your friends. We will continue to update different game modes for you to play with your friends. \n\nVisit the theater\nYou can create your own movie theater for your friends to play and watch on YouTube. Prepare popcorn and pizza!", "short_description": "Galaxity is a wonderful virtual world. In this game, you can create an avatar and customize it with a variety of costumes. You can also talk to people and become friends with them. Join Galaxity, and enjoy various mini-games and fun videos together!"}, {"images": {"nodes": []}, "id": "253008409058767", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u94f6\u6cb3\u57ce (Galaxity) \u6d4b\u8bd5\u7248", "keywords": ["\u72ec\u7acb", "\u793e\u4f1a", "\u591a\u91cd\u6e38\u620f", "\u548c\u670b\u53cb"], "long_description": "\u4f7f\u7528 Facebook \u8d26\u53f7\u767b\u5f55\n\u60a8\u662f\u5426\u62e5\u6709 Facebook \u8d26\u53f7\uff1f\u5982\u679c\u60a8\u4f7f\u7528 Facebook \u8d26\u53f7\u8fde\u63a5\u5230\u865a\u62df\u57ce\u5e02\uff0c\u60a8\u7684\u6570\u636e\u5c06\u4e88\u4ee5\u5b58\u50a8\uff0c\u5c4a\u65f6\u60a8\u53ef\u4ee5\u5728\u4efb\u4f55\u5176\u4ed6 VR \u8bbe\u5907\u4e0a\u4f7f\u7528\u8be5\u8d26\u53f7\u8fdb\u884c\u6e38\u620f\u3002\n\n\u521b\u5efa\u89d2\u8272\n\u6211\u4eec\u6709\u5404\u79cd\u5934\u53d1\u3001\u76ae\u80a4\u3001\u8863\u670d\u548c\u989c\u8272\u9009\u9879\u4f9b\u60a8\u5bf9\u81ea\u5df1\u7684\u89d2\u8272\u8fdb\u884c\u81ea\u5b9a\u4e49\u3002\u53ef\u4ee5\u5728\u865a\u62df\u4e16\u754c\u4e2d\u5411\u670b\u53cb\u5c55\u793a\u60a8\u7684\u4e2a\u6027\u3002\n\n\u4e0e\u4eba\u4ea4\u8c08\uff0c\u7ed3\u4ea4\u670b\u53cb\n\u94f6\u6cb3\u57ce (Galaxity) \u63d0\u4f9b\u8bed\u97f3\u804a\u5929\u529f\u80fd\u3002\u60a8\u53ef\u4ee5\u4f7f\u7528\u81ea\u5df1\u7684\u58f0\u97f3\u4e0e\u4eba\u6c9f\u901a\uff0c\u6216\u4f7f\u7528\u5404\u79cd\u89d2\u8272\u8868\u60c5\u6765\u4e0e\u4e0d\u540c\u56fd\u5bb6\u7684\u4eba\u4ea4\u6d41\u3001\u6210\u4e3a\u670b\u53cb\u3002 \n\n\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u7cbe\u5f69\u4e0d\u65ad\n\u6211\u4eec\u4e3a\u60a8\u63d0\u4f9b\u5404\u79cd\u5c0f\u6e38\u620f\uff0c\u5982\u8db3\u7403\u3001\u68d2\u7403\u548c\u591a\u4eba\u751f\u5b58\u6e38\u620f\u6a21\u5f0f\u3002\u4e0e\u670b\u53cb\u4eec\u4e00\u8d77\u7545\u4eab\u5feb\u4e50\u65f6\u5149\u3002\u6211\u4eec\u5c06\u6301\u7eed\u66f4\u65b0\u4e0d\u540c\u7684\u6e38\u620f\u6a21\u5f0f\uff0c\u4e30\u5bcc\u60a8\u548c\u670b\u53cb\u4eec\u7684\u5a31\u4e50\u751f\u6d3b\u3002 \n\n\u53c2\u89c2\u5267\u9662\n\u60a8\u53ef\u4ee5\u521b\u5efa\u81ea\u5df1\u7684\u7535\u5f71\u9662\uff0c\u4f9b\u670b\u53cb\u4eec\u5728 YouTube \u4e0a\u64ad\u653e\u548c\u89c2\u770b\u3002\u51c6\u5907\u597d\u7206\u7c73\u82b1\u548c\u62ab\u8428\u5427\uff01\n\n\u5176\u4ed6\n\u60a8\u5728\u865a\u62df\u4e16\u754c\u4e2d\u91c7\u53d6\u7684\u884c\u52a8\u8d8a\u591a\uff0c\u60a8\u53ef\u4ee5\u6536\u96c6\u7684\u8d44\u91d1\u5c31\u8d8a\u591a\u3002\u6709\u4e86\u8fd9\u7b14\u8d44\u91d1\uff0c\u60a8\u53ef\u4ee5\u4ece\u5546\u5e97\u8d2d\u4e70\u6f