nt-iad3-1.oculuscdn.com&oh=00_AYCPPAK4xKDOccKD2BNYj1Pa3kTXGY7KNqF8B9WPVu-hlg&oe=676D3224"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "heroart (1).png", "id": "255464397022691", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568668_255464400356024_7599096233503142883_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s6vJVgKvUv8Q7kNvgEeiJU1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0GCKADC2azgloIPKUIBaYqc0q-uk8mNj8d4W8SGITIw&oe=676D3051"}, "display_name": "Baboon", "keywords": [], "long_description": "Discord: https://discord.gg/bm2cv74hrW \n\n\nIntuitive Movement Mechanics:\nAt the core of \"Baboon\" are the intuitive movement mechanics, taking inspiration from \"Gorilla Tag\" and enhancing them to create a diverse and dynamic gameplay experience.\n\nSprinting: Channel your inner baboon as you sprint through the jungle at breakneck speeds, leaving your opponents in the dust. The sensation of speed is exhilarating, and you'll feel like a true jungle sprinter.\n\nLeaping and Climbing: Baboons are known for their agility, and in \"Baboon,\" you can leap incredible distances and climb up trees and cliffs with ease. The game's physics system ensures that every jump and climb feels responsive and realistic", "short_description": "Welcome to \"Baboon,\" an exhilarating game where you become a nimble baboon, inspired by the electrifying movements of gorillas. In this high-octane multiplayer adventure, you'll swing through trees, leap between platforms, and race your friends in a lush, immersive jungle environment. \"Baboon\" brings the thrill of \"Gorilla Tag\" to new heights, with intuitive, heart-pounding movement mechanics that put you in the heart of the action."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/baboonery/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "pepega", "support_website_url": null, "website_url": "https://sites.google.com/view/baboonery/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7094365053918116"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001703_296110469936318_6886108619206940017_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BJOEL0XbG7oQ7kNvgEPW4hq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMvHicpsX4eIGlu2Pj76J5xdkafJqfXFcQ_dwyTXhW6w&oe=676D448F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Baboon", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1697726124, "lastRevision": {"nodes": [{"id": "6881528278535129", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6881528258535131", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "337410442290704"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "MiniLandscape.png", "id": "3570743539820811", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031479_3570743543154144_6696277748465146028_n.