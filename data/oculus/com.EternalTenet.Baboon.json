you'll swing through trees, leap between platforms, and race your friends in a lush, immersive jungle environment. \"Baboon\" brings the thrill of \"Gorilla Tag\" to new heights, with intuitive, heart-pounding movement mechanics that put you in the heart of the action."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/baboonery/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "pepega", "support_website_url": null, "website_url": "https://sites.google.com/view/baboonery/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6920537374634219"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "674691024757479"}]}, "baseline_offer": {"id": "674691024757479"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697726124, "status": "PUBLISHED", "id": "674691024757479"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7698662260155056", "version": "0.37"}, "id": "3258943624410228", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6881528258535131", "is_concept": false, "latest_released_binary":