KytWp7JA&oe=67559148"}, {"file_name": "NEON_Store_02.png", "id": "464361479272292", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974758_464361485938958_4228011701016162833_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mMFxMVvOHVYQ7kNvgH1OUpW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXXkbqI-M3GAzrhG_M930Bw2-L8vO3v4d68MccGrAySw&oe=67559D70"}, {"file_name": "NEON_Store_03.png", "id": "724454076431619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035424_724454083098285_6512103179725332886_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzJoqnYBn3YQ7kNvgEpAhHJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBj9vDyZYjvjZhAljElkj9W_KeigoHt_4TgjgKYj0-0UA&oe=675583F9"}, {"file_name": "NEON_Store_04.png", "id": "257065704155491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982652_257065707488824_1737069673614396722_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tb6XN1DB5zkQ7kNvgGik7Rp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCC1kFfv4x2D4Y6t2SJy_2EArn0kLW_JJkFCfWs9pYz4A&oe=6755714E"}, {"file_name": "NEON_Store_05.png", "id": "1673242923417334", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469629_1673242926750667_783934628841519375_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Susj5Twx9_sQ7kNvgFmB3bo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBLNZv1isu36hsC1AKOBWaFd9fyrDP6elUjGSSvyVLWQ&oe=67558579"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage.png", "id": "569792655646743", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468871745_569792662313409_3088814771807349512_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huM5lqvg5B8Q7kNvgFAS7Ki&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaVdASwSYzue0U6VjD9gxcju91QjMlbOxGUwuAqIa0hA&oe=67559711"}, "display_name": "NEON Squad Tactics", "keywords": [], "long_description": "- Turn-based tactics strategy game with a compelling single-player campaign and drop in / drop out multiplayer missions for up to 4 players.\n- 31 playfields across 3 diverse biomes. \n- Choose from 9 playable Squad members - Floor Model / Assassin / Vanguard / Ravager / Juggernaut / E-Goop / Ghost / Queen / Wildcard\n- Over-the-top futuristic weaponry includes laser swords, combat drones, lightning launchers, smart mines, nano-bots, and more.\n- Wagering system. The bigger the risks, the bigger the rewards!\n- Buy drinks at the bar. Throw them on the battlefield for added buffs.\n- Hyper-retro 90s aesthetic and a modern synthwave soundtrack featuring tracks by AM0k, Metasphere, Fynn\u2019s Arcade, Hearts in Beta and Monster Mansion. \n\n\n", "short_description": "A turn-based tactics strategy game with a compelling single-player campaign and drop in / drop out multiplayer missions for up to 4 players. Choose from 9 playable Squad members and battle it out across 31 playfields, generated by a holographic table in a cyberpunk bar. Upgrade your crew with a wide array of weapons and gadgets, and reap the rewards with clever wagering and strategy. While you're here, grab a drink at the bar and throw it on the table for extra buffs!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinmangames.com.au/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Tin Man Games", "support_website_url": "https://tinmangames.com.au/contact/", "website_url": "https://tinmangames.com.au/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_playe