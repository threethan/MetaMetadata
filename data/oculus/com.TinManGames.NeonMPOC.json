0_AYCHjItKIsxuJXkXrO5L26rkqcyluz_fnFUweKFBaf_vKA&oe=675596E3"}]}, "id": "1194294338031608", "locale": "en_US", "screenshots": [{"file_name": "NEON_Store_01.png", "id": "456937680032207", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031538_456937683365540_23961723034282453_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_EiR2BtBasQ7kNvgHwIx20&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDf_gBle_I9EEGZZ63QP5REcUxclXVOGhwXRSKytWp7JA&oe=67559148"}, {"file_name": "NEON_Store_02.png", "id": "464361479272292", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974758_464361485938958_4228011701016162833_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mMFxMVvOHVYQ7kNvgH1OUpW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXXkbqI-M3GAzrhG_M930Bw2-L8vO3v4d68MccGrAySw&oe=67559D70"}, {"file_name": "NEON_Store_03.png", "id": "724454076431619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035424_724454083098285_6512103179725332886_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzJoqnYBn3YQ7kNvgEpAhHJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBj9vDyZYjvjZhAljElkj9W_KeigoHt_4TgjgKYj0-0UA&oe=675583F9"}, {"file_name": "NEON_Store_04.png", "id": "257065704155491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982652_257065707488824_1737069673614396722_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tb6XN1DB5zkQ7kNvgGik7Rp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCC1kFfv4x2D4Y6t2SJy_2EArn0kLW_JJkFCfWs9pYz4A&oe=6755714E"}, {"file_name": "NEON_Store_05.png", "id": "1673242923417334", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469629_1673242926750667_783934628841519375_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Susj5Twx9_sQ7kNvgFmB3bo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBLNZv1isu36hsC1AKOBWaFd9fyrDP6elUjGSSvyVLWQ&oe=67558579"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NEON_VidCover.png", "id": "1027149605449777", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222943_1027149608783110_2994484418473768632_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BjhH-IO0-4QQ7kNvgH_0aYG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZSxA6PEsvuX6gmawIOcOhYX9DggVxEojzdPMOAXNLLA&oe=675597B3"}, "display_name": "NEON Squad Tactics", "keywords": [], "long_description": "Welcome to UltraCity, where the neon-lit streets pulse with the rhythm of cybernetic life. In NEON Squad Tactics, immerse yourself in the heart of a cyberpunk metropolis as one of the elite Operators, capable of projecting your consciousness into a team of skilled heroes known as the NEON Squad.\n\nGather your friends or online allies and navigate the vibrant, wacky world from the comfort of a virtual bar. A captivating holographic table serves as your interface to key locations in the city and beyond. You'll undertake daring missions on behalf of the powerful corporations, all under the guidance of an enigmatic Handler.\n\nBut success demands more than just brute force. As you navigate the dangerous streets, underworld, and irradiated badlands, strategic thinking and clever teamwork will be your greatest assets. Coordinate your squad's actions in thrilling turn-based tactical battles, where every decision could mean the difference between victory and defeat.\n\nPre-mission planning is crucial. Wager wisely to secure valuable resources and credits, essential for recruiting new squad members and crafting advanced weaponry and cybernetic enhancements. Choose your team carefully, each member bringing unique skills and abilities to the table. Customize your squad members to suit your playstyle!\n\nForge alliances, outsmart your enemies, and rise to the top of the cybernetic food chain. Are you ready to become a legend in the neon-lit world of the NEON Squad?", "short_description": "Get ready for NEON Squad Tactics: an electrifying turn-based tactics experience where you, your friends and online allies plunge into UltraCity's cybernetic underworld as elite bounty hunters! Strategize, battle, and shape the city's destiny in epic strategic showdowns. Are you prepared to lead your squad to victory amidst the neon-lit chaos?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinmangames.com.au/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Tin Man Games", "support_website_url": "https://tinmangames.com.au/contact/", "website_url": "https://tinmangames.com.au/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "SINGLE_USER"], "id": "2757697737869767"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "3990769394500791"}, {"status": "PUBLISHED", "id": "427543290082655"}]}, "baseline_offer": {"id": "427543290082655"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "3990769394500791"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8588535427895005", "version": "1.0.8"}, "id": "500264291482319", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4882322701849648", "is_concept": false, "latest_released_b