 of game- 2 game modes: \n1)  3.5 minute demo time limit in the dark mode\n(full game has no time limit and an extra game mode with extra timed visual hints)\n2) Exploration mode with puzzles off, light on, and no timer\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.zosustudio.com/", "developer_terms_of_service_url": "http://www.zosustudio.com/", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "https://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "EXPLORATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "739414090486712"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "621846282674205"}]}, "baseline_offer": {"id": "621846282674205"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1665903600, "status": "PUBLISHED", "id": "621846282674205"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8089096401164329", "version": "1.158"}, "id": "3049658738659496", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7850202051720433", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8089096401164329"}, "release_status": "RELE