03411922099_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8WAuSYzELt0Q7kNvgFBH94Y&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6aSYv2p1Gz6ppaNFlUE1EXrSb6kUYiXKoIU4G3emZ2w&oe=66F7D2BF"}, {"file_name": "darkscreen5.png", "id": "1105133380424978", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031621_1105133383758311_6873446132024460387_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nBN8_W0H2IQQ7kNvgG17laa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCqxLab32eqSPBZu5j1HBEUEsJVv_T-0VgjXwmYnHfTng&oe=66F804EC"}, {"file_name": "darkscreen1.png", "id": "437924861651698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035438_437924864985031_4403920815778226323_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwvfp9Y2WrMQ7kNvgE-8FqO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiTKZt2u_AIHt6P2F208RsuX4_d5fK3-FNAtvF17gr6Q&oe=66F7FFEC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "darkscreen4.png", "id": "479696827019627", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982680_479696830352960_5549907941080741188_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-zyJzghCEz0Q7kNvgGokf84&_nc_ht=scontent.oculuscdn.com&oh=00_AYCw6lHQGLiW3YZRgpfFdL2P2S-hM2wxg0SHI1ram6j7kA&oe=66F7D7C2"}, "display_name": "ZOSU Castle Morgue Escape Demo", "keywords": [], "long_description": "Demo of \"ZOSU Castle Morgue Escape\"\n- You awaken in a dark and spooky castle that was being used as morgue after a pandemic and must find your way out through a series of simple puzzles and mechanics, it is very dark, but fortunately you have a flashlight\n- This is a casual and somewhat scary escape-room/area type of game\n- Some events are slightly randomized for replay ability\n- 2 game modes: \n1)  3.5 minute demo time limit in the dark mode\n2) Exploration mode with puzzles off, light on, and no timer\n", "short_description": "- You awaken in a dark and spooky castle that was being used as morgue after a pandemic and must find your way out through a series of simple puzzles and mechanics, it is very dark, but fortunately you have a flashlight\n- This is a casual and somewhat scary escape-room/area type of game- 2 game modes: \n1)  3.5 minute demo time limit in the dark mode\n(full game has no time limit and an extra game mode with extra timed visual hints)\n2) Exploration mode with puzzles off, light on, and no timer\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.zosustudio.com/", "developer_terms_of_service_url": "http://www.zosustudio.com/", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "https://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "EXPLORATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "739414090486712"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035322_394406892652192_7672717385601277325_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XbtfYwW7W0kQ7kNvgHZpDpt&_nc_ht=scontent.oculuscdn.com&oh=00_AYALRwT1SN7bWm7zcDSFx5IKFpbi3_4fN9l7khP5oFvZ8Q&oe=66F7EA39"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ZOSU Castle Morgue Escape Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1665903600, "lastRevision": {"nodes": [{"id": "7850202235053748", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata":