=sxi46B9Zq74Q7kNvgGd5RX-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQxywkIyhe5pEg9o3gi6VfxBsGhKZcL375eQh_EaFtyQ&oe=6784EA41"}, {"file_name": "M1.png", "id": "1216361798974392", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031447_1216361802307725_8039935415640532482_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JrUzD9N5gscQ7kNvgGIMbJ4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBllI8CSkU5TPdWN9PTeRBUCRJZ-5BCYEocaQVycb9aVw&oe=6784E87D"}, {"file_name": "B3.png", "id": "722131162741458", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_722131166074791_7213949306635626087_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-la4kykIJ3gQ7kNvgGxkAxE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXXfAEkKgVKLjDJaQLbCdjathM7cpu_Idv74W7XiN7IQ&oe=67851370"}, {"file_name": "B1.png", "id": "892308705227836", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262747_892308708561169_3687301272969524582_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ZoWTAbKqCEQ7kNvgHOqSBI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoEDC-__0uMBEYusS8y2HW0XfoYgvt4nz2MNcpWigKIQ&oe=678500A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "UPGRADE_VideoCover.png", "id": "456245369483804", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035406_456245376150470_4810981854464787811_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CaDIpPym7yEQ7kNvgFGtxjq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNN7ItI2Uq5hC8tG2zSKiL-wRrJaguy6rxlr92_sR8ag&oe=6784F91E"}, "display_name": "Upgrade VR", "keywords": [], "long_description": "Developed by neuropsychologists, UPGRADE VR is a fun, simple training routine that helps you test and hone your brain\u2019s cognitive skills.\n\nExercise with UPGRADE VR every day to improve your cognitive skills, such as:\n\n- memory\n- concentration and attention span\n- reaction\n- eye-hand coordination\n- stress tolerance\n\nOur entertaining and engaging workout only takes 10\u202615 minutes a day. Training feels like playing a game!\n\nTrack your progress in our mobile app UPGRADE VR where  you can review your achievements, read interesting news about brain-related research and the latest discoveries in neuropsychology.\n\nNote that cognitive training could be a useful addition to comprehensive COVID-19 recovery regimen.\n\nUPGRADE your brain now!\n", "short_description": "Developed by neuropsychologists, UPGRADE VR is a fun, simple training routine that helps you test and hone your brain\u2019s cognitive skills.\nThis cognitive VR-training could be a useful addition to comprehensive COVID-19 recovery regimen.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vr-upgrade.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "UPGRADE VR \u2013 FZCO", "support_website_url": null, "website_url": "https://vr-upgrade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "MEDICINE", "ARCADE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1532775580551572"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982528_739376764466048_2889236259863729106_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LQ_jEf0IhZcQ7kNvgHc7Qw4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.