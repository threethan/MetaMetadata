=uSDmrgVZlSIQ7kNvgHOWftW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBc_TjKuINsZthLkd3ttFfx110l2V61gSOBRre__wGWcQ&oe=671CC3C1"}, {"file_name": "M1.png", "id": "1216361798974392", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031447_1216361802307725_8039935415640532482_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jb4nIC0IJbEQ7kNvgG6Dhan&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIibChoxNb_5H4xulipFRd46nQrA6jueSwiNtx9P1FuA&oe=671CC1FD"}, {"file_name": "B3.png", "id": "722131162741458", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_722131166074791_7213949306635626087_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P7qWnv2aqw8Q7kNvgHaf-6F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAH40zXRveIExXQeznazssta9MaRkgoqhxUiWY6M5F0LA&oe=671CECF0"}, {"file_name": "B1.png", "id": "892308705227836", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262747_892308708561169_3687301272969524582_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=19DkTuvuzl8Q7kNvgEjtUHu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDPAwxKrLnmlBAk_loELa0l-X1B8bLgtxIVLen6vQGW_w&oe=671CDA29"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "UPGRADE_VideoCover.png", "id": "456245369483804", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035406_456245376150470_4810981854464787811_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gMgNt8EsKUUQ7kNvgEWX-kE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNw6Oi66xBHx3eCQ6LCYq8hwZ1vPz9cz6tbS1eXU-ABw&oe=671CD29E"}, "display_name": "Upgrade VR", "keywords": [], "long_description": "Developed by neuropsychologists, UPGRADE VR is a fun, simple training routine that helps you test and hone your brain\u2019s cognitive skills.\n\nExercise with UPGRADE VR every day to improve your cognitive skills, such as:\n\n- memory\n- concentration and attention span\n- reaction\n- eye-hand coordination\n- stress tolerance\n\nOur entertaining and engaging workout only takes 10\u202615 minutes a day. Training feels like playing a game!\n\nTrack your progress in our mobile app UPGRADE VR where  you can review your achievements, read interesting news about brain-related research and the latest discoveries in neuropsychology.\n\nNote that cognitive training could be a useful addition to comprehensive COVID-19 recovery regimen.\n\nUPGRADE your brain now!\n", "short_description": "Developed by neuropsychologists, UPGRADE VR is a fun, simple training routine that helps you test and hone your brain\u2019s cognitive skills.\nThis cognitive VR-training could be a useful addition to comprehensive COVID-19 recovery regimen.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vr-upgrade.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "UPGRADE VR \u2013 FZCO", "support_website_url": null, "website_url": "https://vr-upgrade.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "879473995923081"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "MEDICINE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1532775580551572"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982528_739376764466048_2889236259863729106_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RtQzTOnGUrsQ7kNvgHD_eo4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculusc