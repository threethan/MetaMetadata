e": "AndroidBinary", "id": "23986158110971326"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1078026156263305"}]}, "change_log": "1.6.0", "created_date": 1688759071, "id": "23986158110971326", "version": "1.6.0", "version_code": 5, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7524228527590878", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "23986158110971326"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1078026156263305"}]}, "change_log": "v1.5.0\n- Added analytics system: graphs with training results\n- Added new music tracks\n- Added leaderboards (in UI and on the big screen at the location)\n- Fixed minor bugs with UI display\n- Added mini-game \"Tower of Ice Cubes\"\n- Pause is now activated when the user removes the HMD (Oculus)\n- New Stress Factor - Lizard\n- New Stress Factor - Robot Vacuum Cleaner\n- New environment: added volcano and eruption\n- New environment: added spaceship\n- New to the environment: added window cleaning robot\n- New environment: added flying robot birds\n- New environment: Ventilation tapes\n- New to the environment: added neon ceiling lights\n- Updated material for hand tracking game mode (Oculus Quest)\n- Fixed lighting from external lamps when roller shutters are closed\n- Added activity monitoring system and display of burned kcal during training\n- Fixed missing session end stats in tutorial when ending via pause menu\n- Added additional HUD on the player's hand\n- Fixed a bug with playing background music when starting the \"Geometric Runner\" mini-game\n- Fixed pause timer, now it shows the correct elapsed time\n- The player can no longer interact with objects while paused in training\n- Fixed memorization time on difficulty level 0\n- Installation of new monitors on the main level, updated appearance of bonuses\n- Fixed neuropoints going beyond four digits or higher in the pause menu\n- Fixed shifting of hands in collisions during reaction training\n- Updated the physics of the game table in the mini-game \"Ping-Pong\"\n- Fixed practice menu options showing the first values from the list instead of the actual difficulty level 0 values when opening the menu\n\n---\nTrain your brain with pleasure!", "created_date": 1679919540, "id": "9624241030922940", "version": "1.5.0", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7524228527590878", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "23986158110971326"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1078026156263305"}]}, "change_log": "Update v.1.4.0\n\nList of modifications:\n\n- Redesigned interface (UI)\n- Added new user registration in VR (without mobile app)\n- Added \"Delete account\" function\n- Added Steam Authorization\n- Redesigned the appearance of awards\n- New balancing of difficulty parameters in all trainings\n- Added bonus - \"Water\"\n- Added bonus - \"Ice\"\n- Added bonus - \"Markers\"\n- Added bonus - \"Game table: Air Hockey and Ping-Pong\"\n- Bonus Monitor displaying a list of bonus items and mini-games\n- Added new training stressors (sparks, lizard, renovation noise, l- ighting problems)\n- New difficulty system - new types of difficulty at every 20 levels in all 5 trainings\n- Optimized 3D models and location materials\n- Added introductory tutorial (text, screenshots)\n- New shelves for awards\n- Added roller shutter control panel - now you can change the lighting of the room when playing on the holographic game table\n- Updated development team list\n- Transition to Unreal Engine version 4.27\n- Improved the mechanics of catching projectiles in the REACTION training\n- Improved shape generator in the SYNCHRONIZATION training\n- Updated VFX in COORDINATION training\n- Received bonus items are now hidden during training\n- Added connection error message if game server or internet is not available.\n- Added new sound effects to trainings\n- Updated parameters in the \"training\" mode\n- Added collisions for location objects\n- Added UI scrolling with stick/trackpad.\n- Removed notification about saving progress every 5 difficulty level for guest user.\n- Fixed bugs with the exchange of profile data\n- Fixed bugs with saving configured parameters\n- Animation and hand posing bug fixed\n- Fixed animation of opening/closing roller blinds\n- Fixed a bug with filling the cup in the \"Coffee Machine\" bonus\n- Fixed capture and transfer of physical objects during teleportation\n- Fixed binding to trainer activation point when user is already standing on the activation marker\n- Fixed an issue where pause was available after the game ended", "created_date": 1659341973, "id": "8397338293613226", "version": "1.4.0", "version_code": 3, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7524228527590878", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "23986158110971326"}, "release_status": "RELEASED"}, "binary_release_c