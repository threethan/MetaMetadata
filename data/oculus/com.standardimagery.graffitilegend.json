RAFFITI LEGEND", "keywords": [], "long_description": "Graffiti Legend is a unique spray simulator engine.\nCreate unique and digital high quality graffiti and art pieces.\n\nStep into GRAFFITI LEGEND VR and let your imagination run wild. \nWith lifelike spray tools and a vast palette, create stunning, \nlarge-scale artwork in an immersive space.\nShape colors and textures with precision, experimenting freely as you bring your artistic vision to life without limits.  \n\nBecome a true digital GRAFFITI LEGEND artist\n\n{583990970967367}\n{2346501429047777}\n{539563508960595}\n{500815739625868}", "short_description": "Graffiti Legend is a unique spray simulator engine.\nCreate unique and digital high quality graffiti and art pieces.\n\nStep into GRAFFITI LEGEND VR and let your imagination run wild. \nWith lifelike spray tools and a vast palette, create stunning, \nlarge-scale artwork in an immersive space.\nShape colors and textures with precision, experimenting freely as you bring your artistic vision to life without limits.  \n\nBecome a true digital GRAFFITI LEGEND artist"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.graffitilegendvr.com/privacypolicy.php", "developer_terms_of_service_url": null, "publisher_name": "https://www.graffitilegendvr.com/", "support_website_url": null, "website_url": "https://www.graffitilegendvr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_inter