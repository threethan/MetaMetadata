0x1440.png", "id": "378037096739289", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462958_378037100072622_3702382533221669080_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RNY6NWJRyLsQ7kNvgHeA80z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzWS5gfMEk-9iOz31SytGcYQnkXd_0oeViFn8CVvHsww&oe=67544D44"}, {"file_name": "ScreenShot_2_2560x1440.png", "id": "4215653161778688", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974786_4215653165112021_6595541215764621791_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NhkobLz3dt0Q7kNvgFb-7h2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAtm0BKdiWYvV5z40u1Sudve09VxEa3hosZImj5d66fEA&oe=67542683"}, {"file_name": "ScreenShot_5_2560x1440.png", "id": "452941665801976", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974766_452941669135309_8968881839752891046_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1KcckK6AMpwQ7kNvgHLnaQL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDicv5j1146k0BWNqQAIzzjZPgthTFtDY8eIReWOmeagA&oe=675439EA"}, {"file_name": "MR1.png", "id": "903222641336761", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001710_903222644670094_3915023995443464496_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CgWu_QMh450Q7kNvgEmmvRp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB-YY9JB3bnc_luXx-71y_kbhs8kSvqbeDybX8OvWf3ZA&oe=67545071"}, {"file_name": "MR2.png", "id": "1582603442567220", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974873_1582603445900553_445949884455277596_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HzvGaqDhZMIQ7kNvgHdJVwC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8gAU2WfHgWkjjzqPTeGWjJgNJ3tHgBYoFBmTc6LxlYg&oe=67542906"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Lanscape_2560x1440_2.png", "id": "285702526555529", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974454_285702533222195_869352482818595611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KYFwqNCooqcQ7kNvgFI-hY3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3DfNqU1qbG9OBKwU2S8x02rUzIKrIRlHynfvQ_WJBMg&oe=675433F9"}, "display_name": "MissionX VR Laser Tag", "keywords": [], "long_description": "Unlock a new era of Mixed reality gaming! \n\nMissionX, a competitive multiplayer FPS game that will turn your play space into a free-roam virtual battlefield. With MissionX, you can create a fun and active shooting laser arena for friends and family right in your backyard, warehouse, basketball court...for a battle or team up against the AI enemy.\n\n\ud83c\udf89 What's new \ud83c\udf89\n- Create your own competitive shooting arena in mixed reality\n- Arena battle or Co-op multiplayer\n- Customize game maps in any shape, any size \n- Calorie consumption tracking\n\n\u2b50\ufe0f Instructions \u2b50\ufe0f\n- Create your mixed reality game map: https://youtu.be/cAhBCJast0U \n- How to set up the game: https://youtu.be/iJJDlxrCwSk\n\n\u2b50\ufe0f Note \u2b50\ufe0f\n- When playing multiplayer, mark a position on the floor, player stands at that position, looks straight and holds the home button on the controller for 3 seconds to synchronize the position in the game.\n- To use the large play space, it is necessary to turn off the Guardian. At this time, you need to pay attention to your own safety to avoid bumping into furniture in the house.\n\nGot any questions or feedback? Please shoot us an email at missionx@holomia.com", "short_description": "Unlock a new era of Mixed reality gaming! \n\nMissionX, a competitive FPS game that will turn your play space into a free-roam virtual battlefield. With MissionX, you can create a shooting laser arena for friends and family right in your backyard, warehouse, basketball court...for a battle or team up against the AI enemy.\n\n-Create your own competitive shooting arena in mixed reality\n-Arena battle or Co-op multiplayer\n-Customize game maps in any shape, any size \n-Calorie consumption tracking"}]}, "devel