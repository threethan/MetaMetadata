0x1440.png", "id": "378037096739289", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75462958_378037100072622_3702382533221669080_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lGfHLtOhXA0Q7kNvgFXgdLX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAq8GMcjRqMufTUgGRWQcyIrPT2F5sUsVJqb99nhlRoUA&oe=6756F044"}, {"file_name": "ScreenShot_2_2560x1440.png", "id": "4215653161778688", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974786_4215653165112021_6595541215764621791_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XLlpOeg7ogkQ7kNvgGofYoY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBh0h-fyD2-VPTVlwVEpceUoqeiekh5W6hW63eKF7yDKQ&oe=6756C983"}, {"file_name": "ScreenShot_5_2560x1440.png", "id": "452941665801976", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974766_452941669135309_8968881839752891046_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1KcckK6AMpwQ7kNvgFpNhjt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDb-7J3--lymySkVwlxuDqed2FiS89tlCF5d42ym3lIkQ&oe=6756DCEA"}, {"file_name": "MR1.png", "id": "903222641336761", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001710_903222644670094_3915023995443464496_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E4uXv6qOTJgQ7kNvgGl_ofe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD0k7swvQsVxUpGC99LcOPBV2XtJntO5GAjLhF1lURccw&oe=6756F371"}, {"file_name": "MR2.png", "id": "1582603442567220", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974873_1582603445900553_445949884455277596_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ANgaoebzirkQ7kNvgFhoRMV&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDu760IrEeMJzZTTwHk7mdL1GfvEIBadK6Dfx8yjwXjCQ&oe=6756CC06"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Lanscape_2560x1440_2.png", "id": "285702526555529", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974454_285702533222195_869352482818595611_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2U1W5RzFfzAQ7kNvgFjze2Z&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDwhE4l86gAaa19stI8rwnVWBtddhhjfbq1pM2aONhqpw&oe=6756D6F9"}, "display_name": "MissionX VR Laser Tag", "keywords": [], "long_description": "Unlock a new era of Mixed reality gaming! \n\nMissionX, a competitive multiplayer FPS game that will turn your play space into a free-roam virtual battlefield. With MissionX, you can create a fun and active shooting laser arena for friends and family right in your backyard, warehouse, basketball court...for a battle or team up against the AI enemy.\n\n\ud83c\udf89 What's new \ud83c\udf89\n- Create your own competitive shooting arena in mixed reality\n- Arena battle or Co-op multiplayer\n- Customize game maps in any shape, any size \n- Calorie consumption tracking\n\n\u2b50\ufe0f Instructions \u2b50\ufe0f\n- Create your mixed reality game map: https://youtu.be/cAhBCJast0U \n- How to set up the game: https://youtu.be/iJJDlxrCwSk\n\n\u2b50\ufe0f Note \u2b50\ufe0f\n- When playing multiplayer, mark a position on the floor, player stands at that position, looks straight and holds the home button on the controller for 3 seconds to synchronize the position in the game.\n- To use the large play space, it is necessary to turn off the Guardian. At this time, you need to pay attention to your own safety to avoid bumping into furniture in the house.\n\nGot any questions or feedback? Please shoot us an email at missionx@holomia.com", "short_description": "Unlock a new era of Mixed reality gaming! \n\nMissionX, a competitive FPS game that will turn your play space into a free-roam virtual battlefield. With MissionX, you can create a shooting laser arena for friends and family right in your backyard, warehouse, basketball court...for a battle or team up against the AI enemy.\n\n-Create your own competitive shooting arena in mixed reality\n-Arena battle or Co-op multiplayer\n-Customize game maps in any shape, any size \n-Calorie consumption tracking"}]}, "devel