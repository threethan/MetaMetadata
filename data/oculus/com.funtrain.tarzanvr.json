, {"file_name": "tarzan_screenshot_2560x1440_swim_rev.png", "id": "607679993967746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982644_607679997301079_5676819698885370613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VC3spPH5qGcQ7kNvgFEKk9h&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQsyo5ne0PPcsKhr0Rn5JUf&oh=00_AYCYasYT5DnwrgZnOy31z13g6eUufoiMS_ilOJte7T-2fw&oe=66E03347"}, {"file_name": "tarzan_screenshot_2560x1440_axe_rev.png", "id": "830940717536179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_830940720869512_707273189859452091_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=naqNV60esR0Q7kNvgHItZrf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQsyo5ne0PPcsKhr0Rn5JUf&oh=00_AYDRdrpAQwekWlh7mKmogzS8xyAWg9JjwujZo3bf7aM3OQ&oe=66E02C31"}, {"file_name": "tarzan_screenshot_2560x1440_boat.png", "id": "910984213087982", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001681_910984216421315_3613691174291640982_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hwLt_RGK6HQQ7kNvgFFiYwM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQsyo5ne0PPcsKhr0Rn5JUf&oh=00_AYBVeKfGOD0PxD8TTpwA_JKy8JWqF0lPnhbxAgQ6SQ7rNg&oe=66E01AF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tarzan_thumb_2560x1440.png", "id": "325985715802257", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_325985719135590_8343625692976156521_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zksqe-p5bOMQ7kNvgHTCO0E&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQsyo5ne0PPcsKhr0Rn5JUf&oh=00_AYCWX45-nA229MGmDtGcST4bB2wXLCd5d8UmrU3tKTEJBQ&oe=66E03415"}, "display_name": "Tarzan VR\u2122", "keywords": ["Tarzan", "fighting"], "long_description": "Become Lord of the Jungle!\n\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous predators and challenges \u2014 experienced through a serialized comic-style adventure.  You get all 3 game episodes together in this release!\n\nEmbrace your inner ape ;) and bring the world\u2019s most legendary action hero to life!\n\nIssue 1 \u2013 \u201cThe Great Ape\u201d: Jane has been abducted by a group of invaders and Tarzan must seek the wisdom of The Great Ape in order to find the trail of her captors.  Features The Mighty Axe.\n\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d: Tarzan begins his pursuit of Jane\u2019s captors and must make his way across dangerous cliffs where one misstep leads to certain doom. Features the Slingshot.\n\nIssue 3 \u2013 \u201cThe Dead of Night\u201d: The jungle swamp poses all manner of hidden dangers.  Only the secret found in The Valley of Forever can save the life of Tarzan\u2019s true love. Features The Long Bow!", "short_description": "Welcome to the Jungle! Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part adventure created especially for virtual reality. You get all 3 game episodes together in this release!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tarzanvirtualreality.com/privacy", "developer_terms_of_service_url": "https://www.tarzanvirtualreality.com/terms", "publisher_name": "Fun Train", "support_website_url": null, "website_url": "http://www.Tarzan-VR.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "460313872243130"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "381289398