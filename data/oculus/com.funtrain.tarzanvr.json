ng?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lHY-cskFm3gQ7kNvgHmer31&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhWH-2RVwLijwQQRLsouafm&oh=00_AYA64el1rNok81GpPMeZYCrvOd7i2TkSL15-L6L-dpZJaA&oe=66E587F4"}, {"file_name": "en_US_Tarzan_MetaScreenshots1_2560x1440xcf.png", "id": "1483056112590664", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_1483056119257330_7878151706059677087_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BlGF3-yi-tEQ7kNvgFPrHWD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhWH-2RVwLijwQQRLsouafm&oh=00_AYC88avSc0gFVITVen0Qc4KGbk10ZxwyEY1tjBzKV3b7ag&oe=66E569B8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tarzan_Comic_Landscape_2560x1440.png", "id": "1949951758788255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/429003650_1949951762121588_1459455801157323558_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z6e2EsuszHQQ7kNvgFjE9If&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhWH-2RVwLijwQQRLsouafm&oh=00_AYBFedkjoF70qqDSO1cMsL8FUNt6X5e2DB6MD2GJRx838w&oe=66E570C2"}, "display_name": "Tarzan VR\u2122", "keywords": ["fighting", "combat", "adventure", "gorilla", "boxing"], "long_description": "A massive new update to Tarzan VR!  Improved combat mechanics, vine swinging, and physics.  Fight your way across treacherous terrain to save Jane from her captors. What are you waiting for? Become Lord of the Jungle!\n\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous enemies, predators and challenges.\n\nIssue 1 \u2013 \u201cThe Great Ape\u201d\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d\nIssue 3 \u2013 \u201cThe Dead of Night\u201d\n\n", "short_description": "Become Lord of the Jungle!  Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part journey created especially for adventure fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.funtrainvr.com