ng?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3UTTjyPziXcQ7kNvgFj61w9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxxEquhnwI1HL_5D8KGL1kk&oh=00_AYCMhjYI0XGYI0J3nvalYAu8gaTkJWuylMM_G76OCrQngA&oe=66E82AF4"}, {"file_name": "en_US_Tarzan_MetaScreenshots1_2560x1440xcf.png", "id": "1483056112590664", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_1483056119257330_7878151706059677087_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFaUpxe5fTsQ7kNvgHK7NPB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxxEquhnwI1HL_5D8KGL1kk&oh=00_AYA45j1ETPp6aMeFTKNggjqFE_krUN-VGbZsA2zltATKZQ&oe=66E80CB8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tarzan_Comic_Landscape_2560x1440.png", "id": "1949951758788255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/429003650_1949951762121588_1459455801157323558_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TCy0RDuUZDEQ7kNvgEK3MBQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxxEquhnwI1HL_5D8KGL1kk&oh=00_AYDHRWo511IStkzh3TQXc3nxgPIfnZOI_L7wHhrgolHuGw&oe=66E813C2"}, "display_name": "Tarzan VR\u2122", "keywords": ["fighting", "combat", "adventure", "gorilla", "boxing"], "long_description": "A massive new update to Tarzan VR!  Improved combat mechanics, vine swinging, and physics.  Fight your way across treacherous terrain to save Jane from her captors. What are you waiting for? Become Lord of the Jungle!\n\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous enemies, predators and challenges.\n\nIssue 1 \u2013 \u201cThe Great Ape\u201d\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d\nIssue 3 \u2013 \u201cThe Dead of Night\u201d\n\n", "short_description": "Become Lord of the Jungle!  Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part journey created especially for adventure fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.funtrainvr.com