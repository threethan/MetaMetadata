tent-lga3-3.oculuscdn.com&oh=00_AYCrTzagtrX1Av9_YIRzSA7hMr5eTIzu2ktHmiSIJEN9kg&oe=67583A74"}, {"file_name": "en_US_Tarzan_MetaScreenshots1_2560x1440xcf.png", "id": "1483056112590664", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982551_1483056119257330_7878151706059677087_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KCciDH8Ea6kQ7kNvgE88Nwq&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAZcoBCVYGJ8rjswNdN6euBpunm8t3exIhTvgD9ZwD47g&oe=67581C38"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tarzan_Comic_Landscape_2560x1440.png", "id": "1949951758788255", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/429003650_1949951762121588_1459455801157323558_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DqDcMXH2QwcQ7kNvgEHzv5W&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBJb9uOXE66jh6TE50FijUCgjfjnN8PkxlM5sXfKE_vaQ&oe=67582342"}, "display_name": "Tarzan VR\u2122", "keywords": ["fighting", "combat", "adventure", "gorilla", "boxing"], "long_description": "A massive new update to Tarzan VR!  Improved combat mechanics, vine swinging, and physics.  Fight your way across treacherous terrain to save Jane from her captors. What are you waiting for? Become Lord of the Jungle!\n{1527376164589023}\n{1236022687575927}\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous enemies, predators and challenges.\n{854194480239447}\nIssue 1 \u2013 \u201cThe Great Ape\u201d\n\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d\n\nIssue 3 \u2013 \u201cThe Dead of Night\u201d\n{547932264391450}\n{1572309823366689}", "short_description": "Become Lord of the Jungle!  Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part journey created especially for adventure fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.funtrainvr.com/privacypolicy", "developer_te