scontent-sin6-3.oculuscdn.com&oh=00_AYDy18SJ3FRUafux9SiB0vU7ohqM2OYCLhk7vg_VlYJPTQ&oe=6728C474"}, {"file_name": "en_US_Tarzan_MetaScreenshots1_2560x1440xcf.png", "id": "1483056112590664", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982551_1483056119257330_7878151706059677087_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y1vMmeHFYmUQ7kNvgFEtRDr&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYC6RyEpm6tjtNvXPAtGwM1oL14SHg24STjvl8xGGKKf_g&oe=6728A638"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tarzan_Comic_Landscape_2560x1440.png", "id": "1949951758788255", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/429003650_1949951762121588_1459455801157323558_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2wVzYQx4dI0Q7kNvgGS2AJx&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCulD5XFWiJuidyXLiRt8mCnHHeNQ7NbNnYeSfcg7DEnA&oe=6728AD42"}, "display_name": "Tarzan VR\u2122", "keywords": ["fighting", "combat", "adventure", "gorilla", "boxing"], "long_description": "A massive new update to Tarzan VR!  Improved combat mechanics, vine swinging, and physics.  Fight your way across treacherous terrain to save Jane from her captors. What are you waiting for? Become Lord of the Jungle!\n{1527376164589023}\n{1236022687575927}\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous enemies, predators and challenges.\n{854194480239447}\nIssue 1 \u2013 \u201cThe Great Ape\u201d\n\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d\n\nIssue 3 \u2013 \u201cThe Dead of Night\u201d\n{547932264391450}\n{1572309823366689}", "short_description": "Become Lord of the Jungle!  Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part journey created especially for adventure fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.funtrainvr.com/privacypolicy", "develope