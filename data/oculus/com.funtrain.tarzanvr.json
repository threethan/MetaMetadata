shot_2560x1440_boat.png", "id": "910984213087982", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001681_910984216421315_3613691174291640982_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QdLf5p-HWAwQ7kNvgHxg_DJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjMLUPI-IF9AvGrXB12J-BskH2anF0eSTLdZWDPCbu2Q&oe=66F92773"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "tarzan_thumb_2560x1440.png", "id": "325985715802257", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_325985719135590_8343625692976156521_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PGoKezTWKe8Q7kNvgFTepOl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDokmKG1NVSkZAiVvjuOGYAocBCuDXuXlVoC4JQuQtrzA&oe=66F94095"}, "display_name": "Tarzan VR\u2122", "keywords": ["Tarzan", "fighting"], "long_description": "Become Lord of the Jungle!\n\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous predators and challenges \u2014 experienced through a serialized comic-style adventure.  You get all 3 game episodes together in this release!\n\nEmbrace your inner ape ;) and bring the world\u2019s most legendary action hero to life!\n\nIssue 1 \u2013 \u201cThe Great Ape\u201d: Jane has been abducted by a group of invaders and Tarzan must seek the wisdom of The Great Ape in order to find the trail of her captors.  Features The Mighty Axe.\n\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d: Tarzan begins his pursuit of Jane\u2019s captors and must make his way across dangerous cliffs where one misstep leads to certain doom. Features the Slingshot.\n\nIssue 3 \u2013 \u201cThe Dead of Night\u201d: The jungle swamp poses all manner of hidden dangers.  Only the secret found in The Valley of Forever can save the life of Tarzan\u2019s true love. Features The Long Bow!", "short_description": "Welcome to the Jungle! Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part adventure created especially for virtual reality. You get all 3 game episodes together in this release!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tarzanvirtualreality.com/privacy", "developer_terms_of_service_url": "https://www.tarzanvirtualreality.com/terms", "publisher_name": "Fun Train", "support_website_url": null, "website_url": "http://www.Tarzan-VR.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "460313872243130"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "3812893982313274"}, {"status": "PUBLISHED", "id": "1488635435117847"}, {"status": "PUBLISHED", "id": "1381734025591127"}, {"status": "PUBLISHED", "id": "1423398274719957"}, {"status": "PUBLISHED", "id": "426828609897300"}, {"status": "PUBLISHED", "id": "5573260489460049"}]}, "baseline_offer": {"id": "5573260489460049"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723741200, "status": "PUBLISHED", "id": "3812893982313274"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5717530441657029", "version": "2.2"}, "id": "675107206753225", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application