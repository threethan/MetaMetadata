1483056119257330_7878151706059677087_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Foh2J_Zi8oQ7kNvgH-0FyQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgctWLj8kp4o1jTcW4IcQ-0rq4s9_x4duiglnHU08_tg&oe=66DED238"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tarzan_Comic_Landscape_2560x1440.png", "id": "1949951758788255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/429003650_1949951762121588_1459455801157323558_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XWjY8lOHtIYQ7kNvgFHTBtm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjFOTppnmPdKqc09E2UrSOzrk8XOmzdxpgwmeF2TPG7A&oe=66DED942"}, "display_name": "Tarzan VR\u2122", "keywords": ["fighting", "combat", "adventure", "gorilla", "boxing"], "long_description": "A massive new update to Tarzan VR!  Improved combat mechanics, vine swinging, and physics.  Fight your way across treacherous terrain to save Jane from her captors. What are you waiting for? Become Lord of the Jungle!\n\nTarzan VR\u2122 transports players deep into 3 unique and fantastical jungle worlds teeming with action and excitement! Swing, swim, climb and fight your way through dangerous enemies, predators and challenges.\n\nIssue 1 \u2013 \u201cThe Great Ape\u201d\nIssue 2 \u2013 \u201cThe Jagged Edge\u201d\nIssue 3 \u2013 \u201cThe Dead of Night\u201d\n\n", "short_description": "Become Lord of the Jungle!  Swing, swim, climb and fight your way through the savage lands of Tarzan in an epic 3-part journey created especially for adventure fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.funtrainvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.tarzanvirtualreality.com/terms", "publisher_name": "Fun Train", "support_website_url": null, "website_url": "http://www.funtrainvr.com/tarzan", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {