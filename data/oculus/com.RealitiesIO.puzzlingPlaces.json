/t64.5771-25/39031619_3989921024389913_5193825855000827551_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J4zSl5VZ6FAQ7kNvgEHU4cT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyoLcSG-pmFhEv9mApJa5g4bCoryzwt8-icEeuQUFXPg&oe=673F2F91"}, {"file_name": "Shot_3_v2 2.png", "id": "3722059684561407", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289720_3722059687894740_8445453005920744310_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oT4ktLTnQMcQ7kNvgHGKFJI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDihPClYVPBxqK3UvPDbwr1rOL7D7pQlDe2RzH8KNPYJw&oe=673F383F"}, {"file_name": "Shot_4_v2 8.png", "id": "2876606199268411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250453_2876606205935077_5249840612440948855_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q2B4OrwygukQ7kNvgHVPQv4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdKrcSs5926YPXHp1l20ygb58-cijtB_ZGT3nv0VEkaQ&oe=673F2D14"}, {"file_name": "Shot_5 5.png", "id": "227935985869484", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210888_227935992536150_6922799241018991580_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=htcURuveMfoQ7kNvgFV9KMs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAgwUzl7DsjEjPm5TNaYSlevhj4F5Bhl96iARK9OPAH5Q&oe=673F26FF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PP_TrailerCover.png", "id": "203932744966676", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031530_203932748300009_2092154938978795572_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wip_tdpF9zEQ7kNvgG85EXx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0BBRVbFFanCxjB-PpV2DiYGzRi-TUr2JSAL0XeHujCQ&oe=673F22FB"}, "display_name": "Puzzling Places", "keywords": ["puzzle", "jigsaw", "relaxing", "photorealistic", "meditation"], "long_description": "Puzzling Places brings relaxing and wholesome 3D jigsaw puzzling to VR.\n\nPut together hyper-realistic miniatures of beautiful places from around the globe. Enter the meditative flow of puzzling and enjoy each place coming alive with their unique & immersive soundscapes as you complete them.\n\nPuzzling Places is a modern take on an age-old pastime that\u2019s fun for the whole family thanks to its simple gameplay and easy controls. Play seated, standing, or at full roomscale!\n\nThe game features 16 unique puzzles created from detailed photogrammetry 3D scans of real locations. Each puzzle is available in 25, 50, 100, 200 & 400 pieces!\n\nCity of Biarritz\n3 puzzles of the picturesque French Atlantic coast\n\nCultural Heritage of Armenia\n5 puzzles of Monasteries, Fortresses and Temples from Armenia\n\nThe Hallwyl Museum\n4 rooms from inside a palatial residence in Stockholm\n\nSingle Puzzles\n4 puzzles from traditional Japanese garb to a city in the sea", "short_description": "Puzzling Places brings relaxing and wholesome 3D jigsaw puzzling to VR.\n\nPut together hyper-realistic miniatures of beautiful places from around the globe. Enter the meditative flow of puzzling and enjoy each place coming alive with their unique & immersive soundscapes as you complete them.\n\nPuzzling Places is a modern take on an age-old pastime that\u2019s fun for the whole family thanks to its simple gameplay and easy controls. Play seated, standing, or at full roomscale!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.realities.io/privacy-policy", "developer_terms_of_service_url": "https://www.realities.io/terms-of-service", "publisher_name": "realities.io", "support_website_url": null, "website_url": "https://discord.gg/D2c3gHWR", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "EXPLORATION", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_