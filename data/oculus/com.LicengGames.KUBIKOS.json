-iad3-1.oculuscdn.com&oh=00_AYDGaHRxZ9Xtl8mONKP1n3OIWn2i0yftm-R-cFYElsHSrA&oe=671B988C"}, {"file_name": "Screenshot_4.png", "id": "450662372845877", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001663_450662376179210_8545309582865803537_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lAycSm3KowgQ7kNvgHqNCyL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCj-klddxr0SktC1XRwbfbUY434E8610J0u1JBysps54w&oe=671B69BA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 1.png", "id": "228207645857532", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003274_228207649190865_7820591263448171830_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7bMUFL6gbRgQ7kNvgHpyKUb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPgF0uQ_5NKG8Do8Po2m9nu2s5qlxk19uh_5kWY6OojA&oe=671B78E3"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "KUBIKOS set is a set of low poly, cartoony, building blocks. Game contains Egypt world, Platformer world, dungeon, published to date (100+ objects) and will be added to overtime.\n\nFeatures:\n*Add more than 1000+ object with out losing fps\n*Autosave. Your progress never be erased\n*You can build dungeon, castle\n*Build with out limit.\n*One of the best simulation games: begin constructing your dream world\n*Enjoy the visual and sound effects.\n*Build your own construction", "short_description": "You have a huge warehouse at your disposal. there are small remarkable and at the same time unusual objects. Using them you can try to build something original and phenomenal"}]}, "developer_name": "livbogdan", "developer_privacy_policy_url": "https://livbogdan.wixsite.com/licenggames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "livbogdan", "support_website_url": null, "website_url": "https://livbogdan.wixsite.com/licenggames/kubikos", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "contex