dn.com&oh=00_AYBW9uwDXrK6vQ37BuLWi0CRyGB1swXH81kD7wdYNJ-JKA&oe=66D196C0"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "Many block types:\n\nThere are many square sorts extending grass, square, water lava magma roads, crystals and much more. You have numerous choices with regards to building your realm.\n\nFeatures:\n\n*3 type of locomotion Flying, Teleport and Smooth\n*Autosave. Your progress never be erased\n*Big Landscape. You can build more than one world\n*Enable or disable player Gravity\n*Perfect game for the whole family.\n*Build anything\n*One of the best simulation games: begin constructing your dream world\n*Fun game: Play with villagers and animals it is so fun!\n*Cool graphics: enjoy the best graphics with animated cube.\n*Building game: Build your own construction", "short_description": "Build your own village. Decorate your house with your mates ' furniture and your own eyes. Learn more and more, and you will never be able to build massive castles and temples! Start building and show the world your best game and constructions. Crafting and Building is best game for the whole family."}]}, "developer_name": "livbogdan", "developer_privacy_policy_url": "https://livbogdan.wixsite.com/licenggames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "livbogdan", "support_website_url": null, "website_url": "https://livbogdan.wixsite.com/licenggames/kubikos", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user