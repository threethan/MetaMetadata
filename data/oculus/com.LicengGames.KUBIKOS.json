110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iHbcokKzRIcQ7kNvgGtjIyp&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoa3IFQTadb59k5E9aVltEc&oh=00_AYD-zaAxCEjxcrbuK00oBrMJmIX6fZL3qiG2ufeSdIyboQ&oe=66F0170C"}, {"file_name": "Screenshot_4.png", "id": "450662372845877", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_450662376179210_8545309582865803537_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OMmOpfhFS7oQ7kNvgFzfxdc&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoa3IFQTadb59k5E9aVltEc&oh=00_AYA4G5BFP7C-_V3xLT1n7e08S3VQxdjJkmfQfP294I-Xvg&oe=66EFE83A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560 1.png", "id": "228207645857532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_228207649190865_7820591263448171830_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nKcOJPQ0zrIQ7kNvgF5ZG-b&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoa3IFQTadb59k5E9aVltEc&oh=00_AYCjxWk_Q-FOKOudj5iGUGPE1Rah3xttpttEAUPFx85RPA&oe=66EFF763"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "KUBIKOS set is a set of low poly, cartoony, building blocks. Game contains Egypt world, Platformer world, dungeon, published to date (100+ objects) and will be added to overtime.\n\nFeatures:\n*Add more than 1000+ object with out losing fps\n*Autosave. Your progress never be erased\n*You can build dungeon, castle\n*Build with out limit.\n*One of the best simulation games: begin constructing your dream world\n*Enjoy the visual and sound effects.\n*Build your own construction", "short_description": "You have a huge warehouse at your disposal. there are small remarkable and at the same time unusual objects. Using them you can try to build something original and phenomenal"}]}, "developer_name": "livbogdan", "developer_privacy_policy_url": "https://livbogdan.wixsite.com/licenggames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "livbogdan", "support_website_url": null, "website_url": "https://livbogdan.wixsite.com/licenggames/kubikos", "category