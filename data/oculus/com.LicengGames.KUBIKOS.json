5T&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCl5uBYmQAtyP9uJn7dqbYEpsJ-dtFdpp9dLg8GXGryMA&oe=670E6FD2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "210978287513785", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974896_210978290847118_7672800902019600580_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hv4aNA6bUToQ7kNvgF7EkIA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_nP5-bGGu-OAmdF1ecHvIdELQmogjbgOa6GhvnWVQ3A&oe=670E3BC0"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "Many block types:\n\nThere are many square sorts extending grass, square, water lava magma roads, crystals and much more. You have numerous choices with regards to building your realm.\n\nFeatures:\n\n*3 type of locomotion Flying, Teleport and Smooth\n*Autosave. Your progress never be erased\n*Big Landscape. You can build more than one world\n*Enable or disable player Gravity\n*Perfect game for the whole family.\n*Build anything\n*One of the best simulation games: begin constructing your dream world\n*Fun game: Play with villagers and animals it is so fun!\n*Cool graphics: enjoy the best graphics with animated cube.\n*Building game: Build your own construction", "short_description": "Build your own village. Decorate your house with your mates ' furniture and your own eyes. Learn more and more, and you will never be able to build massive castles and temples! Start building and show the world your best game and constructions. Crafting and Building is best game for the whole family."}]}, "developer_name": "livbogdan", "developer_privacy_policy_url": "https://livbogdan.wixsite.com/licenggames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "livbogdan", "support_website_url": null, "website_url": "https://livbogdan.wixsite.com/licenggames/kubikos", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"},