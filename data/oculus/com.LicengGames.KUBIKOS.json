=6e7a0a&_nc_ohc=5wP-XNVp6Y8Q7kNvgFBbGhw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdEfEsGWpJpxTTKZicAj0tt&oh=00_AYAsoYC-kA4nTLDaFNIfaoN9eylWNMtVVE67_46Uy3uQ6w&oe=66DC53A2"}, {"file_name": "Screenshoot5.png", "id": "1127246447759319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_1127246451092652_894795109150974798_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ShBx7l3LPmIQ7kNvgGDmldS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdEfEsGWpJpxTTKZicAj0tt&oh=00_AYAdmg937cy2neZbAIzGVgEX50sdV6UcTaROL5CARApyzg&oe=66DC1E92"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "210978287513785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974896_210978290847118_7672800902019600580_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=14qDQRXF-48Q7kNvgG2QwCb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdEfEsGWpJpxTTKZicAj0tt&oh=00_AYB74bpkdot0N5Dp606a3UAFMbeE-2lmI_L4mJrWUv6T4Q&oe=66DC22C0"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "Many block types:\n\nThere are many square sorts extending grass, square, water lava magma roads, crystals and much more. You have numerous choices with regards to building your realm.\n\nFeatures:\n\n*3 type of locomotion Flying, Teleport and Smooth\n*Autosave. Your progress never be erased\n*Big Landscape. You can build more than one world\n*Enable or disable player Gravity\n*Perfect game for the whole family.\n*Build anything\n*One of the best simulation games: begin constructing your dream world\n*Fun game: Play with villagers and animals it is so fun!\n*Cool graphics: enjoy the best graphics with animated cube.\n*Building game: Build your own construction", "short_description": "Build your own village. Decorate your house with your mates ' furniture and your own eyes. Learn more and more, and you will never be able to build massive castles and temples! Start building and show the world your best game and constructions. Crafting and Building is best game for the whole family."}]