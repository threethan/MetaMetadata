a&_nc_ohc=JL-aTmHdb1QQ7kNvgGjFoh5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQHPeth3gLD5qsUqofBu-88&oh=00_AYBKCTfZA-H45N7GTZmo06nn9KLhaqx113V7qpVjfw9Q1Q&oe=66EE9062"}, {"file_name": "Screenshoot5.png", "id": "1127246447759319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_1127246451092652_894795109150974798_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b2OcKR34Kb8Q7kNvgHWNwfY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQHPeth3gLD5qsUqofBu-88&oh=00_AYCrWwUu5zm-iPTM-p7Uhnd2Z8V3WLJ0IGbdQwUNbjOXEA&oe=66EE9392"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "210978287513785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974896_210978290847118_7672800902019600580_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IbLy7WYV3ksQ7kNvgGSurjO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQHPeth3gLD5qsUqofBu-88&oh=00_AYAZfwpgP2tLq0KShkFWzKId_pJxL5sk3Wl3zaEv1wlt7w&oe=66EE97C0"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "Many block types:\n\nThere are many square sorts extending grass, square, water lava magma roads, crystals and much more. You have numerous choices with regards to building your realm.\n\nFeatures:\n\n*3 type of locomotion Flying, Teleport and Smooth\n*Autosave. Your progress never be erased\n*Big Landscape. You can build more than one world\n*Enable or disable player Gravity\n*Perfect game for the whole family.\n*Build anything\n*One of the best simulation games: begin constructing your dream world\n*Fun game: Play with villagers and animals it is so fun!\n*Cool graphics: enjoy the best graphics with animated cube.\n*Building game: Build your own construction", "short_description": "Build your own village. Decorate your house with your mates ' furniture and your own eyes. Learn more and more, and you will never be able to build massive castles and temples! Start building and show the world your best game and constructions. Crafting and Building is best game for the whole family."}]}, "de