587_389893592330565_8506709594514748826_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zjASvaNLFToQ7kNvgHjmcR6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAHTdy7hoHwGdfL-BQtN2tpc4QuqUWF0pcgDQ-SwIDKPg&oe=677BCD0A"}, {"file_name": "Screenshoot4.png", "id": "752407815429543", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974515_752407822096209_1781836653202113190_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=owoSV4tyIzYQ7kNvgG6Gsed&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCOGw-Lyi2Ei8TPxh2Ooyiu_Y1n_I-queWyPLqSOmi5-Q&oe=677BD922"}, {"file_name": "Screenshoot5.png", "id": "1127246447759319", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003282_1127246451092652_894795109150974798_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dnjIrpVSkOAQ7kNvgFAhH5B&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDACEkOxZ6pXToOzCRk2f_fmjTgR_RZtudM9jHChlX52Q&oe=677BDC52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "210978287513785", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974896_210978290847118_7672800902019600580_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0dKfhr86oO4Q7kNvgHv1lCy&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA62FcmImmoDLdGh1mOAPxcwyeUFcBd_EI-6M7PZ6HVIg&oe=677BA840"}, "display_name": "KUBIKOS", "keywords": [], "long_description": "Many block types:\n\nThere are many square sorts extending grass, square, water lava magma roads, crystals and much more. You have numerous choices with regards to building your realm.\n\nFeatures:\n\n*3 type of locomotion Flying, Teleport and Smooth\n*Autosave. Your progress never be erased\n*Big Landscape. You can build more than one world\n*Enable or disable player Gravity\n*Perfect game for the whole family.\n*Build anything\n*One of the best simulation games: begin constructing your dream world\n*Fun game: Play with villagers and animals it is so fun!\n*Cool graphics: enjoy the best graphics with animated cube.\n*Building game: Build your own construction", "short_description": "Build your own village. Decorate your house with your mates ' furniture and your own eyes. Learn more and more, and you will never be able to build massive castles and temples! Start building and show the world your best game and constructions. Crafting and Building is best game for the whole family."}]}, "developer_name": "livbogdan", "developer_privacy_policy_url": "https://livbogdan.wixsite.com/licenggames/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "livbogdan", "support_website_url": null, "website_url": "https://livbogdan.wixsite.com/licenggames/kubikos", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1725996564472128"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "910088806366842"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1095861915338716"}, {"status": "PUBLISHED", "id": "386651712793419"}]}, "baseline_offer": {"id": "386651712793419"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1095861915338716"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6120709257970090", "version": "1.0"}, "id": "762670311345765", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries"