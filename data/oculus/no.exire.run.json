nt-iad3-1.oculuscdn.com&oh=00_AYCjvE9gOvDx2ioXNv6vTpXxuJx1xQzN5FwcO1Zb-jcW3g&oe=670E6DEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Run Hero Cover wide 6.png", "id": "268162596144934", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974468_268162602811600_4885201341835588377_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sgQwY4QyfAIQ7kNvgH3gd60&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWB1sd1PhnmCFji6dLwlU2dhKFMH6G4sIyV5xL8R1wyA&oe=670E5BE5"}, "display_name": "Run", "keywords": [], "long_description": "**Embark on an exhilarating journey where you can run, walk, or even ski through virtual landscapes. Choose from a variety of immersive worlds, each offering unique challenges and scenery.**\n\n- **Forest Trails:** Run or walk through lush, green forests.\n- **Quests:** Complete exciting quests on remote islands.\n- **Snowy Days:** Glide across snowy terrains on skis.\n- **Sky Paths:** Collect coins on wooden paths high up in the sky.\n- **Desert Island:** Explore the vast, sandy deserts.\n- **Mazes:** Find the fastest way, or not.\n- **Elliptical Machine:** Try the experimental level.\n\nUnlock achievements by collecting coins and hidden diamonds as you explore. With a mix of free and paid levels, there\u2019s always something new to discover.\n\nOur app is designed to make your workouts fun and engaging. Get moving and enjoy the adventure!\n\n**Download now and start your journey for free!**", "short_description": "Embark on an exhilarating journey where you can run, walk, or even ski through virtual landscapes. Choose from a variety of immersive worlds, each offering unique challenges and scenery.\nRun or walk through lush, green forests. Complete quests on remote islands. Glide across snowy terrains on skis. Explore sandy deserts. Collect coins on wooden paths high up in the sky.\n\nUnlock achievements by collecting coins and hidden diamonds as you explore.\n\nDownload now and start your journey for free!"}]}, "develop