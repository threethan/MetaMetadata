1731396, "id": "7638336429622046", "version": "1.7.2", "version_code": 36, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7638336429622046"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "We\u2019re thrilled to announce some fantastic additions to our virtual reality game:\n\nNew Quests: Embark on thrilling adventures with fresh quests that will challenge your skills and immerse you in captivating narratives.\n\nFree Level: Explore a brand-new level without any cost! Uncover hidden secrets, solve puzzles, and enjoy the immersive environment.\n\nLow Poly Designs: Our game now features even more low-poly visuals, enhancing performance while maintaining a unique and stylish look.\n\nHuman Characters: Added humans to make the quests and stories more alive.\n\nAnd that\u2019s not all! We\u2019ve fine-tuned gameplay mechanics, squashed pesky bugs, and optimized performance. Dive into the updated world of our VR game today!", "created_date": 1721692140, "id": "7635904523198570", "version": "1.7.1", "version_code": 35, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7638336429622046"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "Embark on an epic quest in our latest update! Explore North Island as the hero, sprinting through lush landscapes, collecting coins and diamonds, and uncovering hidden secrets. And this is just the beginning\u2014stay tuned for even more thrilling adventures!", "created_date": 1720431683, "id": "7557304931058530", "version": "1.7.0", "version_code": 34, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7638336429622046"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "We\u2019re thrilled to announce that our latest update brings not only a transformed Skiing level but also smoother movement across all levels for an even more fluid VR experience. Dive into the updated tutorial to master the latest movement options, and explore every free level with ease under a single tab.", "created_date": 1717799421, "id": "7401137936675231", "version": "1.6.2", "version_code": 33, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7638336429622046"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "Mixed Reality Menu Area: We\u2019ve introduced an exciting mixed reality menu area that seamlessly blends the virtual and real worlds. Navigate through your options with ease!\n\nSmoother Paths: All running paths have undergone significant improvements, resulting in a more fluid and enjoyable experience. Say goodbye to jarring transitions!\n\nElliptical Machine Enhancements:\n* Lap Timing: The elliptical machine level now features lap timing functionality. Keep track of your performance and beat your personal best!\n* Best Lap: Compete against yourself or challenge friends to achieve the ultimate lap time. Who will be the fastest?\n\nNew Levels Await:\n\ud83c\udf32 Forest Map: Immerse yourself in a lush, serene forest environment. Feel the crunch of leaves beneath your virtual sneakers as you explore.\n\ud83c\udf00 Maze Adventure: Get lost (and found!) in our intricate maze. Sharpen your reflexes and find the exit!\n\u2601\ufe0f Skyworld: Ascend to new heights in this ethereal realm. Soar through the clouds and unlock hidden secrets.\n\nMore levels are already in development, promising even more exhilarating adventures! Lace up your virtual shoes and let the journey begin. \ud83c\udfc3\u200d\u2640\ufe0f\ud83c\udf20", "created_date": 1713562557, "id": "7172185222903838", "version": "1.6.1", "version_code": 32, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}