25/38974682_367837535697681_4041375092477978935_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IoSbEVSOFtoQ7kNvgFU8HIC&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBxo-VRdw8QOwQV5RbJ-CWEXtN3DD8R4lPtudNsO3CVaQ&oe=6756CF18"}, {"file_name": "screenshot-oceanrun.png", "id": "2609514472586848", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003283_2609514475920181_5848610477621831118_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cC6t_lL_Tr0Q7kNvgGtSwmr&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDLnXRRLupKvM8n3enq_1_htaYODmSMC3LP-p7RSmU4UA&oe=6756F06E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Run Hero Cover wide 6.png", "id": "268162596144934", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974468_268162602811600_4885201341835588377_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lECxsv2XOCQQ7kNvgFH4LMK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYABiVn93nUO8JjnCSgu3j9LK_mlD4ViatRwP9gVzMpncw&oe=6756DE65"}, "display_name": "Run", "keywords": ["run", "fitness", "nature", "walk", "free"], "long_description": "**Embark on an exhilarating journey where you can run, walk, or even ski through virtual landscapes. Choose from a variety of immersive worlds, each offering unique challenges and scenery.**\n\n- **Forest Trails:** Run or walk through lush, green forests.\n- **Quests:** Complete exciting quests on remote islands.\n- **Snowy Days:** Glide across snowy terrains on skis.\n- **Sky Paths:** Collect coins on wooden paths high up in the sky.\n- **Desert Island:** Explore the vast, sandy deserts.\n- **Mazes:** Find the fastest way, or not.\n- **Elliptical Machine:** Try the experimental level.\n\nUnlock achievements by collecting coins and hidden diamonds as you explore. With a mix of free and paid levels, there\u2019s always something new to discover.\n\nThis app is designed to make your workouts fun and engaging. Get moving and enjoy the adventure!\n\n**Download now and start your journey for free!**", "short_description": "Embark on an exhilarating journey where you can run, walk, or even ski through virtual landscapes. Choose from a variety of immersive worlds, each offering unique challenges and scenery.\nRun or walk through lush, green forests. Complete quests on remote islands. Glide across snowy terrains on skis. Explore sandy deserts. Collect coins on wooden paths high up in the sky.\n\nUnlock achievements by collecting coins and hidden diamonds as you explore.\n\nDownload now and start your journey for free!"}]}, "developer_name": "Exire Apps AS", "developer_privacy_policy_url": "https://exireapps.com/run-app-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Exire Apps AS", "support_website_url": "https://exireapps.com/run-app-support", "website_url": "https://exireapps.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8301360063319676"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974887_740619904264289_3107987640363918662_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nLBRf5mE-MoQ7kNvgGbg5ij&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCEt3MM_KJFoBEnl5WqV6zZzu_MMM6ZqNYLjSiNXRdzzg&oe=6756CC48"}, "is_concept": false, "is_test": false, "is_trial_offer_v