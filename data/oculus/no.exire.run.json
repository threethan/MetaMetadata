_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "There is a new update for run VR! Here's some of what's new:\n\nNew Bonus Level: Dive into the fun with the latest bonus level where you can run around catching rabbits! This level features multiple stages and offers a unique challenge.\n\nCredits System: Access the bonus levels using the credits you've earned or purchased.\n\nEnhanced Gameplay: You will find more coins to collect and updated the graphics in some of the older levels for a more immersive experience.\n\nUpdate now and enjoy the new adventures!", "created_date": 1733872644, "id": "8540234322765581", "version": "1.8.0", "version_code": 42, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8573855272736819"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "**Exciting Update!**\n\nUnlock two brand-new bonus levels using your credits! Each level features a PT with engaging tasks for you to complete.\n\nThis update also brings:\n- **More Animals**: Discover new creatures in the game.\n- **Settings Panel**: Customize your gameplay experience.\n- **Enhanced Levels**: Enjoy improved and more challenging levels.\n- **Increased Fun**: Dive into an even more entertaining adventure.", "created_date": 1732369464, "id": "8447584352030579", "version": "1.7.7", "version_code": 41, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5368570423265336", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8573855272736819"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "525411026263854"}]}, "change_log": "Animals are now added to the Forest Run XL level. They are not dangerous at all.", "created_date": 1731190861, "id": "8372705336185148", "version": "1.7.6", "version_code": 40, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}