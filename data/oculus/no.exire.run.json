NI5aU5OKRE-YTnVbQ&oe=676AA54D"}, {"file_name": "Screenshot - run menu.png", "id": "3691320051103700", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982722_3691320054437033_8470338715562496127_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IDxt8ua6iHoQ7kNvgEudpnF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbvujdcU74eiXW4M1NfojaLSD9c-81W_le6rw36VdhRQ&oe=676AA63C"}, {"file_name": "run screenshot desert island.png", "id": "6586269381405029", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394636_6586269384738362_6206770470726848686_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_5cU3W_nWa8Q7kNvgHFJONn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-ddumB1BuRwsJgVEgUsKXCvH24kqRLfU5wFJrs2VFdQ&oe=676AAF05"}, {"file_name": "run screenshot desert island 2.png", "id": "1370296817161595", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86594848_1370296820494928_2141501431161532084_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g4prbhC4P-UQ7kNvgFUQtwp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHOtPYpgTFYpESoN1nDYFzkA1XS1xNkrb_ablFAt9SsA&oe=676A8A17"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Run Cover.png", "id": "149834304661929", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001664_149834307995262_2211424663824539600_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJFX-r9SVY0Q7kNvgHvMbSC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAn8U0jrB6dM3zW8hffrGvUlUgYu3Grgog9frCRmU57tg&oe=676A9E61"}, "display_name": "Run", "keywords": [], "long_description": "Run is a VR app that combines fitness and fun. It uses Bounce-In-Place motion to let you run on the spot in various virtual environments. Whether you are indoors due to bad weather, lockdown, sleeping kids or any other reason, you can enjoy a smooth and exhilarating VR run. Plus, you will encounter some unexpected and amusing surprises along the way\n\nCollect all the coins, or find the hidden diamonds to unlock achievements in each level.\n\nOur app has one goal: to get you moving and have fun at the same time. \n\nTry it today! It\u2019s free!", "short_description": "Discover the joy of running with this app! Whether you want to go for a brisk walk or a challenging run, you can choose from different worlds to explore. Run through snowy mountains, lush forests or sandy deserts. Collect coins along the way, or search for hidden diamonds to earn achievements. This app will make your running fun and rewarding!"}]}, "developer_name": "Exire Apps AS", "developer_privacy_policy_url": "https://exireapps.com/run-app-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Exire Apps AS", "support_website_url": "https://exireapps.com/run-app-support", "website_url": "https://exireapps.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "795752021492028"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "8858424044250319"}, {"status": "PUBLISHED", "id": "709746047619379"}]}, "baseline_offer": {"id": "8858424044250319"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733873100, "status": "PUBLISHED", "id": "8858424044250319"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8573855272736819", "version": "1.8.2"}, "id": "525411026263854", "channel_name": "LIVE"}]}