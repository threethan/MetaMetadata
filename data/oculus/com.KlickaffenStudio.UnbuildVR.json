g!\nYours Matthias from Klickaffen\n\nTry Unbuild VR now!\nAs part of the Klickaffen summer freshness,\nthe game is available here for free for a short time!", "short_description": "Build turrets the other way around!\nHere you have 29 completed building block constructs.\nCan you take it brick by brick\nwithout anything falling to the ground?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.klickaffen.tv/unbuild/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Matthias Mach - Klickaffen Studio", "support_website_url": null, "website_url": "https://www.klickaffen.tv/unbuild", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1004147043959444"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "310529318101360"}, {"status": "PUBLISHED", "id": "703457658379235"}]}, "baseline_offer": {"id": "703457658379235"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1692655078, "status": "PUBLISHED", "id": "310529318101360"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6506178519496299", "version": "1.1"}, "id": "808634457655540", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application