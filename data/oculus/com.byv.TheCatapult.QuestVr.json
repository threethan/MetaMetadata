v/t64.5771-25/38974456_1327389234774960_937105756692731641_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1bvwO-4rpNUQ7kNvgE6sjin&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAy0iDj73YDLg59lKn7Q6nkV1AGo6DGKlPWqrZnoOs51Q&oe=6734848D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1h1h1In6WMQ7kNvgF3twXK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBQ8Xe5zpQcSa-rr7esrYRG2xoi_vGwiP_EKAd57Io1Bg&oe=67348576"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bWc5UUhlPm4Q7kNvgExrp-6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAE9SqZWlUANVfalXxOzwQQfGMh6hFajJzFe2qg2fMREQ&oe=67348663"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tkd8D1BPkGwQ7kNvgEu6YKP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBPpXIVc_JRWrQ_P6Fh3layjP-CzwZYXaORNTJPpBH0JQ&oe=67349ED0"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "