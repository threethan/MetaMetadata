1627", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974456_1327389234774960_937105756692731641_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gOVPkl8BU2cQ7kNvgF3m0Th&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYASvxazPbZQj1Vycil3bsQ_n2O61Y7vHXrdJ1aj6rgiGw&oe=6716320D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Z9GTfftBOsQ7kNvgGsnCL7&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCbGrXaTcEJfwqTZyzAud1chlXoNOwlxnPSTH2-o97XnQ&oe=671632F6"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GqP83G3VVb0Q7kNvgGggaD8&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCAAbQ5XnXii7YEsdcW26yv7bmXUST2v-Ow7FQnr9Hy0A&oe=671633E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aojl4zV9asUQ7kNvgEDTiXO&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAXyPmwN8S5oHLXkCTJ0kXj3Bs2l01yBs3Pvv4i8JdqnA&oe=67164C50"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "short_description": "Game about hero in castle siege, vs stickmans with catapult and archers with bows and arrows."}]}, "developer_name": null, "developer_privacy_policy_url": "https://byvgames.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "BYV", "support_website_url": null, "website_url": "https://byvgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "756569646097764"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "458057607209449"}, {"status": "PUBLISHED", "id": "2030687427264906"}, {"status": "PUBLISHED", "id": "711107607058920"}]}, "baseline_offer": {"id": "458057607209449"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722370580, "status": "PUBLISHED", "id": "458057607209449"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8251964544858258", "version": "1.7.6"}, "id": "5531253943667871", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5570330959688310", "is_concept": false, "l