MIwZHbTfjfdYG58X9Xh-nbKJEqfD06Xy3R2g&oe=66E56A8D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mbub3hQIhZAQ7kNvgHUfPQR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWCk6gv0AuPMxWY5XT24BA2B38HE0L77vNSgvFIXxKrQ&oe=66E56B76"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0STFd_1nA3YQ7kNvgHosAt-&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3kMo4OH1D4LDHziyptyXp8_5uqksxsiqTbvNRtFmzpA&oe=66E56C63"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wDHubNROWJkQ7kNvgFgmqv4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfsN0IYQgIi9Fg2DD4BcSTk0NzG2e4DU0rhHSDgHs5_A&oe=66E584D0"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "short_description": "Game about hero in castle siege, vs stickmans with catapult and archers with bows and arrows."}]}, "developer_name": null, "developer_privacy_policy_url": "https://byvgames.com/privacy.php", "developer_terms_of_service_url": null, "publisher_