v/t64.5771-25/38974456_1327389234774960_937105756692731641_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6DoxPaIscgQ7kNvgHahE2-&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBC3DSz32hZ-_3CLAh-8zTxExj1xCbrTbWGZ0v6rJ6UKw&oe=6729F88D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N65_Ps9LPwkQ7kNvgEn1s4F&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBlEjmdje2f7aj1EfQ_tpvrtFU6xR7_ZjH9Y82NbIoGow&oe=6729F976"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cbenNVlDRakQ7kNvgHj5j0J&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCVlMbHA94tyhvGVYm0ZzOt2an7MdZe_Ro_gzY80hm-cA&oe=6729FA63"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UqrbOdnpBS8Q7kNvgG8MEwY&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCRMd5oiKhjvINp4J3STIKGoDq3Z54QOh46jdxdGL-Jcw&oe=672A12D0"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "