truck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "short_description": "Game about hero in castle siege, vs stickmans with catapult and archers with bows and arrows."}]}, "developer_name": null, "developer_privacy_policy_url": "https://byvgames.com/privacy.php", "developer_terms_of_service_url": null, "publisher_name": "BYV", "support_website_url": null, "website_url": "https://byvgames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "756569646097764"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "458057607209449"}, {"status": "PUBLISHED", "id": "2030687427264906"}, {"status": "PUBLISHED", "id": "711107607058920"}]}, "baseline_offer": {"id": "458057607209449"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722370580, "status": "PUBLISHED", "id": "458057607209449"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8251964544858258", "version": "1.7.6"}, "id": "5531253943667871", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppB