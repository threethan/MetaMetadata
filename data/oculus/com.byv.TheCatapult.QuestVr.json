_Q-JHEnOgCsv4NFGBpJH_6CJl8FSYhiZ8qvw&oe=66D6EA0D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RS6mDxqjIOYQ7kNvgFvKgt4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoIydOU65vHbefA5TyWjXZe84DoZrPkgKrt3L1DKa8OQ&oe=66D6EAF6"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=21OX5RkI3-IQ7kNvgFfQZV4&_nc_ht=scontent.oculuscdn.com&oh=00_AYALGrlAX9xxMl9oFeG1a36zGioslAZioUbesq1fGijARA&oe=66D6EBE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XuJ1Fqfu_eQQ7kNvgEf8rdO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBveUQA0VE4IUXL3cA_oWyvqHn9HrC97l2L-j1_0OF7ZQ&oe=66D70450"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "short_description": "Game about hero in castle siege, vs stickmans with catapult and archers with bows and arrows."}]}, "developer_name": null, "developer_privacy_policy_url": "https://byvgames.com/privacy.php", "developer_terms_of_service_url": null, "publisher_