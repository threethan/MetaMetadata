v/t64.5771-25/38974456_1327389234774960_937105756692731641_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-Nfk1C_kd4Q7kNvgHrOIUW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzu6vy4IS1CTqMmH9N83Is5DXdEfvVy_zCeqlmYkJywg&oe=6720BE0D"}, {"file_name": "scr_oc_4.png", "id": "558958162543431", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982461_558958169210097_7816353356458586551_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CXQhgfeVbHEQ7kNvgGhGxOK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCt2rp7gSq61srcDrvsdJcThyZ8XeHk8r5tw-_tOyjw8A&oe=6720BEF6"}, {"file_name": "scr_oc_5.png", "id": "581845237090311", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003267_581845240423644_3938985980174475050_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0xP5JS9IuBgQ7kNvgHhZgke&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCd3kgw57T67u5335zeShbY3S7_pNkENotKjz48v2HvOw&oe=6720BFE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art Landscape.png", "id": "659780682294753", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035382_659780685628086_2198134721319690650_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=58XoI89WPxAQ7kNvgElZ6lO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlH8KROJpvQkdswlw-N13NwrlJDDmJbAKBWbVf-DcpzA&oe=6720D850"}, "display_name": "The Catapult", "keywords": [], "long_description": "Help the stickman defend his castle from the siege weapons of the enemy. \n\nUse the slingshot, ballista or cannon to throw stones at the opponents and break their military mechanisms and siege towers.\n\nThe game has a simple intuitive control. Pull and throw a projectile at the enemy to charge the slingshot and select the tension force. Release to launch the projectile into the enemy.\n\nFor each struck enemy you will earn coins which help you to upgrades a weapon, turret or your equipment.\n\nWe are waiting for your wishes and comments on the game.\n\nHave a good game!", "