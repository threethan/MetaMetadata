e7a0a&_nc_ohc=Y0-r4desU9MQ7kNvgGGyViw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChJwiuXW0tAztqD3dSVrM7HyFvGNLcVhb7vvIQtVD8Bw&oe=67179C79"}, {"file_name": "Preview5-1.png", "id": "251504337630601", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974855_251504344297267_2704252636234673923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUu4ruziJc4Q7kNvgE5uPhg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAc_i_DnwlvH1w1VHzQemawJ2MQXcejFKEZP4xAsMSiDQ&oe=6717A124"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u898b\u51fa\u3057\u3092\u8ffd\u52a0.png", "id": "1013340913157774", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974727_1013340916491107_6987464292749567898_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kHeGvFBprI4Q7kNvgHBtZ4E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDc0e38RtXkSJNCgo6pj68f-eOtwb2Dt04DzVNFzSQCAA&oe=67177B3F"}, "display_name": "Mind Palace", "keywords": [], "long_description": "Mind Palace provides an ideal environment for organizing thoughts in a 3D space. \nWe offer a room-based platform with the following features.\n\nFirstly, you can create mind maps to visually organize your thoughts. \nYou have the freedom to customize colors, shapes, and sizes.\nIt's also possible to add text to the lines connecting objects in the mind map to display related information.\n\nAdditionally, you can decorate each room with various objects. \nChoose from a wide selection and even climb on the decorations. \nBy placing mind maps, changing perspectives, or moving within the room, you can temporarily step away from your current thoughts.\n\nMind Palace offers a gaming-like experience, making it easy to get started. With an intuitive interface and seamless interactions, you can effectively organize your thinking process.\n\nWhy not utilize this space to clarify your ideas? \nMindPalace serves as an excellent supporter for your thoughts, helping to unlock creativity and insight. \nThe preparation to get started is already in place.", "short_description": "An app for organizing your thoughts.\nThis App can use by Oculus Quest series."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.m-palace.com/home/privacy", "developer_terms_of_service_url": "https://www.m-palace.com/home/terms", "publisher_name": "https://www.i-standard.jp", "support_website_url": null, "website_url": "https://www.m-palace.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1433463757194750"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982694_583587917268359_530868824494148936_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ojrxkoQDoNAQ7kNvgHZKpXV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZn-nTLSV-BVQijNogR_q5PXVb51-f2IKc2VPAigs9TA&oe=6717AB47"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mind Palace", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Utilities", "id": "393222478507326"}, {"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1689220800, "lastRevision": {"nodes": [{"id": "62995283