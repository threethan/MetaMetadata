e7a0a&_nc_ohc=jy9tvc-G69sQ7kNvgHPwfWJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7XVz3D8OrpfHmAEb8wr3r0oNG6YJQykLSp7F6AUaGvQ&oe=671B90F9"}, {"file_name": "Preview5-1.png", "id": "251504337630601", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974855_251504344297267_2704252636234673923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DvTEv9Me_N8Q7kNvgGDQay1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuiUSkj1G1aRCFQHjIOncGT2z6jsdro_jAON-DSjgAkQ&oe=671B95A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u898b\u51fa\u3057\u3092\u8ffd\u52a0.png", "id": "1013340913157774", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974727_1013340916491107_6987464292749567898_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gws0-WikkYUQ7kNvgEgh5CH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAN1tV23beWUBgZkrvojvtUsFJaBDismlgSTz0FXK0plw&oe=671B6FBF"}, "display_name": "Mind Palace", "keywords": [], "long_description": "Mind Palace provides an ideal environment for organizing thoughts in a 3D space. \nWe offer a room-based platform with the following features.\n\nFirstly, you can create mind maps to visually organize your thoughts. \nYou have the freedom to customize colors, shapes, and sizes.\nIt's also possible to add text to the lines connecting objects in the mind map to display related information.\n\nAdditionally, you can decorate each room with various objects. \nChoose from a wide selection and even climb on the decorations. \nBy placing mind maps, changing perspectives, or moving within the room, you can temporarily step away from your current thoughts.\n\nMind Palace offers a gaming-like experience, making it easy to get started. With an intuitive interface and seamless interactions, you can effectively organize your thinking process.\n\nWhy not utilize this space to clarify your ideas? \nMindPalace serves as an excellent supporter for your thoughts, helping to unlock creativity and insight. \nThe preparation to get started is already in place.", "short_description": "An app for organizing your thoughts.\nThis App can use by Oculus Quest series."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.m-palace.com/home/privacy", "developer_terms_of_service_url": "https://www.m-palace.com/home/terms", "publisher_name": "https://www.i-standard.jp", "support_website_url": null, "website_url": "https://www.m-palace.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1433463757194750"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982694_583587917268359_530868824494148936_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XusNO_Xrr1IQ7kNvgEqLz3v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCslHLGW390tlqvPIki2eXImFHV3XQqexoETsxJa0LPdw&oe=671B9FC7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mind Palace", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Utilities", "id": "393222478507326"}, {"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1689220800, "lastRevision": {"nodes": [{"id": "62995283