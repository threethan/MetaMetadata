stay human when a monster awakens inside?\nFeatures:\n\u2022 Two distinct skill trees - modify and upgrade your gear and weapons or invest into devastating vampire skills;\n\u2022 Non-linear storyline \u2013 decide which side you will end up on: humanity or the vampires;\n\u2022 Advanced enemy A.I. \u2013 be wary of the the hunter becoming the hunted.", "short_description": "Dixotomia is a roleplaying VR shooter in a world of a science-fiction dystopia. Dive into the daily life of a SpecOps contractor, who is forced to fight vampires while also trying to stay sane without giving in to infection himself. Can he return back unchanged?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deep-matrix.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Deep Matrix", "support_website_url": null, "website_url": "https://deep-matrix.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8045714332122967"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "373252721789488"}]}, "baseline_offer": {"id": "373252721789488"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1705701484, "status": "PUBLISHED", "id": "373252721789488"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9672048629489521", "version": "0.17.25