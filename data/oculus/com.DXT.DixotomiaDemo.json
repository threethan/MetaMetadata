67486735939755_4379200462181283728_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-sgDUdDkWDMQ7kNvgHpFeST&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2udXWjJHlIUEeKzgAWQHpFoUszylReIjRL-Ykt6Zfqg&oe=67332AAB"}, {"file_name": "3.png", "id": "666655978655245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982528_666655981988578_1469220975944538521_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aZk3G8TYy9gQ7kNvgF3_D1z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_V33v76wGG7CsFLF6-vm12sN6Fq01CiIQ17MKNHDJiw&oe=673358BD"}, {"file_name": "4.png", "id": "888107462503578", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031363_888107465836911_284597345126760055_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U2HQbO62ePYQ7kNvgFtCQRS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAP5tvYit-JmBatDqv3ZYeUSc0NK5Hv17bWQAmweKAbvA&oe=6733332F"}, {"file_name": "5.png", "id": "743706847570907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_743706850904240_1322426532043155909_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ecMF1iHPSZcQ7kNvgHWCEWB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOW-e0wixEtgB0pxid-6XXDmP3Jf1_ECfky1yUKFdcFA&oe=673337BA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "3514370875543369", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982453_3514370878876702_8115289566190127780_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MItDDVXMDDwQ7kNvgEXcFWq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCO8eIjFlGqBxweyURhe0ntHfEBRyVqaC_Pi_y4_bnh4A&oe=67333451"}, "display_name": "Dixotomia Demo", "keywords": [], "long_description": "Dixotomia - a thrilling VR shooter, set in a world of a sci-fi dystopia. Dive into the daily life of a SpecOps contractor, who is forced to fight vampires while also trying to stay sane without giving in to infection himself. Together you will reveal what secrets a recently colonized planet Carna hides on its surface.\nFaced with a merciless and bloodthirsty opponent, the protagonist Ron Adams must survive, no matter the cost. But the situation shifts, and not in his favour...\nThrough the use of various modern weaponry, or with the awakened potential of superpowers - get to the core of the truth surrounding this world and answer the most important question: can one stay human when a monster awakens inside?\nFeatures:\n\u2022 Two distinct skill trees - modify and upgrade your gear and weapons or invest into devastating vampire skills;\n\u2022 Non-linear storyline \u2013 decide which side you will end up on: humanity or the vampires;\n\u2022 Advanced enemy A.I. \u2013 be wary of the the hunter becoming the hunted.", "short_description": "Dixotomia is a roleplaying VR shooter in a world of a science-fiction dystopia. Dive into the daily life of a SpecOps contractor, who is forced to fight vampires while also trying to stay sane without giving in to infection himself. Can he return back unchanged?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deep-matrix.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Deep Matrix", "support_website_url": null, "website_url": "https://deep-matrix.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8045714332122967"}}]}, "scheduled_offers": {"count": 1, "nodes