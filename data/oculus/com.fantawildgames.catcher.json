lar Catcher is a VR game with a high level of physical intensity. It's time to put your agility and reflexes to the ultimate test!\n\nPilot a spaceship across the vast universe catching as many energy producing orbs as possible. Avoid obstacles and being caught by the crimson golem. Don't stop! You can only gain victory when you're alive!\n\n\u00b7  A fully immersive visual experience.\n\u00b7  This game involves various movements. It is easy to get started, but difficult to master.\n\u00b7  Challenge yourself and play against players all over the globe!\n\u00b7  Additional content coming soon!", "short_description": "Feel the thrill of flying in spaceship traveling at full speed through the expanse of outer space. Obtain enough energy to escape the crimson golem. Take on players from all over the world and embark on an exciting interstellar adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fountainmeta.com/privacy-policy-en.html", "developer_terms_of_service_url": null, "publisher_name": "Fountain Game Studio", "support_website_url": null, "website_url": "https://www.fountainmeta.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7410211742336658"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1354090058818142"}]}, "baseline_offer": {"id": "1354090058818142"}, "is_approved": true,