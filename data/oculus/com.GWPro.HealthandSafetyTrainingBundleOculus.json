d3-1.oculuscdn.com&oh=00_AYDWSDTY7KCCK3pebrEjf4n_Xu2m00OCBD4oshgmXP8BkA&oe=673F3291"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ET_meta_2560x1440.png", "id": "334719156393952", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340710_334719159727285_2662614486446128346_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dyEFo-flCuUQ7kNvgFmQV2w&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDy9qQgcKWoh1BQQGKKybWcBL5H8NGHhBSxkUU4oQrTuw&oe=673F24E0"}, "display_name": "Health and Safety Training Bundle", "keywords": [], "long_description": "Train your professional skills in GWPro VR Training safely and in correspondence with international standards! (OSHA, NEBOSH, ISO).\nThis VR Training Bundle includes:\n\n1. Electrical safety\n2. Work at height\n3. Fire Safety (WORKSHOP)\n4. Fire Safety (OFFICE)\n5. Lockout Tagout (LOTO)\n6. Confined Space Entry\n7. Hot Work\n8. Load Slinging\n9. Maintenance Safety (Pipes and Acids)\n10. Underground roof fall hazard assessment\n11. Truck preparation for driving\n12. Road accident with dangerous goods\n13. Workplace safety\n14. Scaffolding (Wedge Lock Scaffolding Assembly Training)\n15. Arc Flash (Flashover) Training\n16. Personal Protective Equipment\n17. First Aid\n16. Personal Protective Equipment\n17. First Aid\n18. Trenching and Excavation Safety\n19. Bakers Scaffolding Assembly VR Training\n\nAll VR training consists of 3 modes: Study, Training, Exam, providing step-by-step control of all VR activities.\nLanguage support: English, Portugu\u00eas, Arabic, Espanol, Dutch, \u0939\u093f\u0928\u094d\u0926\u0940 (\u092d\u093e\u0930\u0924), \u0c95\u0ca8\u0ccd\u0ca8\u0ca1 (\u0cad\u0cbe\u0cb0\u0ca4), \u09ac\u09be\u0982\u09b2\u09be (\u09ad\u09be\u09b0\u09a4), \u65e5\u672c\u8a9e\uff08\u65e5\u672c), \u092e\u0930\u093e\u0920\u0940 (\u092d\u093e\u0930\u0924), Bahasa Melayu, T\u00fcrk\u00e7e, \ud55c\uad6d\uc5b4, Fran\u00e7ais, Deutsch, Ti\u1ebfng Vi\u1ec7t, Italiano, \u0a97\u0ac1\u0a9c\u0ab0\u0abe\u0aa4\u0ac0 (\u0aad\u0abe\u0ab0\u0aa4), Dutch, Svenska, \u010ce\u0161tina, Polski, Latvie\u0161u, Sloven\u010dina.", "short_description": "Train your professional skills in GWPro VR Training safely and in correspondence with international standards! (OSHA, NEBOSH, ISO).\nThis VR Training Bundle includes 18 ready-made VR modules covering wide variety of professional topics.\nAll VR training consists of 3 modes: Study, Training, Exam, providing step-by-step control of all VR activities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1r7fPASKr-4XFrvk21IGtZ-w_H0dYz9jk/edit?usp=sharing&ouid=111001160316405883703&rtpof=true&sd=true", "developer_terms_of_service_url": null, "publisher_name": "GWPro VR Training", "support_website_url": null, "website_url": "https://gwpro.io/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "pt_BR", "es", "hi", "bn", "ja", "tr", "ko", "fr", "de", "vi", "it", "gu", "nl_BE", "sv", "cs", "ms", "pa", "kn", "lv", "sk", "pl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26212891861659416"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/227814955_478197731434015_3374721453722413442_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XfqL4d3yvVQQ7kNvgG2lYcb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUmCEJyAbdUZQAMD9c-sihdow2TONUUxwmDWVNWy_I8w&oe=673F13F