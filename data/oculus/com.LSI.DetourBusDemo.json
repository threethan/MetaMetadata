3_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OyPgGFSnrjkQ7kNvgExU92J&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAPH7zihN2b9o-57LZyeiTeEtDZyfCii4ziKDYqlUkBrw&oe=670BB35D"}]}, "id": "1010694229837752", "locale": "en_US", "screenshots": [{"file_name": "DBGame.png", "id": "239736384729743", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031540_239736388063076_289168406410085238_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cRAfmwXtgnsQ7kNvgHeHJkp&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDKzHUsEIyVr4uPfYoD3jdmlAb2kscx6wlGy_4G_eSoUw&oe=670BBF5C"}, {"file_name": "DBVolcano.png", "id": "210185554339855", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031347_210185557673188_1675127275918293002_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7CGashEIIDcQ7kNvgHe9aJX&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDLs2dPOPTLjdDMXfTbmfCLjLD4R6zAFgofpyt4OfFGfQ&oe=670BC62D"}, {"file_name": "DBStorm.png", "id": "1287665691667265", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031562_1287665695000598_3589077205279925176_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=r-xJgMrwpKIQ7kNvgFKqz8G&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYArqbFXg1tllYxmE3BQZbMP1LH9Y0-O5S01_27cSAOz-A&oe=670BC14D"}, {"file_name": "DetourBus_MaxVelocity_169.png", "id": "674612656986098", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57575358_674612660319431_7744869453757794187_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFe2EWZv0_8Q7kNvgHz0QpR&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCSTpV1Vs8Y7H4zLNk4izKUnc4ZuRnYieLQxfg2yTaPSw&oe=670BA307"}, {"file_name": "DBBusmore.png", "id": "378079580544541", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982720_378079583877874_3988563265796264783_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_h1LVrZoX2cQ7kNvgH5-A4v&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD9tT1nGyCUm30HAvIz_eohl1fROisf2yBvDjjMQh0PUw&oe=670BA21D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "509747380621677", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031591_509747383955010_7293900799620714682_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Oy_I48qMaIQ7kNvgH11rnc&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAmFuTuqBuwVzNx2I9qtcPXky9Vlm6qopVOPuzY-KkSeg&oe=670BAD3F"}, "display_name": "Detour Bus Demo", "keywords": [], "long_description": "ARRIVING SUMMER 2022\nTHIS DEMO INCLUDES THE FIRST LEVEL OF DETOUR BUS\n\nDetour Bus is a VR construction-comedy adventure, where you build ridiculous winding highways, to take the dysfunctional Flowers family on a road trip across Post-Infrastructure America. Nostalgia junkie Daddy Flowers aims to revive his family's bonds before the end of summer vacation, but stuck together in a restored microbus, workaholic Momma, communist-in-training Junior, and social-media-baby Goldie have a lot more to fight about than unite over. Meanwhile, the open road is under threat; you'll have to get in the construction groove to take on corrupt Senator Joseph McCarthief\u2019s attempts to turn all freeways into pay-to-drive tunnels and reclaim your right to transportation.\n\nAccessibility Considerations:\none-button controls\ncaptioning\ndyslexia friendly fonts\nartificial locomotion incl. snap turning, smooth moving\nheight calibration\none-controller mode\nno-reach 3DoF mode\nbuttons-only mode\nfull button remapping", "short_description": "Snap together inconvenient road pieces to build ridiculously convoluted highways, and guide the dysfunctional Flowers family on a psychedelic road trip across post-infrastructure America."}]}, "developer_name": null, "developer_privacy_policy_url": "https://latestageinteractive.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Late Stage Interactive", "support_website_url": null, "website_url": "https://detourbus.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_c