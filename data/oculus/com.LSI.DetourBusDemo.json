t64.5771-25/38974797_189157729974863_5292858727758345177_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EzmsX2xg46gQ7kNvgE6KSmn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0CNmiXOc3UxEX1GpUEbQXsaBEEZUWfD6tyEe5k4CLeA&oe=6714E2C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DBCoverImage.png", "id": "1068790687282975", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036661_1068790690616308_7779510658910897506_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m4StdA0Z4moQ7kNvgEjU-Ji&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgTwMGqLxc13cLe4kV1Kri5qVPu3n1kIqakxSiS_7Y9w&oe=6714F628"}, "display_name": "Detour Bus Demo", "keywords": [], "long_description": "ARRIVING SUMMER 2021!\nTHIS DEMO INCLUDES THE FIRST LEVEL OF DETOUR BUS\n\nDetour Bus is a VR construction-comedy adventure, where you build ridiculous winding highways, to take the dysfunctional Flowers family on a journey across Post-Infrastructure America. Nostalgia junkie Daddy Flowers aims to revive his family's bonds before the end of Summer vacation, by taking them on a good old-fashioned road trip, but stuck together in a restored microbus, workaholic Momma, communist-in-training Junior, and social-media-baby Goldie have a lot more to fight about than unite over. Meanwhile, the open road is under threat; you'll have to get in the construction groove to take on corrupt Senator Joseph McCarthief\u2019s attempts to turn all freeways into pay-to-drive tunnels and reclaim your right to transportation.", "short_description": "Snap together inconvenient road pieces to build ridiculously convoluted highways, and guide the dysfunctional Flowers family on a psychedelic road trip across post-infrastructure America."}]}, "developer_name": null, "developer_privacy_policy_url": "https://latestageinteractive.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Late Stage Interactive", "support_website_url": null, "website_url": "https://www.detourbus.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "TRAVEL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2444995855643306"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1157947471607266"}]}, "baseline_offer": {"id": "1157947471607266"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1652252400, "status": "PUBLISHED", "id": "1157947471607266"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5309029565826348", "version": "0.029"}, "id": "1181848715653580", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4380393272023320", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5309029565826348"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1181848715653580"}]}, "change_log": null, "created_date": 1656098200, "id": "5309029565826348", "version": "0.029", "version_code": 29, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "5309026765826628"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename"