/t64.5771-25/57572929_555828918327887_190267210126589952_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-_iOUpLAovwQ7kNvgGD0N4s&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA7Wp99D9pudxIkuRUn51EiIs7e4-URj43vv0jlJJWOmw&oe=677673A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RGP_StoreTrailer_Thumbnail.png", "id": "1394736561278402", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982698_1394736564611735_120826945869404446_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gD7QPuenWYAQ7kNvgFDlNrL&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCUHVMrEmuHLrwzMf4xnTDv0-65beoUWAjBVRNvuWX7OA&oe=677682F2"}, "display_name": "Radial-G: Proteus", "keywords": ["radialg", "proteus", "radial", "racing", "things3d"], "long_description": "Radial-G: Proteus is a futuristic arcade racer for the VR generation! Climb into the cockpit of a gravity-defying race craft and tear up the tubular tracks as battle commences. Radial-G delivers full immersion racing featuring gut-wrenching twists, jumps, splits and unique inverted racing.\n\nFeaturing:\n- 8 modes including combat, elimination & championship\n- 9 racetracks\n- Kicking electronic soundtrack\n- Single player career mode\n- 4 unlockable ships\n- 3 speed classes\n- Achievements & leaderboards\n\nOMEGA Update \u2013 Now Live:\nBattle a giant mechanoid boss on a signature Radial-G track - avoid an array of attacks and deliver your own knock-out blows.  \n- New boss-fight game-mode with 3 difficulty tiers\n- Additional racetrack \n- Expanded single player campaign\n- 3 more unlockable ships\n\nThe Omega update delivers performance improvements, specifically within the top two difficulty tiers (X-II and X-III) plus visual improvements within the ship cockpits and additional audio elements.", "short_description": "Radial-G: Proteus is a futuristic arcade racer for the VR generation! Climb into the cockpit of a gravity-defying race craft and tear up the tubular tracks as battle commences. Radial-G delivers full immersion racing featuring gut-wrenching twists, jumps, splits and unique inverted racing."}]}, "developer_name": "Tammeka Games", "developer_privacy_policy_url": "https://www.things3d.com/Things3D-Privacy-Policy-VR-Games.pdf", "developer_terms_of_service_url": "https://www.things3d.com/Things3D-EULA-VR-Games.pdf", "publisher_name": "Things3D Ltd", "support_website_url": "https://discordapp.com/invite/bDkEMzt", "website_url": "https://www.things3d.com/#radial_g_proteus", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "RACING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_GB"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "955303148977276"}, "review_messages": ["Approving your metadata update.", "(1) Trailer - please remove old Oculus logo. You are not required to use Meta branding in your assets, but if you do, please comply with our latest guidelines: https://facebook.widen.net/s/s82trcbms2\n(2) Raising the price from $12.99 to $24.99 may negatively impact the application unless a lot of value will be continuously added to meet that price point. "]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974807_924233572240833_5188701069138810893_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kT1uhNgwSf4Q7kNvgEN5AvM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCAWaVrsbNraPGAfw2ctuCzjn_S0XZTWsqV0Ol6xaU1Lg&oe=677674F9"}, "is_concept": false, "is_test": fals