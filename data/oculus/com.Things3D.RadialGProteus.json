7773757_7209550545655169024_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FMp5UImOVdUQ7kNvgG6vfE4&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB8jHXTCwpGX7Tbq73LZkAtIkQtCng4ME8bnnJN7cSNeg&oe=67768378"}, {"file_name": "migrated_image.png", "id": "2261039114192815", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974481_788857818232394_4707270738938167296_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f2V976wLf0QQ7kNvgEdmVbR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQsN-WMxfLwwv5RtuO0AMoRQyxJcXVJbO_-nYpSuu3Ow&oe=677682D7"}, {"file_name": "migrated_image.png", "id": "3075741012460768", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982691_2776582082398392_6443691841656193024_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YxYNsF8fNOUQ7kNvgH7OYHZ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBf36aODw_pOF3QqGy0al9AJGyyQhNTQM0nhQdbB2wSHw&oe=677687DE"}, {"file_name": "migrated_image.png", "id": "2811869315595470", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974661_431605264219466_8140254934902767616_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mBnimJntV9kQ7kNvgGHt9vh&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAaMQlYWJVWjDmqciyvtOWqzCe4CoZRv-YHmWInvZKeKA&oe=677667CF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Radial-G: Proteus", "keywords": ["radialg", "proteus", "radial"], "long_description": "Radial-G: Proteus is a futuristic arcade racer for the VR generation! Climb into the cockpit of a gravity-defying race craft and tear up the tubular tracks as battle commences. Radial-G delivers full immersion racing featuring gut-wrenching twists, jumps, splits and unique inverted racing.\n\nFull release features:\n- 8 Gameplay modes including combat, elimination and championship\n- 9 racetracks\n- Kicking electronic soundtrack\n- Single player career mode\n- 4 unlockable ships\n- 3 speed classes\n- Oculus achievements and leaderboards\n\nOMEGA Update \u2013 Due Q1 2020\nA free update to be released in early 2020 will deliver a new boss-fight game mode where players will battle a giant mechanoid boss on a signature Radial-G trac - avoid an array of attacks and deliver your own knock-out blows.\n- New boss-fight game-mode\n- Additional racetrack\n- Expanded single player campaign\n- 3 additional, unlockable ships", "short_description": "Radial-G: Proteus is a futuristic arcade racer for the VR generation! Climb into the cockpit of a gravity-defying race craft and tear up the tubular tracks as battle commences. Radial-G delivers full immersion racing featuring gut-wrenching twists, jumps, splits and unique inverted racing."}]}, "developer_name": "Tammeka Games", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Things3D Ltd", "support_website_url": "https://discordapp.com/invite/bDkEMzt", "website_url": "https://www.things3d.com/#radial_g_proteus", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RACING", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_GB"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "456787509273639"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "787831964975181"}, {"status": "PUBLISHED", "id": "567046687267935"}, {"status": "PUBLISHED", "id": "975514470133192"}, {"status": "PUBLISHED", "id": "716765135524404"}, {"status": "PUBLISHED", "id": "1679858375485304"}, {"status": "PUBLISHED", "id": "1942164