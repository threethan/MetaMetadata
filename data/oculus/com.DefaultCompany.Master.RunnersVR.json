1016684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SIPSxSBPeg0Q7kNvgFinMsz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZGSvZuIHv8XYjH8_jIvj54EJxe-J75JFiCUxJpVE-Iw&oe=66FA8CD5"}, {"file_name": "eeeeeeeeee (1).png", "id": "1121557132334302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974534_1121557135667635_4134163534322495179_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bGqaxZaEPNgQ7kNvgHweUBp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCP103qOX5SMOZT_EaO83AJ1GFdEekDTBfA-6rirD6ySg&oe=66FAA280"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pLmuJ6dVsjQQ7kNvgG3KXw_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSVnZkmqTQMVmzH9EVAKypKpwRUe3QkuCtKv2zUwbCzQ&oe=66FAA6F0"}, {"file_name": "file (47).png", "id": "1568162237134735", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_1568162240468068_2070856399929019743_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9gxUcyX1OwQ7kNvgEDAEIm&_nc_ht=scontent.oculuscdn.com&oh=00_AYDp2ctBd_OmCUAPGTLfVcKDzXxZEy-5RQdh0SaVexjhOg&oe=66FA7434"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n__y1vVWDw4Q7kNvgHFBIxg&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8lcd6IfS92ot34Q5TDq400Lg7lFZsJLgSVgha-EJ4dw&oe=66FA8273"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1623171634894204", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451785_1623171638227537_7743361280080950072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d6SPy96lmCoQ7kNvgHhgiYd&_nc_ht=scontent.oculuscdn.com&oh=00_AYBLCcWrut6bKTcheYte8YirIEfGwwrvdTydvfZ29qjBnA&oe=66FA7734"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQU