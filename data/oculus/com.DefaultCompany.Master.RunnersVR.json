DyGARVXAvwhBi2yTvMa-1wXM5nddZSgcTPc1ON7mw&oe=673F2BBD"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iX1LTYLqNmwQ7kNvgFUa2sh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHHFKHYZfnlsipeCnZZTthUDNKVvdePSg4S5Lk0yIJlw&oe=673F34F0"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xMuDpH96QrsQ7kNvgGQAra1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFrSRpWkYKz7_0bjgQDuKAptMHAvJ2GWX7xoCz5BFQXQ&oe=673F1073"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (50).png", "id": "920675899557293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982634_920675902890626_6766560299956088835_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DA8u65OUVlgQ7kNvgGid9xE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLvba3ZeufAi52FEAnhz77abfhDSv9yyt1WGaJkWlaYA&oe=673F0257"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **10+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{1750476139119333}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{905759964367379}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "RACING", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27467182489595199"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031314_879033621047498_2571690055100882231_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uc8BGodrqOgQ7kNvgGuaP9Z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkl_bZWmu3-vVj2QAg5aAUOVT8iudOPn-phc