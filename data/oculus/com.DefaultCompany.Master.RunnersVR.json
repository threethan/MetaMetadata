44_1016684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FO1O6SdOw_EQ7kNvgEHG5Pm&_nc_ht=scontent.oculuscdn.com&oh=00_AYC30R-F5h_GusavK250fyvZiqnpm01ol4NZfT4UZWlYBg&oe=66D6F455"}, {"file_name": "eeeeeeeeee (1).png", "id": "1121557132334302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974534_1121557135667635_4134163534322495179_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T1HE189BazQQ7kNvgHieckh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCseYkmEep4hQlpMmqRzTgiY9SVu5aOaM15KWoHtMjT1w&oe=66D70A00"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bCt1hBFcW-wQ7kNvgHygmfw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmoUvEJUS1ZeOkVhiNmVcNcECp1In1K8walCD1IUEV_Q&oe=66D70E70"}, {"file_name": "Master Robbery Meta.png", "id": "186678101013226", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982505_186678107679892_8224342104526079261_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXJY_RG3hmYQ7kNvgFiT7KM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsNUOjNAF1BPQA6ZzcY5n38gCBAwV9jop3lbGjYVgwtg&oe=66D6ED6D"}, {"file_name": "MRVR Horror.png", "id": "1544181109415037", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982627_1544181126081702_3277664498223821582_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oezP5lshG90Q7kNvgHno4OV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxfDr3sVK6FfBE5OKWKaqi96S4NU7Qy9Ln9NUyp_WrNQ&oe=66D70247"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1623171634894204", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451785_1623171638227537_7743361280080950072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8AyvfAMgyjkQ7kNvgHG67IZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDO_TddBHBrmyHw7NKmj5jvNURcVFDFtBbgOda1XEKRnw&oe=66D6DEB4"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer with **no lag.** For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NO