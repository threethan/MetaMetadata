nDOwqbav6aOJCizwT1Sg3wBRmaCOf_TsY67Rw&oe=677BB522"}, {"file_name": "Ethan's Chase.png", "id": "1255499219235286", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982699_1255499222568619_8971902771772652696_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NnQpAJyfvz8Q7kNvgHzjGZ4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD7g1byd_VqYZPPZu1CSJWhxt9IYFfRhFW4gb7CfvY_mg&oe=677BD0BD"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4c7CQrkyh0kQ7kNvgGGc5Ec&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBPWC5CFXVkwZi0b0UYq-dEautzy-oH5d4D8DduihwHew&oe=677BB573"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (17).png", "id": "1103861788182754", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982446_1103861791516087_7629112291782068296_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-SRZdj5tcr8Q7kNvgF909SD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDbpuBfEh-HxzqOUtU5YvY_phC7i2831Rl_YHUKGYy05A&oe=677BC294"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **10+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{1750476139119333}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{905759964367379}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "RACING", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27980199238293519"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974667_1261716038455485_6040978320866109861_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pUcU_Wd5TGkQ7kNvgH5CZPa&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDssofnw1Kzuuh1W1_oy4WWF_kS7DbJU_XkMr