841081692752_5615313403274744634_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZTQwTZS_nOEQ7kNvgH3MTKw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrY5nZ5rvZEpPhTJMoWzLDq6ovzODtg9D3kS1_weSxRw&oe=67236A08"}]}, "id": "3908010202776824", "locale": "en_US", "screenshots": [{"file_name": "MRVR Group Meta.png", "id": "1016684059650413", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314844_1016684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6No8F3EWQE4Q7kNvgHFlMe-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9FzQXOIC1tgMxItEF_CZWbMtlurdaS2RPpufF-6lPjg&oe=67236B55"}, {"file_name": "file (32).png", "id": "1205901723819230", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035397_1205901727152563_7583367210078983654_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6yg4_7ziZMQ7kNvgHbRNFa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATZUrxlc0lzxjxSuiyo2RNUWHDJbSgRxRm33TqDmiv2Q&oe=672375C1"}, {"file_name": "Ethan's Chase.png", "id": "1255499219235286", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982699_1255499222568619_8971902771772652696_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I4wx1MqRmvMQ7kNvgH6M2B7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfuItsta7ollE_tkwpEajf4W_inO3RNaQJ3ReC3f-y0g&oe=67237C3D"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SVzsPIGP8P0Q7kNvgHaMbOo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDr31PNBZo23kswh8oyHbl6MCFEJnU0eRnGLN6a7S72mg&oe=67238570"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JjvgM6Eft1gQ7kNvgGsAzWO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7Gtusw3wGdeEk-i5LgY6p7HE-WRrB_x4irFzHrdUawQ&oe=672360F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1292376902181564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395422_1292376905514897_388636402360163328_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rqvT8SNSOLIQ7kNvgFLThaK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwukgERGUmz-j-haF6CWqcwhgd7JjXlUbhvgGXjR-_sw&oe=67235C6A"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMV