cdn.com&oh=00_AYDuFY5Pkpe6zDtEIaHzl5a18kPY65QF-hRR_Js2yeJoKg&oe=670A5D88"}]}, "id": "889495433128660", "locale": "en_US", "screenshots": [{"file_name": "MRVR Group Meta.png", "id": "1016684059650413", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314844_1016684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wQAu0RQ01sgQ7kNvgHj65EU&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo0TcleGi3USkZsYbAJqWU6oW_oQ4almHOaxewyhL1vw&oe=670A5ED5"}, {"file_name": "file (32).png", "id": "1205901723819230", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035397_1205901727152563_7583367210078983654_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=myUlNWbFVlcQ7kNvgH9u7dq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxWNPse7Aqe35Hj3NxIz1E8FVLWpdZtUkal7bIPd_8Tg&oe=670A6941"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qP5ucx_YcT0Q7kNvgFFRduT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAN2Fu-O7OT5-oOZVfdTUyXOEwJlP9D16fiurtHWPagog&oe=670A78F0"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eGn23exFJ2QQ7kNvgGeqDhi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBu-qJaG-cfqgCNzbpgNdnA9BLSKDp3kC7AXmJ-AGLABQ&oe=670A5473"}, {"file_name": "eeeeeeeeee (1).png", "id": "1121557132334302", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974534_1121557135667635_4134163534322495179_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RR69akSFkIYQ7kNvgF2MLlh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBngMgSPtzL1EVDSVXhn_iStHcNTbhHbnJ5ohFF5sig0Q&oe=670A7480"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1292376902181564", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395422_1292376905514897_388636402360163328_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tstUiCoF9DkQ7kNvgGatEDY&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwdD7_PG6vk43j9c_FgVyG9g7EEG467gzYn6FtZwG18Q&oe=670A4FEA"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "webs