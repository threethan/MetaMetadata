16684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mbS5T1yymxgQ7kNvgG5X9P3&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2vLMHzSCNCBmBmZN2bov2O59k3qwLuUJbe3DL1ndaPQ&oe=66F93B55"}, {"file_name": "eeeeeeeeee (1).png", "id": "1121557132334302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974534_1121557135667635_4134163534322495179_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=683kX3Qa76IQ7kNvgGlfXcn&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9X_L190hZdZon1fveuEt2kdqUtjYalfY0-VjUMSmVLA&oe=66F95100"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pLmuJ6dVsjQQ7kNvgF1RuJ2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKtb-8WuoY4FTUiL8AuWlj5GeYhezxZB1lw8a8948x5w&oe=66F95570"}, {"file_name": "file (47).png", "id": "1568162237134735", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_1568162240468068_2070856399929019743_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9gxUcyX1OwQ7kNvgG7_7kR&_nc_ht=scontent.oculuscdn.com&oh=00_AYBoWshC9rBXyxKmtReo_lnDeqRc4-FIA5ofKCe0H5as1Q&oe=66F922B4"}, {"file_name": "file (46).png", "id": "1692382654890848", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240103_1692382658224181_5970319058825815420_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n__y1vVWDw4Q7kNvgFfSVnR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDm5Gi9JuEqKdJ2mfBH0uO6BTGRYC3106sJ5iD5VJz8Kw&oe=66F930F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1623171634894204", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451785_1623171638227537_7743361280080950072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NuV63FJ45s0Q7kNvgGEmD_E&_nc_ht=scontent.oculuscdn.com&oh=00_AYBooBOOxdkBteQ4cjeZ0oEXlDGSoUvP8LBLd2D8wotE7Q&oe=66F925B4"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer & have a very fun time. For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIR