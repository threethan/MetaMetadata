_1016684062983746_3607708188658648680_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UFwYErk8kWQQ7kNvgEojOvB&_nc_ht=scontent.oculuscdn.com&oh=00_AYALZSJI003ndmpcT5h2GTnOrIBTlfa7CclC_AqcM6tLyg&oe=66CF0B55"}, {"file_name": "eeeeeeeeee (1).png", "id": "1121557132334302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974534_1121557135667635_4134163534322495179_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OL8_OX1SHUMQ7kNvgEbGJQq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsnsRbqHNGXmyxCKrsM12nnVQPWgmIqBrs9lhzO89uaw&oe=66CF2100"}, {"file_name": "file (38).png", "id": "820420093582718", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035371_820420096916051_7743172578757633537_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1v_MCjaZtV0Q7kNvgEozO-o&_nc_ht=scontent.oculuscdn.com&oh=00_AYCii8CuNj3lkbFMqjbtQo8APQCdOMR_gQKvGQZ-yrAWJQ&oe=66CEED30"}, {"file_name": "Master Robbery Meta.png", "id": "186678101013226", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982505_186678107679892_8224342104526079261_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=16duwnN9KoIQ7kNvgGSNkxM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDW1t45pATQjmKpdflFa-O2U_64hq1aNFro-aPOc15zOg&oe=66CF046D"}, {"file_name": "MRVR Horror.png", "id": "1544181109415037", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982627_1544181126081702_3277664498223821582_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rrOdaK0yk28Q7kNvgH3S2XO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzijtzTtFLjIHjndyqpqmClf0Oro_0ALRVh6QEOVjI_w&oe=66CF1947"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (33).png", "id": "1623171634894204", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451785_1623171638227537_7743361280080950072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqrC6Wy1t3AQ7kNvgHiQfPL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiQbEfLW-zDKhvN9rpY9XTfky8K8odp_aeCDDWngEwFA&oe=66CEF5B4"}, "display_name": "MasterRunners", "keywords": ["runners", "master", "mrvr", "mrvrv2", "masterunner"], "long_description": "# Welcome to the MasterRunners Page.\n\nMasterRunners is a free-to-play multiplayer hand based movement game surrounding a variety of entertaining gamemodes, cosmetics, obstacles, etc.\n\nWith over **9+ gamemodes** and an **active player count of 100,000+**, we guarantee this game is worth your time. We have lots to offer, so what are you waiting for!?\n\n# What you can do:\n\n- Play Gamemodes with players across the **WORLD**. MasterRunners can be played worldwide and with our **advanced multiplayer system**, you can enjoy multiplayer with **no lag.** For the gamemodes, we build special gamemodes that have never been used in others games making us stand out and more fun.\n{440204882312445}\n- Chill with friends and have a **great time.** With areas such as the \"Main Hub\", you can relax and have a calming time with buddies as you talk to your hearts desire.\n{509486194868299}\n- Shop for new cosmetics at Gregson's Shop with the free in-game currency... Energy! Using energy, you can get all kinds of cosmetics of any type just with one click. This is how you can customize your character!\n{1216230166051298}\n\n- **Survive Monsters..**\n{770419325031966}\n\nAnd more. \n\nThere is lots to do in MasterRunners, so check it out **TODAY!**\n{346841078359419}", "short_description": "Complete Obstacles, Beat Gamemodes, & Be yourself to show, you are the true \"MasterRunner\"."}]}, "developer_name": "EthanMonke (EMVRGames)", "developer_privacy_policy_url": "https://www.masterrunnersvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EthanMonke", "support_website_url": null, "website_url": "https://www.masterrunnersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_