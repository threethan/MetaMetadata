664468307", "locale": "en_US", "screenshots": [{"file_name": "SCREEN_1.png", "id": "1647335826047956", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035430_1647335829381289_2263322871571288497_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qm7u3odFq6EQ7kNvgF1gTXS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAF8SScWkbtbuSBcPJbZ3GzrQylvpgKMbCAD2vCwi9n6w&oe=6734896D"}, {"file_name": "SCREEN_2.png", "id": "991061998991291", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572953_991062002324624_2438135491551864254_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jooHbi-VZ1cQ7kNvgGpqEQ4&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAhCDDqh05J1iCQSnqhatCd2TIHCxkTgzcC0Mw523AOgw&oe=673487C6"}, {"file_name": "SCREEN_3.png", "id": "2695344147327953", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/86636486_2695344150661286_8929751713226599295_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GhyUYxveEiMQ7kNvgEgc1J7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCI7CjhfK5u3_N3mFl8MaZeTwWdMsrrvp2zsIA5oPCI6A&oe=673481BD"}, {"file_name": "SCREEN_4.png", "id": "814968403674639", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982568_814968407007972_8019743597048671869_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3gevxuOYOa0Q7kNvgFQHQrk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCT70Xn523NlWmH33njI_wIt5x9bfq0LOHjAwS8ycysQg&oe=67349507"}, {"file_name": "SCREEN_5.png", "id": "1132088471356761", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031350_1132088474690094_2513089939497492850_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I6KenpY_aIIQ7kNvgGm4LWU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAFSnY8c85Su_4r6SL80m_kn2hbBDaZESsALMx0sA6CEw&oe=6734A32D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1465584857472922", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974500_1465584860806255_7766854712898267653_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6nvA8eOskOoQ7kNvgG_HbNe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCop1Lau7sD5txNV9jDyjFDsq6ljdRoeky2cTHp-4iQkA&oe=67348581"}, "display_name": "FortiCasa", "keywords": [], "long_description": "Immerse yourself in a unique strategic defense adventure with FortiCasa: AR Robot Defense for Oculus Quest! This game brings the tower defense genre to your living space using augmented reality. Transform your room into a futuristic battlefield and defend your base from waves of hostile robots!\n\nIn FortiCasa, your mission is to protect your base from relentless robotic attacks. Strategically place powerful turrets around your play area to create a fortress. Utilize your real-world environment to enhance your defenses and adapt to the evolving threats posed by different types of robotic enemies.\n\nKey Features:\n\n- Augmented Reality Immersion: Your room becomes the battlefield, with robots seamlessly blending into the real world.\n- Strategic Depth: Choose and place turrets, each with unique abilities and upgrade paths, to optimize your defense.\n- Varied Arsenal: Access a selection of defensive turrets, including rapid-fire cannons, laser beams, and explosive launchers. Upgrade them to increase their effectiveness.\n- Dynamic Challenges: Face increasingly difficult waves of enemies with varying strengths and attack patterns. Adapt your strategy to counter different robotic foes.\n\nGear up and defend your base with precision and strategy.  Can you withstand the robotic onslaught and become the ultimate defender in FortiCasa: AR Robot Defense? Your fortress awaits!", "short_description": "\nImmerse yourself in an unparalleled strategic defense experience with FortiCasa for Oculus Quest 3! Transform your room into a futuristic battlefield using augmented reality and defend your base from relentless waves of hostile robots. Plan your strategy, place defensive turrets around your play area, and utilize your real environment to create an invincible fortress."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.eyeliensheroes.com/documents/privacy_forti.html", "developer_terms_of_service_url": null, "publisher_name": "Floaty S.r.l.", "support_website_url": null, "website_url": "https://floaty.it/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9129719697060514"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974895_1675544253310505_6114060850662942230_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhH2zZl4tQ8Q7kNvgFL9TR6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCgoYvA-39bo2XufDk2TZoKnLqdw3YtrQ3oaHpLERhVpQ&oe=6734A5D8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "FortiCasa", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1725985320, "lastRevision": {"nodes": [{"id": "8152730641426096", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8152730618092765", "is_first_party": false, "enables_in_app_