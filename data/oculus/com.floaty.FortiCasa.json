356761", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031350_1132088474690094_2513089939497492850_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I6KenpY_aIIQ7kNvgGm4LWU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAFSnY8c85Su_4r6SL80m_kn2hbBDaZESsALMx0sA6CEw&oe=6734A32D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1465584857472922", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974500_1465584860806255_7766854712898267653_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6nvA8eOskOoQ7kNvgG_HbNe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCop1Lau7sD5txNV9jDyjFDsq6ljdRoeky2cTHp-4iQkA&oe=67348581"}, "display_name": "FortiCasa", "keywords": [], "long_description": "Immerse yourself in a unique strategic defense adventure with FortiCasa: AR Robot Defense for Oculus Quest! This game brings the tower defense genre to your living space using augmented reality. Transform your room into a futuristic battlefield and defend your base from waves of hostile robots.\n\nIn FortiCasa, your mission is to protect your base from relentless robotic attacks. Strategically place powerful turrets around your play area to create a fortress. Utilize your real-world environment to enhance your defenses and adapt to the evolving threats posed by different types of robotic enemies.\n\nKey Features:\n\n- Augmented Reality Immersion: Your room becomes the battlefield, with robots seamlessly blending into the real world.\n- Strategic Depth: Choose and place turrets, each with unique abilities and upgrade paths, to optimize your defense.\n- Varied Arsenal: Access a selection of defensive turrets, including rapid-fire cannons, laser beams, and explosive launchers. Upgrade them to increase their effectiveness.\n- Dynamic Challenges: Face increasingly difficult waves of enemies with varying strengths and attack patterns. Adapt your strategy to counter different robotic foes.\n\nGear up and defend your base with precision and strategy. Can you withstand the robotic onslaught and become the ultimate defender in FortiCasa: AR Robot Defense? Your fortress awaits!", "short_description": "\nImmerse yourself in an unparalleled strategic defense experience with FortiCasa for Oculus Quest 3! Transform your room into a futuristic battlefield using augmented reality and defend your base from relentless waves of hostile robots. Plan your strategy, place defensive turrets around your play area, and utilize your real environment to create an invincible fortress."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.eyeliensheroes.com/documents/privacy_forti.html", "developer_terms_of_service_url": null, "publisher_name": "Floaty S.r.l.", "support_website_url": null, "website_url": "https://floaty.it/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8596502950382194"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "897405722362739"}, {"status": "PUBLISHED", "id": "478302615109296"}, {"status": "PUBLISHED", "id": "1204884953865490"}]}, "baseline_offer": {"id": "1204884953865490"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "897405722362739"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", 