 conditions; simply download the navigation package before experiencing. Each individual equipped with a device can engage in group discussions and collaborate on completing learning tasks, making learning as enjoyable as embarking on a treasure hunt adventure.", "short_description": "A lightweight, stable, and fast navigation eyewear app, designed to assist in education and facilitate VR product demonstrations for businesses."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ar2vr.io/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "AR2VR", "support_website_url": null, "website_url": "https://ar2vrtw.wixsite.com/ar2vr", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7157692847686551"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "742216988017737"}]}, "baseline_offer": {"id": "742216988017737"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1713402420, "status": "PUBLISHED", "id": "742216988017737"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7805458959576600", "version": "2.3.2.1"}, "id": "961032818863568", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary