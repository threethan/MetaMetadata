ile_name": "Screenshot1.png", "id": "586367519626138", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003242_586367522959471_5282683893066263987_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JXvwO_oTj04Q7kNvgGY87EW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMDPMQPZsD7I4ZTl7l1_87&oh=00_AYDU_Qt_A6k5q0iY_bE6dkGFtGxf60urk6lrnFWefnpSAg&oe=66F2B3CC"}, {"file_name": "Screenshot2.png", "id": "582630293360190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982541_582630296693523_6117141187659797588_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OTHjFHkUHGAQ7kNvgFQG88j&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMDPMQPZsD7I4ZTl7l1_87&oh=00_AYAnJFTu4anPNmQGkPSGpgev-px7xeeWdn5l0xC4swBAKQ&oe=66F29213"}, {"file_name": "Screenshot3.png", "id": "1615302805533708", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031315_1615302808867041_8474953266952880772_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gO26yEYzTXsQ7kNvgGYDUkp&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMDPMQPZsD7I4ZTl7l1_87&oh=00_AYA2VveYs8UpIB1olw9KvsH8TwG3rxd66EwbQ3NSglMenw&oe=66F295D1"}, {"file_name": "Screenshot4.png", "id": "782483226108424", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_782483229441757_2357525884853135287_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-sqC3eG-qCAQ7kNvgHsLbpk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMDPMQPZsD7I4ZTl7l1_87&oh=00_AYBWPTfYP2zelWk3VNKNo1spPo1bAghwThkLIQ65mtniiA&oe=66F2B2B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "782023966478773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974515_782023973145439_749891387670287731_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UvoBXUI0yC0Q7kNvgHMWc7n&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMDPMQPZsD7I4ZTl7l1_87&oh=00_AYDv_uUo9b6txZB71eUwcWiNsc3vxTUG343jU9C2lm4uHg&oe=66F2A2AF"}, "display_name": "3D scan of a snowy town", "keywords": [], "long_description": "Move like a pedestrian in a snowy town, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 670m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.", "short_description": "Move continuously like a pedestrian in a snowy town, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held camera (Garmin Virb 360) and by walking about 670 meters in a town (Laschamps, in France)."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes":