771-25/38982541_582630296693523_6117141187659797588_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffTlCJLcSUwQ7kNvgGgOgXy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAoaOFROYQix5wNw3UDKn5-LtWrSWDpRUpOfJAYsSO_ZA&oe=67347D13"}, {"file_name": "Screenshot3.png", "id": "1615302805533708", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031315_1615302808867041_8474953266952880772_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pT3C4oEfGFIQ7kNvgFiPVbr&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAGYkLHhdneW8RI0OPFqLhbRR-1vIIfKasXSir78PaUSg&oe=673480D1"}, {"file_name": "Screenshot4.png", "id": "782483226108424", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974593_782483229441757_2357525884853135287_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-sDUQYiug2cQ7kNvgF7h-nw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYApk0tJQGF3ADKHmH-jnXVDIMPCqisO29LNAkN1smNdfA&oe=67349DB2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "782023966478773", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974515_782023973145439_749891387670287731_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eaPpM_GPPNUQ7kNvgEKeITm&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCyjaYhUB-Sclxtzv84_kW1S0C7xSSpPGJjIoICIQXuHA&oe=67348DAF"}, "display_name": "3D scan of a snowy town", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a pedestrian in a snowy town, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 670m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.", "short_description": "Move continuously like a pedestrian in a snowy town, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held camera (Garmin Virb 360) and by walking about 670 meters in a town (Laschamps, in France)."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8618312318218961"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974901_393927342871345_7472813470315400161_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ettxfxfMRosQ7kNvgHwl7NQ&_nc_zt=3&_nc_ht=scontent-ams4