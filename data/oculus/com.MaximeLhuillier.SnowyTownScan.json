771-25/38982541_582630296693523_6117141187659797588_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4O2ZknaxDG8Q7kNvgE5aK0r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdomtU9O5Fe0-xoktoqRr_B7osmKWDCA4G7l9CcmmDoA&oe=67274E13"}, {"file_name": "Screenshot3.png", "id": "1615302805533708", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031315_1615302808867041_8474953266952880772_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TeEstLx08CQQ7kNvgEK-A0R&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCs9TLMmAxowxwBHYIRyn-3N-E7cVR3oGaQhnLWXds4gw&oe=672751D1"}, {"file_name": "Screenshot4.png", "id": "782483226108424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974593_782483229441757_2357525884853135287_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9QmalWEvJNkQ7kNvgEVc9hg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCS24JP2DGG60Rm5jBnbTaQqYPtvvYiZgKzhBHl0-I0w&oe=67276EB2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "782023966478773", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974515_782023973145439_749891387670287731_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q-EefONtQvIQ7kNvgGchlwz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUWtYECpZth41xT-qoorbNr37LRccTucN2hs5vAPGbTQ&oe=67275EAF"}, "display_name": "3D scan of a snowy town", "keywords": ["photogrammetry", "reconstruction", "360camera", "digitization", "scan"], "long_description": "Move like a pedestrian in a snowy town, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 670m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.", "short_description": "Move continuously like a pedestrian in a snowy town, which was computed by photogrammetry from two 2496x2496 videos taken by a helmet-held camera (Garmin Virb 360) and by walking about 670 meters in a town (Laschamps, in France)."}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8618312318218961"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_393927342871345_7472813470315400161_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lBcXSrc_POsQ7kNvgG-_fA9&_nc_zt=3&_nc_ht=scontent-iad3