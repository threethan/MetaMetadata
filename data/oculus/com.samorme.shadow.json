ging.png", "id": "1200948237451705", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982671_1200948240785038_8011447553024896647_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KtA0oY4rS-0Q7kNvgFxck-l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjSMm5K3xLTSoPt1qsWGOW8PVHfilO7xV50Ihb1MPf2Q&oe=674706FB"}, {"file_name": "bow-and-arrow.png", "id": "540687551526051", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031560_540687554859384_2223023307864762140_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-JRIGUlJAOUQ7kNvgHXArAP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUXtKebVwBAaV6ehb41gNcWHHgHw3PDuhzMdzm_DtV2g&oe=67470E87"}, {"file_name": "zipline.png", "id": "1004630790075228", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036607_1004630796741894_4051486913823091613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qalfkCwq5NYQ7kNvgF1S6It&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_WCijRtoGxJ79PtLztsfM-e1iaHeRE3uMPkMuMfym5Q&oe=6747011C"}, {"file_name": "village.png", "id": "233090625855580", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974888_233090629188913_3030239811315842344_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sflhq6jQkNEQ7kNvgGpGsfg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKoBPKk6Dz72lQPwC-KmAma8XxBKP2Evh_wvyQB5G9JQ&oe=674705D0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Out of the Shadows", "keywords": [], "long_description": "Welcome potential assassins!\n\nArmed with your weapons you must complete your objectives completely undetected in order to succeed. Sneak, climb, evade your enemy, or kill at your own risk. Use a variety of weapons including daggers, axes, shields and hidden blades to stab, slash and trip up your enemies. Some weapons are provided, others you'll have to find, steal or kill for. Enemy awareness is heightened as the difficulty level rises! Hide the bodies.\n\n\n\nOut of the Shadows is a stealth based assassin game currently in early access. There are 3 unique maps with various difficulties, each one has it's own challenges and objectives. There are currently 2 modes: Objective (Complete objectives as quickly as possible) and Overkill (Kill everything as quickly as possible). Not a stealth fan? Run, jump & climb around the maps without any reaction from enemies in Sandbox mode!\n\nThis game is in Early Access, to get the latest updates on the development, and give your feedback for potential inclusion in the game - join our Discord.", "short_description": "You are an assassin. Armed with your weapons you must complete your objectives completely undetected in order to succeed. Sneak, climb and evade your enemy, or kill at your own risk."}]}, "developer_name": null, "developer_privacy_policy_url": "https://outoftheshadowsvr.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Sam Orme", "support_website_url": null, "website_url": "https://outoftheshadowsvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "275629210202852"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "175358788704327"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "173544728957233"}]}, "baseline_offer": {"id": "173544728957233"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1683154800, "sta