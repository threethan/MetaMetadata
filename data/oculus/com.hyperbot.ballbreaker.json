00_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbQCeIPxPFAQ7kNvgEozBXc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADwYeVoKcPs8lLRAHU79gEWeXON0V6Dgb3GMAumgmseQ&oe=677FA08B"}, {"file_name": "migrated_image.png", "id": "2758661591018871", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974601_789577681422880_1145664500230258688_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LPGuaBEkJOQQ7kNvgHtQau5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEuYdujkwOhFbckyRFl9HM8_0HYUWZvwe2yUHvvn0hnw&oe=677FB416"}, {"file_name": "migrated_image.png", "id": "577041926244020", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974547_367260324005391_6580659839079284736_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tmOlTXBEnloQ7kNvgFC5U0w&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAx1KAg3-9IOgJjNAoCb_o1c4Od9PgA5JaZYyQBi5WTLw&oe=677FC614"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boba Pop", "keywords": ["casual", "easy", "indie", "boba", "puzzle"], "long_description": "Boba Pop is the juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes. Find the angle that hits the sweet spot, pop power-ups for explosive chain reactions, but whatever you do, clear the jellies before they overwhelm you!\n\nFeatures:\n- Easy to pick up and hours of fun!\n- Compete for high score on the global and friends leaderboards\n- See how long you can last in endless levels!\n- Discover all of the awesome power-ups\n- Play distinct levels inspired by Taiwanese boba tea and shaved ice\n- Cute original art and catchy music", "short_description": "The juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes."}]}, "developer_name": "Hyperbot Studio", "developer_privacy_policy_url": "http://www.lyravr.com/privacy-policy2", "developer_terms_of_service_url": null, "publisher_name": "LyraVR Inc.", "support_website_url": null, "website_url": "http://