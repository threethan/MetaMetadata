00_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IROHsOkphIoQ7kNvgHYwpeg&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwDY53WGjcWY5cjgmx7ja7ZB_GAa-dsimeGx_V8DA7hA&oe=6776660B"}, {"file_name": "migrated_image.png", "id": "2758661591018871", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974601_789577681422880_1145664500230258688_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lXTQ4gFShs0Q7kNvgEq8wKQ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBRk59SyeZnLOrrEeihGUWbk6hCC30gSaco7ttmaSpbOQ&oe=67767996"}, {"file_name": "migrated_image.png", "id": "577041926244020", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974547_367260324005391_6580659839079284736_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=duJ7zbG36EMQ7kNvgHH_ykF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBHRUdZH50MsL5j5e2tPzUJ8_ZG5Dy-puZLFFt0q6J99w&oe=67768B94"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boba Pop", "keywords": ["casual", "easy", "indie", "boba", "puzzle"], "long_description": "Boba Pop is the juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes. Find the angle that hits the sweet spot, pop power-ups for explosive chain reactions, but whatever you do, clear the jellies before they overwhelm you!\n\nFeatures:\n- Easy to pick up and hours of fun!\n- Compete for high score on the global and friends leaderboards\n- See how long you can last in endless levels!\n- Discover all of the awesome power-ups\n- Play distinct levels inspired by Taiwanese boba tea and shaved ice\n- Cute original art and catchy music", "short_description": "The juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes."}]}, "developer_name": "Hyperbot Studio", "developer_privacy_policy_url": "http://www.lyravr.com/privacy-policy2", "developer_terms_of_service_url": null, "publisher_name": "LyraVR Inc.", "support_website_url": null, "website_url": "http://