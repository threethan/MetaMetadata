8_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vqMq5owM1NsQ7kNvgGK2fxh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDi2WJ9wx1BYgVYt3f9wYQZHG8PNgL7Q0e1v3vLJMgyLg&oe=66D5A296"}, {"file_name": "migrated_image.png", "id": "577041926244020", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974547_367260324005391_6580659839079284736_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UqGEgoVPL3AQ7kNvgFK38wG&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAqWsqAMzbP6CfW-UTjQg_3e1j0GWGCvINVlsgx3t5hw&oe=66D5B494"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Boba Pop", "keywords": ["casual", "easy", "indie", "boba", "puzzle"], "long_description": "Boba Pop is the juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes. Find the angle that hits the sweet spot, pop power-ups for explosive chain reactions, but whatever you do, clear the jellies before they overwhelm you!\n\nFeatures:\n- Easy to pick up and hours of fun!\n- Compete for high score on the global and friends leaderboards\n- See how long you can last in endless levels!\n- Discover all of the awesome power-ups\n- Play distinct levels inspired by Taiwanese boba tea and shaved ice\n- Cute original art and catchy music", "short_description": "The juiciest jelly poppin' VR game! Aim your straw and bounce boba balls to burst the jelly cubes."}]}, "developer_name": "Hyperbot Studio", "developer_privacy_policy_url": "http://www.lyravr.com/privacy-policy2", "developer_terms_of_service_url": null, "publisher_name": "LyraVR Inc.", "support_website_url": null, "website_url": "http://bobapopgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended