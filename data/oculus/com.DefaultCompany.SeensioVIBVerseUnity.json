_sid=6e7a0a&_nc_ohc=K7tGgdAO1FgQ7kNvgHTtSNG&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCydEYHg5Uc4oaRQMPJ_CUQJxWNZOpUq9nlfcnIDHco3w&oe=6710EA7A"}, {"file_name": "1.png", "id": "1209259770428933", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75375766_1209259773762266_5984976996110111453_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4kFrz2CrNDcQ7kNvgGAPZp5&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAAzH91cDeH31EwMG443K3ib4ugH2xUmWwbVERjQ3esPA&oe=67110DEC"}, {"file_name": "5.png", "id": "309144408932247", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974866_309144412265580_1493421067471455022_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T03ejrG_1rsQ7kNvgF1uKSV&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCwEV6lIULY-yPcbZtUUa67mGA3R0hLc5A4UzXucpGPKw&oe=67111223"}, {"file_name": "2.png", "id": "471515532223784", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39036692_471515535557117_7381538198738259856_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N4scWQjIpmoQ7kNvgFIVg5b&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAZKwIL4YE_2jHZ6GsJMPBXGOw8qYKvSw_GnwTDeBJE3g&oe=6710E878"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.2 Cover Landscape.png", "id": "447879878176094", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035310_447879881509427_6152545594938277359_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uubHrjLQ1bgQ7kNvgE7STKP&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCn2q3NxsFlm2_VTw7kmQpxYUMY0hs5XMUBfEjOxI6uLg&oe=67110AAD"}, "display_name": "VIB Verse", "keywords": [], "long_description": "Here are some key features of VIB Verse app\n- Immerse yourself in and experience a virtual banking city with numerous zones dedicated to separate products\n- Customize your avatar to appear in VIB Verse\n- Convenient and flexible movement\n- Easy to access with quick access\n- View card information\n- Find a card that suits your needs\n- Select cards and compare their features\n- View the visually engaging car with realistic dimensions \n- Calculate and receive the loan payment details\n- View VIB promotions and campaigns displayed on the street, in parks, and even in the sky\n- Leave contact information, VIB will call then\n", "short_description": "VIB Verse is the Virtual reality app - a product of Vietnam International Bank (VIB). Users need to use VR headset to immerse themselves in VIB city banking with numerous zones dedicated to separate products such as Auto Loan and Credit Card, as well as entertainment areas like beach, bar, park, and fountain. Users can customize their appearance by editing character's face, hair, clothes, and shoes, as well as selecting a nickname. Surely, VIB Verse app will provide a delightful experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vib.com.vn/i/en/vib-verse/chinh-sach-bao-mat", "developer_terms_of_service_url": null, "publisher_name": "VIB Bank", "support_website_url": null, "website_url": "https://www.vib.com.vn/i/en/vib-verse", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "vi"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7516763178449258"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "354458587384418"}]}, "baseline_offer": {"id": "354458587384418"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721644725, "status": "PUBLISHED", "id": "354458587384418"}]}, "liveChannel": {