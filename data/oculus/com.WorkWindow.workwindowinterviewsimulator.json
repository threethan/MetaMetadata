?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SH-y4Hy1U_wQ7kNvgGsqUGj&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYB8-V2L_aLjEiaNhHGDn67NHwwPaO4eYGcRPkzXRyOiDw&oe=675EB1D5"}, {"file_name": "Interview_01.png", "id": "558098475502894", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982460_558098478836227_2195642163881727498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bf_R_le38jQQ7kNvgGymsjO&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCam2px8Cs5S3Ss7AvwGAcfvY6KkfrNnzNjpDp-LzmU1w&oe=675ECE4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JOb INterview Simulator (4).png", "id": "371985591479423", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39035469_371985598146089_1320847157226308449_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fp1HyxdN2BkQ7kNvgHkx-ea&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCcbHaF2NCa_0i6G1tnB-_bcfUBUrJ4aBfP_uS6G6CA7A&oe=675ECDD0"}, "display_name": "Job Interview Simulator", "keywords": ["interview", "job", "interviewing", "simulator", "jobinterview"], "long_description": "Get comfortable with interview nerves in a low-pressure environment. Practice and receive interview feedback as many times as you need to boost confidence and succeed. \n\nCorrespond with HR, plan your travel to ensure you arrive on time, pick an outfit, catch the elevator, greet the receptionist, and ace the interview. Practice the whole process of job interviewing to accurately replicate the experience and prepare for the real thing. Get automated feedback across a range of metrics. \n\nIf you're an individual looking to use this app for personal use, then please visit app.workwindow.com.au to create an account. If you're looking to use this application in a commercial, or education setting then please visit www.workwindow.com.au to request a demonstration. \n\n*This application is a Paid app ", "short_description": "Simulate the experience of a Job Interview in Virtual Reality. Practice and hone your interviewing craft in a safe setting, so you can ace your next job interview!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.workwindow.com.au/privacy-policy", "developer_terms_of_service_url": "https://www.workwindow.com.au/terms-and-conditions", "publisher_name": "Work Window ", "support_website_url": "https://workwindow.atlassian.net/servicedesk/customer/portals", "website_url": "https://www.workwindow.com.au/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8474001332680724"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57566695_1853128728355683_2492449898506515379_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BX3puXEMyPAQ7kNvgEVR_AY&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCmsnX5Te7TnvQXRjg2YmJ_rfImgFKa0MQRSrDEsMflvg&oe=675EBB44"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Job Interview Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1653573600, "lastRevision": {"nodes": [{"id": "1112874389660352", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": 