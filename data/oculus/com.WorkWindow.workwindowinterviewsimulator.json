room_01.png", "id": "332281102302816", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036629_332281108969482_4697895475146858678_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WMpV1soigc4Q7kNvgEgEb_u&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOEqMm5HSCmnteRLERCp3uCEREZz5oL1kCW2mYlVR-qg&oe=67447041"}, {"file_name": "Lobby_02.png", "id": "694455891679972", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974862_694455895013305_5365825317235734912_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n69UDCdledMQ7kNvgEb2ESI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAs6bdEzZjwvQrSScvKak7K2UC_bJlroRvugT2tzdmqzw&oe=674453D5"}, {"file_name": "Interview_01.png", "id": "558098475502894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982460_558098478836227_2195642163881727498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K8DD5HrGUs8Q7kNvgHeA7Il&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA71MDgcrwkDQDKB5t6aLhyihggYNLphDoVjW-MxkuMKQ&oe=6744704E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JOb INterview Simulator (4).png", "id": "371985591479423", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035469_371985598146089_1320847157226308449_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FKvJeJ2LNFwQ7kNvgGCywg-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD220JJOcJXA2guJhW5j0Xlu4v85-JQYVrFMprqrcD0uQ&oe=67446FD0"}, "display_name": "Job Interview Simulator", "keywords": [], "long_description": "Proficient job interviewing craft is vital to attain the careers of our dreams. Unfortunately, it's difficult to practice this skill in a realistic way.\n\nThat's why we built the Job Interview Simulator. Simulate the entire interviewing process; from emailing HR before the interview, picking an outfit, arriving on time, catching the elevator, greeting the receptionist, and acing the interview. \n\nFeel the situational pressure of a Job Interview in an immersive virtual environent, and refine your interviewing craft with automated feedback. \n", "short_description": "Simulate the experience of a Job Interview in Virtual Reality. Practice and hone your interviewing craft in a safe setting, so you can ace your next job interview!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.workwindow.com.au/privacy-policy", "developer_terms_of_service_url": "https://www.workwindow.com.au/terms-and-conditions", "publisher_name": "Work Window ", "support_website_url": "https://support.workwindow.com.au/en", "website_url": "https://www.workwindow.com.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3271013276447340"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "825030802220866"}]}, "baseline_offer": {"id": "825030802220866"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1653573600, "status": "PUBLISHED", "id": "825030802220866"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7899571506790379", "version": "3.0.8"}, "id": "321439943420134", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5008217522592473", "is_concept": fal