ay.\n\nThat's why we built the Job Interview Simulator. Simulate the entire interviewing process; from emailing HR before the interview, picking an outfit, arriving on time, catching the elevator, greeting the receptionist, and acing the interview. \n\nFeel the situational pressure of a Job Interview in an immersive virtual environent, and refine your interviewing craft with automated feedback. \n", "short_description": "Simulate the experience of a Job Interview in Virtual Reality. Practice and hone your interviewing craft in a safe setting, so you can ace your next job interview!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.workwindow.com.au/privacy-policy", "developer_terms_of_service_url": "https://www.workwindow.com.au/terms-and-conditions", "publisher_name": "Work Window ", "support_website_url": "https://support.workwindow.com.au/en", "website_url": "https://www.workwindow.com.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3271013276447340"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "825030802220866"}]}, "baseline_offer": {"id": "825030802220866"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1653573600, "status": "PUBLISHED", "id": "825030802220866"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7899571506790379", "version": "3.0.8"}, "id": "321439943420134", "cha