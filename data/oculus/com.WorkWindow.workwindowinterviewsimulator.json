oom_01.png", "id": "332281102302816", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39036629_332281108969482_4697895475146858678_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SUZiQsscbeUQ7kNvgH1QiVS&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYARLAGOmr9r266zwvZlqWO7QqQcSIeqlgIK8-MYBfrPVg&oe=675ECE41"}, {"file_name": "Lobby_02.png", "id": "694455891679972", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974862_694455895013305_5365825317235734912_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SH-y4Hy1U_wQ7kNvgGsqUGj&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYB8-V2L_aLjEiaNhHGDn67NHwwPaO4eYGcRPkzXRyOiDw&oe=675EB1D5"}, {"file_name": "Interview_01.png", "id": "558098475502894", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982460_558098478836227_2195642163881727498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bf_R_le38jQQ7kNvgGymsjO&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCam2px8Cs5S3Ss7AvwGAcfvY6KkfrNnzNjpDp-LzmU1w&oe=675ECE4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JOb INterview Simulator (4).png", "id": "371985591479423", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39035469_371985598146089_1320847157226308449_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fp1HyxdN2BkQ7kNvgHkx-ea&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCcbHaF2NCa_0i6G1tnB-_bcfUBUrJ4aBfP_uS6G6CA7A&oe=675ECDD0"}, "display_name": "Job Interview Simulator", "keywords": [], "long_description": "Proficient job interviewing craft is vital to attain the careers of our dreams. Unfortunately, it's difficult to practice this skill in a realistic way.\n\nThat's why we built the Job Interview Simulator. Simulate the entire interviewing process; from emailing HR before the interview, picking an outfit, arriving on time, catching the elevator, greeting the receptionist, and acing the interview. \n\nFeel the situational pressure of a Job Interview in an immersive virtual 