content.oculuscdn.com/v/t64.5771-25/38974862_694455895013305_5365825317235734912_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvrqdGUeU-IQ7kNvgH5R7La&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWZ897cOVsFlQNi9iAFjr-K&oh=00_AYCpD2zPOnLeiJ908c0crwB8i51iDzE8n7rjtx03DG2Hxg&oe=66EBFF55"}, {"file_name": "Interview_01.png", "id": "558098475502894", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982460_558098478836227_2195642163881727498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VV_5pVzN9qcQ7kNvgFwcEqy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWZ897cOVsFlQNi9iAFjr-K&oh=00_AYDADkXUZIoEer3aWu6lJ3rzoztLW7VF8C49mVfkdJ4gZA&oe=66EC1BCE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JOb INterview Simulator (4).png", "id": "371985591479423", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035469_371985598146089_1320847157226308449_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gi7YZj5n79oQ7kNvgGgsqkC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWZ897cOVsFlQNi9iAFjr-K&oh=00_AYC_JoyYZkQu4pAEuBVxhPW01nnHwwlLv_nXc05wT854-A&oe=66EC1B50"}, "display_name": "Job Interview Simulator", "keywords": [], "long_description": "Get comfortable with interview nerves in a low-pressure environment. Practice and receive interview feedback as many times as you need to boost confidence and succeed. \n\nCorrespond with HR, plan your travel to ensure you arrive on time, pick an outfit, catch the elevator, greet the receptionist, and ace the interview. Practice the whole process of job interviewing to accurately replicate the experience and prepare for the real thing. Get automated feedback across a range of metrics. \n\nIf you're an individual looking to use this app for personal use, then please visit app.workwindow.com.au to create an account. If you're looking to use this application in a commercial, or education setting then please visit www.workwindow.com.au to request a demonstration. \n\n*This application is a Paid app ", "short_description": "Simulate the experience of a Job Interview in Virtual Reality. Practice and hone your interviewing craft in a safe setting, so you can ace your next job interview!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.workwindow.com.au/privacy-policy", "developer_terms_of_service_url": "https://www.workwindow.com.au/terms-and-conditions", "publisher_name": "Work Window ", "support_website_url": "https://workwindow.atlassian.net/servicedesk/customer/portals", "website_url": "https://www.workwindow.com.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}, {"id": "393222478507326"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "923206862097435"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566695_1853128728355683_2492449898506515379_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3cxcilyX7IMQ7kNvgESF4G_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWZ897cOVsFlQNi9iAFjr-K&oh=00_AYCUxu_w0IABaaWpEMAk7kwpe0Xdetnvl7GvdG4haL23BQ&oe=66EC08C4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Job Interview Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Business", "id": "421923165850360"}, {"topic_name": "Utilities"