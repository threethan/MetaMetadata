oom_01.png", "id": "332281102302816", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036629_332281108969482_4697895475146858678_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8DnEcNF-bTIQ7kNvgEU7Ztc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxjphHL1K_xJFr_KmQsEzxT3mpq90RWG4J0Aey-gNYgg&oe=6783B841"}, {"file_name": "Lobby_02.png", "id": "694455891679972", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974862_694455895013305_5365825317235734912_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NLHtkt_lrS4Q7kNvgGxlqC1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMK1r0uathdF5wV00MteZgV9dsoPWP5rzONmw7NgQxBg&oe=67839BD5"}, {"file_name": "Interview_01.png", "id": "558098475502894", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982460_558098478836227_2195642163881727498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o932U-oULWEQ7kNvgEsiZUA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqaizJa0dXpyVN9cbqLKfFqA6CA7TMUQCTxcVuEpuUng&oe=6783B84E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "JOb INterview Simulator (4).png", "id": "371985591479423", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035469_371985598146089_1320847157226308449_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bYEvIzQoD8UQ7kNvgFubrGr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1N-nSFHNCSGjUSIUW3wUWotDYZJx_OLYMXXXmqYz_BA&oe=6783B7D0"}, "display_name": "Job Interview Simulator", "keywords": [], "long_description": "Proficient job interviewing craft is vital to attain the careers of our dreams. Unfortunately, it's difficult to practice this skill in a realistic way.\n\nThat's why we built the Job Interview Simulator. Simulate the entire interviewing process; from emailing HR before the interview, picking an outfit, arriving on time, catching the elevator, greeting the receptionist, and acing the interview. \n\nFeel the situational pressure of a Job Interview in an immersive virtual 