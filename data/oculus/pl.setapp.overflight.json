"https://scontent.oculuscdn.com/v/t64.5771-25/12504684_1830772370552289_7764688889867927552_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9lcfOO7TivQQ7kNvgGzWuGm&_nc_ht=scontent.oculuscdn.com&_nc_gid=As-Q7pbp_UnxQO3IxKwCdJv&oh=00_AYCYmMv5u_Dn1BfKcE2Xt91GWKmu6JtCW07Wqiqk2d9gkw&oe=66F1675B"}, {"file_name": "migrated_image.png", "id": "529110084653372", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427628_2018543371727636_1353766519103815680_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9NAXOjsJl1UQ7kNvgE60w1v&_nc_ht=scontent.oculuscdn.com&_nc_gid=As-Q7pbp_UnxQO3IxKwCdJv&oh=00_AYCNbhf4p3iK3LrMd2xGQHFrZoXoN-YBuY16Y2y5jtoUMw&oe=66F167A6"}, {"file_name": "migrated_image.png", "id": "336715987294365", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12680484_548941498839373_7170827356737634304_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I52LPP8y11gQ7kNvgE_BrpR&_nc_ht=scontent.oculuscdn.com&_nc_gid=As-Q7pbp_UnxQO3IxKwCdJv&oh=00_AYDPV_5rTws6K9NhGyGOKxwmxle87cCByGP0HDe53PlG9w&oe=66F15027"}, {"file_name": "migrated_image.png", "id": "234957094297374", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_175673583092453_2324535449915228160_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SDaSCLelJfMQ7kNvgEMIY81&_nc_ht=scontent.oculuscdn.com&_nc_gid=As-Q7pbp_UnxQO3IxKwCdJv&oh=00_AYDp4jRPy1q4kToSa6jvmPWlRIgs1n3fkDoQA7Gg8qdlZw&oe=66F15445"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Overflight", "keywords": ["plane", "dogfighter", "shooting", "simulator", "simulation"], "long_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis. \n\nOverflight Campaign will take you to the uncharted lands of South America to engage in a conflict that can define the final results of World War II. Immerse yourself in a unique story-driven VR experience with fully-fledged characters, intense dogfighting action and take part in the most breathtaking missions ever encountered on Mobile VR.\n\nAfter you save the world, enjoy Overflight for hours in the multiplayer mode. Here, the game changes into a semi-realistic VR dogfight with dynamic action and constant adrenaline rush. Play with your friends or challenge the community! \n\nSee you in the skies of Overflight!", "short_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis."}]}, "developer_name": "Gamedust", "developer_privacy_policy_url": "https://gamedust.co/news/privacy", "developer_terms_of_service_url": "https://gamedust.co/news/privacy", "publisher_name": "Gamedust Sp. z o.o.", "support_website_url": null, "website_url": "http://gamedust.co/overflight", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "FLYING", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "1656367071422468"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.ocul