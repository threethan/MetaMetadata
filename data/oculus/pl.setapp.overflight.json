552289_7764688889867927552_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PuA6Y2gOnZYQ7kNvgEyH3As&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDIqlAYf-VAFOAWS2WU8pJ9j7xhkF11PYO_BD7iJvMUqA&oe=672774DB"}, {"file_name": "migrated_image.png", "id": "529110084653372", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12427628_2018543371727636_1353766519103815680_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fR7CcAgrBSIQ7kNvgFrUs5M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhUz6LsQqR5jml4WQ45iwA2lKNsU9PXDKKmETTbcT9vg&oe=67277526"}, {"file_name": "migrated_image.png", "id": "336715987294365", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12680484_548941498839373_7170827356737634304_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iLnZKJ8wyrUQ7kNvgEaJ94t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdF0EjsCMu4QbwzGrtnwNdDmKAWhH_U_E1L32GpgvB8g&oe=67275DA7"}, {"file_name": "migrated_image.png", "id": "234957094297374", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138999_175673583092453_2324535449915228160_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rxwS4SOkD9YQ7kNvgH5CX1Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnbz8lO6p5ntt0o_dB8JOkgiMBNQoRbVrHFnAJabNOWA&oe=672761C5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Overflight", "keywords": ["plane", "dogfighter", "shooting", "simulator", "simulation"], "long_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis. \n\nOverflight Campaign will take you to the uncharted lands of South America to engage in a conflict that can define the final results of World War II. Immerse yourself in a unique story-driven VR experience with fully-fledged characters, intense dogfighting action and take part in the most breathtaking missions ever encountered on Mobile VR.\n\nAfter you save the world, enjoy Overflight for hours in the multiplayer mode. Here, the game changes into a semi-realistic VR dogfight with dynamic action and constant adrenaline rush. Play with your friends or challenge the community! \n\nSee you in the skies of Overflight!", "short_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis."}]}, "developer_name": "Gamedust", "developer_privacy_policy_url": "https://gamedust.co/news/privacy", "developer_terms_of_service_url": "https://gamedust.co/news/privacy", "publisher_name": "Gamedust Sp. z o.o.", "support_website_url": null, "website_url": "http://gamedust.co/overflight", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "FLYING", "SHOOTER", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "1656367071422468"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12386401_1620777384702632_5070003748110073856_n.png?stp=dst-png_s360x360&_nc_