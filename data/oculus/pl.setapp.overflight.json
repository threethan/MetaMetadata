552289_7764688889867927552_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wp3SfpWeAcwQ7kNvgGaf0yV&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA0SxttFpt_2DlVhBVYEP2JQfLXL8uGCJT_iptk9wUo3A&oe=6787B25B"}, {"file_name": "migrated_image.png", "id": "529110084653372", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/12427628_2018543371727636_1353766519103815680_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W0IKuYnBaDkQ7kNvgHyhcS-&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAZ9TQ6x2KaNCZSspaREpHvgGr9_FbFM7E7N79fWdw51g&oe=6787B2A6"}, {"file_name": "migrated_image.png", "id": "336715987294365", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/12680484_548941498839373_7170827356737634304_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iwZ1X2SqksgQ7kNvgFneBNq&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAbOOy0alb9mpiF99LGJIt_1Xj5-0j2-mCeaUhwGdBIqQ&oe=67879B27"}, {"file_name": "migrated_image.png", "id": "234957094297374", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/12138999_175673583092453_2324535449915228160_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYI2q9jis-YQ7kNvgGk8Oer&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAzrbBEzriPUUO4S-3-hcfvJoH4MIgizYeQ6qyxd6eqRg&oe=67879F45"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Overflight", "keywords": ["plane", "dogfighter", "shooting", "simulator", "simulation"], "long_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis. \n\nOverflight Campaign will take you to the uncharted lands of South America to engage in a conflict that can define the final results of World War II. Immerse yourself in a unique story-driven VR experience with fully-fledged characters, intense dogfighting action and take part in the most breathtaking missions ever encountered on Mobile VR.\n\nAfter you save the world, enjoy Overflight for hours in the multiplayer mode. Here, the game changes into a semi-realistic VR dogfight with dynamic action and constant adrenaline rush. Play with your friends or challenge the community! \n\nSee you in the skies of Overflight!", "short_description": "Unveil the truth about unknown heroes fighting in the aftermath of World War II.\n\nThe war is finally over. Skilled pilots looking for new occupation have spread all over the world. You are one of them, a mercenary, smuggling a mysterious package for an unknown, powerful client. Things go south when you realize that the package contains fake documents for fleeing Nazis."}]}, "developer_name": "Gamedust", "developer_privacy_policy_url": "https://gamedust.co/news/privacy", "developer_terms_of_service_url": "https://gamedust.co/news/privacy", "publisher_name": "Gamedust Sp. z o.o.", "support_website_url": null, "website_url": "http://gamedust.co/overflight", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "FLYING", "SHOOTER", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "1656367071422468"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/12386401_1620777384702632_5070003748110073856_n.png?stp=dst-png_s360x360&_nc_c