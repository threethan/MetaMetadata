1955123398_738398746983768786_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=42dPXAEexLIQ7kNvgEYzwEj&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0vXiTEkwrr6EKzGTId-FB&oh=00_AYAIigV2_vVzbgyBeDK77QOMhb68avs2mouJ4cyVCqC5yA&oe=66D30336"}, {"file_name": "startMenu.png", "id": "423322422225187", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031391_423322425558520_2333985987481995841_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EAF9fa0EY-EQ7kNvgEgH9nq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw0vXiTEkwrr6EKzGTId-FB&oh=00_AYB0Cnz8hmznwnCXGGyaTINvHVxarDExBWNqFqp26PhKKA&oe=66D30E3E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SuturingVR", "keywords": [], "long_description": "SuturingVR is primarily designed to be a highly immersive game that uses the unique aspects of virtual reality while also taking into consideration design constraints inherently imposed by the use-case situation: a child will primarily be using this before and during routine medical procedures, limited in motion in their hospital bed. Limited FOV, simple and intuitive controls, fluid motion, calming music, and immersive environments are all crucial to keeping the child comfortable.\n\nThis application is for use as a VR Distraction-Based Therapy tool in the study \"Feasibility and Acceptability of Virtual Reality to Reduce Perceived Pain and Anxiety Among Patients within a Hospital System\"", "short_description": "VR Distraction-Based Therapy"}]}, "developer_name": null, "developer_privacy_policy_url": "https://suturingvr.github.io/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Dream Team Engineering", "support_website_url": null, "website_url": "https://www.ufdreamteam.org/dream-team-engineering", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "RELAXATION_MEDITATION", "UTILITY"], "has_in_app_ads": fal