453260688321293_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1w5JbM8AjrgQ7kNvgFV0nN-&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_Y8545XLpfxrhKGZ9NC2NcDJaaEvP7rLmrCcxdLgp7w&oe=66F14E58"}, {"file_name": "Screenshot5.png", "id": "550686242671123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_550686246004456_5555286399400016975_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMv8TnjPwzAQ7kNvgGvFmJ3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBxEdB2tQkS3DHwOsMYcGkBI2ylm78htoJe0gG7Ip6kzg&oe=66F14782"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "577920866668319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569483_577920870001652_682900588683931991_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pm6JSbh1tGYQ7kNvgFteMUb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAD_Hbvw5Y2JMB0JHJ3vvQ61I7Ps-ifBcSoAHYGiRZiyA&oe=66F142C9"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "tir", "fps", "combat"], "long_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Avancez dans une m\u00e9gatour dystopique.\n\nTraversez des niveaux g\u00e9n\u00e9r\u00e9s al\u00e9atoirement en utilisant explosifs, armes de corps \u00e0 corps, armes \u00e0 feu et augmentations pour \u00e9liminer les machines.\n\nCombats vifs : \nUtilisez un large choix d\u2019armes, d\u2019outils et d\u2019explosifs. D\u00e9couvrez des passages secrets. Adaptez votre comportement en fonction de vos ennemis et ciblez leurs points faibles. Traversez des \u00e9tendues de lave en tyrolienne et franchissez les couloirs \u00e0 l\u2019aide d\u2019un grappin tout en abattant les machines.\n\nAugmentations et am\u00e9liorations : \nTrouvez des puces d\u2019augmentation. Dotez vos armes d\u2019un effet IEM, augmentez votre force et votre vitesse, ou siphonnez l\u2019\u00e9nergie de vos ennemis.\n\nContenus d\u00e9blocables et progression :\nFranchissez de nouvelles \u00e9tapes au fil de votre progression. Suivez vos statistiques. R\u00e9pertoriez les messages laiss\u00e9s par vos pr\u00e9d\u00e9cesseurs. D\u00e9couvrez de nouveaux effets pour vos armes, et combinez les augmentations.\n", "short_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Dans une m\u00e9gatour dystopique, vous devez constamment vous adapter \u00e0 un environnement sans piti\u00e9 et une action au rythme effr\u00e9n\u00e9.\n"}, {"images": {"nodes": [{"file_name": "CoverImageLandscape.png", "id": "616500419733536", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035340_616500423066869_3483619644102186279_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zYwnwidDSBwQ7kNvgGWpDHZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnE_Q91wJRs5n5aKgEKK5bNlfMfNJ5ld5RAsP0BfWjKA&oe=66F162AE"}, {"file_name": "CoverImageMiniLandscape.png", "id": "596253448403194", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_596253455069860_6720339828695346593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DAMb1GA4HfsQ7kNvgGYoOxS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDj77b4EhipR2vXoMpWDVlzTsIH19gkBsnBTBCkxR9sQg&oe=66F15077"}, {"file_name": "CoverImageSquare.png", "id": "586332725889641", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031501_586332729222974_107555271491119635_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1_Kt5sEXmjkQ7kNvgFJvZID&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLEKjagukgII-Uy_nQBCMARkZ3QFabzh9Da13NnsAZwA&oe=66F13CCA"}, {"file_name": "Logo.png", "id": "395340675529366", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_395340682196032_6964156802148439849_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bf1TmXjfVo4Q7kNvgHq9P_t&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3eRIl_SJz4iRbFatfa7zxqPMoi3bOk7McIXWsQhoJPg&oe=66F14C55"}, {"file_name": "Icon.png", "id": "390235939285279", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_390235949285278_3843481588384649834_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02PUafInk4oQ7kNvgFrrliU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCViWV81VTbYxy8p-NCEXqTPBA6KcUzH6RUSENmI6qBAw&oe=66F16CC5"}, {"file_name": "CoverImagePortrait.png", "id": "383584229965844", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_383584233299177_6771641515237035930_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekVn_hG9tqgQ7kNvgEbOFuJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwcrjMfH0nYlW81AfxQPLFiZH5ADEF_FrzNiHTNhhpMw&oe=66F13852"}, {"file_name": "CoverImageHero.png", "id": "247768457272242", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_247768463938908_2187039554841960072_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcMt5fik_oMQ7kNvgHqg-f6&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNtnL_WLERq2uFI7wSKRxtEWgOWA2utrFJuKNrqrrFOA&oe=66F151AE"}]}, "id": "836351943603624", "locale": "de_DE", "screenshots": [{"file_name": "Screenshot1.png", "id": "597112954802621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_597112958135954_4619942593222797157_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NDJJikHXnx8Q7kNvgFrNU7T&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqn2NMDviqaICqpBSLQcoUYAQbfKonMn9djzLK2Re9zw&oe=66F166CD"}, {"file_name": "Screenshot2.png", "id": "898198597759981", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_898198601093314_7265353852158285013_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-1Q1xp4hAYQ7kNvgFwLmk3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDlupYvNW_wnoolgeNre5lhFwuxphndfQtAefq0GV-Qlw&oe=66F1426A"}, {"file_name": "Screenshot3.png", "id": "971396676759350", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001713_971396683426016_126507528010253971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d65Bp4pwW00Q7kNvgEq42fM&_nc_ht=scontent.oculuscdn.com&oh=00_AYACErAQd0On9V-FrCGml97przENbCL9q0H2q0yw4JCX-A&oe=66F147A1"}, {"file_name": "Screenshot4.png", "id": "606190327044171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_606190330377504_1844159778777880661_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bFZt7yPDL7sQ7kNvgFxxHaR&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVxuQWaODA2y9Fc-5t2NDa8yGXVcRm8ZuLpNgtlvIqAQ&oe=66F16266"}, {"file_name": "Screenshot5.png", "id": "414076387104290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_414076390437623_7171154147182914860_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pPle5-frFoEQ7kNvgGkh4FM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCH032foQEQVZLOccQMqf2apcBnbLct8HmlmBzUKFC9Og&oe=66F14AE9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "277775003978784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_277775007312117_7307744386116844089_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3eR7TTVja6sQ7kNvgFIUpoS&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOxjoRpFfNdBr-hPr7zxLKfkNTJqLkcdyug8AL-4JwtQ&oe=66F1510D"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "kampf"], "long_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n\nSchalte die Maschinen, die dich jagen, mit Sprengstoffen, Waffen, Gewehren und Upgrades aus und k\u00e4mpfe dich durch prozedural generierte Levels.\n\nAgiler Kampf \u2013\nSetze Waffen, Werkzeuge und Sprengstoffe gegen Feindtrupps ein. Sprenge dich durch W\u00e4nde, entdecke Geheimnisse, ziele auf Schwachstellen und passe dich dem Verhalten deines Gegners an. Springe \u00fcber Lava, hangle dich mit Greifhaken durch G\u00e4nge und schie\u00dfe Maschinen-Sicherheitstrupps ab.\n\nUpgrades und Verbesserungen \u2013\nEntdecke Upgrade-Chips und verbessere deine F\u00e4higkeiten. Erhalte EMP-Effekte auf Waffen, erh\u00f6he St\u00e4rke und Tempo, sauge Energie von Feinden ab.\n\nFreischaltbare Items und Fortschritt \u2013\nErreiche Meilensteine, je weiter du kommst. Verfolge deine Statistiken und K\u00e4mpfe, katalogisiere Nachrichten von jenen vor dir. Entdecke neue Waffeneffekte, kombiniere Upgrades.\n", "short_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHeroJP.png", "id": "281055800511489", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_281055803844822_5004621190288595314_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P64x3VCYyBsQ7kNvgEPHVuO&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_v56DPzp0jOeEHns8NdXyAIGgqy-vJBGyNb5hM_KEBA&oe=66F16116"}, {"file_name": "CoverImageMiniLandscapeJP.png", "id": "1858552550973548", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_1858552554306881_9025508674624382891_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ON5JpV5dmgQ7kNvgEc10ax&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrW4VWQshTGi6s9r5xA5AZ9QqHcjO5J8wD-rZfTS7Q_A&oe=66F13925"}, {"file_name": "CoverImageLandscapeJP.png", "id": "1280641505712102", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569445_1280641512378768_7516279709291076340_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N_pSqB4plE4Q7kNvgG_Ssoq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnpo8S5TfWrazJqNqy2GLc17vMV08s8u780pLnn6BhQA&oe=66F163A4"}, {"file_name": "IconJP.png", "id": "1238336366627447", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_1238336369960780_7056998765223432835_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OSdJdtZR83oQ7kNvgGB_r8L&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzZAFgGxP0AOa--5Grtt_CH-C2GhuKJt727WWbzareGg&oe=66F1