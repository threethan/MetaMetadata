.com/v/t64.5771-25/39003241_369426484830931_3192786912307997496_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xj9TRYTBKSYQ7kNvgFdUXe3&_nc_ht=scontent.oculuscdn.com&oh=00_AYADfmwlCUV4-t7jDkfex4Df2mU96X1hRz0YKRnTmy8jFw&oe=66EE96F4"}, {"file_name": "Screenshot3.png", "id": "446950453304504", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035406_446950456637837_6166095464791538498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kydtsfjxGAYQ7kNvgGmHexY&_nc_ht=scontent.oculuscdn.com&oh=00_AYALVaYepdLvxKQFnT_4ALS1660BQ9k78wZvlR4rmrJvZg&oe=66EEB67C"}, {"file_name": "Screenshot4.png", "id": "839063753463255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974538_839063756796588_4319456000214463966_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cuni_mgM5xAQ7kNvgFIg8aY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDE5Ge6lT2YsWwy7bkkxGs3QkoZKUIaqAZNyxgP9RUo-A&oe=66EE9381"}, {"file_name": "Screenshot5.png", "id": "1262860397460495", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_1262860400793828_1181162491891081469_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDWUsnDUnw8Q7kNvgHUdG1G&_nc_ht=scontent.oculuscdn.com&oh=00_AYAr9Z4qaqL6TydleYKJ80AXJa1ZSyo-pIzLAJuMTtoUNg&oe=66EE9FF1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscapeKR.png", "id": "1305135276608103", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_1305135286608102_1282784577749709177_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSuhGqewPDEQ7kNvgGg-Kim&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdvsahY80slgHRKPsZKp7yZhlhvwm10Fj-4XkuzZd5FQ&oe=66EEBFB4"}, "display_name": "\uc2a4\uc717 \uc11c\ub80c\ub354", "keywords": ["\ub85c\uadf8\ub77c\uc774\ud2b8", "\ub85c\uadf8\ub77c\uc774\ud06c", "\uc288\ud305", "FPS", "\uc804\ud22c"], "long_description": "<\uc2a4\uc717 \uc11c\ub80c\ub354>\ub294 \ub514\uc2a4\ud1a0\ud53c\uc544 \uba54\uac00\ud0c0\uc6cc\ub97c \ubc30\uacbd\uc73c\ub85c \ubb34\uc790\ube44\ud558\uace0 \ube60\ub974\uac8c \uc9c4\ud589\ub418\uba70 \uc561\uc158\uc774 \uac00\ub4dd\ud55c \ud658\uacbd\uc5d0 \uc801\uc751\ud574\ub098\uac00\ub294 \ub85c\uadf8\ub77c\uc774\ud06c \uc288\ud305 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\n\ud3ed\ubc1c\ubb3c, \uadfc\uc811 \ubb34\uae30, \ucd1d \ubc0f \uc5c5\uadf8\ub808\uc774\ub4dc\ub97c \uc774\uc6a9\ud574 \uc54c\uace0\ub9ac\uc998\uc5d0 \ub530\ub77c \uc0dd\uc131\ub418\ub294 \uac01 \uce35\uc5d0\uc11c \uc5ec\ub7ec\ubd84\uc744 \ucad3\ub294 \uae30\uacc4\ub97c \ucc98\uce58\ud558\uace0 \uc815\uc0c1\uae4c\uc9c0 \uc2f8\uc6cc\ub098\uac00\uc138\uc694.\n\n\ubbfc\ucca9\ud55c \uc804\ud22c - \n\uc5ec\ub7ec \uac00\uc9c0 \ubb34\uae30, \ub3c4\uad6c \ubc0f \ud3ed\ubc1c\ubb3c\uc744 \uc774\uc6a9\ud574 \uc801\uad70\uc744 \uc2e0\uc18d\ud558\uac8c \ubb3c\ub9ac\uce58\uc138\uc694. \ubcbd\uc744 \ud3ed\ud30c\ud574 \uc228\uaca8\uc9c4 \ube44\ubc00\uc744 \ud30c\ud5e4\uce58\uace0, \uc57d\uc810\uc744 \ub178\ub824 \uc801\uc758 \uc6c0\uc9c1\uc784\uc5d0 \ub300\uc751\ud558\uc138\uc694. \uc9d1\ub77c\uc778\uc73c\ub85c \uc6a9\uc554\uc744 \ub118\uace0, \uadf8\ub798\ud50c \ud6c5\uc73c\ub85c \ud1b5\ub85c\ub97c \uac00\ub85c\uc9c8\ub7ec \uae30\uacc4 \ubcf4\uc548 \ubd80\ub300\ub97c \ucd1d\uc73c\ub85c \uaca9\ucd94\ud558\uc138\uc694.\n\n\uc5c5\uadf8\ub808\uc774\ub4dc \ubc0f \uae30\ub2a5 \ud5a5\uc0c1 - \n\ub2a5\ub825\uc744 \ud5a5\uc0c1\ud558\ub294 \uc5c5\uadf8\ub808\uc774\ub4dc \uce69\uc744 \ucc3e\uc544\ubcf4\uc138\uc694. \ubb34\uae30\uc5d0 EMP \ud6a8\uacfc\ub97c \ubd80\uc5ec\ud558\uace0, \ud798\uacfc \uc18d\ub3c4\ub97c \ub192\uc774\uba70, \uc801\uc5d0\uac8c\uc11c \uc5d0\ub108\uc9c0\ub97c \ud761\uc218\ud558\uc138\uc694.\n\n\uc7a0\uae08 \ud574\uc81c \ucf58\ud150\uce20 \ubc0f \uc9c4\ud589\ub3c4 -\n\uc55e\uc73c\ub85c \uc9c4\ud589\ud574\ub098\uac00\uba74\uc11c \uc0c8\ub85c\uc6b4 \ub9c8\uc77c\uc2a4\ud1a4\uc744 \ub2ec\uc131\ud558\uc138\uc694. \uac1c\uc778 \ud1b5\uacc4 \ubc0f \uc801\uacfc\uc758 \uad50\uc804, \uba3c\uc800 \uc654\ub358 \ud50c\ub808\uc774\uc5b4\ub4e4\uc758 \uce74\ud0c8\ub85c\uadf8 \uba54\uc2dc\uc9c0\ub97c \ud655\uc778\ud574\ubcf4\uc138\uc694. \uc0c8\ub85c\uc6b4 \ubb34\uae30 \ud6a8\uacfc\ub97c \uc5bb\uace0 \uc5c5\uadf8\ub808\uc774\ub4dc\ub97c \uc870\ud569\ud574\ubcf4\uc138\uc694.\n", "short_description": "<\uc2a4\uc717 \uc11c\ub80c\ub354>\ub294 \ub514\uc2a4\ud1a0\ud53c\uc544 \uba54\uac00\ud0c0\uc6cc\ub97c \ubc30\uacbd\uc73c\ub85c \ubb34\uc790\ube44\ud558\uace0 \ube60\ub974\uac8c \uc9c4\ud589\ub418\uba70 \uc561\uc158\uc774 \uac00\ub4dd\ud55c \ud658\uacbd\uc5d0 \uc801\uc751\ud574\ub098\uac00\ub294 \ub85c\uadf8\ub77c\uc774\ud06c \uc288\ud305 \uac8c\uc784\uc785\ub2c8\ub2e4.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortrait.png", "id": "4223583834356812", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_4223583847690144_3969148212653210449_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HapcA0nUhwgQ7kNvgGTvrRA&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5kyB-4doRzy9b2tobfls94HQ5D1Z14IUPh5ETP9ZJcQ&oe=66EEA002"}, {"file_name": "CoverImageMiniLandscape.png", "id": "1797844770402159", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1797844773735492_1851471833968509009_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LA1f7-x6EpAQ7kNvgEfbuDy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsjhJbh0jers-4khmdSI92IcLZSbiDaRusslJtQIE8rg&oe=66EEA747"}, {"file_name": "Icon.png", "id": "1657555244443849", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_1657555247777182_1306060781361412918_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gqPNb7oNIXYQ7kNvgGjSfwq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmFIz-8jE3UAZpp-JRjn5c9Mds7yRZ3MjWQF35pvnFgA&oe=66EEA131"}, {"file_name": "CoverImageSquare.png", "id": "580910053051674", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86659802_580910056385007_3841875226947026636_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RfU5B0gSacsQ7kNvgGtAD5o&_nc_ht=scontent.oculuscdn.com&o