489726196039915113_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zu0hw5DEb1oQ7kNvgFbnboO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUQ44eFxAx-Zxo3Y2xWd31O1Dk2NAXsff6OE0jeuc55g&oe=66EE92AA"}, {"file_name": "Screenshot 3 1440.png", "id": "439146270861179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_439146274194512_3265374891474992569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v7KKosVMIJsQ7kNvgH-jdBb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvyOOyGy6AzBxMkLR8dT_TPRgSiX9MzA4LE6pWKs5wUw&oe=66EE9C3B"}, {"file_name": "7 1440.png", "id": "587557329050301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_587557332383634_613148445108165191_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fEdM9Q1ZSnsQ7kNvgHI_yMh&_nc_ht=scontent.oculuscdn.com&oh=00_AYD10ubOV6lORP5gK7vtlQbnW1KvEbz7YwM5ic4Qbpih1A&oe=66EEB069"}, {"file_name": "8 1440.png", "id": "278301000580045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_278301003913378_4961165780702200385_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hd1PgpF8eooQ7kNvgEQoS1y&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0s6b8IOlwPbcRVO3UJ5yTJz7UTV_aWWVfdSYF04Vm2Q&oe=66EEB156"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1632100410468901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1632100413802234_1726393786771260074_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XkX2takHvfkQ7kNvgEkOCTX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBualYHPFDgy_ZVKA8J7QSiYOsaRz4sNbSAlMDVrlW4hg&oe=66EEC467"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "combat"], "long_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n\nUse explosives, melee weapons, guns and upgrades to take down the machines hunting you as you fight your way to the summit through procedurally-generated levels.\n\nAgile Combat - \nUse an array of weapons, tools and explosives to dispatch enemy forces. Blast through walls to uncover secrets, aim for weak points and adapt to the behaviour of your enemy. Zipline across lava, grapple hook through corridors as you gun down machine security forces.\n\nUpgrades and Enhancements - \nDiscover upgrade chips that can heighten your abilities. Gain EMP effects on your weapons, increase your strength and speed, siphon energy from your enemies.\n\nUnlockables and Progression -\nAchieve new milestones the further you advance. Track your personal stats and enemy encounters, catalog messages from those who came before you. Discover new weapon effects, combine upgrades.\n", "short_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHero.png", "id": "115634340767631", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_115634344100964_4698064246001205638_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ARMAVl7p4EQ7kNvgEon0VI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDX4foyyK1u3ogxJ5T8IzWsDNrVCh3Wz1Ob49gGrvNfAQ&oe=66EEA250"}, {"file_name": "CoverImageMiniLandscape.png", "id": "4531926600196916", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_4531926603530249_6962821853766922858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q7dVRz7uc0EQ7kNvgHFAkdM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJ2H0vtA07ALOqMaZfRkMyXwP0weX9TsakLBNzClK95A&oe=66EEBB76"}, {"file_name": "CoverImagePortrait.png", "id": "606660833673980", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_606660837007313_7189004430715192244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMFiqjRo-DoQ7kNvgE5jVi2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvf2BwdSiaLqqZFZe6qRF0dOgNCYH0E1m66367IV9PWA&oe=66EEA648"}, {"file_name": "CoverImageLandscape.png", "id": "594329141601992", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_594329144935325_3798676971550141837_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VM7P9zpMmqwQ7kNvgED7pFR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAm9WIubfuPdhycDPNxbkEiapkJsKAE3uOs1Fivj3yCCg&oe=66EE91A4"}, {"file_name": "CoverImageSquare.png", "id": "559777915269063", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_559777918602396_6224991975423925847_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQ8b1HOWRlQQ7kNvgH-i2Aw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQWr-YBtUj_cCzgdipVckOILycJw3jYHEQQ5C5jDvrEA&oe=66EEBFA1"}, {"file_name": "Logo.png", "id": "443595463754143", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_443595467087476_7978473456414610396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IjFbkinS2gUQ7kNvgEgmgWl&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5vBfddm69nwh_LZzvI-1dCl7W1hwDB7g8YIckgpJUQQ&oe=66EEA028"}, {"file_name": "Icon.png", "id": "350115806796631", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_350115813463297_488826976810587709_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABjgWSdpff4Q7kNvgFdGR3I&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEFRLOd1q5F5Lfg_ZQ2IZVGJ1ul4ltZfIURXEK-1Dipg&oe=66EEC595"}]}, "id": "2959089641073973", "locale": "es_LA", "screenshots": [{"file_name": "Screenshot1.png", "id": "149961060659239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_149961063992572_3317862938453630568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03KDCviQr6oQ7kNvgGy6pcJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYABHmgUSTWPuk7Gngb8Uf4IuKjN6pQizVkCJXLY3YJLdg&oe=66EE92D4"}, {"file_name": "Screenshot2.png", "id": "854916028748159", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_854916035414825_1482957548994953661_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xK2qYHfDG8sQ7kNvgHXgoCj&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6RPGarj2Mmoef_PNB0LCgmtEQX-aZHNhsh6rWO8e34w&oe=66EE9B48"}, {"file_name": "Screenshot3.png", "id": "3880899298676771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_3880899312010103_2182482223037715146_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STijH0U4FrAQ7kNvgFlAkhq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzl2f53uZGzbn-vkOEaBN_cZF9-KMjpKDzECqHao1l-A&oe=66EEB916"}, {"file_name": "Screenshot4.png", "id": "632541957738951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570295_632541961072284_9041265518534613224_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZI2QTsgfrUQ7kNvgE-9Yi4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqvcqzc-p_46O-E7fwAV2mS8QEsUSGq9YNTIKNXIG0WA&oe=66EEA97E"}, {"file_name": "Screenshot5.png", "id": "3118602568465145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_3118602571798478_5241911405837164837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxbHEeHvj0wQ7kNvgGPFsqw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdyQLi4e2ULTkmWVYnaONIQvm0f0CFbL2leg0NwPaRvg&oe=66EEA625"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "3304918962966230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_3304918969632896_7921060189846060168_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fWXrPQr0esQ7kNvgGSPL9a&_nc_ht=scontent.oculuscdn.com&oh=00_AYDah-PgQZ2Fwzynwc-VeIj0JEzYiEaCaZcJaMtEtqiEtg&oe=66EE915E"}, "display_name": "Sweet Surrender", "keywords": ["roguelike", "disparos", "fps", "combate"], "long_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n\nUsa explosivos, armas de mano, pistolas y actualizaciones para derribar las m\u00e1quinas que te persiguen mientras luchas por llegar a la cima pasando los niveles generados por procedimientos.\n\nCombate \u00e1gil: \nusa una variedad de armas, herramientas y explosivos para eliminar las fuerzas enemigas. Atraviesa las paredes con explosiones para descubrir secretos, apunta a los puntos d\u00e9biles y ad\u00e1ptate al comportamiento de tus enemigos. Cruza r\u00edos de lava en tirolesa, usa arpeos para trepar por los corredores mientras reduces a disparos las fuerzas de seguridad de las m\u00e1quinas.\n\nActualizaciones y mejoras: \ndescubre los chips de actualizaci\u00f3n que pueden elevar tus habilidades. Obt\u00e9n efectos EMP para tus armas, aumenta tu fuerza y velocidad, extrae la energ\u00eda de tus enemigos.\n", "short_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortraitKR.png", "id": "1120975665100000", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_1120975668433333_1316925696992055825_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NCMXUHRVHV4Q7kNvgFqpNoT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkaMFcT6pL8k672glqq22x8GPZbxkHjVjdEIzoraTm4g&oe=66EEABA2"}, {"file_name": "CoverImageSquareKR.png", "id": "1038622706922441", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_1038622710255774_8643929694250534637_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bb4YEEbNmugQ7kNvgEAO2AJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2aBMt_E2SuIrUIVuUum_Ctd1TRsz_dG5KrvLwMwqV0A&oe=66EE9D72"}, {"file_name": "CoverImageMiniLandscapeKR.png", "id": "979162109598833", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_979162116265499_1764438849254555913_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nCGhiD6Gi7gQ7kNvgFAQGSa&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6V2w8HSfRGV