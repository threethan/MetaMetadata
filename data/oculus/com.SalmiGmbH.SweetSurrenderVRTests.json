453260688321293_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxtph-Wvem8Q7kNvgHGwR5U&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5aLfQmZtb0d34SXPw75XPt2zUSv4R1oFPGZL5fW4TqA&oe=66EEAB58"}, {"file_name": "Screenshot5.png", "id": "550686242671123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_550686246004456_5555286399400016975_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ppZtr0GuajEQ7kNvgE12lji&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0eNOC_94tNRGpyk9XpWnBE01Gx0sLELU3sLzdVXBhxg&oe=66EEA482"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "577920866668319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569483_577920870001652_682900588683931991_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4UPOZoQZBgQ7kNvgH1t-mQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDt_UnaG1VnYQBIk5TG401_O6usDW0AiaOXI45xfS7quw&oe=66EE9FC9"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "tir", "fps", "combat"], "long_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Avancez dans une m\u00e9gatour dystopique.\n\nTraversez des niveaux g\u00e9n\u00e9r\u00e9s al\u00e9atoirement en utilisant explosifs, armes de corps \u00e0 corps, armes \u00e0 feu et augmentations pour \u00e9liminer les machines.\n\nCombats vifs : \nUtilisez un large choix d\u2019armes, d\u2019outils et d\u2019explosifs. D\u00e9couvrez des passages secrets. Adaptez votre comportement en fonction de vos ennemis et ciblez leurs points faibles. Traversez des \u00e9tendues de lave en tyrolienne et franchissez les couloirs \u00e0 l\u2019aide d\u2019un grappin tout en abattant les machines.\n\nAugmentations et am\u00e9liorations : \nTrouvez des puces d\u2019augmentation. Dotez vos armes d\u2019un effet IEM, augmentez votre force et votre vitesse, ou siphonnez l\u2019\u00e9nergie de vos ennemis.\n\nContenus d\u00e9blocables et progression :\nFranchissez de nouvelles \u00e9tapes au fil de votre progression. Suivez vos statistiques. R\u00e9pertoriez les messages laiss\u00e9s par vos pr\u00e9d\u00e9cesseurs. D\u00e9couvrez de nouveaux effets pour vos armes, et combinez les augmentations.\n", "short_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Dans une m\u00e9gatour dystopique, vous devez constamment vous adapter \u00e0 un environnement sans piti\u00e9 et une action au rythme effr\u00e9n\u00e9.\n"}, {"images": {"nodes": [{"file_name": "CoverImageLandscape.png", "id": "616500419733536", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035340_616500423066869_3483619644102186279_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zwDxTXpnmjIQ7kNvgGMjLvM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUZ71Z0hy_5KLn6sSPN2hMXFkxnVVkh0oUEfERTdWAaQ&oe=66EEBFAE"}, {"file_name": "CoverImageMiniLandscape.png", "id": "596253448403194", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_596253455069860_6720339828695346593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QeAjufEfs5UQ7kNvgEno-CO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAVCT_dsVxZI4B5vLmoR9K2_ere2uQJHV37IxKaU0w5PQ&oe=66EEAD77"}, {"file_name": "CoverImageSquare.png", "id": "586332725889641", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031501_586332729222974_107555271491119635_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FUf7stWpD7MQ7kNvgGYcyhf&_nc_ht=scontent.oculuscdn.com&oh=00_AYC3W1eG0tkzmOPLnRn8alvIj97_01oQ77Md9ewmK9I_JQ&oe=66EE99CA"}, {"file_name": "Logo.png", "id": "395340675529366", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_395340682196032_6964156802148439849_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RN5H1XNZN1sQ7kNvgER3UUU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSlusEfr8tTbGkCGNbA3QNzTvJt_5Le13_kwY11ifXjw&oe=66EEA955"}, {"file_name": "Icon.png", "id": "390235939285279", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_390235949285278_3843481588384649834_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yg-GPO7hKNYQ7kNvgENshp-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCGQG5D1GvClgvk8zhjlGZJbbhssVShyOhhpNsQqGR87g&oe=66EE9185"}, {"file_name": "CoverImagePortrait.png", "id": "383584229965844", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_383584233299177_6771641515237035930_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekVn_hG9tqgQ7kNvgGIKZ6E&_nc_ht=scontent.oculuscdn.com&oh=00_AYCP_tCM53biap3GitvoFBMNVAamNJC0s9-b1uZaM8qmZQ&oe=66EE9552"}, {"file_name": "CoverImageHero.png", "id": "247768457272242", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_247768463938908_2187039554841960072_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcMt5fik_oMQ7kNvgEl4o_l&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRKJrZp0IrQ38xrlIZChg5wmOVgbZoMJQiWSRTGy2MUg&oe=66EEAEAE"}]}, "id": "836351943603624", "locale": "de_DE", "screenshots": [{"file_name": "Screenshot1.png", "id": "597112954802621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_597112958135954_4619942593222797157_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cjUvDLVQSR0Q7kNvgF93ce_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAY9kZV7qyj_LqQC_EmEcCFJt0ay--ejhfuP3qfvcj2Q&oe=66EEC3CD"}, {"file_name": "Screenshot2.png", "id": "898198597759981", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_898198601093314_7265353852158285013_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-1Q1xp4hAYQ7kNvgHOXuVm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBiGu1kikQE_nuEl40PLjiKE5LeJd5aeJspKdULt7QegQ&oe=66EE9F6A"}, {"file_name": "Screenshot3.png", "id": "971396676759350", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001713_971396683426016_126507528010253971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zvh2Kgv_7-sQ7kNvgHfIORN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQp7OTDXQsy1jdNynYmfFTTc8zXL0ttI2WNVU55OhOLg&oe=66EEA4A1"}, {"file_name": "Screenshot4.png", "id": "606190327044171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_606190330377504_1844159778777880661_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fKowSJFOrEMQ7kNvgHZJ5Vg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpNYbqFFG2ibRPRd1nDS7Jb5Jdm1AlzUvvisx8ycbFFw&oe=66EEBF66"}, {"file_name": "Screenshot5.png", "id": "414076387104290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_414076390437623_7171154147182914860_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pPle5-frFoEQ7kNvgEnXVp6&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCP4p8Uygs1XplaOcJI7J83bCMeJwjoLz_UxiHx8jOBw&oe=66EEA7E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "277775003978784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_277775007312117_7307744386116844089_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=22bv46uIWZgQ7kNvgEl3r2y&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQYcV_1GGl4hSrETjPW34Mw_g7yNmKx0iMzoCpVh1yPQ&oe=66EEAE0D"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "kampf"], "long_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n\nSchalte die Maschinen, die dich jagen, mit Sprengstoffen, Waffen, Gewehren und Upgrades aus und k\u00e4mpfe dich durch prozedural generierte Levels.\n\nAgiler Kampf \u2013\nSetze Waffen, Werkzeuge und Sprengstoffe gegen Feindtrupps ein. Sprenge dich durch W\u00e4nde, entdecke Geheimnisse, ziele auf Schwachstellen und passe dich dem Verhalten deines Gegners an. Springe \u00fcber Lava, hangle dich mit Greifhaken durch G\u00e4nge und schie\u00dfe Maschinen-Sicherheitstrupps ab.\n\nUpgrades und Verbesserungen \u2013\nEntdecke Upgrade-Chips und verbessere deine F\u00e4higkeiten. Erhalte EMP-Effekte auf Waffen, erh\u00f6he St\u00e4rke und Tempo, sauge Energie von Feinden ab.\n\nFreischaltbare Items und Fortschritt \u2013\nErreiche Meilensteine, je weiter du kommst. Verfolge deine Statistiken und K\u00e4mpfe, katalogisiere Nachrichten von jenen vor dir. Entdecke neue Waffeneffekte, kombiniere Upgrades.\n", "short_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHeroJP.png", "id": "281055800511489", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_281055803844822_5004621190288595314_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s2JNvaukFGkQ7kNvgFBd8r2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAPKT4Bd3IZbq6yaAAA2fRsB3yG-5pTPDGzj8_SNfPaQ&oe=66EEBE16"}, {"file_name": "CoverImageMiniLandscapeJP.png", "id": "1858552550973548", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_1858552554306881_9025508674624382891_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ed2zjA638cwQ7kNvgEpEwqy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK6cCexVJUK19OoJMkkBOlZn3BjiiPBXoxNIGbnqHXuQ&oe=66EE9625"}, {"file_name": "CoverImageLandscapeJP.png", "id": "1280641505712102", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569445_1280641512378768_7516279709291076340_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N_pSqB4plE4Q7kNvgEc8SxL&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-BNZkNRsfahZjaw2R3eKUFatFTm2KHa4H2PwryzOXGw&oe=66EEC0A4"}, {"file_name": "IconJP.png", "id": "1238336366627447", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_1238336369960780_7056998765223432835_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMPttUDXKO4Q7kNvgEjoPfF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNVtQ2cb3Fvpf6FdKiY3nMt6zS0xyTeabkV2KjdaWLzQ&oe=66EE