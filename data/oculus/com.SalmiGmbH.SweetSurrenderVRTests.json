453260688321293_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1w5JbM8AjrgQ7kNvgFgNm8E&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJKooFrGADZRvUIBKsL8jX2iyGcu0hgU63yOEGvwOszg&oe=66EFFCD8"}, {"file_name": "Screenshot5.png", "id": "550686242671123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_550686246004456_5555286399400016975_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMv8TnjPwzAQ7kNvgGj5hYD&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-kvQHUTTFHOluFh-nGweceqxU1Wpm4c8fP94LXLI5rg&oe=66EFF602"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "577920866668319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569483_577920870001652_682900588683931991_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4UPOZoQZBgQ7kNvgEwmWKT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBURqtwQsQA1HwhoeRWxViVTxO13P721rMcmxuJq5P8Tw&oe=66EFF149"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "tir", "fps", "combat"], "long_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Avancez dans une m\u00e9gatour dystopique.\n\nTraversez des niveaux g\u00e9n\u00e9r\u00e9s al\u00e9atoirement en utilisant explosifs, armes de corps \u00e0 corps, armes \u00e0 feu et augmentations pour \u00e9liminer les machines.\n\nCombats vifs : \nUtilisez un large choix d\u2019armes, d\u2019outils et d\u2019explosifs. D\u00e9couvrez des passages secrets. Adaptez votre comportement en fonction de vos ennemis et ciblez leurs points faibles. Traversez des \u00e9tendues de lave en tyrolienne et franchissez les couloirs \u00e0 l\u2019aide d\u2019un grappin tout en abattant les machines.\n\nAugmentations et am\u00e9liorations : \nTrouvez des puces d\u2019augmentation. Dotez vos armes d\u2019un effet IEM, augmentez votre force et votre vitesse, ou siphonnez l\u2019\u00e9nergie de vos ennemis.\n\nContenus d\u00e9blocables et progression :\nFranchissez de nouvelles \u00e9tapes au fil de votre progression. Suivez vos statistiques. R\u00e9pertoriez les messages laiss\u00e9s par vos pr\u00e9d\u00e9cesseurs. D\u00e9couvrez de nouveaux effets pour vos armes, et combinez les augmentations.\n", "short_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Dans une m\u00e9gatour dystopique, vous devez constamment vous adapter \u00e0 un environnement sans piti\u00e9 et une action au rythme effr\u00e9n\u00e9.\n"}, {"images": {"nodes": [{"file_name": "CoverImageLandscape.png", "id": "616500419733536", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035340_616500423066869_3483619644102186279_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zYwnwidDSBwQ7kNvgHvEBC8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCLakUZXtMqwYNFKGORsmhhxOi7lgC2opwGY8WO9OUYA&oe=66F0112E"}, {"file_name": "CoverImageMiniLandscape.png", "id": "596253448403194", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_596253455069860_6720339828695346593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QeAjufEfs5UQ7kNvgGE3Uex&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3DuagUxlZGI_rZDTGBLKdCu1qaCfv93ROfPHQxoQysg&oe=66EFFEF7"}, {"file_name": "CoverImageSquare.png", "id": "586332725889641", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031501_586332729222974_107555271491119635_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FUf7stWpD7MQ7kNvgG_uuOj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTWjS1GyOBnlJD9dJxrqqltJLRmFxYTdSqFhJDlPUiHw&oe=66EFEB4A"}, {"file_name": "Logo.png", "id": "395340675529366", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_395340682196032_6964156802148439849_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RN5H1XNZN1sQ7kNvgFHvrwn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAU2jWgdCJCJmX7ehT2yGhYPo1xdHrDk0T12XCTRkK36w&oe=66EFFAD5"}, {"file_name": "Icon.png", "id": "390235939285279", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_390235949285278_3843481588384649834_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yg-GPO7hKNYQ7kNvgGReiXL&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZvhFMIIR4-agPoQLbxLaO06a6dsyBR7Qu1nDCoTAByw&oe=66F01B45"}, {"file_name": "CoverImagePortrait.png", "id": "383584229965844", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_383584233299177_6771641515237035930_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ekVn_hG9tqgQ7kNvgHPz5DY&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9x58nz5Tge0wsr7H0hQsEBbIxUDfwtAmbg25aUQnpPw&oe=66EFE6D2"}, {"file_name": "CoverImageHero.png", "id": "247768457272242", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_247768463938908_2187039554841960072_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcMt5fik_oMQ7kNvgGoY46U&_nc_ht=scontent.oculuscdn.com&oh=00_AYCY6iI0v7M7hOL8NkLwsJ-g_OUHBDFG-SDxhcEv8cgecw&oe=66F0002E"}]}, "id": "836351943603624", "locale": "de_DE", "screenshots": [{"file_name": "Screenshot1.png", "id": "597112954802621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_597112958135954_4619942593222797157_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NDJJikHXnx8Q7kNvgG00j8U&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7rhaEqks5K4ygBJow47WNUPlb90IGGlmY8Hi-TWryZg&oe=66F0154D"}, {"file_name": "Screenshot2.png", "id": "898198597759981", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_898198601093314_7265353852158285013_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-1Q1xp4hAYQ7kNvgH5XqUa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJNCc-6zPtlnRYySrOd7Iaf_lkSybYRrSXThcOveJ3EA&oe=66EFF0EA"}, {"file_name": "Screenshot3.png", "id": "971396676759350", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001713_971396683426016_126507528010253971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d65Bp4pwW00Q7kNvgGsoa5h&_nc_ht=scontent.oculuscdn.com&oh=00_AYBquj6Bz7JcYxQs8wRAUxlYupvvlUj3f-sxf6P48ueryg&oe=66EFF621"}, {"file_name": "Screenshot4.png", "id": "606190327044171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_606190330377504_1844159778777880661_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fKowSJFOrEMQ7kNvgHBv0gX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAW8CR25stDdcmTHE165SbiuTu9TNXQvBA_GXnqDTaz_Q&oe=66F010E6"}, {"file_name": "Screenshot5.png", "id": "414076387104290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_414076390437623_7171154147182914860_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pPle5-frFoEQ7kNvgFqs4uY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCN6L-abdPnPX55HfOuwVzIn4PCa_ao3k_XOxAxg0BPMg&oe=66EFF969"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "277775003978784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_277775007312117_7307744386116844089_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3eR7TTVja6sQ7kNvgFEXhTQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPIhqlotRYgLACy7k5EykTYQ9qk7PV1ZhoiV1UBYLlZQ&oe=66EFFF8D"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "kampf"], "long_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n\nSchalte die Maschinen, die dich jagen, mit Sprengstoffen, Waffen, Gewehren und Upgrades aus und k\u00e4mpfe dich durch prozedural generierte Levels.\n\nAgiler Kampf \u2013\nSetze Waffen, Werkzeuge und Sprengstoffe gegen Feindtrupps ein. Sprenge dich durch W\u00e4nde, entdecke Geheimnisse, ziele auf Schwachstellen und passe dich dem Verhalten deines Gegners an. Springe \u00fcber Lava, hangle dich mit Greifhaken durch G\u00e4nge und schie\u00dfe Maschinen-Sicherheitstrupps ab.\n\nUpgrades und Verbesserungen \u2013\nEntdecke Upgrade-Chips und verbessere deine F\u00e4higkeiten. Erhalte EMP-Effekte auf Waffen, erh\u00f6he St\u00e4rke und Tempo, sauge Energie von Feinden ab.\n\nFreischaltbare Items und Fortschritt \u2013\nErreiche Meilensteine, je weiter du kommst. Verfolge deine Statistiken und K\u00e4mpfe, katalogisiere Nachrichten von jenen vor dir. Entdecke neue Waffeneffekte, kombiniere Upgrades.\n", "short_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHeroJP.png", "id": "281055800511489", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_281055803844822_5004621190288595314_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s2JNvaukFGkQ7kNvgHZ16s5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAd6RbFIp0tXB37P9a51bzaiDYbTfSjjDSnTGaDdLPlA&oe=66F00F96"}, {"file_name": "CoverImageMiniLandscapeJP.png", "id": "1858552550973548", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_1858552554306881_9025508674624382891_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ON5JpV5dmgQ7kNvgFzdI2j&_nc_ht=scontent.oculuscdn.com&oh=00_AYApge-yArR5SQZIxu9C1JywDBs6RGhotcBAnO52afZCGQ&oe=66EFE7A5"}, {"file_name": "CoverImageLandscapeJP.png", "id": "1280641505712102", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569445_1280641512378768_7516279709291076340_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N_pSqB4plE4Q7kNvgF5B5oe&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMfGu22y2qh_YnlMrA73FklCxszeHat49tCEy9j8w4sA&oe=66F01224"}, {"file_name": "IconJP.png", "id": "1238336366627447", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_1238336369960780_7056998765223432835_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yMPttUDXKO4Q7kNvgEWfNzS&_nc_ht=scontent.oculuscdn.com&oh=00_AYCS5bLxNNwVOgZfrisqBZF0J-eBgJowSZPRwNtRuyWLzw&oe=66EF