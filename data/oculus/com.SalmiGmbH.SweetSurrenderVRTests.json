61_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xK2qYHfDG8sQ7kNvgHbTOOz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjk54TXNojK0RWljAgML7_g15kBzz1gmdK44sNgNS72Q&oe=66EFECC8"}, {"file_name": "Screenshot3.png", "id": "3880899298676771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_3880899312010103_2182482223037715146_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STijH0U4FrAQ7kNvgHyO-rM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDg0xH6iXZFdNrXsSKeXLJXIoxHnZ_XD8NgRgAY3KLQPg&oe=66F00A96"}, {"file_name": "Screenshot4.png", "id": "632541957738951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570295_632541961072284_9041265518534613224_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZI2QTsgfrUQ7kNvgEogWhv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBrtScjeSSXnS86ojTUjcIJwqLJT-0bcag68M9gCGMYw&oe=66EFFAFE"}, {"file_name": "Screenshot5.png", "id": "3118602568465145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_3118602571798478_5241911405837164837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xxbHEeHvj0wQ7kNvgGroQhk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNf-HF_7O5rhpZuKVPOFSJOxFPz8THikuhk8q-PVCp3Q&oe=66EFF7A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "3304918962966230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_3304918969632896_7921060189846060168_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PlI0VWabXDEQ7kNvgGA9pd6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlpcjE2X8xFLNgq1DrNnrRkFKk5FumoSbo1Rj8m7FJLA&oe=66F01B1E"}, "display_name": "Sweet Surrender", "keywords": ["roguelike", "disparos", "fps", "combate"], "long_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n\nUsa explosivos, armas de mano, pistolas y actualizaciones para derribar las m\u00e1quinas que te persiguen mientras luchas por llegar a la cima pasando los niveles generados por procedimientos.\n\nCombate \u00e1gil: \nusa una variedad de armas, herramientas y explosivos para eliminar las fuerzas enemigas. Atraviesa las paredes con explosiones para descubrir secretos, apunta a los puntos d\u00e9biles y ad\u00e1ptate al comportamiento de tus enemigos. Cruza r\u00edos de lava en tirolesa, usa arpeos para trepar por los corredores mientras reduces a disparos las fuerzas de seguridad de las m\u00e1quinas.\n\nActualizaciones y mejoras: \ndescubre los chips de actualizaci\u00f3n que pueden elevar tus habilidades. Obt\u00e9n efectos EMP para tus armas, aumenta tu fuerza y velocidad, extrae la energ\u00eda de tus enemigos.\n", "short_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortraitKR.png", "id": "1120975665100000", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_1120975668433333_1316925696992055825_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5bNeqOaIZygQ7kNvgGsENQU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzWO3-jUZA8GGD3ydC9nZrrR_VeAUzlcxfPn9W6GPfPg&oe=66EFFD22"}, {"file_name": "CoverImageSquareKR.png", "id": "1038622706922441", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_1038622710255774_8643929694250534637_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bb4YEEbNmugQ7kNvgEyewEM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfKlYSyLwl54HM1eftckf6UDsahIQGrmoyKGQM4JSvaQ&oe=66EFEEF2"}, {"file_name": "CoverImageMiniLandscapeKR.png", "id": "979162109598833", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_979162116265499_1764438849254555913_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nCGhiD6Gi7gQ7kNvgE0qlnu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKR8sjdrgOqy