489726196039915113_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zu0hw5DEb1oQ7kNvgEH6L0P&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5Hp_XRKVDM3vbWDwot-jAoOg6vgE1uLeYMgDI10ZBGw&oe=66EFE42A"}, {"file_name": "Screenshot 3 1440.png", "id": "439146270861179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_439146274194512_3265374891474992569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v7KKosVMIJsQ7kNvgFtLVfO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaAz4ru9Fmhsrk3gbOcz8eYj9sjZviBrNaOhCqbi80Nw&oe=66EFEDBB"}, {"file_name": "7 1440.png", "id": "587557329050301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_587557332383634_613148445108165191_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0LOxwt-Ci1gQ7kNvgHVYThU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUYP0eZ-2qr-LhNT5bO_iO6zZacFHnWCSzubl27xet2w&oe=66F001E9"}, {"file_name": "8 1440.png", "id": "278301000580045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_278301003913378_4961165780702200385_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=McELXDxU9F0Q7kNvgHaRKHv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAp17VRkA39VW_FAuyJD1sAAXFeAntNsy7v_ZGBrxK5jg&oe=66F002D6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1632100410468901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1632100413802234_1726393786771260074_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XkX2takHvfkQ7kNvgFOLk_T&_nc_ht=scontent.oculuscdn.com&oh=00_AYDv5VcFST2A840J356uqJOKgFZRxoEQUN7UBU5RnH-Q3w&oe=66F015E7"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "combat"], "long_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n\nUse explosives, melee weapons, guns and upgrades to take down the machines hunting you as you fight your way to the summit through procedurally-generated levels.\n\nAgile Combat - \nUse an array of weapons, tools and explosives to dispatch enemy forces. Blast through walls to uncover secrets, aim for weak points and adapt to the behaviour of your enemy. Zipline across lava, grapple hook through corridors as you gun down machine security forces.\n\nUpgrades and Enhancements - \nDiscover upgrade chips that can heighten your abilities. Gain EMP effects on your weapons, increase your strength and speed, siphon energy from your enemies.\n\nUnlockables and Progression -\nAchieve new milestones the further you advance. Track your personal stats and enemy encounters, catalog messages from those who came before you. Discover new weapon effects, combine upgrades.\n", "short_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHero.png", "id": "115634340767631", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_115634344100964_4698064246001205638_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ARMAVl7p4EQ7kNvgHwvkp8&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8AvIHPhDhySkPQZ5hh9lVbLoGfcHEeDKwl1yz1Cpyxw&oe=66EFF3D0"}, {"file_name": "CoverImageMiniLandscape.png", "id": "4531926600196916", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_4531926603530249_6962821853766922858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q7dVRz7uc0EQ7kNvgGHcavn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEish1sJen6ubrs2spPzmm9Jbz4umsAsNaD7ykeIfhJw&oe=66F00CF6"}, {"file_name": "CoverImagePortrait.png", "id": "606660833673980", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_606660837007313_7189004430715192244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMFiqjRo-DoQ7kNvgGVmK85&_nc_ht=scontent.oculuscdn.com&oh=00_AYARB72Go27fO4T3Ts-IMGb0jnFJ-IAzO3bugclk-QCJqA&oe=66EFF7C8"}, 