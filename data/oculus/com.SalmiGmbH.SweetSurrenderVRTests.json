.com/v/t64.5771-25/39003241_369426484830931_3192786912307997496_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sb6MZfylL6wQ7kNvgE3obV4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhtG1gENVLy8EK44Qus_4sTk7Z7n3SOU7ARMEIE8VcNg&oe=66EFE874"}, {"file_name": "Screenshot3.png", "id": "446950453304504", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035406_446950456637837_6166095464791538498_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kydtsfjxGAYQ7kNvgEgiDmc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBH0frG-YRevmtiQfKuu24CQNfgjSms2_3BRyHEUPjvLw&oe=66F007FC"}, {"file_name": "Screenshot4.png", "id": "839063753463255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974538_839063756796588_4319456000214463966_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qmy_HiN3GOcQ7kNvgEKDFkG&_nc_ht=scontent.oculuscdn.com&oh=00_AYD19N2JDAj_aj0I3GbZhd56yoqaF6AhNu_g3vSTditZ_g&oe=66EFE501"}, {"file_name": "Screenshot5.png", "id": "1262860397460495", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_1262860400793828_1181162491891081469_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDWUsnDUnw8Q7kNvgGCY-Re&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUN7niNne-F1aYJW-OsZxKDro9aMghOVPF-rFNWGBO8g&oe=66EFF171"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscapeKR.png", "id": "1305135276608103", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_1305135286608102_1282784577749709177_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSuhGqewPDEQ7kNvgF23E16&_nc_ht=scontent.oculuscdn.com&oh=00_AYDDCM6Il8WQV_m4XFB1OuApulhHt9Y6L-AR8igAtG97Uw&oe=66F01134"}, "display_name": "\uc2a4\uc717 \uc11c\ub80c\ub354", "keywords": ["\ub85c\uadf8\ub77c\uc774\ud2b8", "\ub85c\uadf8\ub77c\uc774\ud06c", "\uc288\ud305", "FPS", "\uc804\ud22c"], "long_description": "<\uc2a4\uc717 \uc11c\ub80c\ub354>\ub294 \ub514\uc2a4\ud1a0\ud53c\uc544 \uba54\uac00\ud0c0\uc6cc\ub97c \ubc30\uacbd\uc73c\ub85c \ubb34\uc790\ube44\ud558\uace0 \ube60\ub974\uac8c \uc9c4\ud589\ub418\uba70 \uc561\uc158\uc774 \uac00\ub4dd\ud55c \ud658\uacbd\uc5d0 \uc801\uc751\ud574\ub098\uac00\ub294 \ub85c\uadf8\ub77c\uc774\ud06c \uc288\ud305 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\n\ud3ed\ubc1c\ubb3c, \uadfc\uc811 \ubb34\uae30, \ucd1d \ubc0f \uc5c5\uadf8\ub808\uc774\ub4dc\ub97c \uc774\uc6a9\ud574 \uc54c\uace0\ub9ac\uc998\uc5d0 \ub530\ub77c \uc0dd\uc131\ub418\ub294 \uac01 \uce35\uc5d0\uc11c \uc5ec\ub7ec\ubd84\uc744 \ucad3\ub294 \uae30\uacc4\ub97c \ucc98\uce58\ud558\uace0 \uc815\uc0c1\uae4c\uc9c0 \uc2f8\uc6cc\ub098\uac00\uc138\uc694.\n\n\ubbfc\ucca9\ud55c \uc804\ud22c - \n\uc5ec\ub7ec \uac00\uc9c0 \ubb34\uae30, \ub3c4\uad6c \ubc0f \ud3ed\ubc1c\ubb3c\uc744 \uc774\uc6a9\ud574 \uc801\uad70\uc744 \uc2e0\uc18d\ud558\uac8c \ubb3c\ub9ac\uce58\uc138\uc694. \ubcbd\uc744 \ud3ed\ud30c\ud574 \uc228\uaca8\uc9c4 \ube44\ubc00\uc744 \ud30c\ud5e4\uce58\uace0, \uc57d\uc810\uc744 \ub178\ub824 \uc801\uc758 \uc6c0\uc9c1\uc784\uc5d0 \ub300\uc751\ud558\uc138\uc694. \uc9d1\ub77c\uc778\uc73c\ub85c \uc6a9\uc554\uc744 \ub118\uace0, \uadf8\ub798\ud50c \ud6c5\uc73c\ub85c \ud1b5\ub85c\ub97c \uac00\ub85c\uc9c8\ub7ec \uae30\uacc4 \ubcf4\uc548 \ubd80\ub300\ub97c \ucd1d\uc73c\ub85c \uaca9\ucd94\ud558\uc138\uc694.\n\n\uc5c5\uadf8\ub808\uc774\ub4dc \ubc0f \uae30\ub2a5 \ud5a5\uc0c1 - \n\ub2a5\ub825\uc744 \ud5a5\uc0c1\ud558\ub294 \uc5c5\uadf8\ub808\uc774\ub4dc \uce69\uc744 \ucc3e\uc544\ubcf4\uc138\uc694. \ubb34\uae30\uc5d0 EMP \ud6a8\uacfc\ub97c \ubd80\uc5ec\ud558\uace0, \ud798\uacfc \uc18d\ub3c4\ub97c \ub192\uc774\uba70, \uc801\uc5d0\uac8c\uc11c \uc5d0\ub108\uc9c0\ub97c \ud761\uc218\ud558\uc138\uc694.\n\n\uc7a0\uae08 \ud574\uc81c \ucf58\ud150\uce20 \ubc0f \uc9c4\ud589\ub3c4 -\n\uc55e\uc73c\ub85c \uc9c4\ud589\ud574\ub098\uac00\uba74\uc11c \uc0c8\ub85c\uc6b4 \ub9c8\uc77c\uc2a4\ud1a4\uc744 \ub2ec\uc131\ud558\uc138\uc694. \uac1c\uc778 \ud1b5\uacc4 \ubc0f \uc801\uacfc\uc758 \uad50\uc804, \uba3c\uc800 \uc654\ub358 \ud50c\ub808\uc774\uc5b4\ub4e4\uc758 \uce74\ud0c8\ub85c\uadf8 \uba54\uc2dc\uc9c0\ub97c \ud655\uc778\ud574\ubcf4\uc138\uc694. \uc0c8\ub85c\uc6b4 \ubb34\uae30 \ud6a8\uacfc\ub97c \uc5bb\uace0 \uc5c5\uadf8\ub808\uc774\ub4dc\ub97c \uc870\ud569\ud574\ubcf4\uc138\uc694.\n", "short_description": "<\uc2a4\uc717 \uc11c\ub80c\ub354>\ub294 \ub514\uc2a4\ud1a0\ud53c\uc544 \uba54\uac00\ud0c0\uc6cc\ub97c \ubc30\uacbd\uc73c\ub85c \ubb34\uc790\ube44\ud558\uace0 \ube60\ub974\uac8c \uc9c4\ud589\ub418\uba70 \uc561\uc158\uc774 \uac00\ub4dd\ud55c \ud658\uacbd\uc5d0 \uc801\uc751\ud574\ub098\uac00\ub294 \ub85c\uadf8\ub77c\uc774\ud06c \uc288\ud305 \uac8c\uc784\uc785\ub2c8\ub2e4.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortrait.png", "id": "4223583834356812", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_4223583847690144_3969148212653210449_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HapcA0nUhwgQ7kNvgGG2ddS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBJ9-qL50DGRIxyILVtp5H_X1x6RnO3NAoaS7Aq95uCA&oe=66EFF182"}, {"file_name": "CoverImageMiniLandscape.png", "id": "1797844770402159", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1797844773735492_1851471833968509009_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LA1f7-x6EpAQ7kNvgEm8GFQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5RSGKeSRQtxicr0UXpyWYK9EujefbKQeesLWDZrPYtg&oe=66EFF8C7"}, {"file_name": "Icon.png", "id": "1657555244443849", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_1657555247777182_1306060781361412918_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gqPNb7oNIXYQ7kNvgHJWtiH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCH08ZSB2GzXbkUN9UEA2Jt4C-iq_nPYgoQkdphZUoG9g&oe=66EFF2B1"}, {"file_name": "CoverImageSquare.png", "id": "580910053051674", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86659802_580910056385007_3841875226947026636_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RfU5B0gSacsQ7kNvgHtXvMi&_nc_ht=scontent.oculuscdn.com&o