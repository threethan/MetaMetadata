453260688321293_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E0rWiAkD0OEQ7kNvgF1ZsrB&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNgvE_DoqGprGbgmAd2njEF33Yf1TgKXX4XvmpmnURLQ&oe=66EAB6D8"}, {"file_name": "Screenshot5.png", "id": "550686242671123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_550686246004456_5555286399400016975_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MVG_RP51OtwQ7kNvgFP9QNZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJJ7wWrjo36_U76G0wC9l7Mtmp54qTOTBPzpN19wl6iw&oe=66EAB002"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "577920866668319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569483_577920870001652_682900588683931991_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AHy96rAxaPsQ7kNvgGlW55M&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQr_LdNYaubSLPJZKOHsYb1Z6FdJ4PezXzICikcKFTIQ&oe=66EAAB49"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "tir", "fps", "combat"], "long_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Avancez dans une m\u00e9gatour dystopique.\n\nTraversez des niveaux g\u00e9n\u00e9r\u00e9s al\u00e9atoirement en utilisant explosifs, armes de corps \u00e0 corps, armes \u00e0 feu et augmentations pour \u00e9liminer les machines.\n\nCombats vifs : \nUtilisez un large choix d\u2019armes, d\u2019outils et d\u2019explosifs. D\u00e9couvrez des passages secrets. Adaptez votre comportement en fonction de vos ennemis et ciblez leurs points faibles. Traversez des \u00e9tendues de lave en tyrolienne et franchissez les couloirs \u00e0 l\u2019aide d\u2019un grappin tout en abattant les machines.\n\nAugmentations et am\u00e9liorations : \nTrouvez des puces d\u2019augmentation. Dotez vos armes d\u2019un effet IEM, augmentez votre force et votre vitesse, ou siphonnez l\u2019\u00e9nergie de vos ennemis.\n\nContenus d\u00e9blocables et progression :\nFranchissez de nouvelles \u00e9tapes au fil de votre progression. Suivez vos statistiques. R\u00e9pertoriez les messages laiss\u00e9s par vos pr\u00e9d\u00e9cesseurs. D\u00e9couvrez de nouveaux effets pour vos armes, et combinez les augmentations.\n", "short_description": "\u00ab Sweet Surrender \u00bb m\u00eale jeu de tir et Roguelike. Dans une m\u00e9gatour dystopique, vous devez constamment vous adapter \u00e0 un environnement sans piti\u00e9 et une action au rythme effr\u00e9n\u00e9.\n"}, {"images": {"nodes": [{"file_name": "CoverImageLandscape.png", "id": "616500419733536", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035340_616500423066869_3483619644102186279_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NfKTz-A8inoQ7kNvgHDFI6q&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUuUskYVYjfeCPUovPbI7lBac-Ii6Frn5uyhIhM_Czuw&oe=66EACB2E"}, {"file_name": "CoverImageMiniLandscape.png", "id": "596253448403194", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_596253455069860_6720339828695346593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-XaANhyGe_YQ7kNvgFxUq3n&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFdgygJclv16J4bILAP0CMT1jfsxZz89hcCmp3TLuIWA&oe=66EAB8F7"}, {"file_name": "CoverImageSquare.png", "id": "586332725889641", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031501_586332729222974_107555271491119635_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gnDh-b1vhpcQ7kNvgG78d4_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcq0utRPHQUu2c3IM_umjSMIAEcbuTIbz9GUUxFZucqA&oe=66EAA54A"}, {"file_name": "Logo.png", "id": "395340675529366", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_395340682196032_6964156802148439849_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zDz5KnwwtRwQ7kNvgEgVVml&_nc_ht=scontent.oculuscdn.com&oh=00_AYAPsFEePFGNdPIvoBRdI6IEv3ZNcL-1gMShWOop-hzWIA&oe=66EAB4D5"}, {"file_name": "Icon.png", "id": "390235939285279", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_390235949285278_3843481588384649834_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lTLj7kHJF6UQ7kNvgHYG8pL&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFGI_jTAG30hXso0Z5Nid8Wfph7YqmLnqE6MboSlMX9w&oe=66EA9D05"}, {"file_name": "CoverImagePortrait.png", "id": "383584229965844", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_383584233299177_6771641515237035930_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AVkbJI1keaEQ7kNvgG7jUkE&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-JeOTsSqTzEFTZDAlD-POY8V2i0JO0VOnU6vOPxxEAA&oe=66EAA0D2"}, {"file_name": "CoverImageHero.png", "id": "247768457272242", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_247768463938908_2187039554841960072_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CoKaY62Mv4EQ7kNvgHh_xtV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCB3aTHO_pte7i1SH5F8BQYUv3rlPF6tLnsVOWnUb2u8A&oe=66EABA2E"}]}, "id": "836351943603624", "locale": "de_DE", "screenshots": [{"file_name": "Screenshot1.png", "id": "597112954802621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_597112958135954_4619942593222797157_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TXP34fuDATcQ7kNvgEklIfI&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9VE_laoXUTOvWPxWHC78sFcDpKcsi2lv3ph1Dh_jRGg&oe=66EACF4D"}, {"file_name": "Screenshot2.png", "id": "898198597759981", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_898198601093314_7265353852158285013_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bpIPwJcYy1UQ7kNvgGJS_9N&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZSDhsQpNmZPO14kqw7DyVsMOnWlEP31UyHxjA7xwwwg&oe=66EAAAEA"}, {"file_name": "Screenshot3.png", "id": "971396676759350", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001713_971396683426016_126507528010253971_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D0rNRJg1InEQ7kNvgHvRQBo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZtS-vM2d_GTFcDcnt5X8ybBbFQMvwedh5aBFtyhzVNA&oe=66EAB021"}, {"file_name": "Screenshot4.png", "id": "606190327044171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_606190330377504_1844159778777880661_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAGAiGPtG3YQ7kNvgFN8YvK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYjQWkrXyV5JJZWgzPW944H58X12RhiQa6qPmoHUqgBQ&oe=66EACAE6"}, {"file_name": "Screenshot5.png", "id": "414076387104290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031440_414076390437623_7171154147182914860_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Zq2pUlraQQQ7kNvgERU2H1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuMt_YaONxmfcre5M41SCh9YjdhWxgLTqgDLCKxwlbSw&oe=66EAB369"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "277775003978784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001663_277775007312117_7307744386116844089_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-EjN0dHRHoEQ7kNvgGJ3RtM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiPm5jo14zQFZQIqjtMnVrCDJ46e05gMBRl7GrB6nowA&oe=66EAB98D"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "kampf"], "long_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n\nSchalte die Maschinen, die dich jagen, mit Sprengstoffen, Waffen, Gewehren und Upgrades aus und k\u00e4mpfe dich durch prozedural generierte Levels.\n\nAgiler Kampf \u2013\nSetze Waffen, Werkzeuge und Sprengstoffe gegen Feindtrupps ein. Sprenge dich durch W\u00e4nde, entdecke Geheimnisse, ziele auf Schwachstellen und passe dich dem Verhalten deines Gegners an. Springe \u00fcber Lava, hangle dich mit Greifhaken durch G\u00e4nge und schie\u00dfe Maschinen-Sicherheitstrupps ab.\n\nUpgrades und Verbesserungen \u2013\nEntdecke Upgrade-Chips und verbessere deine F\u00e4higkeiten. Erhalte EMP-Effekte auf Waffen, erh\u00f6he St\u00e4rke und Tempo, sauge Energie von Feinden ab.\n\nFreischaltbare Items und Fortschritt \u2013\nErreiche Meilensteine, je weiter du kommst. Verfolge deine Statistiken und K\u00e4mpfe, katalogisiere Nachrichten von jenen vor dir. Entdecke neue Waffeneffekte, kombiniere Upgrades.\n", "short_description": "\u201eSweet Surrender\u201c ist ein Roguelike-Shooter in einem dystopischen Megaturm. Dort musst du dich an eine gnadenlose, tempo- und actionreiche Umgebung anpassen.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHeroJP.png", "id": "281055800511489", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_281055803844822_5004621190288595314_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a6tr76AIJEcQ7kNvgGu9P4B&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1xzxmZxTzviX5q7BtGrttIOZVeKvjH5b154v92bBiXA&oe=66EAC996"}, {"file_name": "CoverImageMiniLandscapeJP.png", "id": "1858552550973548", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_1858552554306881_9025508674624382891_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s9YC_CKvZ4sQ7kNvgGsEDSb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDYphMW4N3uToQXnLHdnZbfw-2Ac4i0dMKhaP1wCGPchw&oe=66EAA1A5"}, {"file_name": "CoverImageLandscapeJP.png", "id": "1280641505712102", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569445_1280641512378768_7516279709291076340_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQRu2Z_xfNQQ7kNvgEbCnVF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAL2-cYTws9q3-aMqDXKC23cdt_arxRrDkxFMMvX8W44Q&oe=66EACC24"}, {"file_name": "IconJP.png", "id": "1238336366627447", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_1238336369960780_7056998765223432835_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5K1YZf9Mk3kQ7kNvgE_SlKn&_nc_ht=scontent.oculuscdn.com&oh=00_AYAE4OV9eka8lgsqEXFiQbs1uVg5YBTBOBPByu2YRl3LGw&oe=66EA