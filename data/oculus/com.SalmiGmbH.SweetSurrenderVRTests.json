489726196039915113_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YcUyH2Xfwa4Q7kNvgGgAOH2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBS2kB6uvC9KcukrIQ9Ek3uocX0ktX5k53ipVAAqcXKA&oe=66EA9E2A"}, {"file_name": "Screenshot 3 1440.png", "id": "439146270861179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_439146274194512_3265374891474992569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O92J8Yex5DkQ7kNvgFzMswG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCF_cRO4xVPLi6dinAV2yeWI4FeRD96b5qSFz0DROiOfg&oe=66EAA7BB"}, {"file_name": "7 1440.png", "id": "587557329050301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_587557332383634_613148445108165191_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yoEi-xJYdvgQ7kNvgFVFXZt&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuieVLmo1PWm1nx0s78UEklU1RKfieWN-7D_Sy1ENrYg&oe=66EABBE9"}, {"file_name": "8 1440.png", "id": "278301000580045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_278301003913378_4961165780702200385_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9355jCW353IQ7kNvgH6RI3D&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfUY8Cy2A892Z48pScXdeg4vNG2GBWE1hmXCQwtFvMrA&oe=66EABCD6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1632100410468901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1632100413802234_1726393786771260074_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNZSKqVhQkcQ7kNvgEGss6c&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKiIIZz5-_Q5hfqqbi9PVevAU3hOq80kUdD0VnxBTB3A&oe=66EACFE7"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "combat"], "long_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n\nUse explosives, melee weapons, guns and upgrades to take down the machines hunting you as you fight your way to the summit through procedurally-generated levels.\n\nAgile Combat - \nUse an array of weapons, tools and explosives to dispatch enemy forces. Blast through walls to uncover secrets, aim for weak points and adapt to the behaviour of your enemy. Zipline across lava, grapple hook through corridors as you gun down machine security forces.\n\nUpgrades and Enhancements - \nDiscover upgrade chips that can heighten your abilities. Gain EMP effects on your weapons, increase your strength and speed, siphon energy from your enemies.\n\nUnlockables and Progression -\nAchieve new milestones the further you advance. Track your personal stats and enemy encounters, catalog messages from those who came before you. Discover new weapon effects, combine upgrades.\n", "short_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHero.png", "id": "115634340767631", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_115634344100964_4698064246001205638_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=veIt5c7s12AQ7kNvgEz8Z6o&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3YIQcc-29F86AuHbvVbTMPNS-RUFpw8Y0o3gh-Xwuyw&oe=66EAADD0"}, {"file_name": "CoverImageMiniLandscape.png", "id": "4531926600196916", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_4531926603530249_6962821853766922858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kAjmE_ZnH3UQ7kNvgEqeZpk&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8VSj3gxWqW1FxgcXqbinIOKQ8zTcNqwpy9GIh_W2Vng&oe=66EAC6F6"}, {"file_name": "CoverImagePortrait.png", "id": "606660833673980", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_606660837007313_7189004430715192244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cpl1McEvTw8Q7kNvgH71XNf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkk6PllJHNNesKw_53rS0WxFf0_sFUfnzoWGdMM1wqPQ&oe=66EAB1C8"}, {"file_name": "CoverImageLandscape.png", "id": "594329141601992", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_594329144935325_3798676971550141837_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2_76ojLDfzMQ7kNvgECfgTr&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0sstuM0xuvTmZtJVbbdYf2kBaBIQ5VjQRu8X0-D1gIA&oe=66EA9D24"}, {"file_name": "CoverImageSquare.png", "id": "559777915269063", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_559777918602396_6224991975423925847_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqGjl4fpp0UQ7kNvgFaqdAz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAYssSXztvawDk3hg__dG_HMFv9vffjm39IJ9sH4b6ag&oe=66EACB21"}, {"file_name": "Logo.png", "id": "443595463754143", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_443595467087476_7978473456414610396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HcYxND-lsqsQ7kNvgG1PW46&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-_3WLATbGs9QbhVM5Pw_6DfXqKR6MGLWZQueZT4S7JA&oe=66EAABA8"}, {"file_name": "Icon.png", "id": "350115806796631", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_350115813463297_488826976810587709_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HmDZp6rlA7MQ7kNvgETbW7U&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3GGxw47b52ebSXzKi7Ctag5AHv0790omYix_nFsjUJg&oe=66EAD115"}]}, "id": "2959089641073973", "locale": "es_LA", "screenshots": [{"file_name": "Screenshot1.png", "id": "149961060659239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_149961063992572_3317862938453630568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xNK0Ga8M3iUQ7kNvgGjI5xy&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdpHSmflVPuPDdWZlH1FT6AZcyVcQ5U74jKMD7QsiY-Q&oe=66EA9E54"}, {"file_name": "Screenshot2.png", "id": "854916028748159", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_854916035414825_1482957548994953661_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8jXtFqMfaroQ7kNvgFHIujB&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlQw0AW72bjUZlQAojsHFJH9iBGayaZQwMxQQ6cHR_dA&oe=66EAA6C8"}, {"file_name": "Screenshot3.png", "id": "3880899298676771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_3880899312010103_2182482223037715146_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w1Ml0OJlHtIQ7kNvgHM6FlH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfHDqhcIcp0bZnhV88ygEryGGhfxaoH2G6Yvdqm2gusg&oe=66EAC496"}, {"file_name": "Screenshot4.png", "id": "632541957738951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570295_632541961072284_9041265518534613224_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7eVdTXIXmvEQ7kNvgHApBam&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSP9n3gimDtwWXCw_zCpUClF56rEpPl_t0J32Q7sk35Q&oe=66EAB4FE"}, {"file_name": "Screenshot5.png", "id": "3118602568465145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_3118602571798478_5241911405837164837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j4A-Z11KIu0Q7kNvgGvSq1s&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgHQhtMPDxmVtN0lUGMHIFLhLb5VQtwtDN5ntPO8iSPg&oe=66EAB1A5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "3304918962966230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_3304918969632896_7921060189846060168_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fw9Ki9m4WmUQ7kNvgElZrrT&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoaoNfk7hTEY6INczu1dQUADNSfvW5b5Kfq8IZeSFAvQ&oe=66EA9CDE"}, "display_name": "Sweet Surrender", "keywords": ["roguelike", "disparos", "fps", "combate"], "long_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n\nUsa explosivos, armas de mano, pistolas y actualizaciones para derribar las m\u00e1quinas que te persiguen mientras luchas por llegar a la cima pasando los niveles generados por procedimientos.\n\nCombate \u00e1gil: \nusa una variedad de armas, herramientas y explosivos para eliminar las fuerzas enemigas. Atraviesa las paredes con explosiones para descubrir secretos, apunta a los puntos d\u00e9biles y ad\u00e1ptate al comportamiento de tus enemigos. Cruza r\u00edos de lava en tirolesa, usa arpeos para trepar por los corredores mientras reduces a disparos las fuerzas de seguridad de las m\u00e1quinas.\n\nActualizaciones y mejoras: \ndescubre los chips de actualizaci\u00f3n que pueden elevar tus habilidades. Obt\u00e9n efectos EMP para tus armas, aumenta tu fuerza y velocidad, extrae la energ\u00eda de tus enemigos.\n", "short_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortraitKR.png", "id": "1120975665100000", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_1120975668433333_1316925696992055825_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OWIowaJ8Mc0Q7kNvgE1WqWi&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqyUmfPLRvEscq1rCC-Rti8uzK3omF5u89tSyuCkrOcg&oe=66EAB722"}, {"file_name": "CoverImageSquareKR.png", "id": "1038622706922441", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_1038622710255774_8643929694250534637_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t1XKaeBQp7EQ7kNvgFuAasn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbCBd_6kj4Oy714kiUkIvlgO_FfPX2fQJuIYHPqLdvuw&oe=66EAA8F2"}, {"file_name": "CoverImageMiniLandscapeKR.png", "id": "979162109598833", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_979162116265499_1764438849254555913_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=clCsEQVCyEUQ7kNvgGRTrNs&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-fp6YqGYe0l