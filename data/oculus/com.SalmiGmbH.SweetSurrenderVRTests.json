489726196039915113_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l4fZV9VtTLQQ7kNvgEIIqO5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCa52Vf_UybZTeuwTyBm9IsnK0GTRia75nmNlspF4rrtQ&oe=66F135AA"}, {"file_name": "Screenshot 3 1440.png", "id": "439146270861179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_439146274194512_3265374891474992569_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v7KKosVMIJsQ7kNvgEwyPIo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEBOpW9qjpadtyN7HdveHWrx3q0oGAcQDZePc6RBhBOA&oe=66F13F3B"}, {"file_name": "7 1440.png", "id": "587557329050301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031421_587557332383634_613148445108165191_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0LOxwt-Ci1gQ7kNvgGvKIZF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlgYCknf8VDpyDRDqvr0BrIglK6A_xCzKgdJ-vCKkyhw&oe=66F15369"}, {"file_name": "8 1440.png", "id": "278301000580045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_278301003913378_4961165780702200385_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=McELXDxU9F0Q7kNvgEa8i1T&_nc_ht=scontent.oculuscdn.com&oh=00_AYDlHFwbbW5hRFUfqFz1JNhhmHbezTxXxIa32wEwtg-SEg&oe=66F15456"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "1632100410468901", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1632100413802234_1726393786771260074_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HxNvA6PYtXAQ7kNvgF5te9B&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_qPtDXQys6fMR6OFevAczqzV27bZ5GNwkKokaAK196A&oe=66F16767"}, "display_name": "Sweet Surrender", "keywords": ["roguelite", "roguelike", "shooter", "fps", "combat"], "long_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n\nUse explosives, melee weapons, guns and upgrades to take down the machines hunting you as you fight your way to the summit through procedurally-generated levels.\n\nAgile Combat - \nUse an array of weapons, tools and explosives to dispatch enemy forces. Blast through walls to uncover secrets, aim for weak points and adapt to the behaviour of your enemy. Zipline across lava, grapple hook through corridors as you gun down machine security forces.\n\nUpgrades and Enhancements - \nDiscover upgrade chips that can heighten your abilities. Gain EMP effects on your weapons, increase your strength and speed, siphon energy from your enemies.\n\nUnlockables and Progression -\nAchieve new milestones the further you advance. Track your personal stats and enemy encounters, catalog messages from those who came before you. Discover new weapon effects, combine upgrades.\n", "short_description": "Sweet Surrender is a Roguelike shooter set in a dystopian megatower where you must adapt to a ruthless, fast-paced action-packed environment.\n"}, {"images": {"nodes": [{"file_name": "CoverImageHero.png", "id": "115634340767631", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_115634344100964_4698064246001205638_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EQiWzUBLf7YQ7kNvgE_7kFF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzTBJz3sWOy-3NwpEE-v88uobxzF_nW56xQ6DK8iebfA&oe=66F14550"}, {"file_name": "CoverImageMiniLandscape.png", "id": "4531926600196916", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_4531926603530249_6962821853766922858_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cT1JIwC0SiEQ7kNvgHHi-NZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDieRMGD6WPHUKZVuKXh_d7ltAuZ2TbM5N2gG-XXMe29Q&oe=66F15E76"}, {"file_name": "CoverImagePortrait.png", "id": "606660833673980", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_606660837007313_7189004430715192244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMFiqjRo-DoQ7kNvgH1_XLg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoPNLsaCC1RPyQC7_ufkNmMmED0hXdh46fTJQfQWeGig&oe=66F14948"}, {"file_name": "CoverImageLandscape.png", "id": "594329141601992", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_594329144935325_3798676971550141837_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2WjOO82AyTYQ7kNvgEdopo_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqQu7ZWcEpMGotZZ5EerKzOBC-_12oToZDeZQbXyu0Dg&oe=66F16CE4"}, {"file_name": "CoverImageSquare.png", "id": "559777915269063", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_559777918602396_6224991975423925847_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aOTlgwFBZGgQ7kNvgHAnDHS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSJWFLCOffFZmEKoUCt-MoQ-E0vSPXaTHSxUE1OOd1VQ&oe=66F162A1"}, {"file_name": "Logo.png", "id": "443595463754143", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_443595467087476_7978473456414610396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IjFbkinS2gUQ7kNvgEjjGeC&_nc_ht=scontent.oculuscdn.com&oh=00_AYD3YqycZooXJdqEpsyNy8hEe_us1lHvCsE6T6xghVIPkA&oe=66F14328"}, {"file_name": "Icon.png", "id": "350115806796631", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_350115813463297_488826976810587709_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CNj4Esfxn2AQ7kNvgFG9ATr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhTWfs109gM0EBAP4EKLoaf4dDdNeovmpJTaLS1Ck_Pw&oe=66F16895"}]}, "id": "2959089641073973", "locale": "es_LA", "screenshots": [{"file_name": "Screenshot1.png", "id": "149961060659239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_149961063992572_3317862938453630568_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KSyF3MWLjaAQ7kNvgGf4NCN&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgPViSKpljBdMxqmwoOyTovSi5wqVhFagh9Uxw2JnRSA&oe=66F135D4"}, {"file_name": "Screenshot2.png", "id": "854916028748159", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_854916035414825_1482957548994953661_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xK2qYHfDG8sQ7kNvgHWw_F8&_nc_ht=scontent.oculuscdn.com&oh=00_AYAiWXIG-kr3TiKn-B2lLVsD5rsNoDMk4WMT7iNWB5Yeog&oe=66F13E48"}, {"file_name": "Screenshot3.png", "id": "3880899298676771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031524_3880899312010103_2182482223037715146_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STijH0U4FrAQ7kNvgHbZeKn&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuzSv1c4pyzd6LjfbfXFlhEfPDK5ePbXAZAMBhmRIfIg&oe=66F15C16"}, {"file_name": "Screenshot4.png", "id": "632541957738951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570295_632541961072284_9041265518534613224_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jyOdlaD13hwQ7kNvgGzF1jw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsieqdk8LL_lzEKvVWJc_ZgSjKPXHxPkf3wpg7Jy0Vpw&oe=66F14C7E"}, {"file_name": "Screenshot5.png", "id": "3118602568465145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003241_3118602571798478_5241911405837164837_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UP1PICdbDGIQ7kNvgGpSuUc&_nc_ht=scontent.oculuscdn.com&oh=00_AYAkG_r1Edlbit0IP7ENfDwjCEjnfuK963vR188Abf7-Qg&oe=66F14925"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageLandscape.png", "id": "3304918962966230", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031337_3304918969632896_7921060189846060168_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PlI0VWabXDEQ7kNvgFYgYrk&_nc_ht=scontent.oculuscdn.com&oh=00_AYCevpw9Kc9YcMzCR0K1q9PMQdx5FbIuSt0fhiU4Gyxhmw&oe=66F16C9E"}, "display_name": "Sweet Surrender", "keywords": ["roguelike", "disparos", "fps", "combate"], "long_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n\nUsa explosivos, armas de mano, pistolas y actualizaciones para derribar las m\u00e1quinas que te persiguen mientras luchas por llegar a la cima pasando los niveles generados por procedimientos.\n\nCombate \u00e1gil: \nusa una variedad de armas, herramientas y explosivos para eliminar las fuerzas enemigas. Atraviesa las paredes con explosiones para descubrir secretos, apunta a los puntos d\u00e9biles y ad\u00e1ptate al comportamiento de tus enemigos. Cruza r\u00edos de lava en tirolesa, usa arpeos para trepar por los corredores mientras reduces a disparos las fuerzas de seguridad de las m\u00e1quinas.\n\nActualizaciones y mejoras: \ndescubre los chips de actualizaci\u00f3n que pueden elevar tus habilidades. Obt\u00e9n efectos EMP para tus armas, aumenta tu fuerza y velocidad, extrae la energ\u00eda de tus enemigos.\n", "short_description": "\"Sweet Surrender\" es un juego de disparos roguelike que se desarrolla en una megatorre dist\u00f3pica, donde debes adaptarte a un entorno despiadado, acelerado y lleno de acci\u00f3n.\n"}, {"images": {"nodes": [{"file_name": "CoverImagePortraitKR.png", "id": "1120975665100000", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_1120975668433333_1316925696992055825_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5bNeqOaIZygQ7kNvgGICSHZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCe2NCVwb1V_3jnlbMK1NZOKzULhfEtVQOt2NEUFZ1-kQ&oe=66F14EA2"}, {"file_name": "CoverImageSquareKR.png", "id": "1038622706922441", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_1038622710255774_8643929694250534637_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f1G9rNq3TTUQ7kNvgFXpsTy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgm57-fjMTwzpX69RAKjxnI6t5wIxcbTGgafY68jIn2Q&oe=66F14072"}, {"file_name": "CoverImageMiniLandscapeKR.png", "id": "979162109598833", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_979162116265499_1764438849254555913_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nCGhiD6Gi7gQ7kNvgGqn7ep&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYc7UyK_Zthd