cb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9XcZEoDEmIQ7kNvgE8Dw_j&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAMXhRI8GmbZdtf0CdGYWH97jvL56J64usUcUAjpB6pAQ&oe=67878580"}, {"file_name": "migrated_image.png", "id": "258673445137195", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974643_386259545323435_5806591867734720512_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HYPDXuiLCqIQ7kNvgGs-Dms&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC7KRUM5Wqp3D-01hHOg7fZNySxN2vB6s4CUijT_nmlcw&oe=67878DA6"}, {"file_name": "migrated_image.png", "id": "1564579483696929", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974461_1112897525577073_4996268960753123328_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LAt6yItqbTMQ7kNvgHkCGbk&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAJyHfankg0QX6maQPIiUizM10RFnif91CsgXC_eScE1w&oe=6787A8B9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/RLecUQ", "id": "456711794899255", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974721_456711798232588_7305697408665518080_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IE9iVfxBPTAQ7kNvgEvOhIE&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAmgzIemU5M4E5p8TxqhlI_lFalmYIxdd6BephdFtvq2Q&oe=6787A433"}, "display_name": "Anne Frank House VR", "keywords": ["Anne", "Frank", "War", "Diary", "Experience"], "long_description": "In 1942, during the Second World War, Anne Frank, a thirteen-year-old Jewish girl and her family were forced to go into hiding to escape persecution from the Nazis. For more than two years, the Franks and 4 others would live in the \u201cSecret Annex\u201d of an old office building in Amsterdam, sharing the burden of living in hiding in confined quarters with the constant threat of discovery. Anne Frank House VR offers a unique and emotional insight into these two years. Experience the world-famous Secret Annex in a never before seen way. Travel back to the years of the Second World War and wander through the rooms of the Annex that housed the group of 8 Jewish people as they hid from the Nazis. Immerse yourself in Anne\u2019s thoughts as you traverse each faithfully recreated room, thanks to the power of VR, and find out what happened to the Annex\u2019 brave inhabitants.", "short_description": "Experience the world-famous \u201cSecret Annex\u201d of the Anne Frank House in a never before seen way. Travel back to the years of the Second World War and wander through the rooms of the Secret Annex, where Anne Frank, her family and four other Jews hid from Nazi persecution during WW2. Immerse yourself in Anne\u2019s thoughts as you traverse each faithfully recreated room, thanks to the power of VR, and find out what happened to the Annex\u2019 brave inhabitants."}]}, "developer_name": "Force Field", "developer_privacy_policy_url": "https://forcefieldxr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.forcefieldxr.com/terms-of-service", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://annefrankhousevr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "es", "pt", "he", "de", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "535852937510727"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "1559598774659827"}, {"status": "PUBLISHED", "id": "2410066772600963"}]}, "baseline_off