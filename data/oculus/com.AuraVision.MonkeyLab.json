ttps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003235_1016803723322364_9102333055484370451_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HMZFfXXt1T8Q7kNvgGO4A2y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtDW-5DbHkszlkFad4mNxhJGmGuQiPCQtP7mAGtaZbOw&oe=67681832"}, {"file_name": "Frame 20.png", "id": "2481507975376796", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210397_2481507978710129_2162693334310625079_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XGXjL9xwFBEQ7kNvgFww3Pm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeAcgWACKR4RVuHgXHNqYpoUXs1YkvtEE3VamHH5GF2g&oe=6767FA2E"}, {"file_name": "Frame 5.png", "id": "461243130295559", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75223484_461243136962225_1456555682535488712_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MtQ9jwN3UmkQ7kNvgG70H3O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_gOAylr0mFpZyx9QA7_VixlmpD1GGy0rfrfvIh-8Yrg&oe=676802F2"}, {"file_name": "Group 427321358.png", "id": "3797133590555494", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272215_3797133593888827_7261517073447716922_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SFHTrZp_-eIQ7kNvgELySCL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKXtPYG-5pAhCzmOWkedwkR5bRimeNz6oCtMbP6bJEZQ&oe=676811D3"}, {"file_name": "Frame 2.png", "id": "8587629007935754", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001707_8587629014602420_567831700586494804_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RzNxH6oYfQQ7kNvgHrwfW6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfLmDHoev4zWd3dn-IRm-rzYcdfiNeOk3hFrELae7TdA&oe=6767F8D6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Group 427321344.png", "id": "1047373087131157", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036648_1047373090464490_2384893340174601244_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TEaWGNa17YoQ7kNvgFtMlqN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqyheWmU48st1bLK81m6iInsvxRT5eNIp-EpKhCAXvKQ&oe=67680840"}, "display_name": "Lab Monkey", "keywords": [], "long_description": "\n\ud83e\uddea **LAB MONKEY: ESCAPE THE MADNESS** \ud83e\uddea\n\nStep into the terrifying world of Lab Monkey, where you play as a monkey trapped in a horror research facility. Explore every corner of the facility, but beware\u2014each step could lead you into one of the many horror experiences hidden behind mysterious portals.\n\n\ud83c\udfad **EXPERIENCE TRUE HORROR** \ud83c\udfad\n\nLab Monkey is more than just a game. It\u2019s the ultimate horror experience. With high-quality graphics, immersive sound design, and a deeply unsettling atmosphere, this is horror like you\u2019ve never seen before.\n\n\ud83d\udee0\ufe0f **MODS & COSMETICS GALORE** \ud83d\udee0\ufe0f\n\nUse any mod that you can think of from Long Arms to Ghost Freeze! New Mods Weekly! Slow your friends down or carry them through different experiences.\n\nCustomize your monkey with a variety of cosmetics to enhance your appearance. Whether you want to blend into the shadows or stand out in style, our in-game shop has something for every monkey.\n\n\u26a1 **CONSTANT UPDATES** \u26a1\n\nWe\u2019re dedicated to bringing you the highest quality monkey horror experience. Expect frequent updates packed with new content, features, and terrifying levels to keep you on the edge.\n\n\ud83d\udd25 **JOIN THE LAB MONKEY MADNESS** \ud83d\udd25\n\nAre you ready to face your fears? Join Lab Monkey now and immerse yourself in the scariest monkey horror experience out there. It\u2019s free to play, but can you handle the terror? Join our Discord to connect with other players and get support: https://discord.gg/wPDFXhXjyJ.", "short_description": "Step into the terrifying world of Lab Monkey, where you're a monkey trapped in a horror research facility. Customize your monkey with unique cosmetics and powerful mods. With high-quality graphics, immersive sound, and frequent updates, this is the ultimate horror experience. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://auravision.xyz/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Aura Vision LLC", "support_website_url": null, "website_url": "https://auravision.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8510212472358698"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035447_8456164944462238_8324641094166490812_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JJFBR26tuI4Q7kNvgGMF0Gi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAP7Gq1GXxS1SxHqolH-bB6VnDek0zThpIfmiJXP2ykiw&oe=6767E844"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Lab Monkey", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Hangout", "id": "1023770785722696"}], "release_date": 1725562080, "lastRevision": {"nodes": [{"id": "8205502342829714", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8205502289496386", "is_first_party": false, "enables_in_app_ads"