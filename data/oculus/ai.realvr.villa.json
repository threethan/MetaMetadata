PEFmCTAzPQ&oe=674D9144"}, {"file_name": "screenshot_3_2560x1440.png", "id": "837285150334022", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031391_837285153667355_5583694166526638160_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fgesJZ_VjioQ7kNvgGpvP-U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCg5dSK5RV706hd-Gw_ZlYea_abzb2Tt03Zorhb5FCew&oe=674DA983"}, {"file_name": "screenshot_4_2560x1440.png", "id": "493746818307559", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974557_493746821640892_1812030317833676803_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GHTiS9oEEV8Q7kNvgGKi9pu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTt0mpI4yRauYv9VmElSaesXsG7okDt1f1teifYpRg8A&oe=674DA935"}, {"file_name": "screenshot_5_2560x1440.png", "id": "1114552522343560", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974453_1114552525676893_1677870913491985454_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dpsn-GsLDigQ7kNvgEftK20&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTvPWXamRiugrreAZG8i7eVSktqTPGzzOFCS15HsyOWg&oe=674DA8C7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "be a superhuman cover image.png", "id": "942148429692825", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974499_942148433026158_7347930193473508401_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-1L7i56QHr4Q7kNvgGYCZy9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbzWA6Tp1F_oPBx-rdl2qj2tE0a9AVSMMjVWgzysBuGQ&oe=674DB954"}, "display_name": "Villa", "keywords": ["among", "team", "fly", "social", "design"], "long_description": "* Standups, roadmapping, happy hours, board meetings, design, 1:1s, and offsites that are out of this world and far better than IRL\n* A creativity platform, much like Zoom + Slack in 3D. Our focus is teams, giving tech professionals superpowers to be their best\n* The answer to \u2018videoconference fatigue\u2019 by putting you in thrilling immersive meeting experiences, giving you the tools to interact, co-invent and play\n* A meeting in VR is multiples more effective than IRL meetings with massive screens, and activities that defy physics like drawing in the air\n* Launched with multiple locations around the world. At the heart of each such micro-universe is your Villa, always the same, and always unique as you personalize it to reflect your team and org\u2019s personality and identity\n* Boost in culture, the glue that holds everyone to a common mission which is tricky in remote\n* Improved camaraderie and positive workplace feelings\n* Big CapEx and OpEx savings to your company relative to IRL meetings", "short_description": "Villa is a VR platform for team collaboration in thrilling immersive environments. For teams of up to 15 simultaneous members per villa. Villas interconnect (feature coming soon) for company wide simultaneous users, giving every team in an organization, from engineering, through product, finance, sales, marketing, partnerships C-Suite and Board professionals, a common space in VR. Come experience standups, strategy, design, roadmapping, 1:1s, offsites and board meetings that are better than IRL!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://app.villa.rocks/privacy", "developer_terms_of_service_url": "https://app.villa.rocks/terms", "publisher_name": "RealVR", "support_website_url": "https://www.villa.rocks/contact", "website_url": "https://www.villa.rocks/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "539527055410505"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"]