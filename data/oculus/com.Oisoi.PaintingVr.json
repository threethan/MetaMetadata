 Final.png", "id": "151130604581798", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974848_151130607915131_4386628654532072698_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0c7SOCboyKsQ7kNvgFeYF_n&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6YaGlbQkpP-oFu2SzwuPPD9UsmeKER3gnL0gZlZb59w&oe=67051409"}]}, "id": "999936457905274", "locale": "en_US", "screenshots": [{"file_name": "Stills_May'23_UI.png", "id": "560254039552163", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422369_560254042885496_462054519402168863_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u1eE4aTJSNwQ7kNvgH3pN-G&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArjyTS03osH2JWxQcdu60m7rprVHcIRQhUu7ciP72qXQ&oe=67052184"}, {"file_name": "Stills_May'23_Doggy.png", "id": "791984432269661", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031575_791984435602994_5762404533638007705_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V-YUPFL9WpAQ7kNvgGKFFZK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQwu8HqKYla_O4fvgGn0d8HPT8jhjHDY5pDodQRh9nqQ&oe=67050762"}, {"file_name": "Stills_May'23_CloseUpBrush.png", "id": "253641880448978", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230048_253641883782311_4318681083896203854_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YF-dPNUnliEQ7kNvgGBuiRk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXldHvBHy2NjLm86XpkmD0fEjrYNO5tOUAGjKk5OPRiw&oe=67050F6C"}, {"file_name": "Stills_May'23_HappyHues.png", "id": "823131322562239", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240098_823131335895571_7345743809290845782_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HuSyPDky3ZgQ7kNvgGwpfVx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZtVWsrbn25Gz1eO2mzDo8HuX0YePyfDuZ5fFm77EF9g&oe=67050559"}, {"file_name": "Stills_May'23_Painting+Envir.png", "id": "788455049219078", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86615891_788455052552411_3926343213990677300_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GMHHJS1IK_AQ7kNvgGkD4Fa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCa94KchnTvrz7H1H1Dx1NAlmEUcXggV0PXFf7nBr91Cw&oe=670518E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 Render Final.png", "id": "963357088178104", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75505859_963357091511437_666998212360027310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NObFfaDDa_EQ7kNvgEEOCVq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4nsNvp_QTnNRoG9yh2lLru4K3JM3-oEAh7Vt-RjDXfg&oe=6704FFF3"}, "display_name": "Painting VR", "keywords": ["art", "creativity", "studio", "social", "relax"], "long_description": "Take a break from the stress of daily life with this must-have virtual painter\u2019s studio. Even if you think you\u2019re not a creative person, Painting VR might prove you wrong. \n\nBe amazed by what you can create in this hands-on experience with unlimited supplies of paint, canvases, and all the tools you need. Play around and feel the satisfaction of putting that first paint stroke on a blank canvas. Learn the basics of colors, the painting process, and composition. Sharpen your skills by experimenting with the tools and techniques at hand. Then display your paintings on the walls and invite your friends to enjoy your exhibition.\n\nFEATURES:\n\n- Realistic Brushes\n- Paint Mixing\n- Undo/Redo\n- In-game Browser\n- Sitting Mode\n- Zero Gravity Mode\n- Colour Picker\n- Customizable Studio\n- In-game Tutorials\n- Import Reference Images\n- Passthrough Mode \n- Meta Avatars 2.0\n- Painting-by-Numbers & Coloring Pages\n\n", "short_description": "Take a break from the stress of daily life with this must-have virtual painter\u2019s studio. Even if you think you\u2019re not a creative person, Painting VR might prove you wrong. \n\nBe amazed by what you can create in this hands-on experience with unlimited supplies of paint, canvases, and all the tools you need. \n"}]}, "developer_name": 