qw&oe=66E2BE59"}, {"file_name": "Stills_May'23_Painting+Envir.png", "id": "788455049219078", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86615891_788455052552411_3926343213990677300_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STA4lLTLijoQ7kNvgFSimlH&_nc_ht=scontent.oculuscdn.com&_nc_gid=Anf8PWLE1CDi90T1KhYaCsF&oh=00_AYDn3aixXR0Uu9Jc5Z9sdGWtJ7Qy8ABm0xzeePRXJ0ZGOg&oe=66E2D1E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 Render Final.png", "id": "963357088178104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75505859_963357091511437_666998212360027310_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BmzZuAhW4JwQ7kNvgEhCxz5&_nc_ht=scontent.oculuscdn.com&_nc_gid=Anf8PWLE1CDi90T1KhYaCsF&oh=00_AYCOeB4XVTYBCI5Vhe7DdS-yUxfj6hpWWAl3u7AG4KtTHw&oe=66E2B8F3"}, "display_name": "Painting VR", "keywords": ["art", "creativity", "studio", "social", "relax"], "long_description": "Take a break from the stress of daily life with this must-have virtual painter\u2019s studio. Even if you think you\u2019re not a creative person, Painting VR might prove you wrong. \n\nBe amazed by what you can create in this hands-on experience with unlimited supplies of paint, canvases, and all the tools you need. Play around and feel the satisfaction of putting that first paint stroke on a blank canvas. Learn the basics of colors, the painting process, and composition. Sharpen your skills by experimenting with the tools and techniques at hand. Then display your paintings on the walls and invite your friends to enjoy your exhibition.\n\nFEATURES:\n\n- Realistic Brushes\n- Paint Mixing\n- Undo/Redo\n- In-game Browser\n- Sitting Mode\n- Zero Gravity Mode\n- Colour Picker\n- Customizable Studio\n- In-game Tutorials\n- Import Reference Images\n- Passthrough Mode \n- Meta Avatars 2.0\n- Painting-by-Numbers & Coloring Pages\n\n", "short_description": "Take a break from the stress of daily life with this must-have virtual painter\u2019s studio. Even if you think you\u2019re not a creative person, Painting VR might prove you wrong. \n\nBe amazed by what you can create in this hands-on experience with unlimited supplies of paint, canvases, and all the tools you need. \n"}]}, "developer_name": "Oisoi Studio", "developer_privacy_policy_url": "https://www.paintingvr.xyz/pages/oisoi-privacy-policy", "developer_terms_of_service_url": "https://www.termsfeed.com/live/b9b579fc-4ffe-4c6d-a7ad-5de1c704c331", "publisher_name": "Oisoi Studio", "support_website_url": null, "website_url": "https://paintingvr.xyz/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6006370662799397"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75307249_338876322166714_1634089093556813204_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iqD9k4GTf2kQ7kNvgFqc5Yv&_nc_ht=scontent.oculuscdn.com&_nc_gid=Anf8PWLE1CDi90T1KhYaCsF&oh=00_AYCsHVCswvm6fEycMzXqG9cCWu9a3x6da6nThg49RS-tow&oe=66E2C0DB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Painting VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name":