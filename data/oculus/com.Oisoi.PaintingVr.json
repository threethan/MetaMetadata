t=scontent.oculuscdn.com&_nc_gid=Alz0IvivWLhPQ31poEuXfDn&oh=00_AYASH-mrBjboolOI80tbcmaKjUX8luMPWRoj-wEk2YgsQA&oe=66F68161"}, {"file_name": "Gamestill_2_2.png", "id": "140060414733186", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254874_140060418066519_404510634789214415_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=heCEZrMkIJwQ7kNvgF-_aJ6&_nc_ht=scontent.oculuscdn.com&_nc_gid=Alz0IvivWLhPQ31poEuXfDn&oh=00_AYCMA2BYMLg6N__iLQuxWDHqpb4002MxQln6yvIjz4El1Q&oe=66F6B20F"}, {"file_name": "Gamestill_2_1.png", "id": "730993767596206", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75292490_730993774262872_7203892228344656958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N1k_5s6yAjYQ7kNvgF3RbL7&_nc_ht=scontent.oculuscdn.com&_nc_gid=Alz0IvivWLhPQ31poEuXfDn&oh=00_AYD5-xOaCb7W5LIvIQSx7-a4DCeje_uwjvc_ZDem3yRCCw&oe=66F6877D"}, {"file_name": "Gamestill_2_3.png", "id": "2939976282883307", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036632_2939976286216640_5800461904326178318_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AzsKY0WiJo0Q7kNvgGQMmjw&_nc_ht=scontent.oculuscdn.com&_nc_gid=Alz0IvivWLhPQ31poEuXfDn&oh=00_AYCCqSB8NLIcPfcjf-m8-aMcetQZ7zQr98y59kv2S0SrQw&oe=66F681D5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Painting VR", "keywords": [], "long_description": "Painting in virtual reality is easy as one two three: mix your colors, dip your brush in and start painting. \n\nThe experience is very hands-on, easy to understand, and aimed at all ages. Play around and feel the relaxing satisfaction of putting unlimited amounts of fresh paint on a huge canvas. Teach yourself the basics of colors, the painting process and composition. Sharpen your skills by experimenting with the tools and techniques at hand, and become part of a new wave of digital artists. All without having to bother about cleaning up afterward. \n", "short_description": "Painting VR is a virtual reality art painting simulation game with gigantic canvases, satisfying brushes, and an unlimited supply of paint. "}]}, "developer_name": "Oisoi.studio", "developer_privacy_policy_url": "https://paintingvr.xyz/privacy-policy-web-1", "developer_terms_of_service_url": null, "publisher_name": "Oisoi.studio", "support_website_url": null, "website_url": "https://paintingvr.xyz/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1062957640944640"}}]}, "scheduled_offers": {"count": 35, "nodes": [{"status": "PUBLISHED", "id": "884438766913325"}, {"status": "PUBLISHED", "id": "7754797444641584"}, {"status": "PUBLISHED", "id": "1619309388904867"}, {"status": "PUBLISHED", "id": "420983540846196"}, {"status": "PUBLISHED", "id": "772694838191706"}, {"status": "PUBLISHED", "id": "1704224099771856"}, {"status": "PENDING", "id": "818840469654476"}, {"status": "PUBLISHED", "id": "1671061373417438"}, {"status": "PUBLISHED", "id": "333965992302242"}, {"status": "PUBLISHED", "id": "1227959461258471"}, {"status": "PUBLISHED", "id": "634021191781279"}, {"status": "PUBLISHED", "id": "141183574568673"}, {"status": "PUBLISHED", "id": "841704000362613"}, {"status": "PENDING", "id": "242827361517802"}, {"status": "PENDING", "id": "501278742111355"}, {"status": "PUBLISHED", "id": "683490159697609"}, {"status": "PENDING", "id": "1361589637951555"}, {"status": "PUBLISHED", "id": "556462262796140"}, {"status": "PUBLISHED", "id": "763463561714574"},