le_name": "Gamestill_2_2.png", "id": "140060414733186", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75254874_140060418066519_404510634789214415_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tz9yOeRzouQQ7kNvgG6rdfJ&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYALMlOZHn4yYWyp-sKIDf883S6N_7kRAmlbBrEwE7OcPQ&oe=6787B70F"}, {"file_name": "Gamestill_2_1.png", "id": "730993767596206", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75292490_730993774262872_7203892228344656958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZH-2XRgIt4UQ7kNvgHDrTpv&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBT7LHSIup18Tv5yByXI0Nueg_dfjLsf1Fe8KEH22DUVQ&oe=67878C7D"}, {"file_name": "Gamestill_2_3.png", "id": "2939976282883307", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39036632_2939976286216640_5800461904326178318_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cav7xnpsU2wQ7kNvgGdFvlL&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDs5a3UK9UwSvoWTmVYH-WNt3X0LEQQNTO9UZRmdyZTOQ&oe=678786D5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Painting VR", "keywords": [], "long_description": "Painting in virtual reality is easy as one two three: mix your colors, dip your brush in and start painting. \n\nThe experience is very hands-on, easy to understand, and aimed at all ages. Play around and feel the relaxing satisfaction of putting unlimited amounts of fresh paint on a huge canvas. Teach yourself the basics of colors, the painting process and composition. Sharpen your skills by experimenting with the tools and techniques at hand, and become part of a new wave of digital artists. All without having to bother about cleaning up afterward. \n", "short_description": "Painting VR is a virtual reality art painting simulation game with gigantic canvases, satisfying brushes, and an unlimited supply of paint. "}]}, "developer_name": "Oisoi.studio", "developer_privacy_policy_url": "https://paintingvr.xyz/pr