tisfying brushes, and an unlimited supply of paint. "}]}, "developer_name": "Oisoi.studio", "developer_privacy_policy_url": "https://paintingvr.xyz/privacy-policy-web-1", "developer_terms_of_service_url": null, "publisher_name": "Oisoi.studio", "support_website_url": null, "website_url": "https://paintingvr.xyz/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1062957640944640"}}]}, "scheduled_offers": {"count": 35, "nodes": [{"status": "PUBLISHED", "id": "884438766913325"}, {"status": "PUBLISHED", "id": "7754797444641584"}, {"status": "PUBLISHED", "id": "1619309388904867"}, {"status": "PUBLISHED", "id": "420983540846196"}, {"status": "PUBLISHED", "id": "772694838191706"}, {"status": "PUBLISHED", "id": "1704224099771856"}, {"status": "PENDING", "id": "818840469654476"}, {"status": "PUBLISHED", "id": "1671061373417438"}, {"status": "PUBLISHED", "id": "333965992302242"}, {"status": "PUBLISHED", "id": "1227959461258471"}, {"status": "PUBLISHED", "id": "634021191781279"}, {"status": "PUBLISHED", "id": "141183574568673"}, {"status": "PUBLISHED", "id": "841704000362613"}, {"status": "PENDING", "id": "242827361517802"}, {"status": "PENDING", "id": "501278742111355"}, {"status": "PUBLISHED", "id": "683490159697609"}, {"status": "PENDING", "id": "1361589637951555"}, {"status": "PUBLISHED", "id": "556462262796140"}, {"status": "PUBLISHED", "id":