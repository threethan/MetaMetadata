F4uDNhe6cicJzOkjkQV3u64CbSSyIrhLg&oe=6706840F"}, {"file_name": "Gamestill_2_1.png", "id": "730993767596206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75292490_730993774262872_7203892228344656958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IxPlvkSKwpwQ7kNvgHLyg8g&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxUN__NxyaOhF0KmfMZfVwvjXh2LT9JvejKWRDjKEjlQ&oe=6706597D"}, {"file_name": "Gamestill_2_3.png", "id": "2939976282883307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_2939976286216640_5800461904326178318_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ls2t8TmGpYEQ7kNvgGnOF4c&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDri_DnPuGabtMSB2QRems6Fny8f8vB46mUGoNPsLoX0g&oe=670653D5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Painting VR", "keywords": [], "long_description": "Painting in virtual reality is easy as one two three: mix your colors, dip your brush in and start painting. \n\nThe experience is very hands-on, easy to understand, and aimed at all ages. Play around and feel the relaxing satisfaction of putting unlimited amounts of fresh paint on a huge canvas. Teach yourself the basics of colors, the painting process and composition. Sharpen your skills by experimenting with the tools and techniques at hand, and become part of a new wave of digital artists. All without having to bother about cleaning up afterward. \n", "short_description": "Painting VR is a virtual reality art painting simulation game with gigantic canvases, satisfying brushes, and an unlimited supply of paint. "}]}, "developer_name": "Oisoi.studio", "developer_privacy_policy_url": "https://paintingvr.xyz/privacy-policy-web-1", "developer_terms_of_service_url": null, "publisher_name": "Oisoi.studio", "support_website_url": null, "website_url": "https://paintingvr.xyz/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "co