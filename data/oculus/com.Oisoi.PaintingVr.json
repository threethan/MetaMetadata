sHHFnwoZc0TliUNvj4usDsuDDw&oe=671776E1"}, {"file_name": "Gamestill_2_2.png", "id": "140060414733186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75254874_140060418066519_404510634789214415_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q13nKi1QkpwQ7kNvgGtWRp4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqUYPLsopbqu810DOy7gQWk1BNAmNvCBs6MK6_yQj3ew&oe=6717A78F"}, {"file_name": "Gamestill_2_1.png", "id": "730993767596206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75292490_730993774262872_7203892228344656958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aNsNOWsrcDEQ7kNvgF5tFBm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXI5F8zrfFRqD3GJybebBSdir0j6mOBsGLTTWpG9Rvfw&oe=67177CFD"}, {"file_name": "Gamestill_2_3.png", "id": "2939976282883307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036632_2939976286216640_5800461904326178318_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CjPlheMjZakQ7kNvgH3EN49&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAzTUjeTcbRJ_1cqk7AiT4Pzu4EMKRUHcvf5tmzDjKr0w&oe=67177755"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Painting VR", "keywords": [], "long_description": "Painting in virtual reality is easy as one two three: mix your colors, dip your brush in and start painting. \n\nThe experience is very hands-on, easy to understand, and aimed at all ages. Play around and feel the relaxing satisfaction of putting unlimited amounts of fresh paint on a huge canvas. Teach yourself the basics of colors, the painting process and composition. Sharpen your skills by experimenting with the tools and techniques at hand, and become part of a new wave of digital artists. All without having to bother about cleaning up afterward. \n", "short_description": "Painting VR is a virtual reality art painting simulation game with gigantic canvases, satisfying brushes, and an unlimited supply of paint. "}]}, "developer_name": "Oisoi.studio", "developer_p