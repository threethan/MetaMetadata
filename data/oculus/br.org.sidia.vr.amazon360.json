8uGei6hToRknUiozNGujiaV5Px0vpupbLImA&oe=6729EEFB"}, {"file_name": "migrated_image.png", "id": "587022662024182", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/11162743_856263527857390_1548916157858185216_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1E3KFt4luEQ7kNvgEEjBea&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYA0Q-ZLHEJpr8sUQ5m_OTd4UVU_eqVD0PifGj76_oi89w&oe=672A1919"}, {"file_name": "migrated_image.png", "id": "643433519843689", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/11162717_142097426377667_7169781802783997952_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=otGd-O_EyvkQ7kNvgEnPnCU&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYC-98PgIe1H89e4sPo2VxiXedYT7s61YQ-KbGs47ArF_w&oe=6729FDE4"}, {"file_name": "migrated_image.png", "id": "202769467648114", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/11162753_362544220815661_7289903370809114624_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-__FgdmcaAAQ7kNvgEfe9rJ&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBTm-L9xSYW1jEHNCz2U6XSXfpzwnH3eM66EBV6ME_uug&oe=672A1347"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Amazon Sights", "keywords": ["amazon", "brazil", "sidia"], "long_description": "Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images.", "short_description": "Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images."}]}, "developer_name": null, "developer_privacy_policy_url": "http://amazon360.sidialab.com/eula.html", "developer_terms_of_service_url": "http://amazon360.sidialab.com/eula.html", "publisher_name": "SIDIA", "support_website_url": null, "website_url": "http://amazon360.sidialab.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EDUCATIONAL", "EXPLORATION", "MOVIE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pt_BR", "es_CO"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "719317025899422"}, "review_messages": ["", "logo transparent needed changes", "", "Thank you for making all of the changes we requested. One final thing you should update is your description. Currently it reads: \"This application allows the user to explore many attractions in Brazilian Amazon, view HD regular images, 360\u00ba images and 360\u00ba videos from any of available tourist attraction.\"  I would recommend something along the lines of \"Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images.\"  That is an example. You are welcome to offer another description. ", "1.)\tThe app runs at a constant 60 FPS, back button behaves as expected; all technical requirements are met except for one \u2013 You need to implement entitlement check.\n2.)\tVR should be removed from the name of your app (all of the titles on our store are VR, it is redundant)\n3.)\tPeople will download this experience thinking that you will be taken into the Amazon. Please rename the app Amazon Sightseeing, Amazon Sights, or something like that. Please fix this. \n4.)\tI noticed that the head lock turned on while in the Photos section of the app twice in an S7. Please fix that. \n5.)\tPlease change the description of \"360 Images\" to \"360 Image\" since I only saw one 360 image per section. That is, unless you plan to add additional 360 images in each section.\n6.)\tThe initial loading bar flashes red, this feels off; red implies something went wrong. We suggest replacing the red loading bar with the text \u201cLoading\" \n7.)\tWe always like to see controller support added. That said, the gaze controller is implemented very well here. \n", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/11162684_1109143952562482_4546187127213260800_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4CRCjEaSdT4Q7kNvgFt99IO&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBWwaWKny-rMj42yCAmRVoziRmlWr5IySuzpAcI6BOqng&oe=672A0B83"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Amazon Sights", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1506617700, "lastRevision": {"nodes": [{"id": "1919824694924030", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1598126356885122", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "412322005829752"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2231381690504044", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/11162676_342332286219270_232615669269528576_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MB03CexTDLwQ7kNvgEuqvGd&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAoddxdAZBQKcjaqZcYu1vVLeXTFGgM1lW__LLudWlh8w&oe=672A1824"}, {"file_name": "migrated_image.png", "id": "1795172280618373", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/11162704_1673241579376046_6783087785248030720_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hA66ysVYZukQ7kNvgEex1qW&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCJtwhxclvs2AoahICgI0obre62bIYNFhTAvi_M0oPwgg&oe=672A1BA9"}, {"file_name": "migrated_image.png", "id": "552344235487580", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64