885HcxKahT9Kutc_kqE89ePe5Oq_Ri-Q9HoA&oe=67502A7B"}, {"file_name": "migrated_image.png", "id": "587022662024182", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162743_856263527857390_1548916157858185216_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OwIr_777f_sQ7kNvgFaEAed&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW9W6I1P_NJ1rHmThKvZZixd_mmspPBm_XmuGO2rYv0w&oe=67505499"}, {"file_name": "migrated_image.png", "id": "643433519843689", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162717_142097426377667_7169781802783997952_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VD0p_NsDmkQ7kNvgF1SOU-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCq644UrgX62Pi_vPPu2y3O9kXRg0ZYVP0AFh_ynGQ9Mg&oe=67503964"}, {"file_name": "migrated_image.png", "id": "202769467648114", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162753_362544220815661_7289903370809114624_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AN_xwn0a990Q7kNvgFFOX9M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCitKvmSC2QTMF7PL5RMlE4Dbw7WpHs2yBNmLG9iVc0ZQ&oe=67504EC7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Amazon Sights", "keywords": ["amazon", "brazil", "sidia"], "long_description": "Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images.", "short_description": "Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images."}]}, "developer_name": null, "developer_privacy_policy_url": "http://amazon360.sidialab.com/eula.html", "developer_terms_of_service_url": "http://amazon360.sidialab.com/eula.html", "publisher_name": "SIDIA", "support_website_url": null, "website_url": "http://amazon360.sidialab.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EDUCATIONAL", "EXPLORATION", "MOVIE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pt_BR", "es_CO"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "719317025899422"}, "review_messages": ["", "logo transparent needed changes", "", "Thank you for making all of the changes we requested. One final thing you should update is your description. Currently it reads: \"This application allows the user to explore many attractions in Brazilian Amazon, view HD regular images, 360\u00ba images and 360\u00ba videos from any of available tourist attraction.\"  I would recommend something along the lines of \"Explore and get a taste of the many attractions in the Brazilian Amazon with rich 360 videos and images.\"  That is an example. You are welcome to offer another description. ", "1.)\tThe app runs at a constant 60 FPS, back button behaves as expected; all technical requirements are met except for one \u2013 You need to implement entitlement check.\n2.)\tVR should be removed from the name of your app (all of the titles on our store are VR, it is redundant)\n3.)\tPeople will download this experience thinking that you will be taken into the Amazon. Please rename the app Amazon Sightseeing, Amazon Sights, or something like that. Please fix this. \n4.)\tI noticed that the head lock turned on while in the Photos section of the app twice in an S7. Please fix that. \n5.)\tPlease change the description of \"360 Images\" to \"360 Image\" since I only saw one 360 image per section. That is, unless you plan to add additional 360 images in each section.\n6.)\tThe initial loading bar flashes red, this feels off; red implies something went wrong. We suggest replacing the red loading bar with the text \u201cLoading\" \n7.)\tWe always like to see controller support added. That said, the gaze controller is implemented very well here. \n", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162684_1109143952562482_4546187127213260800_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ID_B8Q9k5nQQ7kNvgF73CVU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBU_lJf8J8ngfOMYTAkk1fqLGECOUwyMhw0hCJe35a49Q&oe=67504703"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Amazon Sights", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1506617700, "lastRevision": {"nodes": [{"id": "1919824694924030", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1598126356885122", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "412322005829752"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2231381690504044", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162676_342332286219270_232615669269528576_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MVHoxfGCEuoQ7kNvgGk3ABN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCEjGWOoDN-s46aPVZdFWpe_M2g24Vw6JJ2pUagvlAwSQ&oe=675053A4"}, {"file_name": "migrated_image.png", "id": "1795172280618373", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162704_1673241579376046_6783087785248030720_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRZgAM0IDGoQ7kNvgHpwtXL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5UrX3ONx-G29biVYPX9597Dn3LmhJSRbT_74haA5eag&oe=67505729"}, {"file_name": "migrated_image.png", "id": "552344235487580", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64