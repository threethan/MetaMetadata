culuscdn.com&oh=00_AYAeiBP3vxcqMUL01sVxO5sB1tcbfi1Bfcds0t1LaxUNwQ&oe=672DE5CE"}, {"file_name": "screen_sokvr_02_oculus_01.png", "id": "423564452686121", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569471_423564456019454_6075983626657630026_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aq7UHO_8OEMQ7kNvgGUoL5s&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmA-BKZZT4uDuZdSKezBy4ykonWV8qqHiJE4VphBNbPQ&oe=672DE873"}, {"file_name": "screen_01_new.png", "id": "425942522539228", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314850_425942525872561_8731403744628156232_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ldxfjSKzDs0Q7kNvgG9e7NF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAs66IFkuRb15QTsmwFkh_2D1QZA4sr_cEPmkaQ4Hesw&oe=672E085B"}, {"file_name": "09_1 (1).png", "id": "421516019412520", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86871412_421516026079186_5482313555239614817_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ziu1eWZgWFYQ7kNvgFq8sM4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqAfbu-8o8zJwEIjROVAOcR3vr59h62OKkhYkMZxDQKg&oe=672DF00E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_01.png", "id": "1216932768802893", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75240098_1216932772136226_1608278777529706391_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ChXMCIu_UkQ7kNvgEU1R_7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNfa7CeERATrmBSHwnhNXaJnuBdi0x5pjB5glEI3Qtpg&oe=672DECCA"}, "display_name": "Return to Kurgansk", "keywords": [], "long_description": "A long time ago, the search for an endless source of energy led to a disaster, now the lands around Kurgansk are infected and cursed and the locals have lost their minds.\nYou have fallen into these mad places by mistake and are trying to find your way back, while hundreds of evil monsters stop you from doing it.\nA stranger helps you by giving out instructions on the walkie-talkie, but can you trust them?\n\nGame features:\n\n* Huge open and diverse world, completely changing with the onset of the night;\n* A mesmerizing VR horror game where you can truly experience fear for your life;\n* A powerful system for crafting weapons and equipment will help you to survive;\n* Mysteries of the zone will drive you crazy;\n* Deadly anomalies can lie in wait anywhere;\n* There is an option to act as a ninja, killing local monsters with W-shaped transformer plates.\n\nDon\u2019t be afraid to make a mistake and fail.\nRemember that death is just the beginning in Shadows of Kurgansk!", "short_description": "Return to Kurgansk is a stylish VR horror game focused on survival in a post-Soviet, post-apocalypse setting."}]}, "developer_name": null, "developer_privacy_policy_url": "https://gaijin.net/en/privacypolicy", "developer_terms_of_service_url": "https://gaijin.net/en/termsofservice/", "publisher_name": "Gaijin Distribution Kft", "support_website_url": null, "website_url": "https://gaijindistribution.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "574303987393604"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "4913187042049625"}, {"status": "PUBLISHED", "id": "1036768087186006"}]}, "baseline_offer": {"id": "4913187042049625"}, "is_approved": true, "firstOffer": {"nodes": [{"start_