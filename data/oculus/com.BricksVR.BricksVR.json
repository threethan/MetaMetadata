jrSKNVGYIEkPjlkCUww&oe=66D198FB"}, "display_name": "BricksVR", "keywords": [], "long_description": "BricksVR is a multiplayer sandbox building game in VR in early access.\n\n- Invite friends to a shared world and build creations together. Shared worlds include voice chat, physics, and the ability to save progress.\n- You're not limited by what's in the box in BricksVR. Place thousands of bricks on mobile VR with no lag, and choose from over 16 million brick colors.\n- Wander around your builds from the perspective of a miniature person, or stomp around and chase others as a giant!\n- Open your world to the public to show off your creations. You can also lock your world so visitors can't make changes.", "short_description": "BricksVR is a multiplayer sandbox building game in VR in early access."}]}, "developer_name": null, "developer_privacy_policy_url": "https://bricksvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "BricksVR Studios Inc.", "support_website_url": null, "website_url": "https://bricksvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ART_CREATIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "454232459568442"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974781_1151057708650253_8305288702707347772_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6NgooH0q1kQ7kNvgEWJ-iI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwG