58726849782110_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cywW7e8QQhoQ7kNvgG9vmOz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2uDK34JGALldMDFYeQoumwEyj_3k52-0g1uJXnVrxZA&oe=673326A8"}, {"file_name": "n674m74.png", "id": "798831032207617", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569428_798831035540950_2899688929131012970_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BtImeW4O9r4Q7kNvgG-B4o7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2f98vRA4evpyfR8Ref9eID1u2XokErr-Ne8suJT3H1A&oe=6733436D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "CrazyMonkey", "keywords": [], "long_description": "CrazyMonkey \n\nCrazyMonkey is a game where you are a Monkey and you do crazy things.\nYou can play with friends or with strangers.\nHave fun or not what ever you like the most.\nYou walk with your Arms, no legs so you can skip leg day.\nExplore the map with your friends, and look at your new cosmetics.\nClimb on trees, walk on the ground or do the parkour for free cosmetics.", "short_description": "CrazyMonkey\n\n- Have fun.\n- Hang out with friends.\n- Find new friends\n"}]}, "developer_name": "Sxraphin", "developer_privacy_policy_url": "https://sites.google.com/view/crazymonkeyprv/startseite", "developer_terms_of_service_url": null, "publisher_name": "Sxraphin", "support_website_url": null, "website_url": "https://sites.google.com/view/crazymonkeyweb/startseite", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported