r8-2.oculuscdn.com/v/t64.5771-25/38974805_1350226065334163_1065864042677638636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZlqfguDdmPgQ7kNvgGHBRLF&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYClDn-UZzvqlSqLd-xBg5oRnR9xwJ1j-NDw02_RLUpjvQ&oe=672A0A16"}, {"file_name": "screenshot_5.png", "id": "3754276174640638", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39036704_3754276177973971_6300334187211752958_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLcBgOTC6y8Q7kNvgGlEys3&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCYJVhiQO0HeDdJc35fDw0tEQPjVQJ3sHjWf-IUmm88Ow&oe=672A0366"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover_2560x1440.png", "id": "763112647971999", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974914_763112651305332_1577427146239561671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S-5VbqGAnmUQ7kNvgHn9gGo&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDsgmoI95C4d0rR2sDOw1yBeFOI-Sw6rprxGzH2r34zCw&oe=6729F1DE"}, "display_name": "Unstung", "keywords": [], "long_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!\n\nUnstung will make you feel like a really busy queen bee! You'll be buzzing and zigging all around the meadow to keep your little bees working. There are many ways to play - you could collect a huge swarm of hundreds of bees, and zoom around eliminating bugs - or you could set up a busy network of pollination to keep your flowers in tip-top shape!\n\nWell, what are you waiting for - the bees need you!", "short_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control th