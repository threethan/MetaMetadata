dn.com/v/t64.5771-25/39036704_3754276177973971_6300334187211752958_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zlptr6OO0g4Q7kNvgHLOK_b&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBLA6WBSkTeh0xkZCRkBlR3mUX4AkrYQGsRX-3FN6F39w&oe=671A3166"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover_2560x1440.png", "id": "763112647971999", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974914_763112651305332_1577427146239561671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j81tDOLqXuYQ7kNvgHOtyVZ&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYADaKV39pFj9eWaqFYwpUTxVGdm_dLvxzYaGvombgGn8w&oe=671A1FDE"}, "display_name": "Unstung", "keywords": [], "long_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!\n\nUnstung will make you feel like a really busy queen bee! You'll be buzzing and zigging all around the meadow to keep your little bees working. There are many ways to play - you could collect a huge swarm of hundreds of bees, and zoom around eliminating bugs - or you could set up a busy network of pollination to keep your flowers in tip-top shape!\n\nWell, what are you waiting for - the bees need you!", "short_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!"}]}, "developer_name": "Thaum Games", "developer_privacy_policy_url": "https://thaum.co/privacy.html", "developer_terms_o