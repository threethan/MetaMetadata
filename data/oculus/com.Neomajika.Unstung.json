H5gqhE&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYBTAGYKu1EGiAE3BHUxX0isqtThsUPu08zss2IS5lXKlA&oe=66E4375B"}, {"file_name": "screenshot_4.png", "id": "1350226062000830", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974805_1350226065334163_1065864042677638636_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g1sIRzgj47UQ7kNvgG7B9-z&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYBqQfsYzKLPX96uuNecs_LJ39HAlh7XER422S-xegwc5g&oe=66E42A96"}, {"file_name": "screenshot_5.png", "id": "3754276174640638", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036704_3754276177973971_6300334187211752958_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ORVYl2a_ueAQ7kNvgHsKPSy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYDVMhbKCy-sDitYOyBFn3_ZIDqiD0xI-DF6UnHQJrPZCA&oe=66E423E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover_2560x1440.png", "id": "763112647971999", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974914_763112651305332_1577427146239561671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KA43FB0cgvMQ7kNvgGH9B0X&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYDcoeJ3IL7CozEngrujpdIPbERiCq9QpdvQ4m6-8U6p_g&oe=66E4125E"}, "display_name": "Unstung", "keywords": [], "long_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!\n\nUnstung will make you feel like a really busy queen bee! You'll be buzzing and zigging all around the meadow to keep your little bees working. There are many ways to play - you could collect a huge swarm of hundreds of bees, and zoom around eliminating bugs - or you could set up a busy network of pollination to keep your flowers in tip-top shape!\n\nWell, what are you waiting for - the bees need you!", "short_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://neomajika.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Neomajika Games", "support_website_url": "https://neomajika.com/support/", "website_url": "https://neomajika.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "899672407413233"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "543518261339589"}, {"status": "PUBLISHED", "id": "643184704278445"}, {"status": "PUBLISHED", "id": "669826550657482"}, {"status": "PUBLISHED", "id": "3811518062219191"}]}, "baseline_offer": {"id": "643184704278445"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "543518261339589"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6693026810805643", "version": "1.5