.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYBqQfsYzKLPX96uuNecs_LJ39HAlh7XER422S-xegwc5g&oe=66E42A96"}, {"file_name": "screenshot_5.png", "id": "3754276174640638", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036704_3754276177973971_6300334187211752958_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ORVYl2a_ueAQ7kNvgHsKPSy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYDVMhbKCy-sDitYOyBFn3_ZIDqiD0xI-DF6UnHQJrPZCA&oe=66E423E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover_2560x1440.png", "id": "763112647971999", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974914_763112651305332_1577427146239561671_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KA43FB0cgvMQ7kNvgGH9B0X&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYDcoeJ3IL7CozEngrujpdIPbERiCq9QpdvQ4m6-8U6p_g&oe=66E4125E"}, "display_name": "Unstung", "keywords": [], "long_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!\n\nUnstung will make you feel like a really busy queen bee! You'll be buzzing and zigging all around the meadow to keep your little bees working. There are many ways to play - you could collect a huge swarm of hundreds of bees, and zoom around eliminating bugs - or you could set up a busy network of pollination to keep your flowers in tip-top shape!\n\nWell, what are you waiting for - the bees need you!", "short_description": "Command a swarm of cute bees as they grow & defend flowers against an army of hungry bugs.\nYou control the Queen, buzzing near bees to select them, drawing zig-zag lines through the air for the bees to follow. Help the meadow bloom by bringing pollen to flowers, making new bees, and always - protecting the hive from the evil, nosy Lord Mothmer and his bug minions!"}]}, "developer_name": "Thaum Games", "developer_privacy_policy_url": "https://thaum.co/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Thaum Games", "support_website_url": null, "website_url": "https://thaum.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6415693448538982"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001692_1683649971845803_1692542267886616977_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X0JkBFQ4jK0Q7kNvgFxpibz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2LRKgLoDds7F_F_yknEoF-&oh=00_AYCAu6aLmpxa6T3ZMq-O2OkCCFDBsGgc6DywanIkhhP1_A&oe=66E42FC9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Unstung", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1618286131, "lastRevision": {"nodes": [{"id": "417184366053901", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3547359935372362", "is_first_party": false, "enables_in