25/38974853_397376573290125_7910228700122213904_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Im4uQKYqPP8Q7kNvgGaeM5D&_nc_ht=scontent.oculuscdn.com&oh=00_AYBs4u9VMe0hyrQ0eTvSIsDCtk-UCl4N6zmmM2c7qpGJ4Q&oe=66FBC7D3"}]}, "id": "1510766013190664", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2024-07-03 134825.png", "id": "1029499778541821", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974574_1029499781875154_759075142631951162_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vObDiXkMc30Q7kNvgF9AUtO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbb-Y2lB9JFfrGb1W4XgoW7FbPDV6-5faKJdFzQdQ3oQ&oe=66FBE45E"}, {"file_name": "Screenshot 2024-07-03 134852.png", "id": "1003853544474294", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982458_1003853547807627_1263036491581981934_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nPzX0LeLoK4Q7kNvgH1AqRe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGER01OqqacVB3kDskem15U9R28rkGwxrkY5TTkM6wFg&oe=66FBDF6C"}, {"file_name": "Screenshot 2024-07-03 134901.png", "id": "3828440627476214", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_3828440630809547_3216889243589096543_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YPCJF8rX_dcQ7kNvgGgOwX7&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3iFfT5N_q_Y8xFwC7iiSKxJVfroTnWhHIPjOgD_0HVw&oe=66FBCD5D"}, {"file_name": "Screenshot 2024-07-03 134937.png", "id": "431588669847693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036607_431588673181026_7983592236454687_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tqIRiovdXiMQ7kNvgH7NczS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDikaIMQHUVJNZvA8OAau3rD0sGzJhVGKIIN6SzlUnUBQ&oe=66FBF734"}, {"file_name": "Screenshot 2024-07-03 134956.png", "id": "1136487730892746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_1136487737559412_348304797268477883_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ilT9qNFTke0Q7kNvgFgH12b&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_JGfN9wvS-UzNWnBzRMH9psM4eQ9NDJGqKl6uCiQ_Vw&oe=66FBCE6D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Munki V3", "keywords": [], "long_description": "Welcome to Munki 3! We're thrilled to have you join us on this adventure. Sadly, our previous version had to bid farewell due to a mishap with the APK, but fear not, for we're back and better than ever! Get ready for a slew of updates in the pipeline, promising more excitement and thrills than ever before. Explore new maps, traverse through dense forests, and brace yourself for the spine-chilling horror that awaits in our yet-to-be-finished horror mode.\n\nBut remember, amidst all the excitement, we uphold certain values to ensure everyone has a great time. Cheating? Absolutely not allowed. Toxic behavior? Not here. Harassment? Absolutely out of the question. We're all about creating a welcoming and enjoyable environment for all players.\n\nSo, buckle up, grab your gear, and get ready to embark on an epic journey filled with challenges, mysteries, and endless fun. Welcome to Munki V3\u2014where the adventure never ends!", "short_description": "Munki is a game thats beem waited on by many!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mikeike-inc/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "DominicDev/Munki V3 Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/mikeike-inc/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "sup