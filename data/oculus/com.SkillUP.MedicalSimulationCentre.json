422_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=KAHa5yAgC2EQ7kNvgGPmhXZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiJ-Q6bbopfN79sQP2pwUdX&oh=00_AYCXgAls8hAhMRP8mYueqKGMJ8df7KqvBs43geysxp0cUg&oe=66D1C517"}, {"file_name": "Screenshot2.png", "id": "206633079150188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_206633082483521_6847252536811318740_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cUzNeHhx-JcQ7kNvgF5px6b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiJ-Q6bbopfN79sQP2pwUdX&oh=00_AYD3tCDdBXGdUjqIK2INP81AcHQxou0_M4fEBa8FUZDImA&oe=66D1A1B5"}, {"file_name": "Screenshot3.png", "id": "3800894513519424", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974650_3800894520186090_5070919904212258566_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5ijgK96sYMQ7kNvgGTsUc4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiJ-Q6bbopfN79sQP2pwUdX&oh=00_AYACwx4R4kxKY328E2GV4_6NKPyatmm5lxKS5NmRT8WfgQ&oe=66D198D4"}, {"file_name": "Screenshot4.png", "id": "6713938438724378", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974606_6713938442057711_7577163229189009914_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7HebbLkJrYYQ7kNvgEMVgH_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiJ-Q6bbopfN79sQP2pwUdX&oh=00_AYC5hUQDXhxWZE-1OXrBYsURLJb-BNFEroaKCZm1iz8IBw&oe=66D19394"}, {"file_name": "Screenshot5.png", "id": "204333212714992", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982553_204333219381658_7265425808697674651_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1apVCNAnD-UQ7kNvgFOmL0G&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiJ-Q6bbopfN79sQP2pwUdX&oh=00_AYCJzd8pmfMqqFwx4te_W0LEOz3RmhhyGefE5wOVsCalWg&oe=66D1B199"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Skillup Medical Simulation Centre", "keywords": [], "long_description": "Skillup Medical Simulation Centre is clinically developed to deliver a dynamic and engaging learning experience.  Complete with scenario customizer, responsive patient, medical tools, drugs, images and adjustable patient vitals, all supported by hand-tracking, users are able to practice scenarios of different complexities, across disciplines and specialties.  \n\nYou are welcome to download and login using your business email address.  Once your email is verified, you will be given access to our trial version.  \n\nTo access Skillup Medical Simulation Centre and its full suite of features including multi-player access, Avatar Customizer, Scenario Customizer, Facilitator Station, and Learning Management System, please submit request via https://skillupvr.com/request-for-a-demo/.  For more information, please visit https://skillupvr.com/.  ", "short_description": "Skillup VR Medical Simulation Centre is a virtual facility designed to mimic the conventional simulation center, with the aim to provide easier access to on-demand medical simulations using fewer resources, for enhanced safety of healthcare procedures."}]}, "developer_name": null, "developer_privacy_policy_url": "https://skillupvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Skillup AS", "support_website_url": null, "website_url": "https://skillupvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25126258710306953"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1222823995796656"}]}, "baseline_offer": {"id": "1222823995796656"}, "is_approved": t