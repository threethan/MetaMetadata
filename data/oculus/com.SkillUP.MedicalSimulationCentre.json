ing, users are able to practice scenarios of different complexities, across disciplines and specialties.  \n\nYou are welcome to download and login using your business email address.  Once your email is verified, you will be given access to our trial version.  \n\nTo access Skillup Medical Simulation Centre and its full suite of features including multi-player access, Avatar Customizer, Scenario Customizer, Facilitator Station, and Learning Management System, please submit request via https://skillupvr.com/request-for-a-demo/.  For more information, please visit https://skillupvr.com/.  ", "short_description": "Skillup VR Medical Simulation Centre is a virtual facility designed to mimic the conventional simulation center, with the aim to provide easier access to on-demand medical simulations using fewer resources, for enhanced safety of healthcare procedures."}]}, "developer_name": null, "developer_privacy_policy_url": "https://skillupvr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Skillup AS", "support_website_url": null, "website_url": "https://skillupvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25126258710306953"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1222823995796656"}]}, "baseline_offer": {"id": "1222823995796656"}, "is_approved": true, "firstOffer": {"nodes": [{"sta