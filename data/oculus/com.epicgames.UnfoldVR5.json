ocale": "en_US", "screenshots": [{"file_name": "newSS03.png", "id": "8109082935839208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974689_8109082945839207_1895842965746061433_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vR3E53OYbBQQ7kNvgFOqkFl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYBrGgQtD_m7PTCw3No2EGKtLWw3E03so9XCO-QLlLkuuQ&oe=66E963E5"}, {"file_name": "newss02.png", "id": "506025802126748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982638_506025805460081_1899308060033542616_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qBbX1RyjTTYQ7kNvgErgvWa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYCkqp1c-ZOu8aDofoZM5i20DmKKdA2VYvr7aJGIBWgsJA&oe=66E96071"}, {"file_name": "newss05.png", "id": "1027202568548506", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982685_1027202571881839_6779034663964375430_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ROE-Hy67oVgQ7kNvgEU0UQ5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYCUgWBldQwatGne7vYI9xyp_H1A-w5BFjW-hVqOmVIH6g&oe=66E978F0"}, {"file_name": "newss04.png", "id": "8010643942306832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031554_8010643952306831_1755293534683580490_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7n2oqPHmlvsQ7kNvgHn98hC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYDQM-jnnuMpBciVOGXvq6Im2KaYEPlJmAcSezb1G9l3Dw&oe=66E9752B"}, {"file_name": "newss01.png", "id": "404400382667184", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031507_404400386000517_8797874923727848035_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=v7sk6Qq0mDgQ7kNvgELedAy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYBjdwwpv3oCyn-ghz6qUKqwrXuTCoJPOnmZa35lUhxaOQ&oe=66E96367"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnailMeta.png", "id": "3656462257929226", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_3656462261262559_183363431045022422_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v9qzKjpK7YMQ7kNvgESMQm1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AaMDKO-s1U6YlmJMQCwDAZw&oh=00_AYAIr_ixAG27qpWheQ_lnGw2aDh9x-aZ8-E-QyW1VoFg6A&oe=66E95822"}, "display_name": "UnfoldVR", "keywords": ["voxel", "sandbox", "creative", "drawing", "blocks"], "long_description": "UnfoldVR is a Social VR Drawing App. \n\nBecome a VR Storyteller. Using the versatile Remix Drawing Feature you can add linked iterations of any Artwork. Piece together multiple drawings to tell your Story! Invite your audience to join in.\n\nAll Published Drawings are instantly available for others to explore on the Explore Page. You can Like, Love or Dislike another drawing and also Remix it and make it your own. \n\nSuper Easy, Super Intuitive. We designed our drawing tools to be as logical as possible making drawing voxels a breeze. We're also actively listening to our community and taking feedback seriously. Join our discord to follow up on our development progress and leave any feedback our way. \n\nWe're actively developing UnfoldVR. The goal is to create a social sandbox platform. Where you create & explore amazing worlds, compete with others in interactive adventures and connect with people who share your passions!\n\nUnfoldVR. Cubes Just Got Awesome!", "short_description": "UnfoldVR is a collaborative playground for Spatial Creators and Explorers!\n\nIt's a very fast way to Create and Share voxel 3D models with the world! In minutes you can have your  Voxel art published or exported as .obj file.\n\nBuild using super simple, intuitive tools, dive right into the fun. Not sure what to build? Remix the best creations with your twist. \n\nAll content can openly be exported as a standard 3D model. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cgartefacts.com/unfoldvr.com/privacy/privacyPolicy_nodata.html", "developer_terms_of_service_url": "https://unfoldvr.com/terms", "publisher_name