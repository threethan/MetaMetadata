 space using your 2D or 3D Art.", "short_description": "UnfoldVR is a VR-first app that has a companion web app, running fully on chain, on IC. We built the tools to empower consumers to create, share and discover 3D content that is built for the Metaverse."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cgartefacts.com/unfoldvr.com/privacy/privacyPolicy_nodata.html", "developer_terms_of_service_url": null, "publisher_name": "UnfoldVR", "support_website_url": null, "website_url": "https://jmorc-qiaaa-aaaam-aaeda-cai.ic0.app/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "983932906099432"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "984611512533536"}]}, "baseline_offer": {"id": "984611512533536"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1683061218, "status": "PUBLISHED", "id": "984611512533536"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8721059791261068", "version": "0.9.04"}, "id": "5426027630779811", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5862544210445988", "is_concept": false, "latest_released_binary": {"_