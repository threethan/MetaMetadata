?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCVBCVhU01UQ7kNvgF0HqVb&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCRf9JCJ3kPU-SYcjVn1-JeGc3MRrniwUDCOUoxiKn-mQ&oe=670F88EA"}, {"file_name": "newss02.png", "id": "506025802126748", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982638_506025805460081_1899308060033542616_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=upp5xM666loQ7kNvgFc8lRv&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB-7sDjtO5h6YTt9ieVBSGceLbfbFRumIKpF-E0begqWQ&oe=670F9BF1"}, {"file_name": "newSS03.png", "id": "8109082935839208", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974689_8109082945839207_1895842965746061433_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vXjvYfFc4UMQ7kNvgFkKgVs&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBoAD2zeZThgEcJgvfabtOuK-1XFL1UDyi4AhYHymNDnQ&oe=670F9F65"}, {"file_name": "newss04.png", "id": "8010643942306832", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031554_8010643952306831_1755293534683580490_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HcMaCJy8EaAQ7kNvgFcDw_t&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAJTMGU7GvnkfXlRF3f92Fx1-V1qFz3lMSymQSlyITV0w&oe=670FB0AB"}, {"file_name": "newss01.png", "id": "404400382667184", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031507_404400386000517_8797874923727848035_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=e3H1yXkADt4Q7kNvgEr_xBP&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCTAQgx-qhb-peGgNw7M5FZew_bxjoYodjdgMLZrGWEqA&oe=670F9EE7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnailNEW.png", "id": "1985915068503753", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982535_1985915071837086_7964873876710673173_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuUFexkQApQQ7kNvgFfRrQi&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCeV3alYiFzXs1w-6SK-2W08Us_VlwLzqK1cCEMoZ8ChQ&oe=670FADB1"}, "display_name": "UnfoldVR", "keywords": ["voxel", "sandbox", "creative", "drawing", "blocks"], "long_description": "# NEW Multiplayer mode launched!\n\n**UnfoldVR is a collaborative playground for Spatial Creators and Explorers!**\n\nIt's a very fast way to Create and Share voxel 3D models with the world! In minutes you can have your  Voxel art published or exported as .obj file.\n\n**Become a VR Storyteller!** Using the versatile Remix Drawing Feature you can add linked iterations of any Artwork. Piece together multiple drawings to tell your Story! Invite your audience to join in.\n\nAll Published Drawings are instantly available for others to explore on the Explore Page. You can Like, Love or Dislike another drawing and also Remix it and make it your own. \n\n**Super Easy, Super Intuitive!** We designed our drawing tools to be as logical as possible making drawing voxels a breeze. We're also actively listening to our community and taking feedback seriously. Join our discord to follow up on our development progress and leave any feedback our way. \n\nWe're actively developing UnfoldVR. The goal is to create a social sandbox platform. Where you create & explore amazing worlds, compete with others in interactive adventures and connect with people who share your passions!\n\nUnfoldVR. Cubes Just Got Awesome!", "short_description": "NEW Multiplayer mode launched!\n\nUnfoldVR is a collaborative playground for Spatial Creators and Explorers!\n\nIt's a very fast way to Create and Share voxel 3D models with the world! In minutes you can have your  Voxel art published or exported as .obj file.\n\nBuild using super simple, intuitive tools, dive right into the fun. Not sure what to build? Remix the best creations with your twist. \n\nAll content can openly be exported as a standard 3D model. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cgartefacts.com/unfoldvr.com/privacy/privacyPolicy_nodata.html", "developer_terms_of_service_url": "https://unfoldvr.com/terms", "publisher_name": "UnfoldVR", "support_website_url"