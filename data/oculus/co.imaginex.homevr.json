e7a0a&_nc_ohc=kTUFD0Nk7a0Q7kNvgHrXf0t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdtJmWAZNqQHPOVQlDxwK79&oh=00_AYC-7z_vbf9HiXU3ZitowHYAj8D99Tj1tNZ8WaNaDZWfhQ&oe=66E024A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1267604337079359", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_1267604340412692_4425314845726952371_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aPh4JjMkl8gQ7kNvgHZljJ2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdtJmWAZNqQHPOVQlDxwK79&oh=00_AYAy_53q9CSo352CyAo-LUYGRTqG5hcjZypF1A9ci6W5Ew&oe=66E03983"}, "display_name": "HomeVR", "keywords": [], "long_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home. Welcome to the future of Real Estate! . If you want your project to be uploaded to our APP, please use the following service: https://homevr.imagine-x.co/. Any other questions, reach us at contact@imagine-x.co", "short_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://imagine-x.co/service-terms/privacy-policy.php", "developer_terms_of_service_url": "https://imagine-x.co/service