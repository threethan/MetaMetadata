sutYy4i4TRr1zhxYM2GuXjBLhQ5fABjYsCeTrA&oe=671A26A8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1267604337079359", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974820_1267604340412692_4425314845726952371_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xDjGs7B9cMEQ7kNvgGvE2px&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAoVo5Si4eaFFUqmAutp0x_M5z0i3IzZC5C4htmElXq-w&oe=671A3B83"}, "display_name": "HomeVR", "keywords": [], "long_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home. Welcome to the future of Real Estate! . If you want your project to be uploaded to our APP, please use the following service: https://homevr.imagine-x.co/. Any other questions, reach us at contact@imagine-x.co", "short_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://imagine-x.co/service-terms/privacy-policy.php", "developer_terms_of_service_url": "https://imagine-x.co/service-terms/privacy-policy.php", "publisher_name": "Imagine-X", "support_website_url": null, "website_url": "https://imagine-x.c