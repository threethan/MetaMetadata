=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z9PJJ4xtEBoQ7kNvgFHZdS-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoOlLkhJ432S16q33Z32trzqej0pnBvsa6nymvtewVJg&oe=66CB2183"}, "display_name": "HomeVR", "keywords": [], "long_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home. Welcome to the future of Real Estate! . If you want your project to be uploaded to our APP, please use the following service: https://homevr.imagine-x.co/. Any other questions, reach us at contact@imagine-x.co", "short_description": "Home VR, powered by ImagineX, is the first real estate platform to experience unbuilt properties worldwide in VR. Through our APP, you can walk through and customize, whenever possible, non-existing properties from around the world. Also, you can contact realtors, brokers, or developers directly and schedule a joint tour of the property. From now on, there's no need to waste time going to the properties and doing mind tricks when you can have it all from your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://imagine-x.co/service-terms/privacy-policy.php", "developer_terms_of_service_url": "https://imagine-x.co/service-terms/privacy-policy.php", "publisher_name": "Imagine-X", "support_website_url": null, "website_url": "https://imagine-x.co/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1063584910766706"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQU