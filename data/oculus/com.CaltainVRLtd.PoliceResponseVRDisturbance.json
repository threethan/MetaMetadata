gF8pSzd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB3YhpOEO16xLYNmc_78byddUQ98xwy2LNacuGQLAskfA&oe=673DDE66"}, {"file_name": "QuestScreenshot3.png", "id": "1146658266129687", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031387_1146658269463020_1525401862727500004_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pE_NVozU7mgQ7kNvgFxLO19&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqChtR0onjO2CiOEBzdEdYXPLhGbtdrGBYGtg_y_so7w&oe=673DD5BE"}, {"file_name": "QuestScreenshot2.png", "id": "719943752791111", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974798_719943756124444_220678638731610447_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jz3kEVbjfO0Q7kNvgEcnj5d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjbDM1H491f-BFjUuto9rSEG22VLd732n84Z9nySg_7w&oe=673DD946"}, {"file_name": "QuestScreenshot5.png", "id": "382642153606381", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031372_382642156939714_8394424819016058973_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VfJQw5DdARUQ7kNvgE9dbcp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZHZotBS0uYrwNCTBL16tux5F6iLVPIV-icJHVmZfsyg&oe=673DC5AE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QuestVid1.png", "id": "785248259113494", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974593_785248262446827_6186186241692420891_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w3CyaIH4YaEQ7kNvgEWW3u3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4dwGQF7Kzn-sIBV7i_OO6aGjcpj2bJlaDCyXkoKZbSg&oe=673DB893"}, "display_name": "Police Response VR Disturbance", "keywords": [], "long_description": "*This is a stationary standing experience only*\n\nExperience an original cartoon reality.\nThe Disturbance is set at 1 address, you take on whatever is presented before you.\nHave you got the weapon drawing skills to cope in pressure situations?\n\nIn this game, you don't have the option to run away\nDuring the scenarios, you choose the right time to react if required without using excessive force in order to progress through the ranks. You the officer have to dynamically risk assess the situation you're faced within this game\n\nEasy Mode - rookie play through allows you to draw weapons without failing. This is set as the default\n\nNormal Mode - professional play through allows you to play the game as originally intended\nCircumstances are likely to change extremely quickly to test if you can react to any situation\n\nYou're armed with a side arm pistol, taser,  pepper spray and handcuffs\nComplete your 30 years and reach your retirement locker.\n\nAre you ready to respond officer?\n", "short_description": "Experience an original cartoon reality.\nQuick Reactions based SIM.\nHave you got the weapon drawing skills to cope in pressure situations? Set at 1 Disturbance Room address. \nToughest Police SIM Game you'll play.\nHave YOU the skills to reach your retirement and complete 30 years service officer ?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://policeresponsevrdisturbance.wordpress.com/", "developer_terms_of_service_url": "https://policeresponsevrdisturbance.wordpress.com/", "publisher_name": "https://policeresponsevrdisturbance.wordpress.com/", "support_website_url": "https://policeresponsevrdisturbance.wordpress.com/", "website_url": "https://policeresponsevrdisturbance.wordpress.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_mod