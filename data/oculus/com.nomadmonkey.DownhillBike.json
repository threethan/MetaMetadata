771-25/38974824_594453632635441_4162220616520561786_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a9F6Puiwc-MQ7kNvgEMweNm&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDSBKbvN9Zn_1n8_0KdzHIB9DGvC6uVL_qJOyedpNqRRw&oe=67600D81"}, {"file_name": "image (4).png", "id": "643299737632555", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38984441_643299740965888_1467808332167381928_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S86t4c1j1kAQ7kNvgE_GnIl&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYANmY3jT7qKFIEBKhKaen38FsTJ7Rt3sN_DCMAL268oAQ&oe=67601ABB"}, {"file_name": "image (6).png", "id": "194737949989844", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031402_194737953323177_388851030718589602_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6MsA4hFXJt8Q7kNvgExcGXF&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYA33dVEiZ8LNoaZNwyduTCVbLTZSOVV7ilC7Ge-iNmFKw&oe=67602FB4"}, {"file_name": "image (3).png", "id": "1016138719771360", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39035455_1016138723104693_841052125582355932_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=455xHXAJ1QgQ7kNvgE1Q7v2&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBv4uMHFfY5kc3rBL8SLkvjDgmSgFO9pD9qinxRr8Vf_Q&oe=67601726"}, {"file_name": "image (5).png", "id": "115885694791570", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39035357_115885698124903_7417904670662466120_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XTaqBeU9GuEQ7kNvgEwiaWc&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYC-LqD8HlgGaPjgVfxhaZ0xX40Lu-o7IFBtIFms5-c_mQ&oe=676020CD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DownhillBikeLandscape.png", "id": "947940119680763", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974727_947940126347429_8874924691088065496_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cj3V2UKynAwQ7kNvgHRRe5S&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDxn7lLTs6Hht4mW7DsCpk2jHR-mJhsMYUVXj-pIJn-pg&oe=67602038"}, "display_name": "Downhill Bike", "keywords": [], "long_description": "Demo Version\n\nExperience the thrill of downhill mountain biking like never before in Downhill Bike, the latest VR game from Nomad Monkey. Get ready to ride through scenic landscapes, tackle challenging terrain, and feel the rush of adrenaline as you race against the clock to reach the finish line. With intuitive controls and immersive graphics, Downhill Bike lets you fully immerse yourself in the world of mountain biking. Take on steep descents, sharp turns, and jumps as you navigate through each level. With multiple levels to unlock and explore, there's always a new challenge waiting for you. Whether you're a seasoned biker or new to the sport, Downhill Bike offers an exciting and realistic experience that will keep you coming back for more. So what are you waiting for? Grab your headset, hop on your virtual bike, and start your ride today!\n\nPlease comment and give us feedback so we can improve the game and implement new worlds for the full version release.", "short_description": "Mountain bike simulation game inside beautiful landscapes and city parkours."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.joygamemobile.com/privacy-policy-vr/", "developer_terms_of_service_url": "https://www.joygamemobile.com/tos/", "publisher_name": "Joygame Oyun ve Teknoloji", "support_website_url": null, "website_url": "https://www.joygame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "sup