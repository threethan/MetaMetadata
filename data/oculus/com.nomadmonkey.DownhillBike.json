Q_4u_v1HblcjmjxYZHO3az4Shw&oe=675ECEB8"}, "display_name": "Downhill Bike", "keywords": [], "long_description": "Demo Version\n\nExperience the thrill of downhill mountain biking like never before in Downhill Bike, the latest VR game from Nomad Monkey. Get ready to ride through scenic landscapes, tackle challenging terrain, and feel the rush of adrenaline as you race against the clock to reach the finish line. With intuitive controls and immersive graphics, Downhill Bike lets you fully immerse yourself in the world of mountain biking. Take on steep descents, sharp turns, and jumps as you navigate through each level. With multiple levels to unlock and explore, there's always a new challenge waiting for you. Whether you're a seasoned biker or new to the sport, Downhill Bike offers an exciting and realistic experience that will keep you coming back for more. So what are you waiting for? Grab your headset, hop on your virtual bike, and start your ride today!\n\nPlease comment and give us feedback so we can improve the game and implement new worlds for the full version release.", "short_description": "Mountain bike simulation game inside beautiful landscapes and city parkours."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.joygamemobile.com/privacy-policy-vr/", "developer_terms_of_service_url": "https://www.joygamemobile.com/tos/", "publisher_name": "Joygame Oyun ve Teknoloji", "support_website_url": null, "website_url": "https://www.joygame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "sup