577472_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Smrl1bFBU4Q7kNvgF8l8qB&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaPzZURmQPaA14cjFqTHuVZxG2c10b0kW78EOuL_5xkg&oe=66D6F20D"}, {"file_name": "migrated_image.png", "id": "642817906294017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_507078186513992_6929025263523069952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KCKCoZ-D-IYQ7kNvgFrWI4D&_nc_ht=scontent.oculuscdn.com&oh=00_AYB70JS-HVTstVjUhiR3c5c4As8VuW2SUNjmV5r9tZ9DqA&oe=66D6F3AD"}, {"file_name": "migrated_image.png", "id": "3089594414384514", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982502_869110003543323_3406698867264061440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TkYVGUfpmsgQ7kNvgFJ-xMC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZtfze3-DFw271tywhIX3NoCE2d5ho0YccbainEFa3Xg&oe=66D6ECCC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/Umvt9q", "id": "786762798399126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572923_786762801732459_3092996182541074432_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qnRHcxvmlQUQ7kNvgGqqBmP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdWo7RbKNK7Nk7T_EtY0f6mKDKH41Ti9lJPM1hgkAEMA&oe=66D6E810"}, "display_name": "Crazy World VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "Come & wonder around this beautifully landscaped Nexon theme park, interact with total stranger, and make new friends online. Crazy arcade VR offers various mini games you can play with others online, together with social & customization features. \nDuring the early access; i)Tennis: An arcade style tennis you can go solo or play with others online. ii)Crossbow: A challenging crossbow game to compete with others. iii)Shooting: Unleash your shooting instinct and go crazy to set new record iV)Bowling: Let\u2019s see who\u2019s got the skill. We are looking for serial strikers. v)My room: For you to manage and customize your characters and inventory. \n**Please note that the game is an online game that requires internet connection. And only accessible from a few selected regions with limited amount of game contents for beta testing. We are going to gradually release new game and new contents over the time.**", "short_description": "**Now on Early Access**\nCrazy World VR is a multiplayer social VR game developed by PIXELITY Games(formerly known as PIXELPIMPS) in association with SKTelecom utilizing Nexon\u2019s casual IP. \nThe game offers various mini games you can play with others online, together with social features, and various customization features."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelitygames.com/privacy-policy/", "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service", "publisher_name": "PIXELITY Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/?lang=en", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "785727332384385"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196228_791101448042740_3462893897242378240_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4obo1sY4dUQ7kNvgHjCsDj&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2rkO-zbK2ry6UXTkzsIjQHx-N_rUjhtxH-t_HJOVaxw&oe=66D6D799"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crazy World VR", "platform": "