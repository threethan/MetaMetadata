0OAPgTKarJpg&oe=67220354"}, {"file_name": "P3kIib.png", "id": "267732127961684", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974442_267732131295017_1741552321621393408_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oYN90zmhCJQQ7kNvgHm9w45&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOY0-21D4Ag_eFKeNya9NzWzUqBBj6QoiHQdOaVrtcsg&oe=672201BE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/eMnkFK", "id": "786761185065954", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031393_786761188399287_2798424652249038848_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SqFuIyBfwcAQ7kNvgGEFS4D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhM8ymdNvMk2EFM-lf1GmVAQDyqhRz-o3ZKkMUm8yErg&oe=67222312"}, "display_name": "\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "- NEXON \uce90\uc8fc\uc5bc \uac8c\uc784 IP\ub97c VR \uc138\uc0c1\uc5d0\uc11c \ub9cc\ub098\uc790!\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 NEXON\uc758 \uc720\uba85 \uce90\uc8fc\uc5bc \uac8c\uc784\uc778 \uce74\ud2b8\ub77c\uc774\ub354, \ud06c\ub808\uc774\uc9c0\uc544\ucf00\uc774\ub4dc, \ubc84\ube14\ud30c\uc774\ud130\uc758 IP\ub97c \ud65c\uc6a9\ud55c \ub2e4\uc911 \uc811\uc18d VR \uac8c\uc784\uc785\ub2c8\ub2e4. \uc775\uc219\ud55c \uce90\ub9ad\ud130\ub4e4\uacfc \ud568\uaed8 VR \uc138\uacc4\ub97c \ud0d0\ud5d8\ud574 \ubcf4\uc138\uc694.\n\n- \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 VR \uc6d4\ub4dc\ub97c \uc990\uae30\uc790!\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uae38 \uc218 \uc788\ub294 \uba40\ud2f0\ud50c\ub808\uc774 \uac8c\uc784\uc785\ub2c8\ub2e4. \uc5ec\ub7ec \uc720\uc800\ub4e4\uc774 \ub3d9\uc2dc \uc811\uc18d \uac00\ub2a5\ud55c \ub9c8\uc744\uc5d0\uc11c \uc720\uc800 \uac04 \ub2e4\uc591\ud55c \uc0c1\ud638\uc791\uc6a9\uc744 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uce90\ub9ad\ud130 \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5, \ub9c8\uc774 \ub8f8 \uafb8\ubbf8\uae30 \ub4f1 \ub2e4\uc591\ud55c \uc990\uac70\uc6c0\ub3c4 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n- \ub2e4\uc591\ud55c \ubbf8\ub2c8 \uac8c\uc784\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uc27d\uace0 \uac04\ud3b8\ud55c \uc870\uc791\uc73c\ub85c \ub204\uad6c\ub098 \uc990\uae38 \uc218 \uc788\ub294 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \ub9c8\uc744 \uacf3\uacf3\uc5d0\uc11c \uc0dd\uc131\ub418\ub294 \ub8e8\ucc0c\ub97c \ud68d\ub4dd\ud558\uc5ec \uac8c\uc784\uc744 \ub9c8\uc74c\uaecf \uc990\uaca8\ubcf4\uc138\uc694. \ud604 \ubca0\ud0c0 \uc11c\ube44\uc2a4 \uae30\uac04 \uc911\uc5d0\ub294 \ud14c\ub2c8\uc2a4, \uc591\uad81, \ubcfc\ub9c1, \uc0ac\uaca9 4\uc885\uc758 \ubbf8\ub2c8 \uac8c\uc784\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc77c\ubd80 \ubbf8\ub2c8 \uac8c\uc784\ub4e4\uc740 \uba40\ud2f0\ud50c\ub808\uc774 \uae30\ub2a5\uc744 \uc81c\uacf5\ud558\uba70, \ud604\uc7ac \uba40\ud2f0\ud50c\ub808\uc774\ub97c \uc9c0\uc6d0\ud558\uc9c0 \uc54a\ub294 \uac8c\uc784\ub4e4\ub3c4 \ud5a5\ud6c4 \ucd94\uac00\ub420 \uc608\uc815\uc785\ub2c8\ub2e4. \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uae30\ub85d\uc744 \uacbd\uc7c1\ud574 \ubcf4\uc138\uc694!\n\n- \uc55e\uc11c \ud574\ubcf4\ub294 \uac8c\uc784\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uc544\uc9c1 \uc644\uc131\ub41c \uac8c\uc784\uc774 \uc544\ub2c8\uba70 \ub2e4\uc591\ud55c \ucd94\uac00 \uae30\ub2a5\ub4e4\uc744 \uac1c\ubc1c\ud558\uace0 \uc788\ub294 \uc5bc\ub9ac\uc5b5\uc138\uc2a4 \uac8c\uc784\uc785\ub2c8\ub2e4. \uac8c\uc784\uc744 \ub354 \uc88b\uac8c \ub9cc\ub4e4 \uc218 \uc788\ub294 \uc720\uc800 \ubd84\ub4e4\uc758 \uc758\uacac\uc744 \uc5b8\uc81c\ub098 \ud658\uc601\ud569\ub2c8\ub2e4. \uc55e\uc73c\ub85c \ucd94\uac00\ub420 \ubbf8\ub2c8 \uac8c\uc784\ub4e4\uacfc \ubd80\uac00 \uae30\ub2a5\ub4e4\uc744 \uae30\ub300\ud574 \uc8fc\uc138\uc694!\n\n* \ubcf8 \uac8c\uc784\uc740 \uc628\ub77c\uc778 \uac8c\uc784\uc73c\ub85c \uc778\ud130\ub137 \uc5f0\uacb0\uc744 \ud544\uc218\ub85c \uc694\uad6c\ud569\ub2c8\ub2e4.", "short_description": "\uc990\uac70\uc6b4 VR \uc6d4\ub4dc\uc5d0 \uc624\uc2e0 \uac83\uc744 \ud658\uc601\ud569\ub2c8\ub2e4! \ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 NEXON\uc758 \uc720\uba85 \uce90\uc8fc\uc5bc \uac8c\uc784\uc778 \uce74\ud2b8\ub77c\uc774\ub354, \ud06c\ub808\uc774\uc9c0\uc544\ucf00\uc774\ub4dc, \ubc84\ube14\ud30c\uc774\ud130\uc758 IP\ub97c \ud65c\uc6a9\ud55c \uba40\ud2f0\ud50c\ub808\uc774 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \uc775\uc219\ud55c \uce90\ub9ad\ud130\ub4e4\uacfc \ud568\uaed8 VR\uc5d0\uc11c \ub2e4\uc591\ud55c \ubbf8\ub2c8 \uac8c\uc784\ub4e4, \uce90\ub9ad\ud130 \uafb8\ubbf8\uae30, \uc18c\uc15c \uae30\ub2a5 \ub4f1\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4. VR \uc6d4\ub4dc\uc5d0\uc11c \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uac70\uc6b4 \uacbd\ud5d8\uc744 \ud574\ubcf4\uc138\uc694!"}, {"images": {"nodes": [{"file_name": "migrated_image.png", "id": "3597253753680697", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196228_791101448042740_3462893897242378240_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vbznFOneinMQ7kNvgFG1YZ6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfSLfDlP66m-jd-3CXKrATq9AkW_RfM8hRt14wC5yQsw&oe=67223559"}, {"file_name": "migrated_image.png", "id": "2979261455457854", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031654_163807288372065_4911031112811151360_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HkoKyK8U780Q7kNvgES9YXH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBa_p6l9ubfmuMEsgon6DsAdlNXT8Q6_45n_1SnL72FZA&oe=672216C1"}, {"file_name": "migrated_image.png", "id": "2698843866911808", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196224_2684667458427327_7948674624424771584_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=efzYWwbjoukQ7kNvgFc6THo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIdUvlIFw7nP0EMaGfBL-I9SOzXvqrBQtehW0PLMtY8w&oe=672227F4"}, 