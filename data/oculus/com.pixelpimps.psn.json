_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qEZaTGq0qawQ7kNvgGol0WQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5T7rJfcSFCZx_G8KGwfV_TjcWJMQ9BwgwJoz4mQZtwg&oe=66FE7F0D"}, {"file_name": "migrated_image.png", "id": "642817906294017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974591_507078186513992_6929025263523069952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7OuYLU5hbkQ7kNvgGKKamT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBCEcq1Oi__ss3TC3h96Zb7gGoF2IDTdvuoltLsel9vw&oe=66FE80AD"}, {"file_name": "migrated_image.png", "id": "3089594414384514", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982502_869110003543323_3406698867264061440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T29DWqO_G9sQ7kNvgE_HeP3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBluxzWxNlQlRTwirbEgEI4ieo2GaIShZoe8cpw5ap89Q&oe=66FE79CC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/Umvt9q", "id": "786762798399126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572923_786762801732459_3092996182541074432_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1IEOy4IM4MEQ7kNvgGabOhj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYAIkEnN43GSLDoKZCt2KUEMWVHGG8PV5of5oX9s16Ug&oe=66FE7510"}, "display_name": "Crazy World VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "Come & wonder around this beautifully landscaped Nexon theme park, interact with total stranger, and make new friends online. Crazy arcade VR offers various mini games you can play with others online, together with social & customization features. \nDuring the early access; i)Tennis: An arcade style tennis you can go solo or play with others online. ii)Crossbow: A challenging crossbow game to compete with others. iii)Shooting: Unleash your shooting instinct and go crazy to set new record iV)Bowling: Let\u2019s see who\u2019s got the skill. We are looking for serial strikers. v)My room: For you to manage and customize your characters and inventory. \n**Please note that the game is an online game that requires internet connection. And only accessible from a few selected regions with limited amount of game contents for beta testing. We are going to gradually release new game and new contents over the time.**", "short_description": "**Now on Early Access**\nCrazy World VR is a multiplayer social VR game developed by PIXELITY Games(formerly known as PIXELPIMPS) in association with SKTelecom utilizing Nexon\u2019s casual IP. \nThe game offers various mini games you can play with others online, together with social features, and various customization features."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelitygames.com/privacy-policy/", "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service", "publisher_name": "PIXELITY Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/?lang=en", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "785727332384385"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196228_791101448042740_3462893897242378240_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ChwKftNhhwgQ7kNvgGC8XLg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHsU6aqugN5k3oPNAVV2bkde2_UT0tB4uTvKwiOxwiWg&oe=66FE9CD9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crazy World VR", "platform": "ANDROI