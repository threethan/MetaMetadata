_name": "migrated_image.png", "id": "208893417103114", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003279_192265352138531_8566456234880794624_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Q8eRUebqUwQ7kNvgGfg65H&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCgUUrkxrMggZmpPQP34DK81wbaFH_-n_x1NpkXyt8XSg&oe=6734969D"}, {"file_name": "migrated_image.png", "id": "762200544304229", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974491_1041754996187366_4398665123833577472_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cJfFkmUH2h4Q7kNvgG9AifQ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDNAgN2slIY2jyw3Czfgj-PmjDgPc3W8Omd1YDdhmuVKg&oe=67348C8D"}, {"file_name": "migrated_image.png", "id": "642817906294017", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974591_507078186513992_6929025263523069952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CRxJRd_fUK4Q7kNvgFIiTl0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBwPeC-N3lT-D_jVjXYzhJ77Ii5FbQmzjQF0AwgXNgc9w&oe=67348E2D"}, {"file_name": "migrated_image.png", "id": "3089594414384514", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982502_869110003543323_3406698867264061440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M0HK3ho1EMQQ7kNvgEAMSza&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCYWyK7x-pvN3TPwGhdiBjwK_BV_w4Nk3hDqfVyqE8FYA&oe=6734874C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/Umvt9q", "id": "786762798399126", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57572923_786762801732459_3092996182541074432_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F7ze-tnMzCYQ7kNvgFoDoRE&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBZ_KtQdi6qNnK9-w7khbyaNr4PkdHupTvxwvFLKctf8w&oe=67348290"}, "display_name": "Crazy World VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "Come & wonder around this beautifully landscaped Nexon theme park, interact with total stranger, and make new friends online. Crazy arcade VR offers various mini games you can play with others online, together with social & customization features. \nDuring the early access; i)Tennis: An arcade style tennis you can go solo or play with others online. ii)Crossbow: A challenging crossbow game to compete with others. iii)Shooting: Unleash your shooting instinct and go crazy to set new record iV)Bowling: Let\u2019s see who\u2019s got the skill. We are looking for serial strikers. v)My room: For you to manage and customize your characters and inventory. \n**Please note that the game is an online game that requires internet connection. And only accessible from a few selected regions with limited amount of game contents for beta testing. We are going to gradually release new game and new contents over the time.**", "short_description": "**Now on Early Access**\nCrazy World VR is a multiplayer social VR game developed by PIXELITY Games(formerly known as PIXELPIMPS) in association with SKTelecom utilizing Nexon\u2019s casual IP. \nThe game offers various mini games you can play with others online, together with social features, and various customization features."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelitygames.com/privacy-policy/", "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service", "publisher_name": "PIXELITY Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/?lang=en", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER