_sid=6e7a0a&_nc_ohc=nVyD1VEE9jwQ7kNvgGHrDBb&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCruzlzuD41_12XkeEW_hq89yXGW8FvQms_8VuLc4N9aw&oe=67027D9D"}, {"file_name": "migrated_image.png", "id": "762200544304229", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974491_1041754996187366_4398665123833577472_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cfIqL_qu2_EQ7kNvgFXvOiQ&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAVG1JBOxIZ6eRID6qaTNmHZyyHIoYDVMehBi6Wv1JETQ&oe=6702738D"}, {"file_name": "migrated_image.png", "id": "642817906294017", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974591_507078186513992_6929025263523069952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cA0WDoR-HscQ7kNvgHSihN2&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDdiG66ZMyZ3oCEgOHAk1AuDh-0BwhdxwUkf6IDoPJaUA&oe=6702752D"}, {"file_name": "migrated_image.png", "id": "3089594414384514", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982502_869110003543323_3406698867264061440_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0goU2O0d7UoQ7kNvgFD-7v2&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAtADNnwD2Df06F-vTSVsolbCNU1fiQcFDES3wtIr9Y-Q&oe=67026E4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/Umvt9q", "id": "786762798399126", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57572923_786762801732459_3092996182541074432_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9s5MfFKC2igQ7kNvgHxu7X-&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBuepTcf2zHsQhJtSEhFvpmrdRqm9qOUFzE5oSTbALgpw&oe=67026990"}, "display_name": "Crazy World VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "Come & wonder around this beautifully landscaped Nexon theme park, interact with total stranger, and make new friends online. Crazy arcade VR offers various mini games you can play with others online, together with social & customization features. \nDuring the early access; i)Tennis: An arcade style tennis you can go solo or play with others online. ii)Crossbow: A challenging crossbow game to compete with others. iii)Shooting: Unleash your shooting instinct and go crazy to set new record iV)Bowling: Let\u2019s see who\u2019s got the skill. We are looking for serial strikers. v)My room: For you to manage and customize your characters and inventory. \n**Please note that the game is an online game that requires internet connection. And only accessible from a few selected regions with limited amount of game contents for beta testing. We are going to gradually release new game and new contents over the time.**", "short_description": "**Now on Early Access**\nCrazy World VR is a multiplayer social VR game developed by PIXELITY Games(formerly known as PIXELPIMPS) in association with SKTelecom utilizing Nexon\u2019s casual IP. \nThe game offers various mini games you can play with others online, together with social features, and various customization features."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelitygames.com/privacy-policy/", "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service", "publisher_name": "PIXELITY Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/?lang=en", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "785727332384385"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-2.oculuscdn.com/v/t