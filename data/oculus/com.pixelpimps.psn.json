e7a0a&_nc_ohc=HtqhObqYMT0Q7kNvgH_cQP8&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9cCvM96WwVKlP0LjaQMU4A4XIdnVEua9nWJXVviLlJQ&oe=66FE7280"}, {"file_name": "migrated_image.png", "id": "145963110059426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982707_2736842443061210_6044344700142354432_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ntdqL58H7HoQ7kNvgHG56r7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSf8UD2n9nNeLxieD6nMJ3URRUJV_UTt7nvyM_nr5L7Q&oe=66FE9220"}, {"file_name": "migrated_image.png", "id": "212428776635508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031569_178271649937912_6061568154654474240_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JcwTjC8DP48Q7kNvgHGcUyB&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFa1JDy17-xeI4-mho4qAP5CLVgauun_gzIwXMdPoJQg&oe=66FE6ED0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/SCRXep", "id": "462753614603570", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974905_462753617936903_4494242701813743616_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Amn5oqfuaY4Q7kNvgHrS8FI&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgnBlLbCS2nXhMZkbHsVs0iXu9fXy-8HYPW55gDMHqIg&oe=66FE8411"}, "display_name": "Crazy World VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "Come & wonder around this beautifully landscaped Nexon theme park, interact with total stranger, and make new friends online. Crazy arcade VR offers various mini games you can play with others online, together with social & customization features. \nDuring the early access; i)Tennis: An arcade style tennis you can go solo or play with others online. ii)Crossbow: A challenging crossbow game to compete with others. iii)Shooting: Unleash your shooting instinct and go crazy to set new record iV)Bowling: Let\u2019s see who\u2019s got the skill. We are looking for serial strikers. v)My room: For you to manage and customize your characters and inventory. \n**Please note that the game is an online game that requires internet connection. And only accessible from a few selected regions with limited amount of game contents for beta testing. We are going to gradually release new game and new contents over the time.**", "short_description": "**Now on Early Access in Korea only**\nCrazy World VR is a multiplayer social VR game developed by PIXELITY Games(formerly known as PIXELPIMPS) in association with SKTelecom utilizing Nexon\u2019s casual IP. \nThe game offers various mini games you can play with others online, together with social features, and various customization features."}, {"images": {"nodes": []}, "id": "573341119938641", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR", "keywords": ["Casual", "Sports", "Arcade", "Social", "Multiplayer"], "long_description": "- NEXON \uce90\uc8fc\uc5bc \uac8c\uc784 IP\ub97c VR \uc138\uc0c1\uc5d0\uc11c \ub9cc\ub098\uc790!\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 NEXON\uc758 \uc720\uba85 \uce90\uc8fc\uc5bc \uac8c\uc784\uc778 \uce74\ud2b8\ub77c\uc774\ub354, \ud06c\ub808\uc774\uc9c0\uc544\ucf00\uc774\ub4dc, \ubc84\ube14\ud30c\uc774\ud130\uc758 IP\ub97c \ud65c\uc6a9\ud55c \ub2e4\uc911 \uc811\uc18d VR \uac8c\uc784\uc785\ub2c8\ub2e4. \uc775\uc219\ud55c \uce90\ub9ad\ud130\ub4e4\uacfc \ud568\uaed8 VR \uc138\uacc4\ub97c \ud0d0\ud5d8\ud574 \ubcf4\uc138\uc694.\n\n- \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 VR \uc6d4\ub4dc\ub97c \uc990\uae30\uc790!\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uae38 \uc218 \uc788\ub294 \uba40\ud2f0\ud50c\ub808\uc774 \uac8c\uc784\uc785\ub2c8\ub2e4. \uc5ec\ub7ec \uc720\uc800\ub4e4\uc774 \ub3d9\uc2dc \uc811\uc18d \uac00\ub2a5\ud55c \ub9c8\uc744\uc5d0\uc11c \uc720\uc800 \uac04 \ub2e4\uc591\ud55c \uc0c1\ud638\uc791\uc6a9\uc744 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uce90\ub9ad\ud130 \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5, \ub9c8\uc774 \ub8f8 \uafb8\ubbf8\uae30 \ub4f1 \ub2e4\uc591\ud55c \uc990\uac70\uc6c0\ub3c4 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\n- \ub2e4\uc591\ud55c \ubbf8\ub2c8 \uac8c\uc784\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uc27d\uace0 \uac04\ud3b8\ud55c \uc870\uc791\uc73c\ub85c \ub204\uad6c\ub098 \uc990\uae38 \uc218 \uc788\ub294 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \ub9c8\uc744 \uacf3\uacf3\uc5d0\uc11c \uc0dd\uc131\ub418\ub294 \ub8e8\ucc0c\ub97c \ud68d\ub4dd\ud558\uc5ec \uac8c\uc784\uc744 \ub9c8\uc74c\uaecf \uc990\uaca8\ubcf4\uc138\uc694. \ud604 \ubca0\ud0c0 \uc11c\ube44\uc2a4 \uae30\uac04 \uc911\uc5d0\ub294 \ud14c\ub2c8\uc2a4, \uc591\uad81, \ubcfc\ub9c1, \uc0ac\uaca9 4\uc885\uc758 \ubbf8\ub2c8 \uac8c\uc784\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc77c\ubd80 \ubbf8\ub2c8 \uac8c\uc784\ub4e4\uc740 \uba40\ud2f0\ud50c\ub808\uc774 \uae30\ub2a5\uc744 \uc81c\uacf5\ud558\uba70, \ud604\uc7ac \uba40\ud2f0\ud50c\ub808\uc774\ub97c \uc9c0\uc6d0\ud558\uc9c0 \uc54a\ub294 \uac8c\uc784\ub4e4\ub3c4 \ud5a5\ud6c4 \ucd94\uac00\ub420 \uc608\uc815\uc785\ub2c8\ub2e4. \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uae30\ub85d\uc744 \uacbd\uc7c1\ud574 \ubcf4\uc138\uc694!\n\n- \uc55e\uc11c \ud574\ubcf4\ub294 \uac8c\uc784\n\ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 \uc544\uc9c1 \uc644\uc131\ub41c \uac8c\uc784\uc774 \uc544\ub2c8\uba70 \ub2e4\uc591\ud55c \ucd94\uac00 \uae30\ub2a5\ub4e4\uc744 \uac1c\ubc1c\ud558\uace0 \uc788\ub294 \uc5bc\ub9ac\uc5b5\uc138\uc2a4 \uac8c\uc784\uc785\ub2c8\ub2e4. \uac8c\uc784\uc744 \ub354 \uc88b\uac8c \ub9cc\ub4e4 \uc218 \uc788\ub294 \uc720\uc800 \ubd84\ub4e4\uc758 \uc758\uacac\uc744 \uc5b8\uc81c\ub098 \ud658\uc601\ud569\ub2c8\ub2e4. \uc55e\uc73c\ub85c \ucd94\uac00\ub420 \ubbf8\ub2c8 \uac8c\uc784\ub4e4\uacfc \ubd80\uac00 \uae30\ub2a5\ub4e4\uc744 \uae30\ub300\ud574 \uc8fc\uc138\uc694!\n\n* \ubcf8 \uac8c\uc784\uc740 \uc628\ub77c\uc778 \uac8c\uc784\uc73c\ub85c \uc778\ud130\ub137 \uc5f0\uacb0\uc744 \ud544\uc218\ub85c \uc694\uad6c\ud569\ub2c8\ub2e4.", "short_description": "\uc990\uac70\uc6b4 VR \uc6d4\ub4dc\uc5d0 \uc624\uc2e0 \uac83\uc744 \ud658\uc601\ud569\ub2c8\ub2e4! \ud06c\ub808\uc774\uc9c0 \uc6d4\ub4dc VR\uc740 NEXON\uc758 \uc720\uba85 \uce90\uc8fc\uc5bc \uac8c\uc784\uc778 \uce74\ud2b8\ub77c\uc774\ub354, \ud06c\ub808\uc774\uc9c0\uc544\ucf00\uc774\ub4dc, \ubc84\ube14\ud30c\uc774\ud130\uc758 IP\ub97c \ud65c\uc6a9\ud55c \uba40\ud2f0\ud50c\ub808\uc774 VR \uac8c\uc784\uc785\ub2c8\ub2e4. \uc775\uc219\ud55c \uce90\ub9ad\ud130\ub4e4\uacfc \ud568\uaed8 VR\uc5d0\uc11c \ub2e4\uc591\ud55c \ubbf8\ub2c8 \uac8c\uc784\ub4e4, \uce90\ub9ad\ud130 \uafb8\ubbf8\uae30, \uc18c\uc15c \uae30\ub2a5 \ub4f1\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4. VR \uc6d4\ub4dc\uc5d0\uc11c \uce5c\uad6c\ub4e4\uacfc \ud568\uaed8 \uc990\uac70\uc6b4 \uacbd\ud5d8\uc744 \ud574\ubcf4\uc138\uc694!"}]}, "developer_name": "PIXELITY Games Inc.", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://pixelitygames.com/terms-of-service", "publisher_name": "PIXELITY Games Inc.", "support_website_url": null, "website_url": "https://pixelitygames.com/", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "327129809315796"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2841115745977052", "version": "1.815"}, "id": "660593744438395", "cha