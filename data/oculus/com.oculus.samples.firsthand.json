4.5771-25/39001654_1324216748101318_3141771138112286303_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oR-PNxCWX3UQ7kNvgFnzhtr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQyAUgPvezb7tIY1C3jdN7JeY5g606PcA_FKTrpkh3_g&oe=675AD5E6"}, {"file_name": "FirstHandBuild.png", "id": "1009659339752364", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036661_1009659343085697_592467976331516214_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VuDvzIjBNPMQ7kNvgFjU3aX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmCxgzKv_RgPh_gPRk14QPnihNXDx3Yi-nCXfMcJoFHw&oe=675AEB17"}, {"file_name": "FirstHandDelivery.png", "id": "383734690410690", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031347_383734693744023_5735233382465372844_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7fPaoqMcun8Q7kNvgHhqZ_i&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVDHK3h6tFazi-lRMdXAq9nspnkHOu5BdjEH3LS27riA&oe=675ABD1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandscape.png", "id": "569857234619253", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001667_569857237952586_7808731989784920215_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v1WsLTncdywQ7kNvgHBUFe2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeAsrLwxubykVMUxbWe9Gwvc5YCcElaMGs3wQEAv8IRQ&oe=675AE2C8"}, "display_name": "First Hand", "keywords": [], "long_description": "First Hand is an official Hand Tracking demo built by Meta. Experience the magic of interacting with the virtual world directly with your hands. Use switches, levers, virtual UIs as you solve puzzles to build robotic gloves, and then experience their superpowers. \n\nWe built First Hand to demonstrate the capabilities and the variety of interaction models possible with Hands. This demo is built using the Presence Platform\u2019s Interaction SDK, a library of interaction components, gestures and tools to build magical hand and controller interactions. This demo is also available as an open source project for developers who would like to easily replicate similar interactions.\n\nWe drew inspiration in this demo from First Contact, the original Meta experience showcasing controller interactions.\n", "short_description": "An official Hand Tracking demo by Meta.\n"}]}, "developer_name": "Oculus Samples", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "SYSTEM", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "977660842915585"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1542017543104035"}, {"status": "PUBLISHED", "id": "1423445964746658"}, {"status": "CANCELLED", "id": "855028325833729"}, {"status": "PENDING", "id": "656397559559858"}]}, "baseline_offer": {"id": "1542017543104035"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731694800, "status": "PUBLISHED", "id": "1542017543104035"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7480620622066920", "version": "2.0.11"}, "id": "528425739061546", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary