c_sid=6e7a0a&_nc_ohc=eHHEzVj6S0MQ7kNvgHarbvk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCGQ2Lz0dT0sOFODqaQ_Tp-BCmdcg3HvpYfwC5BZTTlBg&oe=674D989A"}, {"file_name": "MR_Schematic.png", "id": "1053187052504826", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569463_1053187055838159_4056919281056215538_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6OIBxEFdbwQ7kNvgG6laet&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZCFUf-5sXC4ghH1ZH6AmXE_Hb_IfDrkOvkpaxcgfPOQ&oe=674DA783"}, {"file_name": "Street_StealthGame.png", "id": "1508427823316801", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572920_1508427826650134_2900192972623687859_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XjYpPe_9hMcQ7kNvgEABvOB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAIdkANubIdFnXv1GWABAU122bBwP5N5heiUlGxnb71RQ&oe=674DA0A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FH_CoverartLandscape.png", "id": "585882610542833", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982719_585882613876166_585649627631976085_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=adW2DxcLULoQ7kNvgE0wSyv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDif1pUnWTkkNzr3zumqCcyN8AHCG68cCzyFbAu9BXSzg&oe=674DB986"}, "display_name": "First Hand", "keywords": [], "long_description": "First Hand is an official Hand Tracking demo built by Meta. Experience the magic of interacting with the virtual world directly with your hands. Use switches, levers, virtual UIs as you solve puzzles to build robotic gloves, and then experience their superpowers. \n\nWe built First Hand to demonstrate the capabilities and the variety of interaction models possible with Hands. This demo is built using the Presence Platform\u2019s Interaction SDK, a library of interaction components, gestures and tools to build magical hand and controller interactions. This demo is also available as an open source project for developers who would like to easily replicate similar interactions.\n\nWe drew inspiration in this demo from First Contact, the original Meta experience showcasing controller interactions.\n", "short_description": "An official Hand Tracking demo by Meta.\n"}]}, "developer_name": "Meta Quest Samples", "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.meta.com/legal/terms-of-service/", "publisher_name": "Meta Quest", "support_website_url": null, "website_url": "https://developers.meta.com/horizon/", "category": "SYSTEM", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8438917696237203"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974900_1054374259701742_8199676770180761864_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Hvh06L2wVgQ7kNvgF-ZO8x&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBq3c4n9MCexzihwVrmrVuvWHumBbSHSktzvvL1cnopUg&oe=674D91D2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "First Hand", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 1696957200, "lastRevision": {"nodes": [{"id": "5030224223773251", "release_type": 