o available as an open source project for developers who would like to easily replicate similar interactions.\n\nWe drew inspiration in this demo from First Contact, the original Meta experience showcasing controller interactions.\n", "short_description": "An official Hand Tracking demo by Meta.\n"}]}, "developer_name": "Oculus Samples", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "SYSTEM", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "977660842915585"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1542017543104035"}, {"status": "PUBLISHED", "id": "1423445964746658"}, {"status": "CANCELLED", "id": "855028325833729"}, {"status": "PENDING", "id": "656397559559858"}]}, "baseline_offer": {"id": "1542017543104035"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731694800, "status": "PUBLISHED", "id": "1542017543104035"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7480620622066920", "version": "2.0.11"}, "id": "528425739061546", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary