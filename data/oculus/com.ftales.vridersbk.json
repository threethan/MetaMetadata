_sid=6e7a0a&_nc_ohc=ZTEKGS_bGR4Q7kNvgG6PSFg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFJAVbxvzpeOoEzZek-jFVYSEmpJykQnjizuCbm36xsg&oe=66F2949F"}, {"file_name": "148.png", "id": "442129885002460", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031579_442129888335793_5087112620990116264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pbPZJ0tiopwQ7kNvgGb3zRk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFrwEKxcP5-O_RmcNyVpjEdYNJqum7FpfnsMWsuGrI_g&oe=66F2AF01"}, {"file_name": "09.png", "id": "349223631452917", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984459_349223634786250_4920435550680692425_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U3z6tzX91TwQ7kNvgG85w9e&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3gQYLJ9lkGEalMgMGgXjAQzITePzldM4zbdWt3A2EFA&oe=66F28C6D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "thumbnail.png", "id": "321927027559412", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974482_321927030892745_7390462043723641625_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TnhiVBexVtEQ7kNvgHSydlz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwgNfBK2OxXNjCWevHaJKYuz8JcaxNqybUkFe-U4sszA&oe=66F296CC"}, "display_name": "VRider: SBK", "keywords": [], "long_description": "Race with Officially Licensed bikes from the 2023 World Superbike Championship and unleash your speed on 12 stunning tracks around the world!\n\nExperience the thrill of head to head on track battles against AI, real-life opponents, or against the clock.\n\nFully immerse yourself in the ultimate world of high-speed, adrenaline-pumping superbike racing experience with our unique control system & don't forget: RACE ON THE EDGE!\n\nFeatures:\n- Challenge your friends in real-time multiplayer races (up to 8 players)\n- Quick Race, Tournament, Ghost Challenge, Endurance and Hot Lap racing modes\n- 12 licensed circuits from the SBK 2023 World Championship \n- 23 riders from the SBK 2023 roster\n- 5 Official Superbikes models: Ducati Panigale V4 R, BMW S100RR, Kawasaki Ninja ZX 10RR, Honda CBR1000RR, Yamaha YZF R1\n- Multi-step tutorial (ranges from basic to track-specific)\n- MotionWellness\u2122 ", "short_description": "Race with Officially Licensed bikes from the 2023 World Superbike Championship and unleash your speed on 12 stunning tracks around the world!\n\nExperience the thrill of head to head on track battles against AI, real-life opponents, or against the clock.\n\nFully immerse yourself in the ultimate world of high-speed, adrenaline-pumping superbike racing experience with our unique control system & don't forget: RACE ON THE EDGE!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vridergame.com/index.php/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRal Games", "support_website_url": null, "website_url": "https://vridergame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7306817136106051"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "430071819524659"}, {"status": "PUBLISHED", "id": "7843548609013943"}, {"status": "PUBLISHED", "id": "982680326464848"}, {"status": "PUBLISHED", "id": "1717371612004110"}, {"status": "PUBLISHED", "id": "368095556281024"}, {"status": "PUBLISHED", "id": "1133801531110274"}]}, "baseline_offer": {"id": "982680326464848"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "430071819524659"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7892587847528974", "version": "1.3"}, "id": "2113469102386072", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7219828628138236", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7892587847528974"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2113469102386072"}]}, "change_log": "NEW Free Practice Mode: The much-awaited \u201cFree Practice\u201d mode is here! Hone your lap times while waiting for friends and other players to join your race. Get ready to dominate the track!\n\nNEW Multiplayer Game Mode: Casual Races: Race globally with players from around the world in our new Casual Race mode. Enjoy a relaxed ping filter and no collisions. It\u2019s all about the fun!\n\nCompetitive Races: Realtime MP Races are now called \u201cCompetitive Races\u201d. This mode features collisions and region-based servers for the ultimate competitive experience.", "created_date": 1722525687, "id": "7892587847528974", "version": "1.3", "version_code": 427, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7219828628138236", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7892587847528974"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2113469102386072"}]}, "change_log": "Changelist:\n\n- Spectator Mode with multiple cameras, auto follow & race info\n- Accessibility feature: drag reduction mechanics can now be controlled via button press if enabled in the accessibility menu\n- Improved Tutorial Flow\n- Ghost Challenge game mode improvements\n- Camera Shake \u201clow intensity\u201d option added\n- UX improvements\n- Various bug fixes", "created_date": 1719497754, "id": "7698295850291509", "version": "1.2", "version_code": 388, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7219828628138236", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7892587847528974"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2113469102386072"}]}, "change_log": "A new version just landed, make sure to update VRider SBK to keep accessing MP Races!\n\n- Quest 3 Graphics optimisations\n\n- Added Steering and Throttle Sensitivity options\n\n- Added left trigger braking for Twist to Throttle controls\n\n- Realtime MP optimisations\n\n- Intro Video with basic game instructions\n\n- Various bug fixes", "created_date": 1718102690, "id": "7621232574664504", "version": "1.1", "version_code": 362, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7219828628138236", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7892587847528974"}, "re