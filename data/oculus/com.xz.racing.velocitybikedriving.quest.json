le_name": "portrait.png", "id": "432604983225961", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245820_432604986559294_8349947125357115413_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-59y_hovQcQ7kNvgG9L7e9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAps3eVreddHktMarChHzMUAFz4MFYaQ2ZcFk0WIpnHDQ&oe=67486F11"}]}, "id": "1752454972216912", "locale": "en_US", "screenshots": [{"file_name": "6.png", "id": "493040790353157", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982499_493040793686490_1628031243535009243_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dAcHlVEhUCgQ7kNvgE1nnsW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBiPC3gZCa2NmqnLFGPxCAFBndigodaZuKbygLMgteWA&oe=6748468F"}, {"file_name": "2.png", "id": "2066113203844006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_2066113207177339_3907984750497176337_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rdq5q4NBvz4Q7kNvgG0jteS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPq5qTvvaiQBNHs90zGfWp5ePY3wApculFVRlzo-9AtA&oe=67483F3A"}, {"file_name": "4.png", "id": "514616584495478", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982638_514616591162144_8384197601788655077_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=etW8LhbKY8MQ7kNvgEvB6_A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADr3OJ_a24fAEroryjo-xdrgCv2wWmgI0N0Dc17A6n0g&oe=674848BA"}, {"file_name": "3.png", "id": "1232491374839153", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982613_1232491378172486_9164745787625074211_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6DtU4ThIqqoQ7kNvgF8oWps&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWYmSHaKplf01NuSftX5TkIcENLuVXZbw-jB0OeHKurQ&oe=67485ED8"}, {"file_name": "1.png", "id": "417774191321974", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982463_417774194655307_7614016113904000749_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tZbRPjfWY9gQ7kNvgEBMJMp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA66EVgLwoOZCwgIAO3sjnhozpCowQqMsFMQSfz6np_pw&oe=674860C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982499_493040793686490_1628031243535009243_n.png", "id": "1543161499906717", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974539_1543161503240050_7237193315745554805_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HC-3DO-VDj8Q7kNvgF09MJJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKc0ye4-7EeL0eRkdsisNFeIszB7wApocaRyscaBUqAg&oe=67483D43"}, "display_name": "Extreme Bike Rider - Bike Stunt & Racing Games", "keywords": ["racing", "stunt", "motocross", "motogp", "Bike"], "long_description": "\ud83c\udfcd\ufe0f Extreme Bike Rider - Bike Stunt & Racing Games | Virtual Reality Motorcycle Stunt Adventure!\n\nEnter the thrilling world of VR bike stunts and high-speed motorcycle racing with Extreme Bike Rider! Experience the ultimate rush of performing heart-pounding stunts on powerful bikes, from sleek sports bikes to rugged motocross models, as you blaze through urban landscapes, dodge traffic, and unleash daring tricks! \ud83c\udfc1\n\n\ud83c\udf1f Key Features:\n\n\ud83c\udf06 Immersive VR Environments: Feel the intensity as you race through detailed urban streets and rugged motocross-inspired courses, designed to push your stunt skills to the limit.\n\n\ud83c\udfcd\ufe0f Wide Range of Bikes: Ride a variety of motorcycles, including sports bikes, motocross bikes, and choppers, each offering a unique experience.\n\n\ud83c\udfae Realistic Bike Physics in VR: Experience lifelike bike handling and physics that make every jump, wheelie, and drift feel true to life in VR.\n\n\ud83d\udd25 Extreme Stunts and Tricks: Perform epic wheelies, flips, and motocross jumps as you take on challenging stunt courses.\n\n\ud83d\udea6 Traffic Dodge Mode: Weave through city traffic while executing daring stunts in VR, challenging your reflexes and riding skills.\n\n\ud83d\udd79\ufe0f Intuitive VR Controls: Easy-to-use bike controls optimized for a seamless and immersive VR experience.\n\nGear up and dive into Extreme Bike Rider - Bike Stunt & Racing Games to conquer daring stunts and VR bike races! Are you ready to hit the throttle and own the road? \ud83c\udfcd\ufe0f\ud83d\udca8", "short_description": "Experience high-speed thrills in Extreme Bike Rider - Bike Stunt & Racing Games! \ud83c\udfcd\ufe0f Tackle daring stunts, dodge traffic \ud83d\udea6, and race through intense VR levels. Take on extreme tracks, unleash your motocross skills, and conquer every challenge. Ready to ride? Rev up and dominate the roads! \ud83d\udeb4\u200d\u2642\ufe0f\ud83d\udca8"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xzsol.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "XZ Solutions", "support_website_url": null, "website_url": "https://xzsol.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7463746410417099"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031608_1465918484093906_6036754919157789354_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7pzIZJMDRCsQ7kNvgG67Sjq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCcLOMxyQXoP62Zg8VllV8oUmdtA1-Orv43sHU2ynWgEQ&oe=67485CC6"}