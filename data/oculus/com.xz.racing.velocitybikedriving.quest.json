01788655077_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gjGokEGZS68Q7kNvgG2VuU2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ0BXlYNQ7KjEELpSvcmVdtcrysS14PFNyJJIaM-Nz7Q&oe=670CF53A"}, {"file_name": "3.png", "id": "1232491374839153", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982613_1232491378172486_9164745787625074211_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5lnsN1q_c_wQ7kNvgEMWwMj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBuAW4PDWjfvQD_bSGmlny1IAsIIhvga8ga8SQRBiM9yA&oe=670D0B58"}, {"file_name": "1.png", "id": "417774191321974", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982463_417774194655307_7614016113904000749_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HxnB51ionZUQ7kNvgFq3__T&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBotHREH8_Giqxe6V0D_FFPSKgW27aWD8bBw-YE57AxWA&oe=670D0D40"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Velocity Bike Driving - Bike Stunt Simulator", "keywords": [], "long_description": "\ud83c\udfcd\ufe0f Velocity Bike Driving - Bike Stunt Simulator | Bike Riding Game - A Thrilling Bike Adventure!\n\nJump into the exciting world of motorcycle stunts with Velocity Bike Driving. Feel the adrenaline rush as you ride sports bikes, trail bikes, and choppers through stunning cityscapes while performing jaw-dropping stunts.\n\n\ud83c\udf1f Key Features:\n\n\ud83c\udf06 City Environments: Ride through dynamic, detailed urban landscapes.\n\ud83c\udfcd\ufe0f Variety of Bikes: Choose from sports bikes, trail bikes, and choppers for a unique ride experience.\n\ud83c\udfae Realistic Bike Physics: Experience authentic bike handling and control.\n\ud83d\udd25 Stunts and Tricks: Perform wheelies, flips, and extreme maneuvers for a true thrill.\n\ud83d\udea6 Traffic Dodge: Weave through city traffic while pulling off stunts.\n\ud83d\udd79\ufe0f Intuitive Controls: Easy-to-use controls for immersive, action-packed gameplay.\n\nRev your engines and hit the streets in Velocity Bike Driving for the ultimate stunt-riding experience! \ud83c\udfc1", "short_description": "Experience the thrill of high-speed bike riding in Velocity Bike Driving - Bike Stunt Simulator! \ud83c\udfcd\ufe0f Perform daring stunts and dodge traffic \ud83d\udea6 as you master extreme bike control. \ud83c\udfc1 Take on intense levels, showcase your stunt skills, and dominate the streets in this ultimate bike riding adventure. Ready to ride? Get on your bike and conquer the road now! \ud83d\udeb4\u200d\u2642\ufe0f\ud83d\udca8"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xzsol.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "XZ SOlutions", "support_website_url": null, "website_url": "https://xzsol.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7077338615724549"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "476179525424953"}, {"status": "PUBLISHED", "id": "26708666422113680"}]}, "baseline_offer": {"id": "26708666422113680"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729447200, "status": "PUBLISHED", "id": "476179525424953"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7089885787803165", "version": "0.0.4"}, "id":