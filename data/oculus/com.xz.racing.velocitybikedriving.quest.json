D8bBw-YE57AxWA&oe=670D0D40"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982499_493040793686490_1628031243535009243_n.png", "id": "1543161499906717", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974539_1543161503240050_7237193315745554805_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t2YGcg5AAUYQ7kNvgEzYpDV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjZidv9u7rDIxor5PSjZPHwe1YhcOhrgFWVAoPML1Twg&oe=670CE9C3"}, "display_name": "Velocity Bike Driving - Bike Stunt | Bike Simulator", "keywords": ["BikeRiding", "BikeRacing", "BikeStunt", "MotorCycle", "Bike"], "long_description": "\ud83c\udfcd\ufe0f Velocity Bike Driving - Bike Stunt Simulator | Bike Riding Game \u2013 The Ultimate Bike Adventure!\nJump into the thrilling world of bike stunts with Velocity Bike Driving. Feel the adrenaline rush as you ride sports bikes, trail bikes, and choppers through stunning urban environments, performing jaw-dropping bike stunts during your bike riding adventure! \ud83c\udfc1\n\n\ud83c\udf1f Key Features:\n\n\ud83c\udf06 City Bike Environments: Navigate dynamic urban landscapes on your bike.\n\ud83c\udfcd\ufe0f Variety of Bikes: Ride sports bikes, trail bikes, and choppers for a unique bike experience.\n\ud83c\udfae Realistic Bike Physics: Enjoy lifelike bike handling and control for an authentic riding experience.\n\ud83d\udd25 Bike Stunts and Tricks: Perform wheelies, flips, and extreme bike maneuvers for an adrenaline-pumping ride.\n\ud83d\udea6 Traffic Dodge on Bikes: Weave through city traffic while pulling off incredible bike stunts.\n\ud83d\udd79\ufe0f Intuitive Bike Controls: Simple and easy-to-use controls for immersive bike gameplay.\n\nRev up your bike and hit the streets in Velocity Bike Driving for the ultimate bike riding stunt adventure! \ud83c\udfcd\ufe0f\ud83d\udca8", "short_description": "Experience the thrill of high-speed bike riding in Velocity Bike Driving - Bike Stunt Simulator! \ud83c\udfcd\ufe0f Perform daring bike stunts, dodge traffic \ud83d\udea6, and master extreme bike control. Take on intense levels, showcase your skills, and dominate the streets in this ultimate bike stunt simulator. Ready to ride? Get on your bike and conquer the road now! \ud83d\udeb4\u200d\u2642\ufe0f\ud83d\udca8"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xzsol.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "XZ Solutions", "support_website_url": null, "website_url": "https://xzsol.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7246735968784812"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003226_881955843993933_382172506358355065_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQWfzSxx_EIQ7kNvgErYOfQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyHz2ObjYlhXmYTti04UAsZDBMLjqy65D3oLplbCqV6A&oe=670CFB29"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Velocity Bike Driving - Bike Stunt | Bike Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Racing", "id": "673385183287495"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulati