hc=i_DERkiOCI8Q7kNvgHJ3LwA&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCa6B7Q0om0Yuv7D5b5nUpdjwQeMJK86q2E4w3uHIFmlA&oe=6728BCC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982499_493040793686490_1628031243535009243_n.png", "id": "1543161499906717", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974539_1543161503240050_7237193315745554805_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K5tElNUmtSEQ7kNvgHSIOdd&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCVH3loy8colJ6JxFVt_bm2rfPUfxYSGIt4WJYAK11fnw&oe=67289943"}, "display_name": "Velocity Bike Driving - Bike Racing Games", "keywords": ["BikeGames", "racing", "stunt", "motocross", "motogp"], "long_description": "\ud83c\udfcd\ufe0f Velocity Bike Driving - Motorcycle Stunt Game | Motocross and Bike Riding Adventure!\n\nJump into a high-speed world of motocross and motorcycle stunts with Velocity Bike Driving! Feel the rush of performing stunts on a variety of bikes, including sports bikes, trail bikes, and choppers, as you navigate urban streets, dodge traffic, and pull off extreme tricks! \ud83c\udfc1\n\n\ud83c\udf1f Key Features:\n\n\ud83c\udf06 Urban and Motocross Environments: Ride through intense cityscapes and challenging motocross-inspired tracks built for motorcycle stunts.\n\ud83c\udfcd\ufe0f Variety of Motorcycles: Choose from sports bikes, trail bikes, motocross bikes, and choppers for a unique riding experience.\n\ud83c\udfae Realistic Motorcycle Physics: Enjoy lifelike handling and physics for the ultimate bike riding experience.\n\ud83d\udd25 Extreme Stunts and Tricks: Perform daring wheelies, flips, and motocross-style jumps for an adrenaline-pumping adventure.\n\ud83d\udea6 Traffic Dodge Mode: Navigate through heavy city traffic while executing wild motorcycle stunts.\n\ud83d\udd79\ufe0f Intuitive Bike Controls: Simple, easy-to-use controls for an immersive bike and motocross gameplay experience.\n\nRev up your bike and take on the ultimate motocross and motorcycle stunt challenge in Velocity Bike Driving! \ud83c\udfcd\ufe0f\ud83d\udca8", "short_description": "Experience high-speed thrills in Velocity Bike Driving - Bike Stunt Simulator! \ud83c\udfcd\ufe0f Master daring stunts, dodge traffic \ud83d\udea6, and ride like a pro through intense levels. Take on the streets, showcase your motocross skills, and conquer every road. Ready to ride? Hit the throttle and dominate the road! \ud83d\udeb4\u200d\u2642\ufe0f\ud83d\udca8"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xzsol.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "XZ Solutions", "support_website_url": null, "website_url": "https://xzsol.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7377581189033622"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39003226_881955843993933_382172506358355065_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jqxTMERgz1UQ7kNvgHFDfR7&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCYxEVg16ozgBxv5540jOiBywrd-fEY_O9a1YiajycxOw&oe=6728AAA9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Velocity Bike Driving - Bike Racing Games", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "27433260359