y.  \n\nArcade\nYou can play standalone maps to try and rage to the highest score you can muster.\n\nStory\nPlay through a short, introductory story that introduces you to the world of Rage Against the Room while smashing everything in your path to become the next Champion.", "short_description": "Rage Against the Room is here to allow to smash, crash and bash your way through all of our Ragerenas!  Use a variety of weapons and items to break down everything in your path and realise the key to unlocking your rage!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://freecreativ.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "FreeCreativ", "support_website_url": null, "website_url": "https://www.freecreativ.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25511893071787967"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1778430839350351"}, {"status": "PUBLISHED", "id": "1130345728271117"}]}, "baseline_offer": {"id": "1778430839350351"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720074282, "status": "PUBLISHED", "id": "1778430839350351"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26136569712653630", "version": "1.0"}, "id": "926651935371182", "channel_name": "LIVE"}]}, "is_for_o