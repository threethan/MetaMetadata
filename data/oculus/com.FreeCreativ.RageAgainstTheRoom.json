rough all of our Ragerenas!  Use a variety of weapons and items to break down everything in your path and realise the key to unlocking your rage!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://freecreativ.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "FreeCreativ", "support_website_url": null, "website_url": "https://www.freecreativ.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26558903090420288"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272212_1760847158073434_8849032972173122217_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YwRctZ5UiRQQ7kNvgHV4ImE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzehxlHtciKu2ckDLvB5qXu&oh=00_AYBF8VwbAx6-aE2PwgWBCOdRSVbcuKApHFfU6y6myQcTxA&oe=66F013A0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Rage Against the Room", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1717437000, "lastRevision": {"nodes": [{"id": "8582203291850210", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"defaul