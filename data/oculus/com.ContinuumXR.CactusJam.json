8-KJ0ipUaE48le2_w2UuxQtexB3KGBX1iTwjr6MCOw&oe=678790B0"}, {"file_name": "3.png", "id": "349907624600198", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035448_349907627933531_8803335368883209591_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EmiXbhcWRoMQ7kNvgGxhHlu&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC4Kj7UXoHAus9Ly7MXXIogslcTszBoDV3f0tsWMhjrSA&oe=6787A0DA"}, {"file_name": "5.png", "id": "299329666453217", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/44000512_299329669786550_2834925494622853204_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pc3Cd10AHkgQ7kNvgERwrY5&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCiF8hYq-82tzn8lvqP-7sW6FhWmlTBcxePMWqQMaZ0Vg&oe=6787A1F8"}, {"file_name": "4.png", "id": "704002208549325", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035401_704002211882658_4561892767722696478_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xgqV7_lCHSsQ7kNvgFrb8tE&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC2xx94H2iGhfImBYlOXOiLRIjS5fQSisHQFAqA20y3Jw&oe=6787A302"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cactus Jam", "keywords": [], "long_description": "Welcome to \"Cactus Jam,\" an exhilarating multiplayer VR game created by two brothers in a basement! \n\nImmerse yourself in a thrilling desert landscape complete with sand dunes, rocky outcrops, and swaying cacti, all under the watchful eye of a hovering UFO. \n\nEngage in an epic game of hide-and-seek between aliens and cacti, where stealth and deception are key as you master the art of blending in to outsmart your opponents. \n\nDive into this immersive VR experience and experience the adrenaline rush of the hunt in a visually stunning and cartoonishly captivating environment.", "short_description": "Welcome to \u201cCactus Jam,\u201d an epic hide-and-seek multiplayer game, where cacti must master the art of stealth and deception to outwit their alien adversaries. Explore a sprawling desert landscape under the curious gaze of a hovering UFO, complete with sand dunes, rocky outcrops, and swaying cacti. Cactus Jam delivers an adrenaline-pumping adventure that will keep you on the edge of your seat!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cactusjamvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Continuum VR", "support_website_url": null, "website_url": "https://www.cactusjamvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6956433494479167"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "315386104553232"}]}, "baseline_offer": {"id": "315386104553232"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1714751640, "status": "PUBLISHED", "id": "315386104553232"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8724349877687511", "version": "0.5.2"}, "id": "739911924749186", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6956433484479168", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8724349877687511"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}