538283628517_6070870613953193742_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JElZ7suxrZ4Q7kNvgEEnlfh&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBH4pFtZBma9kmvyUpPsU5eegw5FHIf810l2c9xIh-yCg&oe=677E4820"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cactus Jam Trailer02.png", "id": "528323783510234", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/57569458_528323786843567_6031111678445073579_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhq_L3nBaBUQ7kNvgH7H5JR&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBTkIyIGmhoCYrqpo1gVkzu9uLBlb8vnhlOQKB8_sc3TQ&oe=677E5842"}, "display_name": "Cactus Jam", "keywords": [], "long_description": "Welcome to \"Cactus Jam,\" an exhilarating multiplayer VR game created by two brothers in a basement! \n\nImmerse yourself in a thrilling desert landscape complete with sand dunes, rocky outcrops, and swaying cacti, all under the watchful eye of a hovering UFO. \n\nEngage in an epic game of hide-and-seek between aliens and cacti, where stealth and deception are key as you master the art of blending in to outsmart your opponents. \n\nDive into this immersive VR experience and experience the adrenaline rush of the hunt in a visually stunning and cartoonishly captivating environment.", "short_description": "Welcome to \u201cCactus Jam,\u201d an epic hide-and-seek multiplayer game, where cacti must master the art of stealth and deception to outwit their alien adversaries. Explore a sprawling desert landscape under the curious gaze of a hovering UFO, complete with sand dunes, rocky outcrops, and swaying cacti. Cactus Jam delivers an adrenaline-pumping adventure that will keep you on the edge of your seat!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.cactusjamvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Continuum VR", "support_website_url": null, "website_url": "https://www.cactusjamvr.com/", "category": null, "comfort_ra