1hAQ7kNvgE27oeb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBEtPb47BOOg3HyqWgKVSohxNeqAxPGwFt0lpa7mxbbdw&oe=67693BC2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1650501399121341", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974744_1650501402454674_7603330016418404631_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V_Z7r6hcZdgQ7kNvgGeLXOQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB6zPvyY21-eje6cRRYbyyiQpTi29cehmMR5mFp4ag9nw&oe=67694C03"}, "display_name": "VR Devotion", "keywords": [], "long_description": "Update : Added newer scenes\n\nImmerse yourself in a transformative spiritual journey with the MR Devotional app. Designed for seekers of all faiths, this app seamlessly integrates immersive reality (MR) technology with timeless devotional practices. Step into serene virtual environments where you can engage in guided meditations, reflective readings, and interactive prayers.\n\nExperience the ancient wisdom of scriptures and teachings through interactive storytelling and visualizations that bring sacred texts to life. Customize your devotional experience with personalized prayer guides and daily affirmations tailored to your spiritual journey.\n\nWhether you seek solace, inspiration, or connection with a higher power, the MR Devotional app offers a unique blend of technology and spirituality to enhance your daily quest for meaning and fulfillment.", "short_description": "Devotional app in mixed reality to do all your prayer and offerings through your quest device"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.superfan.studio/vrdevotionprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Superfan Studio", "support_website_url": null, "website_url": "https://superfan.studio/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "AP