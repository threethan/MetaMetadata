tiplayer Boxing Game! Join public or private lobbies and brawl!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/16nVx6NY4obMdecDeanQVyuQt7YWvr4kuDTn19ccpQ0U/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Phoze", "support_website_url": null, "website_url": "https://docs.google.com/document/d/1YkGs89urCk65xODWdYlGF4bFnXxgmVktcYsBFWT1tn8/edit?usp=sharing", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8442250215885863"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2327425527629632"}]}, "baseline_offer": {"id": "2327425527629632"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730550000, "status": "PUBLISHED", "id": "2327425527629632"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8514601398650744", "version": "0.25"}, "id": "870156751889243", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8387274078050144", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8514601398650744"}, "release_status": "RELEASED"}, "binary