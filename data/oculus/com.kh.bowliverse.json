3B36"}, {"file_name": "ss1.png", "id": "1204577364128636", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031382_1204577367461969_7049697876348417668_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nav8IkiPMOkQ7kNvgGmeqPN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASFOzVMu1HzF_etcKtl5R8z&oh=00_AYB_u3p6MfHMcUEtEq8niMOAuVbf92T2eoW58M3nq4l7TA&oe=66F53181"}, {"file_name": "ss2.png", "id": "1009530637435356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254878_1009530640768689_803764645605571401_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZoUe4bykS8Q7kNvgFMFPM7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASFOzVMu1HzF_etcKtl5R8z&oh=00_AYABN8_g6D9grumyOEKp6ZZAoXJRiun2CRW040RU43OmpQ&oe=66F562FD"}, {"file_name": "ss3.png", "id": "738875504913414", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_738875508246747_2158305255338028142_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8vC1bgI56ygQ7kNvgG-1AgV&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASFOzVMu1HzF_etcKtl5R8z&oh=00_AYB2fehmO4W4H5Nc7qv1Xjp_fpnhAsO5j3aqxVvV1cl-7w&oe=66F5325D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "405044145251835", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86796210_405044148585168_541174282990593081_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_hGnDhMLHm0Q7kNvgE-u_nB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASFOzVMu1HzF_etcKtl5R8z&oh=00_AYBm8eXGHBi0chV2Dy_db6fJvsITVjw0bfMaLEWSH_di5w&oe=66F54A0A"}, "display_name": "Bowliverse", "keywords": [], "long_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Bowliverse\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/bowliverse/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "KH Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/bowliverse", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8715910298425928"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary":