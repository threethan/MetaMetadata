_nc_ohc=x1mxK-0tc3IQ7kNvgGuet21&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCL3aBj4Nic-vWHNb5MEbsJHGZ_OiVN1bkVJvK19_hgOA&oe=675C0681"}, {"file_name": "ss2.png", "id": "1009530637435356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254878_1009530640768689_803764645605571401_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ShAOjJZnWSMQ7kNvgFbmRwv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDW2OdWtrlloTFJczoBlxkxzdpgTz2nXeHwLfbNsoApSQ&oe=675C37FD"}, {"file_name": "ss3.png", "id": "738875504913414", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001660_738875508246747_2158305255338028142_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IxDHIcLJgUEQ7kNvgEQeqOJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJUhJMay1Q4PAa6-nePpj3EyjtVpPKYMVQlzJe0yGgNA&oe=675C075D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "405044145251835", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796210_405044148585168_541174282990593081_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yxbs3l8-bZ0Q7kNvgFtWtik&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8XYZcOK0uPHmCOt0VlqGsPt2FrWtuAmTg-Im4iMVfog&oe=675C1F0A"}, "display_name": "Bowliverse", "keywords": [], "long_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Bowliverse\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/bowliverse/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "KH Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/bowliverse", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8715910298425928"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8735993799750911", "version": "2.1"}, "id": "451570284321115", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typen