F536"}, {"file_name": "ss1.png", "id": "1204577364128636", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031382_1204577367461969_7049697876348417668_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PY92mTBamFoQ7kNvgGRhg7o&_nc_ht=scontent.oculuscdn.com&_nc_gid=AO1Of1k3g3VRT9gg4lNpKB5&oh=00_AYAEOeEDIWTqABMqk7dB31rcq39zLdOEs3Igp3xE7fty_Q&oe=66EFEB81"}, {"file_name": "ss2.png", "id": "1009530637435356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254878_1009530640768689_803764645605571401_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z7TJvgofUwYQ7kNvgFMUPMw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AO1Of1k3g3VRT9gg4lNpKB5&oh=00_AYDkm73iL52rwt8sCp9ZlnE4a69MJhUzYr9E0dDMcF13iQ&oe=66EFE4BD"}, {"file_name": "ss3.png", "id": "738875504913414", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_738875508246747_2158305255338028142_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O4__7F0WxB8Q7kNvgGIa7XM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AO1Of1k3g3VRT9gg4lNpKB5&oh=00_AYDfI-3cIaiHa-e2faDPuxLkNe6f5AIhOfrUOpvfT8PiTg&oe=66EFEC5D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "405044145251835", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86796210_405044148585168_541174282990593081_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-6NWV94-JE0Q7kNvgEPCJn9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AO1Of1k3g3VRT9gg4lNpKB5&oh=00_AYBQ1t08k2Z6duRxkIkcqzNQbMJdt7NbfcYUyk7bj8sVNQ&oe=66F0040A"}, "display_name": "Bowliverse", "keywords": [], "long_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Bowliverse\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/bowliverse/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "KH Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/bowliverse", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8715910298425928"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary":