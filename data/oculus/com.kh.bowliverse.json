AYCHT-zY15sMg1G_-ymXCYgSKhv1kmVW27-L-YUTV-4OKw&oe=6762CF7D"}, {"file_name": "ss3.png", "id": "738875504913414", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001660_738875508246747_2158305255338028142_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GF7rp5WFadsQ7kNvgFFbT09&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmtZB7Fh9utJbR23m1eBEar7oKo4fsiA-1BEdDdNBGmw&oe=67629EDD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "405044145251835", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796210_405044148585168_541174282990593081_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5wIxnKnhrnkQ7kNvgHN-yhq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADvjiOwzo_pabea83ilctz8CW2dxauiQpKHOEMdAi2gQ&oe=6762B68A"}, "display_name": "Bowliverse", "keywords": [], "long_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Bowliverse\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Bowliverse: The Ultimate VR Bowling Experience\n\nWelcome to \"Bowliverse,\" where the classic sport of bowling transcends the ordinary and enters a realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Bowliverse\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/bowliverse/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "KH Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/bowliverse", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}, {"id": "2691890164460465"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8715910298425928"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035430_829854685414919_1154626813851005210_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qf2mwvwras0Q7kNvgFw66jt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0H-UM-Uo3m182Tb0XxGr2FqRsLgSM7KHERHxTe5gQOw&oe=6762CE65"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Bowliverse", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1720591993, "lastRevision": {"nodes": [{"id": "8715910311759260", "release_type": "S