_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYAGTW6VWaXZUUttA2g7cAsSkAs758wq40CeGTxXbJgNUw&oe=66F3F0C6"}]}, "id": "465115339386686", "locale": "en_US", "screenshots": [{"file_name": "1_Bedroom_2.png", "id": "3816307451964293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974924_3816307455297626_2385956162505570634_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O3J1z2yRz8MQ7kNvgFovMIB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYDsp3lX_1UtqLWaeaHgXiTHe1UlpD4Nzs00wcaweMuSpw&oe=66F3F9FB"}, {"file_name": "2_seabed_2.png", "id": "838025314887768", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_838025318221101_7707084731870819346_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8S3ReDE8y0YQ7kNvgGKbLx2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYAsnZbmchKUjlW9x7ThbV2W0NYWA-E77I7X1kYU6V7hpA&oe=66F40553"}, {"file_name": "3_cave_menu.png", "id": "452437480664609", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931328_452437483997942_4227945670507173829_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wlqyr7jSf08Q7kNvgEL_5xK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYByu5jP9t-Y_aZ_S0Pf565hbuH5PORrZPGtzP1RrQPYVg&oe=66F3E31E"}, {"file_name": "4_seabed_partner.png", "id": "777343604544239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610703_777343614544238_531505398877845635_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HnVCFI0ykvEQ7kNvgFr1FZA&_nc_ht=scontent.oculuscdn.com&_nc_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYDqZUnZw3nH7sfhEscfRdLN05yhDTcsYFZWCC7t7Li8Vg&oe=66F3DC93"}, {"file_name": "5_half_and_half.png", "id": "1002520941530773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031471_1002520944864106_4243668137345014312_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6MjmD7WZG0AQ7kNvgFm_Uk5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A91tq_BMZ0hZLmJDjcnnjW0&oh=00_AYAZOLBGT8zo_9uxYRkd2bZdanunaR_hTWzFeSJml-uWFA&oe=66F3F624"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Sleep Haven", "keywords": [], "long_description": "Make bedtime better\n\nGoing to bed can be an unwelcome, boring, lonely and anxiety producing moment in our daily lives.\n\nLet Sleep Haven transport you from your busy daytime wakefulness to a place of serene sleepfulness.\n\nSo you can sleep better, longer and get all the benefits that come from getting the amount of sleep your body and mind need to operate at their best.\n\nYou can:\nChoose your bedtime environment\nChoose your bedtime partner should you wish\nControl the weather outside\nControl the lighting inside (including blue light)\nControl the sounds around you\n\nYour bedtime partner can physically be anywhere in the real world and are able to select their own ideal environment while you both share the same blankets in the virtual world.\n\nWe aim to continuously enhance your Sleep Haven experience and you\u2019ll see many improvements over time including new environments.\n\nIf there\u2019s an environment you\u2019d like to see please let us know.\n", "short_description": "Make bedtime better\n\nGoing to bed can be an unwelcome, boring, lonely and anxiety producing moment in our daily lives.\n\nLet Sleep Haven transport you from your busy daytime wakefulness to a place of serene sleepfulness.\n\nChoose your bedtime environment\nChoose your bedtime partner should you wish\nControl the weather outside\nControl the lighting inside (including blue light)\nControl the sounds around you\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.autonomousunit.com/sleep-haven-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Autonomous Unit", "support_website_url": null, "website_url": "https://www.autonomousunit.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type"