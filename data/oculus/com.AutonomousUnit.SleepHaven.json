ler_thumbnail": null, "display_name": "Sleep Haven", "keywords": [], "long_description": "Make bedtime better\n\nGoing to bed can be an unwelcome, boring, lonely and anxiety producing moment in our daily lives.\n\nLet Sleep Haven transport you from your busy daytime wakefulness to a place of serene sleepfulness.\n\nSo you can sleep better, longer and get all the benefits that come from getting the amount of sleep your body and mind need to operate at their best.\n\nYou can:\nChoose your bedtime environment\nChoose your bedtime partner should you wish\nControl the weather outside\nControl the lighting inside (including blue light)\nControl the sounds around you\n\nYour bedtime partner can physically be anywhere in the real world and are able to select their own ideal environment while you both share the same blankets in the virtual world.\n\nWe aim to continuously enhance your Sleep Haven experience and you\u2019ll see many improvements over time including new environments.\n\nIf there\u2019s an environment you\u2019d like to see please let us know.\n", "short_description": "Make bedtime better\n\nGoing to bed can be an unwelcome, boring, lonely and anxiety producing moment in our daily lives.\n\nLet Sleep Haven transport you from your busy daytime wakefulness to a place of serene sleepfulness.\n\nChoose your bedtime environment\nChoose your bedtime partner should you wish\nControl the weather outside\nControl the lighting inside (including blue light)\nControl the sounds around you\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.autonomousunit.com/sleep-haven-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Autonomous Unit", "support_website_url": null, "website_url": "https://www.autonomousunit.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}], "external_subscription_type"