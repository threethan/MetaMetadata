cb=1-7&_nc_sid=6e7a0a&_nc_ohc=kBdOgx09rE0Q7kNvgEC3V5x&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAsfwi8NPBKGOU1Ni42mH0cTbaO_Lt5VxkCrJvIyoCAxQ&oe=670BC498"}, {"file_name": "Inreal_20210311T143739Z.png", "id": "184564026524755", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39003263_184564029858088_7212951086265236834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KIoBsXHUi_0Q7kNvgGjptml&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYB2Ql9FNYccJzfBLecXthnq6JvTkOYHIAkZpE40p9nHzA&oe=670BA121"}, {"file_name": "Inreal_20210707T091729Z.png", "id": "330742758725374", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982658_330742762058707_9023178974783749073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mkDrBEEgt3cQ7kNvgEUTpJA&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCyYtc4Nj5JfrFY4yWUIxs7PQLqSrso8euAZqB8Lcy9iA&oe=670BB03B"}, {"file_name": "Inreal_20210311T144220Z.png", "id": "483409719471779", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031322_483409722805112_1496698754582646786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TyEjiPozypoQ7kNvgFAoPcL&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDFz7cY1-HFNNu6FkF7a-IPFvvVUcGdkicd4Ffutgo7Tg&oe=670BC6BF"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V3vDBMV1S_IQ7kNvgG_bT4E&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB-m3ozy44qfM0bglDYBWjtgD-nrhCQqeSQxlA5Mr32-Q&oe=670BB6F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PymlV6EzguAQ7kNvgEr1549&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDj2PCl_5QrTXYTwxZ5S3lUhgtwu-dEh9-MZ8kZqPsKdw&oe=670BA6E4"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}]}, "developer_name": "INREAL", "developer_privacy_policy_url": "https://inreal.online/privacypolicyeng", "developer_terms_of_service_url": null, "publisher_name": "INREAL", "support_website_url": null, "website_url": "https://inreal.online/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUI