3CUA1&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATEgeLNUebYljvNTmF2V2CW&oh=00_AYDvJolt6Ob7NIzaMOZKVtNVrq8_PoXh-SeRqs6wsoY2hg&oe=66F0173F"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yGzJGh-55TQQ7kNvgH8k-hR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATEgeLNUebYljvNTmF2V2CW&oh=00_AYCX5liUmy3ebTHY9CcM2kqd6wX8ruBifN3Jnx4tHIk_EQ&oe=66F00779"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6JBMnX9qU5UQ7kNvgGS_-_z&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATEgeLNUebYljvNTmF2V2CW&oh=00_AYCIWSux9Ic594_JIzntTv9qqcBOLEq4h5gGHtYeFRZ5Uw&oe=66EFF764"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_desc