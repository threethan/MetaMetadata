5_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BaZNH-6OX90Q7kNvgF09zI6&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYB7BUla-FW3mYg5MWz7ICSk1EUJphtvmDyteQoASs1O-A&oe=66E03579"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qf6Dw0I4-3YQ7kNvgH75of3&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYDrC5eW1TDEjZtbHEt3R1yQSJxAc5Vdl6VDyAYN2D-CXg&oe=66E02564"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}, {"images": {"nodes": [{"file_name": "1080x360.png", "id": "3119915358249525", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236_3119915361582858_6545192787103876952_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kYUd0BrnoIYQ7kNvgHDneEO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYC2pow8PZCPmZk8zZ_8qF60kqtkum0FHdQYxmfe-2NX_w&oe=66E03E8D"}, {"file_name": "1008x1440.png", "id": "1446079785740864", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322595_1446079792407530_5254163000743833631_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m4kLp4CsjugQ7kNvgF40_Dt&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYAJD05OEcn2xkVcPL9Tnt-he7SvsMn63UqriUM9F3rSfg&oe=66E032A1"}, {"file_name": "2560x1440.png", "id": "955673598546327", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86634394_955673601879660_5741107853444331358_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pFDu8drNAlwQ7kNvgFZAGLY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYBlFMf4RqjemefXcKC8kQSTs7Prq6DurCKUZ_IaVwn7QA&oe=66E03BEE"}, {"file_name": "38974483_726523611561315_8747720002162579260_n.png", "id": "824848701484673", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375752_824848704818006_6565657883099149214_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y8XiCzMalj8Q7kNvgFCllIf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADLQSeIRP8FPwqI-gOera8P&oh=00_AYBye23eBRbJSYJd0XNfBmW5dIbg_VvdMUZhgUAC7sB9sw&oe=66E01D65"}, {"file_name": "3000x900.png", "id": "804253526945916", "image_type": "APP_IMG_HERO", "uri": "https://sco