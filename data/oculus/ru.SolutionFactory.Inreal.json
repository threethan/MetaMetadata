5_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V8WB9BNETzIQ7kNvgFeoKdV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYDHBqRVlVrdwXdhWM0bkIqM7qhcWc3uTDyiuRkguHnkVA&oe=66E81E79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SVdpDo7bdJgQ7kNvgGgJQiS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYAfwJkyfQ4_xlUbUw6NL-ypaQ1-iky00M5ty-hcV1hVzg&oe=66E80E64"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}, {"images": {"nodes": [{"file_name": "1080x360.png", "id": "3119915358249525", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236_3119915361582858_6545192787103876952_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3uimnziijEsQ7kNvgGUpcff&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYDPoafc1e8X_zX3peAeSdCyOeYFoDvNmHG7mjNNlREf8A&oe=66E8278D"}, {"file_name": "1008x1440.png", "id": "1446079785740864", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322595_1446079792407530_5254163000743833631_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IIkJd0TtIloQ7kNvgEfYH1_&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYCfvpoJIsCLiee0Bo0hmyy7fPUJy4Anqdu-21g9_JtHpg&oe=66E81BA1"}, {"file_name": "2560x1440.png", "id": "955673598546327", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86634394_955673601879660_5741107853444331358_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K83GYQVXHJgQ7kNvgEkSH4L&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYBwi04zJjSu-zw5jpIY9XHH3UyschOe35o_bhaMml8Hrg&oe=66E824EE"}, {"file_name": "38974483_726523611561315_8747720002162579260_n.png", "id": "824848701484673", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375752_824848704818006_6565657883099149214_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lCl0w1oWiscQ7kNvgG8K25S&_nc_ht=scontent.oculuscdn.com&_nc_gid=A79HCfl17qyakqz-SoUb5P2&oh=00_AYDaSgJXfmni5aMlLG_-BpBmNMbHJcRofXdYhOt4cK5SgQ&oe=66E80665"}, {"file_name": "3000x900.png", "id": "804253526945916", "image_type": "APP_IMG_HERO", "uri": "https://sco