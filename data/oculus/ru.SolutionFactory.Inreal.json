s_VRAQ7kNvgHtIUjv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXdr4cAEAC_-o49pcgzVTrFV1mySFUt8FUmfC9_wk60Q&oe=66EC0C3B"}, {"file_name": "Inreal_20210311T144220Z.png", "id": "483409719471779", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031322_483409722805112_1496698754582646786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-yxaf6QApIQ7kNvgE3oUes&_nc_ht=scontent.oculuscdn.com&oh=00_AYClfVYDmSZicr4R9vW6tYETwOjfzfYYXRo-m0qg_V_-VQ&oe=66EC22BF"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eYurRoaPqk0Q7kNvgHoeRWI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjLOCUwQPNtXDd-3VTvwuIL0lr62vJwv-opuxh3pD1_A&oe=66EC12F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cuYOlYT34VMQ7kNvgElph2O&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZB3mwFZRp5CB6JrmvlGKykaTAYtcf4-l382LtWXAYdg&oe=66EC02E4"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}]}, "developer_name": "INREAL", "developer_privacy_policy_url": "https://inreal.online/privacypolicyeng", "developer_terms_of_service_url": null, "publisher_name": "INREAL", "support_website_url": null, "website_url": "https://inreal.online/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "395491819001788"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5606065509488785", "version": "059ded555521523d"}, "id