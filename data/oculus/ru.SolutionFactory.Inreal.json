7kNvgHLl_YZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBGV5EGJ_1oZaCVXIsx5hbF_7lWu8CK9Skvyw4VDZ1XGA&oe=671B88F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mYTa_NWRFJ8Q7kNvgHCEyVK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDk_kH4D_9PdmZTkyfKqPa-aLsCbSKLsjhRJnuIz8CucQ&oe=671B78E4"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}, {"images": {"nodes": [{"file_name": "1080x360.png", "id": "3119915358249525", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75294236_3119915361582858_6545192787103876952_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HmFQywW1UD4Q7kNvgHHZtg1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFRQI-mLjuKafgAywiNYKPp-MqCk9CPg1uCg3e2xmGgg&oe=671B920D"}, {"file_name": "1008x1440.png", "id": "1446079785740864", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75322595_1446079792407530_5254163000743833631_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-Y_bxZt9FwQ7kNvgF1YH_0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCs737Y0vXn_Zs710DuiV-Uq0RxmVWzv0ZhG_qGTFTCtg&oe=671B8621"}, {"file_name": "2560x1440.png", "id": "955673598546327", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86634394_955673601879660_5741107853444331358_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QmVym0YKxH4Q7kNvgFjOTS7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlLq7K8FTr36O9XMz-u71gPPMlYsRSKWGkc01Qz0WT3g&oe=671B8F6E"}, {"file_name": "38974483_726523611561315_8747720002162579260_n.png", "id": "824848701484673", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375752_824848704818006_6565657883099149214_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uy2L1TgYs1AQ7kNvgFD4wws&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfg3XzJO3Lc9w3CmXEUo5SiJ2EGBvkJIrVCA0qwPMk-w&oe=671B70E5"}, {"file_name": "3000x900.png", "id": "804253526945916", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314849_804253530279249_945778578296609791_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gvgJjWR6uAAQ7kNvgH3BDuG&_