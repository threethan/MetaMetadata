scontent.oculuscdn.com&oh=00_AYDWrB8pvC8AnG8bOL8AeWjII0v4bDQEmovFac-xemZr1w&oe=66FBE3BF"}]}, "id": "1119778328772777", "locale": "en_US", "screenshots": [{"file_name": "Inreal_20210707T085945Z.png", "id": "1012817836127254", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443242_1012817839460587_1948243825525830173_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6_H5HrILhB0Q7kNvgEYKJUH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBcG-nSzHrreVMJdn_o6AsmxJgxmLdNe3eP7qwvcaRi-g&oe=66FBF298"}, {"file_name": "Inreal_20210311T143739Z.png", "id": "184564026524755", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003263_184564029858088_7212951086265236834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ujMgRb5YPX8Q7kNvgFZLbDv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIq_4FZvtkQMwf_-0CYTFB8jRZGjVemq_ZmJmGBF3kGg&oe=66FBCF21"}, {"file_name": "Inreal_20210707T091729Z.png", "id": "330742758725374", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_330742762058707_9023178974783749073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w0DWiNrDOdsQ7kNvgF1880l&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPGx3aYdTsigOW8a8VqY6jCjj3CzC5tf4O80Sd9g3fVA&oe=66FBDE3B"}, {"file_name": "Inreal_20210311T144220Z.png", "id": "483409719471779", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031322_483409722805112_1496698754582646786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zzHZfHriqgUQ7kNvgFEF_Xf&_nc_ht=scontent.oculuscdn.com&oh=00_AYBlojfkVAXRT_hDlqB-7dP0jDzH1zMjcFcti3SDxbfa1w&oe=66FBF4BF"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5vGHsHP4ysQ7kNvgFtJ4dW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDG7QeZlvGC702F2E2dDr1LU4kH2OEYjMgbGrN4oHNGHg&oe=66FBE4F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pcL4hL3USGgQ7kNvgHlOJnb&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmrWai42RZWlqYylt9wKE62G0qUEkSS_PJux2lhV36wA&oe=66FBD4E4"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}, {"images": {"nodes": [{"file_name": "1080x360.png", "id": "3119915358249525", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236