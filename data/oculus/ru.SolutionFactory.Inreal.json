cb=1-7&_nc_sid=6e7a0a&_nc_ohc=2bpyCUmtN9EQ7kNvgHlp6A0&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDpVk7G0bJbAYsasJ-oMLmlRf53Fu-qC2LwiwjrycG_ag&oe=67028A18"}, {"file_name": "Inreal_20210311T143739Z.png", "id": "184564026524755", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39003263_184564029858088_7212951086265236834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VCY4sMyrCGAQ7kNvgG08EcV&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAyxj_uc1bRwqWQ9vTFODcsyHm-6_1G8XxeGiu9hhPobg&oe=670266A1"}, {"file_name": "Inreal_20210707T091729Z.png", "id": "330742758725374", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982658_330742762058707_9023178974783749073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=40USTexibSIQ7kNvgH95Vy2&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAzEhTdh6HHER6NOkfUR2MA1dh9RFdnNzjTk_o7kHWmmQ&oe=670275BB"}, {"file_name": "Inreal_20210311T144220Z.png", "id": "483409719471779", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031322_483409722805112_1496698754582646786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mKyhUNWR8Q4Q7kNvgHp3YP4&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCMT6Sa9pycMqrlR_tC3Ks60Kc4iswi5e7vROo5Fl__1Q&oe=67028C3F"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XFA_PVP-gfIQ7kNvgFIMNPB&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCkudFEU0L8G000SSt_EFIy52wysD1pNChluiVquH4Hrg&oe=67027C79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xjj2ccbJgBgQ7kNvgFRFOf_&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDZbFQ5kIdCqfbbCg53Y-_gy6Go2xE1LJhff6l8BOHjmQ&oe=67026C64"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}]}, "developer_name": "INREAL", "developer_privacy_policy_url": "https://inreal.online/privacypolicyeng", "developer_terms_of_service_url": null, "publisher_name": "INREAL", "support_website_url": null, "website_url": "https://inreal.online/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUI