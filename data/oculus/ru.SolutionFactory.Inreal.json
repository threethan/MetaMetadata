scontent.oculuscdn.com&oh=00_AYDlbQ__o7ESFHliQ-KA9wqOYNivcSdSHTU3yIA6S6z_5A&oe=66FE86BF"}]}, "id": "1119778328772777", "locale": "en_US", "screenshots": [{"file_name": "Inreal_20210707T085945Z.png", "id": "1012817836127254", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443242_1012817839460587_1948243825525830173_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6_H5HrILhB0Q7kNvgGumFrJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhQyafFFuE1iBCX7L6pKyT9Qs5VndHqnZr5U2Z4eEACg&oe=66FE9598"}, {"file_name": "Inreal_20210311T143739Z.png", "id": "184564026524755", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003263_184564029858088_7212951086265236834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ujMgRb5YPX8Q7kNvgHo7g5b&_nc_ht=scontent.oculuscdn.com&oh=00_AYBH4zZ0v6lyw2bpXPFV3svY-FzGDgozSrQMJzA7yy3u4A&oe=66FE7221"}, {"file_name": "Inreal_20210707T091729Z.png", "id": "330742758725374", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_330742762058707_9023178974783749073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dd46G07DJPkQ7kNvgFcilNG&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkWN8TZLGbx0mL4pf0fkb4lKIZQtOUn4wiMY4b3Hohng&oe=66FE813B"}, {"file_name": "Inreal_20210311T144220Z.png", "id": "483409719471779", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031322_483409722805112_1496698754582646786_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zzHZfHriqgUQ7kNvgEJ8xAk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTu8yqj9W78VKP0l4KPYqgny2atLQFnTlu0f_We1iB6w&oe=66FE97BF"}, {"file_name": "Inreal_20210311T144824Z.png", "id": "135858941699855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_135858945033188_411072329942497310_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5vGHsHP4ysQ7kNvgFCM-Ij&_nc_ht=scontent.oculuscdn.com&oh=00_AYAszhr9nitRsjh_E5f0lg8rciBm9jjWmQZSpdmpGu582g&oe=66FE87F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "5467090-abstract-wal (1).png", "id": "550937552939703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210400_550937559606369_6381882796231696618_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ryme-xqZvcQ7kNvgF1eop2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZ_9P4tDEEKs1EUuhQRP7iMuW1_PbVUh62f4pai6KJQA&oe=66FE77E4"}, "display_name": "INREAL", "keywords": [], "long_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are.\n\nIn your tablet you will find a large set of tools that are indispensable for teamwork: whiteboards, virtual markers, geometric rulers, stickers and much more, as well as you will have the opportunity to download the images, videos and 3D models you need and use them during meetings or presentations.\n\nVirtual worlds that imitate the environment of an office or lecture hall, photorealistic avatars, will allow you to immerse yourself in a virtual environment and focus on communication or work.", "short_description": "INREAL is a modern platform where you will forget about existing geographic and physical boundaries and feel as if you are with your friends or colleagues.\n\nIn INREAL, you can make video calls outside VR through any video communication service convenient for you: Zoom, Skype, Microsoft Team, Twitch and others, connect directly to your computer from virtual reality to use the applications most important to you , and share links and files with other meeting participants wherever they are."}, {"images": {"nodes": [{"file_name": "1080x360.png", "id": "3119915358249525", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294236