f&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYDv9JE3WnMT6BKAWq8g32xxz9yK2OZf7qdSm2EzHLye_g&oe=66F2BA75"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "8336887969683188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036662_8336887973016521_5591144575698802230_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N29d7iV3pPQQ7kNvgGS2e-a&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYD04Met7ZQ1Ag2YZRfYLiccwEHfutlE9rwq6DNGbvBsOA&oe=66F2B6C9"}, "display_name": "Pet Doctor", "keywords": ["arcadeidle", "idle", "fun", "Animal", "Veterinarian"], "long_description": "Pet Doctor is an engaging VR and arcade idle game where players take on the role of a veterinarian, responsible for treating a variety of animals. From mending broken bones to diagnosing infections, players utilize their medical skills to help their patients recover and thrive. As the game progresses, players can expand their clinic with new equipment, enhancing their ability to care for more animals and tackle increasingly complex cases.\n\nWith numerous levels and daily challenges, Pet Doctor offers a rewarding gameplay experience that combines strategic planning and engaging challenges. As players advance, they unlock new animals, tools, and clinic upgrades, adding depth to the game. The game's captivating visuals and accessible gameplay mechanics ensure it is enjoyable for a wide audience, particularly those who are passionate about animals.\n\nWhether you're immersed in the VR environment or enjoying the idle gameplay mode, Pet Doctor provides the perfect blend of relaxation and excitement as you build your clinic and care for your animal patients on their road to recovery!", "short_description": "Pet Doctor is a VR and arcade idle game where players step into the role of a veterinarian responsible for caring for a variety of animals. Players must use their skills to diagnose and treat different pets while managing and upgrading their clinic. With a diverse range of animals to care for and a calming gameplay experience, Pet Doctor offers engaging and rewarding gameplay for anyone who enjoys strategy and simulation games. Expand your clinic, treat your patients, and become the ultimate pet"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/pet-doctor", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "961172191044986"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8829567207073023"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1560403254906832"}]}, "baseline_offer": {"id": "1560403254906832"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726267501, "status": "PUBLISHED", "id": "1560403254906832"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8827786887251055", "version": "3"}, "id": "878611640356147", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": 