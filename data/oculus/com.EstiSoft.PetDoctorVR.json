wa4E0-Xt87lmpuJlK_&oh=00_AYDBRnbJ3PeMgNCKbUZQKXSS4y0xV1iPSP6qxSarlTrQiQ&oe=66F2B80B"}, {"file_name": "4.png", "id": "431511143277531", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001707_431511149944197_1167809239338159518_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-Ddc4sMoSgQ7kNvgGbnbtA&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYCUAuOcjwJgjqdanrT4n5f8fEIge-I6pDEgNqi94i0KOQ&oe=66F2B557"}, {"file_name": "1.png", "id": "532507495822932", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982722_532507499156265_5732531680935524395_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6m2vLFUBbqcQ7kNvgGTPmvo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYCAf2YoBDRl8z326eyDzBeUXlYDlIzTXYJo_efcE7tCtQ&oe=66F29651"}, {"file_name": "5.png", "id": "1703849130379650", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974579_1703849133712983_7947250077501606259_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qsH5Xq59K9QQ7kNvgGIT5jy&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYCRRGu0l1r9kLpugrbgAVUHll0Uy5RiqBFceto1hUqrhg&oe=66F2A5BD"}, {"file_name": "3.png", "id": "828353402839594", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974702_828353406172927_2110914434387565788_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bt668pKvlg0Q7kNvgGF2tdf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYDv9JE3WnMT6BKAWq8g32xxz9yK2OZf7qdSm2EzHLye_g&oe=66F2BA75"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "8336887969683188", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036662_8336887973016521_5591144575698802230_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N29d7iV3pPQQ7kNvgGS2e-a&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALPQpwa4E0-Xt87lmpuJlK_&oh=00_AYD04Met7ZQ1Ag2YZRfYLiccwEHfutlE9rwq6DNGbvBsOA&oe=66F2B6C9"}, "display_name": "Pet Doctor", "keywords": ["arcadeidle", "idle", "fun", "Animal", "Veterinarian"], "long_description": "Pet Doctor is an engaging VR and arcade idle game where players take on the role of a veterinarian, responsible for treating a variety of animals. From mending broken bones to diagnosing infections, players utilize their medical skills to help their patients recover and thrive. As the game progresses, players can expand their clinic with new equipment, enhancing their ability to care for more animals and tackle increasingly complex cases.\n\nWith numerous levels and daily challenges, Pet Doctor offers a rewarding gameplay experience that combines strategic planning and engaging challenges. As players advance, they unlock new animals, tools, and clinic upgrades, adding depth to the game. The game's captivating visuals and accessible gameplay mechanics ensure it is enjoyable for a wide audience, particularly those who are passionate about animals.\n\nWhether you're immersed in the VR environment or enjoying the idle gameplay mode, Pet Doctor provides the perfect blend of relaxation and excitement as you build your clinic and care for your animal patients on their road to recovery!", "short_description": "Pet Doctor is a VR and arcade idle game where players step into the role of a veterinarian responsible for caring for a variety of animals. Players must use their skills to diagnose and treat different pets while managing and upgrading their clinic. With a diverse range of animals to care for and a calming gameplay experience, Pet Doctor offers engaging and rewarding gameplay for anyone who enjoys strategy and simulation games. Expand your clinic, treat your patients, and become the ultimate pet"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/pet-doctor", "category": null, "comfort_rating": "COMFORTABLE_FOR_