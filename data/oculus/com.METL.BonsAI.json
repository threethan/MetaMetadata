ad3-1.oculuscdn.com&oh=00_AYCIua-a0tFTM5wWIHhWTuHYMr7LHXnr2Z0wSDW6HOWr6A&oe=67713857"}, {"file_name": "DroneVision.png", "id": "1359000001125319", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982648_1359000004458652_7227389611288828689_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J5atdbXewzUQ7kNvgG-KJ8a&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYuU-mJIjFpmK3kv2vyW95rwd7yN9Kkx-iktY_8EB9Gw&oe=67712122"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo2560x1440.png", "id": "461677318355524", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974864_461677321688857_139602460111776365_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PCwYmxgWmX8Q7kNvgEv8dZf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAX_aAQAVZ-Wc8AbRYiYlitl7NwWexDkg5oW3xWSrIyvQ&oe=67714A27"}, "display_name": "BonsAI", "keywords": [], "long_description": "BonsAI is a narrative experience featuring hand tracking.\n\nA novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness.\n\nFrom the developers:\n\nWe met for the first time in March 2020 during METL\u2019s very first Immersive Media Residency in Winston-Salem, North Carolina just as the world was beginning to understand the seriousness of COVID-19. BonsAI sprang from a wish amidst the heaviness of the pandemic: to give people a memory of saving the world by blending nature and technology. With this short narrative experience, we wanted to provide a radically positive vision of a possible future. We hope you enjoy it.", "short_description": "A novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness."}]}, "developer_name": "Trent Spivey, Alex Moro and Fernando Goyret", "developer_privacy_policy_url": "https://sites.google.com/view/bonsaiprivacypolicy/ho