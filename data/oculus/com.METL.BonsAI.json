FmCOnq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAL2Hn2XUBuWcnwdiybfUkMwflrNzP8xGlypt2ngxfeaA&oe=676BEB7A"}, {"file_name": "Hangar_Blowdelion.png", "id": "429261505187785", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974738_429261508521118_2688888966824031806_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f0dX5XKIUEcQ7kNvgHCUpAE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHZvHG_CFApVkcDCuikEUVEPgo-_V2WfNiYHsPyZ1ANQ&oe=676BF257"}, {"file_name": "DroneVision.png", "id": "1359000001125319", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982648_1359000004458652_7227389611288828689_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4aUKEC67X58Q7kNvgFxoZcD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5q35ARGa_2hbxFiN09D9EnxWzVtyMXk4ZAiVfjxZEAQ&oe=676BDB22"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo2560x1440.png", "id": "461677318355524", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974864_461677321688857_139602460111776365_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nKVXroKlVBUQ7kNvgEPYmNM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlK4uDmbxsmn4TqshFcfwTvnVkJ52cP8t3lyLLuYhJ6w&oe=676C0427"}, "display_name": "BonsAI", "keywords": [], "long_description": "BonsAI is a narrative experience featuring hand tracking.\n\nA novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness.\n\nFrom the developers:\n\nWe met for the first time in March 2020 during METL\u2019s very first Immersive Media Residency in Winston-Salem, North Carolina just as the world was beginning to understand the seriousness of COVID-19. BonsAI sprang from a wish amidst the heaviness of the pandemic: to give people a memory of saving the world by blending nature and technology. With this short narrative experience, we wanted to provide a radically positive vision of a possible future. We hope you enjoy it.", "short_description": "A novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness."}]}, "developer_name": "Trent Spivey, Alex Moro and Fernando Goyret", "developer_privacy_policy_url": "https://sites.google.com/view/bonsaiprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "METL", "support_website_url": null, "website_url": "https://www.uncsa.edu/metl/residency-program/2020-residency.aspx", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1008279844328894"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "360616258909065"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035342_137577571546981_2272057334843838698_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J8T7c36ffV8Q7kNvgFZIkhg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDt0NF-zaF81wo6Q5bBi03s99v0zxukOd06JoFMmVyP0Q&oe=676BDAAC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BonsAI", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Narrative", "id": "1008279844328894"}, {"topic_name": "Action", "id": "459781504968480"}], "release_da