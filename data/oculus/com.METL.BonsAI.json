7650035_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IeckLkuIejMQ7kNvgHoLAWa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN34mshDuxgLyt9qwQOyzzh&oh=00_AYCk6kEoTUVvPWq2ZV3zy1GIsJ4ydOUi5Fyk9UHN-CbeYg&oe=66EFFE7A"}, {"file_name": "Hangar_Blowdelion.png", "id": "429261505187785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974738_429261508521118_2688888966824031806_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rv2g-YWtMekQ7kNvgHEcjMw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN34mshDuxgLyt9qwQOyzzh&oh=00_AYBub7Et1LS9IDPL6v6we-T9G-lZuiO0OlDPfMkeUZPjsw&oe=66F00557"}, {"file_name": "DroneVision.png", "id": "1359000001125319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982648_1359000004458652_7227389611288828689_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dXFMmbXy3hEQ7kNvgHnNsJn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN34mshDuxgLyt9qwQOyzzh&oh=00_AYBZoDTyOhxaDn4OjihCzNx_7iy0klhEiNWNL5RDT9xeXg&oe=66EFEE22"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo2560x1440.png", "id": "461677318355524", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_461677321688857_139602460111776365_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iOfR30NVMeIQ7kNvgFeynt2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN34mshDuxgLyt9qwQOyzzh&oh=00_AYAwxcOdY0PuJxwwSwmUk3n6i20Cp0Vp7Ls-ljKOAcpWmA&oe=66F01727"}, "display_name": "BonsAI", "keywords": [], "long_description": "BonsAI is a narrative experience featuring hand tracking.\n\nA novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness.\n\nFrom the developers:\n\nWe met for the first time in March 2020 during METL\u2019s very first Immersive Media Residency in Winston-Salem, North Carolina just as the world was beginning to understand the seriousness of COVID-19. BonsAI sprang from a wish amidst the heaviness of the pandemic: to give people a memory of saving the world by blending nature and technology. With this short narrative experience, we wanted to provide a radically positive vision of a possible future. We hope you enjoy it.", "short_description": "A novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness."}]}, "developer_name": "Trent Spivey, Alex Moro and Fernando Goyret", "developer_privacy_policy_url": "https://sites.google.com/view/bonsaiprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "METL", "support_website_url": null, "website_url": "https://www.uncsa.edu/metl/residency-program/2020-residency.aspx", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "360616258909065"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035342_137577571546981_2272057334843838698_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cuMuWMlwiv8Q7kNvgEQ9iUW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN34mshDuxgLyt9qwQOyzzh&oh=00_AYCAfnFV1-r1Ae8o89SyyXnnysdwIgxBqte19HZ538EC4w&oe=66EFEDAC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BonsAI", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1617669709, "lastRevision": {"nodes": [{"id": "3698676413511760", "release_t