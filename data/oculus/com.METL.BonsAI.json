": "SeedlingInHand.png", "id": "135631955001811", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_135631958335144_1978491405307650035_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nEhPjJcvxUAQ7kNvgGapiFY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApP9HUdWrCURJyFjDE2YEge&oh=00_AYCs9so24r5x1tnTEIrZDr6en3BjL2gJdUp6iMxEmRb6jA&oe=66E8157A"}, {"file_name": "Hangar_Blowdelion.png", "id": "429261505187785", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974738_429261508521118_2688888966824031806_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9YbWsLksF6IQ7kNvgFQmDn9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApP9HUdWrCURJyFjDE2YEge&oh=00_AYCJHMKJreXX1k1si9wsPAB5HV9Y0lfKxfJn-I1JD_yfcw&oe=66E81C57"}, {"file_name": "DroneVision.png", "id": "1359000001125319", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982648_1359000004458652_7227389611288828689_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gvvEEMOCWogQ7kNvgHScsm9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApP9HUdWrCURJyFjDE2YEge&oh=00_AYAJcOozfptnCqkKTihWuVlxz_BxTSncRIV1MVW4qFHkVg&oe=66E80522"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo2560x1440.png", "id": "461677318355524", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_461677321688857_139602460111776365_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wk0SxSWjlxkQ7kNvgH4UYOJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApP9HUdWrCURJyFjDE2YEge&oh=00_AYAcRYr0pxUXy7e-02t5l-rdKtp9fd1nT6xq6Sl-5ih6sA&oe=66E82E27"}, "display_name": "BonsAI", "keywords": [], "long_description": "The three of us met for the first time on March 2, 2020 for METL\u2019s inaugural Immersive Media Residency in Winston-Salem, North Carolina. What followed were six months of inspiration, growth, adversity, and the burning desire to make something authentic. \n\nBonsAI came to us roughly two months into our time together, springing from a wish amidst the heaviness of the pandemic: to give folks a memory of saving the world by blending nature and technology. We wanted to provide a radically positive vision of a possible future. Just weeks before, the world shifted to disrupt what we thought our futures would be. ", "short_description": "A novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness."}]}, "developer_name": "Trent, Alex and Fernando", "developer_privacy_policy_url": "https://sites.google.com/view/bonsaiprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "METL", "support_website_url": null, "website_url": "https://www.uncsa.edu/metl/residency-program/2020-residency.aspx", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "964756971068890"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1502668190118001"}]}, "baseline_offer": {"id": "1502668190118001"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1617669780, "status": "PUBLISHED", "id": "1502668190118001"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6971749946172808", "version": "1.0"}, "id": "1478726018987881", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "438531