ature and technology. We wanted to provide a radically positive vision of a possible future. Just weeks before, the world shifted to disrupt what we thought our futures would be. ", "short_description": "A novel plant virus threatens the world's vegetation. As the new assistant to a top botanist, you step up to save the day while avoiding the clutches of an evil agribusiness."}]}, "developer_name": "Trent, Alex and Fernando", "developer_privacy_policy_url": "https://sites.google.com/view/bonsaiprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "METL", "support_website_url": null, "website_url": "https://www.uncsa.edu/metl/residency-program/2020-residency.aspx", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1008279844328894"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "964756971068890"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1502668190118001"}]}, "baseline_offer": {"id": "1502668190118001"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1617669780, "status": "PUBLISHED", "id": "1502668190118001"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6971749946172808", "version": "1.0"}, "id": "1478726018987881", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "And