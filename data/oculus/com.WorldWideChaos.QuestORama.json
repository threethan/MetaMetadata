_3152039310657209185_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOuk_9i55IEQ7kNvgEMOaoP&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBZ5cyUBwf0upQA4E0P2_p4kHIz7kpSgP5yNJ6BSOW9Mw&oe=67012438"}, {"file_name": "AppLab-Screenshot1.png", "id": "287089292808520", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974787_287089296141853_444106832633864054_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzxRxR7TYDkQ7kNvgGn0ulo&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEzyHoOqRrlGzRErPQvkm50eQPIqcfWMXnXHgy_NVXPQ&oe=67011AF4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "QOR (QuestORama)", "keywords": [], "long_description": "Inspired by Dactyl Nightmare and Tron, you are the computer virus, sent by nefarious hackers to take down a server from the inside. Use rocket jumps, grappling hooks, and climbing to quickly dart around each Node of the server, stealing every bit of data you can before bringing the whole thing down. \n\nProcedural generation of the levels and enemies keeps every fight new and fresh. Slow down time mid-flight for insane maneuvers and Hollywood movie-style gun fights. Buy upgrades, modify your weapons, crack puzzles, and more in this Retro Tron-esque world on the other side of the computer screen. ", "short_description": "Retro Grapple-Gun Shooter! Survive in mind-bending procedurally generated worlds with a computer server you're trying to loot and destroy. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://i.stack.imgur.com/lXzGI.jpg", "developer_terms_of_service_url": null, "publisher_name": "World Wide Chaos", "support_website_url": null, "website_url": "http://www.worldwidechaosinc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet