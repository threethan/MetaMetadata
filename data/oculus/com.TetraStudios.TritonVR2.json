: "OculusScreenshot1.png", "id": "359631729899732", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75532179_359631733233065_7998893518034454882_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=slLCPI-gmbgQ7kNvgEHLpAh&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ark_YrJGpp-RmsuyaRNavdk&oh=00_AYAC-6fWMvMVCchDSC48GTcbl4sQ8mXinQTjsN3jX1zg0Q&oe=66F69091"}, {"file_name": "OculusScreenshot3.png", "id": "1422047048384773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974714_1422047051718106_7215813195562031034_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DiEUG7gU80oQ7kNvgFFL8zC&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ark_YrJGpp-RmsuyaRNavdk&oh=00_AYCoBn4keJi3EnXnlUaF6nSKRDvfj6GhSMOaccbUpfBblA&oe=66F69792"}, {"file_name": "OculusScreenshot5.png", "id": "667149165591308", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429290_667149168924641_6609562516381524837_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJb7gaP2LoIQ7kNvgHwNhRB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ark_YrJGpp-RmsuyaRNavdk&oh=00_AYDtcakl_kVS8mi1PZ19hRqNZJyKR2dVg1SOP_GEE_PxlA&oe=66F69A3C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HeroLandscape.png", "id": "277489128156801", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_277489134823467_4204457001143684943_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fQe5CgKm_CkQ7kNvgE-T5rS&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ark_YrJGpp-RmsuyaRNavdk&oh=00_AYDAXgk75lCV-gz_HdK58-UaBDMnTnpOd7YQYYNYrtidWg&oe=66F6A0A4"}, "display_name": "TritonVR 2: Next Gen MR Warfare", "keywords": [], "long_description": "The next generation of VR is here. Created from the ground-up and iterating on its predecessor, TritonVR 2 combines thrilling yet accessible VR combat with platform-defining shared-space gameplay - you\u2019ll need to move around your play area in real life to move in the game, in custom-built maps designed for any playspace size.\n\nSettle your differences in fast-paced and high-stakes PvP warfare, both online or locally. And new to the series is the next-generation map editor, World Weaver. Utilising the latest tech advancements, this editor will intelligently build a map from your exact play-space dimensions to create a one-of-a-kind map that you and your friends can battle on.", "short_description": "Turn any playspace into the ultimate multiplayer combat arena in TritonVR 2! Using cutting-edge tech, TritonVR 2 allows you to turn any area into a battlefield, with up to 4 players simultaneously able to compete in the action."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.tetrastudios.com.au/privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "Tetra Studios", "support_website_url": "https://www.tetrastudios.com.au/contact", "website_url": "https://www.tetrastudios.com.au/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6874326265990615"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "883813249964350"}]}, "baseline_offer": {"id": "883813249964350"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1702904400, "status": "PUBLISHED", "id": "883813249964350"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8026776464078917", "version": "1.5.3"}, "id": "260816166552950", "channel_name": "LIVE"}