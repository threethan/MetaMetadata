YBsd-bcy9ae4WrGn-tpeOcv11Lwkrz4TWXKaSkxdrTdAg&oe=675818DC"}, {"file_name": "2023-03-21_19-57-02.png", "id": "232674785924918", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38984463_232674789258251_4733865034867576966_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=emQYy0bl1CQQ7kNvgE2dI-6&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAJeZrdKtng5GVBjEJzLYHb_aUuSAPvTqUj2CQ8VSjr7Q&oe=67581ADB"}, {"file_name": "566.png", "id": "724648312629394", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031588_724648315962727_8458282529807701185_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SLoNfY_Q_5UQ7kNvgExZoyM&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCMhGBFRjx95_onv5felyzGQxLWh-FSDkL-3AMvsx7Iug&oe=6758479F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "111111111111.png", "id": "4866259026832086", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75195913_4866259030165419_751740270347823471_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VB0sUMG_5lAQ7kNvgHnQttN&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYC8nqvLME5dz6CO1S7bdBezKa6tnwZHkmrYrpswD-C4cQ&oe=675818D4"}, "display_name": "MonkeyRush", "keywords": [], "long_description": "You play as a monkey, you just have to have fun, make yourself a set of things in the store and be the most beautiful monkey or play different modes (There will be more and more of them in different updates.) In our game you can find friends and play with them, and talk to them using voice. I hope you enjoy my game>.", "short_description": "This is a game where you play as a monkey). Where you can have the most fun with friends or find friends in the game Monkey Rush. I hope you enjoy my game."}, {"images": {"nodes": []}, "id": "538234485146619", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monkey Rush", "keywords": [], "long_description": "\u0412\u044b \u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0437\u0430 \u043e\u0431\u0435\u0437\u044c\u044f\u043d\u0443, \u0432\u044b \u0434\u043e\u043b\u0436\u043d\u044b \u043f\u0440\u043e\u0441\u0442\u043e \u0440\u0430\u0437\u0432\u043b\u0435\u043a\u0430\u0442\u044c\u0441\u044f, \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0441\u0435\u0431\u0435 \u0441\u0435\u0442 \u0438\u0437 \u0432\u0435\u0449\u0435\u0439 \u0432 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0435 \u0438 \u0431\u044b\u0442\u044c \u0441\u0430\u043c\u043e\u0439 \u043a\u0440\u0430\u0441\u0438\u0432\u043e\u0439 \u043e\u0431\u0435\u0437\u044c\u044f\u043d\u043e\u0439 \u0438\u043b\u0438 \u0438\u0433\u0440\u0430\u0442\u044c \u0432 \u0440\u0430\u0437\u043d\u044b\u0435 \u0440\u0435\u0436\u0438\u043c\u044b( \u0418\u0445 \u0431\u0443\u0434\u0435\u0442 \u0431\u043e\u043b\u044c\u0448\u0435 \u0438 \u0431\u043e\u043b\u044c\u0448\u0435 \u0432 \u0440\u0430\u0437\u043d\u044b\u0445 \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u044f\u0445.) \u0412 \u043d\u0430\u0448\u0435\u0439 \u0438\u0433\u0440\u0435 \u0432\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043d\u0430\u0439\u0442\u0438 \u0434\u0440\u0443\u0437\u0435\u0439 \u0438 \u0438\u0433\u0440\u0430\u0442\u044c \u0441 \u043d\u0438\u043c\u0438, \u0438 \u0440\u0430\u0437\u0433\u043e\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044c \u0441 \u043d\u0438\u043c\u0438 \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e voice. \u043d\u0430\u0434\u0435\u044e\u0441\u044c \u0432\u0430\u043c \u043f\u043e\u043d\u0440\u0430\u0432\u0438\u0442\u0441\u044f \u043c\u043e\u044f \u0438\u0433\u0440\u0430>.", "short_description": "\u042d\u0442\u043e \u0438\u0433\u0440\u0430, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0432\u044b \u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0437\u0430 \u043e\u0431\u0435\u0437\u044c\u044f\u043d\u0443). \u0413\u0434\u0435 \u0432\u044b \u0441\u043c\u043e\u0436\u0435\u0442\u0435 \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0432\u0435\u0441\u0435\u043b\u043e \u043f\u0440\u043e\u0432\u0435\u0441\u0442\u0438 \u0432\u0440\u0435\u043c\u044f \u0441 \u0434\u0440\u0443\u0437\u044c\u044f\u043c\u0438 \u0438\u043b\u0438 \u043d\u0430\u0439\u0442\u0438 \u0434\u0440\u0443\u0437\u0435\u0439 \u0432 \u0438\u0433\u0440\u0435 Monkey Rush. \u042f \u043d\u0430\u0434\u0435\u044e\u0441\u044c, \u0432\u0430\u043c \u043f\u043e\u043d\u0440\u0430\u0432\u0438\u0442\u0441\u044f \u043c\u043e\u044f \u0438\u0433\u0440\u0430."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/monkeyrushprivacy/", "developer_terms_of_service_url": null, "publisher_name": "BelugaTag", "support_website_url": null, "website_url": "http://monkeyrush.ulcraft.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5768035296638236"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6440625869310621", "version": "1.1.2"}, "id": "138905515784447", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6373131432726732", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "64