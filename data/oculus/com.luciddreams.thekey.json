/39031545_538871186670173_4682019170211069952_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W8VggWndu8IQ7kNvgGG5pji&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAerD60V6o3-g-UdY5TyZHQ-vGxTDnvAq7N3MaKzz029Q&oe=67408085"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/YYNtmx", "id": "1308766412659120", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982618_1308766415992453_4163626508893552640_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O3FCbVOnH6AQ7kNvgHkoqnx&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBuSbkDY-YRfpiqvuQJXgPJ-HS6Yg3GTtbUBo44Q5KBiQ&oe=67405CA2"}, "display_name": "The Key", "keywords": ["adventure", "interactive", "award", "key", "animation"], "long_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\nMeet Anna. Anna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery behind The Key without sacrificing too much?\n\nThe Key is a magical realism experience that will take you on a journey through dreams, facing challenges and difficult decisions, leading to a shocking reveal. The Key is NOT a video game. So relax, and let the story guide you.\n\n(20-minute, standing interactive theatrical VR experience) \n\n10' x 10' play area recommended - Touch things to interact - hold the trigger to teleport\n\n\u201cOne of Tribeca's breakout successes\u201d - CNET\n\n\u201cOf particular note are the superbly executed virtual reality technical details, including character design, use of color, and sound design.\u201d\nJury - Tribeca Film Festival", "short_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\n(20-minute, standing interactive theatrical VR experience) \n\nA journey through dreams filled with magical realism, concluding with a shocking reveal.\nAnna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery without sacrificing too much?"}]}, "developer_name": "Lucid Dreams Productions", "developer_privacy_policy_url": "https://www.luciddreamsprod.com/privacy-policy/", "developer_terms_of_service_url": "https://www.luciddreamsprod.com/eula/", "publisher_name": "Lucid Dreams Productions", "support_website_url": null, "website_url": "http://www.luciddreamsprod.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "DOCUMENTARY_HISTORY", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "370765984860174"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974794_502056403726416_5134191428758405120_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aaks7poZvoAQ7kNvgFcRbmS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDZfmnFLvXwO2RrvHGOUC6Nhb9j-qsIgZNsfegM30xi7w&oe=67406631"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Key", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Travel & Exploration", "id": "726368587961803"}], "