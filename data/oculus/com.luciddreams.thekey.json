ed_image.png", "id": "522206502060832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_538871186670173_4682019170211069952_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xU5X_96A1KgQ7kNvgHqsQdk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATCpy4UVRiGkcYdTwJ3A5r_&oh=00_AYBRPvXOuAlO9gWoSCqUSjqI1oCTGdq8NdyxU6D7ABtnkg&oe=66F55B05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/YYNtmx", "id": "1308766412659120", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_1308766415992453_4163626508893552640_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n4_UYi4VRFwQ7kNvgH2di_d&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATCpy4UVRiGkcYdTwJ3A5r_&oh=00_AYCCeDh1z6kJazmeBQbjqrV8JJtatAq7xBXuTOhve-HDQQ&oe=66F53722"}, "display_name": "The Key", "keywords": ["adventure", "interactive", "award", "key", "animation"], "long_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\nMeet Anna. Anna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery behind The Key without sacrificing too much?\n\nThe Key is a magical realism experience that will take you on a journey through dreams, facing challenges and difficult decisions, leading to a shocking reveal. The Key is NOT a video game. So relax, and let the story guide you.\n\n(20-minute, standing interactive theatrical VR experience) \n\n10' x 10' play area recommended - Touch things to interact - hold the trigger to teleport\n\n\u201cOne of Tribeca's breakout successes\u201d - CNET\n\n\u201cOf particular note are the superbly executed virtual reality technical details, including character design, use of color, and sound design.\u201d\nJury - Tribeca Film Festival", "short_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\n(20-minute, standing interactive theatrical VR experience) \n\nA journey through dreams filled with magical realism, concluding with a shocking reveal.\nAnna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery without sacrificing too much?"}]}, "developer_name": "Lucid Dreams Productions", "developer_privacy_policy_url": "https://www.luciddreamsprod.com/privacy-policy/", "developer_terms_of_service_url": "https://www.luciddreamsprod.com/eula/", "publisher_name": "Lucid Dreams Productions", "support_website_url": null, "website_url": "http://www.luciddreamsprod.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1499583320412802"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "DOCUMENTARY_HISTORY", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "370765984860174"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_502056403726416_5134191428758405120_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nPG5-8a7VUMQ7kNvgFangXW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATCpy4UVRiGkcYdTwJ3A5r_&oh=00_AYCkmGy8OqsXwLHpcCkjPjisWVDJWe4jRgrfUCSnY97__w&oe=66F540B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Key", "platform": "ANDROID_6DOF", "context_category": {"context_cate