migrated_image.png", "id": "522206502060832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031545_538871186670173_4682019170211069952_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mGjwLUqEwxcQ7kNvgHV4oCR&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0eZTdavYoO8UK2xSaGLVyL&oh=00_AYCHx44u1oc8-YgolMCUpwYRbXu92TzhMTkY4QN5EXS_KA&oe=66E6DA85"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/YYNtmx", "id": "1308766412659120", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_1308766415992453_4163626508893552640_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=COpNdORu1ScQ7kNvgH3HOMy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0eZTdavYoO8UK2xSaGLVyL&oh=00_AYCtOm7_A4wJKuWO0_J_wZplRs6usRnPfUmYgDhNCD4Mqg&oe=66E6B6A2"}, "display_name": "The Key", "keywords": ["adventure", "interactive", "award", "key", "animation"], "long_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\nMeet Anna. Anna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery behind The Key without sacrificing too much?\n\nThe Key is a magical realism experience that will take you on a journey through dreams, facing challenges and difficult decisions, leading to a shocking reveal. The Key is NOT a video game. So relax, and let the story guide you.\n\n(20-minute, standing interactive theatrical VR experience) \n\n10' x 10' play area recommended - Touch things to interact - hold the trigger to teleport\n\n\u201cOne of Tribeca's breakout successes\u201d - CNET\n\n\u201cOf particular note are the superbly executed virtual reality technical details, including character design, use of color, and sound design.\u201d\nJury - Tribeca Film Festival", "short_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\n(20-minute, standing interactive theatrical VR experience) \n\nA journey through dreams filled with magical realism, concluding with a shocking reveal.\nAnna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery without sacrificing too much?"}]}, "developer_name": "Lucid Dreams Productions", "developer_privacy_policy_url": "https://www.luciddreamsprod.com/privacy-policy/", "developer_terms_of_service_url": "https://www.luciddreamsprod.com/eula/", "publisher_name": "Lucid Dreams Productions", "support_website_url": null, "website_url": "http://www.luciddreamsprod.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1499583320412802"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "DOCUMENTARY_HISTORY", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "370765984860174"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_502056403726416_5134191428758405120_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qCrbDtz8AdcQ7kNvgHt5IVj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0eZTdavYoO8UK2xSaGLVyL&oh=00_AYBTuA4gJhDo1Ptquff1K8So44sJNvEEHwLvUDleNrGidg&oe=66E6C031"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Key", "platform": "ANDROID_6DOF", "context_category"