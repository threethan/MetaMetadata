e_name": "migrated_image.png", "id": "2816084098460083", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974588_467315880574382_5178158506456383488_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZHkN2BDShIQ7kNvgH7xdhc&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDd6JNpZw016rQcBjDcyidmgEq8uQ0C3FR5EAuuCAGAAQ&oe=677E6135"}, {"file_name": "migrated_image.png", "id": "240430290340327", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/57570309_525881104629288_4535729242624753664_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HVNMPDXpAH8Q7kNvgFYHIij&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDTCpVaSAxEgTkEdfCwD64jAt7gF--ko75ErT0K2Tv2aA&oe=677E521D"}, {"file_name": "migrated_image.png", "id": "522206502060832", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031545_538871186670173_4682019170211069952_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Elz9DCnk_oUQ7kNvgHn0t9a&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDkFwRh-oEpSw7MTztOUO5MZiecmUUNgJLlRhBqZtT-FQ&oe=677E7705"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/YYNtmx", "id": "1308766412659120", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/38982618_1308766415992453_4163626508893552640_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9vq1FJMEIecQ7kNvgHpr0S_&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYAfNqWf2wQCQ9x2GJs1ssgr-2xQGzJqXouN2VkVqWTckw&oe=677E5322"}, "display_name": "The Key", "keywords": ["adventure", "interactive", "award", "key", "animation"], "long_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\nMeet Anna. Anna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery behind The Key without sacrificing too much?\n\nThe Key is a magical realism experience that will take you on a journey through dreams, facing challenges and difficult decisions, leading to a shocking reveal. The Key is NOT a video game. So relax, and let the story guide you.\n\n(20-minute, standing interactive theatrical VR experience) \n\n10' x 10' play area recommended - Touch things to interact - hold the trigger to teleport\n\n\u201cOne of Tribeca's breakout successes\u201d - CNET\n\n\u201cOf particular note are the superbly executed virtual reality technical details, including character design, use of color, and sound design.\u201d\nJury - Tribeca Film Festival", "short_description": "***Winner Tribeca Film Festival  Storyscapes Award *** \n** Winner Grand Jury Prize for Best VR Venice Film Festival**\n*Narrated by Alia Shawkat*\n\n(20-minute, standing interactive theatrical VR experience) \n\nA journey through dreams filled with magical realism, concluding with a shocking reveal.\nAnna doesn\u2019t remember her past, but she has vivid dreams about it. In every one of her dreams, there is a mysterious Key. Will you be able to unlock the mystery without sacrificing too much?"}]}, "developer_name": "Lucid Dreams Productions", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://www.luciddreamsprod.com/eula/", "publisher_name": "Lucid Dreams Productions", "support_website_url": null, "website_url": "http://www.luciddreamsprod.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "DOCUMENTARY_HISTORY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": [