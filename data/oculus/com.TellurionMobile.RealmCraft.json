ur hands.\nAdded the concept of dominant hand.\nThe buildings in the world have been improved, the chests are filled with loot.\nThe movement system has been changed and improved.\nMany bugs have been fixed.", "created_date": 1721668626, "id": "8087931814588588", "version": "0.5", "version_code": 40, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5355683574480106", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8395563197158780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "757817938556737"}]}, "change_log": null, "created_date": 1712828177, "id": "7589901697724938", "version": "0.4", "version_code": 39, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5355683574480106", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8395563197158780"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "757817938556737"}]}, "change_log": null, "created_date": 1710927337, "id": "7498955573486218", "version": "0.4", "version_code": 38, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_ap