": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422395_724482509183212_2393691795585506642_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-sJFnbOyQQUQ7kNvgHmzj34&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBIOHxJ3g3EESNpw6ZNHzZLpIg0Y48M5Ypd9esAgBqBw&oe=673C8EAB"}, {"file_name": "5.png", "id": "700969055110483", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395604_700969058443816_4044737004445159089_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g4ZgVRHcv_4Q7kNvgFVeitm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBu6BrsJr-tVxJrEHXw5JzOWJ9HHHddHhPn-3Yx8lnQog&oe=673C8DE6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1396364434468584", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75458092_1396364441135250_4991631154994422202_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D3RRpXD5ccQQ7kNvgFvPyGR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmABSn8kui0rYg6g9cH4R0h6EQPyZ4dVF7xF4FJcAooA&oe=673C8302"}, "display_name": "RealmCraft", "keywords": [], "long_description": "RealmCraft is a sandbox construction game with 3D procedurally generated world. Create and break apart various kinds of blocks, explore the environment, gather resources, craft weapons, build shelter and take part in combat with dangerous opponents.\nThe game offers Creative mode where you focus on breaking new grounds of creation by building the most elaborate structures you can dream of.\nRealmcraft will entertain you for a long time and earn an unforgettable experience.\n\u2022\t3D Sandbox construction game;\n\u2022\tHuge world to explore;\n\u2022\tBuild and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-po