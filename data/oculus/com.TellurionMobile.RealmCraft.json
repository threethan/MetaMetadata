_&oh=00_AYDWb2hygeuya2mr-Qun4GrxZzPXpNxV6R0CHpEQJW1ICA&oe=66E97482"}, "display_name": "RealmCraft", "keywords": [], "long_description": "RealmCraft is a sandbox construction game with 3D procedurally generated world. Create and break apart various kinds of blocks, explore the environment, gather resources, craft weapons, build shelter and take part in combat with dangerous opponents.\nThe game offers Creative mode where you focus on breaking new grounds of creation by building the most elaborate structures you can dream of.\nRealmcraft is a game for adults and kids, it will entertain you for a long time and earn an unforgettable experience.\n\u2022\t3D Sandbox construction game;\n\u2022\tHuge world to explore;\n\u2022\tBuild and destroy everything;\n\u2022\tBuild your own shelter;\n\u2022\tGo deep into the mines;\n\u2022\tFight your enemies;\n\u2022\tCreative mode to set your imagination free.", "short_description": "Sandbox block craft game. Build and explore!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.tellurionmobile.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Tellurion Mobile", "support_website_url": null, "website_url": "https://www.realmcraft.app/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "ACTION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru", "pt"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "445339520296302"}}]