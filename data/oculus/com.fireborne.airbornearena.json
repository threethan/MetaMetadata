nd shoot at the other riders using different weapons and special powers to give you an edge during the race.", "short_description": "Airborne Arena is an intense and action-packed VR racing-shooter game where the player embodies a hoverbike rider in a 2058's sci-fi, dystopian setting.\nFollow the single player campaing to unveil Rider City's story or race against other riders in the multiplayer and arena modes."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.firebornegames.com/inicio/airbornearenaprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Fireborne Games", "support_website_url": null, "website_url": "https://uruguayvideogames.com/game/airborne-arena/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "673385183287495"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "RACING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6851703121606390"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "376428628628817"}, {"status": "PUBLISHED", "id": "1105560240448872"}]}, "baseline_offer": {"id": "376428628628817"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724173140, "status": "PUBLISHED", "id": "376428628628817"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7815848808525145", "version": "465"}, "id": "11102921