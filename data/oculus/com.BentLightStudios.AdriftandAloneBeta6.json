601_815879825500595_4984963000512282624_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I7viSvJ_7f8Q7kNvgHkN9Ev&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDa0uoXprM8ffb3vEc1-5QEuU_4znpANmTt1wvUtj77oQ&oe=67543780"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Adrift and Alone", "keywords": ["sailing", "shark", "carribean", "sea", "shooting"], "long_description": "Adrift and Alone is a single player, survival- adventure game.\nAfter being shipwrecked, you take control of your raft to explore the nearby islands.\nResources and treasure can be found everywhere, but so can the overprotective man-eating sharks.\nOutmanuver them or use your pistol if you have to.\nReturn to your camp to upgrade your raft and increase your chances for survival.\nGet rescued by a passing ship, or survive in the open seas for as long as you can!\nWith a full year of updates and support, there has never been a better time to survive the Caribbean!", "short_description": "Adrift and Alone is a single player, survival- adventure game with a massive open world. Take control of your raft on a quest for adventure. Fight off sharks, find treasure and craft upgrades to improve your raft and camp."}]}, "developer_name": "Bent Light Industries", "developer_privacy_policy_url": "https://www.bentlightindustries.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Bent Light Industries", "support_website_url": "https://www.bentlightindustries.com/contact", "website_url": "https://www.bentlightindustries.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["