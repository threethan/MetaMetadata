ng", "id": "354776197669343", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001658_354776201002676_8605003780930451185_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfxXgYZcBvUQ7kNvgGotGyN&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYAvJY9hL6b09uPiTr4-QQBAKzlsIstZb797LwJZhdyESw&oe=66EAD07B"}]}, "id": "287314281111649", "locale": "en_US", "screenshots": [{"file_name": "38982585_475770868433804_3381825633794015563_n.png", "id": "1513570359234640", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001725_1513570365901306_2885736174122189534_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p7ivyjWNEPAQ7kNvgFCv-00&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYCve5mGn7tM58S3Z0tvRMbqCJpIOU3ERoO1OuvUsmFhUA&oe=66EAC92C"}, {"file_name": "75240096_1235335441174046_4906910678931428688_n.png", "id": "977433437259146", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_977433440592479_8344681439808562036_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZ_AebuhtDAQ7kNvgHKKv-R&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYCEz1kb5R1DjOx_UtO--TIAU85BXV7DjDfsMg1LqncsDA&oe=66EAC3B9"}, {"file_name": "38974627_1426143531411794_2539205614057598082_n.png", "id": "3888160118133312", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608434_3888160121466645_4102924857382221306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EDpCPS7tp-UQ7kNvgElc3Hr&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYAv8rjfXiMQmfS_0jw-rZ80964QzRcRLozv-6z2Sh4XXg&oe=66EAAABC"}, {"file_name": "38974771_914663160423989_8412528913888708301_n.png", "id": "1471442040147115", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_1471442043480448_4137664387287025678_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQEDPw8-uTEQ7kNvgG3KKpK&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYD35Imjk1iAUjZEztVCIyoypo4yR9-hPj4IxSFTJsmtmA&oe=66EAAF16"}, {"file_name": "57568678_442736708598857_2601426099645306453_n.png", "id": "1585260168698302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569443_1585260175364968_5377620633503669556_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YbIojCVxFMIQ7kNvgE9tma3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYDdJa2lUpFBPdyiqFz96PzzQrrAYhIgcyaSkqrFieODZg&oe=66EAA1F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Corpo1.png", "id": "2813117865521024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003262_2813117868854357_4558799537007488466_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3nHErwMdYwcQ7kNvgHJQWFJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af2YBbuWh0Eu8Nvn2Eefvd-&oh=00_AYAGqVVQlYPZW2QINyBNBW2tOwt9pyYHawg0X0OO_5irAQ&oe=66EAA5A2"}, "display_name": "Simtryx", "keywords": [], "long_description": "**Experience the next step in virtual simulations for healthcare**\n\nTalk, observe, and interact with your patient to diagnose them correctly inside the most immersive and accessible simulation for VR headsets.\n\nImmerse yourself with our powerful main features:\n\n- **AI-powered speech simulation**: Talk freely with the patient to learn more about their history, habits, and to empathize with them.\n- **Advanced hand tracking**: Built from the ground up with hand tracking in mind, every object in the world has a physical presence, and your virtual hands won't phase through.\n- **Seamless onboarding**: Through video passthrough, bring 3D elements into your physical space and jump into the simulation in the most comfortable way.\n\nWith our focus on accessibility, ease of use, and immersion, Simtryx delivers the new standard of healthcare simulations for the next generation of headsets. ", "short_description": "Experience the next step in virtual simulations for healthcare"}]}, "developer_name": null, "developer_privacy_policy_url": "https://simtryx.notion.site/Simtryx-Privacy-Policy-a5977ffc191d4a22a