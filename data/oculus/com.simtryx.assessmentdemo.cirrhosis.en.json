18133312", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608434_3888160121466645_4102924857382221306_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f_eoUZfWSOgQ7kNvgG31U8s&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ajoc1eNni6P1YESvqu_06Z_&oh=00_AYCm0Kh-1O6_YrqTgJ4Kd974zHi-ev751r4wkj--Vn7AUw&oe=66DECD3C"}, {"file_name": "38974771_914663160423989_8412528913888708301_n.png", "id": "1471442040147115", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_1471442043480448_4137664387287025678_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nOn7zY1ErfkQ7kNvgHzExKJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ajoc1eNni6P1YESvqu_06Z_&oh=00_AYDZS4YYz5sUhqPdimAnoGieW_fLmuk1-OGrpi_T1JsaFA&oe=66DED196"}, {"file_name": "57568678_442736708598857_2601426099645306453_n.png", "id": "1585260168698302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569443_1585260175364968_5377620633503669556_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2aIQ4WjqXTsQ7kNvgGmsyto&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ajoc1eNni6P1YESvqu_06Z_&oh=00_AYBpaS_Zg9Sqx5SCtN_OjWGWR2BED-y3zgeJLsS75HCShw&oe=66DEC478"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Simtryx", "keywords": [], "long_description": "**Experience the next step in virtual simulations for healthcare**\n\nTalk, observe, and interact with your patient to diagnose them correctly inside the most immersive and accessible simulation for VR headsets.\n\nImmerse yourself with our powerful main features:\n\n- **AI-powered speech simulation**: Talk freely with the patient to learn more about their history, habits, and to empathize with them.\n- **Advanced hand tracking**: Built from the ground up with hand tracking in mind, every object in the world has a physical presence, and your virtual hands won't phase through.\n- **Seamless onboarding**: Through video passthrough, bring 3D elements into your physical space and jump into the simulation in the most comfortable way.\n\nWith our focus on accessibility, ease of use, and immersion, Simtryx delivers the new standard of healthcare simulations for the next generation of headsets.", "short_description": "Experience the next step in virtual simulations for healthcare"}]}, "developer_name": null, "developer_privacy_policy_url": "https://simtryx.notion.site/Simtryx-Privacy-Policy-a5977ffc191d4a22a4bca6330d8d855a", "developer_terms_of_service_url": null, "publisher_name": "Simtryx", "support_website_url": null, "website_url": "https://www.simtryx.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}, {"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_MX", "es_PE"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7801311536570570"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1674801420021678"}]}, "baseline_offer": {"id": "1674801420021678"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721918234, "status": "PUBLISHED", "id": "1674801420021678"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7993285500706505", "version": "0.5.26.s161"}, "id": "1002083254599925", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7780703355298055", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id"