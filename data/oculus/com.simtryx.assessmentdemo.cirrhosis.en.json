888708301_n.png", "id": "1471442040147115", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003240_1471442043480448_4137664387287025678_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fA8PIXCgj1EQ7kNvgFonB1q&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD3q6k-y7pfXdTTv6S8vzzWs9d0J55xa7qVn2c0w1iX5A&oe=6780FA16"}, {"file_name": "57568678_442736708598857_2601426099645306453_n.png", "id": "1585260168698302", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569443_1585260175364968_5377620633503669556_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yFYrFB5OZ6gQ7kNvgGTsC_m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCTJLe5j-gZ0_l4bPUmhMVczyc_PKonMCqQ-RCnHYtD8g&oe=6780ECF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Corpo1.png", "id": "2813117865521024", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003262_2813117868854357_4558799537007488466_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9yOc3DzAWoYQ7kNvgFXcjvo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAiEGd6NbfDeTAkDHNMJWmQ3zayaaMzD5Pql9FLdzZ9zw&oe=6780F0A2"}, "display_name": "Simtryx", "keywords": [], "long_description": "**Experience the next step in virtual simulations for healthcare**\n\nTalk, observe, and interact with your patient to diagnose them correctly inside the most immersive and accessible simulation for VR headsets.\n\nImmerse yourself with our powerful main features:\n\n- **AI-powered speech simulation**: Talk freely with the patient to learn more about their history, habits, and to empathize with them.\n- **Advanced hand tracking**: Built from the ground up with hand tracking in mind, every object in the world has a physical presence, and your virtual hands won't phase through.\n- **Seamless onboarding**: Through video passthrough, bring 3D elements into your physical space and jump into the simulation in the most comfortable way.\n\nWith our focus on accessibility, ease of use, and immersion, Simtryx delivers the new standard of healthcare simulations for the next generation of headsets. \n\nNOTE: Login credentials are only available to Simtryx partners at the moment. Please join through www.simtryx.com to get your credentials today!", "short_description": "Experience the next step in spatial simulations for healthcare"}]}, "developer_name": null, "developer_privacy_policy_url": "https://simtryx.notion.site/Simtryx-Privacy-Policy-a5977ffc191d4a22a4bca6330d8d855a", "developer_terms_of_service_url": null, "publisher_name": "Simtryx", "support_website_url": null, "website_url": "https://www.simtryx.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es_MX", "es_PE", "es_AR", "es_CL", "es_CO", "es_PR", "es", "es_VE", "en_US", "en_AU", "en_CA", "en_GB"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8625243420844040"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031647_1731916267651703_5169411206367113292_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=baneR50LI6IQ7kNvgEry3hn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDw4MRnEs_mi-7A6eLLWRrok9lpvg1P7pqr-SebGzqQfA&oe=67811810"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Simtryx", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", 