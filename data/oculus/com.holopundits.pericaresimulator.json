_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=64vDmG0SCzUQ7kNvgEChLbz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDm83o9j8z5hp9P9Bgt8RfTeJ8lME_F_AOyRtvgSttTJg&oe=67656979"}, {"file_name": "Peri_Care_Simulation_SS_02.png", "id": "1102469361431633", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974842_1102469368098299_320957277908279133_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yDV5kkJ1EbIQ7kNvgGAMvK_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4Mq1FPvga4rI980e_efcovT5z7S3Avj-1qZauwca8WA&oe=676548ED"}, {"file_name": "Peri_Care_Simulation_SS_03.png", "id": "2366421803697363", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982688_2366421807030696_6211716405170298611_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-h-8gJRiDqcQ7kNvgFUi8FP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALeuUI837IkHB0oiWH2UQoZD297Ea6WR4JTI5hJ8b43Q&oe=676558C1"}, {"file_name": "Peri_Care_Simulation_SS_04.png", "id": "426330707083597", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001707_426330710416930_6596946581515181031_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YjeVPAHKZSoQ7kNvgGuxLSz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAo0B-32-lhlmA0rJUSR_EheaCh6mj3dQqO_jdr5eqYeg&oe=67655F50"}, {"file_name": "Peri_Care_Simulation_SS_05.png", "id": "1297061554632657", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035447_1297061557965990_2258742275702844852_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cnvacAGef7wQ7kNvgGfASaP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsZ7vdii19PMkJ8e6yi2N8oUtLt6-oKXd_ldupUbcYHg&oe=6765414D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Peri_Care_Simulation_SS_02.png", "id": "1110258354229413", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001705_1110258357562746_522679531656503055_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8cJFQDaeU-oQ7kNvgH-UP3M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxt09VnOK4TJhpdyV02F9peq5B99cHJaXFCAXajlicqg&oe=6765672B"}, "display_name": "Peri-Care Simulator", "keywords": ["CNA", "nursing", "training", "perineal", "healthcare"], "long_description": "The Peri-Care Simulator tutorial immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the essential techniques for providing proper perineal care. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n# Learning Objectives:\n- Remember the steps and protocols for providing perineal care. \n- Understand the importance of proper hygiene in preventing infections. \n- Apply the correct techniques to provide perineal care safely and respectfully. \n- Analyze the patient's condition and comfort level during the procedure. \n- Evaluate their own technique to ensure it adheres to best practices and safety standards. \n- Create a hygienic and respectful care environment for patients through proper perineal care. \n\nThis thorough approach ensures CNAs are well-prepared to perform perineal care competently and confidently in clinical settings. ", "short_description": "Learn the essential skill of providing perineal care for female patients, ensuring hygiene and comfort with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", 