8_6204851161972714316_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vzMYxK5P5vkQ7kNvgFwsfl6&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCefzz_6Gpr9h3zwELc0jjconOfOR63fu4E8m46kA3_9Q&oe=67583178"}, {"file_name": "New Project (25).png", "id": "1107122524353944", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39036683_1107122527687277_9107521330902773707_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cln75GtUX9YQ7kNvgFwbdVq&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYB6G70fOGm4MhVj1FAgs8be7drlhkm3X9c2iZl-1zrO3w&oe=67583BF0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cricket frenzy VR", "keywords": ["cricket", "vrcricket", "vrmultiplayercricket", "game", "sports"], "long_description": "Experience the thrill of cricket like never before in VR Cricket Multiplayer! Dive into the immersive world of virtual cricket, where you can play in fast-paced matches, practice your batting and bowling, and compete with players from around the world.\n\nKey Features:\n\nMultiplayer Action: Play with friends or compete against players globally in real-time multiplayer matches.\nRealistic Gameplay: Bat, bowl, and field with realistic physics and responsive controls that bring the sport to life.\nImmersive VR Experience: Feel like you\u2019re truly on the pitch with detailed environments and intuitive VR controls\n", "short_description": "Step into the crease with VR Cricket Multiplayer\u2014an immersive cricket experience where you can bowl, bat, and field with friends in thrilling multiplayer matches. Perfect your skills and dominate the leaderboard"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ierainnovations.com/IRCricket/", "developer_terms_of_service_url": null, "publisher_name": "Tech iera Innovations Pvt Ltd", "support_website_url": null, "website_url": "https://ierainnovations.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id":