=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rr0bKvB1RX8Q7kNvgFhwfAq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1dKqH73gCvvh8Vz7r7bNMqY6TzZbCJN4iBv_dh5f56A&oe=6703AEB0"}, {"file_name": "04.png", "id": "875655784092160", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_875655787425493_7919968481314071270_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o6GxSgcu6hwQ7kNvgEkHFNx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSCbY7q1eUpg1bqmxHg752u6teFdS4QGL_etjnva5xzw&oe=6703D1BA"}, {"file_name": "03.png", "id": "2401123923415788", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982643_2401123926749121_1143732005627484856_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kX85fLTlHIYQ7kNvgEWkTxK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAechuGLarZQVXpidr5KuLxMl-NzvFMfy4EaKus4nP4sg&oe=6703BACC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Cricket Multiplayer", "keywords": ["cricket", "vrcricket", "vrmultiplayercricket", "game", "sports"], "long_description": "Experience the thrill of cricket like never before in VR Cricket Multiplayer! Dive into the immersive world of virtual cricket, where you can play in fast-paced matches, practice your batting and bowling, and compete with players from around the world.\n\nKey Features:\n\nMultiplayer Action: Play with friends or compete against players globally in real-time multiplayer matches.\nRealistic Gameplay: Bat, bowl, and field with realistic physics and responsive controls that bring the sport to life.\nImmersive VR Experience: Feel like you\u2019re truly on the pitch with detailed environments and intuitive VR controls\n", "short_description": "Step into the crease with VR Cricket Multiplayer\u2014an immersive cricket experience where you can bowl, bat, and field with friends in thrilling multiplayer matches. Perfect your skills and dominate the leaderboard"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ierainnovations.com/IRCricket/", "de