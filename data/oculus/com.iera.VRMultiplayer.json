677BB8CF"}, {"file_name": "02.png", "id": "488400680708020", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974458_488400684041353_8150336156893475725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TojAG84SbvQQ7kNvgE7tVXY&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCzABri2cJ9ghACoGqxmfWPchuVinEro06id6Wn7FYVAg&oe=677BA730"}, {"file_name": "04.png", "id": "875655784092160", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974891_875655787425493_7919968481314071270_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F_LFsXlQNcoQ7kNvgHWCYud&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCNSiJvw1D3vkRYlX3cVA_ZIrO83S8UfVXS3XDa28S9rg&oe=677BCA3A"}, {"file_name": "03.png", "id": "2401123923415788", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982643_2401123926749121_1143732005627484856_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TOCbnODjaRoQ7kNvgHIKsky&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYATaSY6DIjEbKYqc1wG-qZCpMrQJpNRRc5ddbJJg9CL1g&oe=677BB34C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Cricket Multiplayer", "keywords": ["cricket", "vrcricket", "vrmultiplayercricket", "game", "sports"], "long_description": "Experience the thrill of cricket like never before in VR Cricket Multiplayer! Dive into the immersive world of virtual cricket, where you can play in fast-paced matches, practice your batting and bowling, and compete with players from around the world.\n\nKey Features:\n\nMultiplayer Action: Play with friends or compete against players globally in real-time multiplayer matches.\nRealistic Gameplay: Bat, bowl, and field with realistic physics and responsive controls that bring the sport to life.\nImmersive VR Experience: Feel like you\u2019re truly on the pitch with detailed environments and intuitive VR controls\n", "short_description": "Step into the crease with VR Cricket Multiplayer\u2014an immersive cricket experience where you can bowl, bat, and fi