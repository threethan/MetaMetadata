72ACF"}, {"file_name": "02.png", "id": "488400680708020", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974458_488400684041353_8150336156893475725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IfwtPMgSapsQ7kNvgFH47zc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyGDVtrnf5oalv8x6ajr0Z19NYlu-RtUV4HX7_Dy0jIQ&oe=67371930"}, {"file_name": "04.png", "id": "875655784092160", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974891_875655787425493_7919968481314071270_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JGagBpuE64AQ7kNvgHsD8LS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDS0lEfgiISRxpZsr9O1GBwADl_CQW6EwUCWsGT8wgsUQ&oe=67373C3A"}, {"file_name": "03.png", "id": "2401123923415788", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982643_2401123926749121_1143732005627484856_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XJYgksEHz7kQ7kNvgHvNAEB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChZfY1N-1bLqvHtNHUJwF5oO_LFaxf4mqcb9OwwQvllg&oe=6737254C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Cricket Multiplayer", "keywords": ["cricket", "vrcricket", "vrmultiplayercricket", "game", "sports"], "long_description": "Experience the thrill of cricket like never before in VR Cricket Multiplayer! Dive into the immersive world of virtual cricket, where you can play in fast-paced matches, practice your batting and bowling, and compete with players from around the world.\n\nKey Features:\n\nMultiplayer Action: Play with friends or compete against players globally in real-time multiplayer matches.\nRealistic Gameplay: Bat, bowl, and field with realistic physics and responsive controls that bring the sport to life.\nImmersive VR Experience: Feel like you\u2019re truly on the pitch with detailed environments and intuitive VR controls\n", "short_description": "Step into the crease with VR Cricket Multiplayer\u2014an immersive cricket experience where you can bowl, bat, and field with friends in thrilling multiplayer matches. Perfect your skills and dominate the leaderboard"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ierainnovations.com/IRCricket/", "developer_terms_of_service_url": null, "publisher_name": "Tech iera Innovations Pvt Ltd", "support_website_url": null, "website_url": "https://ierainnovations.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "27551436371122002"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "534991358990406"}]}, "baseline_offer": {"id": "534991358990406"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726719960, "status": "PUBLISHED", "id": "534991358990406"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28290246140574351", "version": "1.6"}, "id": "1918312111984334", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "27465210369744603", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28290246140574351"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE"