_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2pwIUfkBxhbQnEKFCvADqvO77gGRGo1CaQMxuvUVdww&oe=670674BA"}, {"file_name": "03.png", "id": "2401123923415788", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982643_2401123926749121_1143732005627484856_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=scJTxhuVY-YQ7kNvgFjLLbE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJc_zVUHqoVWU-kz4OkBupXcguOoFmjmaa4bMpQB8bDA&oe=67065DCC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "VR Cricket Multiplayer", "keywords": ["cricket", "vrcricket", "vrmultiplayercricket", "game", "sports"], "long_description": "Experience the thrill of cricket like never before in VR Cricket Multiplayer! Dive into the immersive world of virtual cricket, where you can play in fast-paced matches, practice your batting and bowling, and compete with players from around the world.\n\nKey Features:\n\nMultiplayer Action: Play with friends or compete against players globally in real-time multiplayer matches.\nRealistic Gameplay: Bat, bowl, and field with realistic physics and responsive controls that bring the sport to life.\nImmersive VR Experience: Feel like you\u2019re truly on the pitch with detailed environments and intuitive VR controls\n", "short_description": "Step into the crease with VR Cricket Multiplayer\u2014an immersive cricket experience where you can bowl, bat, and field with friends in thrilling multiplayer matches. Perfect your skills and dominate the leaderboard"}]}, "developer_name": null, "developer_privacy_policy_url": "https://ierainnovations.com/IRCricket/", "developer_terms_of_service_url": null, "publisher_name": "Tech iera Innovations Pvt Ltd", "support_website_url": null, "website_url": "https://ierainnovations.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_typ