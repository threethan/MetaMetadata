name": "The Infinite Inside", "keywords": [], "long_description": "Explore the impossible and transcend realities in the first mixed reality (MR) game from Maze Theory, creators of \"Doctor Who: The Edge Of Time\" and \"Peaky Blinders: The King's Ransom.\" From your own home, seamlessly transition between the real and virtual worlds, tackling mind-bending puzzles and impossible scenarios.\n\nMIXED REALITY FIRST: Designed from the ground up for mixed-reality devices, offering a truly unique experience.\n\nMIND-BENDING PUZZLES: Engage with thought-provoking puzzles that seamlessly merge the real and virtual worlds, transporting you to realms of impossibility.\n\nIMMERSIVE NARRATIVE: Dive into a hidden world with a rich and intricate story waiting for your discovery.\n", "short_description": "Explore the impossible and transcend realities in the first mixed reality (MR) game from Maze Theory, creators of \"Doctor Who: The Edge Of Time\" and \"Peaky Blinders: The King's Ransom.\" From your own home, seamlessly transition between the real and virtual worlds, tackling mind-bending puzzles and impossible scenarios."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.maze-theory.com/legal/#privacy", "developer_terms_of_service_url": "https://www.maze-theory.com/legal/#terms", "publisher_name": "Maze Theory", "support_website_url": null, "website_url": "http://www.maze-theory.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING",