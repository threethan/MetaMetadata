2158175036_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dAJYCe8hj_QQ7kNvgEIiRGD&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYB-ifaVIULTrMckD8OAU86uKd2Ab1CID7fac0GwCQcNEA&oe=670BA482"}, {"file_name": "02_BEACH_BAR_001.png", "id": "622147656438467", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39001665_622147659771800_7404410097182384590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VVaEhouBOCAQ7kNvgGt1wXG&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCNjkngYiHgpjESzNcECD7JQ0g1uTFtq-NRSU4LVqQSoQ&oe=670BA7E4"}, {"file_name": "03_MOUNTAIN_001.png", "id": "720768289805258", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974848_720768293138591_8041020299056376857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UYr2ee5HOfgQ7kNvgHQ9suF&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBmaTmIdniplHFYOS6lsD7seMxK27Ir3Nw5e7Omjmu7Hg&oe=670BB410"}, {"file_name": "04_ROOFTOP_001.png", "id": "256205720301779", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39036646_256205723635112_1369683091072364262_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=goLBN_-e1kgQ7kNvgHnrwdl&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC5uyxUyAWpYVciBR1ogvcqHZPydCY2I6U86lF9hZf4VA&oe=670BBCA4"}, {"file_name": "05_VIP_BAR_001.png", "id": "191792770362029", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001732_191792773695362_8601594000717301485_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jx-udkx5iPIQ7kNvgHNxWA4&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYArY5W1AX0epSPk6saThd3kVtjnCkO69ykN4s6DwCSIbA&oe=670B974F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zdj\u0119cie w tle.png", "id": "737488934724253", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39003258_737488938057586_7754330107928197856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pma6o0ako0EQ7kNvgHeoTTT&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDzq-CH_Fgz3u6-RX08tU7R7K4bOCuCW0LyH3Y2nOWYMw&oe=670BB39E"}, "display_name": "BARTENDER VR SIMULATOR", "keywords": ["drinks", "challenge", "drink"], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. \n\nBegin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. \n\nMaster more and more demanding drinks as you progress to new, unique bars. Earn the course completion certificate and take up a whole new challenge in the Pro Mode.\n\n\ud83e\uddcaA range of drinking glasses to choose from, different liquors, beverages, and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\n\ud83e\uddcaWho will earn the most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? Today you are in the top 10, tomorrow you drop outside the top 100. Every day someone quicker than you takes your place. Don\u2019t let them get ahead of you!\n", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. \n\nDeveloped in cooperation with a six-time Bartending World Champion, Tomek Malek. \n\nYou choose whether you follow the path of developing bartending know-how or having fun. \n\nYou decide whether you fight for the best possible result or just have a good time without tension.\n"}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory Games S.A.", "support_website_url": "http://www.bartendervrsimulator.com/", "website_url": "http://www.bartendervrsimulator.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "611311777333333"}}]}, "scheduled_offers": {"count": 25, "nodes": [{"status": "PUBLISHED", "id": "807111544838621"}, {"status": "PUBLISHED", "id": "488213860286055"}, {"status": "PUBLISHED", "id": "813916566238712"}, {"status": "PUBLISHED", "id": "1295983914394838"}, {"status": "PUBLISHED", "id": "1069536647369506"}, {"status": "PENDING", "id": "262676559730619"}, {"status": "PENDING", "id": "1063471515034949"}, {"status": "PENDING", "id": "892140795446084"}, {"status": "PENDING", "id": "820685729653794"}, {"status": "PENDING", "id": "847617863439429"}, {"status": "PUBLISHED", "id": "1053250688893599"}, {"status": "PUBLISHED", "id": "1738135043315099"}, {"status": "PUBLISHED", "id": "1101634071159938"}, {"status": "PUBLISHED", "id": "1052690329476814"}, {"status": "PENDING", "id": "740804881146997"}, {"status": "PUBLISHED", "id": "740618584274921"}, {"status": "PUBLISHED", "id": "1816366735493971"}, {"status": "PENDING", "id": "1021367889048365"}, {"status": "PENDING", "id": "642847737941175"}, {"status": "PUBLISHED", "id": "7466945699992677"}, {"status": "PENDING", "id": "1316493799747680"}, {"status": "PENDING", "id": "1738179979959147"}, {"status": "PENDING", "id": "818549193210234"}, {"status": "PUBLISHED", "id": "1787300388392039"}, {"status": "PUBLISHED", 