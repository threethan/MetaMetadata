60", "locale": "en_US", "screenshots": [{"file_name": "01_NIGHT_CLUB_001.png", "id": "721229896444607", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001702_721229899777940_8182319592158175036_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QxnqsH_uaCUQ7kNvgELyybx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC7u7oYSpMSvBkXWXV4t0Dy3ZtuLYvzj6Yj4Iuysh7a8g&oe=67864002"}, {"file_name": "02_BEACH_BAR_001.png", "id": "622147656438467", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001665_622147659771800_7404410097182384590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0GOr-ybfsWkQ7kNvgGwCt-A&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAPjObUD75eoNSkSJzHeCEpsW1uIItSzscNbSQX16yhEw&oe=67864364"}, {"file_name": "03_MOUNTAIN_001.png", "id": "720768289805258", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974848_720768293138591_8041020299056376857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yTUqN70vaogQ7kNvgGZK90W&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBlbkoJ6_-Q0gyfW9Ch4xGT-c8MRMhlQRQZO6X8c252iA&oe=67864F90"}, {"file_name": "04_ROOFTOP_001.png", "id": "256205720301779", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036646_256205723635112_1369683091072364262_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s23w9GTvedMQ7kNvgH3v5X6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCAauefQVompMvcTIEGJLxl3jXxwTwswoKYh4e5PIpxQA&oe=67865824"}, {"file_name": "05_VIP_BAR_001.png", "id": "191792770362029", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001732_191792773695362_8601594000717301485_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I0E0qZLZKw0Q7kNvgH1pXXg&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCjHwIKSZb2DFGS4RIR2xWm18ato518TV5DpQkX2KFBng&oe=678632CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zdj\u0119cie w tle.png", "id": "737488934724253", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003258_737488938057586_7754330107928197856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aaYvAAnNWsAQ7kNvgHkuwzP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBj0qjbf9aOIlLyC5r-wPz9O-IUN2QusLWzZAIWvf_Gbg&oe=67864F1E"}, "display_name": "BARTENDER VR SIMULATOR", "keywords": ["drinks", "challenge", "drink"], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. \n\nBegin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. \n\nMaster more and more demanding drinks as you progress to new, unique bars. Earn the course completion certificate and take up a whole new challenge in the Pro Mode.\n\n\ud83e\uddcaA range of drinking glasses to choose from, different liquors, beverages, and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\n\ud83e\uddcaWho will earn the most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? Today you are in the top 10, tomorrow you drop outside the top 100. Every day someone quicker than you takes your place. Don\u2019t let them get ahead of you!\n", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. \n\nDeveloped in cooperation with a six-time Bartending World Champion, Tomek Malek. \n\nYou choose whether you follow the path of developing bartending know-how or having fun. \n\nYou decide whether you fight for the best possible result or just have a good time without tension.\n"}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory Games S.A.", "support_website_url": "http://www.bartendervrsimulator.com/", "website_url": "http://www.bartendervrsimulator.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "611311777333333"}}]}, "scheduled_offers": {"count": 27, "nodes": [{"status": "CANCELLED", "id": "3328565430607000"}, {"status": "PUBLISHED", "id": "1098685621654565"}, {"status": "PUBLISHED", "id": "807111544838621"}, {"status": "PUBLISHED", "id": "488213860286055"}, {"status": "PUBLISHED", "id": "813916566238712"}, {"status": "PUBLISHED", "id": "1295983914394838"}, {"status": "PUBLISHED", "id": "1069536647369506"}, {"status": "PENDING", "id": "262676559730619"}, {"status": "PENDING", "id": "1063471515034949"}, {"status": "PENDING", "id": "892140795446084"}, {"status": "PENDING", "id": "820685729653794"}, {"status": "PENDING", "id": "847617863439429"}, {"status": "PUBLISHED", "id": "1053250688893599"}, {"status": "PUBLISHED", "id": "1738135043315099"}, {"status": "PUBLISHED", "id": "1101634071159938"}, {"status": "PUBLISHED", "id": "1052690329476814"}, {"status": "PENDING", "id": "740804881146997"}, {"status": "PUBLISHED", "id": "740618584274921"}, {"status": "PUBLISHED", "id": "1816366735493971"}, {"status": "PEND