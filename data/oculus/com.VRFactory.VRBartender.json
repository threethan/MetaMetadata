899777940_8182319592158175036_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x4daewg6vBkQ7kNvgHCCnx-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNcZSR-Zmh0erObeqXUJ8uneLeZMg9Jv4LfiloUiLW7Q&oe=67178202"}, {"file_name": "02_BEACH_BAR_001.png", "id": "622147656438467", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001665_622147659771800_7404410097182384590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c9AS-LkMeSYQ7kNvgEZWIWd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3W6HtChvx9FQnccinTTaCsYUMmDUU4zWEeQv-R2SKrA&oe=67178564"}, {"file_name": "03_MOUNTAIN_001.png", "id": "720768289805258", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974848_720768293138591_8041020299056376857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=btCxzrzZlHIQ7kNvgHJn6Uf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHNr8UqC0_P2-2gqRnAitrRr0c7uB5J7WUfUXQAnHpYA&oe=67179190"}, {"file_name": "04_ROOFTOP_001.png", "id": "256205720301779", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036646_256205723635112_1369683091072364262_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=00zEwSHeS-UQ7kNvgECnQB_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCE1lBpHyNvfIMap4Yh8ZEiVsRzd2cC5AdqfcJMAYyiZg&oe=67179A24"}, {"file_name": "05_VIP_BAR_001.png", "id": "191792770362029", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001732_191792773695362_8601594000717301485_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EBJ4fn6J0wAQ7kNvgHzR5bZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4dIdQGGvPmegK-yw8C-87wSgBuRfzehinQIPPLm4IGw&oe=671774CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zdj\u0119cie w tle.png", "id": "737488934724253", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003258_737488938057586_7754330107928197856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mzW9CqRvhTsQ7kNvgEwqhrD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvDIzaz9RmFyQBimqc12_ND9uLZCK4zPT7KphKoRzZZQ&oe=6717911E"}, "display_name": "BARTENDER VR SIMULATOR", "keywords": ["drinks", "challenge", "drink"], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. \n\nBegin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. \n\nMaster more and more demanding drinks as you progress to new, unique bars. Earn the course completion certificate and take up a whole new challenge in the Pro Mode.\n\n\ud83e\uddcaA range of drinking glasses to choose from, different liquors, beverages, and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\n\ud83e\uddcaWho will earn the most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? Today you are in the top 10, tomorrow you drop outside the top 100. Every day someone quicker than you takes your place. Don\u2019t let them get ahead of you!\n", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. \n\nDeveloped in cooperation with a six-time Bartending World Champion, Tomek Malek. \n\nYou choose whether you follow the path of developing bartending know-how or having fun. \n\nYou decide whether you fight for the best possible result or just have a good time without tension.\n"}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory 