nt-iad3-1.oculuscdn.com/v/t64.5771-25/39001702_721229899777940_8182319592158175036_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aXR-OABBZ6MQ7kNvgEjV8w2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAg3RHhcdgfAN7mnckWDUy6CwPYDU5OBg0a8BIQ_qUrqg&oe=6714DF02"}, {"file_name": "02_BEACH_BAR_001.png", "id": "622147656438467", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001665_622147659771800_7404410097182384590_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HJFk_VY7N1sQ7kNvgFdZJz8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCcBEWyWWqCPnxwEAO4cF2ty1X2v3JPDF47r8SPNIoVOA&oe=6714E264"}, {"file_name": "03_MOUNTAIN_001.png", "id": "720768289805258", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974848_720768293138591_8041020299056376857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=btCxzrzZlHIQ7kNvgGRFEld&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWf-nKQYj4PN22Zf8kxE19JTWZXxn6J3Jygcn_iNqyDQ&oe=6714EE90"}, {"file_name": "04_ROOFTOP_001.png", "id": "256205720301779", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036646_256205723635112_1369683091072364262_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U0qeJTieCpUQ7kNvgEHsdkY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCk8zacAo_0wRBdHbNnBh49NVt0txzsocRDPYfTXJZODg&oe=6714F724"}, {"file_name": "05_VIP_BAR_001.png", "id": "191792770362029", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001732_191792773695362_8601594000717301485_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EBJ4fn6J0wAQ7kNvgEDuvJn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv4SNUuDzsWvptiwpJQlgUks0sHMujOlHYsZ_wStkJkg&oe=6714D1CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zdj\u0119cie w tle.png", "id": "737488934724253", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003258_737488938057586_7754330107928197856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vYd-50cHhMwQ7kNvgFNjwyH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0YVrUfXNdjh7PVVnYjCa3ubWRSyDALSuK_mSSvlEe5w&oe=6714EE1E"}, "display_name": "BARTENDER VR SIMULATOR", "keywords": ["drinks", "challenge", "drink"], "long_description": "Working in four unique and professionally equipped virtual bars, you will experience the thrill of the art of bartending under the watchful eye of Tomasz Ma\u0142ek, a six-time Bartending World Champion. \n\nBegin your journey in a music club and learn how to make four basic drinks. Prove yourself and win the opportunity to train and work in the next location. \n\nMaster more and more demanding drinks as you progress to new, unique bars. Earn the course completion certificate and take up a whole new challenge in the Pro Mode.\n\n\ud83e\uddcaA range of drinking glasses to choose from, different liquors, beverages, and additions. Crushed or cubed ice? Professional bartending know-how. Various bartending techniques. Item destruction. Juggling with bartending equipment and drink ingredients. We serve it all in a super-realistic quality.\n\n\ud83e\uddcaWho will earn the most money in each bar? Who will make a perfect drink in the shortest time? Who will earn the biggest tip for a single drink by mesmerizing the customers by using the flair technique? Today you are in the top 10, tomorrow you drop outside the top 100. Every day someone quicker than you takes your place. Don\u2019t let them get ahead of you!\n", "short_description": "Bartender VR Simulator offers you a unique combination of a simulator, bartending course and incredible immersive VR game. \n\nDeveloped in cooperation with a six-time Bartending World Champion, Tomek Malek. \n\nYou choose whether you follow the path of developing bartending know-how or having fun. \n\nYou decide whether you fight for the best possible result or just have a good time without tension.\n"}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://www.bartendervrsimulator.com/privacy", "developer_terms_