_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFwC2MbZn2AL0zcU_adra4d-RVVQ79t0hn7IIEjXEWnQ&oe=675981B1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Monke Den", "keywords": [], "long_description": "The Monke Den is a game based off of Gorilla Tag. You can play with your friends or meet new friends. There are a handful of maps to play in such as a Forest map, a Maze map, an Obstacle Course and more to come soon. Hope you enjoy the game and remember to reject humanity and always BE MONKE!!!!! I'm TrooperVR, I am a Gorilla Tag player and lover. I create content to put out onto TikTok and YouTube, I have recently been making a hobby of developing Gorilla Tag fan games, but over time I have failed over and over again. But I believe that I can make this game work and keep moving forward, my inspiration is Cebus, Monkeys Realm, Capuchin, Monkeys Place, Samango, Monk and Cube Runners. I hope you enjoy The Monke Den.", "short_description": "The Monke Den is a game based off of Gorilla Tag. You can play with your friends or meet new ones. I hope you enjoy the game and remember to reject humanity and always BE MONKE!!!!!"}]}, "developer_name": "TrooperVR", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/bc67117d-fa26-42b0-bf66-16ecef188bad", "developer_terms_of_service_url": null, "publisher_name": "TrooperVR", "support_website_url": null, "website_url": "https://sites.google.com/view/themonkeden/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_