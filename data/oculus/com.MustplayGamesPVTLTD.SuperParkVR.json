h=00_AYDCOYxovTQhLePxMxcwfbO7CpTh6uoS2v2d1hAKuepTzQ&oe=66FFCC7A"}, {"file_name": "Text_2560x1440_2.png", "id": "654494352823436", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982694_654494356156769_3978824436828714141_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iFltvVhxqTIQ7kNvgH1wh_s&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKcW5ScgZ0G5D86d6DhVwoS2sRJecOjD_ZzPd8kL6v0A&oe=66FFD794"}, {"file_name": "Text_2560x1440_5.png", "id": "2306190386211705", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974524_2306190389545038_2059558723262562359_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZpJjs80n0LcQ7kNvgFmwNF3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBZdw5hxP8b5mIBrZFBSdx6TJFJzT_XaksG5Kgv7dZwZA&oe=66FFD610"}, {"file_name": "Text_2560x1440_1.png", "id": "1376716176472108", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001710_1376716179805441_6049222892862345597_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MZQzqe1Q8IEQ7kNvgGqDnfE&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHFvvMz7MqS0GD3afRKBl3BT5hQjNDZwlhBQxP8wYxaw&oe=66FFC01B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SUPER PARK_Trailer_Cover_2560x1440.png", "id": "937550737213833", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982492_937550740547166_6424033886403615163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lCKydrN5dHoQ7kNvgEJkvsf&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3oGwJkGeubakDcutx73tjmsPksHCUNOOpk8sAxtsBug&oe=66FFD74F"}, "display_name": "SuperPark VR", "keywords": [], "long_description": "The joy of exploring the amusement park comes alive with SuperPark VR.  \nIt's an ever-growing world of new rides, experiences and games.\nSuperPark VR gives the player a thrill and joy that can be experienced in a real-world amusement park.  Experience riding a rollercoaster and other major rides from your home using VR headsets, playing different arcade games, and feel the adrenal rush throughout your body. \n\nRides:\n1.\tDrop Tower.\n2.\tRoller-coaster.\n3.\tSlingshot.\n4.\tLoop.\n5.\tFerris wheel.\n6.\tTechno Jump.\n7.\tTwin Flip.\n8.\tColumbus.\n9.\tMavric.\n10.\tPendulum.\n11.\tHurricane Ride.\n12.\tBamba Ride.\n13.\tDisko Ride.\n14.\tSpace Trainer.\n\nArcade Games:\n1.\tBasket Ball.\n2.\tPunching Box.\n3.\tDart Game.\n4.\tArchery Game.\n5.\tShooting Game.\n6.\tGo-karting.\nMany more games and rides coming Soon!!!!!!!", "short_description": "SuperPark VR opens a new way to experience the thrill of an amusement park. It's an ever-growing park with new rides, experiences and games every month as free updates."}]}, "developer_name": null, "developer_privacy_policy_url": "http://mustplay.com/vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mustplay games private limited", "support_website_url": null, "website_url": "http://mustplay.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ROLLER_COASTER", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "447790420901557"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1999351987167195"}, {"status": "PUBLISHED", "id": "480455987557309"}]}, "baseline_offer": {"id": "1999351987167195"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717753112, "status": "PUBLISHED", "id": "1999351987167195"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7409717