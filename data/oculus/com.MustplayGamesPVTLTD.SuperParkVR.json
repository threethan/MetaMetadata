7", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974868_2176939609173030_7465405056159628155_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CSNBxJQLIecQ7kNvgFBvjJ2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgCB5bHUAAE31D9YPLP7v1OXH_NGB_Ut3abETH-PUrDA&oe=6714E47A"}, {"file_name": "Text_2560x1440_2.png", "id": "654494352823436", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982694_654494356156769_3978824436828714141_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EPfRrGipqq8Q7kNvgGZP3cy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATwyK7vt36NovB5jgRIrtctMKre5I_nZV6FCyot5Zsmw&oe=6714EF94"}, {"file_name": "Text_2560x1440_5.png", "id": "2306190386211705", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974524_2306190389545038_2059558723262562359_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IjSE0JCs3EQQ7kNvgFR0cAF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwtGlxxbbIt_3iJzwi8wqOAgNWLWIJTAckSo04o6Z-YQ&oe=6714EE10"}, {"file_name": "Text_2560x1440_1.png", "id": "1376716176472108", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001710_1376716179805441_6049222892862345597_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vZCA9_gnyTcQ7kNvgEM9sKv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb5ZQ04EQUZmCzkO2R4a1X_721m1L0GHA_0O_8-DRzxg&oe=6714D81B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SUPER PARK_Trailer_Cover_2560x1440.png", "id": "937550737213833", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982492_937550740547166_6424033886403615163_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ag2I7Nsa-AAQ7kNvgF_n4_3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-HqF9EnNNB7VKGceXT71EkPzK8w-edkyk7EfZtsAKog&oe=6714EF4F"}, "display_name": "SuperPark VR", "keywords": [], "long_description": "The joy of exploring the amusement park comes alive with SuperPark VR.  \nIt's an ever-growing world of new rides, experiences and games.\nSuperPark VR gives the player a thrill and joy that can be experienced in a real-world amusement park.  Experience riding a rollercoaster and other major rides from your home using VR headsets, playing different arcade games, and feel the adrenal rush throughout your body. \n\nRides:\n1.\tDrop Tower.\n2.\tRoller-coaster.\n3.\tSlingshot.\n4.\tLoop.\n5.\tFerris wheel.\n6.\tTechno Jump.\n7.\tTwin Flip.\n8.\tColumbus.\n9.\tMavric.\n10.\tPendulum.\n11.\tHurricane Ride.\n12.\tBamba Ride.\n13.\tDisko Ride.\n14.\tSpace Trainer.\n\nArcade Games:\n1.\tBasket Ball.\n2.\tPunching Box.\n3.\tDart Game.\n4.\tArchery Game.\n5.\tShooting Game.\n6.\tGo-karting.\nMany more games and rides coming Soon!!!!!!!", "short_description": "SuperPark VR opens a new way to experience the thrill of an amusement park. It's an ever-growing park with new rides, experiences and games every month as free updates."}]}, "developer_name": null, "developer_privacy_policy_url": "http://mustplay.com/vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mustplay games private limited", "support_website_url": null, "website_url": "http://mustplay.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ROLLER_COASTER", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "447790420901557"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1999351987167195"}, {"status": "PUBLISHED", "id": "48045598