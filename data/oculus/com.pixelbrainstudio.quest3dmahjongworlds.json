4_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iuaRx6LpXGAQ7kNvgF_fLEH&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBdum5qAV5AWWm-PSV0NbgYHdLmhnT4rTWfj3VwzqpYRA&oe=677E7808"}, {"file_name": "screenshot3ok.png", "id": "1307442800261130", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39035455_1307442803594463_415106524989439193_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4QXfpvi-vYUQ7kNvgEnGzld&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYDuV9yg_AAkExHwfyPuers72KSZxrkAUfJVm-0HhWL6kA&oe=677E50E7"}, {"file_name": "screenshot6.png", "id": "943327351077800", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/468741112_943327354411133_7842717366783559423_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LvzgZ78d9p0Q7kNvgFjhl3N&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCyaXBv4hQ30P011TpG-uoi0wNvvx19Lv61bL08KIZWwQ&oe=677E7BEB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xOTdpt03m7IQ7kNvgF3pWkk&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDYfezpCRku75hJMC7juGA16fqESvlGFdhr6cRPasaDxg&oe=677E6872"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["mahjong", "board", "relax", "classic", "puzzle"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- 4 Relaxing environment with daytime and night mode.\n- 3 Tile set\n- Classic and 3D style levels.\n- English, Hungarian and Simplified Chinese languages.\n- Rotate, move and zoom the board.\n", "short_description": "This is the VR implementation of the classic Mahjong game\nCreative design of solid 3D mahjong levels, and simple game rules!\nRelaxing environments, various tile sets, and night mode!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://pixelbrainstudio.com/privacy/oculus/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Pixelbrain Studio", "support_website_url": null, "website_url": "http://www.pixelbrainstudio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "hu", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8667021190076496"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/57572921_2527400760786168_2850351988594609361_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YFO1M6mCSFEQ7kNvgHsIU28&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYArMZSsV8idsjZo5oDtGtqOzXbYQGZ1dy0O_hFbkxKOkA&oe=677E4F1E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "3D Mahjong worlds - Quest", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Tabletop", "id": "1676485315806614"}, {"