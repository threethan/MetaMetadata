292_4741404782520524397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhThVCDMtLcQ7kNvgH6kKbb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4bk35XKoKpMwLDIh2sVcDP1mp0WrzAO9_KWbbNWqZOw&oe=6766B637"}, {"file_name": "vlcsnap-00008.png", "id": "7282727451839924", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035307_7282727458506590_4830324704851622877_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LxgV335nLXoQ7kNvgGRMgNP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCSw0klCwrgngBxh4f-r2KX59FGVBcPUxU9uXUSJL_ygA&oe=6766B2AE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDpNkQL3tWkQ7kNvgFGhnOV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDlerZ6PA2EMvYv0rWM-_fBH9FWUeT2uHK8BAeUe0aDyw&oe=6766AD72"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["strategy", "mahjong", "board", "relax", "classic"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- Classic and 3D style levels.\n- Rotate, move and zoom the board.\n- English, Hungarian and Simplified Chinese languages.\n- Relaxing environment.\n", "short_description": "This is the VR implementation of the classic Mahjong game\n\nNo matter if you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules!"}, {"images": {"nodes": [{"file_name": "logo2-