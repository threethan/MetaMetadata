463_415106524989439193_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=njl3nowUnuEQ7kNvgGkH9Zd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXDA_2iTWb2l4R1GkWmrjD1730I7Edg4YPyuwZnf2wjg&oe=67790AE7"}, {"file_name": "screenshot6.png", "id": "943327351077800", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468741112_943327354411133_7842717366783559423_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZncfmrdCBUQ7kNvgFJKgRQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1-DdbBY2tmnLcaDAMv3vL3u-8poL3Acz_nMeVdhEowA&oe=677935EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGwIK8cLKX0Q7kNvgF1f6Af&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSRHcTts0JKApPF3s6j1SN77DN3jIMPhp569i6AjoHuA&oe=67792272"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["mahjong", "board", "relax", "classic", "puzzle"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- 4 Relaxing environment with daytime and night mode.\n- 3 Tile set\n- Classic and 3D style levels.\n- English, Hungarian and Simplified Chinese languages.\n- Rotate, move and zoom the board.\n", "short_description": "This is the VR implementation of the classic Mahjong game\nCreative design of solid 3D mahjong levels, and simple game rules!\nRelaxing environments, various tile sets, and night mode!"}, {"images": {"nodes": [{"file_name": "l