463_415106524989439193_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=njl3nowUnuEQ7kNvgF31vJU&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAp2rQ9nNHBkonUbttq8V0aJyvRxONCm1MpFNV_5kR3Vw&oe=6777B967"}, {"file_name": "screenshot6.png", "id": "943327351077800", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/468741112_943327354411133_7842717366783559423_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZncfmrdCBUQ7kNvgE9C1zR&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBavL9x9ocWJum3nVQgnq5wcpbiLCsyF-0bMVIA8bMecQ&oe=6777E46B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGwIK8cLKX0Q7kNvgEjiHi7&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAFah0ATRN9M4x4iPDOsBD5tt7d-z-yVE0olSQFgMwpFQ&oe=6777D0F2"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["mahjong", "board", "relax", "classic", "puzzle"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- 4 Relaxing environment with daytime and night mode.\n- 3 Tile set\n- Classic and 3D style levels.\n- English, Hungarian and Simplified Chinese languages.\n- Rotate, move and zoom the board.\n", "short_description": "This is the VR implementation of the classic Mahjong game\nCreative design of solid 3D mahjong levels, and simple game rules!\nRelaxing environments, various tile sets, and night mode!"}, {"images": {"nodes": [{"file_name": "l