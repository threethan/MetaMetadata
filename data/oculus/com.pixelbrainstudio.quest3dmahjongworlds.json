463_415106524989439193_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=67GxXz5aCEIQ7kNvgEzfX5s&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCOUxfzs1upTJIcaMw9BKdVLMCrt7Xi7TxPIRaxEOZkew&oe=67727367"}, {"file_name": "screenshot6.png", "id": "943327351077800", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/468741112_943327354411133_7842717366783559423_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n4qPgCINrPoQ7kNvgH2U-1U&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC4t7V_vEhfCw4lZRnqVdjd8O4UX0ICmdNnXJxYCTISaA&oe=67729E6B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rqnyQR6uKyAQ7kNvgG6B17s&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC3b2ep44WIV2I4qGrYcQQ1QbqMBrqPk4jdgG6-rYYJrw&oe=67728AF2"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["mahjong", "board", "relax", "classic", "puzzle"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- 4 Relaxing environment with daytime and night mode.\n- 3 Tile set\n- Classic and 3D style levels.\n- English, Hungarian and Simplified Chinese languages.\n- Rotate, move and zoom the board.\n", "short_description": "This is the VR implementation of the classic Mahjong game\nCreative design of solid 3D mahjong levels, and simple game rules!\nRelaxing environments, various tile sets, and night mode!"}, {"images": {"nodes": [{"file_name": "l