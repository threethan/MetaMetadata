, "display_name": "3D Mahjong worlds - Quest", "keywords": [], "long_description": "This is the VR implementation of the classic Mahjong game\n\nNo matter if you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- Classic and 3D style levels.\n- Rotate, move and zoom the board.\n- It\u2019s a simple puzzle game which is suitable for any age group.\n", "short_description": "This is the VR implementation of the classic Mahjong game\n\nNo matter if you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, simple game rules, suitable for everyone!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://pixelbrainstudio.com/privacy/oculus/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Pixelbrain Studio", "support_website_url": null, "website_url": "http://www.pixelbrainstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3050872021910333"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1781878415552025"}, {