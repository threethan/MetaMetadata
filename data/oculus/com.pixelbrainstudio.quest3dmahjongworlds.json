463_415106524989439193_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_1qwyELn-18Q7kNvgHFDlgT&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAZLMLJc0oH3MqyA5aP8cq6MB4VsCToVrVV-wBGy1OjiQ&oe=677667E7"}, {"file_name": "screenshot6.png", "id": "943327351077800", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/468741112_943327354411133_7842717366783559423_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AU-M6wXH094Q7kNvgGgCVzM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDSICcwcXTBAY3dxDkMxQ4CJuegQKvnlRG3FKmBp2wQXw&oe=677692EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscapefull3.png", "id": "1181005139718728", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036670_1181005143052061_709758329527305958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGwIK8cLKX0Q7kNvgFp2sPW&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC2T50QqdZgFGJfIY86VRCo13dVTCrXKBg909gf1Cqwag&oe=67767F72"}, "display_name": "3D Mahjong worlds - Quest", "keywords": ["mahjong", "board", "relax", "classic", "puzzle"], "long_description": "This is the VR implementation of the classic Mahjong game\n\nWhether you are a mahjong master or a beginner, this game will be your best choice!\nCreative design of solid 3D mahjong levels, and simple game rules, suitable for everyone!\nIt\u2019s transformed from the traditional matching game and brings a relaxing experience to players in a 3D way.\nBe the master and pair all the cubes to eliminate them on over 30 levels!\n\nGame features:\n\n- 30 levels\n- 4 Relaxing environment with daytime and night mode.\n- 3 Tile set\n- Classic and 3D style levels.\n- English, Hungarian and Simplified Chinese languages.\n- Rotate, move and zoom the board.\n", "short_description": "This is the VR implementation of the classic Mahjong game\nCreative design of solid 3D mahjong levels, and simple game rules!\nRelaxing environments, various tile sets, and night mode!"}, {"images": {"nodes": [{"file_name": "l