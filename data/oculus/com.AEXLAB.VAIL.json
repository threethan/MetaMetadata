20443328868513_6411875275116420844_n.png", "id": "285134704228099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330714_285134707561432_3234887307545743678_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YPu58XvgtVsQ7kNvgETlbFA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdAr5l972W7YGfIfF4aRG4ZoNZxXHiO2QyzMw8ccSOMQ&oe=672CA667"}, {"file_name": "75234365_955127302605897_7353253837967133594_n.png", "id": "203381096078195", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441579_203381099411528_5840312568870297212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpCwVE7aw9wQ7kNvgG_Mjwc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0u_FRYBASIzWXhvjDd6r4JgLWfiOm2wNSepdE3JSZNQ&oe=672C9049"}, {"file_name": "38974756_558741246193370_668536515100319150_n.png", "id": "3690479004560351", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542965_3690479007893684_3771681653278788897_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T-g7UP2goUUQ7kNvgEqKLxD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDm6CTKyffg1fPke0F4OYKZ9a5SFzf6Ubovn6JZpdAdKQ&oe=672CAD63"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "1713229479151882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036617_1713229482485215_2083808281094830010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t16gqUxdG-4Q7kNvgHsqLZ_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8uLLWkmkrgjLrhNaqAvBgEZ4TlzVsLrKcnNW660bhHg&oe=672CB8EA"}, "display_name": "VAIL", "keywords": [], "long_description": "VAIL is a 5v5 tactical shooter game developed from the ground-up for virtual reality.\n\nImmersive Physics:\nGuns collide with the environment. Throw magazines to teammates, bounce grenades around corners, climb ladders, vault over obstacles, ride ziplines, defy gravity on jump pads, and more.\n\nCompetitive Integrity:\nEverything in VAIL is designed to uphold competitive integrity. From standardizing player height, to preventing play space cheats; trust that every match will be competitive and fair.\n\nSocial Experiences (in development):\nAfter a fast-paced match, challenge friends to mini-games in the social hub, flex gun and avatar skins, or 1v1 a friend. Customizable home, game modes and experiences in development.", "short_description": "VAIL VR is a virtual reality multiplayer competitive shooter. Emphasizing tactical gunplay, high-caliber combat, and collaborative teamwork. Introducing the ultimate VR shooter experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vailvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6880763315300606"}}]}, "scheduled_offers": {"count": 10, "nodes": [{"status": "PUBLISHED", "id": "1081364740094887"}, {"status": "PUBLISHED", "id": "474221682067997"}, {"status": "CANCELLED", "id": "836009151754637"}, {"status": "PUBLISHED", "id": "1672035033332794"}, {"status": "PUBLISHED", "id": "428300393457750"}, {"status": "CANCELLED", "id": "3620465474949999"}, {"status": "PUBLISHED", "id": "1062876784945458"}, {"status": "PUBLISHED", "id": "1824427548055081"}, {"status": "CANCELLED", "id": "297587676219649"}