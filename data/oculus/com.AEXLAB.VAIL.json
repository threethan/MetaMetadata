5", "locale": "en_US", "screenshots": [{"file_name": "38982716_646629380731446_8803849827396003486_n.png", "id": "643371774527728", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031434_643371777861061_1091724261344973666_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V4r8f-e6TcEQ7kNvgHG2NfK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDLQnyeIwLOd3I1SrhZRGVi2kSalJWVyANjjL3HHd2xJQ&oe=67615711"}, {"file_name": "38982631_6231837130205021_6080763725342049857_n.png", "id": "843380544054157", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569428_843380547387490_639587016570583862_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O_2CMWL4kVwQ7kNvgERG7QP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaaYZfRhhdtD1Sbugh3DzBnk891BkO4WgSXNlyYPGjEA&oe=676171AA"}, {"file_name": "39031474_1320443328868513_6411875275116420844_n.png", "id": "285134704228099", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330714_285134707561432_3234887307545743678_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hIqKcx90jPwQ7kNvgEKSXXw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIRsRoGS17ekVLZQhiSUqGdXwFnssfocW_iRXQGMoyWA&oe=67616267"}, {"file_name": "75234365_955127302605897_7353253837967133594_n.png", "id": "203381096078195", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75441579_203381099411528_5840312568870297212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pOZhT1era2EQ7kNvgFkUjjQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtPGeqKGdEuIjhkv72LYQQjE5YkgLv4bkFo4o-vB1mLw&oe=67614C49"}, {"file_name": "38974756_558741246193370_668536515100319150_n.png", "id": "3690479004560351", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75542965_3690479007893684_3771681653278788897_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sRISwfulD9YQ7kNvgHyokvt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9LqUbtsExqqdtiYo8BHtNKqKiWffAUk4aHKhW3uIxYg&oe=67616963"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "1713229479151882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036617_1713229482485215_2083808281094830010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d2Q2Ub7gmZoQ7kNvgENjyqi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDD96VilqtQ4iCc-nx1DL8xzfHBLkuwurVKqt4O_mi8fQ&oe=676174EA"}, "display_name": "VAIL", "keywords": [], "long_description": "VAIL is a 5v5 tactical shooter game developed from the ground-up for virtual reality.\n\nImmersive Physics:\nGuns collide with the environment. Throw magazines to teammates, bounce grenades around corners, climb ladders, vault over obstacles, ride ziplines, defy gravity on jump pads, and more.\n\nCompetitive Integrity:\nEverything in VAIL is designed to uphold competitive integrity. From standardizing player height, to preventing play space cheats; trust that every match will be competitive and fair.\n\nSocial Experiences (in development):\nAfter a fast-paced match, challenge friends to mini-games in the social hub, flex gun and avatar skins, or 1v1 a friend. Customizable home, game modes and experiences in development.", "short_description": "VAIL VR is a virtual reality multiplayer competitive shooter. Emphasizing tactical gunplay, high-caliber combat, and collaborative teamwork. Introducing the ultimate VR shooter experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vailvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recomm