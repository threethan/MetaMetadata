ity on jump pads, and more.\n\nCompetitive Integrity:\nEverything in VAIL is designed to uphold competitive integrity. From standardizing player height, to preventing play space cheats; trust that every match will be competitive and fair.\n\nSocial Experiences (in development):\nAfter a fast-paced match, challenge friends to mini-games in the social hub, flex gun and avatar skins, or 1v1 a friend. Customizable home, game modes and experiences in development.", "short_description": "VAIL VR is a virtual reality multiplayer competitive shooter. Emphasizing tactical gunplay, high-caliber combat, and collaborative teamwork. Introducing the ultimate VR shooter experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vailvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6880763315300606"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "474221682067997"}, {"status": "CANCELLED", "id": "836009151754637"}, {"status": "PUBLISHED", "id": "1672035033332794"}, {"status": "PUBLISHED", "id": "428300393457750"}, {"status": "CANCELLED", "id": "3620465474949999"}, {"status": "PUBLISHED", "id": "1062876784945458"}, {"status": "PUBLISHE