=scontent-sjc3-1.oculuscdn.com&oh=00_AYCpDbuZTL_TPwdBScHv22IXFoXQYi1HP_76URXO6a5ENA&oe=67011483"}, {"file_name": "Screenshot5.png", "id": "3827117000946530", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75340709_3827117004279863_2151149415370285711_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RueSLavNRW0Q7kNvgGj-w8N&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAigkvPhzPNBMQ3G8pXWUqsIhUm4nNimid2yUEsB3Ub2w&oe=67013DFC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "820035533223852", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982447_820035536557185_289606171667312693_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3XyjL0vCnN0Q7kNvgGtKk3n&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBE-FLV-FaDRoNImHCxcnd9ST7nNdGX_lXf9x63VYxew&oe=6701386D"}, "display_name": "VAIL", "keywords": ["shooter", "fps", "multiplayer", "gun", "social"], "long_description": "Immerse yourself in the world of VAIL, a multiplayer FPS game built for virtual reality. Engage in high-octane gameplay centered around objective-based game modes or connect with a vibrant community in social environments. Set in a sci-fi future of the solar system, choose between opposing factions and battle for the claim to humanity\u2019s legacy.\n{390905377282488}\n\n#  **EXPERIENCE UNPARALLELED COMBAT**\n\nFeel high-impact FPS combat with best-in-class shooter mechanics, precisely tuned interactions, and immersive physics systems.\n\n{1162628724924512}\n\n# **LEVEL UP AND UNLOCK REWARDS**\n\nDominate in popular team-based and free-for-all game modes as you level up, unlock rewards, and top the leaderboards.\n\n{766149719046755}\n\n#  **UNCOVER VAIL'S STORY**\nTraverse through awe-inspiring brutalist environments as the lines between right and wrong begin to blur.\n\n\n{1884336785321853}\n\n# **YOUR NEXT BEST FRIEND IS ONE REALITY AWAY**\n\nUnite with your friends for battle, or bring them to your Armory to play mini-games and chill.\n\n{1136583027611274}\n\n# **CRITICALLY ACCLAIMED**\n\n\n{481558107552824}", "short_description": "Immerse yourself in the unparalleled world of VAIL, a hybrid first-person shooter game built for virtual reality. Engage in high-octane gameplay centered around objective-based game modes or connect with a vibrant community in social environments. Set in a sci-fi future of the solar system, choose between opposing factions and battle for the claim to humanity\u2019s legacy."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aexlab.com/aexlab/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8066742653369327"}, "review_messages": ["approved. Developer will need to set time/day for release. "]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003240_2184584341915317_6001676625511015797_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VivoN42yotkQ7kNvgGE2H-N&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA3_nJASlOtvGlkfW7g8qxevF19XayqjzMOkMyWFbxVjw&oe=670138CC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VAIL", "platform": "ANDROID_6DOF", "context_ca