yTUTiGDhzmIRtOUnCg&oe=66E6C6E7"}, {"file_name": "75234365_955127302605897_7353253837967133594_n.png", "id": "203381096078195", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441579_203381099411528_5840312568870297212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_w5X50mU5HIQ7kNvgG6UE5X&_nc_ht=scontent.oculuscdn.com&oh=00_AYCACptRccVfTL4PcILb4qK7ZDOshwPDKKQ-AKqR0mjEPg&oe=66E6B0C9"}, {"file_name": "38974756_558741246193370_668536515100319150_n.png", "id": "3690479004560351", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542965_3690479007893684_3771681653278788897_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RRnikqXWGOoQ7kNvgEQA4Oq&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-dZOaAoSwMVc5FLk0jiJem3tNDRVOM_fPNplNsemQSw&oe=66E6CDE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "1713229479151882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_1713229482485215_2083808281094830010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7FH4RyDZdNsQ7kNvgHscffs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBtqmPEbRocJW1r3UUNwokZZJ7RK57pr3oH8GFZaW13hg&oe=66E6D96A"}, "display_name": "VAIL", "keywords": [], "long_description": "VAIL is a 5v5 tactical shooter game developed from the ground-up for virtual reality.\n\nImmersive Physics:\nGuns collide with the environment. Throw magazines to teammates, bounce grenades around corners, climb ladders, vault over obstacles, ride ziplines, defy gravity on jump pads, and more.\n\nCompetitive Integrity:\nEverything in VAIL is designed to uphold competitive integrity. From standardizing player height, to preventing play space cheats; trust that every match will be competitive and fair.\n\nSocial Experiences (in development):\nAfter a fast-paced match, challenge friends to mini-games in the social hub, flex gun and avatar skins, or 1v1 a friend. Customizable home, game modes and experiences in development.", "short_description": "VAIL VR is a virtual reality multiplaye