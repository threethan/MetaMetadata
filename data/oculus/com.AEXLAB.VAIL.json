KJava1MuKSLg&oe=66EC0CE7"}, {"file_name": "75234365_955127302605897_7353253837967133594_n.png", "id": "203381096078195", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441579_203381099411528_5840312568870297212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L7iu-XDjSxwQ7kNvgFmHUuO&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8sjToOB39VbVQcafuxO5RBkL-GSx65l-JzWJBT4iD9Q&oe=66EBF6C9"}, {"file_name": "38974756_558741246193370_668536515100319150_n.png", "id": "3690479004560351", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542965_3690479007893684_3771681653278788897_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uh2R7NfOOz8Q7kNvgHog4Fa&_nc_ht=scontent.oculuscdn.com&oh=00_AYBxfssOXEsMiufkLBWtIDpOWFRolkH1za_GuHRN6Tz7_g&oe=66EC13E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "1713229479151882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_1713229482485215_2083808281094830010_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHGsab31KJIQ7kNvgFWLz-P&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhDVf2tO9LS0OdTxmu8-rJ5eWIDeRyxIOieMeXdtusgA&oe=66EC1F6A"}, "display_name": "VAIL", "keywords": [], "long_description": "VAIL is a 5v5 tactical shooter game developed from the ground-up for virtual reality.\n\nImmersive Physics:\nGuns collide with the environment. Throw magazines to teammates, bounce grenades around corners, climb ladders, vault over obstacles, ride ziplines, defy gravity on jump pads, and more.\n\nCompetitive Integrity:\nEverything in VAIL is designed to uphold competitive integrity. From standardizing player height, to preventing play space cheats; trust that every match will be competitive and fair.\n\nSocial Experiences (in development):\nAfter a fast-paced match, challenge friends to mini-games in the social hub, flex gun and avatar skins, or 1v1 a friend. Customizable home, game modes and experiences in development.", "short_description": "VAIL VR is a virtual reality multiplayer competitive shooter. Emphasizing tactical gunplay, high-caliber combat, and collaborative teamwork. Introducing the ultimate VR shooter experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vailvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6880763315300606"}}]}, "scheduled_offers": {"count": 9, "nodes": [{"status": "PUBLISHED", "id": "474221682067997"}, {"status": "CANCELLED", "id": "836009151754637"}, {"status": "PUBLISHED", "id": "1672035033332794"}, {"status": "PUBLISHED", "id": "428300393457750"}, {"status": "CANCELLED", "id": "3620465474949999"}, {"status": "PUBLISHED", "id": "1062876784945458"}, {"status": "PUBLISHED", "id": "1824427548055081"}, {"status": "CANCELLED", "id": "297587676219649"}, {"status": "PUBLISHED", "id": "1675915319600293"}]}, "baseline_offer": {"id": "1062876784945458"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724094000, "status": "PUBLISHED", "id": "474221682067997"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8274625505914373", "version": "1.2.3.5"}, "id": "277275011906292", "channel_name": "LIVE"}]}, "is