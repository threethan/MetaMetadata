841"}, {"file_name": "Screenshot4.png", "id": "383461994432608", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003255_383461997765941_7321913003346408327_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BwoC9AxTrRAQ7kNvgFdd0To&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkMrIE1QAnzgqdoVJwyZ99naxaZ3SBgWgSpvGWukLVSg&oe=67542303"}, {"file_name": "Screenshot5.png", "id": "3827117000946530", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340709_3827117004279863_2151149415370285711_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SatG5oUGC_4Q7kNvgG5kY6B&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDxbHXwB6MhNDga9XJJsVjn3updjB7GTmbQcm5WcHLXQ&oe=67544C7C"}, {"file_name": "Screenshot3.png", "id": "1329895131046853", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_1329895134380186_3255244674483954341_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w03Bhg7YWyUQ7kNvgGnq09l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDloGMIjv3Yxhkl9Wc6G8fdZhOIHPbWj4FhSeTAEZVSrQ&oe=67543722"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape.png", "id": "2967303570084331", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982534_2967303576750997_4199489769763339074_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFYXTggjr1oQ7kNvgFCNQEq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBg3Td0Y_eWlJpqb1dNXBdkEZiKsIAbYoz44jEv12oa8g&oe=675435AF"}, "display_name": "VAIL", "keywords": ["shooter", "fps", "multiplayer", "gun", "social"], "long_description": "Download now and explore VAIL\u2019s free-to-play Citadel\n\n#  **VAIL CITADEL (FREE-TO-PLAY)**\nDiscover why VAIL is the highest rated VR Shooter with best-in-class mechanics, precisely tuned interactions, and immersive physics systems. Challenge others to intense 1v1 battles, get the best score in mini-golf, or discover the mysteries in the quarry \u2014 The Citadel is constantly being updated with new features and content.\n\n{559972780086817}\n\n#  **VAIL COMBAT (DLC)**\nGain access to everything VAIL has to offer. Dominate in popular team-based and free-for-all game modes as you level up, unlock rewards, and top the leaderboards. \n\n{1162628724924512}\n\nUncover VAIL's story as you traverse through awe-inspiring brutalist environments and the lines between right and wrong begin to blur.\n\n{1884336785321853}\n\n# **BUT WAIT THERE'S MORE**\nVAIL Combat (DLC) will also include future game modes that are currently in development, such as an upcoming extraction mode. \n\n{390905377282488}\n\n# **CRITICALLY ACCLAIMED**\n\n{481558107552824}", "short_description": "Download now and explore VAIL\u2019s free-to-play Citadel.\n\nDiscover why VAIL is the highest rated VR Shooter with best-in-class mechanics, precisely tuned interactions, and immersive physics systems."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aexlab.com/aexlab/privacy", "developer_terms_of_service_url": null, "publisher_name": "AEXLAB", "support_website_url": null, "website_url": "https://vailvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8781844031859182"}, "review_messages": ["", "Your app's store cover square, and cover portrait include text in the bleed area of the images. Store cover ar