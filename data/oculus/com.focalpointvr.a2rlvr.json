dn.com&oh=00_AYAfx1GByxJmpUf0Nn2cYGDr_4BY-ifbuHj7ntTU-ReJcA&oe=677523F6"}, {"file_name": "com.focalpointvr.a2rlvr-20240321-143848.png", "id": "951500289959030", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031339_951500293292363_1892480222127105765_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fZSuYGERo48Q7kNvgF7K-Rr&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD5O57XsWm3AmaSVJhLJpAPzRhflT1DgtxtK4AYDdyy9A&oe=67752099"}, {"file_name": "com.focalpointvr.a2rlvr-20240321-144812.png", "id": "1097481431464122", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982588_1097481434797455_6052519219973323555_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=79EMgZocfJEQ7kNvgGjKMPC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBfrCFuYk9LphuOTViv_F0DKvTtEqI-CblTOZM-3RR5LA&oe=67753AC5"}, {"file_name": "com.focalpointvr.a2rlvr-20240321-144038.png", "id": "278063665360060", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036623_278063668693393_7943965453410782702_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1dFKigQYy1EQ7kNvgGdoZcb&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDpmWLLrFzlFWMZYtCU0Pz1Jvu1_wks5F1utn5JLQRDMw&oe=6775362D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "A2RL VR", "keywords": [], "long_description": "Experience the future of motorsport with A2RL VR! Dive into the heart of the action at the Abu Dhabi Autonomous Racing League, where cutting-edge AI technology meets adrenaline-fueled racing.\n\nA2RL VR transports you directly into the cockpit of A2RL's autonomous racing cars, immerse yourself in ultra-high-resolution onboard VR video and witness every twist and turn of the Yas Marina Circuit in stunning detail.\n\nWith our innovative integration of 3D data visualization and live telemetry, you'll have access to an unprecedented level of engagement, offering a truly immersive and thrilling viewing experience.\n\nDon't just watch the race \u2013 be part of it with A2RL VR!", "short_description": "Step into the future of motorsport with A2RL VR! Immerse yourself in the adrenaline-fueled world of autonomous racing, experiencing every twist and turn from inside the A2RL cars. With ultra-high-resolution VR video and live telemetry, A2RL VR offers unparalleled engagement for sports enthusiasts. Get ready to race like never before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://focalpointvr.com/a2rl-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ASPIRE UAE \u2013 Sole Proprietorship LLC", "support_website_url": null, "website_url": "https://a2rl.io/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25338181279129641"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "938316904446500"}]}, "baseline_offer": {"id": "938316904446500"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1714114800, "status": "PUBLISHED", "id": "938316904446500"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27699755942972151", "version": "0.9.136"}, "id": "721189079496695", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_appl