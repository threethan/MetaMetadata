r": null, "video_trailer_thumbnail": {"file_name": "LDU_trailer_end.png", "id": "148050940768225", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031354_148050947434891_531769334988008976_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bF7HlH8z1SoQ7kNvgF_eOHG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBry7btGLCa9eKIV1PLcCSuXMlZPesKaNk68qIyggbFYQ&oe=677FA238"}, "display_name": "Loco Dojo Unleashed", "keywords": ["party", "minigame", "social", "ninja", "board"], "long_description": "Enter the whimsical wooden world of Loco Dojo & step up to Grand Sensei\u2019s \u2018Table of Trials\u2019 to pit your silliest skills against (up to) 3 friends or strangers in this hilariously competitive multiplayer party game\n\nTake turns to spin the wheel & move your counter around the dojo\u2019s game board, acquiring strategic prizes & launching ludicrous trials in which to compete with your rival players to prove yourself as a master of martial madness!\n\nDiscover a wealth of wacky inputs woven through sixteen ridiculous minigames. Perform well & win a pile of Golden Suns to please Grand Sensei, earning the right to enter his temple where overall victory can be claimed in an asymmetric showdown of epic absurdity\n\nNo friends? No problem! Grand Sensei\u2019s Ten Trial Test provides a highly replayable mode that\u2019s different every time you play. Do you have what it takes to obtain the fabled Black Headband? Or hone your skills in the Solo Dojo to unlock more avatar masks\n\n*NB Internet required for multiplayer", "short_description": "Enter the whimsical wooden world of Loco Dojo & step up to Grand Sensei\u2019s \u2018Table of Trials\u2019 to pit your silliest skills against friends or strangers in this hilariously competitive multiplayer party game. Take turns to spin the wheel & move your counter around the dojo\u2019s game board, acquiring strategic prizes & launching ludicrous trials in which to compete with your rival players to prove yourself as a master of martial madness! No friends? No problem! Solo Dojo and Ten Trials Tests awaits you!"}]}, "developer_name": "Make Real Ltd", "developer_privacy_policy_url": "https://makereal.co.uk/privacy-policy/", "developer_terms_of_service_url": "https://makereal.co.uk/terms-of-service-loco-dojo/", "publisher_name": "Make Real Ltd", "support_website_url": "https://www.locodojogame.com/faqs", "website_url": "https://www.locodojogame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1660591790945168"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1619134722329079"}, {"status": "PUBLISHED", "id": "1078949672672205"}, {"status": "PUBLISHED", "id": "3017237761865751"}]}, "baseline_offer": {"id": "3017237761865751"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1619134722329079"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6527355817307593", "version": "104"}, "id": "1275832639223360", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2097356583640894", "is_concept": false, "latest