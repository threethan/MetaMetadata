b=1-7&_nc_sid=6e7a0a&_nc_ohc=5pH4sEKx_3sQ7kNvgEr033p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXPQ1u7d-LM6voknf5siTpbi2Fxd-KbE8Jg1pUnmsokA&oe=674C3438"}, {"file_name": "Mission1_Airsupport_CloseToTerrain.png", "id": "511665811210366", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974820_511665814543699_4057157697723389302_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLMK-Il6wJ4Q7kNvgHMk3-y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4pY7HVTSCidyF3r-Gg5wurNuBf7QKwwfKoSdga0Rcmw&oe=674C4386"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_Landscape_highRes_demo.png", "id": "1216624106004579", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569468_1216624109337912_3069334669929622439_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WC0oBt_bRqYQ7kNvgF-lVXa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOo4YqwDxCZ26L7NQEJgg95F5HBVBHmkQYaHmLt2CfeQ&oe=674C5A91"}, "display_name": "Unoffensible Demo", "keywords": [], "long_description": "# VR RTS\nA classic RTS in VR where all projectiles and units have simulated physics. Move your units by throwing. Stack units to increase their power.\n\n# Features\n- Build for VR only. With unique VR interactions\n- Campaign/Story driven RTS focus on single player\n- Physics based. All projectiles, enemies, friendlies and neutral items can be grabbed by the player\n- RTS basics : Fog of war, Tech tree, Base building, Superweapons, Resources, Cutscenes, many weapons & many enemies\n\n# Current state of DEMO\n- The demo is of the current state of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084777771554102"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1645795706250160"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719906534, "status": "PUBLISHED", "id": "1645795706250160"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8228239640541247", "version": "0.1.23"}, "id": "998539825117601", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8084777758220770", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8228239640541247"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "998539825117601"}]}, "change_log": "alpha build", "created_date": 1719490180, "id": "8228239640541247", "version": "0.1.23", "version_code