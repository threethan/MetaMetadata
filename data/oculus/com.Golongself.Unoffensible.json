id=6e7a0a&_nc_ohc=JzY2QE0ePMMQ7kNvgG2nLdj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwwkPLoG9zS0HFWC3F23j1rZKpizYMUExmoo0-Zc_VXw&oe=66D2F986"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_Landscape_highRes_demo.png", "id": "1216624106004579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569468_1216624109337912_3069334669929622439_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u6rnmVLeim8Q7kNvgGY4AdE&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhTZYQjTZcwMpE2NujnoTTGZWh8ueXXDmN7AI259zbqw&oe=66D31091"}, "display_name": "Unoffensible Demo", "keywords": [], "long_description": "# VR RTS\nA classic RTS in VR where all projectiles and units have simulated physics. Move your units by throwing. Stack units to increase their power.\n\n# Features\n- Build for VR only. With unique VR interactions\n- Campaign/Story driven RTS focus on single player\n- Physics based. All projectiles, enemies, friendlies and neutral items can be grabbed by the player\n- RTS basics : Fog of war, Tech tree, Base building, Superweapons, Resources, Cutscenes, many weapons & many enemies\n\n# Current state of DEMO\n- The demo is of the current state of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_