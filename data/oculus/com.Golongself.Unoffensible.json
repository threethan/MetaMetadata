tate of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084777771554102"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1645795706250160"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719906534, "status": "PUBLISHED", "id": "1645795706250160"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8228239640541247", "version": "0.1.23"}, "id": "998539825117601", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"no