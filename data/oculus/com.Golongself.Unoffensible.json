=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJmJgcVQYDUQ7kNvgFbq01S&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYCUtgw2mY9pun4FDrAnLnbWBObfF2G3KVBfK1Ecm12kJQ&oe=66E96EE4"}, {"file_name": "OverviewBattleFinalDemoMission_2.png", "id": "822690069500505", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340708_822690076167171_8100936849385053388_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=atvkETDqM1YQ7kNvgEhowau&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYASAaO4LWlGAxZmzARQCtxbDcMWk7d99fR9p-0rp5lHNg&oe=66E953B8"}, {"file_name": "Mission1_Airsupport_CloseToTerrain.png", "id": "511665811210366", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_511665814543699_4057157697723389302_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KT6BY66FpeQQ7kNvgFvcsbk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYC4uBlPhiYCMVjA_MorSgEWsu2H9cSp8uNeoNWEuGrfbA&oe=66E96306"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_Landscape_highRes_demo.png", "id": "1216624106004579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569468_1216624109337912_3069334669929622439_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KxufZMXEtvUQ7kNvgHWQ9RV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYAns-ibkic7C96-f_AiIjjhOPBTTfIlLoliv2qypPZCDw&oe=66E97A11"}, "display_name": "Unoffensible Demo", "keywords": [], "long_description": "# VR RTS\nA classic RTS in VR where all projectiles and units have simulated physics. Move your units by throwing. Stack units to increase their power.\n\n# Features\n- Build for VR only. With unique VR interactions\n- Campaign/Story driven RTS focus on single player\n- Physics based. All projectiles, enemies, friendlies and neutral items can be grabbed by the player\n- RTS basics : Fog of war, Tech tree, Base building, Superweapons, Resources, Cutscenes, many weapons & many enemies\n\n# Current state of DEMO\n- The demo is of the current state of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084777771554102"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1645795706250160"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719906534, "status": "PUBLISHED", "id": "1645795706250160"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8228239640541247", "version": "0.1.23"}, "id": "998539825117601", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"no