MnfW7AUVdUvfiMyZ1D3mh58TpKrViZw&oe=677E4D38"}, {"file_name": "Mission1_Airsupport_CloseToTerrain.png", "id": "511665811210366", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974820_511665814543699_4057157697723389302_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i05ggREZNNoQ7kNvgGWejVT&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDXa866IIwV8cy5TtFKI9trJINThQqXlOTXNUhbdYHJSA&oe=677E5C86"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_Landscape_highRes_demo.png", "id": "1216624106004579", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/57569468_1216624109337912_3069334669929622439_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2rqXdGNt1UQ7kNvgE4vuBW&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYApBbYz-qKsjkUP-BEbs2X5yzq5IZkh69auvh5kM3NfkQ&oe=677E7391"}, "display_name": "Unoffensible Demo", "keywords": [], "long_description": "# VR RTS\nA classic RTS in VR where all projectiles and units have simulated physics. Move your units by throwing. Stack units to increase their power.\n\n# Features\n- Build for VR only. With unique VR interactions\n- Campaign/Story driven RTS focus on single player\n- Physics based. All projectiles, enemies, friendlies and neutral items can be grabbed by the player\n- RTS basics : Fog of war, Tech tree, Base building, Superweapons, Resources, Cutscenes, many weapons & many enemies\n\n# Current state of DEMO\n- The demo is of the current state of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084777771554102"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031508_336210142894463_2122759765850544447_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TCvh3hsUHcUQ7kNvgE9Y8Fv&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYAcfyXs7VBuy1CuGz5iCUuSPyoU0aVcRMoiV3NqW8LX2Q&oe=677E621F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Unoffensible Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1719906534, "lastRevision": {"nodes": [{"id": "8084777781554101", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8084777758220770", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "7740547902679141"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Meta_Portrait_highRes_DEMO.png", "id": "3840306056293394", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-