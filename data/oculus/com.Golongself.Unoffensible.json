NvgEhowau&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYASAaO4LWlGAxZmzARQCtxbDcMWk7d99fR9p-0rp5lHNg&oe=66E953B8"}, {"file_name": "Mission1_Airsupport_CloseToTerrain.png", "id": "511665811210366", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_511665814543699_4057157697723389302_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KT6BY66FpeQQ7kNvgFvcsbk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYC4uBlPhiYCMVjA_MorSgEWsu2H9cSp8uNeoNWEuGrfbA&oe=66E96306"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_Landscape_highRes_demo.png", "id": "1216624106004579", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569468_1216624109337912_3069334669929622439_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KxufZMXEtvUQ7kNvgHWQ9RV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYAns-ibkic7C96-f_AiIjjhOPBTTfIlLoliv2qypPZCDw&oe=66E97A11"}, "display_name": "Unoffensible Demo", "keywords": [], "long_description": "# VR RTS\nA classic RTS in VR where all projectiles and units have simulated physics. Move your units by throwing. Stack units to increase their power.\n\n# Features\n- Build for VR only. With unique VR interactions\n- Campaign/Story driven RTS focus on single player\n- Physics based. All projectiles, enemies, friendlies and neutral items can be grabbed by the player\n- RTS basics : Fog of war, Tech tree, Base building, Superweapons, Resources, Cutscenes, many weapons & many enemies\n\n# Current state of DEMO\n- The demo is of the current state of the full game, so as long as the full game is not released the demo will receive updates to keep it in sync.  \n- There is 1 tutorial and 4 missions in the demo\n- Game state is saved after each mission (except the tutorial), there is a reset option.\n- User feedback is very welcome, both positive and negative. ", "short_description": "A classic RTS in VR with simulated physics. Move your units by throwing, stack units to increase their power. Gather resources, build a base and an army, expand across the map and defeat your enemies."}]}, "developer_name": null, "developer_privacy_policy_url": "https://golongself.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Golongself", "support_website_url": null, "website_url": "https://golongself.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8084777771554102"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031508_336210142894463_2122759765850544447_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G5mYc9DAWPkQ7kNvgEzSYXT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGXd-kFu4tdKf73MFxaV0EE&oh=00_AYDHhtF8cK5sDMU825dIfOKFVXAlonSXMrRuENIedM-ixg&oe=66E9689F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Unoffensible Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1719906534, "lastRevision": {"nodes": [{"id": "8084777781554101", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8084777758220770", "is_first_party": false, "enables_in_app_ads": false, "is_concept": 