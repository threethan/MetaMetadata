iad3-1.oculuscdn.com&oh=00_AYBpfpl0P56fo5bLly76tEJxFOIksv7S5Obx0S1W1aJTwA&oe=6708F8D6"}, {"file_name": "Session_1.23.1.png", "id": "186237824499218", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75363516_186237827832551_3418390153140386055_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y-hTNqbrt6cQ7kNvgEvPADM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKWarBxWha1lhd2f4dZfX3vsV98Ga2pYFvNZlLA8WibQ&oe=670929BD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NewHeroSnowOculusLiteVideoThumb.png", "id": "1461202384440410", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035321_1461202391107076_2829141908334275354_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6xEdE-05VMQ7kNvgHJdHjR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBw7y7yfEdKysnWfTniIwR0VJ_MvaKxM13l0LrFgjHFmA&oe=67091317"}, "display_name": "Tranzient Lite", "keywords": ["Music", "DJ", "Beats", "Drums", "Concert"], "long_description": "Make Music in VR - This is not a rhythm game!\n\nImmerse yourself in live looping and music production in VR.\n\n- Synced looping with content library, auto time-stretched and pitch-shifted to fit the song.\n- Record vocals including mo-cap and replay of your avatar.\n- Use your custom Ready Player Me avatar.\n- Set of drum kits/one-shots.\n- Use Decks to create a seamless mix.\n- Full set of audio FX applied per clip or per scene (reverbs, chorus etc). \n- Loop record automation of audio FX parameters and synth parameters.\n- Assignable 3D control of FX and synth parameters.\n- Loop videos synced to the beat.\n- Step sequencer - trigger any item in the world and loop record instruments/drumkits. Edit steps, swing quantize.\n- Built in Analog Synth sim and Wavetable synth with >250 Sounds\n- Spatial Mixing - create a binaural mix based on clip positions.\n- In game camera and screen/mirror.\n- Use your USB Midi keyboard or controller", "short_description": "The Lite/Free version of Tranzient.\nMake music in VR. Full live looping music production and sequencing environment in VR including visuals. \n\nThis is not a rhythm game.\n\nWho made the beats? You did!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aliveintech.com/privacy-policy", "developer_terms_of_service_url": "https://www.aliveintech.com/eula", "publisher_name": "AliveIn Tech Ltd.", "support_website_url": "https://www.aliveintech.com/issues", "website_url": "https://aliveintech.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "384928226018505"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7885787881469221"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974893_975637387424833_1412858605559418067_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2aTNaIGBK2QQ7kNvgFcTy-C&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCN9t8iBcL_qP0HOls2AtXqn-5UdGAWgy3kt3dBBZ1Cbw&oe=6708FF58"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tranzient Lite", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media & Streaming", "id": "384928226018505"}, {"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1627604630, "lastRevision": {"nodes": [