ontrol of FX and synth parameters.\n- Loop videos synced to the beat.\n- Step sequencer - trigger any item in the world and loop record instruments/drumkits. Edit steps, swing quantize.\n- Built in Analog Synth sim and Wavetable synth with >250 Sounds\n- Spatial Mixing - create a binaural mix based on clip positions.\n- In game camera and screen/mirror.", "short_description": "Make beats in VR. Full live looping music production and sequencing environment in VR including visuals. The Lite/Free version of Tranzient.\n\nThis is not a rhythm game.\n\nWho made the beats? You did!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aliveintech.com/privacy-policy", "developer_terms_of_service_url": "https://www.aliveintech.com/eula", "publisher_name": "AliveIn Tech Ltd.", "support_website_url": "https://www.aliveintech.com/issues", "website_url": "https://aliveintech.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3097222440525123"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3012857272266513"}]}, "baseline_offer": {"id": "3012857272266513"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1627604580, "status": "PUBLISHED", "id": "3012857272266513"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_re