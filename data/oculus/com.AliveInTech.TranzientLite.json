luscdn.com/v/t64.5771-25/38974666_525714748855075_2372348755040121265_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HXToJohovxgQ7kNvgGWtHU_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHfc3ICIuqFmkiOAUkLyKkJRW_AQ2iWk5ErvYRdF_Qmg&oe=676557D9"}, {"file_name": "VFXCrop.png", "id": "177051320991484", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_177051324324817_536426833029901367_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K6My8jLAb9oQ7kNvgFt8DMn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhadKA94OfmdNNvAp8gmbbUh_Z8CtulFVdGWWbA6XIWw&oe=676564D4"}, {"file_name": "DrumsBrightCrop.png", "id": "906668313223333", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974538_906668316556666_7612337564929272449_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Kf147OE554Q7kNvgGBxQAU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALxp4ayrp_YdT0Oc6DKc7vWYcTz9dCIIiGJJYHhIZ0ew&oe=67654B57"}, {"file_name": "vidwallcrop.png", "id": "188480243148567", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974503_188480246481900_1395795850249111562_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bBgI3eAvJTwQ7kNvgFi6rhy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3Id7GvFcP71L1Dc_KGLWivHoleuCkwgSnX0xyLaGzzw&oe=6765731C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RPMSynth.png", "id": "529939358451396", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86613168_529939361784729_5099460692979232560_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TPcOUkCfOI8Q7kNvgGRPgIQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_Bp6DKyVHWqnEKMEIQMNyvU8XHEBrc7OJBtnM743Bdw&oe=676540C2"}, "display_name": "Tranzient Lite", "keywords": [], "long_description": "Make beats in VR - This is not a rhythm game!\n\nImmerse yourself in live looping and music production in VR.\n\n- Synced looping with content library, auto time-stretched and pitch-shifted to fit the song.\n- Record vocals including mo-cap and replay of your avatar.\n- Use your custom Ready Player Me avatar.\n- Set of drum kits/one-shots.\n- Use Decks to create a seamless mix.\n- Full set of audio FX applied per clip or per scene (reverbs, chorus etc). \n- Loop record automation of audio FX parameters and synth parameters.\n- Assignable 3D control of FX and synth parameters.\n- Loop videos synced to the beat.\n- Step sequencer - trigger any item in the world and loop record instruments/drumkits. Edit steps, swing quantize.\n- Built in Analog Synth sim and Wavetable synth with >250 Sounds\n- Spatial Mixing - create a binaural mix based on clip positions.\n- In game camera and screen/mirror.", "short_description": "Make beats in VR. Full live looping music production and sequencing environment in VR including visuals. The Lite/Free version of Tranzient.\n\nThis is not a rhythm game.\n\nWho made the beats? You did!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.aliveintech.com/privacy-policy", "developer_terms_of_service_url": "https://www.aliveintech.com/eula", "publisher_name": "AliveIn Tech Ltd.", "support_website_url": "https://www.aliveintech.com/issues", "website_url": "https://aliveintech.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "PRODUCTIVITY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3097222440525123"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"s