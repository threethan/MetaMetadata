iad3-2.oculuscdn.com/v/t64.5771-25/38984460_811116060709548_7403678277679912327_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_jb3yYmdSocQ7kNvgGM2V48&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHTKqGUyEfXTR_7Zgb_XTWn5V_AgFvGDZHUvG9botEcQ&oe=6720C724"}, {"file_name": "Respiratory Rate Monitoring Simulator_screenshot_04.png", "id": "502571615763924", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984460_502571619097257_3337648881620361105_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-1xX-tHhSMYQ7kNvgGVZhrZ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbvDvZsWWYOvBMrxA3xth53JYsr97N3V5Hmaxn5TIltg&oe=6720E5F0"}, {"file_name": "Respiratory Rate Monitoring Simulator_screenshot_05.png", "id": "1975815742883312", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031336_1975815749549978_3918464507945065724_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k7Im7xPw_qUQ7kNvgG7elfX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiJ5Eq-7bjY_CO-K-0NzpW4Z58yCAuTR597PZuke5uGg&oe=6720CE94"}, {"file_name": "Respiratory Rate Monitoring Simulator_screenshot_06.png", "id": "367005485993481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035412_367005489326814_7160952519256106619_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dZXhKZVpBsMQ7kNvgGAAvfs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDK-Z7joo5Pfd9oF9D_Iw4QQusJxDaxYxQa_DEpmqrWkw&oe=6720B1DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1130584721390747", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245823_1130584724724080_3393375799380002574_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sHj6as_Yu5sQ7kNvgHp0-9F&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbtMZxDEnHmhelUidgbm4KdoqrltDiEBfRnWXOvXmeWg&oe=6720CD05"}, "display_name": "Respiratory Rate Monitoring Simulator", "keywords": [], "long_description": "The Respiratory Rate Monitoring tutorial immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the technique of monitoring a patient's respiratory rate using a stopwatch. This application guides users through the correct procedure for counting breaths, timing accurately, and interpreting the results.  \n# Learning Objectives:\n- Remembering the normal ranges for respiratory rates \n- Understanding the importance of accurate respiratory rate monitoring \n- Applying the correct technique for using a stopwatch to count breaths \n- Analyzing the data to identify normal and abnormal rates \n- Evaluating the patient's respiratory status based on the gathered data   \n\nThis comprehensive approach ensures CNAs are proficient in monitoring respiratory rates accurately in real-world clinical settings. ", "short_description": "Designed to train CNAs in accurately measuring and interpreting patient respiratory rate using an interactive, hands-on virtual scenario."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7422961481160424"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_92411450615