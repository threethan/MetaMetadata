nail": {"file_name": "Respiratory Rate Monitoring Simulator_04.png", "id": "1130429714923155", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/75451781_1130429718256488_1594838047299649356_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OiQQh54YsFMQ7kNvgESpQZb&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYDTowLs9-FJn9U8aujkwm8SE048KIIBl47QoOhiDVTP9A&oe=677E7EE0"}, "display_name": "Respiratory Rate Monitoring Simulator", "keywords": ["CNA", "nurse", "nursing", "respiratory", "healthcare"], "long_description": "The Respiratory Rate Monitoring tutorial immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the technique of monitoring a patient's respiratory rate using a stopwatch. This application guides users through the correct procedure for counting breaths, timing accurately, and interpreting the results.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n# Learning Objectives:\n- Remembering the normal ranges for respiratory rates \n- Understanding the importance of accurate respiratory rate monitoring \n- Applying the correct technique for using a stopwatch to count breaths \n- Analyzing the data to identify normal and abnormal rates \n- Evaluating the patient's respiratory status based on the gathered data   \n\nThis comprehensive approach ensures CNAs are proficient in monitoring respiratory rates accurately in real-world clinical settings. ", "short_description": "Designed to train CNAs in accurately measuring and interpreting patient respiratory rate using an interactive, hands-on virtual scenario with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8549641815159046"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75294241_3783903601868846_284297527829948636_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8TCYc84aqeEQ7kNvgHVl2Ql&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBKbhghpuyRS_vhGwrxkIejhc-ShvcwlGIa2Kxs7ijjTw&oe=677E604B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Respiratory Rate Monitoring Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], 