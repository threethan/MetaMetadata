&oe=6739C287"}, {"file_name": "Glitch_Screen_03.png", "id": "969119757401688", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982585_969119760735021_5974992275693101456_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJGdtpHWSPIQ7kNvgHBK9gy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5hzW6d3_eJi5f45A_zYHkw0DkzPZb655UmmV8pG03rA&oe=6739D4F9"}, {"file_name": "Glitch_Screen_04.png", "id": "900310361069511", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031594_900310364402844_4762867149900547984_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAa-GOjWKD0Q7kNvgHKnk1A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdazHvuo4Mk2p8TCw6fmIW_7GORvpCgafjZ_iYhDFAJw&oe=6739BB19"}, {"file_name": "Glitch_Screen_05.png", "id": "287924536904722", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931333_287924540238055_3983448721471694475_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SrDuSRreb2YQ7kNvgHHaYsy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAz9L3loyMfqMLbLSuJRdTiFyLNkVcNJs8OFdGbEGkCgg&oe=6739EF69"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "57569446_8289298184443855_7078290401953413423_n_hdr.png", "id": "635852425067938", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75340709_635852428401271_9131587383912358370_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1nIqVhxM7wQ7kNvgHqO4tw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDuvArkp6exUYUc7hgw43EOzE3W7nSAE9KMrz6rxdy55w&oe=6739C1E5"}, "display_name": "Glitch Moba", "keywords": [], "long_description": "Welcome to Glitch, the next frontier in Virtual Reality gaming! Prepare to immerse yourself in a pulsating sci-fi universe, where the line between reality and the digital realm blurs. Designed as a MOBA game, Glitch offers you adrenaline-charged 5v5 battles that test your strategy, teamwork, and skill.\n\nIn the world of Glitch, you're not just a player, but a virtual hacker. You have the freedom to select from a pool of abilities, enabling you to customize your avatar to match your gaming style. Each match is a sprint, lasting no more than 15 minutes of heart-racing, strategic combat. Outmaneuver opponents, bring down their defensive firewalls, and ultimately seize control of their database to claim victory.\n\nBut Glitch is more than just a game; it's a community. Level up, participate in tournaments, and grow alongside a vibrant, engaged player base. Plus, with the promise of account progression and a robust meta-game, every match brings you closer to becoming a legend in the Glitch universe.\n\nSo, if you're up for the challenge and ready to make your mark on a game that's redefining the VR landscape, Glitch awaits. Strap on your headset, step into the arena, and get ready to experience gaming like never before. Welcome to Glitch, champion!", "short_description": "Welcome to Glitch, the cosmic realm of virtual warfare! Suit up for explosive 5v5 MOBA battles, customize your avatar with unique abilities, and dive into fast-paced, strategic skirmishes. Set in a vibrant sci-fi universe, Glitch takes VR gaming to a whole new level. Your mission, if you dare to accept, is to outwit opponents, demolish enemy firewalls, and capture their database. Are you ready to become a Glitch champion? Gear up, it's game time!"}]}, "developer_name": "Glitcher", "developer_privacy_policy_url": "https://sites.google.com/view/glitchmoba/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/glitchmoba/terms-of-service", "publisher_name": "Glitcher", "support_website_url": null, "website_url": "https://sites.google.com/view/glitchmoba/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "