dn.com/v/t64.5771-25/38974869_321540700945346_1531431346310518851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VMf6v2U7hg8Q7kNvgFC1vQa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXhCsfNb2Pe4CiOamy1N3rPCGna6SdYBC1vdCKU54JPg&oe=676D5A72"}, {"file_name": "Worksite01.png", "id": "947796243326733", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439595_947796246660066_7188587219428017429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qIME5gGqme8Q7kNvgFGvgxe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnL8WDLdjdk3yHO3weOqCehmRpcmQujnm1BwtlHWtGGQ&oe=676D3BA9"}, {"file_name": "Duck01.png", "id": "940126944514536", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334060_940126947847869_515873439267457350_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5IR1esWOs1oQ7kNvgFy_i-z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2lvuYl_IBb-bUlyD5mVpaW-C0EKXLNQjATaetWWAB_A&oe=676D5048"}, {"file_name": "Resi03.png", "id": "960732608584758", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540503_960732615251424_1965277303103811287_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cTrK5G5q9t0Q7kNvgHmA81A&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_ehD5Xh9xTKTmQCwLtkeee8zsftWgWvOLQn64XHHCpg&oe=676D5AD8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "950729092970267", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974891_950729102970266_760305580491375736_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_M_RPAYCNvwQ7kNvgH7FZfr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA9Bu5Q_bwwmaWuTW9vcV360fRdBrfHUUG-UO98UZUt0A&oe=676D3871"}, "display_name": "DIG VR", "keywords": ["Simulation", "Digger", "Multiplayer", "Casual", "Construction"], "long_description": "DIG VR captures the sheer joy, adrenaline and frustrations of life on a digger in an exciting experience for novices and pros. Featuring authentic, immersive controls that recreate the feeling of driving a real digger, DIG VR is a light-simulation game with a casual arcade-twist!\n\nGrow your business in the charming town of Diglington, a place where everything can be fixed by the power of a digger. Take on a variety of jobs for the town's residents - from traditional construction jobs, to more obscure requests! Accompanying you is DIG FM, a dedicated radio station with a wide selection of music to brighten any day. \n\nProgress from micro-sized to colossal diggers, with a diverse set of attachments to overcome any challenge. Dig in style by unlocking over 70 customization options to suit your aesthetic!\n\nAvailable to play solo or with a friend, get hands on with the fast-paced mini-games or unwind in the sandbox mode. Then, discover a trove of Lost Treasure in a standalone mode where new items are added regularly.\n\nWhether this is your first time operating a digger or you\u2019re already a master, digging fortunes await!\n\nKey Features:\n\u2022\tThe first ever digger game developed exclusively for Meta Quest\n\u2022\tChoice of authentic & simplified controller schemes\n\u2022\tCareer Mode Campaign with options for serious & casual players\n\u2022\tUnlock new machinery & attachments \n\u2022\tPersonalize your digger with decal, paint & skins\n\u2022\tPlay with a friend in select modes\n\u2022\tDiscover new items regularly in Lost Treasure mode", "short_description": "DIG VR captures the sheer joy, adrenaline and frustrations of life on a digger, whilst delivering an authentic and exciting experience regardless of whether you're a novice or pro. \n\nStarting off with nothing more than a mini-digger and a dream, unearth your digging passion in a casual, light-simulation game set in the charming town of Diglington. Progress from a micro-sized digger to a colossal machine, with a diverse set of attachments to overcome the most challenging of jobs.\n"}]}, "developer_name": "Just Add Water", "developer_privacy_policy_url": "https://wiredproductions.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Wired Productions", "support_website_url": null, "website_url": "https://wiredproductions.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es", "pt", "zh_CN", "ko", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "496487385930716"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1099585184409000"}, {"status": "PUBLISHED", "id": "338510645992045"}, {"status": "PUBLISHED", "id": "1341946140111363"}, {"status": "PUBLISHED", "id": "859678296299251"}]}, "baseline_offer": {"id": "338510645992045"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1099585184409000"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9221220254608185", "version": "1.0.2"}, "id": "3345255162356016", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6128709557192619", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9221220254608185"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 173432