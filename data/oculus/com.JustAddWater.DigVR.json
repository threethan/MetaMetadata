/v/t64.5771-25/38982716_3777799962545658_8150453798281951959_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S8h2CZLnuVEQ7kNvgG1qCO6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApVySoCbNrV5_I1B3FyA6-lEJGL3bfLeGsQcqt2313qg&oe=673C84F1"}, {"file_name": "Bowling.png", "id": "321540697612013", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974869_321540700945346_1531431346310518851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n1WyAjNT8ngQ7kNvgEuPQJE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASdc53I60flAq79GCxoVHN2RCWoLaUb_atSiKdJC6w2Q&oe=673C92F2"}, {"file_name": "Worksite01.png", "id": "947796243326733", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439595_947796246660066_7188587219428017429_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F7TbA_MSMhQQ7kNvgE-Qxpb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiqUrbujyn8XzXCKi5_7mJvVwVbJeO5RHCZgq7a98Qkg&oe=673C7429"}, {"file_name": "Duck01.png", "id": "940126944514536", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75334060_940126947847869_515873439267457350_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wHiirXZn74gQ7kNvgEJFwVh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSDM8D8fPKuSKVNJCphYGdugW3rEjspsqvOU9aTHfEGQ&oe=673C88C8"}, {"file_name": "Resi03.png", "id": "960732608584758", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75540503_960732615251424_1965277303103811287_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-e25VU1BYsIQ7kNvgHnh2Go&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXOdZ9wDVPysl2XO3W0iJRZDm8L-xpJK7d0NDPaf1NQA&oe=673C9358"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "950729092970267", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974891_950729102970266_760305580491375736_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1_HmSZKF0PIQ7kNvgFjPH6E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALqqXpI20dr1nzbmXUzI1MFdcHBGb6GZ6vu8tnLzYgtQ&oe=673C70F1"}, "display_name": "DIG VR", "keywords": ["Simulation", "Digger", "Multiplayer", "Casual", "Construction"], "long_description": "DIG VR captures the sheer joy, adrenaline and frustrations of life on a digger in an exciting experience for novices and pros. Featuring authentic, immersive controls that recreate the feeling of driving a real digger, DIG VR is a light-simulation game with a casual arcade-twist!\n\nGrow your business in the charming town of Diglington, a place where everything can be fixed by the power of a digger. Take on a variety of jobs for the town's residents - from traditional construction jobs, to more obscure requests! Accompanying you is DIG FM, a dedicated radio station with a wide selection of music to brighten any day. \n\nProgress from micro-sized to colossal diggers, with a diverse set of attachments to overcome any challenge. Dig in style by unlocking over 70 customization options to suit your aesthetic!\n\nAvailable to play solo or with a friend, get hands on with the fast-paced mini-games or unwind in the sandbox mode. Then, discover a trove of Lost Treasure in a standalone mode where new items are added regularly.\n\nWhether this is your first time operating a digger or you\u2019re already a master, digging fortunes await!\n\nKey Features:\n\u2022\tThe first ever digger game developed exclusively for Meta Quest\n\u2022\tChoice of authentic & simplified controller schemes\n\u2022\tCareer Mode Campaign with options for serious & casual players\n\u2022\tUnlock new machinery & attachments \n\u2022\tPersonalize your digger with decal, paint & skins\n\u2022\tPlay with a friend in select modes\n\u2022\tDiscover new items regularly in Lost Treasure mode", "short_description": "DIG VR captures the sheer joy, adrenaline and frustrations of life on a digger, whilst delivering an authentic and exciting experience regardless of whether you're a novice or pro. \n\nStarting off with nothing more than a mini-digger and a dream, unearth your digging passion in a casual, light-simulation game set in the charming town of Diglington. Progress from a micro-sized digger to a colossal machine, with a diverse set of attachments to overcome the most challenging of jobs.\n"}]}, "developer_name": "Just Add Water", "developer_privacy_policy_url": "https://wiredproductions.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Wired Productions", "support_website_url": null, "website_url": "https://wiredproductions.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "de", "es", "pt", "zh_CN", "ko", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "496487385930716"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "338510645992045"}, {"status": "PUBLISHED", "id": "1341946140111363"}, {"status": "PUBLISHED", "id": "859678296299251"}]}, "baseline_offer": {"id": "338510645992045"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731607200, "status": "PUBLISHED", "id": "338510645992045"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9045072655556280", "version": "1.0.1"}, "id": "3345255162356016", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_a