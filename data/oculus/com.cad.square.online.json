06D9C"}, {"file_name": "migrated_image.png", "id": "920066628431043", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572954_173344193887274_5306210525435133952_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0LkR5DA0RxUQ7kNvgFEleNb&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4Vq7LpOYj_whRhM1IfD6dkRgeyBqNFFziQd1pfbXPrA&oe=66D05F64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/N23dAl", "id": "763889544102940", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388621_763889547436273_4459547260211953664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uOtb-3w1z9gQ7kNvgELFOmI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNlFv2jyBBq7V_PA3yBDghsQP8Sm5pJ5dJl-vj0g-WAA&oe=66D06EAE"}, "display_name": "SQUARE ONLINE - Mahjong Online -", "keywords": ["mahjong", "VRoid", "Avatar"], "long_description": "\u25a0 VR compatible online Mahjong appeared!\nOnline Mahjong game that can be played on iOS, Android and Oculus Go!\n\n\u25a0 Operation is just a tap\nEasy to operate and intuitive!\n\n\u25a0 Adopt M League rules\nInternet Mahjong uses the rare M-League rules.\nPlease check the official website for detailed rules.\n\n\u25a0 Voice chat support\nYou can play while chatting with friends in voice chat, or Vtuber can use it for events.\n\n\u25a0 Feel free to play against CPU\nSince it implements a CPU battle that is not strong, please enjoy yourself.\n\n* You cannot get actual money or rewards through gameplay.\n* Gambling does not necessarily improve with game play.\n* This game is recommended for Mahjong fans and adults who want to learn Mahjong.", "short_description": "hat can be played on iOS, Android, Oculus Go"}, {"images": {"nodes": []}, "id": "625200414728050", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SQUARE ONLINE -\u30aa\u30f3\u30e9\u30a4\u30f3\u9ebb\u96c0 -", "keywords": ["\u9ebb\u96c0", "VRoid", "Avatar", "\u30a2\u30d0\u30bf\u30fc"], "long_description": "\u25a0VR\u5bfe\u5fdc\u306e\u30aa\u30f3\u30e9\u30a4\u30f3\u9ebb\u96c0\u304c\u767b\u5834\uff01\niOS, Android, Oculus Go\u3067\u5bfe\u6226\u3067\u304d\u308b\u30aa\u30f3\u30e9\u30a4\u30f3\u9ebb\u96c0\u30b2\u30fc\u30e0\uff01\n\n\u25a0\u64cd\u4f5c\u306f\u30bf\u30c3\u30d7\u3060\u3051\n\u64cd\u4f5c\u304c\u7c21\u5358\u3067\u3001\u76f4\u611f\u7684\u306b\u904a\u3079\u307e\u3059\uff01\n\n\u25a0M\u30ea\u30fc\u30b0\u30eb\u30fc\u30eb\u3092\u63a1\u7528\n\u30cd\u30c3\u30c8\u9ebb\u96c0\u3067\u306f\u73cd\u3057\u3044M\u30ea\u30fc\u30b0\u30eb\u30fc\u30eb\u3092\u63a1\u7528\u3057\u3066\u3044\u307e\u3059\u3002\n\u7d30\u304b\u3044\u30eb\u30fc\u30eb\u306f\u516c\u5f0f\u30b5\u30a4\u30c8\u3092\u3054\u78ba\u8a8d\u304f\u3060\u3055\u3044\u3002\n\n\u25a0\u30dc\u30a4\u30b9\u30c1\u30e3\u30c3\u30c8\u5bfe\u5fdc\n\u30dc\u30a4\u30b9\u30c1\u30e3\u30c3\u30c8\u3067\u53cb\u9054\u540c\u58eb\u3067\u3057\u3083\u3079\u308a\u306a\u304c\u3089\u5bfe\u5c40\u3057\u305f\u308a\u3001Vtuber\u306e\u65b9\u306a\u3069\u304c\u30a4\u30d9\u30f3\u30c8\u306b\u4f7f\u3063\u305f\u308a\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\n\u25a0\u6c17\u8efd\u306bCPU\u3068\u5bfe\u6226\n\u5f37\u304f\u306a\u3044CPU\u6226\u3092\u5b9f\u88c5\u3057\u3066\u3044\u308b\u306e\u3067\u3001\u7121\u53cc\u3057\u3066\u697d\u3057\u3093\u3067\u304f\u3060\u3055\u3044\u3002\n\n\u203b\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\u306b\u3088\u3063\u3066\u5b9f\u969b\u306e\u91d1\u92ad\u30fb\u5831\u5968\u3092\u5f97\u308b\u3053\u3068\u306f\u3067\u304d\u307e\u305b\u3093\u3002\n\u203b\u30b2\u30fc\u30e0\u30d7\u30ec\u30a4\u306b\u3088\u3063\u3066\u3001\u30ae\u30e3\u30f3\u30d6\u30eb\u304c\u4e0a\u624b\u304f\u306a\u308b\u308f\u3051\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\n\u203b\u672c\u30b2\u30fc\u30e0\u306f\u9ebb\u96c0\u30d5\u30a1\u30f3\u3084\u3001\u9ebb\u96c0\u3092\u899a\u3048\u305f\u3044\u3068\u8003\u3048\u3066\u3044\u308b\u5927\u4eba\u306e\u65b9\u306e\u30d7\u30ec\u30a4\u3092\u63a8\u5968\u3057\u3066\u304a\u308a\u307e\u3059\u3002", "short_description": "iOS, Android, Oculus Go\u