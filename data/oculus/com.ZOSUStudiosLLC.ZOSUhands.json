culuscdn.com&oh=00_AYDG8td2li5KArgjGW9i6JiVkCJ9hPmd0oU0p7HpF-eT2Q&oe=671CDEB9"}, {"file_name": "CoverImageSafeAreaTemplateLandscape Q2.png", "id": "3224952671149093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75258662_3224952674482426_4595095236790555344_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TCLRR3UUiwoQ7kNvgGevG3f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAfajWJwARK8BNqEN61Nw47REPr9g61FgvDWZZSOhDq5g&oe=671CEF69"}, {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w zoodemo-s5.png", "id": "3183172028661305", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974615_3183172031994638_6284235289518104872_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PKDvDQ4bM0sQ7kNvgGMcAJq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaZNt_hN-IboI-q9yc2TiX1nkSv8NoS4IaEEs42vbb3A&oe=671CDD38"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w0012.png", "id": "8649301608477476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982699_8649301621810808_7305192826088229005_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PU6s-zukIGQQ7kNvgFZqSaV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBE5IckNrh6WyqDAQAYs0wF1fsz043Hb969Encx6tGPhg&oe=671CEA76"}, "display_name": "Landz and Seaz Mixed Reality", "keywords": ["Dinosaur", "mixed", "reality", "fish", "shark"], "long_description": "Create a Zoo and Ocean in your home with over 160 creatures\n- passthrough enabled to see animals in your actual surroundings in mixed reality / augmented reality , create a zoo or ocean aquarium in your home\n- handtracking enabled to allow hand placement of animals (controllers work as well)\n- animals are placeable and moveable with random spawn options and deletion options with bonus test levels with animal copying and enlarging options\n- 20 scenes of animals to enjoy with new bonus jungle area\n-- animals: 100+ ocean and 60+ land/air\n- animals include: dinosaurs, sharks, whales, zebras, bears, lions, tigers, lionfish, birds, sunfish, otter, penguin, moorish, leopards, cuttlefish,  elephants, rhinos, hippos, deer, cows, dolphins, clown fish, crocodiles,  starfish, turtles, mountain goats, dogs, cats, horses,  squid, discus, carp, trout, foxes, octopus, marlin,, tigers, zoo animals, common and exotic fish, and many more!", "short_description": "Create a Zoo and Ocean in your home with over 160 creatures!\n- passthrough enabled to see animals in your actual surroundings in mixed reality, create a zoo or ocean aquarium in your home\n- handtracking enabled to allow hand placement of animals (controllers work as well)\n- animals are placeable and moveable with random spawn/remove, bonus test levels to copy/enlarge\n- over 20 scenes of animals to enjoy\n-- animals:100+ ocean, 60+ land/air"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26518042214509976"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t6