50 levels by full release (Currently 16)\n-With enough support: Level Editor to create and share new levels\n-With enough support: Co-op and Multiplayer Functionality\n\nJoin the Discord to learn more about future updates, and provide your own feedback of what you want in the game!", "short_description": "Blockies VR is a fast-paced, action-puzzle game where you throw projectiles. Destroy block buildings and defend friendly Blockies! Fight against all kinds of enemy monsters by throwing projectiles ranging from a silly pineapple to a destructive blackhole."}]}, "developer_name": null, "developer_privacy_policy_url": "https://dragongatestudio.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "DragonGate Studio", "support_website_url": null, "website_url": "https://dragongatestudio.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "514769586930731"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "341078832353807"}, {"status": "PUBLISHED", "id": "537577598026590"}]}, "baseline_offer": {"id": "341078832353807"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719249260, "status": "PUBLISHED", "id": "341078832353807"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6442418539104582", "version": "0.0.13"}, "id": "406938807758555", "channel_name": "LIVE"}]}, "is_for_oculus_