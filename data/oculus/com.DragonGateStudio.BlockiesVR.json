c_ht=scontent.oculuscdn.com&oh=00_AYDP4t9_K0SsnUYM5REpQS-bn-EvQQLJ3mLummXs8rA5zA&oe=66FFC7E1"}, {"file_name": "5.png", "id": "1061517104420269", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_1061517107753602_1383467785716530594_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=12oYrE8jHSEQ7kNvgGA61uR&_nc_ht=scontent.oculuscdn.com&oh=00_AYA26WleZ5HXIrV8WSPlyK0OIjIBkqydGYWz0Wi2NHmqWw&oe=66FFD775"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.png", "id": "2078471315650549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2078471318983882_98333641966260853_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VHlwA_sig-wQ7kNvgGm9Nq9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAiIJFrQQ5warqpHLW-Mg_17jfZbNNLjtWoLEI6WPdXoA&oe=66FFC88F"}, "display_name": "Blockies VR", "keywords": [], "long_description": "Blockies VR is a single player action-puzzle game where you knock down block buildings and protect friendly Blockies against the forces of evil. Launch a wide range of objects at enemies in this low-poly physics world. Travel to the Kingdom\u2019s shop to expand your weapon arsenal to take on the most difficult puzzles in all the land.\n\nFeatures\n-A dozen types of blocks that interact uniquely with the world\n-A dozen AI enemy types each with their own abilities\n-Levels where you must defend the Blockies from monster attacks\n-Levels with intricate block puzzles to solve\n-The Kingdom where cool new projectiles can be purchased\n-Beautifully designed low poly environments\n-At least 50 levels by full release (Currently 16)\n-With enough support: Level Editor to create and share new levels\n-With enough support: Co-op and Multiplayer Functionality\n\nJoin the Discord to learn more about future updates, and provide your own feedback of what you want in the game!", "short_description": "Blockies VR is a fast-paced, action-puzzle game where you throw projectiles. Destroy block buildings and defend friendly Blockies! Fight against all kinds of enemy monsters by throwing projectiles ranging from a silly pineapple to a destructive blackhole."}]}, "developer_name": null, "developer_privacy_policy_url": "https://dragongatestudio.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "DragonGate Studio", "support_website_url": null, "website_url": "https://dragongatestudio.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "514769586930731"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "341078832353807"}, {"status": "PUBLISHED", "id": "537577598026590"}]}, "baseline_offer": {"id": "341078832353807"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719249260, "status": "PUBLISHED", "id": "341078832353807"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6442418539104582", "version": "0.0.13"}, "id": "406938807758555", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4920494881296963", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6442418539104582"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "40