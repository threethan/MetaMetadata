Ball Banner 2.png", "id": "244277984396844", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974598_244277987730177_6159679590959644567_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j5e4ifblI28Q7kNvgElIHw3&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMp1-6TnDdybu8we-iCFXJCpmvWyfAcR_Iwt-ycjYB5Q&oe=66F7F37A"}]}, "id": "463105929602855", "locale": "en_US", "screenshots": [{"file_name": "GunJitsu_Screenshot_1.png", "id": "260782252516995", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982697_260782255850328_5084442595581820356_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-XbdICqNzgQ7kNvgFk4Hb3&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9jis1Vi7-2dUmny14aDOJoWvxLjZ346LILH1S3CAMuQ&oe=66F7D994"}, {"file_name": "GunJitsu_Screenshot_2.png", "id": "620338102668749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_620338106002082_282661273207928436_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N0_wDVf_7j4Q7kNvgHRvqGX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAt0HQmiIxqKR8-RO0Ln9Ujp72pJgHVGF67w4e6PROsqQ&oe=66F805D3"}, {"file_name": "GunJitsu_Screenshot_5.png", "id": "408220474212174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974766_408220477545507_4507206763881336195_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IdPqhXeyk3UQ7kNvgE4gyZ7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAVnPLvOLBKnFLeZWZHjrGHf0tRiciwYBR3H1qT_d6TVw&oe=66F7EE89"}, {"file_name": "GunJitsu_Screenshot_4.png", "id": "385455932967464", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001673_385455936300797_7786371991393010935_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8BJAuaojtHQQ7kNvgGpxo5X&_nc_ht=scontent.oculuscdn.com&oh=00_AYDu27LI5tc6IIWjf9502ea_E4JLYET2wWiGEWxkdiSOQA&oe=66F7E03A"}, {"file_name": "GunJitsu_Screenshot_7.png", "id": "867514127465859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974511_867514130799192_909843452170294806_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-JLOEL8InNgQ7kNvgH4DROq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDS5vzJshotRaIs-wYy0KrV5KWbuSOZaiwAs3ownD_BQg&oe=66F7E1F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FluxBall Main Graphic 2.png", "id": "387248966427000", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_387248969760333_3966639532335732948_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZcX4URlk17QQ7kNvgFQ6gpl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAt5yJMTANsRvk_baemeE70uYwHa4C9MPlaPWBX7Bpqrg&oe=66F7F329"}, "display_name": "Flux Ball", "keywords": [], "long_description": "Why stop with pivots and squats?  Flux Ball pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a liquid container, drowning those who fall too far down.  Flux Ball is best played on fitness mats and/or a rug.  Come test your Flux Ball skills...", "short_description": "You have a glove on your left hand and pistol in your right hand...Flux Ball is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Flux Ball combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Flux Ball champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/fluxballprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Scrimage Entertainment, LLC", "support_website_url": null, "website_url": "https://liftedline.tumblr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_conne