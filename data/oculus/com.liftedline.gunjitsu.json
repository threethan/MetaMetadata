Ball Banner 2.png", "id": "244277984396844", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974598_244277987730177_6159679590959644567_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pKPpgqj3yEAQ7kNvgFlOxza&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBOXrh3vCAzMVbQ9AWIf6g3-9DRvy7xjXbrOuIPny3sA&oe=66FFDC7A"}]}, "id": "463105929602855", "locale": "en_US", "screenshots": [{"file_name": "GunJitsu_Screenshot_1.png", "id": "260782252516995", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982697_260782255850328_5084442595581820356_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XMNqifvNLpwQ7kNvgF2dE1o&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbCJ2TZVSETEPjirrzJu1HPjinsMHWuQHFyRMGJFf1RA&oe=66FFC294"}, {"file_name": "GunJitsu_Screenshot_2.png", "id": "620338102668749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_620338106002082_282661273207928436_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v6CTIS1J-yoQ7kNvgGrbVGT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHZzTLNVGDDMRAZiNzd85lemdK4-V1nnLMx4GMGNef0Q&oe=66FFEED3"}, {"file_name": "GunJitsu_Screenshot_5.png", "id": "408220474212174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974766_408220477545507_4507206763881336195_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BSooti_s7_wQ7kNvgHfx_sn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDktcwhGsAwXTTeFqqHXhb6hi0530KIuOkUJ8gW-M-lrg&oe=66FFD789"}, {"file_name": "GunJitsu_Screenshot_4.png", "id": "385455932967464", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001673_385455936300797_7786371991393010935_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QhLa2JVoPs4Q7kNvgHCdRVO&_nc_ht=scontent.oculuscdn.com&oh=00_AYAS1n3R988kCltVaVQTdUPRJiZqpVN2fVZ4e_Vei0koiw&oe=66FFC93A"}, {"file_name": "GunJitsu_Screenshot_7.png", "id": "867514127465859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974511_867514130799192_909843452170294806_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gYLSlkssD_sQ7kNvgFEBtLF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhWeHSI84eBEGk_8seZuPrA9XEcUJY1Ct3CbdV9TZoIA&oe=66FFCAF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FluxBall Main Graphic 2.png", "id": "387248966427000", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_387248969760333_3966639532335732948_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2vziBjLdTsYQ7kNvgGCuDHi&_nc_ht=scontent.oculuscdn.com&oh=00_AYCez2XYFWuPidyso8xbkFIEY4wfxqqrE4TdqwHxPZQ6aA&oe=66FFDC29"}, "display_name": "Flux Ball", "keywords": [], "long_description": "Why stop with pivots and squats?  Flux Ball pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a liquid container, drowning those who fall too far down.  Flux Ball is best played on fitness mats and/or a rug.  Come test your Flux Ball skills...", "short_description": "You have a glove on your left hand and pistol in your right hand...Flux Ball is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Flux Ball combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Flux Ball champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/fluxballprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Scrimage Entertainment, LLC", "support_website_url": null, "website_url": "https://liftedline.tumblr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_conne