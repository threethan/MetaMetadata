t_4.png", "id": "543034060423177", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_543034063756510_2669844710469119593_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pM24e8orPqUQ7kNvgGYmXhE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF0Pe8Ke2lEREENFbhuWlUp&oh=00_AYBD4oYkCZVRJrZT6kqVqPVupDdoNO2qvBui_0FmEHO2lQ&oe=66E18525"}, {"file_name": "GunJitsu_Screenshot_5.png", "id": "858720074723984", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031493_858720078057317_327362154166650108_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TsinTMvQGz8Q7kNvgHGByBg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF0Pe8Ke2lEREENFbhuWlUp&oh=00_AYA2I4rumntHm6XMq9HB00hyyX2rufKZbF1xuFab_sdoFQ&oe=66E17ADB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DevelopmentPage_Graphics_Landscape.png", "id": "602863867340357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974630_602863870673690_3287891887603076943_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3UN_ZbaP3vQQ7kNvgHHHNTT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF0Pe8Ke2lEREENFbhuWlUp&oh=00_AYC03ECHCcvOK1kQ6i_-i_IGWswc2B9g229_W5pcPbtK4w&oe=66E17E5E"}, "display_name": "Gun Jitsu", "keywords": [], "long_description": "Why stop with pivots and squats?  GUN JITSU pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a garbage compactor, crushing those who fall too far down.  Gun Jitsu is best played on fitness mats and/or a rug.  Come test your Gun Jitsu skills...", "short_description": "Gun Jitsu is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Gun Jitsu combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Gun Jitsu champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lifted-line.com/gunjitsuprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Lifted Line, LLC", "support_website_url": null, "website_url": "https://www.lifted-line.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD_VIA_TOUCH"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "766669984298989"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "379509253566476"}, {"status": "PUBLISHED", "id": "807333126642049"}, {"status": "PUBLISHED", "id": "1172042106630892"}]}, "baseline_offer": {"id": "379509253566476"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1629484140, "status": "PUBLISHED", "id": "379509253566476"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5276571719093897", "version": "1.0"}, "id": "126979572618272", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3684232281661190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5276571719093897"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "126979572618272"}]}, "change_log": "main obb upload", "created_date": 1658497715, "id": "5276571719093897", "version": "1.0", "version_code":