MjRQQ7kNvgHT3koP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCoJG65Ucj-Gra_MIB5SlBnuNVOhak9XrOgLCqch6kWfw&oe=6762A9BA"}, {"file_name": "GunJitsu_Screenshot_7.png", "id": "867514127465859", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974511_867514130799192_909843452170294806_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2KN70EWHH0Q7kNvgHaNoWU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAr5B_T8yiFlSP66-xtrFSv_P0Qrwvrqgqoq_g0mQ2vbA&oe=6762AB73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FluxBall Main Graphic 2.png", "id": "387248966427000", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003280_387248969760333_3966639532335732948_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rg1U4zsbbDUQ7kNvgHsLMWf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqphVoi3uQlz2FehC9oVYA4qJp2DICkqUaoXOZ5D3jNg&oe=6762BCA9"}, "display_name": "Flux Ball", "keywords": [], "long_description": "Why stop with pivots and squats?  Flux Ball pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a liquid container, drowning those who fall too far down.  Flux Ball is best played on fitness mats and/or a rug.  Come test your Flux Ball skills...", "short_description": "You have a glove on your left hand and pistol in your right hand...Flux Ball is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Flux Ball combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Flux Ball champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/fluxballprivacypolicy", "developer_terms_of_service_url": null, "publishe