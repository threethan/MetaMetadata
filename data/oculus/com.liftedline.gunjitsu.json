Ball Banner 2.png", "id": "244277984396844", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974598_244277987730177_6159679590959644567_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VxHtejWEL-QQ7kNvgFBqkv8&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7LbxkB0V9MFbKdf-oV2G5xKodLbccO2xL1rEBjxma8A&oe=66F944FA"}]}, "id": "463105929602855", "locale": "en_US", "screenshots": [{"file_name": "GunJitsu_Screenshot_1.png", "id": "260782252516995", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982697_260782255850328_5084442595581820356_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WU9mg0vyZQEQ7kNvgFWApWd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC_HcnHNO0IAlfNjn6U8zkP48FgHpJbW_nHOAEnF87Sw&oe=66F92B14"}, {"file_name": "GunJitsu_Screenshot_2.png", "id": "620338102668749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982459_620338106002082_282661273207928436_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N0_wDVf_7j4Q7kNvgGg191e&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoEdbb5nX1tDWEbyxwu8DA2iNhoKg7_B2kyyXoIKTa7A&oe=66F95753"}, {"file_name": "GunJitsu_Screenshot_5.png", "id": "408220474212174", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974766_408220477545507_4507206763881336195_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IdPqhXeyk3UQ7kNvgHVbF9g&_nc_ht=scontent.oculuscdn.com&oh=00_AYCck53WS97R4NjhYIofvJfT9nNo8Q2vE2VT2ZCERwKjsg&oe=66F94009"}, {"file_name": "GunJitsu_Screenshot_4.png", "id": "385455932967464", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001673_385455936300797_7786371991393010935_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tPrn0dVw8P4Q7kNvgGRgvwN&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQ0bIexALlEy1d2JTbikWAPBub1MeMtLQzQE37zpWrow&oe=66F931BA"}, {"file_name": "GunJitsu_Screenshot_7.png", "id": "867514127465859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974511_867514130799192_909843452170294806_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uUY3jGpq464Q7kNvgH_3oXY&_nc_ht=scontent.oculuscdn.com&oh=00_AYARa6bORHZ7wN1giiW6buXRes-xdiS3otgkpjG_5Oux4w&oe=66F93373"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FluxBall Main Graphic 2.png", "id": "387248966427000", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003280_387248969760333_3966639532335732948_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9X10tghpKgQ7kNvgEdFHKz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAppvHZA0zSP9-A91PHIRTpBO2KApo4K6XLtdtqrvFfxg&oe=66F944A9"}, "display_name": "Flux Ball", "keywords": [], "long_description": "Why stop with pivots and squats?  Flux Ball pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a liquid container, drowning those who fall too far down.  Flux Ball is best played on fitness mats and/or a rug.  Come test your Flux Ball skills...", "short_description": "You have a glove on your left hand and pistol in your right hand...Flux Ball is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Flux Ball combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Flux Ball champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/fluxballprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Scrimage Entertainment, LLC", "support_website_url": null, "website_url": "https://liftedline.tumblr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_conne