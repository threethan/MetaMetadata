LxW0Q7kNvgHUBIsx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB-yMxhah4k9BSSnMmP43jvn2RD9UdlLN4qXBktkEzKqg&oe=675D63BA"}, {"file_name": "GunJitsu_Screenshot_7.png", "id": "867514127465859", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974511_867514130799192_909843452170294806_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SbvJ3Y-Mv34Q7kNvgG9sm6z&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDP3xSPcjMZc6_Gno_F2yMmlphsrOkggQ8CZe3gAN9VPg&oe=675D6573"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FluxBall Main Graphic 2.png", "id": "387248966427000", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003280_387248969760333_3966639532335732948_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j7SIVWzhpDwQ7kNvgFo7RRw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDlQaYZZD2DQiLhdbzpbhQsUKGpc6_pyHeJVL5cMHzl7Q&oe=675D76A9"}, "display_name": "Flux Ball", "keywords": [], "long_description": "Why stop with pivots and squats?  Flux Ball pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a liquid container, drowning those who fall too far down.  Flux Ball is best played on fitness mats and/or a rug.  Come test your Flux Ball skills...", "short_description": "You have a glove on your left hand and pistol in your right hand...Flux Ball is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Flux Ball combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Flux Ball champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://liftedline.tumblr.com/fluxballprivacypolicy", "developer_terms_of_service_url": null, "publishe