974827_543034063756510_2669844710469119593_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8zS04DnbcZYQ7kNvgFu1QM5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLQwXQzdbabPUxsw58l4LAJyjofcdIB-J_TpoXcyxV9w&oe=671CD8A5"}, {"file_name": "GunJitsu_Screenshot_5.png", "id": "858720074723984", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031493_858720078057317_327362154166650108_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6YaNVRArx88Q7kNvgFhiB-L&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3uw65bQBtWPpzvYY-H5uCFK3clT-KxddXhO0UEU_ZWA&oe=671CCE5B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DevelopmentPage_Graphics_Landscape.png", "id": "602863867340357", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974630_602863870673690_3287891887603076943_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ByTHXE5NwoUQ7kNvgEDTHMN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeJCeISM-7eqBw3fvFMQ1z2mNyxuZD7eA9TCpswpJ6dg&oe=671CD1DE"}, "display_name": "Gun Jitsu", "keywords": [], "long_description": "Why stop with pivots and squats?  GUN JITSU pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a garbage compactor, crushing those who fall too far down.  Gun Jitsu is best played on fitness mats and/or a rug.  Come test your Gun Jitsu skills...", "short_description": "Gun Jitsu is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Gun Jitsu combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Gun Jitsu champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lifted-line.com/gunjitsuprivacypolicy", "develo