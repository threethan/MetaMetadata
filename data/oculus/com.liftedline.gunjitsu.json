5771-25/39031493_858720078057317_327362154166650108_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=En9AeDG_wksQ7kNvgE9_C2L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPsU1AKXf32gFa_zf2pW4hSAIiFIuoIOoHVcr3H-Gq8Q&oe=670664DB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DevelopmentPage_Graphics_Landscape.png", "id": "602863867340357", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974630_602863870673690_3287891887603076943_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2A7QbHWRoYQ7kNvgHzo0al&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA26jMbbQOkX_P29U2fO0pw3wFItcRCPNTlqCPe3ptl8g&oe=6706685E"}, "display_name": "Gun Jitsu", "keywords": [], "long_description": "Why stop with pivots and squats?  GUN JITSU pressures the player to lie flat and tumble out of sticky situations, constantly moving between standing, crouching and prone positions.  Engage in a close quarters shoot out using your Guard Cage for protection from enemy fire.  When struck, your cage will be lowered into a garbage compactor, crushing those who fall too far down.  Gun Jitsu is best played on fitness mats and/or a rug.  Come test your Gun Jitsu skills...", "short_description": "Gun Jitsu is a competitive shooting game which requires players to dodge, squat and lie down to avoid enemy fire.  Gun Jitsu combines ground martial arts like Jiu Jitsu with VR sharp shooting.  Grab some fitness mats or your nearest rug and begin your journey to become the Gun Jitsu champion of the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.lifted-line.com/gunjitsuprivacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Lifted Line, LLC", "support_website_url": null, "website_url": "https://www.lifted-line.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "gen