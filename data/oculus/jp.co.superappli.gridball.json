 action. Combine numerous PERKs and devise your own strategy to protect the GRID from the invading BITs!\nLeaderboards are also included, aim for the 1st place in the rankings!\n\n\u3010ONE BALL\u3011\nUpdated visuals!\nDestroy all BITs in a grid as efficiently as possib"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.super-appli.co.jp/en/privacypolicy", "developer_terms_of_service_url": "https://www.super-appli.co.jp/en/termsofuse", "publisher_name": "SuperAppli Inc", "support_website_url": null, "website_url": "https://www.super-appli.co.jp/en/grid-ball", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "522914945856883"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035420_661140004824862_6226830565877973771_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UVdsEb-OEJQQ7kNvgFUaaM0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAKCgVjx9TDLKTbpvQhF1MS8OJMbA_ttrvZUxYN17BSzg&oe=6718DDF4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Grid Ball", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1635174000, "lastRevision": {"nodes": [{"id": "115022864148708", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"defau