png", "id": "510436073534081", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974654_510436076867414_6917383956735567478_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FPCpkRiU20sQ7kNvgF1-fb9&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBtK74tVlWOMEPZc6yZu9J0LvDwEwfz-tIzbb67CAk9FQ&oe=675EA77C"}, {"file_name": "HRDVR21_OculusQuest_Screenshots_2.png", "id": "1477736362619176", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974778_1477736365952509_4739087624588915067_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wCTntILwB5QQ7kNvgGFGMU5&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYB41gzsDLw8KzDfeu81b7d4_uP_BHywrybJC-XH5eRM6A&oe=675EDB85"}, {"file_name": "HRDVR21_OculusQuest_Screenshots_5.png", "id": "1021772251951979", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982637_1021772255285312_372300276559789197_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MR_u2jTNNTYQ7kNvgE8TnAX&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYB0h469o3Vp7IswrZDPxAHm3_yTDguUsiAIJohlKtJc_Q&oe=675EB4E9"}, {"file_name": "HRDVR21_OculusQuest_Screenshots_3.png", "id": "181132487322314", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39003256_181132490655647_1924791396398911867_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJ0x5kPQTn0Q7kNvgEfE4Ze&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD976FvHRi46V_s7AvIbvCvObnRQhyxdjEFRcKVRTDLhA&oe=675EA8FC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MLB Home Run Derby VR!", "keywords": [], "long_description": "Step up to the plate and crush it in the most immersive and authentic Home Run Derby VR game presented by Major League Baseball!\n \nFEEL THE ACTION!\nGOING, GOING, GONE! Hit home runs and rack up points in a timed home run competition. The motion based controls let you feel the speed and power of every swing at the plate. Choose between righty/lefty and multiple difficulty settings.\n \nPLAY IN OFFICIAL MLB BALLPARKS!\n25 new ballparks added in 2021! Crush homers in ballparks across MLB! Unique leaderboards for every ballpark means you have a lot of ways to claim the top spot. \n\nHIGH FIDELITY GRAPHICS!\nThe competition comes alive in our unparalleled 3D environments. New for 2021 -- experience stepping up to the plate in 25 new ballparks in high fidelity graphics. \n \nBEAT THE BEST!\nTag multipliers and hit it deep to climb to the top of the leaderboards and prove you are the ultimate Home Run Derby champion!", "short_description": "HOME RUN! Step into the diamond and crush it in the most immersive Home Run Derby VR game to date, presented by Major League Baseball. Feel the action and power of every swing with motion based controls.  Swing for the fences in the most authentic virtual reality MLB ballparks ever created."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.mlb.com/official-information/privacy-policy", "developer_terms_of_service_url": "https://www.mlb.com/official-information/terms-of-use", "publisher_name": "MLB", "support_website_url": "https://securea.mlb.com/mobile/gamingcs/index.jsp", "website_url": "https://www.mlb.com/fantasy/home-run-derby-vr/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SPORTS", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1150907709014505"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PENDIN