anies this idyllic journey, where the world slows down, and peace reigns.", "short_description": "Relax yourself in a virtual reality tour across a gentle mountain river"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.polyrawdevelopment.com/Policy.html", "developer_terms_of_service_url": null, "publisher_name": "PolyrawDevelopment", "support_website_url": null, "website_url": "https://www.polyrawdevelopment.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "687057922013375"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1241637220103230"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982674_284401375511883_108529846430203904_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f1R8SZSkbfYQ7kNvgHfxVAa&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAClEgGaQ9s0vZWMQ7NDe3dW-vW57wjEEe4RNM-lqMhHQ&oe=670FBEE0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RelaxRiver", "platform": "ANDROID", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Nature", "id": "687057922013375"}], "release_date": 1502902800, "lastRevision": {"nodes": [{"id": "1824846827826524", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id