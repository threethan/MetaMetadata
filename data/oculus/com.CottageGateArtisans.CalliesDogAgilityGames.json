n.com/v/t64.5771-25/75307248_562157059275348_2956675218899554246_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KSOjIAkiutoQ7kNvgH7jTH7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwDtF2F_4vvq0pPAaKAPdr6NsDahGmovmVOq-DpUTvbA&oe=671CDB80"}, {"file_name": "screenshot_2.png", "id": "250426577530661", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035449_250426580863994_8331402531073700115_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VbRt1h8sxUYQ7kNvgHpOjDO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAK50AOjpS0KX5Svbtw0uXRkpP0Ma-EdM1IZ1LcSa_AZQ&oe=671CCD11"}, {"file_name": "image_005_3000.png", "id": "3518339268451184", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_3518339271784517_6182602566968493729_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KBU18aGaICUQ7kNvgHGrsQP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAyKYHhnbfp_P9BtqGYOf_elPj2jRK5sNZYdfOxHeQBg&oe=671CD6B1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "night_2560 x 1440.png", "id": "545498841114982", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75481473_545498844448315_7405858449675253485_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F3f0L5Z9K9MQ7kNvgEFhL5E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSsz3uB6kxs7iQvEo-R4u_QVZGc1Ys_vDX_FuXAj3-Lw&oe=671CCB57"}, "display_name": "Callie's Canine Agility Challenges", "keywords": [], "long_description": "Experience the fun of running an agility course as the dog. Jump over jumps, run through tunnels, climb high on an A-frame, walk the narrow dogwalk and follow the increasingly complex obstacles and courses. Try your best to weave through the weave poles or jump the broad jump. Get a bird's eye view from the viewing stands. Start the timer when you begin and see how quickly you can complete the course. Or you can make up your own sequences using the obstacles on the fields. \n\nThere are now four courses to try, some easier, some more difficult. No violence, no fighting, good for family fun. More courses to follow in future releases.", "short_description": "Have you ever watched dog agility competitions on TV? Did you want to know how it feels to run through an agility course and jump over jumps, run through tunnels, climb over A-frames, weave the weave poles or walk the dogwalk? \n\nHere is your chance. See the courses through the dog's eyes and experience the fun of running through a number of obstacle courses. Challenge yourself to be faster with each run as you follow the sequences through the fields or gym."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cottagegateartisans.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "CottageGateArtisans", "support_website_url": null, "website_url": "https://cottagegateartisans.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "541761888132256"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "558428146406453"}]}, "baseline_offer": {"id": "558428146406453"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1686958357, "status": "PUBLISHED", "id": "558428146406453"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "63951285138