/t64.5771-25/38974873_3518339271784517_6182602566968493729_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9e1FATk6ZvwQ7kNvgFGY8z3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBO2unHbTaPk8-WBQewNQ3bvu49RwyMuMTZmS-g0XPPpw&oe=66D1B131"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "night_2560 x 1440.png", "id": "545498841114982", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75481473_545498844448315_7405858449675253485_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WOeQcBLUbLUQ7kNvgEamGL1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWJDN48QXz911dpMwj5Mk5l_2pEjig8bzzaNr3DIDhWA&oe=66D1A5D7"}, "display_name": "Callie's Canine Agility Challenges", "keywords": [], "long_description": "Experience the fun of running an agility course as the dog. Jump over jumps, run through tunnels, climb high on an A-frame, walk the narrow dogwalk and follow the increasingly complex obstacles and courses. Try your best to weave through the weave poles or jump the broad jump. Get a bird's eye view from the viewing stands. Start the timer when you begin and see how quickly you can complete the course. Or you can make up your own sequences using the obstacles on the fields. \n\nThere are now four courses to try, some easier, some more difficult. No violence, no fighting, good for family fun. More courses to follow in future releases.", "short_description": "Have you ever watched dog agility competitions on TV? Did you want to know how it feels to run through an agility course and jump over jumps, run through tunnels, climb over A-frames, weave the weave poles or walk the dogwalk? \n\nHere is your chance. See the courses through the dog's eyes and experience the fun of running through a number of obstacle courses. Challenge yourself to be faster with each run as you follow the sequences through the fields or gym."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cottagegateartisans.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name