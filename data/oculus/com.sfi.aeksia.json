_ohc=uBHaKU_u0xMQ7kNvgGAOQ4v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC50mdBsQ6NS-srWldHLqP7qSjJ4hbdLJyhdRjYiQOaTg&oe=67614A5E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot-4.png", "id": "1187310485594879", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223486_1187310488928212_3586454318052687755_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5zodTUOYXokQ7kNvgFhvC0t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDGt6V6P0X7u5w2LRxM7JqQg6xMd0SvrKIegAqJVc6kg&oe=676158E4"}, "display_name": "Aexia", "keywords": [], "long_description": "Aexia is a platform for creating, sharing, and playing VR role-playing games. In Aexia, players can role-play as actual actors in a movie set.\n\nStep into the role and experience thoughtfully crafted worlds, participate in compelling narratives, and interact with a wide array of characters, while game masters (GMs) guide these stories within the expansive VR environment.\n\nWe are in early access. Join our Discord community to find roleplayers and game masters to join you in Aexia: https://discord.gg/STsWt7BXFV\n\nHere's a quickstart guide on how to create and share a game with a friend: https://youtu.be/Ho0gELmwkRU?si=PZ6JvUA8oogao1-c", "short_description": "Aexia is a platform for creating, sharing and playing VR role-playing games. With Aexia, players can role-play as actual actors in a movie set.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.strawberryfields.ca/privacy-policy-1", "developer_terms_of_service_url": null, "publisher_name": "Strawberry Fields Interactive", "support_website_url": null, "website_url": "https://aexia.ca/", "category": "APPS", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["RPG", "SOCIAL"], "has_in_app_ads": null, "intern