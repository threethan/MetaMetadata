yle, Spanish, & more. Change your service online anytime."}]}, "developer_name": "Sling TV, LLC", "developer_privacy_policy_url": "https://www.sling.com/offer-details/disclaimers/privacy-policy", "developer_terms_of_service_url": "https://www.sling.com/offer-details/disclaimers/terms-of-use", "publisher_name": "Sling TV, LLC", "support_website_url": null, "website_url": "https://www.sling.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED", "genres": ["MOVIE", "NEWS_AND_INFORMATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_EX"], "id": "5196024393755085"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974609_695765217470338_3934964825171427328_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cinmOf0eSYIQ7kNvgHxn7tD&_nc_ht=scontent.oculuscdn.com&oh=00_AYAb14deQRlbG0KBd8CrTt31NV5ZChmVJT2NvSlAi4raOA&oe=66DED4E2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sling TV", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1545069600, "lastRevision": {"nodes": [{"id": "290244948265759", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2412412708773095", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "381048652437695"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {