_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WK_0UR-l1fEQ7kNvgHKYSGo&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBpJOs-kcKsvFmHEMiqqbMhaXTokhMN5qasgrE8YnEqRQ&oe=67601429"}, {"file_name": "CaveDigger2_EarlyAccess_AppLab_Screenshot_2560x1440_3.png", "id": "1286429361833298", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/57569471_1286429365166631_5325321180725559216_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dc5G_ApeLBcQ7kNvgFn_PCa&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCuLLP6RXvXuexX0yvRY6ITnRe-DEYB67y9M_I-WlSpbw&oe=675FFC7A"}, {"file_name": "CaveDigger2_EarlyAccess_AppLab_Screenshot_2560x1440_1.png", "id": "454775166360011", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031498_454775169693344_31583402968538251_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UA8_1c52lD4Q7kNvgFzx2yb&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCAe_pUGCRMhBSb-5HQBDKVyof4M0lg3Oc7OFaHInkT5w&oe=6760280C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CaveDigger2_EarlyAccess_AppLab_Trailer Cover Image_2560x1440.png", "id": "1063060227849831", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031316_1063060231183164_159257958263301126_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e6Y5XJuo0SQQ7kNvgGATmKc&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAKK55Oq6oLWmnN2U-7viezveeUIny4VULRM_9ZSwdhQg&oe=67600F90"}, "display_name": "Cave Digger 2: Dig Harder", "keywords": [], "long_description": "Early Access\n\nA VR adventure game taking place in an alternative, weird west dieselpunk world. The player is a penniless but adventurous prospector in the wild northern region known only as \u201cThe New Frontier\u201d. As the player excavates the mountains of their claim, they encounter many mysteries along the way as they mine and fight their way through various unique biomes.\n\nChoose the right tools for the job from a collection of mining equipment on the surface. Exchange your loot for money to upgrade your gear. The upgrades will make your tools more effective, for both prospecting and combat.\n\nEarly Access features:\n- Mining, looting, capitalizing\n- Tool and weapon upgrades\n- Exploration in procedurally generated levels\n- Close-quarters combat\n- Co-op multiplayer\n- Character customization", "short_description": "Cave Digger 2: Dig Harder is a VR adventure game for 1-4 players, taking place in an alternative, weird west dieselpunk world. The player excavates the mountains of their claim, and encounters many mysteries along the way. The North is cold and the Frontier guards its secrets well!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mekiwi", "support_website_url": null, "website_url": "https://vrkiwi.org/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ACTION", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "2994820037408435"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "1241395833751760"}, {"status": "PUBLISHED", "id": "865447945215790"}, {"status": "CANCELLED", "id": "3714428412129167"}, {"status": "CANCELLED", "id": "467812149540975"}, {"status": "CANCELLED", "id": "879031374280577"}, {"status": "PUBLISHED", "id": "1025103112480928"}, {"status": "PUBLISHED", "id