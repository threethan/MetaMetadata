593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FBgFixgg6wYQ7kNvgEXVhaU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAADAaa-7chWab3cThwxuLSEfwhd7Qj7gwnuo_S2i9i6Q&oe=677A5F02"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YdO7LN2KrgIQ7kNvgHsMYG8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdAuDAyx70hsuQIpkZ_WqoVKOSkqLXFxpbK267XQnsaQ&oe=677A7F69"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-zdHuzD-E0Q7kNvgH3ZTFO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJksVd5_U8pg6s1eHrpG3bpBrj38wNAKJHgYpZA5d6ZQ&oe=677A7931"}, {"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gc9UAJjqh5AQ7kNvgEjP41k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0YceZQi1wZQSTrQwoZWV52MgOclMt4dzHt_iY-30uaw&oe=677A644E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush", "keywords": [], "long_description": "Open Brush is a derivative made from the open source code of Tilt Brush, a room-scale 3D-painting virtual-reality application available from Google, originally developed by Skillman & Hackett.\n\nOpen Brush lets you paint in 3D space with virtual reality. \n\nUnleash your creativity with three-dimensional brush strokes, choosing from a wide palette, of brushes, including stars, light, and even fire. Your room is your canvas. Your palette is your imagination.\n\nThe possibilities are endless.\n\nA huge thank you to the Tilt Brush team and Google for making this open source, especially Patrick Hackett!", "short_description": "A Tilt Brush derivative for free on Oculus Quest! Enjoy making awesome art in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.openbrush.org/privacy-policy-page", "developer_terms_of_service_url": null, "publisher_name": "Icosa Gallery", "support_website_url": "https://discord.icosa.gallery/", "website_url": "https://www.openbrush.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "215917727416463"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "879363140746945"}, {"status": "PUBLISHED", "id": "404326110906838"}]}, "baseline_offer": {"id": "879363140746945"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1735425780, "status": "PUBLISHED", "id": "879363140746945"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8078049858929929", "version": "2.9.0"}, "id": "2010012175808324", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3600360710032222", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8078049858929929"}, "release_status": "RELEASED"}, "binary_release_channels