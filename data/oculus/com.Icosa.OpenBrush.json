, "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RSY4axHNEpAQ7kNvgF_4j8W&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXI5OZLFBlpzcDc1PP0FHQMMj6m06BgTt_1HjtAytslA&oe=66D84AC2"}]}, "id": "1687189822069498", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j-wkVxUXdsYQ7kNvgEc5u1z&_nc_ht=scontent.oculuscdn.com&oh=00_AYAim7uFKmkZp_VeIifq0p-4w_ijpCeAvkHJ2Zj8M378kA&oe=66D83BCE"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bwDi44pta2UQ7kNvgFwNcLf&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIM7fiINhPYEOIofGOuXBzW6v4czRtHlE64VXU105OdA&oe=66D83682"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UZn77agBqHAQ7kNvgGoHcoh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCuQrCxEobWzPokJvu8LVi64aULg1PryuFqz0LHw6iQwQ&oe=66D850B1"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NHMFN8n9OpYQ7kNvgHsRGT7&_nc_ht=scontent.oculuscdn.com&oh=00_AYACz3lgFMAfXLVm9ckJ3PGaqOlRQbzfI8StfmIFFV3M8g&oe=66D85749"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uI7dqi9r6vIQ7kNvgFTKY82&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmyqVL7NrXLbgySD5BharyoA5hQ9mqFtlJ9Ye6KZYS1w&oe=66D856E9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush - 3D Painting", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your art from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.openbrush.app/", "website_url": "https://openbrush.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "inter