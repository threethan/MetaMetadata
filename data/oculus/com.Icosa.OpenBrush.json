hOIZnuO7-pcy_t9GzQCwQ&oe=6703C25A"}, {"file_name": "Open Brush Logo Color.png", "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BeI4G6Z5wJUQ7kNvgGE6X8z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDn5JfSu1g2ao6M4ZW3ISw-Dl-eP9lJoc-ft1vyWNZUmQ&oe=6703CC42"}]}, "id": "1687189822069498", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Vqj753Oa1oQ7kNvgFdTnBp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBsE_QA8hZXb3VoqAVK54VxMw3327NslbCyh0JIpZcZBQ&oe=6703BD4E"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-1mgo_sX_1UQ7kNvgEYCxt9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4MByP-wHHi5AvUCGasZhuUFywZHHyQgcMSzAxqWSuPw&oe=6703B802"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7SdKshgVqH8Q7kNvgEa3Me4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-f7LFVgu5P85h1nWClF8DBz7P_QLoNwV-7dydveicTw&oe=6703D231"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TvpePhNxIFcQ7kNvgGlgPXD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9ydR5fVYwpiRSWGnY0LJqrl_utDFDg0A-v3Z6vNlPXg&oe=6703D8C9"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nN-hC5OcDJkQ7kNvgGV_Ltm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb9_uL0x4tNkMrOtF9mRWbsDkpb2vQtFtpOx-ZQiQ1sw&oe=6703D869"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush - 3D Painting", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your art from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.openbrush.app/", "website_url": "https://openbrush.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "c