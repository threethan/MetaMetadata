t-xsp1-1.oculuscdn.com&oh=00_AYBSD0qUUkta-0NDwrP9dOteeJ4CDIQevvfNOKvgNKp6KA&oe=671A2BDA"}, {"file_name": "Open Brush Logo Color.png", "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vLl_-DYJKf0Q7kNvgFoIvYf&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBS40zby7EPyNj6OLW8pKVG6wv7EZvv9vrpSw2MOKuxSQ&oe=671A35C2"}]}, "id": "1687189822069498", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7QF4dFzE88Q7kNvgEKb_H-&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCRMf9je8LCFtcCqNaMB24BG6JQ2IQ1G8acmqAageXJAg&oe=671A26CE"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JO60MePtTzsQ7kNvgGqBsmJ&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAB4SVL6Anklg7eydcEDiZold2I5AQwU0CKH-9JZIfUqQ&oe=671A2182"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9g2lI7z1ccQQ7kNvgEQ6ABt&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCX_NcZ9njdNlaPSi2hbvmWG3HTfaCfVl2oYCkSRGVmCA&oe=671A3BB1"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CNf0-EOjD4YQ7kNvgE-gu6J&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAV43ryPcBNuO9TWUuJ67o0u9fXA54oSe3Z3rhtujUxZw&oe=671A4249"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TQVkn3IjX7wQ7kNvgELn-Xo&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYChasuc_FlnqZ5CIkiAQoPtNp5Hhy_e_xr4nZ4s8EdgtQ&oe=671A41E9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush - 3D Painting", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your art from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.openbrush.app/", "website_url": "https://openbrush.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_