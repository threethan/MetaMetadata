, "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6eJ5Sgj2UQQ7kNvgHdY1Ha&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGaeuXP-8g6lPuC3jiX-nkE16An8jshkqnq9CeYFq6HQ&oe=66E2D6C2"}]}, "id": "1687189822069498", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XhVIRRfXdw4Q7kNvgGMJgVX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvfmLZPhpXS7GYR5MQBxBKUa_rxYFNuGE3Qw7yl5_fjA&oe=66E2C7CE"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9VBqUvfGG9QQ7kNvgEt9iVX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEnVjzq6BsUdUz7faCkrX-dqAg_Wu5qDEEHRGiciz-vQ&oe=66E2C282"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-qb3F7teKBkQ7kNvgFYp32B&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJ68A5PTuFP0oX2uUhoBmkxY9TjNP7cGtLlTSvX1vSzw&oe=66E2DCB1"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xmw-GXz8kwsQ7kNvgEWc9FP&_nc_ht=scontent.oculuscdn.com&oh=00_AYB50PIbit8ls3po3nvfo10M0VDuhu6e2_yBKN5qxiLGQQ&oe=66E2E349"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzCQHXRxMWcQ7kNvgH4kB4G&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkvMNWhKgJLlyAWH7fvffbo7AmWuzUj4R3PsOz5xwnrQ&oe=66E2E2E9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush - 3D Painting", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your art from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.openbrush.app/", "website_url": "https://openbrush.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "inter