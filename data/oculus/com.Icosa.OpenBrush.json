1387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o7hnaJjd5QUQ7kNvgEiDTGB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARN2U5CHU-jjm-ci6RsVduY&oh=00_AYCJn2DzXpFd5mhsWGuDMrGjUON-SEcCmYXa-5Uc61lhFA&oe=66EC1731"}, {"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lvbn5dIg4lEQ7kNvgHyiKJK&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARN2U5CHU-jjm-ci6RsVduY&oh=00_AYBXAkilVsXRVqkbdXMHgx4RzQUABlvkrEh3QGQ2xUe9iQ&oe=66EC024E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush", "keywords": [], "long_description": "Open Brush is a derivative made from the open source code of Tilt Brush, a room-scale 3D-painting virtual-reality application available from Google, originally developed by Skillman & Hackett.\n\nOpen Brush lets you paint in 3D space with virtual reality. \n\nUnleash your creativity with three-dimensional brush strokes, choosing from a wide palette, of brushes, including stars, light, and even fire. Your room is your canvas. Your palette is your imagination.\n\nThe possibilities are endless.\n\nA huge thank you to the Tilt Brush team and Google for making this open source, especially Patrick Hackett!", "short_description": "A Tilt Brush derivative for free on Oculus Quest! Enjoy making awesome art in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.openbrush.org/privacy-policy-page", "developer_terms_of_service_url": null, "publisher_name": "Icosa Gallery", "support_website_url": "https://discord.icosa.gallery/", "website_url": "https://www.openbrush.org/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MO