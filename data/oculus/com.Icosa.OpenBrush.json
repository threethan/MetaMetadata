FQQ7kNvgFvyNkJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYBuaPhA8y4VN3YQ41SyEdTrilsP3sekofKrJcnwwmr0aA&oe=66F3F05A"}, {"file_name": "Open Brush Logo Color.png", "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HQAtF1klL_YQ7kNvgEJg9nS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYAO_qp8BtSv8TcRhuIJXW-fH0IpZa3C2ffD1wvRMrUioA&oe=66F3FA42"}]}, "id": "1687189822069498", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=91XlHjQsDG0Q7kNvgGT-pe1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYAkpGR4BGWNehcaQefPlfiLzS8DXS8HawsJ3lqkUcwo_A&oe=66F3EB4E"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vdGdw6u45FQQ7kNvgGlvViB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYCxQrHsFFK0EL-q8hu8NwjtRccOM-8DLLRVFtdW1wW80Q&oe=66F3E602"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XmHlE8MbFesQ7kNvgEWnop5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYAiR3Kfq8PqDiHdJxUO-pFKwsVdUT8Ad3FJbC__hm7RhQ&oe=66F40031"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4PN0Iit7BOEQ7kNvgH5hfi-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYC8l51G1SZe9zfVpiORC46xt3m_WPDLL6YuRAOedStI1g&oe=66F406C9"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nx3j4F3rXB4Q7kNvgHTBx7l&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAlC4UL1udHV5BD5wQo_-Hr&oh=00_AYCzNqKMwnmetFtjnTtYg7xbJ1M2TR1YlMuEsHUgLgJgmQ&oe=66F40669"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush - 3D Painting", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your art from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.o