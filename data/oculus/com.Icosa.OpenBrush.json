, "id": "369828895507830", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_369828905507829_5274956890955372561_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QynCnaMEYmAQ7kNvgFxB4Tr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpCPsL15mh-c0pdaRy-sdcc9Acejz4MdSnViKid1olwQ&oe=66D304C2"}]}, "id": "1550161522583022", "locale": "en_US", "screenshots": [{"file_name": "screenshot5.png", "id": "2821407844790496", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031585_2821407848123829_3224853210786065950_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fPVuFLAxDooQ7kNvgHY-G2b&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuSoxv2VB75x_XtKyTZIV0IIlSAyy8FH1-oLpXeAGrYA&oe=66D2F5CE"}, {"file_name": "screenshot2.png", "id": "479558133229510", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_479558136562843_7987833068602593533_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lTx1fZULZm4Q7kNvgHbA1IX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAa0Aj8Y9-3bWuO95so7oYkvCTfe1owsDRs5sMxnFG_ug&oe=66D2F082"}, {"file_name": "screenshot4.png", "id": "274826374249566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_274826377582899_1841387916013093121_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7cDM7Nd4ZpoQ7kNvgEKU8Cw&_nc_ht=scontent.oculuscdn.com&oh=00_AYANUrGYz0vyXeDZWN95uyx6D6AKuim9dQScGCK6c2T5aQ&oe=66D30AB1"}, {"file_name": "screenshot1.png", "id": "260518315614856", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_260518318948189_226943859161597011_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R6qDpFjP0Y8Q7kNvgEgmx0j&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPgPWqLpl4a9aR8s7_hv0y5VeJdfJhUuI3YmQoOgedZw&oe=66D31149"}, {"file_name": "screenshot3.png", "id": "247636483752807", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_247636487086140_5819658012213053062_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F3qq3lGs8x8Q7kNvgFesrxp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCx1HNUfvYDucK8iEJpOmdDJPg4_VZWw0vg15832F166g&oe=66D310E9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Open Brush", "keywords": ["Art", "Paint", "Creative", "Tilt", "Productivity"], "long_description": "Open Brush allows you to paint in 3D space with XR. Unleash your creativity with three-dimensional brush strokes. Your canvas is open around you. Your palette is your imagination. Your inspiration is everywhere.\n\nYour freedom comes the moment you move your head to one side, and see your strokes from a different perspective.\n\nFrom here, Open Brush will treat you to a palette of 48 different brush types, freed from the bounds of typical painting media. Fire, water, smoke and light beams are just a selection of the wonderful brushes you\u2019ll find. A large selection of environments will find you floating in space, creating costumes, or transforming your living space into a dragon\u2019s cave through the magic of passthrough.\n\nAnything is possible in Open Brush. Transport yourself across the cosmos, or jump through the frames of famous portraits and see what lies beyond. The choice is yours.\n\nOpen Brush is the community powered evolution of Tilt Brush from Google, originally developed by Skillman & Hackett. ", "short_description": "Art from all angles \ud83d\udd8c\ufe0f\ud83c\udfa8 3D paint in XR! The community powered evolution of Tilt Brush"}]}, "developer_name": "Icosa Foundation", "developer_privacy_policy_url": "https://openbrush.app/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Icosa Foundation", "support_website_url": "https://discord.openbrush.app/", "website_url": "https://openbrush.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL"], "has_in_app_ads": false, "internet_connec