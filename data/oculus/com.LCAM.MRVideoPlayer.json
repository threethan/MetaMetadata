scontent-iad3-1.oculuscdn.com&oh=00_AYCJ-_ey6AD9iwXM6mNjRgPfIk9KUIEoHeffOwXIfN94Sg&oe=6735CA53"}, {"file_name": "shot5.png", "id": "919964143195311", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982706_919964146528644_158944188084046006_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJEL4-xLpmcQ7kNvgHM5_oZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEM0TAxYvzxrZzyrFiqpugELgpsITEZMa6w0OS8e7-IA&oe=6735F4F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER2.png", "id": "764994265576553", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269159_764994268909886_7552406079357889813_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QB57XU2hm3cQ7kNvgH9u0Nz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIjOZy05S4rskSKualB3a-r_S_xyGEeA9mLbrImfKCow&oe=6735E9E9"}, "display_name": "LCAM MR Video Player", "keywords": [], "long_description": "This is a personal offline video player for 2D and VR videos. Users can put any video into quest3 and name the file according to the App's specifications, and the video player will recognize it.\n(Video move to here: Quest 3\\Android\\data\\com.LCAM.MRVideoPlayer\\files)\n\nThere are two playback modes: 2D mode and VR mode. If you use \"_2D\" at the end of the file name, the video player will use 2D mode. If you use \"_180\" \"_360\" \"_180OV\" \"_180SS\"\"_360OV\"\"_360SS\"\"_6FL\" at the end of the file name, the video player will use VR mode\n\nWhen using 2D mode, Passthrough + depth can be turned on to detect the actual position and depth of objects, and the transparency can be adjusted according to personal needs.\n\nThe video player supports video preview (jpg/png) and subtitle files (srt), as long as the names of these files are the same as the video", "short_description": "You can use USB or URL to transfer 2D videos or VR videos and combine them with real space (Mixed Reality)"}]}, "developer_name": null, "developer_privacy_policy_url": "https://lcamstudio.weebly.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "LCAM STUDIO", "support_website_url": null, "website_url": "https://lcamstudio.weebly.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7473600792706427"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568678_1860290017732731_9005045556428135412_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wo89SjcwoigQ7kNvgGDkw91&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTy3-XjhBtNDQkEc3sJILf0WhRf9yLvkYbWH5g1gsmww&oe=6735EF64"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "LCAM MR Video Player", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media", "id": "434961926215971"}], "release_date": 1712249820, "lastRevision": {"nodes": [{"id": "7368523433214164", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7368523416547499", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "443602441455064"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_n