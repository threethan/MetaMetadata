e7a0a&_nc_ohc=eFOz37x8tD0Q7kNvgH-GVAY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP9BB1YQZoaisNjbYJjUd1L&oh=00_AYC7AWbXwlFEcsIMIOw7GJZT5-L8k5gKde2fSCLVaOGsew&oe=66F55871"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailercover.png", "id": "220866570343800", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322598_220866573677133_8839184849655379560_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ovWAQwl_QBIQ7kNvgF2ExEy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP9BB1YQZoaisNjbYJjUd1L&oh=00_AYBvR5nxHZ8ABGQAKFATLf53yLAiAp0e4AxQFxTm42hyGQ&oe=66F54B78"}, "display_name": "Raccoon Flyers", "keywords": [], "long_description": "Raccoon Flyers is a thrilling VR game that takes players on a heart-pumping adventure through a vibrant and lush forest. In the game, players take on the role of a daring raccoon flyer, using their virtual reality headset and controller to navigate through the forest canopy, dodge obstacles, and collect power-ups along the way.\n\nFeaturing stunning graphics, realistic physics, and intuitive controls, Raccoon Flyers offers a truly immersive and unforgettable gaming experience. With each level, players are challenged with new and exciting obstacles, including tight spaces, narrow gaps, and treacherous terrain, which require quick reflexes and skillful maneuvers to overcome.\n\nAs players progress through the game, they'll discover hidden areas and unlock new power-ups that enhance their raccoon flyer's abilities, allowing them to perform impressive stunts and soar to even greater heights. With multiple game modes and levels to explore, Raccoon Flyers offers endless hours of fun and excitement for both casual and hardcore gamers alike.\n\nWhether you're a seasoned VR gamer or new to the world of virtual reality, Raccoon Flyers is a game that's sure to leave you breathless and wanting more. So strap on your VR headset, grab your controller, and get ready to experience the thrill of flying like never before.", "short_description": "Raccoon Flyers VR is a breathtaking game that takes you on an immersive flying adventure through a lush, vibrant forest. In this video, we'll show you how Raccoon Flyers VR uses virtual reality technology to create an unforgettable flying experience that will leave you feeling like you're soaring through the treetops."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/villanstudiospracivypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "Villan Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/villanstudios/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25922848334028018"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974798_905492464067656_5225953678812892820_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2jmfYlCEYTsQ7kNvgHw-FUE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AP9BB1YQZoaisNjbYJjUd1L&oh=00_AYC0vz860rPO27uc_JhQyG242M3JdsEeAayW3wIbPX_Ljw&oe=66F5479F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Raccoon Flyers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1676049396, "lastRevision": {"nodes": [{"id": "8628908330515