=674EDCAE"}, {"file_name": "MHD_20220131_142951052.png", "id": "640043650673218", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439593_640043654006551_7051351553269026222_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4q-2dnClWsAQ7kNvgHQOZjd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZ6d1WHouf7QOx8V3ZDOAVmEn7ClAJOEF0QxBLr3q_xw&oe=674F0B21"}, {"file_name": "MHD_20220131_142935667.png", "id": "951099422186728", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75532179_951099428853394_2950810225293688420_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t0WklnagQQMQ7kNvgEWK1ec&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQW1wUHAHn25l_MlHjDIUMVbcrE4EDp4XHze1m1iNvtA&oe=674ED5B5"}, {"file_name": "MHD_20220131_143028542.png", "id": "473945630951304", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75557061_473945634284637_1179387240987874291_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vigCs52Y3ZcQ7kNvgEyDHUZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSMq5zxgxQ7JCM4cWcw9wbdpa215-2CCqKRhe29PFviA&oe=674F03C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape-app-lab-01-04.png", "id": "1726320934218866", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375762_1726320944218865_8479957325917845115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yKG0PmxlyQIQ7kNvgG9FgVT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0rH5dcAd2fvV1WsDTOU4hKKTZtcyniO44t1r9D_3r3w&oe=674EF925"}, "display_name": "Medicalholodeck Dissection Master XR", "keywords": [], "long_description": "Dissection Master XR is suitable for teaching in classes in VR and for independent preparation of courses and exams. The interactive anatomical 3D data enable a steep learning curve and optimal learning success. \n\nDissection Master XR brings human dissections of the highest quality to VR and makes them interactively accessible for medical teaching and education. The entire human body can be studied in multiple layers and discussed in groups in VR. The app is the perfect complement to traditional face-to-face lessons in the anatomy and dissection lab.\n", "short_description": "Dissection Master XR is the dissection and anatomy lab in virtual reality. It presents high-resolution human dissections created especially for anatomy teaching. The entire human body has been carefully dissected and digitized in up to 10 high-resolution layers. All structures relevant for anatomical education on a university level are precisely marked and annotated.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.medicalholodeck.com/privacy-data-protection/privacy.html", "developer_terms_of_service_url": "https://www.medicalholodeck.com/privacy-data-protection/terms.html", "publisher_name": "Medicalholodeck", "support_website_url": null, "website_url": "https://www.medicalholodeck.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "MEDICINE", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "678408766843213"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "406445178046082"}]}, "baseline_offer": {"id": "406445178046082"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1653948000, "status": "PUBLISHED", "id": "406445178046082"}]}, "liveChannel": {"n