34_291558082324718_5638391478751275778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e91DQlM6YtAQ7kNvgG-o8nd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUEsWh2wm-HvxHUxkvIRWAjnud-EJoDDXCvzs1Us6ssw&oe=67485F0B"}, {"file_name": "shot 0038.png", "id": "189191919452236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001654_189191922785569_3473505442128561070_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xU8GKKhc_IMQ7kNvgHI6Kg-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJgZfGDe2b0GiQkGHEW8iuQwktWVrkLgfRK_ilSWirAQ&oe=674864D3"}, {"file_name": "shot 0100.png", "id": "275532634192687", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_275532637526020_8486343831437358974_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUuUffWInOYQ7kNvgFB22Ti&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5qss6in_MyY7MEJXkhm8-5IOIfK7j2SQeVjVXjvnC-Q&oe=67487429"}, {"file_name": "shot 0015.png", "id": "440879667172126", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982584_440879670505459_5606495520519872624_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_l1NqL9YprcQ7kNvgH4JukL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCLQTO0byXuAaLkpnrhsiZ4Ko6vbNWaspzjZoRybTwClw&oe=67486BEF"}, {"file_name": "shot 0025.png", "id": "160260029196243", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982720_160260032529576_4963456793867992308_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uCDjZq7oLd4Q7kNvgEqAwIl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9kMjrjRrMlufhe4CKpzHzCE_jOqbW-shwB-utFQqc1Q&oe=6748568C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "853816492160058", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003248_853816495493391_1038613569093630295_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3XBZXDJtQsQ7kNvgHE0W6O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDe4QSQsryjwtfoGOa4iXD7HZnzfPp_vNi4CwcKKS0DpQ&oe=67483ECE"}, "display_name": "VR Pigeons", "keywords": ["silly", "weird", "party", "pigeons", "family"], "long_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!\n\nAll the world\u2019s a rooftop, and all the men and women merely pigeons. \n\nUse the power of VR and absolutely unique movement controls to slip into your pigeon-self!\nGo out into the world and find a rooftop. Wait for the granny to throw some bread. Eat as much bread as possible! BREAD IS LIFE!\n\n\nHow to become the ultimate VR Pigeon:\n\n\u2022 Channel to your inner Pigeon. Bob your head like a pigeon in order to move around and interact with your world\n\u2022 Unlock and discover four different levels\n\u2022 Protect your bread from other pigeons\n\u2022 Use power-ups and map shortcuts to be faster than other pigeons\n\u2022 Your pigeon enemies come in different shapes, avoid unnecessary conflicts!", "short_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!"}]}, "developer_name": "Maestro Pivetta / Studio Seufz", "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VRKiwi (MeKiwi)", "support_website_url": null, "website_url": "https://vrkiwi.org/portfolio/vr-pigeons/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1592192974313489"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_