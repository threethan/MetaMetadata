34_291558082324718_5638391478751275778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Otq0HBKW3RwQ7kNvgEnzJff&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDklD8eMuHhjCrGCTxHPwZnsoyhgad0V26zMQ6GWdmNbQ&oe=676BF78B"}, {"file_name": "shot 0038.png", "id": "189191919452236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001654_189191922785569_3473505442128561070_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ydQHSEsIDMAQ7kNvgEswRR-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1tBxIJcpi-QpgfW4WBOlIf0CM9ji5Pw_JTW-zYf6xFA&oe=676BFD53"}, {"file_name": "shot 0100.png", "id": "275532634192687", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_275532637526020_8486343831437358974_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=63nNYumphOAQ7kNvgFGqGBo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfrp8xeplmQEsie1bEeT7N0nFLFnJxQZAOOW6yuDNqng&oe=676BD469"}, {"file_name": "shot 0015.png", "id": "440879667172126", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982584_440879670505459_5606495520519872624_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RrLy9ifSqIQ7kNvgF9hMKi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCeRcLGpHGeWZ_z-TUo6gk7jTEqPavnURdrFZkryRQANw&oe=676C046F"}, {"file_name": "shot 0025.png", "id": "160260029196243", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982720_160260032529576_4963456793867992308_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=katyrkS_F_8Q7kNvgHA6npX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjM_pygJDuGhTxrsFD7lOmfk18hwtV35EQKwT62B-Rxw&oe=676BEF0C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "853816492160058", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003248_853816495493391_1038613569093630295_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fzAIxn64U9MQ7kNvgGfzH33&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYkpGsMHD-oPrO0SJoWVumb1F3M8GGSWrJ3tDrRIwbJw&oe=676BD74E"}, "display_name": "VR Pigeons", "keywords": ["silly", "weird", "party", "pigeons", "family"], "long_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!\n\nAll the world\u2019s a rooftop, and all the men and women merely pigeons. \n\nUse the power of VR and absolutely unique movement controls to slip into your pigeon-self!\nGo out into the world and find a rooftop. Wait for the granny to throw some bread. Eat as much bread as possible! BREAD IS LIFE!\n\n\nHow to become the ultimate VR Pigeon:\n\n\u2022 Channel to your inner Pigeon. Bob your head like a pigeon in order to move around and interact with your world\n\u2022 Unlock and discover four different levels\n\u2022 Protect your bread from other pigeons\n\u2022 Use power-ups and map shortcuts to be faster than other pigeons\n\u2022 Your pigeon enemies come in different shapes, avoid unnecessary conflicts!", "short_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!"}]}, "developer_name": "Maestro Pivetta / Studio Seufz", "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VRKiwi (MeKiwi)", "support_website_url": null, "website_url": "https://vrkiwi.org/portfolio/vr-pigeons/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1592192974313489"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_p