i": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003248_853816495493391_1038613569093630295_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fzAIxn64U9MQ7kNvgGfzH33&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYkpGsMHD-oPrO0SJoWVumb1F3M8GGSWrJ3tDrRIwbJw&oe=676BD74E"}, "display_name": "VR Pigeons", "keywords": [], "long_description": "All the world\u2019s a rooftop, and all the men and women merely pigeons. \n\nUse the power of VR and absolutely unique movement controls to slip into your pigeon-self!\nGo out into the world and find a rooftop. Wait for the granny to throw some bread. Eat as much bread as possible! BREAD IS LIFE!\n\n\nHow to become the ultimate VR Pigeon:\n\n\u2022 Channel to your inner Pigeon. Bob your head like a pigeon in order to move around and interact with your world\n\u2022 Unlock and discover four different levels\n\u2022 Protect your bread from other pigeons\n\u2022 Use power-ups and map shortcuts to be faster than other pigeons\n\u2022 Your pigeon enemies come in different shapes, avoid unnecessary conflicts!", "short_description": "All the world\u2019s a rooftop, and all the men and women merely pigeons. \n\nUse the power of VR and absolutely unique movement controls to slip into your pigeon-self!\nGo out into the world and find a rooftop. Wait for the granny to throw some bread. Eat as much bread as possible! BREAD IS LIFE!"}]}, "developer_name": "Maestro Pivetta", "developer_privacy_policy_url": "https://vrkiwi.org/wp-content/uploads/2021/07/VR-Pigeons-EULA.pdf", "developer_terms_of_service_url": null, "publisher_name": "VRKiwi (Mekiwi)", "support_website_url": null, "website_url": "https://vrkiwi.org/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SIMULATION"], "has