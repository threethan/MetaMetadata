culuscdn.com/v/t64.5771-25/39001654_189191922785569_3473505442128561070_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QxxBFII_mxgQ7kNvgGmDg5l&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_MlkgFur5cOR-lwpXx0tAPgr0MTQlclArSbRle9kLpw&oe=66F161D3"}, {"file_name": "shot 0100.png", "id": "275532634192687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974840_275532637526020_8486343831437358974_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3MGYlcj4BRwQ7kNvgGXFy7o&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJ0pMysdQ1zzHL1AqsTrlyo-TaGxhAYA9V46GZ16b8dw&oe=66F138E9"}, {"file_name": "shot 0015.png", "id": "440879667172126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_440879670505459_5606495520519872624_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mhjq2rymOBwQ7kNvgEx8mso&_nc_ht=scontent.oculuscdn.com&oh=00_AYChecaX1hJauaUCw8QjhEIlujhi8O_g4Ob20hnJJyo8Sg&oe=66F168EF"}, {"file_name": "shot 0025.png", "id": "160260029196243", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982720_160260032529576_4963456793867992308_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2gRZvhb0DBMQ7kNvgFjNmoy&_nc_ht=scontent.oculuscdn.com&oh=00_AYBp8xQG9O3n4iAskarcQVjNxKwC3Jn9-dbOkBZz_qLJNg&oe=66F1538C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "853816492160058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003248_853816495493391_1038613569093630295_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-4DkEcJxJsQ7kNvgEHng1W&_nc_ht=scontent.oculuscdn.com&oh=00_AYBU_u19yUiChMagFupgwOgUzmPgv0nfLLK0xLEmnCIG6A&oe=66F13BCE"}, "display_name": "VR Pigeons", "keywords": ["silly", "weird", "party", "pigeons", "family"], "long_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!\n\nAll the world\u2019s a rooftop, and all the men and women merely pigeons. \n\nUse the power of VR and absolutely unique movement controls to slip into your pigeon-self!\nGo out into the world and find a rooftop. Wait for the granny to throw some bread. Eat as much bread as possible! BREAD IS LIFE!\n\n\nHow to become the ultimate VR Pigeon:\n\n\u2022 Channel to your inner Pigeon. Bob your head like a pigeon in order to move around and interact with your world\n\u2022 Unlock and discover four different levels\n\u2022 Protect your bread from other pigeons\n\u2022 Use power-ups and map shortcuts to be faster than other pigeons\n\u2022 Your pigeon enemies come in different shapes, avoid unnecessary conflicts!", "short_description": "Bob your head like a pigeon to use the unique movement controls to slip into your pigeon-self!"}]}, "developer_name": "Maestro Pivetta / Studio Seufz", "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VRKiwi (MeKiwi)", "support_website_url": null, "website_url": "https://vrkiwi.org/portfolio/vr-pigeons/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8169114449820367"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974693_462721473297291_583541181875223647_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lzFG7QccDgkQ7kNvgF4f__W&_nc_ht=scontent.oculuscdn.