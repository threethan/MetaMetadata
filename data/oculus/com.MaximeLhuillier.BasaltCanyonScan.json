zSw&oe=66D9A784"}, {"file_name": "Screenshot3.png", "id": "479919230355261", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75604733_479919237021927_3270815822813629402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hpb3XQziXMkQ7kNvgFgfzfX&_nc_ht=scontent.oculuscdn.com&oh=00_AYB1XeDWmSpDr145KFQOi5SSOEtFglkSDyh7-x_qOjSfVw&oe=66D9AFD2"}, {"file_name": "Screenshot4.png", "id": "587095653146814", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035330_587095656480147_1944626692418926411_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZlRdmkuUXvgQ7kNvgHOE3a2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBya0RkplwZ8HhLBcjzyc8DjEhwh-oF0wRFY6HSyTN89g&oe=66D9AE05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1279312729273224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031422_1279312735939890_4968861642343199335_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Z4BNp9roiMQ7kNvgGIahbA&_nc_ht=scontent.oculuscdn.com&oh=00_AYDizTPGDP5-JdLnSUjaUS9A7DwrrO_kvzR5tHifm7dTTg&oe=66D989E2"}, "display_name": "3D scan of a basalt canyon", "keywords": [], "long_description": "Move like a pedestrian in a basalt canyon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 800m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- 