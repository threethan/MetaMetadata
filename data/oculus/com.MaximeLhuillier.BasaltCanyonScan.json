64.5771-25/39035330_474009491266299_1456643477844227164_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f_eVbiYtDPEQ7kNvgFzKgzm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBvkbS2ZoguHs4pr9wDZIaufduhKVPIlcx2GWDiybncVA&oe=67559484"}, {"file_name": "Screenshot3.png", "id": "479919230355261", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75604733_479919237021927_3270815822813629402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=miH3e0Tb2b4Q7kNvgFNSWRS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPlP9AdmzMU2t0-iNKlVNd_FvMx9ZvLWsQRIcaLrzFRQ&oe=67559CD2"}, {"file_name": "Screenshot4.png", "id": "587095653146814", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035330_587095656480147_1944626692418926411_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dWZiLPTWvgsQ7kNvgG3WCN6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9tQmS7Dx5cDh_ub8ZHCae3pmX3qk_Qs_U6TStl8ma5A&oe=67559B05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "1279312729273224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031422_1279312735939890_4968861642343199335_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jCTOzVT_6PoQ7kNvgEBpmCS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2kyJQo5JCzqQ1ZK5dIksANbDz8q5WEweoHYpoP-GTUA&oe=675576E2"}, "display_name": "3D scan of a basalt canyon", "keywords": [], "long_description": "Move like a pedestrian in a basalt canyon, reconstructed from videos taken by a helmet-held 360 camera, whose trajectory is about 800m long.\n\nRight controller:\n- Rotate on the left or right by using the joystick\n- Update the vertical offset (up or down) by using the joystick\n- Choose a location and teleport to it by using the virtual laser pointer\n- Teleport by using the index trigger only if the laser is green (not red)\n\nLeft controller:\n- Move continuously by using the joystick\n- Switch pannel and map by using the grip/hand trigger\n- If both map and pannel are disabled, switch between rendering modes (texturing or normal colors) by pressing the index trigger\n- The map shows the cloud of mesh vertices and the user location\n- If the pannel is enabled, switch between constrained and unconstrained motions by pressing the index trigger\n- The constrained motion controls your height above the ground\n- The pannel shows information about the 3D model and the selected motion.\n", "short_description": "Move continuously like a pedestrian in a basalt canyon, which was computed by photogrammetry from a cubemap video (4096x1344x2) taken by a helmet-held 360 camera (Gopro Max) and by walking about 800 meters.\n"}]}, "developer_name": "Maxime Lhuillier", "developer_privacy_policy_url": "https://maximelhuillier.fr/", "developer_terms_of_service_url": null, "publisher_name": "Unity 2019.4", "support_website_url": "http://maxime.lhuillier.free.fr/", "website_url": "https://maximelhuillier.fr/", "category": "ENTERTAINMENT", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7976016799149933"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036690_776174883598520_3389467299385980139_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=egnt8Sy8MToQ7kNvgGb1Oyg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb3t48AB-5zH5oDkEmIS-T91cNSqWrmB_m59arFdaE4g&oe=6755708A"}, "