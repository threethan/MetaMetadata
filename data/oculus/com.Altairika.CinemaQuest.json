ype": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982522_372906375738636_6814495351850937791_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-xrQsd_DkUQ7kNvgEOu7u8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5LUPY4pi24d-M8iGq_nw5AERHTcTkLVacbq3X2-sb2A&oe=672B3BA7"}]}, "id": "1538902203715150", "locale": "ru_RU", "screenshots": [{"file_name": "com.UnityTechnologies.com.unity.template 1.png", "id": "7337749689686793", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035346_7337749693020126_4239701023832394456_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xd__EksCDnoQ7kNvgEpfTQm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfC4AJCh43rH6vgUydOGOTaG53aFysFI6-nW18GGWOiQ&oe=672B5718"}, {"file_name": "com.UnityTechnologies.com.unity.template 4.png", "id": "799420072240729", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982522_799420075574062_4551016890279521117_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0rP2teO_nVoQ7kNvgF_6U-t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD8kGt0KFmWiTtniomc9TH2jx4mary2op5wnkUWhERBQw&oe=672B670A"}, {"file_name": "com.UnityTechnologies.com.unity.template 5.png", "id": "443961808191014", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974875_443961811524347_8496953500855530090_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PZbVEPfgSxQQ7kNvgFr537Q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOYxB6R7ocHcoqv7aIzSrnnTumZtKwVNjeyw51UGaAkQ&oe=672B4837"}, {"file_name": "com.UnityTechnologies.com.unity.template 2.png", "id": "1183332412694025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75363513_1183332416027358_8851354000477926830_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U9UNB0VU2vkQ7kNvgHR1ymN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlm9yDv9o3OA8HEs6075e6n4-WNm2HbSpAHuO73F1AaA&oe=672B6A5B"}, {"file_name": "com.UnityTechnologies.com.unity.template 3.png", "id": "7532872686775360", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035465_7532872690108693_2879296747885982118_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2qO--6HTn-wQ7kNvgH9fLRA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAi0xYTCra1ChgPOwYKrtaazBmu2-DTnsbBmGM3dXU_tQ&oe=672B3CF8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Altairika", "keywords": [], "long_description": "\n\u041f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044c\u0442\u0435: \u0432\u044b \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u0435\u0442\u0435\u0441\u044c \u0432 \u0433\u043b\u0443\u0431\u0438\u043d\u044b \u0441\u043e\u043b\u0451\u043d\u043e\u0433\u043e \u043e\u043a\u0435\u0430\u043d\u0430, \u043f\u0440\u043e\u043f\u043b\u044b\u0432\u0430\u044f \u043f\u0440\u044f\u043c\u043e \u0440\u044f\u0434\u043e\u043c \u0441 \u0431\u0435\u043b\u043e\u0439 \u0430\u043a\u0443\u043b\u043e\u0439, \u0438\u043b\u0438 \u0443\u043c\u0435\u043d\u044c\u0448\u0430\u0435\u0442\u0435\u0441\u044c \u0432 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432 \u0440\u0430\u0437, \u0447\u0442\u043e\u0431\u044b \u0441\u0432\u043e\u0438\u043c\u0438 \u0433\u043b\u0430\u0437\u0430\u043c\u0438 \u0443\u0432\u0438\u0434\u0435\u0442\u044c, \u043a\u0430\u043a \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0442 \u043a\u043b\u0435\u0442\u043a\u0438, \u0430 \u043f\u043e\u0441\u043b\u0435 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0435\u0441\u044c \u0432 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0435 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435, \u043f\u043e\u0437\u043d\u0430\u0432\u0430\u044f \u0442\u0430\u0439\u043d\u044b \u0412\u0441\u0435\u043b\u0435\u043d\u043d\u043e\u0439.\n\n\u0412\u0441\u0435 \u044d\u0442\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 VR.\n\u0424\u0438\u043b\u044c\u043c\u044b \u0438\u0437 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u043c\u043e\u0436\u043d\u043e \u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043f\u043e\u0440\u0442\u0430\u0442\u0438\u0432\u043d\u044b\u0445 \u043a\u0430\u0440\u043c\u0430\u043d\u043d\u044b\u0445 \u043e\u0447\u043a\u043e\u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 Cardboard, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0432\u0430\u0448 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d.\n\n\u041a\u041e\u041c\u0423 \u041f\u041e\u041d\u0420\u0410\u0412\u0418\u0422\u0421\u042f ALTAIRIKA?\n1. \u041a\u0430\u0436\u0434\u043e\u043c\u0443, \u043a\u0442\u043e \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u0443\u0435\u0442\u0441\u044f \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u044f\u043c\u0438 \u0438 \u043e\u0442\u043a\u0440\u044b\u0442 \u043d\u043e\u0432\u044b\u043c \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u044f\u043c!\n2. \u0421\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u043c \u0440\u043e\u0434\u0438\u0442\u0435\u043b\u044f\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0445\u043e\u0442\u044f\u0442 \u043b\u0443\u0447\u0448\u0435 \u0443\u0437\u043d\u0430\u0442\u044c \u0441\u0432\u043e\u0438\u0445 \u0434\u0435\u0442\u0435\u0439 \u0438 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c \u0438\u0445 \u043a\u0440\u0443\u0433\u043e\u0437\u043e\u0440.\n3. \u0428\u043a\u043e\u043b\u044c\u043d\u0438\u043a\u0430\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0443\u0441\u0442\u0430\u043b\u0438 \u043e\u0442 \u0441\u043a\u0443\u0447\u043d\u044b\u0445 \u043a\u0430\u0440\u0442\u0438\u043d\u043e\u043a \u0432 \u0443\u0447\u0435\u0431\u043d\u0438\u043a\u0430\u0445 \u0438 \u0445\u043e\u0442\u044f\u0442 \u043f\u043e\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u043d\u0435\u043e\u0431\u044b\u0447\u043d\u044b\u0435 \u0441\u043f\u043e\u0441\u043e\u0431\u044b \u0443\u0447\u0438\u0442\u044c\u0441\u044f.\n\n\u041b\u044e\u0431\u043e\u0437\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0438 \u0441\u0430\u043c\u043e\u043c\u043e\u0442\u0438\u0432\u0430\u0446\u0438\u044e \u0432\u0430\u0436\u043d\u043e \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 ALTAIRIKA \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0431\u0443\u0447\u0430\u0435\u0442, \u043d\u043e \u0438 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u043b\u044f\u0435\u0442. \u0417\u0440\u0435\u043b\u0438\u0449\u043d\u044b\u0439 \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u044b\u0439 \u0440\u044f\u0434 + \u043f\u043e\u0437\u043d\u0430\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u043b\u0435\u043a\u0446\u0438\u044f = \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435, \u0433\u0434\u0435 \u043a\u0430\u0436\u0434\u044b\u0439 \u0444\u0430\u043a\u0442 \u0443\u0434\u0438\u0432\u043b\u044f\u0435\u0442, \u0437\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u0435\u0442\u0441\u044f \u0438 \u0432\u044b\u0437\u044b\u0432\u0430\u0435\u0442 \u0436\u0435\u043b\u0430\u043d\u0438\u0435 \u0443\u0437\u043d\u0430\u0442\u044c \u0435\u0449\u0451 \u0431\u043e\u043b\u044c\u0448\u0435!\n\nALTAIRIKA \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043d\u0442, \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043b\u0438\u0446\u0435\u043d\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u0438 \u0441\u043e\u0437\u0434\u0430\u043d\u043d\u044b\u0439 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u043d\u0430\u0448\u0438\u0445 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439. \u041c\u044b \u0443\u0434\u0435\u043b\u044f\u0435\u043c \u043e\u0441\u043e\u0431\u043e\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438, \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u0443\u044f, \u0447\u0442\u043e \u043d\u0430\u0448\u0438 \u0444\u0438\u043b\u044c\u043c\u044b \u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0442 \u0434\u043b\u044f \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0434\u0435\u0442\u044c\u043c\u0438 11 \u043b\u0435\u0442 \u0438 \u0441\u0442\u0430\u0440\u0448\u0435.\n\nALTAIRIKA \u2014 \u044d\u0442\u043e \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435, \u044d\u0442\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0443\u0447\u0438\u0442\u044c\u0441\u044f \u0432 \u043b\u044e\u0431\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0438 \u0432 \u043b\u044e\u0431\u043e\u043c \u043c\u0435\u0441\u0442\u0435, \u0432\u0435\u0434\u044c \u0432\u0441\u0451 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0435 \u0443 \u0432\u0430\u0441 \u043f\u043e\u0434 \u0440\u0443\u043a\u043e\u0439, \u043f\u0440\u044f\u043c\u043e \u0432 \u0432\u0430\u0448\u0435\u043c \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d\u0435!\n\n\u041f\u043e\u0437\u043d\u0430\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e, \u0432\u0435\u0441\u0435\u043b\u043e, \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u043e \u0438 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0438\u0432\u043d\u043e!", "short_description": "\n\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0432 \u0441\u0435\u0431\u0435 \u0430\u0437\u0430\u0440\u0442 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044f! \u0418\u0437\u0443\u0447\u0430\u0439\u0442\u0435 \u043e\u043a\u0440\u0443\u0436\u0430\u044e\u0449\u0438\u0439 \u043c\u0438\u0440 \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 360\u00b0 \u0432 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0439 \u0438 \u0438\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0439 \u0441\u0440\u0435\u0434\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0438\u0437\u043c\u0435\u043d\u0438\u0442 \u0432\u0430\u0448 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u043d\u0430\u0443\u043a\u0443!\n"}, {"images": {"nodes": [{"file_name": "\u041e\u0431\u043b\u043e\u0436\u043a\u0430 2.png", "id": "1465164684113948", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612002_1465164687447281_5907844551825454489_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQjhQherQVIQ7kNvgHaeqU9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDL_529Z0wT9isMo8_6JEP3sYpeawsZPxGmGZkt6cGclQ&oe=672B57AF"}, {"file_name": "\u041a\u0430\u0440\u0442\u0438\u0440\u043a\u0430 \u0434\u043b\u044f \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f 2.png", "id": "1333536230825544", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974635_1333536234158877_5940209259687451389_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S7ZP7JzVWx8Q7kNvgGTsBb3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcMmlGYiRA_Utd-ulKiRWwOSjuD8sLcwv6rqHRBujzqQ&oe=672B412F"}, {"file_name": "\u0417\u043d\u0430\u0447\u043e\u043a.png", "id": "1012884576920313", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031613_1012884580253646_2707786302516754438_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hKO4KrFO8EEQ7kNvgHNNG73&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6Jlspz_s-cr2yLUuKmwA6URcgcVzzdh-vpuYFa