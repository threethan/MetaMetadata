-1.oculuscdn.com/v/t64.5771-25/38982522_372906375738636_6814495351850937791_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SRVAznYolmUQ7kNvgGnqbt7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaGh2SRY6TX2P7sRXQS5Y-VwxRb3_nk2fLWfu3es8pOQ&oe=6708F4A7"}]}, "id": "1538902203715150", "locale": "ru_RU", "screenshots": [{"file_name": "com.UnityTechnologies.com.unity.template 1.png", "id": "7337749689686793", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035346_7337749693020126_4239701023832394456_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_v31Ujp_Q54Q7kNvgFc5JlH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_bgejP7G3OGXtDqqL68QDp0MIg_TKUU4QjohG8RhKWg&oe=67091018"}, {"file_name": "com.UnityTechnologies.com.unity.template 4.png", "id": "799420072240729", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982522_799420075574062_4551016890279521117_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=upapO7_AWxwQ7kNvgGPXIYQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8mR1jsr9nZHzqW1GD2uhEhPX1i18YJ9kvloi_mpS3CA&oe=6709200A"}, {"file_name": "com.UnityTechnologies.com.unity.template 5.png", "id": "443961808191014", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974875_443961811524347_8496953500855530090_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0onexSLJ8IsQ7kNvgF9RLbN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8HoZlQj4s29xBrwfdy_b5SX3RDHGnXAQnp5EWS7_Ftg&oe=67090137"}, {"file_name": "com.UnityTechnologies.com.unity.template 2.png", "id": "1183332412694025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75363513_1183332416027358_8851354000477926830_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wlcu-1o7wXYQ7kNvgFqvAz_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCikhzV__JCREIV2SZwcFGSoHa-2sYLHOsdDU2iL3wrYQ&oe=6709235B"}, {"file_name": "com.UnityTechnologies.com.unity.template 3.png", "id": "7532872686775360", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035465_7532872690108693_2879296747885982118_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z09aM34xJO0Q7kNvgHlJYCa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxlr39SqXzPwzcVXG0QhH7XArwcftiXN3Qbcl1O-5UZg&oe=6708F5F8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Altairika", "keywords": [], "long_description": "\n\u041f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044c\u0442\u0435: \u0432\u044b \u043f\u043e\u0433\u0440\u0443\u0436\u0430\u0435\u0442\u0435\u0441\u044c \u0432 \u0433\u043b\u0443\u0431\u0438\u043d\u044b \u0441\u043e\u043b\u0451\u043d\u043e\u0433\u043e \u043e\u043a\u0435\u0430\u043d\u0430, \u043f\u0440\u043e\u043f\u043b\u044b\u0432\u0430\u044f \u043f\u0440\u044f\u043c\u043e \u0440\u044f\u0434\u043e\u043c \u0441 \u0431\u0435\u043b\u043e\u0439 \u0430\u043a\u0443\u043b\u043e\u0439, \u0438\u043b\u0438 \u0443\u043c\u0435\u043d\u044c\u0448\u0430\u0435\u0442\u0435\u0441\u044c \u0432 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043c\u0438\u043b\u043b\u0438\u043e\u043d\u043e\u0432 \u0440\u0430\u0437, \u0447\u0442\u043e\u0431\u044b \u0441\u0432\u043e\u0438\u043c\u0438 \u0433\u043b\u0430\u0437\u0430\u043c\u0438 \u0443\u0432\u0438\u0434\u0435\u0442\u044c, \u043a\u0430\u043a \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0442 \u043a\u043b\u0435\u0442\u043a\u0438, \u0430 \u043f\u043e\u0441\u043b\u0435 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442\u0435\u0441\u044c \u0432 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0435 \u043a\u043e\u0441\u043c\u0438\u0447\u0435\u0441\u043a\u043e\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435, \u043f\u043e\u0437\u043d\u0430\u0432\u0430\u044f \u0442\u0430\u0439\u043d\u044b \u0412\u0441\u0435\u043b\u0435\u043d\u043d\u043e\u0439.\n\n\u0412\u0441\u0435 \u044d\u0442\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0431\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0438 VR.\n\u0424\u0438\u043b\u044c\u043c\u044b \u0438\u0437 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u043c\u043e\u0436\u043d\u043e \u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043f\u043e\u0440\u0442\u0430\u0442\u0438\u0432\u043d\u044b\u0445 \u043a\u0430\u0440\u043c\u0430\u043d\u043d\u044b\u0445 \u043e\u0447\u043a\u043e\u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438 Cardboard, \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u0432\u0430\u0448 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d.\n\n\u041a\u041e\u041c\u0423 \u041f\u041e\u041d\u0420\u0410\u0412\u0418\u0422\u0421\u042f ALTAIRIKA?\n1. \u041a\u0430\u0436\u0434\u043e\u043c\u0443, \u043a\u0442\u043e \u0438\u043d\u0442\u0435\u0440\u0435\u0441\u0443\u0435\u0442\u0441\u044f \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u044f\u043c\u0438 \u0438 \u043e\u0442\u043a\u0440\u044b\u0442 \u043d\u043e\u0432\u044b\u043c \u0432\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u044f\u043c!\n2. \u0421\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u043c \u0440\u043e\u0434\u0438\u0442\u0435\u043b\u044f\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0445\u043e\u0442\u044f\u0442 \u043b\u0443\u0447\u0448\u0435 \u0443\u0437\u043d\u0430\u0442\u044c \u0441\u0432\u043e\u0438\u0445 \u0434\u0435\u0442\u0435\u0439 \u0438 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c \u0438\u0445 \u043a\u0440\u0443\u0433\u043e\u0437\u043e\u0440.\n3. \u0428\u043a\u043e\u043b\u044c\u043d\u0438\u043a\u0430\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0443\u0441\u0442\u0430\u043b\u0438 \u043e\u0442 \u0441\u043a\u0443\u0447\u043d\u044b\u0445 \u043a\u0430\u0440\u0442\u0438\u043d\u043e\u043a \u0432 \u0443\u0447\u0435\u0431\u043d\u0438\u043a\u0430\u0445 \u0438 \u0445\u043e\u0442\u044f\u0442 \u043f\u043e\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u043d\u0435\u043e\u0431\u044b\u0447\u043d\u044b\u0435 \u0441\u043f\u043e\u0441\u043e\u0431\u044b \u0443\u0447\u0438\u0442\u044c\u0441\u044f.\n\n\u041b\u044e\u0431\u043e\u0437\u043d\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0438 \u0441\u0430\u043c\u043e\u043c\u043e\u0442\u0438\u0432\u0430\u0446\u0438\u044e \u0432\u0430\u0436\u043d\u043e \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044c, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 ALTAIRIKA \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0431\u0443\u0447\u0430\u0435\u0442, \u043d\u043e \u0438 \u0432\u0434\u043e\u0445\u043d\u043e\u0432\u043b\u044f\u0435\u0442. \u0417\u0440\u0435\u043b\u0438\u0449\u043d\u044b\u0439 \u0432\u0438\u0437\u0443\u0430\u043b\u044c\u043d\u044b\u0439 \u0440\u044f\u0434 + \u043f\u043e\u0437\u043d\u0430\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u0430\u044f \u043b\u0435\u043a\u0446\u0438\u044f = \u0443\u0432\u043b\u0435\u043a\u0430\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435, \u0433\u0434\u0435 \u043a\u0430\u0436\u0434\u044b\u0439 \u0444\u0430\u043a\u0442 \u0443\u0434\u0438\u0432\u043b\u044f\u0435\u0442, \u0437\u0430\u043f\u043e\u043c\u0438\u043d\u0430\u0435\u0442\u0441\u044f \u0438 \u0432\u044b\u0437\u044b\u0432\u0430\u0435\u0442 \u0436\u0435\u043b\u0430\u043d\u0438\u0435 \u0443\u0437\u043d\u0430\u0442\u044c \u0435\u0449\u0451 \u0431\u043e\u043b\u044c\u0448\u0435!\n\nALTAIRIKA \u043f\u0440\u0435\u0434\u043b\u0430\u0433\u0430\u0435\u0442 \u0443\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043d\u0442, \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043b\u0438\u0446\u0435\u043d\u0437\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u0438 \u0441\u043e\u0437\u0434\u0430\u043d\u043d\u044b\u0439 \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u043d\u0430\u0448\u0438\u0445 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u0435\u0439. \u041c\u044b \u0443\u0434\u0435\u043b\u044f\u0435\u043c \u043e\u0441\u043e\u0431\u043e\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438, \u0433\u0430\u0440\u0430\u043d\u0442\u0438\u0440\u0443\u044f, \u0447\u0442\u043e \u043d\u0430\u0448\u0438 \u0444\u0438\u043b\u044c\u043c\u044b \u043f\u043e\u0434\u0445\u043e\u0434\u044f\u0442 \u0434\u043b\u044f \u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440\u0430 \u0434\u0435\u0442\u044c\u043c\u0438 11 \u043b\u0435\u0442 \u0438 \u0441\u0442\u0430\u0440\u0448\u0435.\n\nALTAIRIKA \u2014 \u044d\u0442\u043e \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435, \u044d\u0442\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u0443\u0447\u0438\u0442\u044c\u0441\u044f \u0432 \u043b\u044e\u0431\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0438 \u0432 \u043b\u044e\u0431\u043e\u043c \u043c\u0435\u0441\u0442\u0435, \u0432\u0435\u0434\u044c \u0432\u0441\u0451 \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0435 \u0443 \u0432\u0430\u0441 \u043f\u043e\u0434 \u0440\u0443\u043a\u043e\u0439, \u043f\u0440\u044f\u043c\u043e \u0432 \u0432\u0430\u0448\u0435\u043c \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d\u0435!\n\n\u041f\u043e\u0437\u043d\u0430\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u043e, \u0432\u0435\u0441\u0435\u043b\u043e, \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u043e \u0438 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u0438\u0432\u043d\u043e!", "short_description": "\n\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0432 \u0441\u0435\u0431\u0435 \u0430\u0437\u0430\u0440\u0442 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044f! \u0418\u0437\u0443\u0447\u0430\u0439\u0442\u0435 \u043e\u043a\u0440\u0443\u0436\u0430\u044e\u0449\u0438\u0439 \u043c\u0438\u0440 \u0432 \u0444\u043e\u0440\u043c\u0430\u0442\u0435 360\u00b0 \u0432 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0439 \u0438 \u0438\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0439 \u0441\u0440\u0435\u0434\u0435 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0438\u0437\u043c\u0435\u043d\u0438\u0442 \u0432\u0430\u0448 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u043d\u0430\u0443\u043a\u0443!\n"}, {"images": {"nodes": [{"file_name": "\u041e\u0431\u043b\u043e\u0436\u043a\u0430 2.png", "id": "1465164684113948", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612002_1465164687447281_5907844551825454489_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Up0BetQwvzcQ7kNvgFPYiYT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBe5Rh1A-R95Op6eQ-4-4eJPcN3HjT_hLQfWu9sq4S-jA&oe=670910AF"}, {"file_name": "\u041a\u0430\u0440\u0442\u0438\u0440\u043a\u0430 \u0434\u043b\u044f \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f 2.png", "id": "1333536230825544", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974635_1333536234158877_5940209259687451389_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KyYDr3yFpbIQ7kNvgE2N0-D&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM4tNv4gsePFEdXOdpgrd43jg-9l6-H_TYVYwWUsrmFg&oe=6708FA2F"}, {"file_name": "\u0417\u043d\u0430\u0447\u043e\u043a.png", "id": "1012884576920313", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031613_1012884580253646_2707786302516754438_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fRfoEiBQgBMQ7kNvgHhulqZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5F3BNpzTZBcRTVDgGJOfwS-RXl8a5faPJhT8VFKoWBg&oe=67091A52"}, {"file_name": "\u041e\u0431\u043b\u043e\u0436\u043a\u0430 1.png", "id": "830551941776569", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86629746_830551948443235_6047326871634663000_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g_5SjFO0gtgQ7kNvgEwoRsH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqGa5sXgQJnxcqpSu8c1EnVtFh2Vfdu7suEOzJ6xUZ-A&oe=67090142"}, {"file_name": "\u041e\u0431\u043b\u043e\u0436\u043a\u0430 3.png", "id": "765478622086208", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_765478625419541_8647197610434986619_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AyfSyf_4mb0Q7kNvgG6Wd8Y&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiAcMO0SYekNlhNy2Qm7P9yi6kxCdj796L_qnOsShVbQ&oe=67090364"}, {"file_name": "\u0417\u043d\u0430\u0447\u043e\u043a.png", "id": "470092728780651", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569432_470092732113984_5040483456865736778_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yPqWsvDFT_IQ7kNvgHSyjbF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCGrZg-t3gr38pUcK33LZKGCOojSJ5GbxHedPm_81aXug&oe=67091265"}, {"file_name": "\u041e\u0431\u043b\u043e\u0436\u043a\u0430.png", "id": "426442536855167", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75469625_426442540188500_5549541476249616465_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5YGIp-BalEcQ7kNvgGSF6uL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZcqLSazzx1UkSUXtENVhXuud-tfJGspIkGJizo9e-Og&oe=67091B79"}]}, "id": "430447203255341", "locale": "en_US", "screenshots": [{"file_name": "com.UnityTechnologies.com.unity.template 1.png", "id": "453065487231304", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404233_453065490564637_5539875580644459319_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fmmpToWX6BUQ7kNvgGt5VsC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZ6GCICB_er-pO8C5DX1ahqcjo6iu7v8vEfdhRgh3tnw&oe=67090F7D"}, {"file_name": "com.UnityTechnologies.com.unity.template 2.png", "id": "1208527426786924", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974544_1208527430120257_2477206735726169512_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ij1tHSAraVcQ7kNvgEYGIUo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjzmOU0NetkiFVMbjCjqZ2pYkxfFHhZ9vvQy_xm0acKQ&oe=67090C28"}, {"file_name": "com.UnityTechnologies.com.unity.template 3.png", "id": "1128267291755854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367586_1128267295089187_850758816064310687_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1FeSWhjr6GoQ7kNvgFhkoCe&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHK_eaKfVRG4vW2MtGa2LR_11B7kjWSGBUwXx6aXmTtg&oe=67090AC7"}, {"file_name": "com.UnityTechnologies.com.unity.template 4.png", "id": "3727718954140423", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_3727718957473756_510651242542684142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIYDqveNwnMQ7kNvgFXyPGR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAd3oSwu3j_lEHSrt8r8jLLdOQrzScAIAWFkCFUh5jmLw&oe=670926D1"}, {"file_name": "com.UnityTechnologies.com.unity.template 5.png", "id": "727210796234483", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974558_727210799567816_7934783513625981075_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sZmL6lMLU8oQ7kNvgGj-HK3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBY29M30eMRfzqUyx1C8r7PZ-fZu8yFIXXVuy-w3CM2Dw&oe=67090707"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Altairika", "keywords": [], "long_description": "Imagine diving into the depths of the ocean, swimming right next to a white shark, or shrinking down several million times to see for yourself how cells function, and then embarking on an exciting space journey to search the mysteries of the Universe. All this is possible with VR technology.\n\nFilms can be watched using a VR headset, a Cardboard portative VR headset or with your smartphone only.\n\nWHO WILL LIKE ALTAIRIKA?\nAnyone who is interested in technologies and is open to new experiences!\nModern parents who want to get to know their children better and expand their horizons.\nStudents who are fed up with boring visual aids and want to try unusual ways of learning.\n\nIt is important to develop curiosity and self-motivation, so ALTAIRIKA not only educates but also inspires. Spectacular visuals + interesting lecture = an exciting adventure where every fact is surprising, memorable and makes you want to learn even more!\n\nALTAIRIKA offers unique content, fully licensed and created especially for our users. We pay special attention to safety, ensuring that our films are suitable for children of 11+ ages.\n\nALTAIRIKA is not just an app, it is an opportunity to learn anytime and anywhere, because everything you need is at your fingertips, right in your smartphone!\n\nInformative, fun, technological and productive!", "short_description": "Discover the scientist within! Explore the world around you in 360\u00b0 in an exciting learning environment that will change the way you look at education!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://altairika.com/privacy/altairika_app", "developer_terms_of_service_url": null, "publisher_name": "Altairika Pte. Ltd.", "support_website_url": "https://altairika.com/contacts", "website_url": "https://altairika.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ru"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_