0LclD-a54Q7kNvgHydy8-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBR4ZUvyj5U4hg8rJItcHlL04WBcci58H75uJZ4KKeLwg&oe=674AFA7D"}, {"file_name": "com.UnityTechnologies.com.unity.template 2.png", "id": "1208527426786924", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974544_1208527430120257_2477206735726169512_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1eJJbR2GiVUQ7kNvgF6bLZv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACg9PktHOA9cwN-pa-30PYKGk0n00cLpdMx7xh0Bx_iw&oe=674AF728"}, {"file_name": "com.UnityTechnologies.com.unity.template 3.png", "id": "1128267291755854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367586_1128267295089187_850758816064310687_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NCVns8vHx9cQ7kNvgF8ujT4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDx8v3fGevenBVPK9WhkOek96jWU8f6XnqRANH5afA7Wg&oe=674AF5C7"}, {"file_name": "com.UnityTechnologies.com.unity.template 4.png", "id": "3727718954140423", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_3727718957473756_510651242542684142_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HMuHo1oQR9gQ7kNvgHXMlTD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbfUhqdIlLMEMcYxGTBQVgN_2DfKQexoRZRlHsRTM3YQ&oe=674B11D1"}, {"file_name": "com.UnityTechnologies.com.unity.template 5.png", "id": "727210796234483", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974558_727210799567816_7934783513625981075_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXU8JEWiYpwQ7kNvgG0tCAO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2qqn28unRQpMerIqXn02hAAW71eWPmFa6J9aIuya9bA&oe=674AF207"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Altairika", "keywords": [], "long_description": "Imagine diving into the depths of the ocean, swimming right next to a white shark, or shrinking down several million times to see for yourself how cells function, and then embarking on an exciting space journey to search the mysteries of the Universe. All this is possible with VR technology.\n\nFilms can be watched using a VR headset, a Cardboard portative VR headset or with your smartphone only.\n\nWHO WILL LIKE ALTAIRIKA?\nAnyone who is interested in technologies and is open to new experiences!\nModern parents who want to get to know their children better and expand their horizons.\nStudents who are fed up with boring visual aids and want to try unusual ways of learning.\n\nIt is important to develop curiosity and self-motivation, so ALTAIRIKA not only educates but also inspires. Spectacular visuals + interesting lecture = an exciting adventure where every fact is surprising, memorable and makes you want to learn even more!\n\nALTAIRIKA offers unique content, fully licensed and created especially for our users. We pay special attention to safety, ensuring that our films are suitable for children of 11+ ages.\n\nALTAIRIKA is not just an app, it is an opportunity to learn anytime and anywhere, because everything you need is at your fingertips, right in your smartphone!\n\nInformative, fun, technological and productive!", "short_description": "Discover the scientist within! Explore the world around you in 360\u00b0 in an exciting learning environment that will change the way you look at education!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://altairika.com/privacy/altairika_app", "developer_terms_of_service_url": null, "publisher_name": "Altairika Pte. Ltd.", "support_website_url": "https://altairika.com/contacts", "website_url": "https://altairika.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": n