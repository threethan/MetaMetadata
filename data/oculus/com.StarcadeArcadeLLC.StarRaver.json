rpies.\n\u2022 Discover the dark secret buried beneath an art deco dining hall.\n\u2022 Finally, relax and enjoy the show as you attend the StarRaver Concert.\n\nYou are our invited guest to the Starcade Arcade universe, and we would like to introduce you as an exclusive VIP in our multiversal club: StarRaver.", "short_description": "Hang out with your friends and party in this sci-fi music experience! Visit the unique clubs defining Starcade Arcade and enjoy the casual multiplayer party games in each room."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/starraver-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Starcade Arcade LLC", "support_website_url": null, "website_url": "https://www.starraver.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "MUSIC", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "8122810594506834"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001718_749270096153637_4174341231030676006_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QALdQb68gwAQ7kNvgGz4xIh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSav91-swhXfFdA6at9VPQ-16UssD-eD0tIMzbDvXjFg&oe=674ED972"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "StarRaver"