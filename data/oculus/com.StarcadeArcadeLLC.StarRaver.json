, "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75210884_547155917363148_5907858472536931705_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Himj0sZtACIQ7kNvgF8K7O6&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDPaaln6qMAMzm3v0Rt7LNjmmpQZaCJAyGMgqZk0q_VVQ&oe=67408624"}, "display_name": "StarRaver", "keywords": [], "long_description": "Hang out with your friends and party in this sci-fi music experience! Visit the unique clubs defining Starcade Arcade and enjoy the casual multiplayer party games in each room.\n\n\u2022 Test your aim in a sci-fi western saloon with a game of Space Pong.\n\u2022 Enjoy classics like Tic-Tac Toe by playing with life-size VR objects.\n\u2022 Vibe with all species of aliens in the notorious Club Jazz.\n\u2022 Party with DJ Inkers while you play with Space Slurpies.\n\u2022 Discover the dark secret buried beneath an art deco dining hall.\n\u2022 Finally, relax and enjoy the show as you attend the StarRaver Concert.\n\nYou are our invited guest to the Starcade Arcade universe, and we would like to introduce you as an exclusive VIP in our multiversal club: StarRaver.", "short_description": "Hang out with your friends and party in this sci-fi music experience! Visit the unique clubs defining Starcade Arcade and enjoy the casual multiplayer party games in each room."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.starcadearcadellc.com/starraver-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Starcade Arcade LLC", "support_website_url": null, "website_url": "https://www.starraver.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "MUSIC", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVE