dn.com/v/t64.5771-25/75286677_1550825638659524_513397768987420019_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DqQFqo3lCq0Q7kNvgHm_0tk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpb3GA39m5hEST8zidLPZjbBf1cnq-rmmxVUDTF11FWQ&oe=67826AD6"}, {"file_name": "7.png", "id": "145718118409249", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395421_145718121742582_9044177559046468251_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DDvFrt1CbPcQ7kNvgEgNLYY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-jS-Fsb7GRLJznIvPcYuWjDlaWu7Tac4Mm-NNUMU01Q&oe=67823E08"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (1).png", "id": "119712334459449", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302219_119712347792781_8012676570988914354_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDSn90TCyPAQ7kNvgG-o6zr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBo92e41PoiS7mzmttQz59SMRPPGYLipBkpNdTu6-9q5A&oe=678249A9"}, "display_name": "Bulletstorm VR", "keywords": ["BS", "BSVR", "Bullet", "Bulletstorm", "Skillshot"], "long_description": "Step into the boots of Grayson Hunt after a crash landing on an abandoned resort planet forces him to make a hard choice: survival or revenge. An exiled member of the elite assassin group Dead Echo, Grayson\u2019s blind desire for vengeance finds his crew stranded on Stygia where he can finally confront the commander behind his betrayal\u2014or get his team off the planet alive.\n\nBattle your way through throngs of Stygia\u2019s mutated inhabitants, performing masterful kills throughout the single-player campaign\u2014now with unique content made specifically for VR.\nUtilize Bulletstorm VR's unique \u201cSkillshot\u201d system that rewards you for executing the most creative and deadly kills imaginable.\n\nImmerse yourself into the world of Bulletstorm VR!", "short_description": "Step into the boots of Grayson Hunt after a crash landing on an old resort planet fo