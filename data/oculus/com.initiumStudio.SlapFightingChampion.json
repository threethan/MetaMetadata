uscdn.com&oh=00_AYDpNqZduYQ9RnO6b6Ak4iqzqs00B_93XkBLjs663KLzdA&oe=66CC6299"}, {"file_name": "5.5.png", "id": "198924935971195", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974840_198924942637861_2988066498749975549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GX-tNQzRiTUQ7kNvgH7lnqS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDwYn4RXXPFSrDqAwrhIFbvyTY3mThe-ZpAniUbhwi0Yg&oe=66CC5975"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cimage.png", "id": "820579113008592", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982487_820579123008591_3061918282524565343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cmWGzf13IFAQ7kNvgFv2zzc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWl7Ls1HSLHoC83HRL4lQ84dMyBVlz6RITVvlxXG8LPQ&oe=66CC7E2A"}, "display_name": "Slap Fighting Champion", "keywords": [], "long_description": "Slap Fighting Champion game is a virtual reality game that takes you on an entertaining and extraordinary experience. With immersive graphics and exciting mechanics, it invites you to a world where you test your skills in defeating enemies using virtual slaps. Fast-paced, addictive, and completely innovative, Slap Fighting Champion Game offers a surreal battle experience, pushing your limits. You'll feel like a real fighter, immersed in an adrenaline-fueled VR adventure.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Being a Slap Fighting Champion is not easy. Slap your slap as fast as you can and turn off your enemy."}]}, "developer_name": "INITIUM STUDIO", "developer_privacy_policy_url": "https://gametriclabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gametriclabs", "support_website_url": null, "website_url": "https://gametriclab