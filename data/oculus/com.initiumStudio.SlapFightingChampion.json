enture.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Being a Slap Fighting Champion is not easy. Slap your slap as fast as you can and turn off your enemy."}]}, "developer_name": null, "developer_privacy_policy_url": "http://initiumstudio.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "initium Stduio", "support_website_url": null, "website_url": "http://initiumstudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1410637526386853"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "2263853893963658"}, {"status": "PUBLISHED", "id": "473980418306180"}, {"status": "PUBLISHED", "id": "211608395032059"}, {"status": "PUBLISHED", "id": "684557890213221"}]}, "baseline_offer": {"id": "473980418306180"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "2263853893963658"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24200699909517340", "version": "7"}, "id": "2027830890888599", "channel_name