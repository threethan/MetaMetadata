m/v/t64.5771-25/75485576_804476537773912_2185238477816533257_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BKegd6Jw6SoQ7kNvgEtIqYx&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYARCNr0XAiXBcLbSa2K11JUWbGoICvxRp9V4VmV-0SmQQ&oe=670F9F19"}, {"file_name": "5.5.png", "id": "198924935971195", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974840_198924942637861_2988066498749975549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mj6j9phcxlYQ7kNvgHFagUr&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAYTbv5KFUkIcRSo-ckrcBBydx_g_Eft1X42mPN9YNr8Q&oe=670F95F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cimage.png", "id": "820579113008592", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982487_820579123008591_3061918282524565343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yfLmKd_FghkQ7kNvgFd-SCB&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDghFpCjKtARI-6ODNUuI_zWyoxex0ABb7zoGatOk-yqQ&oe=670FBAAA"}, "display_name": "Slap Fighting Champion", "keywords": ["slap", "fight", "champion", "faint", "strength"], "long_description": "Slap Fighting Champion game is a virtual reality game that takes you on an entertaining and extraordinary experience. With immersive graphics and exciting mechanics, it invites you to a world where you test your skills in defeating enemies using virtual slaps. Fast-paced, addictive, and completely innovative, Slap Fighting Champion Game offers a surreal battle experience, pushing your limits. You'll feel like a real fighter, immersed in an adrenaline-fueled VR adventure.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Being a Slap Fighting Champion is not easy. Slap your slap as fast as you can and turn off your enemy."}]}, "developer_n