565771204_7333079974764665331_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uoomab5AMnoQ7kNvgES8hm8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClKNdgZ6zl5NvJH7tBqLwnpis1qWPawn1uVa5B0p86Og&oe=67791E52"}, {"file_name": "4.4.png", "id": "804476534440579", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75485576_804476537773912_2185238477816533257_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eiMjUVjz-D8Q7kNvgFfKlBk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpooesbKcriZ_1BVxGGojEZOX31TknxmCCUwWoakH5fg&oe=67791719"}, {"file_name": "5.5.png", "id": "198924935971195", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_198924942637861_2988066498749975549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ZpW1V-ZztkQ7kNvgH7KDzd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFFiZSR26OvW-aoiDxSWxls8mKqtKcnDt6OzQQyPcKEw&oe=67790DF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cimage.png", "id": "820579113008592", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982487_820579123008591_3061918282524565343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e3R5FQH0mOMQ7kNvgEocEYP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3HfD6aERC9fi7kGwnJPDImUtVYfFBpe8e5BO1hb-Xyw&oe=677932AA"}, "display_name": "Slap Fighting Champion", "keywords": [], "long_description": "Slap Fighting Champion game is a virtual reality game that takes you on an entertaining and extraordinary experience. With immersive graphics and exciting mechanics, it invites you to a world where you test your skills in defeating enemies using virtual slaps. Fast-paced, addictive, and completely innovative, Slap Fighting Champion Game offers a surreal battle experience, pushing your limits. You'll feel like a real fighter, immersed in an adrenaline-fueled VR adventure.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Being a Slap Fighting Champion is not easy. Slap your slap as fast as you can and turn off your enemy."}]}, "developer_name": null, "developer_privacy_policy_url": "http://initiumstudio.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "initium Stduio", "support_website_url": null, "website_url": "http://initiumstudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1410637526386853"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "537903252210673"}, {"status": "PUBLISHED", "id": "2263853893963658"}, {"status": "PUBLISHED", "id": "473980418306180"}, {"status": "PUBLISHED", "id": "211608395032059"}, {"status": "PUBLISHED", "id": "684557890213221"}]}, "baseline_offer": {"id": "473980418306180"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "537903252210673"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24200699909517340", "version": "7"}, "id": "2027830890888599", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "Android