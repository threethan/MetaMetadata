/t64.5771-25/39035351_5976594565771204_7333079974764665331_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Kwh8GrGfEEQ7kNvgEAK1wG&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB7umojdSHmRozEk-bQFFsg97dVInX_BkynNj6E_Vp5rg&oe=67879ED2"}, {"file_name": "4.4.png", "id": "804476534440579", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75485576_804476537773912_2185238477816533257_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V18PVKiROEgQ7kNvgGSmtBp&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDb3c6-IInKjZ2pZ1LaURZb4lcO_a9_JZdFzs_H6u6Nhw&oe=67879799"}, {"file_name": "5.5.png", "id": "198924935971195", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974840_198924942637861_2988066498749975549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7vf8mDOnzFUQ7kNvgHDENUZ&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDhRs-SJPr5fu00tjk6wAbxYEMxgYeZ9dMRD8cdE4gNAg&oe=67878E75"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cimage.png", "id": "820579113008592", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982487_820579123008591_3061918282524565343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hXgLLNTBzI0Q7kNvgEYJ9kQ&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBvKAbupJfBNIuVxK2x7mIkbzeyTK4BLN7u_MSJiDFMMA&oe=6787B32A"}, "display_name": "Slap Fighting Champion", "keywords": ["slap", "fight", "champion", "faint", "strength"], "long_description": "Slap Fighting Champion game is a virtual reality game that takes you on an entertaining and extraordinary experience. With immersive graphics and exciting mechanics, it invites you to a world where you test your skills in defeating enemies using virtual slaps. Fast-paced, addictive, and completely innovative, Slap Fighting Champion Game offers a surreal battle experience, pushing your limits. You'll feel like a real fighter, immersed in an adrenaline-fueled VR adventure.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Being a Slap Fighting Champion is not easy. Slap your slap as fast as you can and turn off your enemy."}]}, "developer_name": "INITIUM STUDIO", "developer_privacy_policy_url": "https://gametriclabs.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gametriclabs", "support_website_url": null, "website_url": "https://gametriclabs.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27100302782890357"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/86627647_2843904902425021_3083082469451671731_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QytJvOMAMDsQ7kNvgExoAIE&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBleJEDQM6I5LrUnbh0wNOF7xyIXsvGmTPPBD5ELRqQDw&oe=6787B9D8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Slap Fighting Champion", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1686160830, "lastRevision": {"nodes": [{