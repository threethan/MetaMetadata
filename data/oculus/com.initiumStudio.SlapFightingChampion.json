le_name": "4.4.png", "id": "804476534440579", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75485576_804476537773912_2185238477816533257_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-Y7oUE3DfEQ7kNvgEuyol8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAPs0Oj2hmOtp7j3Cl0RldUbyR7Z3yDxQyFpEkPcJv2PQ&oe=67275A19"}, {"file_name": "5.5.png", "id": "198924935971195", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_198924942637861_2988066498749975549_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uX2Ip4zT0ssQ7kNvgEGD-zJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD73ZOHWRWpLzz1KEqwffcAazboO6hvbOa49SrGSCWPCw&oe=672750F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cimage.png", "id": "820579113008592", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982487_820579123008591_3061918282524565343_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PokER-pv_KMQ7kNvgHHCvac&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCtNWXK9g7oB-NiFHMgje50uHKuKTa-gKxiMDdLq2QIMw&oe=672775AA"}, "display_name": "Slap Fighting Champion", "keywords": ["slap", "fight", "champion", "faint", "strength"], "long_description": "Slap Fighting Champion game is a virtual reality game that takes you on an entertaining and extraordinary experience. With immersive graphics and exciting mechanics, it invites you to a world where you test your skills in defeating enemies using virtual slaps. Fast-paced, addictive, and completely innovative, Slap Fighting Champion Game offers a surreal battle experience, pushing your limits. You'll feel like a real fighter, immersed in an adrenaline-fueled VR adventure.\n\nGain different experiences by training and increase your strength and endurance. Fight with many opponents in many different venues and tournaments and show who is the champion.\n\nWe only ask you to pay attention to your surroundings while playing this game. You can really slap someone :)", "short_description": "Bei