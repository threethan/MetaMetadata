6e7a0a&_nc_ohc=PvAKmKvGGNIQ7kNvgFLU3Sw&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA_4jh1DGcdUY4DTf1XE2aRW3i7WcpfIdodm3ogrfnsJg&oe=6710FAD7"}, {"file_name": "OculusScreenshot1702168716.png", "id": "1045546456768821", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031557_1045546460102154_8869584294705848419_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RljXO9rp1-IQ7kNvgEKpgXZ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAffwZKS1ZEsvXzg22kmXuSyJbjsvQY3lfgnOuT16fjdQ&oe=6710E894"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OculusScreenshot1702169579.png", "id": "1421996451722456", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974657_1421996455055789_5575213174514540843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eX3Byq8Y4bEQ7kNvgE3h0vN&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC3wpatk-TtlkQ-4g1xPZcN_906dJRmRQH-6LdKr42yUA&oe=6710DFDC"}, "display_name": "StarGateVR", "keywords": [], "long_description": "StarGateVR represents a breakthrough in astronomical research and collaboration, offering a virtual reality application uniquely designed for the exploration of stars based on Gaia or other star database queries. This innovative tool allows users and their collaborators to immerse themselves in a shared virtual space, where the downloaded star parameters, selected 3 at a time, are rendered in three-dimensional detail. By leveraging the power of VR technology, StarGateVR provides an unparalleled platform for interactive learning, analysis, and discovery in the field of astronomy.", "short_description": "Use VR to view, explore, analyze, and collaborate on multi-parameter Gaia Archive star data."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immsci.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Immersive Science LLC", "support_website_url": null, "website_url": "https://www.immsci.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags