v/t64.5771-25/38982441_1024146145547151_3805722331130364725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ao_lGLUhOIwQ7kNvgESoWUv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArI7oMeecFD345sdDt0QQq02PIjcVuGBw0i_lBToR7wA&oe=674D9FD7"}, {"file_name": "OculusScreenshot1702168716.png", "id": "1045546456768821", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031557_1045546460102154_8869584294705848419_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=egk89vyz2yUQ7kNvgHe9_l3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmv88pCLwZxy6Kd-ZDn5h7eNGED4QQbAwHO5SK-O_Sng&oe=674D8D94"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OculusScreenshot1702169579.png", "id": "1421996451722456", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974657_1421996455055789_5575213174514540843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4jTMDIlV7bAQ7kNvgED4NZ8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJbBsI84usS8VYAn6lawtFGhV7BSwUE2a74aDIVhetug&oe=674D84DC"}, "display_name": "StarGateVR", "keywords": [], "long_description": "StarGateVR represents a breakthrough in astronomical research and collaboration, offering a virtual reality application uniquely designed for the exploration of stars based on Gaia or other star database queries. This innovative tool allows users and their collaborators to immerse themselves in a shared virtual space, where the downloaded star parameters, selected 3 at a time, are rendered in three-dimensional detail. By leveraging the power of VR technology, StarGateVR provides an unparalleled platform for interactive learning, analysis, and discovery in the field of astronomy.", "short_description": "Use VR to view, explore, analyze, and collaborate on multi-parameter Gaia Archive star data."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immsci.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Immersive Science LLC", "support_web