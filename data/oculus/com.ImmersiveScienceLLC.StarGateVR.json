v/t64.5771-25/38982441_1024146145547151_3805722331130364725_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UyEs5NXE-kUQ7kNvgGU_Oa6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcyfmxNd7HG-a3o-f-6verzEQauYB5k8jVYeW1t7NRlw&oe=677D15D7"}, {"file_name": "OculusScreenshot1702168716.png", "id": "1045546456768821", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031557_1045546460102154_8869584294705848419_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=854Zsdo7-lUQ7kNvgE6M2DT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAhG7xwZyGfhtGUrVwNhQM0qm8tHO0c5C8Y2vUtkF9x5A&oe=677D0394"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OculusScreenshot1702169579.png", "id": "1421996451722456", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974657_1421996455055789_5575213174514540843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jVHKWN-r6pcQ7kNvgFgiPk8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQgmB0e0nDL7wMlelTIqkFxIOWXtHlbhDBV95unvPkvg&oe=677CFADC"}, "display_name": "StarGateVR", "keywords": [], "long_description": "StarGateVR represents a breakthrough in astronomical research and collaboration, offering a virtual reality application uniquely designed for the exploration of stars based on Gaia or other star database queries. This innovative tool allows users and their collaborators to immerse themselves in a shared virtual space, where the downloaded star parameters, selected 3 at a time, are rendered in three-dimensional detail. By leveraging the power of VR technology, StarGateVR provides an unparalleled platform for interactive learning, analysis, and discovery in the field of astronomy.", "short_description": "Use VR to view, explore, analyze, and collaborate on multi-parameter Gaia Archive star data."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.immsci.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Immersive Science LLC", "support_web