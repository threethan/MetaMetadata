76367147436724", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982597_976367150770057_2894554143204748662_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j8kQC7dfXWEQ7kNvgFSo2Y9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGQYsbyb97NBIw0KQ9UfrdE-38767-DBeOvJcUwvsnOA&oe=670683A7"}, {"file_name": "005.png", "id": "2481855685354387", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982583_2481855688687720_4139726687525641317_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_GeLkIp7YesQ7kNvgF3arP0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGA6MLkqUK42V4QuZUZkwt8uk9pmmqHeBTWU4maxQZFQ&oe=67065568"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "ReadQuest", "keywords": [], "long_description": "Step into the world of phonics with ReadQuest, an innovative app that revolutionizes the learning process. This immersive application uses cutting-edge technology to create an engaging and interactive environment where users 10 years old and above can develop their reading skills. Whether you're just starting out or looking to improve your reading proficiency, ReadQuest provides a comprehensive, self-paced experience that makes learning enjoyable and accessible. With realistic simulations and interactive exercises, users can practice phonics in a supportive virtual setting, building confidence and mastery over time. Ideal for learners at any stage, ReadQuest is designed to accommodate both beginners and those seeking to enhance their reading abilities. Experience the joy of reading with an app that not only teaches but also inspires a lifelong love for learning.", "short_description": "Experience the future of reading with ReadQuest, a revolutionary app that transforms phonics learning into an interactive adventure. This immersive application provides a supportive environment for users over 10 years old to practice and perfect their reading skills through intuitive simulations. Ideal for beginners and advanced learners alike, ReadQuest offers a self-paced, engaging way to enhance reading proficiency, making learning to read an accessible and enjoyable experience for everyone."}]}, "developer_name": null, "developer_privacy_policy_url": "https://foretellreality.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://foretellreality.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25331752813134871"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1416725842543678"}]}, "baseline_offer": {"id": "1416725842543678"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715104668, "status": "PUBLISHED", "id": "1416725842543678"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27014077138235755", "version": "6.23.16"}, "id": "765065545554869", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25046615408315281", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27014077138235755"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "7