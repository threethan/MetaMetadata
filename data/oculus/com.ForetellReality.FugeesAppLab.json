pWw&oe=66E811B6"}, {"file_name": "MiniLandscape.png", "id": "255256627608684", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031560_255256630942017_2718590427365249953_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=obiw8kMx4N4Q7kNvgFNc9ts&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkSvGHtOn_7SyvU21EOIhzBu41egyqQJAEOqTc6Aqb6A&oe=66E80EE5"}]}, "id": "963721522000910", "locale": "en_US", "screenshots": [{"file_name": "001.png", "id": "441264131889872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974491_441264135223205_7970030276054095276_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kLT9z-2ON2EQ7kNvgE4HP52&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQ95FSCjmmR91AbStdORKDs-MCzL6oStmpD0JRNnsacA&oe=66E81468"}, {"file_name": "002.png", "id": "443250714768688", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974575_443250718102021_1351052423407545473_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p7lCjaDaVZoQ7kNvgHLBRtM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOr6sakS8_UKHzqV5SQsLur6Kmfn9OeAPhoQbKiACVHw&oe=66E7FFDB"}, {"file_name": "003.png", "id": "275055692345193", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982719_275055695678526_8919710582386734806_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7k-unNSxl10Q7kNvgH6_BaO&_nc_ht=scontent.oculuscdn.com&oh=00_AYByrA9DmfROs9nPbo8LSgfLnvR2RnVOFWNQsxyOnk1gtw&oe=66E82F84"}, {"file_name": "004.png", "id": "976367147436724", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982597_976367150770057_2894554143204748662_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kIfJUwCatV0Q7kNvgHsmF1C&_nc_ht=scontent.oculuscdn.com&oh=00_AYADm_JOwcIxWYHoNWLMhlyXwtl368ISdsEB6CR2AkasZA&oe=66E83127"}, {"file_name": "005.png", "id": "2481855685354387", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982583_2481855688687720_4139726687525641317_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_YXMCwABnE4Q7kNvgF1hl45&_nc_ht=scontent.oculuscdn.com&oh=00_AYCE-dLZL39uNlghtL6AEbPAS8gKPuzE8YoyKgYxW-74Fw&oe=66E802E8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "ReadQuest", "keywords": [], "long_description": "Step into the world of phonics with ReadQuest, an innovative app that revolutionizes the learning process. This immersive application uses cutting-edge technology to create an engaging and interactive environment where users 10 years old and above can develop their reading skills. Whether you're just starting out or looking to improve your reading proficiency, ReadQuest provides a comprehensive, self-paced experience that makes learning enjoyable and accessible. With realistic simulations and interactive exercises, users can practice phonics in a supportive virtual setting, building confidence and mastery over time. Ideal for learners at any stage, ReadQuest is designed to accommodate both beginners and those seeking to enhance their reading abilities. Experience the joy of reading with an app that not only teaches but also inspires a lifelong love for learning.", "short_description": "Experience the future of reading with ReadQuest, a revolutionary app that transforms phonics learning into an interactive adventure. This immersive application provides a supportive environment for users over 10 years old to practice and perfect their reading skills through intuitive simulations. Ideal for beginners and advanced learners alike, ReadQuest offers a self-paced, engaging way to enhance reading proficiency, making learning to read an accessible and enjoyable experience for everyone."}]}, "developer_name": null, "developer_privacy_policy_url": "https://foretellreality.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Foretell Reality", "support_website_url": null, "website_url": "https://foretellreality.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "8794