iyaDBpiRc3qxHug&oe=66DED05C"}, {"file_name": "screenshot-6 (Custom).png", "id": "2355623321275734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_2355623324609067_1563260484992063580_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=woyjuV4HfoYQ7kNvgFa041g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY8XcQhQQQtxcKS15fERwMx&oh=00_AYDy4dmKIU7811N_LgoJ00QThF415Du90nKzkgAcTun5Wg&oe=66DEC706"}, {"file_name": "oculus-screenshot-3.png", "id": "1857655031366310", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227959192_1857655034699643_8295944093819254073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ixEacvpz6aMQ7kNvgFnexcm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY8XcQhQQQtxcKS15fERwMx&oh=00_AYAb0jZyZOjRsv5cV1bnvr2fCQNevCGMkar_BGDYWaEGIA&oe=66DEE28A"}, {"file_name": "oculus-screenshot-1.png", "id": "731293328867359", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001714_731293332200692_2232626649433013156_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EUptAlw-vmIQ7kNvgGM3YKE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY8XcQhQQQtxcKS15fERwMx&oh=00_AYBqWS2pMLVfWAWYQsk6jKvLWWvRW0VJX1lKbi795-iFIA&oe=66DECA7F"}, {"file_name": "oculus-screenshot-2.png", "id": "122339860972704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330716_122339864306037_621619318168205922_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TfvuOM5JbgwQ7kNvgH_iXAz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY8XcQhQQQtxcKS15fERwMx&oh=00_AYAlNpj5nchCKPkNyK3CvDfh3CSrvutZqnR7HY4pZA01Hw&oe=66DEF200"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-header.png", "id": "754339716706590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974703_754339720039923_1466024971125960051_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J6IelYgez-EQ7kNvgFtKp6w&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY8XcQhQQQtxcKS15fERwMx&oh=00_AYBcMwDIVo1OuV0MdbwKZGjcbSvQyuxiKkvnvgaQq3hYrw&oe=66DEC86D"}, "display_name": "Security Control", "keywords": [], "long_description": "Security Control is a 1-4 player co-op and PVP escape room game. You have fallen asleep on your first day of work and now have to evade the security officer to escape or get caught and fired. Hide, run, complete objectives, steal money and escape before you get fired!\n\nGAMEPLAY\nPlay With Friends\nEmbark on your escape mission solo, with a squad of friends, or join an online lobby to outwit the vigilant security team. Utilize every resource available to make your way out of the corporate maze before you're caught. Can you and your team uncover the secrets of the office and make your grand escape, or will you assume the role of the relentless security guard to thwart their every move?\n\nCONQUER THE CORPORATE NIGHTMARE\nIn the office world, your relentless pursuers are the vigilant security team, determined to stop your escape. Each security guard has their own unique skills and tactics. Can you and your team overcome their strengths, exploit their vulnerabilities, and make a daring getaway?\n\nTRAVERSE EVER-CHANGING WORKPLACES\nPlay in one of ten diverse workplace settings, each uniquely designed to capture the essence of different professional environments. With procedurally generated layouts, no two missions are alike. Discover and navigate through various workplace hazards, security measures, and secrets, ensuring each escape endeavor provides a fresh and exhilarating challenge.\n", "short_description": "Security Control is a 1-4 player co-op and PVP escape room game. You have fallen asleep on your first day of work and now have to evade the security officer to escape or get caught and fired. Hide, run, complete objectives, steal money and escape before you get fired!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://securitycontrolgame.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Eric Greavette", "support_website_url": null, "website_url": "https://securitycontrolgame.com/", "category": null, "comfort_rating": "NOT_