"}, {"file_name": "oculus-screenshot-1.png", "id": "731293328867359", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001714_731293332200692_2232626649433013156_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rqrC09ZGv0kQ7kNvgGMqduA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCSovi63M4PhZwIEjhtyVLdFwqOttxJHij8NTmApRxOhw&oe=66DD78FF"}, {"file_name": "oculus-screenshot-2.png", "id": "122339860972704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330716_122339864306037_621619318168205922_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TfvuOM5JbgwQ7kNvgGwlJk2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyg7CAuw6ijSq5nhxbJUr_jjOZbOVYVhfkkR7N0aOwTQ&oe=66DDA080"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-header.png", "id": "754339716706590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974703_754339720039923_1466024971125960051_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J6IelYgez-EQ7kNvgGsNIIF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBN5FyuGzqfX4xUyI49kcY7P9qrL2VREmUOVkeCF0A0Vg&oe=66DD76ED"}, "display_name": "Security Control", "keywords": [], "long_description": "Security Control is a 1-4 player co-op and PVP escape room game. You have fallen asleep on your first day of work and now have to evade the security officer to escape or get caught and fired. Hide, run, complete objectives, steal money and escape before you get fired!\n\nGAMEPLAY\nPlay With Friends\nEmbark on your escape mission solo, with a squad of friends, or join an online lobby to outwit the vigilant security team. Utilize every resource available to make your way out of the corporate maze before you're caught. Can you and your team uncover the secrets of the office and make your grand escape, or will you assume the role of the relentless security guard to thwart their every move?\n\nCONQUER THE CORPORATE NIGHTMARE\nIn the office world, your relentless pursuers are the vigilant security team, determined to stop your escape. Each security guard has their own unique skills and tactics. Can you and your team overcome their strengths, exploit their vulnerabilities, and make a daring getaway?\n\nTRAVERSE EVER-CHANGING WORKPLACES\nPlay in one of ten diverse workplace settings, each uniquely designed to capture the essence of different professional environments. With procedurally generated layouts, no two missions are alike. Discover and navigate through various workplace hazards, security measures, and secrets, ensuring each escape endeavor provides a fresh and exhilarating challenge.\n", "short_description": "Security Control is a 1-4 player co-op and PVP escape room game. You have fallen asleep on your first day of work and now have to evade the security officer to escape or get caught and fired. Hide, run, complete objectives, steal money and escape before you get fired!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://securitycontrolgame.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Eric Greavette", "support_website_url": null, "website_url": "https://securitycontrolgame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6697315003699536"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "309406372024968"}]}, "baseline_offer": {"id": "309406372024968"}, "is_approved