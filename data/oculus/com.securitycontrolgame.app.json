8974728_965507358632286_2453934777900307542_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-7NDn3OPgIcQ7kNvgFyiGqL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBtHKYd3AdhcS_okrNg3ehABIu29nI_FJ9SmLneeq2PvQ&oe=66DD72EF"}]}, "id": "2307459902954940", "locale": "en_US", "screenshots": [{"file_name": "screenshot-6 (Custom).png", "id": "2355623321275734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036617_2355623324609067_1563260484992063580_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=woyjuV4HfoYQ7kNvgE9XF1C&_nc_ht=scontent.oculuscdn.com&oh=00_AYCqq136ETAzMdJb5665XN5t8E8ETTaQbsnJNwRCxIEzGQ&oe=66DD7586"}, {"file_name": "screenshot1.png", "id": "822193239808147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/428912992_822193243141480_8219858354461425670_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=32-7l8VdnvgQ7kNvgHWEEYP&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOp158z_wnFc45fPekgUsGZUl9knaTUKSM6TthU2rRRQ&oe=66DD91B1"}, {"file_name": "screenshot-5 (Custom).png", "id": "3270693743224065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035303_3270693746557398_8610652414073463038_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2-B6DNryy7kQ7kNvgETOTW_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAN7NNhbdOtS4dY7Ioly8UjJFgRzlwnFq97k4PCgIcV7w&oe=66DD7EDC"}, {"file_name": "oculus-screenshot-3.png", "id": "1857655031366310", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227959192_1857655034699643_8295944093819254073_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cL2ya_rTb6sQ7kNvgEaFScg&_nc_ht=scontent.oculuscdn.com&oh=00_AYACfFbmNAhnXBFQEoInD9v0vMAeYSFv_BpwAXgtKONF3Q&oe=66DD910A"}, {"file_name": "oculus-screenshot-2.png", "id": "122339860972704", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330716_122339864306037_621619318168205922_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TfvuOM5JbgwQ7kNvgGwlJk2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyg7CAuw6ijSq5nhxbJUr_jjOZbOVYVhfkkR7N0aOwTQ&oe=66DDA080"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage.png", "id": "434842892702560", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031542_434842896035893_1174240752487053500_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6gmnKKpo2EoQ7kNvgHJktpp&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEcy_ACN_4ZGg_aJpEA8130spclUpUoCDjkVtROWMZxQ&oe=66DD7258"}, "display_name": "Security Control", "keywords": [], "long_description": "**Security Control** is a 1-4 player co-op and PVP escape room game. You have fallen asleep on your first day of work and now have to evade the security officer to escape or get caught and fired. Hide, run, complete objectives, steal money and escape before you get fired!\n{989051122321309}\n\n# GAMEPLAY  \n**The Cellphone**  \nYour essential in-game companion: the Cellphone. Packed with versatile apps, it's your go-to for navigating the corporate maze. Stay connected with your team, hack security cameras, or boost your visibility with night vision.\n{2250752908597077}\n\n**Play With Friends**  \nEmbark on your escape mission solo, with a squad of friends, or join an online lobby to outwit the vigilant security team. Utilize every resource available to make your way out of the corporate maze before you're caught. Can you and your team uncover the secrets of the workplace and make your grand escape, or will you assume the role of the relentless security guard to thwart their every move?\n{965596411927278}\n\n**Complete Texts**  \nWhile you are trying to escape your workplace your significant other is texting you to complete objectives before coming home! Make sure to complete all the texts before you come back from work, or you shouldn't come back at all!\n{398946759771855}\n\n**TRAVERSE EVER-CHANGING WORKPLACES**  \nPlay ten diverse workplace settings, each uniquely designed to capture the essence of different professional environments. With procedurally generated layouts, no two missions are alike.", "short_description": "Security Control: A 1-4 player co-op game where you navigate the chaos of your first day on the job, either as employees oversleeping or as the security guard capturing them in an action-packed adventure."}]}, "developer_name": null, "developer_privacy_policy_url": "https://securitycontrolgame.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Eric Greavette", "support_website_url": null, "website_url": "https://securitycontrolgame.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7670778653019828"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/428901723_971073694721893_4978842923107351578_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76wsvp3uG5MQ7kNvgFTmAzx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFSEVmBLSZOTMWAbZh1v-fhgThEdRH6LezzJzvJsGc6w&oe=66DD8A79"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Security Control", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1725275340, "lastRevision": {"nodes": [{"id": "6526088390822199", "release_type": "SCHED