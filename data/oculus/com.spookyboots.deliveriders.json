: "DeliveridersScreenshots1.png", "id": "7196507950363673", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570288_7196507953697006_1581426346260008618_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7l_BzSm5OQQ7kNvgF-G95s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHaVDj9NCvckT13WjfzLiqb&oh=00_AYCHK6WNrfHVcajSG1zR7DSFwxD3l-IlSfOLvcjPUj134w&oe=66E18F3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DeliveridersCoverImageLandscape.png", "id": "944051900002993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031579_944051903336326_4502587919904884482_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tEhTRhADmcQ7kNvgHlVfFR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHaVDj9NCvckT13WjfzLiqb&oh=00_AYAn-MTXiNMyFnpZfVjDscw_XyUIXASlcUacSj-qjPt2XQ&oe=66E19653"}, "display_name": "Deliveriders", "keywords": [], "long_description": "Get your first taste of the future of food delivery in the Deliveriders Demo, a captivating new game where you navigate the bustling streets of NeoSoba City on a high-speed hoverboard.\n\n \u2022 Take on the role of a futuristic food delivery rider.\n \u2022 Meet unique characters and take on challenging missions\n \u2022 Master your hoverboard skills with fun intuitive controls\n \u2022 Customize your board with impressive upgrades\n\nThis demo is just the appetizer. In the full version, you'll unlock more upgrades, meet more characters, and help your delivery company outshine all others! More levels, challenges, and a fun, engaging story await!\n\nHop on your Magboard and join us in the Deliveriders Demo. Full game coming soon!", "short_description": "Hoverboarding food delivery action!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vSkpD8jRGkTuZr26qZBXj0x5ElANOu5WgYlCK8PnpDr159d6AB9qFPCJ05znM4DuyKFAIYqXGmWX7-x/pub", "developer_terms_of_service_url": null, "publisher_name": "Spooky Boots", "support_website_url": null, "website_url": "https://www.spookyboots.co.u