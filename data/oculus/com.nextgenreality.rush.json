NvgF14DMe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6l55kSc8uy71FNcC6osqyuNXj9s-veoc-hXZbToSYtQ&oe=67335957"}, {"file_name": "migrated_image.png", "id": "630485084451585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162683_157115144820099_4966208025086918656_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kdi2V1Tw6zMQ7kNvgG20vFZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfkIxlv_0nk7jajhGWJ68xKTR8fVSHeiCxBbHqU7rAyw&oe=67335607"}, {"file_name": "migrated_image.png", "id": "535752600698496", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12331069_187812818526107_299323941669830656_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YgpncdoCVgoQ7kNvgEcBzLE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYpT1cK-PBcE1pxFMLkULcu6cmWuQ0ZQXHyb6Nye8MsA&oe=6733524B"}, {"file_name": "migrated_image.png", "id": "520066718545729", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162681_1781082078868905_1799416813977600000_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Q7uRpRNR5YQ7kNvgFBGs2s&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWm8_k2JPWsh6LMNrd8P6JqJ-8AaieY26KoEZLJOFcsQ&oe=6733540C"}, {"file_name": "migrated_image.png", "id": "204847957499066", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162699_1937600323136154_2625204291874324480_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rgtNiQrVMGMQ7kNvgF8m-gM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlzyXUtELNIrXQMQ7HMNnKnAoliQnzBjfsOtJosmvROg&oe=67334378"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "RushGo_trailer_thumbnail.png", "id": "2072563853016576", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12448961_2072563856349909_5507482725969297408_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hmeOs--mlNcQ7kNvgEgVjgd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAH2_tlrA0DYcYOaOkrFeVafAMbxWMSoOo-pKZDnMESFw&oe=67333557"}, "display_name": "RUSH", "keywords": ["skydiving", "wingsuit", "race", "thrill", "multiplayer"], "long_description": "Take a dive into the adrenaline-pumping world of wingsuit flying with RUSH. Soar down mountainsides at breakneck speeds. Weave through canyons, dodge outcrops, and plummet down sheer drops as you race towards the finish line.\n\nDo you have what it takes to walk a tightrope at near terminal velocity?\n\nFEATURES\n- Stunning environments: Soar down four breathtaking mountainsides\n- Challenging races: 80 unique mountain paths to master, from basic downhill trails to expert-level suicide runs through the narrowest of spaces.\n- Multiple game modes: Race to the finish, Time Attack, and Score Challenge, each requiring a different set of skills and strategies to succeed.\n- Epic multiplayer jumps: Challenge up to 3 of your friends online via Oculus home parties, or quick race against random jumpers.\n\nStrap on your headset and hold on tight; you're in for a RUSH!", "short_description": "Are you ready for the ultimate thrill ride?\n\nTake a dive into the adrenaline-pumping world of wingsuit flying with RUSH! Soar down mountainsides at breakneck speeds. Weave through canyons, dodge outcrops, and plummet down sheer drops as you race towards the finish line.\n\nDo you have what it takes to walk a tightrope at near terminal velocity?\n\nStrap on your headset and hold on tight; you're in for a RUSH!"}]}, "developer_name": "The Binary Mill", "developer_privacy_policy_url": "http://www.thebinarymill.com/privacy.php", "developer_terms_of_service_url": "http://www.thebinarymill.com/terms.php", "publisher_name": "The Binary Mill", "support_website_url": null, "website_url": "http://www.thebinarymill.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "EXPLORATION", "RACING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_