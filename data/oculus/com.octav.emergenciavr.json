3919"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Emergencia VR", "keywords": ["Healthcare", "Hospital", "Doctor", "Medical", "Simulation"], "long_description": "EMERGENCIA VR is a virtual reality application designed to simulate the high-stakes environment of an emergency room, placing you in the role of an ER doctor.\n \nAs critically ill patients arrive, you'll need to rapidly conduct tests, analyze results, and make crucial decisions to save lives. With a VR headset and controllers, you can perform medical procedures and rely on your training and instincts to navigate this intense and realistic medical scenario.", "short_description": "EMERGENCIA VR is a virtual reality application designed to simulate the high-stakes environment of an emergency room, placing you in the role of an ER doctor."}]}, "developer_name": null, "developer_privacy_policy_url": "https://octav.studio/Privacy%20Policy%20for%20Emergencia%20VR.html", "developer_terms_of_service_url": null, "publisher_name": "Octav Studio", "support_website_url": null, "website_url": "https://octav.studio/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "879473995923081"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26641144542197928"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "8688347634556678"}]}, "baseline_offer": {"id": "8688347634556678"}, "is_approved": true, 