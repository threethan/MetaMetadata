4955345704", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_Ambulating_belt_01.png", "id": "876883577849233", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294243_876883581182566_6446470062167226290_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OBImcuogeeAQ7kNvgFTyMOc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2FIZsT_BfqCP-cVU7jwnZ17nhVA1eu3dRdSAuedpGCg&oe=676FE1F9"}, {"file_name": "Screenshot_Ambulating_belt_02.png", "id": "966544715288201", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75394635_966544718621534_1855503340670505854_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhBVM7FE_VsQ7kNvgFnFpZ-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDiIfhwL6CHX-SrQfnpbAF5wHt96Ttxa-fIbgi5pfVpEA&oe=676FE968"}, {"file_name": "Screenshot_Ambulating_belt_03.png", "id": "921177439603959", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468732404_921177442937292_6160956172358336461_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JlfDiPY6Xi8Q7kNvgG3WxY4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDuV0gD3PB-f6jDoTcenh_nEzivXxSSngL8hxCGCKS5VA&oe=676FC9B5"}, {"file_name": "Screenshot_Ambulating_belt_04.png", "id": "1276101480397251", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035363_1276101483730584_8932455262361737337_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1w9NEmhXzEQ7kNvgEAJ69D&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCr9WjUDpVo4wR01VGBYYSbnWot3VhWbsOMUia_T66NrA&oe=676FD6AF"}, {"file_name": "Screenshot_Ambulating_belt_05.png", "id": "1574879866454133", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_1574879869787466_1060087473445890128_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pHdP2X1qJ8EQ7kNvgFzr2aj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdjz_q3JlgmwkNpzptjF4_U8RXdTolmRzGlcwSh5Iuog&oe=676FF48B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Ambulating_belt_03.png", "id": "494471276981032", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035352_494471280314365_4201252089685071508_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NcqeQQZv_JYQ7kNvgHhYDgU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCu6XyP9cdNciwh5V3zMuJgzNh0IiTkOnLivGfubAhPeg&oe=676FEF41"}, "display_name": "Ambulate using Transfer Belt Simulator", "keywords": ["CNA", "nurse", "nursing", "ambulate", "training"], "long_description": "In this VR simulation, learners will master the process of assisting patients to ambulate using a transfer belt. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\nBy the end of this tutorial, participants will be able to: \n- Remember the necessary steps and safety protocols for using a transfer belt. \n- Understand the importance of proper transfer techniques in patient safety. \n- Apply the correct method to secure the transfer belt and assist patients in ambulation. \n- Analyze the patient's condition and environment to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a safe and supportive environment for patients during ambulation using a transfer belt. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the essential skill of safely assisting patients to ambulate using a transfer belt with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8669271316492363"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974735_1297558774595529_2441635775773936788_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dAdMDOReNEIQ7kNvgFm_j1b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdpZd-GLSI_hc9fAEjLOBEzfhEtidT12K7NInVpYIXqg&oe=676FE162"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ambulate using Transfer Belt Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1725450000, "lastRevision": {"nodes": [{"id": "7956572294428939", "release_type": "SCHEDULED", "administr