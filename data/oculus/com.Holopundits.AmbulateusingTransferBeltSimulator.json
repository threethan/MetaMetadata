43919717608_4066480831666542312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zYYD0XqFnGwQ7kNvgH67duE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJdWgex-rKvAnTHbbuREcb_ympAHQiZBMskR6InObV2Q&oe=6783AC6E"}, {"file_name": "Screenshot_Ambulating_belt_04.png", "id": "490392290607410", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974839_490392293940743_1765071940836830125_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3wXj7nqqxTsQ7kNvgF-v2yI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDwyKtA2gaP8xM018OVqjYDAYnxyHS2hLHT4V33vx3vhA&oe=6783915B"}, {"file_name": "Screenshot_Ambulating_belt_05.png", "id": "1508972156392410", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982656_1508972159725743_344779921690540713_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_3qaCvzJgGMQ7kNvgE64ZFY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtt2BGa2jsilBaqg76rIeUBYhbQvdsvHTB6247E-hvlw&oe=6783C306"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "522645180123106", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569445_522645183456439_8914387727413741660_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8g4esIkXFSsQ7kNvgHrehJE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrfudOdvf4-uMwUgoI9MpzZujcybumG-YdbTW6bPwAKg&oe=6783B7CF"}, "display_name": "Ambulate using Transfer Belt Simulator", "keywords": ["CNA", "nurse", "nursing", "ambulate", "training"], "long_description": "In this VR simulation, learners will master the process of assisting patients to ambulate using a transfer belt. The tutorial covers preparation, communication, application of the transfer belt, and the ambulation process itself. By the end of this tutorial, participants will be able to: \n- Remember the necessary steps and safety protocols for using a transfer belt. \n- Understand the importance of proper transfer techniques in patient safety. \n- Apply the correct method to secure the transfer 