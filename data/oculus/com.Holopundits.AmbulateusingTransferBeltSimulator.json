43919717608_4066480831666542312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJuEdv67tFcQ7kNvgFh8sCU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5oDncA0paq4AsDMIPZn4j0E1KJZQJQ01t9bPrXdqJlQ&oe=6773DA6E"}, {"file_name": "Screenshot_Ambulating_belt_04.png", "id": "490392290607410", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974839_490392293940743_1765071940836830125_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebnRqB81OrEQ7kNvgFVnu2S&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYOWyUMk8BYPzPhFbLJLtT6BH5f4EH7cHp00hhKKLDzw&oe=6773BF5B"}, {"file_name": "Screenshot_Ambulating_belt_05.png", "id": "1508972156392410", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982656_1508972159725743_344779921690540713_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qLfFSRwLHJcQ7kNvgF7SuKc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4xp25fvMEWqG8uiWzTEZumkQJMjgQq0LTeM3YNKYe5g&oe=6773F106"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "522645180123106", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569445_522645183456439_8914387727413741660_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uqy35f0EFK0Q7kNvgEVr_4b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDw0s-sMkqTfjFpR-tkHAQ3VVD4nWNnLzp33t6joHVJsg&oe=6773E5CF"}, "display_name": "Ambulate using Transfer Belt Simulator", "keywords": ["CNA", "nurse", "nursing", "ambulate", "training"], "long_description": "In this VR simulation, learners will master the process of assisting patients to ambulate using a transfer belt. The tutorial covers preparation, communication, application of the transfer belt, and the ambulation process itself. By the end of this tutorial, participants will be able to: \n- Remember the necessary steps and safety protocols for using a transfer belt. \n- Understand the importance of proper transfer techniques in patient safety. \n- Apply the correct method to secure the transfer belt and assist patients in ambulation. \n- Analyze the patient's condition and environment to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a safe and supportive environment for patients during ambulation using a transfer belt. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the essential skill of safely assisting patients to ambulate using a transfer belt."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "478089301798119"}, {"id": "514087707868786"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7956572267762275"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "477867771836880"}]}, "baseline_offer": {"id": "477867771836880"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725450000, "status": "PUBLISHED", "id": "477867771836880"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "87182647