b=1-7&_nc_sid=6e7a0a&_nc_ohc=RMmQZEpINeYQ7kNvgHSlCGT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyIr36JBYfxgprA-tbmG_Avfwc_VkGOIGr5vAI-cUZrA&oe=67694A79"}, {"file_name": "Screenshot_Ambulating_belt_02.png", "id": "966544715288201", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75394635_966544718621534_1855503340670505854_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KOykjdGGhp0Q7kNvgFaBJiq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvOml3dodr2P2W2gbFma7ZVl3-vNIWZ8IJEeeiVsps1g&oe=676951E8"}, {"file_name": "Screenshot_Ambulating_belt_03.png", "id": "921177439603959", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468732404_921177442937292_6160956172358336461_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L5_bt5u-_7oQ7kNvgE-bY0O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDF3kLTqZtROCvPShSCjwNFt7OmaGWI0t8MEV8U5MVxzw&oe=67693235"}, {"file_name": "Screenshot_Ambulating_belt_04.png", "id": "1276101480397251", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035363_1276101483730584_8932455262361737337_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huNSfvOZ-T0Q7kNvgHEXCFr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHsCkaFA92MmY6M0FWnmv33gd4lfwFgPgolAFP4b5w5A&oe=67693F2F"}, {"file_name": "Screenshot_Ambulating_belt_05.png", "id": "1574879866454133", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_1574879869787466_1060087473445890128_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XaJaFzn9jh8Q7kNvgFfuNUm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyImeGv9ygYQMe5EqJii7aY7JwDU36gQ2IoIjkxa-2tg&oe=67695D0B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Ambulating_belt_03.png", "id": "494471276981032", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035352_494471280314365_4201252089685071508_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VI7rkFzR9p0Q7kNvgEG-IV4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC216LLLBS3XGER1QV4wiijTAGVriIQvUTLF-UE3cnqjw&oe=676957C1"}, "display_name": "Ambulate using Transfer Belt Simulator", "keywords": ["CNA", "nurse", "nursing", "ambulate", "training"], "long_description": "In this VR simulation, learners will master the process of assisting patients to ambulate using a transfer belt. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\nBy the end of this tutorial, participants will be able to: \n- Remember the necessary steps and safety protocols for using a transfer belt. \n- Understand the importance of proper transfer techniques in patient safety. \n- Apply the correct method to secure the transfer belt and assist patients in ambulation. \n- Analyze the patient's condition and environment to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a safe and supportive environment for patients during ambulation using a transfer belt. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the essential skill of safely assisting patients to ambulate using a transfer belt with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "