25/39031500_859547269233114_6874294734507533955_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQ-C6pctA1QQ7kNvgGQVf68&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCZMWHEEQIaK3wJgNTEimW1ZezZ1OMPz09DziuSidJtjg&oe=6716496C"}, "display_name": "Hunt Together", "keywords": ["Horror", "PVP", "Action", "Multiplayer", "Online"], "long_description": "Challenge your friends in a PvP VR Horror game (with Meta Quest x PCVR crossplay)! \ud83d\udc7b\n\nFeel the thrill of a hunt in a 1v1 Duel or up to 1v3 Hide and Seek mode that will push your wits, perceptiveness, and courage to their very limits \ud83d\ude31 Employ a wide array of items, triggers, and skills tailored to your class to outsmart and defeat your adversary - a terrifying, lifeforce-draining Ghost or a dauntless, vigilant Hunter. All of this set in spine-chilling locations such as a haunted Mansion, Mines, or a horrid Orphanage.\n\nFeatures:\n\u2022 Challenge your friends in a spooky horror PvP system with 1v1 and up to 1v4 modes\n\u2022 Meta Quest x PCVR Crossplay\n\u2022 Two unique classes with dedicated skills and items\n\u2022 A suspenseful vibe of psychological horror\n\u2022 Haunted locations abound with possibilities and usable environment elements\n\u2022 Skins to customize your favorite character\n\u2022 Events and updates with new content to the game", "short_description": "Challenge your friends in a PvP Horror game (with Meta Quest x PCVR crossplay)! \ud83d\udc7b\n\nFeel the thrill of a hunt in a 1v1 Duel or up to 1v3 Hide and Seek mode that will push your wits, perceptiveness, and courage to their limits \ud83d\ude31 Employ an array of items, triggers, and skills tailored to your class to outsmart your adversary - a terrifying, lifeforce-draining Ghost or a dauntless, vigilant Hunter. All of this set in spine-chilling locations such as a haunted Mansion, Mines, or a horrid Orphanage."}]}, "developer_name": null, "developer_privacy_policy_url": "https://hunt-together.com/wp-content/uploads/2023/11/Hunt_Together_Privacy_Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Carbon Studio", "support_website_url": null, "website_url": "https://hunt-together.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6734168086679261"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1042866867353604"}, {"status": "PUBLISHED", "id": "1229972055083417"}, {"status": "PUBLISHED", "id": "958488942429146"}, {"status": "PUBLISHED", "id": "1242109167175559"}, {"status": "PUBLISHED", "id": "347189488240227"}, {"status": "PUBLISHED", "id": "1131409488265265"}]}, "baseline_offer": {"id": "1131409488265265"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724695200, "status": "PUBLISHED", "id": "1042866867353604"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8315317828564271", "version": "1.7"}, "id": "904073950235622", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4404934906269269", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8315317828564271"}, "release_status": "RELEASED"}