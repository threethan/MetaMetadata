 the role of a project manager in \"The Task Titans,\" where you'll tackle various challenges from saving spaceships to constructing bridges and solving treasure maps."}]}, "developer_name": "START", "developer_privacy_policy_url": "https://taleoconnects.com/privacypolicy-tasktitans", "developer_terms_of_service_url": null, "publisher_name": "Taleo", "support_website_url": null, "website_url": "https://taleoconnects.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7486606131429064"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "406446488852729"}]}, "baseline_offer": {"id": "406446488852729"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715616000, "status": "PUBLISHED", "id": "406446488852729"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8273593356063667", "version": "2.1"}, "id": "25287766510838265", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7486606128095731", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8273593356063667"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_