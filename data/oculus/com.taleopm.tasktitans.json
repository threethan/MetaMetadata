410_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W4V0ri23eVQQ7kNvgFS80TF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBugZHksROr03qF3pZ1OWqm4Dv3eYDDVEGdv0nlr1e8PQ&oe=67179F12"}, {"file_name": "scShot_2.png", "id": "7383528298412888", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982620_7383528311746220_2178009886707352184_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K6othcURBzMQ7kNvgH7FD79&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDOhdhXpbXO-hjh10pYYblEfDQSNrDVbKnoqtorV3yN0g&oe=67178CDB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TaskTitan_2560x1440.png", "id": "318678027752199", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982572_318678031085532_2872445775829117351_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gSZtMolWkzIQ7kNvgFJvMlO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgsD87_e8Dm2UgAzYTfD6PKLU0-yuY271hbZgTO6f4dQ&oe=67177970"}, "display_name": "Task Titans", "keywords": [], "long_description": "Task Titans is a series of 3 virtual reality mini games intended to teach the player project management concepts. \n\nDefeat Gremlins:\nOvercome risks and issues by battling gremlins, enhancing your problem-solving skills.\n\nBridge Building: \nConstruct one of multiples bridges types,  applying project management principles to ensure success.\n\nResource Management & Team Coordination:\nManage resources wisely and work with a team to bring your bridge project to completion.\n\nLearn Valuable Life Skills:\nGain insights into leadership, teamwork, strategic planning, and adaptability through real-life project scenarios.\n \nExperience:\nWhether a beginner or a seasoned pro, \"The Task Titans\" offers a fun and educational way to sharpen your project management skills.", "short_description": "Jump into the role of a project manager in \"The Task Titans,\" where you'll tackle various challenges from saving spaceships to constructing bridges and solving treasure maps."}]},