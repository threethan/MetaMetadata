ns,\" where you'll tackle various challenges from saving spaceships to constructing bridges and solving treasure maps."}]}, "developer_name": "START", "developer_privacy_policy_url": "https://taleoconnects.com/privacypolicy-tasktitans", "developer_terms_of_service_url": null, "publisher_name": "Taleo", "support_website_url": null, "website_url": "https://taleoconnects.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7486606131429064"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982665_957506029499330_7935029406456349610_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=REd6_IfiNlsQ7kNvgGJKpv-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zFZuOhZ3cDSOQs0pdf3my&oh=00_AYBEBirA3XEhdKO75zzzzIMeSH3QpiB3pM0BV4bFPFVZiA&oe=66D847D5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Task Titans", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1715616000, "lastRevision": {"nodes": [{"id": "7486606148095729", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "748660