iler": null, "video_trailer_thumbnail": null, "display_name": "Rock & Rails", "keywords": ["Rock", "Rails", "Shooter", "Music", "Cooperative"], "long_description": "The world of Rock \u2018n\u2019 Roll has been silenced, so it\u2019s time to get loud! Take up guitars and basses, and blow up the Silence Beasts with a BAAANG! Ride on rails all over the city, shredding riffs solo or jamming with your friends, and reclaim our world back in the name of Rock!\n\n- 9 levels full of rock and metal\n- 3 eligible characters\n- Metal Mode - harder levels for hard rockers\n- Local Co-Op Mode - jam with a friend*\n\n* Requires two devices with the game installed and a WiFi connection to play in co-op mode.", "short_description": "The world of Rock \u2018n\u2019 Roll has been silenced, so it\u2019s time to get loud! Take up guitars and basses, and blow up the Silence Beasts with a BAAANG! Fly over the place shredding riffs solo or jamming with your friends, and reclaim our world back in the name of Rock!"}, {"images": {"nodes": []}, "id": "248799673186091", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rock & Rails", "keywords": ["Rock", "Rieles", "Disparos", "Musica", "Multijugador"], "long_description": "El mundo del rock fue silenciado. \u00a1Es hora de subir el volumen y cambiarlo! Toma tu guitarra y bajo, y destruye a las Bestias del Silencio con un sonoro estruendo. Desliza por rieles que llevan a todo tipo de lugar, ya sea solo o tocando con amigos, \u00a1y reclama nuestro mundo de vuelta en el nombre del Rock!\n\n- 9 niveles llenos de rock y metal\n- 3 personajes elegibles\n- Modo Metal - niveles m\u00e1s dificiles para rockeros hardcore\n- Modo Cooperativo Local - juega con un amigo*\n\n* Requiere dos tel\u00e9fonos con el juego instalado y una conexi\u00f3n WiFi para jugar en modo cooperativo.", "short_description": "El mundo del rock fue silenciado. \u00a1Es hora de subir el volumen y cambiarlo! Toma tu guitarra y bajo, y destruye a las Bestias del Silencio con un sonoro estruendo. Desliza por rieles que llevan a todo tipo de lugar, ya sea solo o tocando con amigos, \u00a1y reclama nuestro mundo de vuelta en el nombre del Rock!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://blackriverstudios.net/docs/privacy-policy.html", "developer_terms_of_service_url": "http://blackriverstudios.net/docs/privacy-policy.html", "publisher_name": "Black River Studios", "support_website_url": null, "website_url": "http://blackriverstudios.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pt_BR", "es"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "SINGLE_USER"], "id": "635079387779832"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162810_347477488982635_4113980913199611904_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X10BfRrVIJYQ7kNvgG2MQzM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFM0R9mFx3jVEnL7OeDgVLgGp7dYuSS1CxAD1OZQXHKA&oe=675ADA83"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Rock & Rails", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1488960000, "lastRevision": {"nodes": [{"id": "731248023715264", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1239388509475291", "is_first_party": false, "enables_in_app_ads": fa