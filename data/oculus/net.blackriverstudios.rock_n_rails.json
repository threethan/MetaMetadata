2533901_1400794959964643_3679010995105169408_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dXu6lbeJPxYQ7kNvgGiKl0S&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArnCCoI-xkoG3OLe39chNom&oh=00_AYB7emA-DiTW-tsYk9HiDtvDbly_C4pdmzfgu3gB8MUlUQ&oe=66E2D961"}, {"file_name": "migrated_image.png", "id": "199433324665659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331072_390968924609489_7297967206267092992_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TpxjRx0LygoQ7kNvgH1BjBd&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArnCCoI-xkoG3OLe39chNom&oh=00_AYDiIjvlGTD8DjnYbWDVjBxzsi274j46jVLoPK-vzcQ8hQ&oe=66E2E7B6"}, {"file_name": "migrated_image.png", "id": "144300716902820", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386357_268640603567273_2370906322024529920_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TCmgTf_TSKwQ7kNvgFEvT00&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArnCCoI-xkoG3OLe39chNom&oh=00_AYAoQeH6Y7mO5KjJAOVycxNVEnkh7adPrjiPQUgJqlkEqw&oe=66E2D496"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "12448923_251787231944060_9159286353089789952_n.png", "id": "404540259897314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482253_404540263230647_6664660092194914304_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AY4Ee70pv9sQ7kNvgGa0aU0&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArnCCoI-xkoG3OLe39chNom&oh=00_AYAExKslSa715CCAKmrD1U-z6dkNj-mkyZec7GPwj9vIQg&oe=66E2DAEF"}, "display_name": "Rock & Rails", "keywords": ["Rock", "Rails", "Shooter", "Music", "Cooperative"], "long_description": "The world of Rock \u2018n\u2019 Roll has been silenced, so it\u2019s time to get loud! Take up guitars and basses, and blow up the Silence Beasts with a BAAANG! Ride on rails all over the city, shredding riffs solo or jamming with your friends, and reclaim our world back in the name of Rock!\n\n- 9 levels full of rock and metal\n- 3 eligible characters\n- Metal Mode - harder levels for hard rockers\n- Local Co-Op Mode - jam with a friend*\n\n* Requires two devices with the game installed and a WiFi connection to play in co-op mode.", "short_description": "The world of Rock \u2018n\u2019 Roll has been silenced, so it\u2019s time to get loud! Take up guitars and basses, and blow up the Silence Beasts with a BAAANG! Fly over the place shredding riffs solo or jamming with your friends, and reclaim our world back in the name of Rock!"}, {"images": {"nodes": []}, "id": "225384372180218", "locale": "pt_BR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rock & Rails", "keywords": ["Rock", "Rail", "Shooter", "M\u00fasica", "Multiplayer"], "long_description": "O mundo do rock & roll foi silenciado, ent\u00e3o \u00e9 hora de mudar subindo o volume! Pegue seus instrumentos e detone as Bestas do Sil\u00eancio com um bom e alto BAM! Deslize em trilhos por lugares irados, seja solo ou numa jam com amigos, e resgate nosso mundo de volta em nome do Rock!\n\n- 9 fases cheias de rock e metal\n- 3 personagens para escolher\n- Modo Metal - fases mais dif\u00edceis para roqueiros hardcores\n- Modo Co-Op Local - jogue com um amigo*\n\n* Requer dois telefones com o jogo instalado e uma conex\u00e3o WiFi para o modo Co-Op.", "short_description": "O mundo do rock & roll foi silenciado, ent\u00e3o \u00e9 hora de mudar subindo o volume! Pegue seus instrumentos e detone as Bestas do Sil\u00eancio com um bom e alto BAM! Deslize em trilhos por lugares irados, seja solo ou numa jam com amigos, e resgate nosso mundo de volta em nome do Rock!"}, {"images": {"nodes": []}, "id": "208832773551302", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rock & Rails", "keywords": ["Rock", "Rieles", "Disparos", "Musica", "Multijugador"], "long_description": "El mundo del rock fue silenciado. \u00a1Es hora de subir el volumen y cambiarlo! Toma tu guitarra y bajo, y destruye a las Bestias del Silencio con un sonoro estruendo. Desliza por rieles que llevan a todo tipo de lugar, ya sea solo o tocando con amigos, \u00a1y reclama nuestro mundo de vuelta en el nombre del Rock!\n\n- 9 niveles llenos de rock y metal\n- 3 personajes elegibles\n- Modo Metal - niveles m\u00e1s dificiles para rockeros hardcore\n- Modo Cooperativo Local - juega con un amigo*\n\n* Requiere dos tel\u00e9fonos con el juego instalado y una conexi\u00f3n WiFi para jugar en modo cooperativo.", "short_description": "El mundo del rock fue silenciado. \u00a1Es hora de subir el volumen y cambiarlo! Toma tu guitarra y bajo, y destruye a las Bestias del Silencio con un sonoro estruendo. Desliza por rieles que llevan a todo tipo de lugar, ya sea solo o tocando con amigos, \u00a1y reclama nuestro mundo de vuelta en el nombre del Rock!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://blackriverstudios.net/docs/privacy-policy.html", "developer_terms_of_service_url": "http://blackriverstudios.net/docs/privacy-policy.html", "publisher_name": "Black River Studios", "support_website_url": null, "website_url": "http://blackriverstudios.net/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pt_BR", "es"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "SINGLE_USER"], "id": "224120003174098"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "260476917740893"}]}, "baseline_offer": {"id": "260476917740893"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1488996000, "status": "PUBLISHED", "id": "260476917740893"}]}, "liveChannel": {"nodes": [{"lates