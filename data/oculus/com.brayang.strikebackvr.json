, they will give you really impressive challenges.\n\nWhat are you waiting for, let's start experiencing the game.", "short_description": "The world order has been turned upside down when the terrorist organizations gradually grew to be on par with the superpowers, as an elite special agent in the international anti-terrorist organization, you have the task of infiltrating and destroying the organization from the inside."}]}, "developer_name": null, "developer_privacy_policy_url": "https://strikeback-vr.web.app/", "developer_terms_of_service_url": null, "publisher_name": "Brayang Studio", "support_website_url": null, "website_url": "https://www.brayang.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "263559509387473"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "803366324589880"}, {"status": "PUBLISHED", "id": "595456319333778"}, {"status": "PUBLISHED", "id": "112981898455788"}]}, "baseline_offer": {"id": "803366324589880"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724035596, "status": "PUBLISHED", "id": "803366324589880"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6625881897506650", "version": "2.3"}, "id": "692024169257862", "channel_name": "LIVE"}]}, "is