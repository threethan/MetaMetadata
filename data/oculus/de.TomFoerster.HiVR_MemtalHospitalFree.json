ylum Free provides a stunning survival and mystery horror experience!\nCan you outlast this game and solve its puzzles? \nFight against zombies and use weapons or tools to succeed the mysterious horror hospital."}]}, "developer_name": "Tom F\u00f6rster", "developer_privacy_policy_url": "http://www.forstech.de/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Tom F\u00f6rster", "support_website_url": null, "website_url": "http://www.forstech.de/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "440351901164835"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974731_799964297118253_6092089253116772352_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FKDdGOYsThMQ7kNvgGlm44i&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHoyvY7fIy-yt9ProVSLler&oh=00_AYCXaVvxHYidpBjVOulbt6298-TXrJgDFTrC1Hd79QS6Sg&oe=66F1525C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Horror Asylum Free", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1568912400, "lastRevision": {"nodes": [{"id": "2361778417272921", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2457073991066118", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "11750