your mirracle morning", "keywords": [], "long_description": "People are always evolving and our goal is to help you find the best approach to this goal \u2014 be the person you are dreaming about to be. As you enter the virtual world, you'll be greeted with serene environments and calming soundscapes. You can choose to start your day with a cognitive training session, where you'll be guided through a series of methods that awaken your body and mind. Alternatively, you can opt for a breathing exercise that helps you center your focus and reduce stress. And if you're short on time, the app also features quick, five-minute routines that can be easily incorporated into your busy morning routine.", "short_description": "With Oyan XR, you can transform your morning routine into a powerful tool for personal growth and self-care. Start your day with intention, focus, and energy, and discover the positive impact that a fulfilling morning ritual can have on your life."}]}, "developer_name": "Khakim Yessenzhanov", "developer_privacy_policy_url": "https://hackstr.github.io/privacy", "developer_terms_of_service_url": null, "publisher_name": "black box studio, Inc", "support_website_url": null, "website_url": "https://hackstr.github.io/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "903567277528092"}, "review_m