g", "id": "421466796605313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031627_421466799938646_4903375708515772592_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TJZcp13B5ncQ7kNvgF_TjmZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aj9D4xn6mgigjKafvtfsmme&oh=00_AYDorN62OmI_Ip1JWKxulkIGSXFwdo7QKZbwuXG8tnax0g&oe=66EC294C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Oyan", "keywords": [], "long_description": "People are always evolving and our goal is to help you find the best approach to this goal \u2014 be the person you are dreaming about to be. Activities that you are going to accomplish include meditations, hydration, exercises to train your brain and affirmations to keep you on track. Also we have developed additional features such as diary, where you can share everything that in your mind and the calendar where you will be able to track your progress in this journey. All the journeys start from the first step. You and your wellbeing is the most important thing in your life. Healthier and happier life is not a dream, it is a reality that can be achieved. Do not afraid or hesitate to try. You can and you will become the best person with this VR app. Let's do it!", "short_description": "Oyan \u2014 interactive VR experience that will help you to become the better version of yourself. Achieve your personal goals by completing tasks and activities."}]}, "developer_name": "Khakim Yessenzhanov", "developer_privacy_policy_url": "https://hackstr.github.io/privacy", "developer_terms_of_service_url": null, "publisher_name": "black box studio, Inc", "support_website_url": null, "website_url": "https://hackstr.github.io/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_grap