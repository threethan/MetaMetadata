here you can share everything that in your mind and the calendar where you will be able to track your progress in this journey. All the journeys start from the first step. You and your wellbeing is the most important thing in your life. Healthier and happier life is not a dream, it is a reality that can be achieved. Do not afraid or hesitate to try. You can and you will become the best person with this VR app. Let's do it!", "short_description": "Oyan \u2014 interactive VR experience that will help you to become the better version of yourself. Achieve your personal goals by completing tasks and activities."}]}, "developer_name": "Khakim Yessenzhanov", "developer_privacy_policy_url": "https://hackstr.github.io/privacy", "developer_terms_of_service_url": null, "publisher_name": "black box studio, Inc", "support_website_url": null, "website_url": "https://hackstr.github.io/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "826293198748407"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5909664142479422", "version": "1.0.1"}, "id": "795376521496467", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidB