6C4CC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Oyan", "keywords": [], "long_description": "People are always evolving and our goal is to help you find the best approach to this goal \u2014 be the person you are dreaming about to be. Activities that you are going to accomplish include meditations, hydration, exercises to train your brain and affirmations to keep you on track. Also we have developed additional features such as diary, where you can share everything that in your mind and the calendar where you will be able to track your progress in this journey. All the journeys start from the first step. You and your wellbeing is the most important thing in your life. Healthier and happier life is not a dream, it is a reality that can be achieved. Do not afraid or hesitate to try. You can and you will become the best person with this VR app. Let's do it!", "short_description": "Oyan \u2014 interactive VR experience that will help you to become the better version of yourself. Achieve your personal goals by completing tasks and activities."}]}, "developer_name": "Khakim Yessenzhanov", "developer_privacy_policy_url": "https://hackstr.github.io/privacy", "developer_terms_of_service_url": null, "publisher_name": "black box studio, Inc", "support_website_url": null, "website_url": "https://hackstr.github.io/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "PRODUCTIVITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes