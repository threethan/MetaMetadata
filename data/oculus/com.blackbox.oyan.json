E37Fl17I0Q7kNvgFsQTbh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCewytFfCq2H0-akQR_MWKmBNRqFoswNV-pz1u_RZ-4LA&oe=66FD4531"}, {"file_name": "screen_2560x1440_2022-07-23_18-19-23.png", "id": "1038136313554143", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556800_1038136316887476_7791107121018473105_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WMvSnNn6sbIQ7kNvgEfUNLN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzY7SHRl6NSP8bby6C9IocLH2VjJmP6makm4BlfXGG1Q&oe=66FD21BC"}, {"file_name": "screen_2560x1440_2022-07-23_18-21-00.png", "id": "770146740874809", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_770146747541475_2951666414597193205_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqNPBCcJToUQ7kNvgHQpxB3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEZtLs8X5g10zXJrascoUBrTXoXE7IW7yos5oGcx8J7g&oe=66FD4432"}, {"file_name": "screen_2560x1440_2022-07-23_18-19-42.png", "id": "385754463478467", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974472_385754466811800_8513273206439066396_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dSFQtEIq5XQQ7kNvgGvDfuB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMwCLl7I8D2Gn05JohXjiXZ8nWQN8sacGBl7_YliM-yA&oe=66FD3DE0"}, {"file_name": "screen_2560x1440_2022-07-23_18-21-23.png", "id": "421466796605313", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031627_421466799938646_4903375708515772592_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P9bogad6seAQ7kNvgHJOvJh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHfPkMK11R2MwOTjyH6YE6W_Zzmgczua13zu2TVW6aig&oe=66FD4CCC"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Oyan", "keywords": [], "long_description": "People are always evolving and our goal is to help you find the best approach to this goal \u2014 be the person you are dreaming about to be. Activities that you are going to accomplish include meditations, hydration, exercises to train your brain and affirmations to keep you on track. Also we have developed additional features such as diary, where y