n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mr4_kFAkQyYQ7kNvgHVEDXh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCNTtLtAzGHiMUvLYvBNPG1lENNO523yrbTyZm1JYVTnQ&oe=676D5A11"}, "display_name": "AIRSOFT VR", "keywords": [], "long_description": "\u300c\u81ea\u5b85\u3067\u624b\u8efd\u306b\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u3092\u697d\u3057\u307f\u305f\u3044\uff01\u300d\n\u300c\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u3084\u30b5\u30d0\u30b2\u2015\u304c\u4e0a\u624b\u304f\u306a\u308a\u305f\u3044\uff01\u300d\n\n\u305d\u3093\u306a\u3042\u306a\u305f\u306b\u30d4\u30c3\u30bf\u30ea\u306a\u30b2\u30fc\u30e0\u304c\u3053\u306e\u300cAIRSOFT VR\u300d\u3067\u3059\u3002\n\n\u3053\u306e\u30b2\u30fc\u30e0\u306e\u30e1\u30ea\u30c3\u30c8\u306f\u4ed6\u306b\u3082\u3001\n\n\u30fb\u72ed\u3044\u7a7a\u9593\u3067\u3082\u5b9f\u73fe\u3067\u304d\u308b\n\u30fbBB\u5f3e\u306e\u6383\u9664\u306e\u624b\u9593\u304c\u7701\u3051\u308b\n\u30fb\u8272\u3093\u306a\u7af6\u6280\u306e\u30b9\u30c6\u30fc\u30b8\u3092\u624b\u8efd\u306b\u904a\u3079\u308b\n\u30fb\u57fa\u672c\u56fa\u5b9a\u4f4d\u7f6e\u306e\u305f\u3081VR\u9154\u3044\u3057\u306b\u304f\u3044\u30b7\u30c1\u30e5\u30a8\u30fc\u30b7\u30e7\u30f3\n\u30fb\u30c7\u30fc\u30bf\u5bb9\u91cf\u304c\u8efd\u3044\u3060\u3051\u3067\u306a\u304f\u51e6\u7406\u843d\u3061\u3082\u3057\u306a\u3044\n\n\u306a\u3069\u304c\u3042\u308a\u307e\u3059\u3002\n\u65e5\u3005\u7df4\u7fd2\u3059\u308b\u305f\u3081\u306e\u30c4\u30fc\u30eb\u3068\u3057\u3066\u30b7\u30f3\u30d7\u30eb\u306b\u4ed5\u4e0a\u3052\u307e\u3057\u305f\u3002\n\n\u30b2\u30fc\u30e0\u4e2d\u306bBGM\u306f\u6d41\u308c\u306a\u3044\u305f\u3081\u3001\u5225\u306e\u30c7\u30d0\u30a4\u30b9\u3067\u597d\u304d\u306a\u97f3\u697d\u3092\u8074\u304d\u306a\u304c\u3089\u30d7\u30ec\u30a4\u3059\u308b\u3068\u3088\u308a\u697d\u3057\u3081\u307e\u3059\u3002\n\n\u3010\u64cd\u4f5c\u65b9\u6cd5\u3011\n\u30fb\u4eba\u5dee\u3057\u6307\u30c8\u30ea\u30ac\u30fc\uff1a\u767a\u7832(\u30ea\u30b3\u30a4\u30eb\u5927)\n\u30fb\u30b0\u30ea\u30c3\u30d7\u30c8\u30ea\u30ac\u30fc(\u62bc\u3057\u306a\u304c\u3089)\uff0b\u4eba\u5dee\u3057\u6307\u30c8\u30ea\u30ac\u30fc\uff1a\u767a\u7832(\u30ea\u30b3\u30a4\u30eb\u5c0f)\n\u30fbA/B\u30dc\u30bf\u30f3\uff1a\u30ea\u30ed\u30fc\u30c9(\u30bf\u30fc\u30b2\u30c3\u30c8\u306e\u8d77\u304d\u4e0a\u304c\u308a)\n\u30fbX/A\u30dc\u30bf\u30f3\uff1a\u30ab\u30a6\u30f3\u30c8(\u7af6\u6280\u958b\u59cb\u306e\u5408\u56f3)\n\u30fbOculus\u30dc\u30bf\u30f3(\u9577\u62bc\u3057)\uff1a\u4f4d\u7f6e\u306e\u30ea\u30bb\u30c3\u30c8\n\n\u3010\u904a\u3073\u65b9\u3011\n\u2460\u8d77\u52d5\u5f8c\u3001\u300c\u30b9\u30c6\u30fc\u30b8\u9078\u629e\u90e8\u5c4b\u300d\u304b\u3089\u59cb\u307e\u308a\u307e\u3059\u3002\n\n\u30b9\u30c6\u30fc\u30b8\u306f\u4ee5\u4e0b\u306e5\u3064\u306b\u5206\u985e\u3055\u308c\u307e\u3059\u3002\n\n\u30fbJTSA(Japan Toygun Shooting Association)\n\u30fbJSC(JAPAN STEEL CHALLENGE)\n\u30fbPPS(Practice Postal Steel)\n\u30fbAPS(Air Precision Shooting)\n\u30fbOTHERS(\u30b5\u30d0\u30b2\u2015\u306e\u7df4\u7fd2\u306b\u7279\u5316\u3057\u305f\u30aa\u30ea\u30b8\u30ca\u30eb\u30b9\u30c6\u30fc\u30b8)\n\n\u2461\u5404\u7a2e\u30b9\u30c6\u30fc\u30b8\u306b\u79fb\u52d5\u3059\u308b\u306b\u306f\u3001\u30b9\u30c6\u30fc\u30b8\u540d\u306b\u30dd\u30a4\u30f3\u30bf\u30fc\u3092\u5f53\u3066\u306a\u304c\u3089\u4eba\u5dee\u3057\u6307\u30c8\u30ea\u30ac\u30fc\u3092\u5f15\u304d\u307e\u3059\u3002\n\n\u2462\u300c\u30b9\u30c6\u30fc\u30b8\u9078\u629e\u90e8\u5c4b\u300d\u306b\u623b\u308b\u306b\u306f\u3001A\u307e\u305f\u306fB\u30dc\u30bf\u30f3\u3092\uff12\u79d2\u9593\u62bc\u3057\u7d9a\u3051\u307e\u3059\u3002\n\n\n\u203b\u5404\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u306e\u30eb\u30fc\u30eb\u3084\u8a73\u7d30\u306b\u95a2\u3057\u307e\u3057\u3066\u306f\u4ee5\u4e0b\u306e\u30ea\u30f3\u30af\u304b\u3089\u3054\u78ba\u8a8d\u304f\u3060\u3055\u3044\u3002\n\n\u30fb\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u95a2\u9023\u30b5\u30a4\u30c8\nJSC\uff1ahttps://japansteelchallenge.net/\nJTSA\uff1ahttps://jtsa-shooting.org/about\nPPS\uff1ahttps://ppsblog.militaryblog.jp/c52968.html\nAPS\uff1ahttps://airsportsgun.com/aps/\n\nAPS\u30b7\u30eb\u30a8\u30c3\u30c8\u7af6\u6280\uff1ahttps://youtu.be/z4XSYUkGcl4\nAPS\u30d7\u30ec\u30fc\u30c8\u7af6\u6280\uff1ahttps://youtu.be/DPJxP2", "short_description": "\u5404\u7a2e\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u3092\u518d\u73fe\u3057\u305fVR\u30b7\u30df\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3\u30b2\u30fc\u30e0\uff01\n\u30a8\u30a2\u30ac\u30f3\u7af6\u6280\u3084\u30b5\u30d0\u30b2\u2015\u306e\u6280\u8853\u5411\u4e0a\u306b\u5f79\u7acb\u3066\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u3072\u3068\u308a\u3067\u3082\u307f\u3093\u306a\u3067\u3082\u8a18\u9332\u3092\u7af6\u3044\u5408\u3063\u3066\u697d\u3057\u307f\u307e\u3057\u3087\u3046\uff01"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xenosamvr.wixsite.com/privacy/post/%E3%83%95%E3%82%A3%E3%82%AF%E3%82%B7%E3%83%A7%E3%83%B3%E5%B0%8F%E8%AA%AC%EF%BC%9A%E3%81%93%E3%81%AE%E5%A4%8F%E8%AA%AD%E3%82%93%E3%81%A7%E3%81%84%E3%82%8B%E6%9C%AC%E3%82%92%E7%B4%B9%E4%BB%8B", "developer_terms_of_service_url": null, "publisher_name": "Xenosam", "support_website_url": null, "website_url": "https://youtu.be/v0kKDFL73IY", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SHOOTER", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1122913868298649"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {