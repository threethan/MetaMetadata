dn.com&oh=00_AYCzmGpD0lpvQIiYMlUcECZ6Z8lNKVK-WM5Bgtri6GHtGw&oe=676A928A"}, {"file_name": "RecursionVR_2560x1440.png", "id": "672969440535232", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982596_672969443868565_1266860602216379806_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=doY_5yER5fUQ7kNvgFT0Ej1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5QPnLcQj2ZJsfaTQNe3T7iW32nZviBEd3Eu0Tx6VSrg&oe=676AADCA"}, {"file_name": "RecursionVR_2560x1440.png", "id": "669942350690411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_669942357357077_4222656847355287240_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0XU4kKwLwQQ7kNvgEZ68FY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAEAmeK47Oqujpxr-bf1YLi4ZNyNkDJHlkaJrBA7GY33g&oe=676AA421"}, {"file_name": "RecursionVR_2560x1440.png", "id": "3233339390233553", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974497_3233339393566886_1151689555219910980_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i_NroKBXIs0Q7kNvgEnuCB3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxEvSSKCGYM0AGKTAub8O2L9HwcIeIS1SEoDfgg7YgRg&oe=676AA7E2"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Recursion VR", "keywords": [], "long_description": "Have you ever wished that Tron had more than just disk golf? Do you constantly find yourself needing to slice things to pieces, but rhythm games just aren't doing it for you? Maybe seek help or give the Outernet wastelands a try!\n\nSwords, shields, axes,  and daggers -  there's plenty more than that to sink your teeth into with Recursion VR. It's all here with a full fledged parkour system to express your finesse with a blade and your resilience as a Netrunner.", "short_description": "Immerse yourself in Cyberspace as the worlds most advanced combatant AI. Customize your cybersecurity loadout by discovering new weapons and abilities. Train your skills and save the web, or succumb to the storm that is raging through the Outernet."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.recursionvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.recursionvr.com/terms-conditions", "publisher_name": "Reality Shift LLC", "support_website_url": "https://www.recursionvr.com/faq", "website_url": "https://www.RecursionVR.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "27362927396627898"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FIGHTING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "646305820362110"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1037846518131263"}, {"status": "PUBLISHED", "id": "1371058087101833"}, {"status": "PUBLISHED", "id": "917825449184810"}]}, "baseline_offer": {"id": "1371058087101833"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1037846518131263"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7381380621875082", "version": "1.7.4"}, "id": "579124153160621", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4989548837724951", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7381380621875082"}, "release_status": "RELEASED"}, "b