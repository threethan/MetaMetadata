scdn.com&_nc_gid=Ac_1fvdaICO6n8WL0RJAw8v&oh=00_AYDeRttTbsJnxrxui2H_EqdLeLypIUBVnAVr8Rwd1VXcwQ&oe=66E2D9A1"}, {"file_name": "RecursionVR_2560x1440.png", "id": "3233339390233553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974497_3233339393566886_1151689555219910980_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jts6I1v-L2gQ7kNvgEXvcVk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ac_1fvdaICO6n8WL0RJAw8v&oh=00_AYDIAJpTampNQrwsiSOHQ_cAcLYvdC42K0Xent6eMnS-ug&oe=66E2DD62"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Recursion VR", "keywords": [], "long_description": "Have you ever wished that Tron had more than just disk golf? Do you constantly find yourself needing to slice things to pieces, but rhythm games just aren't doing it for you? Maybe seek help or give the Outernet wastelands a try!\n\nSwords, shields, axes,  and daggers -  there's plenty more than that to sink your teeth into with Recursion VR. It's all here with a full fledged parkour system to express your finesse with a blade and your resilience as a Netrunner.", "short_description": "Immerse yourself in Cyberspace as the worlds most advanced combatant AI. Customize your cybersecurity loadout by discovering new weapons and abilities. Train your skills and save the web, or succumb to the storm that is raging through the Outernet."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.recursionvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.recursionvr.com/terms-conditions", "publisher_name": "Reality Shift LLC", "support_website_url": "https://www.recursionvr.com/faq", "website_url": "https://www.RecursionVR.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FIGHTING"], "has_in_app_ads": false, "internet_