dn.com&oh=00_AYCFlapZGOlyYrtksT3vWULhNlTnRpmI3Ip-3UaLhDSJvg&oe=672F3F0A"}, {"file_name": "RecursionVR_2560x1440.png", "id": "672969440535232", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982596_672969443868565_1266860602216379806_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7kOYAQ8YPIQ7kNvgHuOUKY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1IH6-kAbURi8Q0cy7rWbt5r_CXkejeTZJwBBAtT2H1A&oe=672F5A4A"}, {"file_name": "RecursionVR_2560x1440.png", "id": "669942350690411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_669942357357077_4222656847355287240_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OnvXnlSHVW4Q7kNvgFimSQ5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQmWnaNH_KM1v_STaVdX6-ubv5_ZTBFXLplpRG6aRN4A&oe=672F50A1"}, {"file_name": "RecursionVR_2560x1440.png", "id": "3233339390233553", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974497_3233339393566886_1151689555219910980_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-8e6YYn-d3cQ7kNvgGv6dGb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn2apZORfCgZaOTVgte8ptXKt8B9KE7uR0ZfnJJ2FNvw&oe=672F5462"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Recursion VR", "keywords": [], "long_description": "Have you ever wished that Tron had more than just disk golf? Do you constantly find yourself needing to slice things to pieces, but rhythm games just aren't doing it for you? Maybe seek help or give the Outernet wastelands a try!\n\nSwords, shields, axes,  and daggers -  there's plenty more than that to sink your teeth into with Recursion VR. It's all here with a full fledged parkour system to express your finesse with a blade and your resilience as a Netrunner.", "short_description": "Immerse yourself in Cyberspace as the worlds most advanced combatant AI. Customize your cybersecurity loadout by discovering new weapons and abilities. Train your skills and save the web, or succumb to the storm that is raging through the Outernet."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.recursionvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.recursionvr.com/terms-conditions", "publisher_name": "Reality Shift LLC", "support_website_url": "https://www.recursionvr.com/faq", "website_url": "https://www.RecursionVR.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "27362927396627898"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "646305820362110"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1037846518131263"}, {"status": "PUBLISHED", "id": "1371058087101833"}, {"status": "PUBLISHED", "id": "917825449184810"}]}, "baseline_offer": {"id": "1371058087101833"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1037846518131263"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7381380621875082", "version": "1.7.4"}, "id": "579124153160621", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4989548837724951", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7381380621875082"}, "release_status": "RELEASED"}, "