ZJvSonaHVOAjJB7S_YKThlXrOcC-trzDA&oe=67371FF1"}, {"file_name": "2-2560x1440.png", "id": "1631350467404912", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035433_1631350470738245_8852123318308072529_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQ4ktDRj0QoQ7kNvgHkisG_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAgzoPsHv4ySZ3IggoqUg8GAAQIIQJ_0XokgwTaAqhnw&oe=6737357A"}, {"file_name": "5-2560x1440.png", "id": "471726615347621", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569432_471726618680954_3135093783903181704_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MY3L0VmNq-MQ7kNvgFeNqTD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDLC_d8JMBaBqWfsl7ilziX8MupXAXrU0BVr_PqHiYuvw&oe=67373062"}, {"file_name": "7-2560x1440.png", "id": "1146548799869781", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035337_1146548803203114_4232071023953588234_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xeALD5t8Je0Q7kNvgHG614M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUuAdrXJyAfZSj4GmfW7Uiy3CzlClzcOq7QKOXwOFZeg&oe=67374F3A"}, {"file_name": "1-2560x1440.png", "id": "999610461677141", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031311_999610465010474_1087177970663193150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BUSdYFGwM0sQ7kNvgHp-G_W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQtfkbMvUwLmSqAhVcme_q8E0Sc9sb7-CoaD79DGIT6w&oe=6737212B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "427799910014327", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_427799913347660_1009234490175775686_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uYOAg0nDY1AQ7kNvgHRyhR4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1nAcR8Le3QpsGvS0fiHNZkMVeEwVcIEIskfHTa0-n-A&oe=67371CCF"}, "display_name": "Hamster Inc.", "keywords": [], "long_description": "Welcome to \"Hamster Inc.\"! It's a physics building game that supports \"mixed reality\". In this delightful puzzle game, you'll design, build, and then program machines to overcome challenges!\n\n# Creativity and Logic\n- Based on physical principles and logic, think about how to overcome obstacles and help hamsters improve transportation efficiency.\n{1557136708179895}\n\n# Assembling\n- Design and build a variety of machines with over 60 types of blocks.\n- Over 20 special-function blocks that can be programmed, such as ultrasonic sensors, DC motors, radars and more.\n{327773876776917}\n\n# Graphical programming\n- Super easy! Graphical programming makes your creations \"alive\"!\n{406792278927140}\n\n# Explore 6 unique themes\n- Explore Eastern Forests, Automated factories, Sunshine Coast, Western Gobi, Volcanic Tunnels, and Northern snowfields.\n- As you progress, develop your hamster company and unlock new resources and challenges.\n\n# Enjoy the sandbox mode\n- where you can build and program freely without any limitations on the block amount!\n{971212150879070}\n\n# Mixed Reality\nBring your creations into real world and transform the entire room into a dream paradise: \n- Create custom levels by using real furniture and virtual terrain models, \n- Have your car/drone automatically avoid furniture as it moves around the room,\n- Watch virtual creatures interact with real world: like bison running on tables, floors, or beds!\n{897586709048914}\n\nDiscord: https://discord.gg/NkC8bwQEmK\n", "short_description": "\"Hamster Inc.\" is a physics-based building game that supports \"mixed reality.\"\nIn the game, you can build a variety of interesting inventions such as trebuchets, unmanned trucks, robotic arms, and drones to help the hamsters overcome challenges one after another and continuously develop and expand the logistics territory."}, {"images": {"nodes": [{"file_name": "\u6d77\u62a52560x1440\u5907\u90097-2+logo-\u4e2d\u6587.png", "id": "3772762123041281", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/