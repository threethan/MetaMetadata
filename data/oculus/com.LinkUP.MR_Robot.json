_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQrKdw4LoFnRfgj1s7-WEFHzqybcTI1pv28usTvsx5QA&oe=676E85F3"}, {"file_name": "2.png", "id": "811460331127807", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035358_811460334461140_7541795200473710410_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m1xSSP-M73IQ7kNvgHcNwep&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJ5sPJ6aD1t8b5YIsDdUB3QmFJjAQilp9-WQ6jjqWxGA&oe=676EAB8F"}]}, "id": "899318455572484", "locale": "en_US", "screenshots": [{"file_name": "11.png", "id": "1097797137999292", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570288_1097797141332625_692184632505995617_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8RR2c1235icQ7kNvgHwnhK7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAM31iz94rHIJpicFUtvQrV1GIdDVHboj6Cj8yc0115zQ&oe=676E7EF1"}, {"file_name": "2-2560x1440.png", "id": "1631350467404912", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035433_1631350470738245_8852123318308072529_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tzuPoWzF4gwQ7kNvgH0pwr-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0NCCtsosUCXLNMokkdZSdVh_YasL1BiacB-mekSh2Jg&oe=676E947A"}, {"file_name": "5-2560x1440.png", "id": "471726615347621", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569432_471726618680954_3135093783903181704_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yjN7LeDFD40Q7kNvgHsNDDM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcB_aRjXxT_vtV-daosGjA-ol2OHrS0xigJEhC8DeOUg&oe=676E8F62"}, {"file_name": "7-2560x1440.png", "id": "1146548799869781", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035337_1146548803203114_4232071023953588234_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hswT2Evc-54Q7kNvgGrNHN9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUFBU7BLAEO_D1aHvqaZMbFUpRL8I0pinrVvZgxAc2Dg&oe=676EAE3A"}, {"file_name": "1-2560x1440.png", "id": "999610461677141", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031311_999610465010474_1087177970663193150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uXsqxGHRb7kQ7kNvgFEPJBx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-vQRGGC3obarEjqDfmqYL9Leay3-UYP4m8MSurvo2xQ&oe=676E802B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "503788578775406", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974504_503788582108739_3834053529888765989_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1IKkeyFecDoQ7kNvgHwBQRf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAonFMnsGRWEPP7wPVlx6ypbece2ggxAHZJAjOAcg_WGA&oe=676E8713"}, "display_name": "Hamster Inc.", "keywords": [], "long_description": "Welcome to \"Hamster Inc.\"! It's a physics building game that supports \"mixed reality\". In this delightful puzzle game, you'll design, build, and then program machines to overcome challenges!\n\n# Creativity and Logic\n- Based on physical principles and logic, think about how to overcome obstacles and help hamsters improve transportation efficiency.\n{1557136708179895}\n\n# Assembling\n- Design and build a variety of machines with over 60 types of blocks.\n- Over 20 special-function blocks that can be programmed, such as ultrasonic sensors, DC motors, radars and more.\n{327773876776917}\n\n# Graphical programming\n- Super easy! Graphical programming makes your creations \"alive\"!\n{406792278927140}\n\n# Explore 6 unique themes\n- Explore Eastern Forests, Automated factories, Sunshine Coast, Western Gobi, Volcanic Tunnels, and Northern snowfields.\n- As you progress, develop your hamster company and unlock new resources and challenges.\n\n# Enjoy the sandbox mode\n- where you can build and program freely without any limitations on the block amount!\n{971212150879070}\n\n# Mixed Reality\nBring your creations into real world and transform the entire room into a dream paradise: \n- Create custom levels by using real furniture and virtual terrain models, \n- Have your car/drone automatically avoid furniture as it moves around the room,\n- Watch virtual creatures interact with real world: like bison running on tables, floors, or beds!\n{897586709048914}\n\nDiscord: https://discord.gg/NkC8bwQEmK\n", "short_description": "\"Hamster Inc.\" is a physics-based building game that supports \"mixed reality.\"\nIn the game, you can build a variety of interesting inventions such as trebuchets, unmanned trucks, robotic arms, and drones to help the hamsters overcome challenges one after another and continuously develop and expand the logistics territory."}]}, "developer_name": null, "developer_privacy_policy_url": "https://linkupxr.oss-cn-shenzhen.aliyuncs.com/Common/PrivacyPolicyofLinkupLLC.pdf", "developer_terms_of_service_url": null, "publisher_name": "LINK-UP IMMERSIVE", "support_website_url": null, "website_url": "https://linkupxr.oss-cn-shenzhen.aliyuncs.com/Common/Hamster%20Inc.%2020240513.pdf", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7629327370501355"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974804_858150846172189_3684137377628731728_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-GR0S2Xzii8Q7kNvgFp3lRh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWSwFwess13534O