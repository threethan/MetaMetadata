_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nHwimN7roqkQ7kNvgGD6ZCp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD28_bsOCyieHSIuSEUFwq7goaGUg0gujjDP5XRHT2xYA&oe=67371D3F"}, {"file_name": "1-2560x1440.png", "id": "1104252097450091", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86621346_1104252100783424_7805917123927614755_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fbZvGJGj-6sQ7kNvgGEctTa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfdwUI5ziqGgwv3iN858D6nX1Mb5ts0vvn9TeW20ZyBg&oe=67373057"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "3637063639838891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982585_3637063643172224_1066663336060733987_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sKEA_84nUVQQ7kNvgF-KEMc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1WzDj4HRs7-lmzv7ZHClEin4rHLa8aLf2znUkuwbBMw&oe=673723B9"}, "display_name": "\u4ed3\u9f20\u8fd0\u8f93\u516c\u53f8", "keywords": [], "long_description": "\u6b22\u8fce\u6765\u5230\u300a\u4ed3\u9f20\u8fd0\u8f93\u516c\u53f8\u300b\uff01\u8fd9\u662f\u4e00\u6b3e\u652f\u6301\u201c\u6df7\u5408\u73b0\u5b9e\u201d\u7684\u7269\u7406\u5efa\u9020\u6e38\u620f\u3002\n\u5728\u8fd9\u6b3e\u8ff7\u4eba\u800c\u6709\u8da3\u7684\u89e3\u8c1c\u6e38\u620f\u4e2d\uff0c\u60a8\u9700\u8981\u7075\u6d3b\u7684\u8fd0\u7528\u903b\u8f91\u548c\u521b\u610f\u6765\u89e3\u51b3\u95ee\u9898\uff1a\u4e3a\u4e86\u5e2e\u52a9\u4ed3\u9f20\u4f19\u4f34\u4eec\u5feb\u901f\u3001\u5b89\u5168\u5730\u5c06\u8d27\u7269\u8fd0\u8f93\u5230\u4e16\u754c\u5404\u5730\uff0c\u4f60\u9700\u8981\u8bbe\u8ba1\u548c\u5efa\u9020\u5404\u79cd\u88c5\u7f6e\uff0c\u7136\u540e\u4e3a\u5b83\u4eec\u7f16\u7a0b -- \u65e0\u8bba\u662f\u4ece\u6760\u6746\u5230\u6295\u77f3\u673a\uff0c\u8fd8\u662f\u4ece\u65e0\u4eba\u8d27\u8f66\u5230\u65e0\u4eba\u673a\uff0c\u751a\u81f3\u8fd8\u6709\u673a\u68b0\u81c2\uff01\n\n# \u521b\u610f\u548c\u903b\u8f91\uff01\n- \u57fa\u4e8e\u7269\u7406\u539f\u5219\u548c\u903b\u8f91\u6027\uff0c\u601d\u8003\u5982\u4f55\u514b\u670d\u969c\u788d\u548c\u6311\u6218\uff0c\u4ee5\u5e2e\u52a9\u4ed3\u9f20\u4eec\u66f4\u6709\u6548\u7387\u5730\u8fd0\u8f93\u8d27\u7269\uff01\n{832086222101730}\n\n# \u79ef\u6728\u62fc\u88c5\n- \u4f7f\u752860\u591a\u79cd\u53ef\u62fc\u88c5\u79ef\u6728\uff0c\u8bbe\u8ba1\u548c\u6784\u5efa\u5404\u79cd\u8bbe\u5907\u4ee5\u5e2e\u52a9\u4ed3\u9f20\u8fd0\u8f93\u3002\u5176\u4e2d\u5305\u62ec20\u591a\u79cd\u5177\u6709\u7279\u6b8a\u529f\u80fd\u7684\u79ef\u6728\uff0c\u4f8b\u5982\u8d85\u58f0\u6ce2\u4f20\u611f\u5668\u3001\u76f4\u6d41\u7535\u673a\u548c\u96f7\u8fbe\u7b49\u3002\n{1110611966838683}\n\n# \u56fe\u5f62\u5316\u7f16\u7a0b\n- \u8d85\u7ea7\u7b80\u5355\u7684\u56fe\u5f62\u5316\u7f16\u7a0b\uff0c\u8ba9\u4f60\u7684\u521b\u9020\u7269\u201c\u52a8\u201d\u8d77\u6765\u3002\n{7727642343959558}\n\n# \u63a2\u7d226\u5927\u4e3b\u9898\n- \u5728\u5173\u5361\u6a21\u5f0f\u4e2d\u4f60\u5c06\u63a2\u7d22\uff1a\u4e1c\u90e8\u68ee\u6797\u3001\u81ea\u52a8\u5316\u5de5\u5382\u3001\u897f\u90e8\u6208\u58c1\u3001\u9633\u5149\u6d77\u5cb8\u3001\u706b\u5c71\u96a7\u9053\u548c\u5317\u90e8\u96ea\u539f\u3002\n- \u800c\u968f\u7740\u8fdb\u5ea6\u7684\u63a8\u8fdb\uff0c\u4f60\u7684\u4ed3\u9f20\u516c\u53f8\u5c06\u4e0d\u65ad\u53d1\u5c55\u58ee\u5927\uff0c\u4ece\u800c\u89e3\u9501\u66f4\u591a\u65b0\u7684\u8d44\u6e90\u548c\u6311\u6218\u3002\n\n# \u4eab\u53d7\u6c99\u76d2\u6a21\u5f0f\uff01\n- \u4f7f\u7528\u5df2\u89e3\u9501\u7684\u8d44\u6e90\uff0c\u81ea\u7531\u62fc\u88c5\u548c\u7f16\u7a0b\uff0c\u4e0d\u9650\u79ef\u6728\u6570\u91cf\uff01\n{1158778315136178}\n\n# \u6df7\u5408\u73b0\u5b9e\uff1a\u548c\u771f\u5b9e\u4e16\u754c\u4e92\u52a8\uff01\n\n\u8ba9\u4f60\u7684\u521b\u9020\u7269\u8fdb\u5165\u73b0\u5b9e\u4e16\u754c\uff0c\u5c06\u6574\u4e2a\u623f\u95f4\u6253\u9020\u6210\u4e00\u4e2a\u5c5e\u4e8e\u4f60\u81ea\u5df1\u7684\u68a6\u60f3\u4e50\u56ed\uff01\n\u6bd4\u5982\u4f60\u53ef\u4ee5\uff1a\n- \u62fc\u88c5\uff1a\u5728\u771f\u5b9e\u7684\u684c\u5b50\u4e0a\u62fc\u88c5\u79ef\u6728\u3002\n- \u81ea\u5b9a\u4e49\u5730\u5f62\uff1a\u4f7f\u7528\u771f\u5b9e\u7684\u5bb6\u5177\u548c\u865a\u62df\u7684\u5730\u5f62\u6a21\u578b\u4e00\u8d77\uff0c\u4e3a\u5c0f\u8f66\u5728\u771f\u5b9e\u4e16\u754c\u4e2d\u521b\u5efa\u5761\u9053\u3001\u96a7\u9053\u6216\u6865\u6881\u3002\n- \u81ea\u5b9a\u4e49\u6311\u6218\uff1a\u4f60\u7684\u65e0\u4eba\u673a\u80fd\u591f\u7075\u6d3b\u7684\u7a7f\u68ad\u4e8e\u5c4b\u5185\u7684\u5bb6\u5177\u4e4b\u95f4\uff0c\u8fd8\u662f\u4f1a\u649e\u5230\u5bb6\u5177\u800c\u5760\u843d\uff1f\u8003\u9a8c\u7f16\u7a0b\u80fd\u529b\u7684\u65f6\u5019\u5230\u4e86\uff01\n- \u89c2\u770b\u865a\u62df\u751f\u7269\u548c\u771f\u5b9e\u73af\u5883\u95f4\u7684\u4e92\u52a8\uff1a\u6bd4\u5982\u91ce\u725b\u4eec\u5728\u684c\u5b50\u4e0a\u3001\u5730\u677f\u4e0a\u6216\u5e8a\u4e0a\u5954\u8dd1\uff01\n{1096736121390191}\n\n\u52a0\u5165\u201c\u4ed3\u9f20\u8fd0\u8f93\u516c\u53f8\u201d\uff0c\u5728\u8fd9\u65e0\u4e0e\u4f26\u6bd4\u7684\u5efa\u9020\u4e0e\u6a21\u62df\u4f53\u9a8c\u4e4b\u4e2d\uff0c\u5f00\u59cb\u4f60\u7684\u5192\u9669\u4e4b\u65c5\uff01\n\nDiscord: https://discord.gg/NkC8bwQEmK", "short_description": "\u300a\u4ed3\u9f20\u8fd0\u8f93\u516c\u53f8\u300b\u662f\u4e00\u6b3e\u652f\u6301\u201c\u6df7\u5408\u73b0\u5b9e\u201d\u7684\u7269\u7406\u5efa\u9020\u6e38\u620f\u3002\n\u5728\u6e38\u620f\u4e2d\uff0c\u4f60\u53ef\u4ee5\u5efa\u9020\u6295\u77f3\u673a\u3001\u65e0\u4eba\u8d27\u8f66\u3001\u673a\u68b0\u81c2\u548c\u65e0\u4eba\u673a\u7b49\u5404\u5f0f\u5404\u6837\u6709\u8da3\u7684\u53d1\u660e\u521b\u9020\uff0c\u4ee5\u6b64\u5e2e\u52a9\u4ed3\u9f20\u4eec\u514b\u670d\u4e00\u4e2a\u53c8\u4e00\u4e2a\u7684\u6311\u6218\uff0c\u4e0d\u65ad\u5730\u53d1\u5c55\u3001\u58ee\u5927\u7269\u6d41\u7248\u56fe\u3002"}, {"images": {"nodes": [{"file_name": "\u6d77\u62a51008x1440\u5907\u90092.png", "id": "4555037884720399", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330713_4555037891387065_1238394388589432401_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8S4GK56ylX8Q7kNvgF-fmyE&_nc_zt=3&_nc_h