-eXY7dHUFLAUQ&oe=66CD9C4F"}]}, "id": "899318455572484", "locale": "en_US", "screenshots": [{"file_name": "11.png", "id": "1097797137999292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570288_1097797141332625_692184632505995617_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=odCVdPGp6J8Q7kNvgGGVHBr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuLIad-W2wKgCMqwv2do2Ns4mCSSzOCNHAvy1_pWLz4A&oe=66CDA7F1"}, {"file_name": "2-2560x1440.png", "id": "1631350467404912", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035433_1631350470738245_8852123318308072529_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uoK2Z8lcLRgQ7kNvgE5pnf1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAb1YKZupfAZbd449fYA9vVGpoS5f3BKbFDuueEZKOHkQ&oe=66CDBD7A"}, {"file_name": "5-2560x1440.png", "id": "471726615347621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569432_471726618680954_3135093783903181704_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9uWycEYlVCwQ7kNvgERH4ZQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuNUHAnYP8cAsnB9eiZBTRX4x6a1jBBtjInsDLAipUqA&oe=66CDB862"}, {"file_name": "7-2560x1440.png", "id": "1146548799869781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035337_1146548803203114_4232071023953588234_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=seGiFVTxIsYQ7kNvgGd2EZr&_nc_ht=scontent.oculuscdn.com&oh=00_AYApjnok9jRA5TdnnEujXn5cipHIhQRdW64aKLulyPvtow&oe=66CD9EFA"}, {"file_name": "1-2560x1440.png", "id": "999610461677141", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031311_999610465010474_1087177970663193150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rp6voYHMTFkQ7kNvgFRwCu8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBKpsxIVCCXOoCYMCzJSYF-FcpMvVYx647jG3AdqKE4vA&oe=66CDA92B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "503788578775406", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974504_503788582108739_3834053529888765989_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U9m2Hi68ongQ7kNvgG_IuIP&_nc_ht=scontent.oculuscdn.com&oh=00_AYBe6IE9lQGuOKNrvlE_FTlowDeiyV4upcVtYZOEXdD0YA&oe=66CDB013"}, "display_name": "Hamster Inc.", "keywords": [], "long_description": "Welcome to \"Hamster Inc.\"! It's a physics building game that supports \"mixed reality\". In this delightful puzzle game, you'll design, build, and then program machines to overcome challenges!\n\n# Creativity and Logic\n- Based on physical principles and logic, think about how to overcome obstacles and help hamsters improve transportation efficiency.\n{1557136708179895}\n\n# Assembling\n- Design and build a variety of machines with over 60 types of blocks.\n- Over 20 special-function blocks that can be programmed, such as ultrasonic sensors, DC motors, radars and more.\n{327773876776917}\n\n# Graphical programming\n- Super easy! Graphical programming makes your creations \"alive\"!\n{406792278927140}\n\n# Explore 6 unique themes\n- Explore Eastern Forests, Automated factories, Sunshine Coast, Western Gobi, Volcanic Tunnels, and Northern snowfields.\n- As you progress, develop your hamster company and unlock new resources and challenges.\n\n# Enjoy the sandbox mode\n- where you can build and program freely without any limitations on the block amount!\n{971212150879070}\n\n# Mixed Reality\nBring your creations into real world and transform the entire room into a dream paradise: \n- Create custom levels by using real furniture and virtual terrain models, \n- Have your car/drone automatically avoid furniture as it moves around the room,\n- Watch virtual creatures interact with real world: like bison running on tables, floors, or beds!\n{897586709048914}\n\nDiscord: https://discord.gg/NkC8bwQEmK\n", "short_description": "\"Hamster Inc.\" is a physics-based building game that supports \"mixed reality.\"\nIn the game, you can build a variety of interesting inventions such as trebuchets, unmanned trucks, robotic arms, and drones to help the hamsters overcome challenges one after another and continuously develop and 