ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYBLRE9DDOyvzNLWFjgeWuhudONkcvKiNOnZhfjlykxP-w&oe=66E6C30F"}]}, "id": "1382466938967099", "locale": "en_US", "screenshots": [{"file_name": "11.png", "id": "1097797137999292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570288_1097797141332625_692184632505995617_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5DM-MRXuPMsQ7kNvgE3E7Pt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYA5we3cuZCmMbCfh0UCh9bP7s0dYeN7n1p61CxcBg2CPQ&oe=66E6B471"}, {"file_name": "2-2560x1440.png", "id": "1631350467404912", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035433_1631350470738245_8852123318308072529_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5DHIjT9rn-oQ7kNvgHFR2oO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYDkRlplqeL06gl0kO97XDUbrQusRAosipSPVzoK6W0E0g&oe=66E6C9FA"}, {"file_name": "5-2560x1440.png", "id": "471726615347621", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569432_471726618680954_3135093783903181704_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tZdi96MKr4IQ7kNvgHjF5sh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYA4C9tuQWTR_VqTmiegzaNE-d3taxjw69El4-79pPjW6Q&oe=66E6C4E2"}, {"file_name": "7-2560x1440.png", "id": "1146548799869781", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035337_1146548803203114_4232071023953588234_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17x93VXJMdEQ7kNvgG-5rh7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYBXO6wXheHvxZdKNIuGZX2pIeSKY9vm4982sMOGqeqT6g&oe=66E6AB7A"}, {"file_name": "1-2560x1440.png", "id": "999610461677141", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031311_999610465010474_1087177970663193150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IVbUo7e2D3MQ7kNvgFCZMjJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYBO8bvCXz13xyD3x8UG4itGWKA0Nl6yzHrSw-m4XnY-MQ&oe=66E6B5AB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "427799910014327", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254872_427799913347660_1009234490175775686_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DbLP8RUH_egQ7kNvgF5RDiA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYC0O9QaXhCUmLlqqnPSQLZI9B0rixrby3qnkiKC8F6rPw&oe=66E6B14F"}, "display_name": "Hamster Inc.", "keywords": [], "long_description": "Welcome to \"Hamster Inc.\"! It's a physics building game that supports \"mixed reality\". In this delightful puzzle game, you'll design, build, and then program machines to overcome challenges!\n\n# Creativity and Logic\n- Based on physical principles and logic, think about how to overcome obstacles and help hamsters improve transportation efficiency.\n{1557136708179895}\n\n# Assembling\n- Design and build a variety of machines with over 60 types of blocks.\n- Over 20 special-function blocks that can be programmed, such as ultrasonic sensors, DC motors, radars and more.\n{327773876776917}\n\n# Graphical programming\n- Super easy! Graphical programming makes your creations \"alive\"!\n{406792278927140}\n\n# Explore 6 unique themes\n- Explore Eastern Forests, Automated factories, Sunshine Coast, Western Gobi, Volcanic Tunnels, and Northern snowfields.\n- As you progress, develop your hamster company and unlock new resources and challenges.\n\n# Enjoy the sandbox mode\n- where you can build and program freely without any limitations on the block amount!\n{971212150879070}\n\n# Mixed Reality\nBring your creations into real world and transform the entire room into a dream paradise: \n- Create custom levels by using real furniture and virtual terrain models, \n- Have your car/drone automatically avoid furniture as it moves around the room,\n- Watch virtual creatures interact with real world: like bison running on tables, floors, or beds!\n{897586709048914}\n\nDiscord: https://discord.gg/NkC8bwQEmK\n", "short_description": "\"Hamster Inc.\" is a physics-based building game that supports \"mixed reality.\"\nIn the game, you can build a variety of interesting inventions such as trebuchets, unmanned trucks, robotic arms, and drones to help the hamsters overcome challenges one after another and continuously develop and expand the logistics territory."}, {"images": {"nodes": [{"file_name": "\u6d77\u62a52560x1440\u5907\u90097-2+logo-\u4e2d\u6587.png", "id": "3772762123041281", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229464_3772762126374614_5116127187365598796_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wSs9cY9jNJoQ7kNvgHJK2Pp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYDJ3ZIT7zYSVICCh-2QNznjXjhb8N3uizBI_R-GkGKDiw&oe=66E6AD99"}, {"file_name": "icon2.png", "id": "1090290192036087", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575357_1090290195369420_677972531973123807_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5zwXnGKbP98Q7kNvgFrKd3g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYDwO_Ib19vWv16BTqZEJsM_d7_Q3WDq9W6vpqGFC4IYzg&oe=66E6CE4D"}, {"file_name": "hamster inc._logo_ch.png", "id": "857711756373822", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476756_857711759707155_7542117578876813577_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrLf8a9fLUsQ7kNvgGc7Sfl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYDCMve3GK_8C7KRvBw-cu6NE1bqpTTnO-1HWgjGZk2OYw&oe=66E6D0D5"}, {"file_name": "\u6d77\u62a53000x900\u5907\u90094-2+logo-\u4e2d\u6587.png", "id": "815164480578655", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035467_815164483911988_1140454430535728752_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hx1ik1Gh7_YQ7kNvgE8hRg4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUAv-wZru8dpdhS9phqK09X&oh=00_AYCK7G5HDaZTF_6olNVy79PQ7dqi31vOaRiYFBjrgEELI