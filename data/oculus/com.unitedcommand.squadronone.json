/scontent.oculuscdn.com/v/t64.5771-25/75210886_316108410589142_4282773429336314561_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dw5pRPVLWDQQ7kNvgG9gq6z&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyU8mfaGEs6l9YDwWQGMhtEpYuhKOJ2zv6sgGKuOtVkQ&oe=66ED5717"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "328193905850922", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75540509_328193909184255_8316465121614427618_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nctcHjjochcQ7kNvgEn-FuA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMEh9mJ5rpB2xYJizGicsaQ_fIoLk4GbWbp1XOI79huQ&oe=66ED46EB"}, "display_name": "Squadron One", "keywords": [], "long_description": "Squadron One is the free spaceship arcade dogfighting game designed for VR that you've been waiting for.\n\nJoin with friends or meet new friends at the command table. Collect power-ups and outwit your friends to win the crown and celebrate with fireworks.\n\nGame Modes\nMultiplayer deathmatch\nMissions\nPractice against AI\nBasic Training\nChill Mode\nYou can use manual controls or the controller thumbsticks.\n\nBuy ships or earn in-game credits by winning matches. There are two playable ships now and more are on the way. All ships are equally balanced.\n\nTired of battle? Chill out to relaxing music in Free Roam.\n\nNew features are added regularly. Come check it out!", "short_description": "Squadron One is the multiplayer arcade dogfighting space combat experience built for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://unitedcommand.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "United Command", "support_website_url": null, "website_url": "https://squadron.one/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "FIGHTING", "ADVENTURE"], "has_in_app_ads": false, "internet