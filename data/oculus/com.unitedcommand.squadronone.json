1.oculuscdn.com&oh=00_AYCVcTOT6WUE6_v81ULnsBEGMFzVbeeCzljUah_ft5YiTA&oe=6705287B"}, {"file_name": "Screen_2.png", "id": "316108407255809", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210886_316108410589142_4282773429336314561_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8MCteBONYLAQ7kNvgFiJsQZ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsaWhv1foXieDReCKlQHh29Ef0TlmlBEqmREJFDYB6zA&oe=67051217"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "328193905850922", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75540509_328193909184255_8316465121614427618_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J9DNMGMppb4Q7kNvgHLaV0G&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZA4hrwDGH0AC3ES9SJV8Whg-ib60Uh3puNF85PkoArQ&oe=670501EB"}, "display_name": "Squadron One", "keywords": [], "long_description": "Squadron One is the free spaceship arcade dogfighting game designed for VR that you've been waiting for.\n\nJoin with friends or meet new friends at the command table. Collect power-ups and outwit your friends to win the crown and celebrate with fireworks.\n\nGame Modes\nMultiplayer deathmatch\nMissions\nPractice against AI\nBasic Training\nChill Mode\nYou can use manual controls or the controller thumbsticks.\n\nBuy ships or earn in-game credits by winning matches. There are two playable ships now and more are on the way. All ships are equally balanced.\n\nTired of battle? Chill out to relaxing music in Free Roam.\n\nNew features are added regularly. Come check it out!", "short_description": "Squadron One is the multiplayer arcade dogfighting space combat experience built for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://unitedcommand.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "United Command", "support_website_url": null, "website_url": "https://squadron.one/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "