g?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJ6wvm-XuVsQ7kNvgEL-w80&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbE420eXTEHHKgK7mECcpqX-J0c3W8Bn36uw0ka6_wiA&oe=67431EFB"}, {"file_name": "Screen_2.png", "id": "316108407255809", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210886_316108410589142_4282773429336314561_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O1hb3SV7s7oQ7kNvgHPkyIZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9CwG5Vl9yAJ1oCXNMQCRcU5SjEEukc5pxjCrd9bxCmA&oe=67430897"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "328193905850922", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75540509_328193909184255_8316465121614427618_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrNbBUnW0H0Q7kNvgG7VxfE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvzzcmz57AfxM4UJ50cfJMMKHFZ6nHGqQSNGHiWtfVyg&oe=6742F86B"}, "display_name": "Squadron One", "keywords": [], "long_description": "Squadron One is the free spaceship arcade dogfighting game designed for VR that you've been waiting for.\n\nJoin with friends or meet new friends at the command table. Collect power-ups and outwit your friends to win the crown and celebrate with fireworks.\n\nGame Modes\nMultiplayer deathmatch\nMissions\nPractice against AI\nBasic Training\nChill Mode\nYou can use manual controls or the controller thumbsticks.\n\nBuy ships or earn in-game credits by winning matches. There are two playable ships now and more are on the way. All ships are equally balanced.\n\nTired of battle? Chill out to relaxing music in Free Roam.\n\nNew features are added regularly. Come check it out!", "short_description": "Squadron One is the multiplayer arcade dogfighting space combat experience built for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://unitedcommand.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "United Command", "support_website_url": nu