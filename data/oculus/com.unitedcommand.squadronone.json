303186_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vy_aDOYrC4YQ7kNvgGQVntM&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCkv5MChiUhUzRHMQYCuykSIrsT8bs3jXOWYBdlkMdF7A&oe=6728C0FB"}, {"file_name": "Screen_2.png", "id": "316108407255809", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75210886_316108410589142_4282773429336314561_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MdRmd8n4wGIQ7kNvgF3qVfP&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAixx11QROaG_5BI29kL6c7xbINygGoEK-zW6v9B8eLcg&oe=6728AA97"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer cover.png", "id": "328193905850922", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75540509_328193909184255_8316465121614427618_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Q5YBT3MEfQQ7kNvgGw2nM4&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBtpWF1E9_ATLNELI9wzYeyjKVCYWF6KMRG-FQzRI7a7Q&oe=67289A6B"}, "display_name": "Squadron One", "keywords": [], "long_description": "Squadron One is the free spaceship arcade dogfighting game designed for VR that you've been waiting for.\n\nJoin with friends or meet new friends at the command table. Collect power-ups and outwit your friends to win the crown and celebrate with fireworks.\n\nGame Modes\nMultiplayer deathmatch\nMissions\nPractice against AI\nBasic Training\nChill Mode\nYou can use manual controls or the controller thumbsticks.\n\nBuy ships or earn in-game credits by winning matches. There are two playable ships now and more are on the way. All ships are equally balanced.\n\nTired of battle? Chill out to relaxing music in Free Roam.\n\nNew features are added regularly. Come check it out!", "short_description": "Squadron One is the multiplayer arcade dogfighting space combat experience built for Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://unitedcommand.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "United Command", "support_