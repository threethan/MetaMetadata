nImprovements in game engine allow creation of more beautiful scenery containing impressive effects and lightings. Each episode bring you to a new environment filled with suspense.\n\n:. Hell of a Problem .:\nA hell of a problem, more creatures emerge from all around the desolated landscapes to torment you, from acid spitters to tough looking zombies packing strong punches!\n\nFacebook:\nhttps://www.facebook.com/LuandunGames/\nhttp://www.luandungames.com", "short_description": "The original creators of the Zombie Hell game series proudly present you with another game. Be the last stand, no zombie can defeat you once again!"}]}, "developer_name": "Luandun Games Pte. Ltd.", "developer_privacy_policy_url": "http://www.luandungames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Luandun Games Pte. Ltd.", "support_website_url": "http://www.luandungames.com/", "website_url": "http://www.luandungames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "359899352304766"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "412170376003074"}]}, "baseline_offer": {"id": "412170376003074"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1557853200, "status": "PUBLISHED", "id": "412170376003074"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2333561536703722", "version": "1.00"}, "