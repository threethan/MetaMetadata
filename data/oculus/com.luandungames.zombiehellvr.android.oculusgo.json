bx9L62J2QNwQ7kNvgHgSu9f&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAbbP4QJgXV4Nai6cLTOg6WB_3giCagzk1f9imMqkCaWA&oe=672B3C24"}, {"file_name": "migrated_image.png", "id": "525858488133385", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984471_633824093757283_3183075626856742912_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ifM92SoguTUQ7kNvgFAPR35&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQkvPNacdRjB_ziq1Z9KMlFkLOrBK94VG1jO0lT0Zt_A&oe=672B3A58"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ZelsCu", "id": "1232830983551530", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_1232830990218196_3888459297247461376_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-hxVjrhHtgQ7kNvgETNLJU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCiPTgHu1oNAzpOp7eCjdCf7BM3aGRipBSpw-TAm7Y3hw&oe=672B63D3"}, "display_name": "Zombie Hell VR", "keywords": ["zombie", "hell", "shooter", "fps", "arcade"], "long_description": "Zombie Hell VR takes you back for a ride in hell once again, this time round with full immersive VR tech.\n\n:. Story .:\nThe city is a dead town. Zombies are everywhere, almost everyone you know is dead, but at least you still have your guns with you. Will you survive Zombie Hell once again?\n\n:. Snappy Gunplay .:\nThe original excitement of firing an actual weapon has been retained. Gunshots are snappy, and each shots connect beautifully. Weapon models has also being enhanced to look better. It's a hell of a gun time.\n\n:. Beautiful Levels .:\nImprovements in game engine allow creation of more beautiful scenery containing impressive effects and lightings. Each episode bring you to a new environment filled with suspense.\n\n:. Hell of a Problem .:\nA hell of a problem, more creatures emerge from all around the desolated landscapes to torment you, from acid spitters to tough looking zombies packing strong punches!\n\nFacebook:\nhttps://www.facebook.com/LuandunGames/\nhttp://www.