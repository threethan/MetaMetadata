&oe=6728C8A9"}, {"file_name": "migrated_image.png", "id": "197227261710024", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38982702_415940889190205_3103934536531050496_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lOv78-NTQPkQ7kNvgHga6fb&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBpsC-rDXdH7U5ZH1-tvHKz-_G06KaCjB43ibXErbNMeA&oe=67289924"}, {"file_name": "migrated_image.png", "id": "525858488133385", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38984471_633824093757283_3183075626856742912_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2OgBRsqmSicQ7kNvgFoHY1R&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCru4gqmD2cD7ZutndrkXciQCyAT7lg8IQJZ9bEfQHllg&oe=6728CF98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ZelsCu", "id": "1232830983551530", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974840_1232830990218196_3888459297247461376_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-hxVjrhHtgQ7kNvgEe2FC0&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYATdbicnVifne8DuWsaRXjuB3YJIW78jV1asKok7872RA&oe=6728C0D3"}, "display_name": "Zombie Hell VR", "keywords": ["zombie", "hell", "shooter", "fps", "arcade"], "long_description": "Zombie Hell VR takes you back for a ride in hell once again, this time round with full immersive VR tech.\n\n:. Story .:\nThe city is a dead town. Zombies are everywhere, almost everyone you know is dead, but at least you still have your guns with you. Will you survive Zombie Hell once again?\n\n:. Snappy Gunplay .:\nThe original excitement of firing an actual weapon has been retained. Gunshots are snappy, and each shots connect beautifully. Weapon models has also being enhanced to look better. It's a hell of a gun time.\n\n:. Beautiful Levels .:\nImprovements in game engine allow creation of more beautiful scenery containing impressive effects and lightings. Each episode bring you to a new environment filled with suspense.\n\n:. Hell of a Problem .:\nA hell of a problem, more creatures emerge from all around the desolated landscapes to torment you, from acid spitters to tough looking zombies packing strong punches!\n\nFacebook:\nhttps://www.facebook.com/LuandunGames/\nhttp://www.luandungames.com", "short_description": "The original creators of the Zombie Hell game series proudly present you with another game. Be the last stand, no zombie can defeat you once again!"}]}, "developer_name": "Luandun Games Pte. Ltd.", "developer_privacy_policy_url": "http://www.luandungames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Luandun Games Pte. Ltd.", "support_website_url": "http://www.luandungames.com/", "website_url": "http://www.luandungames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "359899352304766"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "412170376003074"}]}, "baseline_offer": {"id": "412170376003074"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1557853200, "status": "PUBLISHED", "id": "412170376003074"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2333561536703722", "version": "1.00"}, "id": "273564976586388", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__t