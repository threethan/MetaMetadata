0xrpeEvOPQIQ7kNvgGj9CSE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApoSbUBI5-c2v4ACgR5opDvbDTXr9aTIOODfEsG_L5GA&oe=67235324"}, {"file_name": "migrated_image.png", "id": "525858488133385", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984471_633824093757283_3183075626856742912_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u1gC1vLKBhMQ7kNvgGdvFZP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBvY3W8RvkH67hmJW9nRlDHKz5T_AEcwlSqeoJKFtGlHg&oe=67238998"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ZelsCu", "id": "1232830983551530", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974840_1232830990218196_3888459297247461376_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzUZwVXsDOEQ7kNvgG9ZTXM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpfascz5blDGYWDF82igyZn7CO63L2yFPYzbpeWPZJRA&oe=67237AD3"}, "display_name": "Zombie Hell VR", "keywords": ["zombie", "hell", "shooter", "fps", "arcade"], "long_description": "Zombie Hell VR takes you back for a ride in hell once again, this time round with full immersive VR tech.\n\n:. Story .:\nThe city is a dead town. Zombies are everywhere, almost everyone you know is dead, but at least you still have your guns with you. Will you survive Zombie Hell once again?\n\n:. Snappy Gunplay .:\nThe original excitement of firing an actual weapon has been retained. Gunshots are snappy, and each shots connect beautifully. Weapon models has also being enhanced to look better. It's a hell of a gun time.\n\n:. Beautiful Levels .:\nImprovements in game engine allow creation of more beautiful scenery containing impressive effects and lightings. Each episode bring you to a new environment filled with suspense.\n\n:. Hell of a Problem .:\nA hell of a problem, more creatures emerge from all around the desolated landscapes to torment you, from acid spitters to tough looking zombies packing strong punches!\n\nFacebook:\nhttps://www.facebook.com/LuandunGames/\nhttp://www.luandungames.com", "short_description": "The original creators of the Zombie Hell game series proudly present you with another game. Be the last stand, no zombie can defeat you once again!"}]}, "developer_name": "Luandun Games Pte. Ltd.", "developer_privacy_policy_url": "http://www.luandungames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Luandun Games Pte. Ltd.", "support_website_url": "http://www.luandungames.com/", "website_url": "http://www.luandungames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "359899352304766"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982683_434307810674673_1980486763956666368_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3cAKstcu-IQQ7kNvgFYqKzs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5izb9j3X7BD97U0BXqllDfNx9oruH7QXp2lvIGRoEXA&oe=67236388"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Zombie Hell VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1557853200, "lastRevision": {"nodes": [{"id": "107463523540558", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1990696800990199", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "