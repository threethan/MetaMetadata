18868274465303812_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0SEcH9xMjqQQ7kNvgHi74g0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AD3lA6gi9stAb_q4hiXOoM7&oh=00_AYA0o3Pm5jh0QxvTJ2B5TblUIN1OcozRE6ehsl4SO9H0jw&oe=66EC1DE4"}, {"file_name": "scr26.png", "id": "960867918241251", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_960867921574584_7574174042497492646_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QAPWvN1cP7UQ7kNvgF-uqia&_nc_ht=scontent.oculuscdn.com&_nc_gid=AD3lA6gi9stAb_q4hiXOoM7&oh=00_AYBlEUclvU_hgBg_LpmpxYFvfSZSzUZQ03nMLAFy3XoRtw&oe=66EC0EB3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Realm of the Fallen: Onslaught", "keywords": [], "long_description": "Assume the role of a resurrected warrior in another dimension where a once-flourishing civilization was eradicated by a sinister interdimensional being. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes. Realm of the Fallen: Onslaught is a free version of the game, Realm of the Fallen. This version includes the full Onslaught/Wave Mode.", "short_description": "Enter Realm of the Fallen: Onslaught, where the action never stops and the challenges never end. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes."}]}, "developer_name": null, "developer_privacy_policy_url": "https://realmofthefallen.com/rotf-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Virtua