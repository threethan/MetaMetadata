18868274465303812_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C4HAAODNiDYQ7kNvgH0IcjZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AODKAjds4GbVKLDKkY2TGaY&oh=00_AYA9uLz5AY9qtbV7RH3783osHyGU8aVuO3E5hGWON-939A&oe=66ED6F64"}, {"file_name": "scr26.png", "id": "960867918241251", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_960867921574584_7574174042497492646_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QAPWvN1cP7UQ7kNvgH8YF5z&_nc_ht=scontent.oculuscdn.com&_nc_gid=AODKAjds4GbVKLDKkY2TGaY&oh=00_AYAj2dODc4YRYdu2ycEWo_6-jOxYJEwSL2fRh_NLM9xmxA&oe=66ED6033"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Realm of the Fallen: Onslaught", "keywords": [], "long_description": "Assume the role of a resurrected warrior in another dimension where a once-flourishing civilization was eradicated by a sinister interdimensional being. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes. Realm of the Fallen: Onslaught is a free version of the game, Realm of the Fallen. This version includes the full Onslaught/Wave Mode.", "short_description": "Enter Realm of the Fallen: Onslaught, where the action never stops and the challenges never end. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes."}]}, "developer_name": null, "developer_privacy_policy_url": "https://realmofthefallen.com/rotf-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Virtua