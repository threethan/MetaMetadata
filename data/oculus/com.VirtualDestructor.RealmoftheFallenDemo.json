872_8118868274465303812_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aElsZFs0Ia8Q7kNvgH_1Od3&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApQ-C1K-MSkVGPwYe1EG0Ar&oh=00_AYA5M18oNiKtdoGKWtyBZVqtsWTki1fXw2vpnNb2RhLZgw&oe=66E04064"}, {"file_name": "scr26.png", "id": "960867918241251", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_960867921574584_7574174042497492646_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1KhuYowqlwgQ7kNvgFyDfmk&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApQ-C1K-MSkVGPwYe1EG0Ar&oh=00_AYC5k6cGDKUdVzV_mfSaxxh4DQ2sQrDcrroLjFlYTgmceg&oe=66E03133"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Realm of the Fallen: Onslaught", "keywords": [], "long_description": "Assume the role of a resurrected warrior in another dimension where a once-flourishing civilization was eradicated by a sinister interdimensional being. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes. Realm of the Fallen: Onslaught is a free version of the game, Realm of the Fallen. This version includes the full Onslaught/Wave Mode.", "short_description": "Enter Realm of the Fallen: Onslaught, where the action never stops and the challenges never end. Battle wave after wave of enemies in arena-like levels, using all of your skill and strategy to emerge victorious. As you progress through the game, you'll be teleported to different arenas, each more challenging than the last. You will become more powerful, unlocking new abilities and skills that will help you take on even the toughest foes."}]}, "developer_name": null, "developer_privacy_policy_url": "https://realmofthefallen.com/rotf-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "