VlLm52rbARKcJXJiZrcPNGiDA&oe=66E95255"}, {"file_name": "migrated_image.png", "id": "222243025593065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410199_149689168862817_1900157273360039936_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2DcmiVNMhXEQ7kNvgERCA15&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7q0EtP0wAMj5sZsKVnYEas&oh=00_AYDb2-jKWyJP8mKdmpOzIkuP7L8UKzX5GilXnshesps3pQ&oe=66E974C5"}, {"file_name": "migrated_image.png", "id": "156133872207577", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12602069_408846176128110_1622930242643427328_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kjUeWKfqKwEQ7kNvgHKD3fG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7q0EtP0wAMj5sZsKVnYEas&oh=00_AYBSdOPGKlGZnJqHrDOLekYv4QnzDVXF8fsi5xWDC4KDYg&oe=66E95F0A"}, {"file_name": "migrated_image.png", "id": "615913599255587", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139431_573834552822232_4372664014593851392_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fHz1sz1KhqoQ7kNvgElZ4Eo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7q0EtP0wAMj5sZsKVnYEas&oh=00_AYAGA3pbzV8WIxXtTtDQSO5_RhE8ObuIFb1Es3MNbp5Z7A&oe=66E97F9A"}, {"file_name": "migrated_image.png", "id": "2999993196920529", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12602284_1826826800862753_385098432890535936_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YN2iTmeOOTkQ7kNvgF6K2cr&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7q0EtP0wAMj5sZsKVnYEas&oh=00_AYARziGeQkJLt5uUYSEM1brjiUqCm4YQ-OpSXoM-JqLAag&oe=66E95C7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_landscape.png", "id": "537702206620263", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162716_537702209953596_7309402616822235136_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9QTdX9iU7PQQ7kNvgHXgAyy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7q0EtP0wAMj5sZsKVnYEas&oh=00_AYALj-88rcPQ8-dscDpGg1VfhEE6PndzGd-s98AWhVKQWg&oe=66E96EB9"}, "display_name": "Sayonara Umihara Kawase VR", "keywords": ["puzzle", "action"], "long_description": "Umihara Kawase is the name of our backpacking, Japanese cuisine chef heroine armed with a fishing rod, elastic fishing line, and a fishing hook. Face fish-like enemies, conveyor belts, spikes, watery pits and more. Collect items, and find your way to the end of each level. The deeper into this dream-like world that you venture, the more challenging the solutions and the greater the time pressure becomes. Along the way, look out for shortcuts and secret exits, and unlock next stages!\n\nThe elasticity of Umihara\u2019s fishing line sets the apart from other games, giving unprecedented levels of mobility and discovery. Tightening the line or giving lots of slack can be the difference between success or failure. The elastic nature of the fishing line allows the player to stretch down to otherwise unreachable areas or be catapulted upwards.", "short_description": "Umihara Kawase is a girl who uses a fishing hook as a grappling hook. You\u2019ll need quick reflexes to swing your way through the branching surreal environments. Use your brains to figure out the best way through. Along the way, look out for shortcuts and secret exits, and unlock next stages!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.saizensen.co.jp/kawase/sayonara_gear_vr01.pdf", "developer_terms_of_service_url": "http://www.saizensen.co.jp/kawase/sayonara_gear_vr01.pdf", "publisher_name": "Studio Saizensen Co.,Ltd.", "support_website_url": null, "website_url": "http://www.saizensen.co.jp/kawase/sayonara_gear_vr01.pdf", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "en_GB", "fr", "de", "it", "pt_BR