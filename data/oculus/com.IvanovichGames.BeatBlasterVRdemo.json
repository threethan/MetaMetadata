0a&_nc_ohc=THnTyw7N0f0Q7kNvgG7q4AG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHHS5Qhuf-dOtCny-Y6_xJLpjLrUitNIwEABDyBaoCbg&oe=66D8426D"}, {"file_name": "screen2.png", "id": "741433226809114", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974819_741433230142447_8441143815888036981_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kOye-M6Y53IQ7kNvgEXavdW&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8rfE8m2EHe_Nniy_3qBJbnNnKVDIL0IOzK2-9PQQUbg&oe=66D836EF"}, {"file_name": "screen3.png", "id": "1350020995358073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_1350020998691406_8282238470663016331_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2HXJv45pl-cQ7kNvgE1LK_O&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYm4B0v2fzK2Fg72DReaAk0AQ09AuwIoagwMw-sqAIIA&oe=66D83725"}, {"file_name": "screen4.png", "id": "247834320144081", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982548_247834323477414_8094020518288850308_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mMEDEQu3sfwQ7kNvgGJxGih&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0Sa3ZRe9krkE78GPIO3_lxN0hoVIQN-O9upyEJ7VhOA&oe=66D84ED9"}, {"file_name": "screen5.png", "id": "126955279243438", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984461_126955285910104_2757384090958905395_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uez3ZT9ADEUQ7kNvgErlfXA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjo4OEL5CebRUETvqEbNR1nYv7Lk8fmy0nQo1fgZsbIA&oe=66D854ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video.png", "id": "1145519002574714", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_1145519009241380_3483380882314472080_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BKeVK7-rVVAQ7kNvgEqaJot&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxbNpFntYRVnZdD2iVlf3MTq4CZ5qsfkUkOwNCOvG_uQ&oe=66D8431F"}, "display_name": "Beat Blaster DEMO", "keywords": [], "long_description": "Beat Blaster is a VR game of shooting, running, and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge.\n\n30 SONGS & AMBISONIC AUDIO\nEach level introduces a novelty, and all the games are different thanks to the intelligent generation of levels. \nAmbisonic sound lets you experience the music in an entirely new way.\n\n3 WAYS OF MOVEMENT\nYou can choose between the classic VR controller, tilting the head, or the intuitive and original control based on the head's movement. \n\nNO MOTION SICKNESS\nBeat Blaster is a VR game with a high-speed component. But all the game moves are designed without rotating the player, thus minimizing the probability of motion sickness.\n\nEASY RULES\nTo clear a level, you must reach the end of the song without dying. You have a Blaster with infinite ammunition and single life to dodge or kill all the enemies that will appear to the music's rhythm.", "short_description": "Beat Blaster is a VR game of shooting, running, and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ivanovichgames.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Ivanovich Games", "support_website_url": "https://www.ivanovichgames.com/web/contact/", "website_url": "https://www.ivanovichgames.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SHOOTER", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ko", "en", "pt_BR", "it", "fr", "es", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH