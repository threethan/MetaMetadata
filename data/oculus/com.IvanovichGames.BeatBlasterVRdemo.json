EKtVOCclYA&oe=672203E3"}]}, "id": "1535006877420231", "locale": "en_US", "screenshots": [{"file_name": "screen1.png", "id": "416045492836328", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003242_416045496169661_3085076221427104579_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3wusikNnDM0Q7kNvgGGiVeK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKuwtCPGN93HF0FM6O58er4PkWuIa17BYDIKPFCRC5-A&oe=6722166D"}, {"file_name": "screen2.png", "id": "741433226809114", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974819_741433230142447_8441143815888036981_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7wEW-7eGbD4Q7kNvgEvYAd-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6W_rGVxukBBsUiaUFgqKb7MLnx0zzscSkhrxbFMLYHQ&oe=67220AEF"}, {"file_name": "screen3.png", "id": "1350020995358073", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_1350020998691406_8282238470663016331_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dr0cZPIbEUwQ7kNvgHJ05mY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqIiAlzaZYrWayKnvDeeFTEhAeqrLflg-yCrbqEdnWXw&oe=67220B25"}, {"file_name": "screen4.png", "id": "247834320144081", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982548_247834323477414_8094020518288850308_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GVnDXKWvuK0Q7kNvgGYIJt6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcc8rZxRLJa1MiUbQF8wJUrnxPnaXjw0w9gAmztB9ilQ&oe=672222D9"}, {"file_name": "screen5.png", "id": "126955279243438", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984461_126955285910104_2757384090958905395_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kNki1Qu9iLMQ7kNvgFQWvHo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYEwWwG7981e1aCLNtbngxiaS7meaJGdtumGP3tU17TA&oe=672228ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video.png", "id": "1145519002574714", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_1145519009241380_3483380882314472080_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a18zD9bXIccQ7kNvgEqTwMP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOEHAz8wYk6dfOOrbVP5ECMwYcJP3Ehqm3L0qGGfY48Q&oe=6722171F"}, "display_name": "Beat Blaster DEMO", "keywords": [], "long_description": "Beat Blaster is a VR game of shooting, running, and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge.\n\n30 SONGS & AMBISONIC AUDIO\nEach level introduces a novelty, and all the games are different thanks to the intelligent generation of levels. \nAmbisonic sound lets you experience the music in an entirely new way.\n\n3 WAYS OF MOVEMENT\nYou can choose between the classic VR controller, tilting the head, or the intuitive and original control based on the head's movement. \n\nNO MOTION SICKNESS\nBeat Blaster is a VR game with a high-speed component. But all the game moves are designed without rotating the player, thus minimizing the probability of motion sickness.\n\nEASY RULES\nTo clear a level, you must reach the end of the song without dying. You have a Blaster with infinite ammunition and single life to dodge or kill all the enemies that will appear to the music's rhythm.", "short_description": "Beat Blaster is a VR game of shooting, running, and dodging where everything happens to the music rhythm. An original mix of styles where each game will offer you a new challenge."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ivanovichgames.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Ivanovich Games", "support_website_url": "https://www.ivanovichgames.com/web/contact/", "website_url": "https://www.ivanovichgames.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "459781504968480"}], "external_subsc