253422", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162694_154963885241438_3520190118180683776_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x83bHlxVemYQ7kNvgHmcEhg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD66heYGXbJJU1Xa0P_D9WuLOOPZPR1s8rsBZq0EL8Tvw&oe=6713B48D"}]}, "id": "692443744863474", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "2794720580610062", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162718_1576290842438024_6608560174267367424_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0w-s3wUEsP4Q7kNvgEss8c6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdO4ZM96CC6xO9xMZJ6JIJwS97yHWW33q8ffddQODW4g&oe=67138902"}, {"file_name": "migrated_image.png", "id": "844425482724351", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162716_147560829187865_2892620358861455360_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IB3c3wozumAQ7kNvgF6b7xb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCAzZ4bP04KKr86W8_hlRtsgaHBTd_Rkbceuic2pgmsTg&oe=6713B286"}, {"file_name": "migrated_image.png", "id": "205380830741731", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162718_1453028484814263_4618537509171757056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EwRFzWrhTQAQ7kNvgFtTqiH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn26YNnk-n-udzBFUllzDb_Wk6eq7HI62lsZjHTK1ORA&oe=67138BED"}, {"file_name": "migrated_image.png", "id": "203088174252498", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162682_142709443024684_6787841205943140352_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ej-8S-y9qwgQ7kNvgHOHMTQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAf8a8ijOCdnzXm7xL30affG6Xav6r6waxj4NGIKN74Q&oe=67138773"}, {"file_name": "migrated_image.png", "id": "202815661040262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162732_1674016092620383_3343980898654617600_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l1bvluOMlgcQ7kNvgFYjxFY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlwL6eACm9MaOA3LxU6kx_aBIzEGJonqxpaPobsG7ZNg&oe=67139FD8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "In the Cloud: VR Afterlife Gear", "keywords": ["InTheCloud", "Afterlife", "Future", "NoraArnezeder", "JustinChatwin"], "long_description": "In the Cloud VR Afterlife begins with Theo James (Tomiwa Edun), the genius inventor behind Cloud Inc., as he welcomes you to the Cloud and walks you through the technology that allows him to map the human brain. After introducing the Cloud, James will begin to ask you a series of questions to dig deep into your soul and better understand your morality. With every answer, a slim crack widens encompassing a visually stimulating journey to the other side to reveal your inner truth that may or may not be what it seems. The VR experience, based off of the Crackle Original Movie, In the Cloud, is a spectacular and mystical ride built with live-action actors, visually stunning special effects and 360-sound.", "short_description": "The waiting room of the Afterlife"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.futurelighthouse.com/", "developer_terms_of_service_url": "http://www.futurelighthouse.com/", "publisher_name": "Future Lighthouse", "support_website_url": null, "website_url": "http://www.futurelighthouse.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "450657583366374"}, "review