c=XIfl8aZ1UdoQ7kNvgEPonCn&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtv4Ctu4NIp5Jqp8_-X_ksrrEiShBT6EPBot04bgz2Cw&oe=66D2F26D"}, {"file_name": "migrated_image.png", "id": "637032750453112", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162682_142709443024684_6787841205943140352_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sC66ZGi5VVkQ7kNvgGkSt1i&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbf-8B9tUMlwRy8XE1KlfU935-YJmoaYQnDplnPO3WrA&oe=66D2EDF3"}, {"file_name": "migrated_image.png", "id": "217095079700059", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162732_1674016092620383_3343980898654617600_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3YCuuSGRUvcQ7kNvgFrYvf3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZUxLaijci_KjWVVld9kp14F2vad4UtSUVWfIfQPbfHA&oe=66D30658"}, {"file_name": "migrated_image.png", "id": "211814026546536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162718_1576290842438024_6608560174267367424_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h_XHTVWgL4sQ7kNvgH1x4Uh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdzyG78CwUFiGCg9TDYNzKtuo092i-Pvlvppa0actTdg&oe=66D2EF82"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1643669579028609", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162711_1643669585695275_2787966308099031040_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F3TSWwfWj_AQ7kNvgGfu__9&_nc_ht=scontent.oculuscdn.com&oh=00_AYBy1eiA_hRpJ6kXLt78oNSJma4B2yEvt1ujJd4JJ7GNWA&oe=66D31833"}, "display_name": "In the Cloud: VR Afterlife Gear", "keywords": ["InTheCloud", "Afterlife", "Future", "NoraArnezeder", "JustinChatwin"], "long_description": "An early dev interface lights up. We are up in an early build of CLOUD Inc., the groundbreaking tech that allows the user to upload their consciousness to digital permanence. The soothing voice of Theo welcomes us as he materializes as a point-cloud hologram. He speaks about the technology which allowed him to map the human brain. He shows us a picture of the departed Doc Wolfe, his mentor, a man who gave his life to the research.\n\nAfter introducing the CLOUD and the possibility of uploading your consciousness he pivots: \n\n\u201cBut what about the journey? What we found is that DMT is a particularly important part of the process. This is a chemical our brains release the moment we are born and the moment we die. Some say it\u2019s the GOD chemical. The closest thing we achieved to simulating this process is what you are about to experience. We call it AFTERLIFE [+]\u201d\n \nWhen he finishes the speech the screens fade and we are left in a dark limbo with a slim, but infinitely tall, crack of light.", "short_description": "The waiting room of the Afterlife"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.futurelighthouse.com/", "developer_terms_of_service_url": "http://www.futurelighthouse.com/", "publisher_name": "Future Lighthouse", "support_website_url": null, "website_url": "http://www.futurelighthouse.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["SIMULATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "347979367173572"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2057615424484099"}]}, "baseline_offer": {"id": "2057615424484099"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1517508000, "status": "PUBLISHED", "id": "2057615424484099"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {