nt-iad3-2.oculuscdn.com/v/t64.5771-25/11162716_147560829187865_2892620358861455360_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C1SLy6aNTJMQ7kNvgGcIKyu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWTY_poj7xB6Pp2JiPI1QyyjAMQ7HYbWpTJe-HerlD2Q&oe=674C6306"}, {"file_name": "migrated_image.png", "id": "818320835345669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162718_1453028484814263_4618537509171757056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=blJddeRn6AEQ7kNvgFQyGwC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTJF7Dt7Q--iIKY8sUuVJLFL3sPmPtQEsrmUMup9ntrA&oe=674C3C6D"}, {"file_name": "migrated_image.png", "id": "637032750453112", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162682_142709443024684_6787841205943140352_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KsbUUQwdHFYQ7kNvgGgDjjT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBiyCKis06bhX0Mb31cASqfZdmXfGmtJaAOASMZRTY5kg&oe=674C37F3"}, {"file_name": "migrated_image.png", "id": "217095079700059", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162732_1674016092620383_3343980898654617600_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IEE-0_7Q-osQ7kNvgHIpWco&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYNoxn9YJXDrTkCdVrNxDCRmDznpquO4ju5Xv8TXKjEA&oe=674C5058"}, {"file_name": "migrated_image.png", "id": "211814026546536", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162718_1576290842438024_6608560174267367424_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0b-tuMMKhXAQ7kNvgFRlvqs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD49ZWH7EywLW10MxKjR2-fdXn9ea8j_H82zYlBY2qhCg&oe=674C3982"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1643669579028609", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162711_1643669585695275_2787966308099031040_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cjchXGIVSYQQ7kNvgF9IQmO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8uL7PtvnC8BeE2iYOYgjMVt4HjBxoD_VWQPkEXyrNww&oe=674C6233"}, "display_name": "In the Cloud: VR Afterlife Gear", "keywords": ["InTheCloud", "Afterlife", "Future", "NoraArnezeder", "JustinChatwin"], "long_description": "An early dev interface lights up. We are up in an early build of CLOUD Inc., the groundbreaking tech that allows the user to upload their consciousness to digital permanence. The soothing voice of Theo welcomes us as he materializes as a point-cloud hologram. He speaks about the technology which allowed him to map the human brain. He shows us a picture of the departed Doc Wolfe, his mentor, a man who gave his life to the research.\n\nAfter introducing the CLOUD and the possibility of uploading your consciousness he pivots: \n\n\u201cBut what about the journey? What we found is that DMT is a particularly important part of the process. This is a chemical our brains release the moment we are born and the moment we die. Some say it\u2019s the GOD chemical. The closest thing we achieved to simulating this process is what you are about to experience. We call it AFTERLIFE [+]\u201d\n \nWhen he finishes the speech the screens fade and we are left in a dark limbo with a slim, but infinitely tall, crack of light.", "short_description": "The waiting room of the Afterlife"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.futurelighthouse.com/", "developer_terms_of_service_url": "http://www.futurelighthouse.com/", "publisher_name": "Future Lighthouse", "support_website_url": null, "website_url": "http://www.futurelighthouse.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["SIMULATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supporte