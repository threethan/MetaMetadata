": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "1637761939705807", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974484_290496828238329_7372871547578482688_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JRIQc4W3vhcQ7kNvgHi7iM_&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCTUilrEIiV_QyFog6uYRtq6sBwkA6sDkqaW9Q9kG_gWQ&oe=670FB54A"}, {"file_name": "migrated_image.png", "id": "921952634889059", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75222937_543176542938807_2654732179149422592_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vpaYzF8ai-EQ7kNvgFILZOq&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDoElbVn6Mhhxh_6zkyReuQzSdDS7iDLV93h-H5Z9U2Mg&oe=670F9157"}, {"file_name": "migrated_image.png", "id": "658281051667324", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974508_715921338768728_2141906078915362816_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2dl-RBgAoZ8Q7kNvgERx8NI&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCkFWT9wEQHPBih98ZcCWs7qD86y1YdDixVmtv2EHr6pQ&oe=670FBC89"}, {"file_name": "migrated_image.png", "id": "529143797801545", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974549_2026771984055710_6855105693788143616_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ogJ2b5fhjrkQ7kNvgHFreC8&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDCVZfFOGBaxT5ZhpMPR3g5ukrm1ZDB3BpQonmQsdpa_w&oe=670F896D"}, {"file_name": "migrated_image.png", "id": "514040819516173", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982592_1861135210673175_7534725856824918016_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJnymFOeXE0Q7kNvgH_usPY&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBZchRrsvW1INuBkXZTEe_NbMUREK4MWDJAue9DZ-gOgg&oe=670F89D3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/kKS07V", "id": "489900695058613", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974691_489900698391946_4969603158079700992_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZ2aPAXdTegQ7kNvgEWdxTL&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD4iu2BbFZrnss4thfTKcd5fJ-gpUsWK8Gs9DRx2hBAtg&oe=670FB047"}, "display_name": "Smash The Beats", "keywords": ["music", "rhythm", "beats", "smash", "saber"], "long_description": "Smash The Beats is an energetic music game that will surround you with music. Come face to face with the beats. Play with 31 handcrafted tracks available in the game or choose your own MP3.\nAll you need to do is to feel the music and smash incoming cubes exactly with the beat.\nBlocks with the blue arrow smash with the blue tool, for orange arrows use the orange tool. How to change the color? Just press the trigger.\n\nIt\u2019s up to you if your controller changes into shield, hammer or sword. \nTry them all to smash the bricks.\nYou can play easy, normal mode or if you like challenges choose advance one.\n \nSo put on your GO and start the fun with smashing beats.\nIf you like energetic music, rhythms  Smash The Beats is for you!", "short_description": "Smash The Beats is an energetic rhythm VR game. Smash the blocks in time with the music. It\u2019s up to you if your controller changes into shield, hammer or sword.  Play with 31 handcrafted tracks available in the game or choose your own MP3. Put on your GO  and start the fun with smashing beats."}]}, "developer_name": "NiVision", "developer_privacy_policy_url": "https://sites.google.com/view/nivision-privacy-policy", "developer_terms_of_service_url": "https://nivisionag.wixsite.com/smashthebeats/eula", "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://nivisionag.wixsite.com/smashthebeats", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "reco