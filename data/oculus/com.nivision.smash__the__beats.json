": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "1637761939705807", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974484_290496828238329_7372871547578482688_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JRIQc4W3vhcQ7kNvgG3_k4X&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7BZcWzXSHPIYNqbEDlnhLynJGKYOI6fpD-2Sgf-xwrw&oe=670D124A"}, {"file_name": "migrated_image.png", "id": "921952634889059", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75222937_543176542938807_2654732179149422592_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yTx8CIpQB6kQ7kNvgEXsMYk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkNMDoEGen2-DrmUIOpj4CHi47YBm-pUskSszzMIeBlw&oe=670CEE57"}, {"file_name": "migrated_image.png", "id": "658281051667324", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974508_715921338768728_2141906078915362816_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d2lcZiL-oUgQ7kNvgEMfco-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOQmlHQbym2SLIwSzjxd905yH2CWIEgeNL1oHvswLg2Q&oe=670D1989"}, {"file_name": "migrated_image.png", "id": "529143797801545", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974549_2026771984055710_6855105693788143616_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ogJ2b5fhjrkQ7kNvgGt1hr5&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZxUeguHLSL7O2CRjgKwZNbyWRt79OS7liYTrZJF3cbw&oe=670D1EAD"}, {"file_name": "migrated_image.png", "id": "514040819516173", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982592_1861135210673175_7534725856824918016_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jFEsBi4GPx0Q7kNvgG3HMaB&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJPeYCpxTmo_4p_0zqKe1aoztERvDYxW7mg5EdlbM-QQ&oe=670D1F13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/kKS07V", "id": "489900695058613", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974691_489900698391946_4969603158079700992_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ony5b_YueYMQ7kNvgHEVfsZ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGkbzYdcj-WOti5N0FJcAbPuycLMLj-hkSyScdam2RVQ&oe=670D0D47"}, "display_name": "Smash The Beats", "keywords": ["music", "rhythm", "beats", "smash", "saber"], "long_description": "Smash The Beats is an energetic music game that will surround you with music. Come face to face with the beats. Play with 31 handcrafted tracks available in the game or choose your own MP3.\nAll you need to do is to feel the music and smash incoming cubes exactly with the beat.\nBlocks with the blue arrow smash with the blue tool, for orange arrows use the orange tool. How to change the color? Just press the trigger.\n\nIt\u2019s up to you if your controller changes into shield, hammer or sword. \nTry them all to smash the bricks.\nYou can play easy, normal mode or if you like challenges choose advance one.\n \nSo put on your GO and start the fun with smashing beats.\nIf you like energetic music, rhythms  Smash The Beats is for you!", "short_description": "Smash The Beats is an energetic rhythm VR game. Smash the blocks in time with the music. It\u2019s up to you if your controller changes into shield, hammer or sword.  Play with 31 handcrafted tracks available in the game or choose your own MP3. Put on your GO  and start the fun with smashing beats."}]}, "developer_name": "NiVision", "developer_privacy_policy_url": "https://sites.google.com/view/nivision-privacy-policy", "developer_terms_of_service_url": "https://nivisionag.wixsite.com/smashthebeats/eula", "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://nivisionag.wixsite.com/smashthebeats", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "reco