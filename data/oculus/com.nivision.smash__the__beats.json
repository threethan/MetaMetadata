eywords": ["music", "rhythm", "beats", "smash", "saber"], "long_description": "Smash The Beats is an energetic music game that will surround you with music. Come face to face with the beats. Play with 31 handcrafted tracks available in the game or choose your own MP3.\nAll you need to do is to feel the music and smash incoming cubes exactly with the beat.\nBlocks with the blue arrow smash with the blue tool, for orange arrows use the orange tool. How to change the color? Just press the trigger.\n\nIt\u2019s up to you if your controller changes into shield, hammer or sword. \nTry them all to smash the bricks.\nYou can play easy, normal mode or if you like challenges choose advance one.\n \nSo put on your GO and start the fun with smashing beats.\nIf you like energetic music, rhythms  Smash The Beats is for you!", "short_description": "Smash The Beats is an energetic rhythm VR game. Smash the blocks in time with the music. It\u2019s up to you if your controller changes into shield, hammer or sword.  Play with 31 handcrafted tracks available in the game or choose your own MP3. Put on your GO  and start the fun with smashing beats."}]}, "developer_name": "NiVision", "developer_privacy_policy_url": "https://sites.google.com/view/nivision-privacy-policy", "developer_terms_of_service_url": "https://nivisionag.wixsite.com/smashthebeats/eula", "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://nivisionag.wixsite.com/smashthebeats", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], 