uluscdn.com&oh=00_AYB1hpE81mhWZgczIqWDWqi_xp_KcmvDZN5WuBx5ZQGe3A&oe=675817B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/OKPFvg", "id": "891597001043982", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974529_891597007710648_1919576886384525312_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P_dmY5BWZj4Q7kNvgHWN6-z&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYD9_wu8v2Je2pgMxfDL9K6dNRsY5SZoufUwZNBRmwBumQ&oe=67584366"}, "display_name": "Smash The Beats", "keywords": ["music", "rhythm", "beats", "smash", "saber"], "long_description": "Smash The Beat is an energetic music  game which will surround you with music. Come face to face with the beats. Play with 15 handcrafted tracks available in the game or choose your own MP3.\nAll you need to do is to feel the music and smash incoming cubes exactly with the beat.\nBlocks with the blue arrow smash with blue tool, for orange arrows use orange tool. How to change the color? Just press the trigger.\n\nIt\u2019s up to you if your controller change into shield, hammer or sword. \nTry them all to smash the bricks.\nYou can play easy, normal mode or if you like challenges choose advance.\n \nSo put on your GO and start fun with smashing beats.\nIf you like energetic music, rhythms  Smash The Beat is  for you!", "short_description": "Smash The Beat is an energetic rhythm VR game. Smash the blocks in time with the music. It\u2019s up to you if your controller change into shield, hammer or sword.  Play with 15 handcrafted tracks available in the game or choose your own MP3. Put on your GO  and start fun with smashing beats."}]}, "developer_name": "NiVision", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "http://nivisionag.wixsite.com/duovr/eula", "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://nivisionag.wixsite.com/smashthebeats", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "conte