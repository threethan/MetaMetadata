buk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDofAPixwmZKlV2_mGUR3kJ8SKrIK4V_bjg4HFaWYkPSA&oe=670D1DE6"}, "display_name": "Smash The Beats", "keywords": ["music", "rhythm", "beats", "smash", "saber"], "long_description": "Smash The Beat is an energetic music  game which will surround you with music. Come face to face with the beats. Play with 15 handcrafted tracks available in the game or choose your own MP3.\nAll you need to do is to feel the music and smash incoming cubes exactly with the beat.\nBlocks with the blue arrow smash with blue tool, for orange arrows use orange tool. How to change the color? Just press the trigger.\n\nIt\u2019s up to you if your controller change into shield, hammer or sword. \nTry them all to smash the bricks.\nYou can play easy, normal mode or if you like challenges choose advance.\n \nSo put on your GO and start fun with smashing beats.\nIf you like energetic music, rhythms  Smash The Beat is  for you!", "short_description": "Smash The Beat is an energetic rhythm VR game. Smash the blocks in time with the music. It\u2019s up to you if your controller change into shield, hammer or sword.  Play with 15 handcrafted tracks available in the game or choose your own MP3. Put on your GO  and start fun with smashing beats."}]}, "developer_name": "NiVision", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "http://nivisionag.wixsite.com/duovr/eula", "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://nivisionag.wixsite.com/smashthebeats", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "ARCADE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_