zK0KWzWkDgQ7kNvgGMeRab&_nc_ht=scontent.oculuscdn.com&oh=00_AYBNG4gbzhilzk75DxyO3mUmixl2hwVwcqm9tKxNvIf9ag&oe=66E2E1D1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail-2560-1440.png", "id": "3752252328342334", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031519_3752252331675667_3560317630855160589_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8pzTDW9BfcQ7kNvgEqXd64&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLCZuYidP0GNczAh3UzRcxLe6vvgIuKpCUw_LF03INgw&oe=66E2C702"}, "display_name": "Happi Art", "keywords": ["painting", "art", "drawing", "canvas", "brush"], "long_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation\n\nHappi Art VR is a realistic simulation of canvas painting in VR, convincingly mimic the way natural media interact with the canvas.\n\nKey features:\n- Realistic Oil Simulation\n- Wet-on-wet color blending\n- Impasto effect\n- Built-in Web Browser\n- Capture any pictures and paint\n\nPackaged with:\n- 17 relaxing nature environment\n- 12 step-by-step instruction tutorial\n- 50+ paint-by-numbers set\n- 4 hours of mediation soundtracks\n- youtube tv to learn art side-by-side\n- fully equipped oil painting studio\n", "short_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation\n\nHappi Art VR is a realistic simulation of canvas painting in VR, convincingly mimic the way natural media interact with the canvas."}]}, "developer_name": "Happi Art Team", "developer_privacy_policy_url": "https://happi-art.world/privacy", "developer_terms_of_service_url": null, "publisher_name": "Happi Art Team", "support_website_url": "https://happi-art.world/support", "website_url": "https://happi-art.world/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": fal