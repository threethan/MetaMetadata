vgEgoS3j&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASO0uY91MJKp2PjTbevGMcV&oh=00_AYA3x606-AyX6QfE7Ra7D4zAXqm-iCg-lA-9yR-Aq_C_iw&oe=66E976A1"}, {"file_name": "Screenshot-2.png", "id": "795675179213201", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_795675182546534_8232398554329886537_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oL8xWYMX0jIQ7kNvgHQeybZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASO0uY91MJKp2PjTbevGMcV&oh=00_AYBhy6PyE9eTPNkJ0vu9FiI8pf5a0hGORATUlgViHBT7Ww&oe=66E97951"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail-2560-1440.png", "id": "3752252328342334", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031519_3752252331675667_3560317630855160589_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdbR4Ah8_TkQ7kNvgFwnn7c&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASO0uY91MJKp2PjTbevGMcV&oh=00_AYDMpi5vOyrHKyJoxidTOcqWA4pHcnJ_FLc7J9lDu8D0Yg&oe=66E95E82"}, "display_name": "Happi Art", "keywords": ["painting", "art", "drawing", "canvas", "brush"], "long_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation\n\nHappi Art VR is a realistic simulation of canvas painting in VR, convincingly mimic the way natural media interact with the canvas.\n\nKey features:\n- Realistic Oil Simulation\n- Wet-on-wet color blending\n- Impasto effect\n- Built-in Web Browser\n- Capture any pictures and paint\n\nPackaged with:\n- 17 relaxing nature environment\n- 12 step-by-step instruction tutorial\n- 50+ paint-by-numbers set\n- 4 hours of mediation soundtracks\n- youtube tv to learn art side-by-side\n- fully equipped oil painting studio\n", "short_description": "Canvas Painting App, with hyper-realistic acrylic/oil simulation\n\nHappi Art VR is a realistic simulation of canvas painting in VR, convincingly mimic the way natural media interact with the canvas."}]}, "developer_name": "Happi Art Team", "developer_privacy_policy_url": "https://happi-art.world/privacy", "developer_terms_of_service_url": null, "publisher