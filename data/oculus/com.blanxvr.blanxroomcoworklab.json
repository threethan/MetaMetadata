scontent.oculuscdn.com/v/t64.5771-25/75196218_1594249598067387_3249087538243762780_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1-7myzyacoQ7kNvgFDLc0w&_nc_ht=scontent.oculuscdn.com&_nc_gid=A72n2fa2BAsN5DDpD6IOXlI&oh=00_AYDd4Wwap6dBjwsPUeRYjinGKkIWTtD65F1mZUCcyBDF5Q&oe=66EEA293"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Coverframe.png", "id": "962516841189968", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982448_962516844523301_6651435611995477856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HtwFIVYBJcAQ7kNvgHmLrer&_nc_ht=scontent.oculuscdn.com&_nc_gid=A72n2fa2BAsN5DDpD6IOXlI&oh=00_AYDIeNhCv9SWvKYQN7Rbela_M_i9v34McupkBuAuMZX7gw&oe=66EE977D"}, "display_name": "RAUM", "keywords": ["meeting", "remote", "work", "mesh", "office"], "long_description": "RAUM is a revolutionary xr collaboration platform that will transform the way we interact and work together. \n\nIt features an amazing spatial tool set, the coolest avatar creator and user-friendly interfaces that require no programming skills to start creating. \nRAUM enhances human interaction by making the manipulation of digital objects feel natural, fostering meaningful collaboration and raising team performance through visualization capabilities and environments tailored to improve focus and concentration. With its human-centered design and focus on increasing productivity and creativity, RAUM is a clear win for any organization.\n\n# RAUM is used for\n- Presentations & events\n- Coachings\n- Workshops \n- Team stand-ups, team building activities\n- Onboardings of new team members\n- Product and business development\n- Showrooms\n- Design Reviews\n- Art exhibitions\n\nAnd anything you can imagine", "short_description": "RAUM virtual reality collaboration changes the way we work today and simplifies the interaction with the digital tools. From meetings, over workshops and immersive learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.raum.app/privacy-policy/#app", "developer_terms_of_service_url": null, "publisher_name": "RAUM", "support_website_url": null, "website_url": "https://www.raum.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}, {"id": "323450648956687"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "6769977923127294"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035463_829480138902154_7639516930637919260_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNU5CoebhrIQ7kNvgFZcIFp&_nc_ht=scontent.oculuscdn.com&_nc_gid=A72n2fa2BAsN5DDpD6IOXlI&oh=00_AYAoi8j14hz7vemyM0ZdA_j_EG7YN6MjyIUu39zfWjXhWQ&oe=66EE99C3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "RAUM", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Business", "id": "421923165850360"}, {"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1628201199, "lastRevision": {"nodes": [{"id": "959054994927452", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3073478306110626", "is_first_party": false, "enables_in_app_ads": false, "is_c