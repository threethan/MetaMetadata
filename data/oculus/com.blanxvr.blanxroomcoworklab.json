m/v/t64.5771-25/75196218_1594249598067387_3249087538243762780_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sF_dtV3K1YAQ7kNvgGrrCly&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCgTaNUxo1pYTdyAvpqYGmXJ488tmbOHj0HKqnyfjd9Fg&oe=67766D13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Coverframe.png", "id": "962516841189968", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982448_962516844523301_6651435611995477856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s2dBKkts170Q7kNvgFYoZ_A&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBOnsqaL3Lith1b_c6k9SFBCutKojpcmSOygm9LpegBUQ&oe=677661FD"}, "display_name": "RAUM", "keywords": ["meeting", "remote", "work", "metaverse", "collaboration"], "long_description": "RAUM is a revolutionary xr collaboration platform that will transform the way we interact and work together. \n\nIt features an amazing spatial tool set, the coolest avatar creator and user-friendly interfaces that require no programming skills to start creating. \nRAUM enhances human interaction by making the manipulation of digital objects feel natural, fostering meaningful collaboration and raising team performance through visualization capabilities and environments tailored to improve focus and concentration. With its human-centered design and focus on increasing productivity and creativity, RAUM is a clear win for any organization.\n\n# RAUM is used for\n- Presentations & events\n- Coachings\n- Workshops \n- Team stand-ups, team building activities\n- Onboardings of new team members\n- Product and business development\n- Showrooms\n- Design Reviews\n- Art exhibitions\n\nAnd anything you can imagine", "short_description": "RAUM virtual reality collaboration changes the way we work today and simplifies the interaction with the digital tools. From meetings, over workshops and immersive learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.raum.app/privacy-policy/#app", "develo