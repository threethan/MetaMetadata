524514", "locale": "en_US", "screenshots": [{"file_name": "raum_shoot_gallery_15.png", "id": "2724933184339313", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031361_2724933187672646_3678978402299632090_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zoP2jEVabs4Q7kNvgEFVxWO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSqZIUTsR6MIkyzB9qI9iv30e-8XN5h4KgHTfwjpCDfg&oe=6741C05F"}, {"file_name": "raum_shoot_gallery_06.png", "id": "2080151652372108", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569423_2080151655705441_5560844202264158328_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YqoGmPo7M-8Q7kNvgF9KKcO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiFf4dVivR839UFT_96LrCWTSxZ15gx8rfBEPchAcGWg&oe=6741AA39"}, {"file_name": "raum_shoot_gallery_24.png", "id": "1516872989228387", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982618_1516872992561720_3437871602487163208_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJM2L1nVzhwQ7kNvgHLXlBy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4OV0W8I_XAmc337hwywohcWOG5ICoEuxGzj8LAPUhoA&oe=6741D1E8"}, {"file_name": "raum_shoot_gallery_02.png", "id": "1473857280227056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221320_1473857283560389_5850563657697259461_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AN6nvrSCaDgQ7kNvgGlACps&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkzhop1Js5Wzr4iETpFVaUtYVEcKhfya7YD7vUCj-0pw&oe=6741D78D"}, {"file_name": "raum_shoot_gallery_20.png", "id": "1594249594734054", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196218_1594249598067387_3249087538243762780_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G0CMwpGWpqcQ7kNvgF62lHk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZBG6dnqvtwPTRU6snLNEckgOVM8iZa3560cq4e6GKVQ&oe=6741B113"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video_Coverframe.png", "id": "962516841189968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982448_962516844523301_6651435611995477856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HRC2jGKIwycQ7kNvgHXk7iv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBeocjFODd1WvF-R7HBxAU3A1XzAU7WV8IKpobrMzqabA&oe=6741A5FD"}, "display_name": "RAUM", "keywords": ["meeting", "remote", "work", "mesh", "office"], "long_description": "RAUM is a revolutionary xr collaboration platform that will transform the way we interact and work together. \n\nIt features an amazing spatial tool set, the coolest avatar creator and user-friendly interfaces that require no programming skills to start creating. \nRAUM enhances human interaction by making the manipulation of digital objects feel natural, fostering meaningful collaboration and raising team performance through visualization capabilities and environments tailored to improve focus and concentration. With its human-centered design and focus on increasing productivity and creativity, RAUM is a clear win for any organization.\n\n# RAUM is used for\n- Presentations & events\n- Coachings\n- Workshops \n- Team stand-ups, team building activities\n- Onboardings of new team members\n- Product and business development\n- Showrooms\n- Design Reviews\n- Art exhibitions\n\nAnd anything you can imagine", "short_description": "RAUM virtual reality collaboration changes the way we work today and simplifies the interaction with the digital tools. From meetings, over workshops and immersive learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.raum.app/privacy-policy/#app", "developer_terms_of_service_url": null, "publisher_name": "RAUM", "support_website_url": null, "website_url": "https://www.raum.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "1819021644882647"}], "external_subscription_type": "REQUIRED_FOR_SO