nt-sin6-1.oculuscdn.com/v/t64.5771-25/38982448_962516844523301_6651435611995477856_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPGx6UBdbn8Q7kNvgGG7kNp&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBIc1VvjGMRW0zVkCqFIvE9CMCz3vfw55zq05LralxEGQ&oe=6728997D"}, "display_name": "RAUM", "keywords": ["meeting", "remote", "work", "mesh", "office"], "long_description": "RAUM is a revolutionary xr collaboration platform that will transform the way we interact and work together. \n\nIt features an amazing spatial tool set, the coolest avatar creator and user-friendly interfaces that require no programming skills to start creating. \nRAUM enhances human interaction by making the manipulation of digital objects feel natural, fostering meaningful collaboration and raising team performance through visualization capabilities and environments tailored to improve focus and concentration. With its human-centered design and focus on increasing productivity and creativity, RAUM is a clear win for any organization.\n\n# RAUM is used for\n- Presentations & events\n- Coachings\n- Workshops \n- Team stand-ups, team building activities\n- Onboardings of new team members\n- Product and business development\n- Showrooms\n- Design Reviews\n- Art exhibitions\n\nAnd anything you can imagine", "short_description": "RAUM virtual reality collaboration changes the way we work today and simplifies the interaction with the digital tools. From meetings, over workshops and immersive learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.raum.app/privacy-policy/#app", "developer_terms_of_service_url": null, "publisher_name": "RAUM", "support_website_url": null, "website_url": "https://www.raum.app/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "1819021644882647"}], "external_subscription_type": "REQUI