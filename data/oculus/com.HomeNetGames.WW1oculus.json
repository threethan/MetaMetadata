u7jueZVtI6zvkBLkWQ&oe=675AE349"}]}, "id": "756728974968114", "locale": "en_US", "screenshots": [{"file_name": "WW1_VR_01.png", "id": "276294377171933", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75534976_276294380505266_1295121940068790048_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=foCiZYEgPEQQ7kNvgEtEybT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJAFgKHLTQOCDlaEesl70t7EuCOZb45UC6O5X4AMoeGg&oe=675AEB10"}, {"file_name": "WW1_VR_02.png", "id": "976323836233630", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984461_976323839566963_8413738230556315370_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHypJjn6POkQ7kNvgG2Oiix&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJYNJXuPkI5zWVeaBJR6FuIlcbjG7wvdsnwW9mBAntXw&oe=675ABF7F"}, {"file_name": "WW1_VR_04.png", "id": "135617458322752", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75469632_135617461656085_4987379834236113477_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3qZjAN6ntiMQ7kNvgE3M2WN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEDilZT-iXulXd9-3VpKJetMMs-2MHApPEL9FEMCThxg&oe=675AC7CE"}, {"file_name": "WW1_VR_03.png", "id": "1054183485078864", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207240_1054183488412197_282113100732422109_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1hR4aCvXsbgQ7kNvgF7Cd8G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaWMhWxL3F04qvhSuXdnjMQdKbwZHs99Qthpb6zIff_A&oe=675AB576"}, {"file_name": "WW1_VR_05.png", "id": "413836713016216", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210400_413836716349549_4647211040027476605_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SILP7z7o8UsQ7kNvgFrqg4f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAg_xpm-ccCmcrpmLzRcsBM6yuG-ioigwAR0ubdUu5dQ&oe=675AD230"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "717257738990156", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_717257742323489_7422512664354756523_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zQeHRK4fW54Q7kNvgEieQG0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBELlRjTyvfrEJh6SHbooJLZ-fwXSv8EAfIuDiShsdppw&oe=675AB615"}, "display_name": "Warplanes: WW1 Fighters", "keywords": [], "long_description": "Become a pilot! Immerse in WW1 aerial combat like never before in a captivating VR experience. Be a pilot during the Great War in Warplanes: WW1 Fighters. No matter whether you prefer arcade games or flight simulators \u2013 a variety of options will let you adjust the game to your preferences.\n\nEXPERIENCE WW1 IN VR!\n\u25cf Amazing graphics and performance on Oculus Quest 1 & 2.\n\u25cf Fully customizable flight models \u2013 from arcade to simulation based on aerodynamics.\n\u25cf Additional options affecting gameplay \u2013 enabling manual takeoffs and landing, aggressive AI, disabling of HUD and more.\n\u25cf Steering designed to fully utilize Oculus Quest controllers.\n\u25cf Over 16 playable planes \u2013 from light scout planes to bombers.\n\u25cf Two campaigns with hundreds of missions set in diverse locations, seasons and time of day.\n\u25cf Build a squadron \u2013 upgrade and customize your machines.\n\u25cf Gain medals and upgrade your skill to manage your base and squadron more efficiently.\n\u25cf Single-player, PvP and Co-op multiplayer modes.", "short_description": "Become a pilot! Immerse in WW1 aerial combat like never before in a captivating VR experience.\n\u25cf Amazing graphics and performance on Oculus Quest 1&2.\n\u25cf Fully customizable flight models \u2013 from arcade to simulation based on aerodynamics.\n\u25cf Additional options affecting gameplay \u2013 enabling manual takeoffs and landing, aggressive AI, disabling of HUD and more.\n\u25cf Two campaigns with hundreds of missions set in diverse locations, seasons and time of day.\n\u25cf Intuitive controls designed especially for VR."}]}, "developer_name": null, "developer_priv