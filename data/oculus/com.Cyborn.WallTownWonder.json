_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JEVjNzPzEvoQ7kNvgFJHKWa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBN4EuYnBB_QcgUHGDXbJQ6xabUpmeS5HZnvGXGv9AwOA&oe=67541C47"}, {"file_name": "WTW Balloon (1).png", "id": "907445711327915", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974857_907445714661248_1419189719547297660_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g86G0HldyUwQ7kNvgHRuT95&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJfVWzDqTWCodzLQHsRUdvAmxP41FbIpQ2BUxSgKy1wg&oe=67542C34"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Logo_poster.png", "id": "1922165081637054", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035329_1922165084970387_5817384052610368178_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0y_hJQTGjc8Q7kNvgECG5Xh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUwaWmH-_US_Fh0CzYilfnorCUdH-BNs71sH7IfywI3g&oe=67544090"}, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "CityBuilding", "Casual", "HandTracking"], "long_description": "Wall Town Wonders is a mixed reality game that turns your living room into a lively miniature town. Help colorful characters build their world through fun quests and mini-games, unlocking unique buildings and surprises along the way.\n\n\ud83d\udcac \"This could win Mixed-Reality Game of the Year!\" - **The Elite Institute**\n\n\ud83d\udcac \"A Mixed Reality City Builder with Tons of Charm.\" - **Road To VR**\n\n\ud83d\udcac \"Wall Town Wonders is the best surprise of 2024 on Meta!\" - **Quel Tizio In VR**\n\n\ud83d\udcac \"Wall to wall fun.\" - **Thumb Culture**\n\n\ud83d\udcac \"Charming, cozy, and addictive. I didn't intend to, but played for hours on my first try.\" - **GameList+**\n\n\ud83d\udcac \"One of the best mixed reality experiences to date!\" - **Gamekod3**\n\n\n\n# Mixed reality cosy life sim city builder:\nDive into a world where you will experience MR like never before, with unique interactions and highly detailed environments.\n\n{1244979130284550}\n\n# Innovative Handtracking and Interactions: \nExperience the magic of interacting with your town's people using just your bare hands, adding a new level of realism and immersion to gameplay.\n\n{877223127628737}\n\n# Gentle and Relaxing Gameplay: \nPlay, discover, and nurture your town at your own pace in a tranquil and soothing environment, perfect for unwinding and relaxation.\n\n{2757946757700941}\n\n# Endless Customization and Exploration: \nCollect countless new looks and customization options for your city through gameplay and exploration, ensuring each experience is uniquely tailored to your preferences.", "short_description": "Wall town wonders is a Mixed reality cozy life sim city builder where you become the  host of a vibrant community in your living room. Explore their culture, discover their secrets and above all, grow their picturesque town into a magnificent wall town wonder."}, {"images": {"nodes": [{"file_name": "header.png", "id": "1755783488518220", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451773_1755783491851553_8951467915600965547_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULG4etaO4AAQ7kNvgEZzbRT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBaxdtadPtWYi9by4uS-9Tidx4vf8Tr5kKihJ47KIswDg&oe=67544192"}, {"file_name": "2ndheader.png", "id": "1017070536890500", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982691_1017070540223833_340583595354965301_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wqE8P_CayvoQ7kNvgFrVf-t&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuo9Xau4EMEd2N6bMsmKJjAVWDAK7LPnzZl7eS2rcQcA&oe=675433D4"}]}, "id": "1275412126836826", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["MixedReality", "MR", "Simulation", "Casual", "HandTracking"], "long_description": "Wall Town Wonders est un jeu en r\u00e9alit\u00e9 mixte qui transforme votre salon en une ville miniature anim\u00e9e. Aidez des personnages color\u00e9s \u00e0 construire leur monde \u00e0 travers des qu\u00eates amusantes et des mini-jeux, en d\u00e9bloquant des b\u00e2timents uniques et des surprises en cours de route.\n\n\ud83d\udcac \"This could win Mixed-Reality Game of the Year!\" - **The Elite Institute**\n\n\ud83d\udcac \"A Mixed Reality City Builder with Tons of Charm.\" - **Road To VR**\n\n\ud83d\udcac \"Wall Town Wonders is the best surprise of 2024 on Meta!\" - **Quel Tizio In VR**\n\n\ud83d\udcac \"Wall to wall fun.\" - **Thumb Culture**\n\n# Constructeur de ville de simulation de vie cosy en r\u00e9alit\u00e9 mixte :\nPlongez dans un monde o\u00f9 vous vivrez la r\u00e9alit\u00e9 mixte comme jamais auparavant, avec des interactions uniques et des environnements tr\u00e8s d\u00e9taill\u00e9s.\n\n{1017070536890500}\n\n# Suivi des mains et interactions innovants :\nD\u00e9couvrez la magie d'interagir avec les habitants de votre ville simplement avec vos mains, ajoutant un nouveau niveau de r\u00e9alisme et d'immersion au jeu.\n\n{3035572349926129}\n\n# Gameplay doux et relaxant :\nJouez, d\u00e9couvrez et d\u00e9veloppez votre ville \u00e0 votre propre rythme dans un environnement calme et apaisant, parfait pour la d\u00e9tente.\n\n{866346609038270}\n\nPersonnalisation et exploration infinies :\nCollectez d'innombrables nouveaux looks et options de personnalisation pour votre ville gr\u00e2ce au jeu et \u00e0 l'exploration, garantissant que chaque exp\u00e9rience est adapt\u00e9e \u00e0 vos pr\u00e9f\u00e9rences.", "short_description": "Wall Town Wonders est un simulateur de vie cosy et constructeur de villes en r\u00e9alit\u00e9 mixte o\u00f9 vous devenez l'h\u00f4te d'une communaut\u00e9 vibrante dans votre salon. Explorez leur culture, d\u00e9couvrez leurs secrets et, surtout, faites grandir leur ville pittoresque pour en faire une magnifique merveille de Wall Town."}, {"images": {"nodes": [{"file_name": "2ndheader.png", "id": "947146317475488", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221322_947146320808821_7483338765309807011_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tCOpDOSNhvIQ7kNvgGsuyKm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6ayu5Db6tORGLS4_M1XmIgwZD15Osm2O8lhLBY7DAdw&oe=67542691"}, {"file_name": "header.png", "id": "906454594755734", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75439593_906454598089067_3534502975837625807_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YOX4uO_e63YQ7kNvgFBGOfv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEQxh4fNp1nGhCBJ55uMhmYrLHiKr3-FD7l3vaqjAQKQ&oe=675422D1"}]}, "id": "1134186088273958", "locale": "nl_NL", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Hand", "MR", "MixedReality", "Simulatie", "Bouwen"], "long_description": "Wall Town Wonders is een mixed reality-spel dat uw woonkamer verandert in een levendige miniatuurstad. Help kleurrijke personages hun wereld op te bouwen door middel van leuke missies en minigames, en ontgrendel unieke gebouwen en verrassingen onderweg.\n\n\ud83d\udcac \"This could win Mixed-Reality Game of the Year!\" - **The Elite Institute**\n\n\ud83d\udcac \"A Mixed Reality City Builder with Tons of Charm.\" - **Road To VR**\n\n\ud83d\udcac \"Wall Town Wonders is the best surprise of 2024 on Meta!\" - **Quel Tizio In VR**\n\n\ud83d\udcac \"Wall to wall fun.\" - **Thumb Culture**\n\n\ud83d\udcac \"Charming, cozy, and addictive. I didn't intend to, but played for hours on my first try.\" - **GameList+**\n\n\ud83d\udcac \"One of the best mixed reality experiences to date!\" - **Gamekod3**\n\n# Mixed reality cosy life sim city builder:\nDuik in een wereld waar je MR op een geheel nieuwe manier ervaart, met unieke interacties en zeer gedetailleerde omgevingen.\n\n{947146317475488}\n\n# Innovatieve handtracking en interacties:\nErvaar de magie van interactie met de inwoners van je stad met alleen je blote handen, wat een nieuw niveau van realisme en onderdompeling toevoegt aan het spel.\n\n{831823185567324}\n\n# Zacht en ontspannend spel:\nSpeel, ontdek en verzorg je stad in je eigen tempo in een rustige en ontspannende omgeving, perfect om te ontspannen.\n\n{550346371036788}\n\n# Eindeloze aanpassing en verkenning:\nVerzamel talloze nieuwe stijlen en aanpassingsopties voor je stad door middel van gameplay en verkenning, zodat elke ervaring uniek is afgestemd op je voorkeuren.", "short_description": "Wall Town Wonders is een mixed reality cozy life sim city builder waarin je de gastheer wordt van een levendige gemeenschap in je woonkamer. Verken hun cultuur, ontdek hun geheimen en laat hun pittoreske stad bovenal uitgroeien tot een prachtig Wall Town Wonder."}, {"images": {"nodes": [{"file_name": "2ndheader.png", "id": "1605868950273237", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340710_1605868953606570_787330470358330913_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3x5HmuIKhvEQ7kNvgHy5aRo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkg3-tNriHSw03VifsLO8bYS52wdreunDUFLU-3xt13A&oe=67545034"}, {"file_name": "header.png", "id": "585418880540675", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982511_585418883874008_8427396616404348694_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tENUpc-uNZkQ7kNvgG0uvW7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB2aVOJYt6J1NEcCDYQuIuwb1GkLrF1-7u_8vHUOdjl0w&oe=6754386C"}]}, "id": "1094779138424671", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "MR", "HandTracking", "Casual"], "long_description": "Wall Town Wonders ist ein Mixed-Reality-Spiel, das Ihr Wohnzimmer in eine lebendige Miniaturstadt verwandelt. Helfen Sie farbenfrohen Charakteren, ihre Welt durch lustige Quests und Mini-Spiele aufzubauen, und schalten Sie dabei einzigartige Geb\u00e4ude und \u00dcberraschungen frei.\n\n\ud83d\udcac \"This could win Mixed-Reality Game of the Year!\" - **The Elite Institute**\n\n\ud83d\udcac \"A Mixed Reality City Builder with Tons of Charm.\" - **Road To VR**\n\n\ud83d\udcac \"Wall Town Wonders is the best surprise of 2024 on Meta!\" - **Quel Tizio In VR**\n\n\ud83d\udcac \"Wall to wall fun.\" - **Thumb Culture**\n\n\ud83d\udcac \"Charming, cozy, and addictive. I didn't intend to, but played for hours on my first try.\" - **GameList+**\n\n\ud83d\udcac \"One of the best mixed reality experiences to date!\" - **Gamekod3**\n\n# Mixed-Reality-Cosy-Life-Sim-City-Builder:\nTauchen Sie ein in eine Welt, in der Sie MR wie nie zuvor erleben werden, mit einzigartigen Interaktionen und hochdetaillierten Umgebungen.\n\n{1605868950273237}\n\n# Innovatives Handtracking und Interaktionen:\nErleben Sie die Magie, die Menschen Ihrer Stadt nur mit Ihren blo\u00dfen H\u00e4nden zu ber\u00fchren, was dem Gameplay ein neues Ma\u00df an Realismus und Immersion verleiht.\n\n{963123972299553}\n\n# Sanftes und entspannendes Gameplay:\nSpielen, entdecken und pflegen Sie Ihre Stadt in Ihrem eigenen Tempo in einer ruhigen und beruhigenden Umgebung, ideal zum Entspannen.\n\n{1112263773568103}\n\n# Unendliche Anpassung und Erkundung:\nSammeln Sie unz\u00e4hlige neue Looks und Anpassungsoptionen f\u00fcr Ihre Stadt durch Gameplay und Erkundung und sorgen Sie daf\u00fcr, dass jede Erfahrung individuell auf Ihre Vorlieben abgestimmt ist.", "short_description": "Wall Town Wonders ist ein Mixed-Reality-Cosy-Life-Sim-City-Builder, in dem Sie Gastgeber einer lebendigen Gemeinschaft in Ihrem Wohnzimmer werden. Erkunden Sie ihre Kultur, entdecken Sie ihre Geheimnisse und vor allem, lassen Sie ihre malerische Stadt zu einem pr\u00e4chtigen Wall Town Wonder heranwachsen."}, {"images": {"nodes": [{"file_name": "header.png", "id": "1781020312725524", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43931338_1781020319392190_5959707311126303589_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CC0F21ixHRcQ7kNvgEUkGZ2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0pICDC2sOBpGYjpQL8WOlBYFnKgIYz8jez0dqjse4hQ&oe=67542291"}, {"file_name": "2ndheader.png", "id": "1237501140904343", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984443_1237501144237676_319567342353361819_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5tS4zV1cusQQ7kNvgGlikJP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC99NUHMxchBqsVbmV3pXiueUUb0PUsOjv-F4lSuYZEMw&oe=67543F37"}, {"file_name": "header.png", "id": "1107923027450933", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451773_1107923030784266_3008265505249619426_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xBVJ6FfwSZ0Q7kNvgHsKpsA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrToaWoW3f9O3CZ26SQcNrDGqfJ8h0Z-DY-rpl3vrBtA&oe=6754267A"}, {"file_name": "2ndheader.png", "id": "573804565190230", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982511_573804568523563_7316769445967962018_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wAAgxyORyYsQ7kNvgGpiO3N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmgB4Yb9lWmTet9DaLMpUGNq6aYVUe_IsqecnFfeXHag&oe=675447C9"}]}, "id": "541823238736650", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "MR", "Casual", "HandTracking"], "long_description": "Wall Town Wonders es un juego de realidad mixta que convierte tu sala de estar en una animada ciudad en miniatura. Ayuda a personajes coloridos a construir su mundo a trav\u00e9s de divertidas misiones y minijuegos, desbloqueando edificios \u00fanicos y sorpresas en el camino.\n\n\ud83d\udcac \"This could win Mixed-Reality Game of the Year!\" - **The Elite Institute**\n\n\ud83d\udcac \"A Mixed Reality City Builder with Tons of Charm.\" - **Road To VR**\n\n\ud83d\udcac \"Wall Town Wonders is the best surprise of 2024 on Meta!\" - **Quel Tizio In VR**\n\n\ud83d\udcac \"Wall to wall fun.\" - **Thumb Culture**\n\n\ud83d\udcac \"Charming, cozy, and addictive. I didn't intend to, but played for hours on my first try.\" - **GameList+**\n\n\ud83d\udcac \"One of the best mixed reality experiences to date!\" - **Gamekod3**\n\n# Simulador de vida acogedor y constructor de ciudades de realidad mixta:\nSum\u00e9rgete en un mundo donde experimentar\u00e1s la realidad mixta como nunca antes, con interacciones \u00fanicas y entornos altamente detallados.\n\n{573804565190230}\n\n# Innovador seguimiento de manos e interacciones:\n\n{883358577260144}\n\nExperimenta la magia de interactuar con la gente de tu ciudad usando solo tus manos, a\u00f1adiendo un nuevo nivel de realismo e inmersi\u00f3n al juego.\n\n# Juego suave y relajante:\n\n{1082825756634967}\n\nJuega, descubre y cuida tu ciudad a tu propio ritmo en un entorno tranquilo y relajante, perfecto para desconectarse y relajarse.\n\n\n\n# Personalizaci\u00f3n y exploraci\u00f3n sin fin:\nColecciona innumerables nuevos estilos y opciones de personalizaci\u00f3n para tu ciudad a trav\u00e9s del juego y la exploraci\u00f3n, asegurando que cada experiencia est\u00e9 adaptada a tus preferencias.\n", "short_description": "Wall Town Wonders es un simulador de vida acogedor y constructor de ciudades en realidad mixta, donde te conviertes en el anfitri\u00f3n de una comunidad vibrante en tu sala de estar. Explora su cultura, descubre sus secretos y, sobre todo, haz que su pintoresca ciudad crezca hasta convertirse en una magn\u00edfica maravilla de Wall Town."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.walltownwonders.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Cyborn BV", "support_website_url": null, "website_url": "https://www.walltownwonders.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1008279844328894"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "pt", "zh_CN", "ja", "ko", "nl_BE", "it", "pl", "ru"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7942253045878160"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982547_994050639083089_652579810331550999_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KPSoZX31BeYQ7kNvgH6RUoc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_6PDr182aphmP9GW_oJlk7ddwNwsksU6g1AS4-lshIw&oe=67541D23"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wall Town Wonders", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "Narrative", "id": "1008279844328894"}], "release_date": 1732204800, "lastRevision": {"nodes": [{"id": "6103056433131173", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"def