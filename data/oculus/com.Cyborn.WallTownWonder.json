100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YXLDVlFmjK8Q7kNvgH3zGsf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbd8utNfccZ5GzXnr2pnIDMoOd3CzOyoIynLk-_KZXzQ&oe=6754484F"}, {"file_name": "WTW_screen_04.png", "id": "403631632306567", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031414_403631635639900_6137862803262801237_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m6wHdzcDH8oQ7kNvgGKrQfm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9GnIQb0qt8bFTX-yLU-N2jlPhrIK5hchg-URXIQJUzg&oe=67543A4C"}, {"file_name": "WTW_screen_05.png", "id": "1010852677173307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982531_1010852680506640_1942459138722142604_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MBnSJXrM400Q7kNvgGIkTEi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCXwX7TEb8Uc8-8vi4YmidXsfJJhaDUQ-Gde_LMEsVVQ&oe=67542547"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "CityBuilding", "Casual", "HandTracking"], "long_description": "Wall Town Wonders is a mixed reality game that turns your living room into a lively miniature town. Help colorful characters build their world through fun quests and mini-games, unlocking unique buildings and surprises along the way.\n\n# Pre-order the game now to earn exclusive in game skins and a discount!\n{854636896731249}\n\n# Mixed reality cosy life sim city builder:\nDive into a world where you will experience MR like never before, with unique interactions and highly detailed environments.\n\n{1244979130284550}\n\n# Innovative Handtracking and Interactions: \nExperience the magic of interacting with your town's people using just your bare hands, adding a new level of realism and immersion to gameplay.\n\n{877223127628737}\n\n# Gentle and Relaxing Gameplay: \nPlay, discover, and nurture your town at your own pace in a tranquil and soothing environment, perfect for unwinding and relaxation.\n\n{2757946757700941}\n\n# Endless Customization and Exploration: \nCollect countless new looks and customization options for your city through gameplay and exploration, ensuring each experience is uniquely tailored to your preferences.", "short_description": "Wall town wonders is a Mixed reality cosy life sim city builder where you become the  host of a vibrant community in your living room. Explore their culture, discover their secrets and above all, grow their picturesque town into a magnificent wall town wonder."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.walltownwonders.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Cyborn BV", "support_website_url": null, "website_url": "https://www.walltownwonders.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "pt", "zh_CN", "ja", "ko", "nl_BE"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6103056413131175"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1119583516234537"}, {"status": "PUBLISHED", "id": "1174522843660828"}, {"status": "PUBLISHED", "id": "529518316104945"}, {"status": "PUBLISHED", "id": "1233232258053239"}, {"status": "PUBLISHED", "id": "822494040034252"}]}, "baseline_offer": {"id": "1119583516234537"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1732204800, "status": "PUBLISHED", "id": "1119583516234