132826898168_7433482727408354768_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ZEA_bqalSgQ7kNvgG8Ndgl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9ihA-kOFBkzUIAh-zuJRzqQccqbPbQqeNDfucsi6W2Q&oe=677D1D5D"}, {"file_name": "WTW_screen_03.png", "id": "732797918938258", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_732797925604924_2682910388421889782_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=930JTxV3_mMQ7kNvgFH9eOt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAStj7dakgyy3OybiCmE_MD3HlkZS8yYYjtNOcQHGWWzw&oe=677D26CF"}, {"file_name": "WTW_screen_04.png", "id": "403631632306567", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031414_403631635639900_6137862803262801237_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vzCBLeqoFcQ7kNvgE_G6Gw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8He16HUpt60mZlgbCVYfQRamETWSiGFMACWD64KJz4Q&oe=677D18CC"}, {"file_name": "WTW_screen_05.png", "id": "1010852677173307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982531_1010852680506640_1942459138722142604_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zIB_WMjnN9IQ7kNvgHyERj7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmKyy_WEhwj25RpbXU1SXDRktkuEb8OO1PnRACiPPjig&oe=677D03C7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "CityBuilding", "Casual", "HandTracking"], "long_description": "Wall Town Wonders is a mixed reality game that turns your living room into a lively miniature town. Help colorful characters build their world through fun quests and mini-games, unlocking unique buildings and surprises along the way.\n\n# Pre-order the game now to earn exclusive in game skins and a discount!\n{854636896731249}\n\n# Mixed reality cosy life sim city builder:\nDive into a world where you will experience MR like never before, with unique interactions and highly detailed environments.\n\n{1244979130284550}\n\n# Innovative Handtracking and Interactions: \nExperience the magic of interacting with your town's people using just your bare hands, adding a new level of realism and immersion to gameplay.\n\n{877223127628737}\n\n# Gentle and Relaxing Gameplay: \nPlay, discover, and nurture your town at your own pace in a tranquil and soothing environment, perfect for unwinding and relaxation.\n\n{2757946757700941}\n\n# Endless Customization and Exploration: \nCollect countless new looks and customization options for your city through gameplay and exploration, ensuring each experience is uniquely tailored to your preferences.", "short_description": "Wall town wonders is a Mixed reality cosy life sim city builder where you become the  host of a vibrant community in your living room. Explore their culture, discover their secrets and above all, grow their picturesque town into a magnificent wall town wonder."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.walltownwonders.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Cyborn BV", "support_website_url": null, "website_url": "https://www.walltownwonders.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "pt", "zh_CN", "ja", "ko", "nl_BE"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6103056413131175"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISH