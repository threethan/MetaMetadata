8168_7433482727408354768_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YsadrmUPT4kQ7kNvgEhFX2K&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJuzpo_XebTBejhxhKhsLfBnhHbMkp4h8dbeeaFDGpAg&oe=674EF8DD"}, {"file_name": "WTW_screen_03.png", "id": "732797918938258", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_732797925604924_2682910388421889782_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uql6U1H_LYoQ7kNvgF5US8O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwTE6OhcaaKOBei4EeILzWdKpBcRdkysxtJN8xPj4INQ&oe=674F024F"}, {"file_name": "WTW_screen_04.png", "id": "403631632306567", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031414_403631635639900_6137862803262801237_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PoUEmH4K6TMQ7kNvgEeHar0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0E5WByK8tEfBpALztixV2oBXjdTRuGgOWBQeFCRwyCg&oe=674EF44C"}, {"file_name": "WTW_screen_05.png", "id": "1010852677173307", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982531_1010852680506640_1942459138722142604_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k_GrTI7nUnEQ7kNvgEddGDO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjXxRY5wZE_RUe2C6dsGv7lhuFfNJ15GSmxQ4NoSph7A&oe=674EDF47"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wall Town Wonders", "keywords": ["Simulation", "MixedReality", "CityBuilding", "Casual", "HandTracking"], "long_description": "Wall Town Wonders is a mixed reality game that turns your living room into a lively miniature town. Help colorful characters build their world through fun quests and mini-games, unlocking unique buildings and surprises along the way.\n\n# Pre-order the game now to earn exclusive in game skins and a discount!\n{854636896731249}\n\n# Mixed reality cosy life sim city builder:\nDive into a world where you will experience MR like never before, with unique interactions and highly detailed environments.\n\n{1244979130284550}\n\n# Innovative Handtracking and Interactions: \nExperience the magic of interacting with your town's people using just your bare hands, adding a new level of realism and immersion to gameplay.\n\n{877223127628737}\n\n# Gentle and Relaxing Gameplay: \nPlay, discover, and nurture your town at your own pace in a tranquil and soothing environment, perfect for unwinding and relaxation.\n\n{2757946757700941}\n\n# Endless Customization and Exploration: \nCollect countless new looks and customization options for your city through gameplay and exploration, ensuring each experience is uniquely tailored to your preferences.", "short_description": "Wall town wonders is a Mixed reality cosy life sim city builder where you become the  host of a vibrant community in your living room. Explore their culture, discover their secrets and above all, grow their picturesque town into a magnificent wall town wonder."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.walltownwonders.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Cyborn BV", "support_website_url": null, "website_url": "https://www.walltownwonders.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "pt", "zh_CN", "ja", "ko", "nl_BE"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6103056413131175"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1119583516234537"}, {"status": "PUBLISHED", "id": "1174522843660828"}, {"status": "PUBLISHED", "id": "529518316104945"}, {"status": "PUBLISHED", "id": "1233232258053239"}, {"status": "PUBLISHED", "id": "822494040034252"}]}, "baseline_offer": {"id": "1119583516234537"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1732204800, "status": "PUBLISHED", "id": "1119583516234537"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7942924775810987", "version": "1.01"}, "id": "901094568300915", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103056399797843", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7942924775810987"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "901094568300915"}]}, "change_log": "* Ninja Quest stability fixes\n* Random balloon character animation fixes\n* Floating character that could randomly float in the middle of your room\n* Alchemist is now also opened up if no ninja quest is active\n* Confirmation menu's are now correctly sorted in the case you want to select a different save slot in a new room\n* Falling seed catcher can find enough room again in most rooms\n* If a building cannot be upgraded due to bigger restraints on higher build tiers you will now get a message for that\n* made it possible again to move old town and restaurant.\n* Sometimes dialogue boxes were no longer interactible when a character spawned while you were in the mine this is resolved.\n* Added a safety that prevent crashes on startup after room swapping", "created_date": 1732809347, "id": "7942924775810987", "version": "1.01", "version_code": 24278, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7942923829144415"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103056399797843", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7942924775810987"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732773765, "id": "7940705126032952", "version": "1.01", "version_code": 24162, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7940703769366421"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103056399797843", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7942924775810987"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732725780, "id": "7937935729643225", "version": "1.01", "version_code": 24160, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7937934792976652"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103056399797843", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7942924775810987"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "901094568300915"}]}, "change_log": "**\ud83c\udf89 Patch 1.01 for Wall Town Wonders is Live now! \ud83c\udf89**\n\nDear Wonderous builders,\nWe are beyond grateful to have all of you on this journey with us! Your support, feedback, and enthusiasm fuel our efforts to make Wall Town Wonders even better.\n\nPatch 1.01 Notes\n\n\ud83c\udf1f Content Updates**\n\n- Added difficulty modes to the following mini-games:\n- Airplane butterfly catching.\n- Painting butterfly mini-game.\n- Harbor crane mini-game.\n- Ninja Quest: Ninjas will sneak around town sabotaging buildings\u2014catch them in time to prevent damage!\n- Bring New Characters to Town: Occasionally, new characters will appear in your room\u2014bring them to town for rewards.\n- Balloon Quest Update: New balloons may arrive\u2014guide them back to town for rewards.\n- Parachute Skins: You can now unlock skins for parachutes!\n\n**\ud83d\udd27 General Fixes**\n\n- Added sound triggers to the airplane and blimp station doors.\n- Improved fishing mini-game mechanics.\n- Enhanced pathfinding for the lizard\u2014it now navigates corners better and is less likely to get stuck.\n- Fixed improperly placed doors in some buildings.\n- Added more safeguards to dialogues to reduce the chance of errors.\n\n**\ud83d\udc1e Bug Fixes**\n\n- Fixed crashes caused by audio files and lizard-related activities.\n- Resolved issues with:\n- Mine upgrades.\n- Buildings spawning vertically instead of horizontally.\n- Beetles wandering inside farms.\n- Missing dialogue bubbles for the mayor.\n- Fixed achievement tracking\u2014players should now be able to unlock all achievements.\n- Prevented boxes from falling through blimp delivery zones.\n- Fixed resource claiming issues after spawn.\n- Resolved occasional missing mini-game rewards from the lizard.\n- Adjusted lizard mine spawns to avoid placing them near buildings.\n\n**\u2728 Quality of Life Improvements**\n\n- First-time mini-games now display a helpful dialogue in the menu.\n- Enhanced visuals for the plane mini-game pointer.\n- Added the ability to rescan your room from within the game.\n- All numbers in the interface are now neatly rounded.\n- Added mute/unmute buttons in the sound settings.\n- Improved French and Italian localizations.\n- Increased rewards for the River Jump mini-game and clarified obtainable resources.\n- Reduced accidental clicks on mini-game hubs during character interactions.\n- Sped up introductory dialogues for less idle time.\n- Enhanced feedback when spraying plants in farms.\n- Airplane buildings can now be moved even with active quests, preventing soft locks.\n- Polished cargo ship mini-game for better rewards.\n- Simplified shooting obstacles in the mine mini-game.\n- Added clearer resource indicators at blimp drop-off points, including iron delivery. \n- Introduced a lizard cave tutorial quest, explaining how food can be traded for resources via the lizard.\n- Updated Chinese localization for Yes/No windows.\n\n**\ud83c\udfa5 Animation Fixes**\n\n- Miner now cheers when finding treasures.\n- Fixed:\n- Airplane landing glitches.\n- Characters spawning outside balloons.\n- River jump animations being too abrupt.\n- The diver now properly dives from the plank.\n- Adjusted mushroom harvesting animations for better alignment.\n- Bubble people now align properly with the net.\n- Fixed mayor glitches when parachuting or being returned to town.\n\n**\ud83c\udfa8 Visual Fixes**\n\n- White cross in hatch-clearing now fades out correctly.\n- Airplane explosion effects now spawn on the surface.\n- Mine visuals no longer flicker upon first entry.\n- Resolved issues with the lizard\u2019s visibility when entering the mine.\n\n**\ud83c\udf85 Stay Tuned for December!**\n\nWe\u2019d like to remind everyone to leave a review for Wall Town Wonders\u2014your support allows us to keep improving and expanding the game! The next update will arrive in December, and it\u2019s sure to get everyone in a very Xmassy mood. \ud83c\udf84\u2728\n\nThank you again for being part of this journey. We can\u2019t wait for you to enjoy Patch 1.01 and all the exciting things we have planned for the future! \ud83d\ude80\n\nKind regards,\n\nKoen ", "created_date": 1732641090, "id": "7932639856839479", "version": "1.0", "version_code": 24078, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7932637573506374"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6103056399797843", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7942924775810987"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732640054, "id": "7932573566846108", "version": "1.0", "version_code": 24077, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7932565176846947"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}