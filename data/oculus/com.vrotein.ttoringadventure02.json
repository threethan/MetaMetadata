c3-1.oculuscdn.com/v/t64.5771-25/12602285_770167273136366_958418567668170752_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Mqh1hi7t8QQ7kNvgG4haPA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBYN-eM9BTPRvlbstF7QrpzIdVdc156fnXmcq62BZ3Fkg&oe=67752192"}, {"file_name": "migrated_image.png", "id": "225480571972076", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12522276_1873261286219813_3147034563411181568_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=14K_QIGfvtgQ7kNvgEFdbzX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCU7RnfBHLgFr-EyuAwH7mu5MgKSqNzwEpzEh06spt9kA&oe=677518F5"}, {"file_name": "migrated_image.png", "id": "213713633046128", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12602069_631102340417775_14906341130764288_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t_gDMdM8-goQ7kNvgHIh7iI&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAlDpZkgoROebUFoR4wjvww6OuAZe0uuviXWgC1Q3MtoA&oe=677511D9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TTORiNG Adventure: Moon's Tears", "keywords": ["puzzle", "adventure", "animation", "microworld", "ttoring"], "long_description": "One day, the Minerva detective team receive a voucher to stay at a luxurious hotel.\nAfter seeing the voucher, Ttoring and Toto pack their stuff and head to the hotel.\nExcited to go on their holiday, they reach the hotel where suddenly a new case is waiting for them to solve.\n\n \u201cMinerva detectives, please protect the \u2018Moon\u2019s Tears\u2019 from the phantom thief, Luna.\u201d\n\nThe hotel owner, who is also a collector of gems asks for their help and shows them a note left by Luna.\nCan you thwart Luna\u2019s plan to steal the \u2018Moon\u2019s Tears\u2019?\n\nMore dynamic puzzles\nMore micro-world experiences that will test your wits!\nA storyline that is more concise and with double the tension!\n\nTtoring and Toto are waiting for you as the third member of the Minerva detective team.\nHow about we solve the second case?", "short_description": "Can you thwart Luna\u2019s plan to steal the \u2018Moon\u2019s Tears\u2019?\nMore dynamic puzzles\nMore micro-world experiences that will test your wits!\nA storyline that is more concise and with double the tension!\nTtoring and Toto are waiting for you."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.vrotein.co.kr/", "developer_terms_of_service_url": "http://www.vrotein.co.kr/", "publisher_name": "VRotein", "support_website_url": null, "website_url": "http://www.vrotein.co.kr/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "CASUAL", "EXPLORATION", "PUZZLE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "341097227885887"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/12727868_1809892199332720_6788388758438805504_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nBJ8xOWhTYAQ7kNvgG3JiTO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBRbV0gJdl1NigHs1JGMx5rlGv0M3Zg8hEg-Y8a3bZWVA&oe=677521C8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TTORiNG Adventure: Moon's Tears", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1490166000, "lastRevision": {"nodes": [{"id": "1249773778404448", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1178115748953782", "is_first_party": false, "enables_in_ap