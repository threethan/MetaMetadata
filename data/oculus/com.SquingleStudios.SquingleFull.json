FULL.png", "id": "371948285912904", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86631740_371948289246237_6520084295772107681_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ma-VSvEcI4YQ7kNvgGeir66&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhrT3gYp22WwBeh3Dh121NwL494_f2wj1ClGtjaf9qgQ&oe=6752D8B5"}, "display_name": "Squingle", "keywords": ["puzzle", "mr", "puzzling", "squingle"], "long_description": "Squingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!\n\n- 10/10 - \u201cThe perfect VR game.\u201d ~ Zimtok5\n- 93% - \u201cA masterpiece.\u201d ~ RuffTalkVR\n- 91% - \u201cOne of a kind.\u201d ~ VRGameCritic\n- \u201cBrilliantly creative\u201d ~ RoadToVR\n\n# \u2728 100 LEVELS AND MORE TO COME\nLaunching with 100 levels, with more added over time. Levels grow complex, featuring tighter spaces and new challenges.\n\n# \ud83c\udf08 A VISUAL MASTERPIECE\nEach maze is a stunning, morphing sculpture, offering an unmatched visual experience in Mixed Reality or immersive modes.\n\n# \ud83e\udde9 ACCESSIBILITY\nDesigned to be accessible for a wide range of skill levels, with intuitive controls and hand-tracking support for seamless play, whether standing or seated.\n\n# \ud83d\ude0c RELAX & UNWIND\nPlay on the sofa or in room-sized mazes. Squingle\u2019s calming gameplay will soothe your soul.\n\n# FEATURES\n\n- Level Add-ons: New puzzles soon.\n- Mixed Reality: Augmented or immersive modes.\n- Challenge Mode: Time trials and global leaderboards.\n- Hand Tracking support.\n- Room/Mini scale: Play big or small!\n- Race your ghost: Beat your best times.\n\n# \ud83c\udfc5 AWARDS\nBest VR Game ~ GDWC Finalist\nFinalist ~ QLDXR Festival\n\u201cBest of the Quest\u201d ~ Gibby\u2019s Guide\n\nGet ready to be Squingled!", "short_description": "Squingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!"}]}, "developer_name": "Dr. Benjamin Outram ", "developer_privacy_policy_url": "https://squingle.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRAL Games", "support_website_url": null, "website_url": "https://squingle.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "pl", "es"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9455383334489301"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207242_926963202668192_7955734701455819403_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xAjDHAA2BPQQ7kNvgF6E5a2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsB87ID7iS9IwdzMH8j1XztSxxGdRnqV7vtKCvSdfPrg&oe=6752D317"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Squingle", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1732212000, "lastRevision": {"nodes": [{"id": "9288954744465495", "release_type": "SCHEDULED", "administration_stat