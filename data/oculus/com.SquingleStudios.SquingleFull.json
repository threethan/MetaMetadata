5_2055235784933454_4629890574825469283_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PyfqI_4ug4sQ7kNvgGjuFPE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAE7Ugxqp_FJsnOym2SrgoEyXavatTyyfucpTxbpgVqkw&oe=67655EC3"}, {"file_name": "screenshot-11.png", "id": "1600564897226685", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974803_1600564900560018_6058402302123344296_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6i92GPXah6kQ7kNvgH0qshi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHTkTDYHdtg1iVETUkUQY5dQdvYXWlXFVYfhanyLEJWA&oe=67655A68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image-FULL.png", "id": "371948285912904", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86631740_371948289246237_6520084295772107681_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A8Dc49uuHj8Q7kNvgEFEXj9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAloxQzZozH4Ta0fLYXnYpghNr16sfdjXSEXZnAKUWpLA&oe=67654DB5"}, "display_name": "Squingle", "keywords": ["puzzle", "mr", "puzzling", "squingle"], "long_description": "Pre-order for exclusive bonus content!\n\nSquingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!\n\n- 10/10 - \u201cThe perfect VR game.\u201d ~ Zimtok5\n- 93% - \u201cA masterpiece.\u201d ~ RuffTalkVR\n- 91% - \u201cOne of a kind.\u201d ~ VRGameCritic\n- \u201cBrilliantly creative\u201d ~ RoadToVR\n\n# \u2728 100 LEVELS AND MORE TO COME\nLaunching with 100 levels, with more added over time. Levels grow complex, featuring tighter spaces and new challenges.\n\n# \ud83c\udf08 A VISUAL MASTERPIECE\nEach maze is a stunning, morphing sculpture, offering an unmatched visual experience in Mixed Reality or immersive modes.\n\n# \ud83e\udde9 ACCESSIBILITY\nDesigned to be accessible for a wide range of skill levels, with intuitive controls and hand-tracking support for seamless play, whether standing or seated.\n\n# \ud83d\ude0c RELAX & UNWIND\nPlay on the sofa or in room-sized mazes. Squingle\u2019s calming gameplay will soothe your soul.\n\n# FEATURES\n\n- Level Add-ons: New puzzles soon.\n- Mixed Reality: Augmented or immersive modes.\n- Challenge Mode: Time trials and global leaderboards.\n- Hand Tracking support.\n- Room/Mini scale: Play big or small!\n- Race your ghost: Beat your best times.\n\n# \ud83c\udfc5 AWARDS\nBest VR Game ~ GDWC Finalist\nFinalist ~ QLDXR Festival\n\u201cBest of the Quest\u201d ~ Gibby\u2019s Guide\n\n# \ud83d\udc96 Experience SQUINGLE\u2019s almost perfect 5-star rating on the Quest Store. Get ready to be Squingled!", "short_description": "Pre-order for exclusive bonus content!\n\nSquingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!"}]}, "developer_name": "Dr. Benjamin Outram ", "developer_privacy_policy_url": "https://squingle.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRAL Games", "support_website_url": null, "website_url": "https://squingle.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "pl", "es"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [],