055235784933454_4629890574825469283_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W2P_sLdY-AIQ7kNvgHd6u0O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQfTnPnpow7Mc8AQhSbrLxFVNC7CG1R_h5rXaRrR6PpA&oe=6752E9C3"}, {"file_name": "screenshot-11.png", "id": "1600564897226685", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974803_1600564900560018_6058402302123344296_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=plHOyGf-a5YQ7kNvgFMmOj_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJ31Yx8RydQ9UUCGYM0NzLiZOZF36cSfr-9AsTdOYwNw&oe=6752E568"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image-FULL.png", "id": "371948285912904", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86631740_371948289246237_6520084295772107681_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ma-VSvEcI4YQ7kNvgGeir66&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhrT3gYp22WwBeh3Dh121NwL494_f2wj1ClGtjaf9qgQ&oe=6752D8B5"}, "display_name": "Squingle", "keywords": ["puzzle", "mr", "puzzling", "squingle"], "long_description": "Pre-order for exclusive bonus content!\n\nSquingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!\n\n- 10/10 - \u201cThe perfect VR game.\u201d ~ Zimtok5\n- 93% - \u201cA masterpiece.\u201d ~ RuffTalkVR\n- 91% - \u201cOne of a kind.\u201d ~ VRGameCritic\n- \u201cBrilliantly creative\u201d ~ RoadToVR\n\n# \u2728 100 LEVELS AND MORE TO COME\nLaunching with 100 levels, with more added over time. Levels grow complex, featuring tighter spaces and new challenges.\n\n# \ud83c\udf08 A VISUAL MASTERPIECE\nEach maze is a stunning, morphing sculpture, offering an unmatched visual experience in Mixed Reality or immersive modes.\n\n# \ud83e\udde9 ACCESSIBILITY\nDesigned to be accessible for a wide range of skill levels, with intuitive controls and hand-tracking support for seamless play, whether standing or seated.\n\n# \ud83d\ude0c RELAX & UNWIND\nPlay on the sofa or in room-sized mazes. Squingle\u2019s calming gameplay will soothe your soul.\n\n# FEATURES\n\n- Level Add-ons: New puzzles soon.\n- Mixed Reality: Augmented or immersive modes.\n- Challenge Mode: Time trials and global leaderboards.\n- Hand Tracking support.\n- Room/Mini scale: Play big or small!\n- Race your ghost: Beat your best times.\n\n# \ud83c\udfc5 AWARDS\nBest VR Game ~ GDWC Finalist\nFinalist ~ QLDXR Festival\n\u201cBest of the Quest\u201d ~ Gibby\u2019s Guide\n\n# \ud83d\udc96 Experience SQUINGLE\u2019s almost perfect 5-star rating on the Quest Store. Get ready to be Squingled!", "short_description": "Pre-order for exclusive bonus content!\n\nSquingle is the ultimate Mixed Reality 3D puzzle game. \nNavigate glass-like mazes called \u2018Squingles,\u2019 guiding orbs while avoiding edges and collecting points. Discover why it\u2019s a critically acclaimed 5-star masterpiece!"}]}, "developer_name": "Dr. Benjamin Outram ", "developer_privacy_policy_url": "https://squingle.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRAL Games", "support_website_url": null, "website_url": "https://squingle.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", "pl", "es"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9351314144896221"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1078939736762971"}, {"status": "PUBLISHED", "id": "1124679472362691"}, {"status": "PUBLISHED", "id": "1081981156897711"}]}, "baseline_offer": {"id": "1078939736762971"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1732212001, "status": "PUBLISHED", "id": "1078939736762971"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9475696215791346", "version": "5.0.40"}, "id": "1083864340410537", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9288954704465499", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9475696215791346"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1083864340410537"}]}, "change_log": "quest_v5-0-40.apk", "created_date": 1731937447, "id": "9475696215791346", "version": "5.0.40", "version_code": 255, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9288954704465499", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9475696215791346"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1731884080, "id": "9470632716297696", "version": "5.0.39", "version_code": 253, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null