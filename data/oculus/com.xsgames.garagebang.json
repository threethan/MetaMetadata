.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k7qfpoT0lQ0Q7kNvgEfqTOm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDrVwP617HEDcTbvjk6JdFLL05wMa5bXcaNmdFPjdGhJA&oe=67408AD4"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fwitETs_rcEQ7kNvgFhor3m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYANO2tQPEhf9N3z5mYCSS3bUoy3lJpk2MZUWFd_yg400Q&oe=674085BB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=achEOF4sUkQQ7kNvgEPiQDn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAPA9zAH6UuGJgtU5Rwe6fNpfoGPnOr70HlwNp-QFXmUg&oe=67405A71"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07xAFxbOyagQ7kNvgEROOwK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBqG3yh9Ojtr-g7gcZzEg-kn2pL6eho-QC0tGEKJ1tROQ&oe=674056B8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HA7i_Y0BzzcQ7kNvgHl-ODz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBcZv-fnnUc3PBwExhdDtLBlx2HUeRyPDRqISH7ApMjMg&oe=67406AAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lRJg3RNaGWsQ7kNvgF2J-Zk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBaTMgU4eyJxz97p3kS1-ZegKkb5VFcp40Av0WHcZuWbQ&oe=67406DA1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYrGgoCyC2kQ7kNvgHMQUET&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCKoouCTCwce2oKFFyApS_MHpa35-YcNQhhxIpDXlsajQ&oe=67406CDA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gmL4xKXr9rUQ7kNvgF1u0iw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAjjkv4HDsNvpyalqtSZzGszq8MzMr0qMJedFmEtGNVXQ&oe=6740585E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734