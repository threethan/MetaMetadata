.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l94Bh8_aTqkQ7kNvgG87vEL&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBB2l4Edrwx0YN2L3_AuDctb0StNrZGf9-Z23ZbZIc9kg&oe=675845D4"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQgl7c23CmkQ7kNvgHiL4WX&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCNEsXEzKr2gwaKkAc6ZTM9xVtG0R-67VHN9I-9QG6a4g&oe=675840BB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1_cc0THSuzoQ7kNvgHAdpdl&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBSyc-sGxBRjrZvl8BjiWz-T84Mj1OAybIiTVLeYexvFQ&oe=67581571"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G__ke35t6v0Q7kNvgEgW0PU&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDBEYL6ksL4UWYMzroJgKrO3X_aoP2IjCuGE0VPVBt-1g&oe=675811B8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8FyJeLnuYSsQ7kNvgGzSS6I&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDZ3Fp8NzoqbLOpidaP_GIn-6062ndEzC8QS3HfkJbrVA&oe=675825AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bo38vC_oA9wQ7kNvgF3qG9g&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBq-_Z6AxvqAXc8AcpOktGx85vPjcqtsbMQJae6aDM-RQ&oe=675828A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3FfJNG76xwQ7kNvgGfl3mV&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDNMbrYgto8p3aaZEZXwAUr-iy8rjsKxkMhCfjiSvc0Tg&oe=675827DA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t1WnBC2ngRUQ7kNvgEjpO2J&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAbFReTfrxK2optU36jt9LKF-vwrn3t-TZVn89I-tGG2A&oe=6758135E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734