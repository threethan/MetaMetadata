K4dgg&oe=66D04738"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vHf3GM1T0swQ7kNvgF-8j6R&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9rqcDlxJDdKVwDyA36dLTellCmH3kjA8CWTi8Pdw2MA&oe=66D05B2F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDX_4WwVlm4Q7kNvgFRtd3m&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqs-AgQg6o596_sDyLN1hRfV8G7sknScdmtrRmTOS6EQ&oe=66D05E21"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uu6WU-q1g0EQ7kNvgGcW2wN&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqJDkLcLekTjO3uhJOrwdJ-xf5wn_nzA73UHDOxrGZ8w&oe=66D05D5A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSK0A28IMOoQ7kNvgGbcBHa&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3Mr5UTBx3iF8cyEM3U0QVjzhgqhEVGuK2iLTWqCpLIw&oe=66D048DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c_YewAw56ogQ7kNvgEIlp3S&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdPgSshZIkiUt78rf8bDoapzrbVOQ0ci6msAH1UFjd1g&oe=66D07099"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jwJ2CTCu46kQ7kNvgGF2inC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAMrUxuSWVqyxG37CyGdpfuXaqdS_yGfr4VivZFdVrIw&oe=66D0647B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-EqNMyGH1bUQ7kNvgGxDZuH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRSxsmQ6SgA6J4oxbANPiq-gXhtg8TZIme8lluGm0vRg&oe=66D0763C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O13dHXxlTscQ7kNvgFYCKQH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqkdfC3cSnYAfhGbv0NsQL6ulHxNdZSU8WxE6pbBIUlQ&oe=66D0421E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA