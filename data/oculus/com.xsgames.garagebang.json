Bk8B3bCGrxvmiEgw&oe=66CDA006"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ejk6HPnHV3kQ7kNvgHPQXFA&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcf3Qsr_oIYjOC4NDItA_DhvwMfQMBRTQ3tPmzuaP3hQ&oe=66CD9E39"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Fast-paced first-person shooter game, you have to shoot targets in a wide variety of stages.\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\nFEATURES:\n- 28 stages\n- Classic and Insane mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "1514656502659964", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031419_1514656505993297_737730914029555485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H1R2Ggof8WgQ7kNvgEe0YuI&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9vEdlc-nDsoEB675pHwW5vOVrmoDyPzQ-yU3P98XpmQ&oe=66CDAFE4"}, {"file_name": "mini_landscape_coverart.png", "id": "1366456457538723", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_1366456460872056_6490869955264152744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=58_YYgFOBFMQ7kNvgH-cpV8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBV6UCPrSEcGmUOaTkc5HzX64U9l1-RWBmonblOt-Qupw&oe=66CDA9CA"}, {"file_name": "PDP_cover.png", "id": "1273758683569584", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572946_1273758686902917_3029776345887807998_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PofEhieSLCgQ7kNvgEevwrj&_nc_ht=scontent.oculuscdn.com&oh=00_AYB58Jwvxa61m5KcTjWKtxwhknCBIVelc4GRuqVDh-fHuw&oe=66CD9F5F"}, {"file_name": "square_coverart.png", "id": "979858306537974", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982640_979858309871307_727268071153472120_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u0IrcilBz1QQ7kNvgENauU1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQ6L6XQpYHMkxZK2d043DEtZpCe3cZEMMhaikA0lh0vA&oe=66CDA0EF"}, {"file_name": "logoTransparent.png", "id": "955770212508078", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984463_955770215841411_3379343552614124445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lf4y_GeWyeIQ7kNvgGm6OiL&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0FI0HaaQQsZ_MY0wM0SA6ORYIg1RiTdNDoPF_G5xrFQ&oe=66CDBC2B"}, {"file_name": "landscape_coverart.png", "id": "779869723710016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569426_779869727043349_8924313598816518583_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iHDkNBvNyY0Q7kNvgF3J0Et&_nc_ht=scontent.oculuscdn.com&oh=00_AYB28LNqeF3_nwuUHEOLjdCQht002HJjKIuHhCmRXxpbxw&oe=66CDB6E8"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PMhNXOGC5pwQ7kNvgEZTE_I&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBQTzCO5X0d4zG_CKqmvGpufnKSBU42XqAmlNs4nftfg&oe=66CDA014"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cRcNNWA4QmcQ7kNvgFrGhDS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfh3RoOd-CZhj-u3neH7Z3Nko5QxIQTBbiqaOwmVxj3w&oe=66CDD33B"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9cqPU4G1Zc4Q7kNvgHNIK46&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8zey1YVk2wbXxHI8oRHCzt3g7UmxydPfUtst3DDBO4A&oe=66CDA7F1"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jioTiTNqXoYQ7kNvgEe0cQ4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAwQpzCiAOXi_GLiHbT0RmuWtlMU6ZUmcalwaHtatfgog&oe=66CDA438"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JNXPyNFgWn8Q7kNvgGNDvPm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBt8n_DsHal7iHR-8kDo--sTxHUxw3DwBgBuAsWkQipMg&oe=66CDB82F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDX_4WwVlm4Q7kNvgGFBZKW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDt1OjFZGzLWJLnYSrXLX0v8BRMv3l9d285wUP9O5zteg&oe=66CDBB21"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7595744743887217"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O13dHXxlTscQ7kNvgHu46mg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZwQPN0NIBHbYfz5b-B-fMfAhFoI-mBbMnxJx70qvJWg&oe=66CD9F1E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Garage Bang", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}], "