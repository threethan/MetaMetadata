=00_AYAWLNBycaqnpUiyX4OwHJ4yuvgv3rlP9VjOYhnHefHgEg&oe=66F93BDA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DuzNlLEdwsAQ7kNvgFT6KwG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCIpRcJXQv08jvb9A4NLupJyAjRp1YFlCzvHMTceEXqQg&oe=66F9275E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7DG-djZoaTkQ7kNvgHGLzRo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsNyIADOffykw4pYvbU5ZUXIOW1myJoU_ELMPvleiULw&oe=66F94F19"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yR8JjKzdfiAQ7kNvgFgCEd-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAmn9s0CtjHtoCqWeB3UpMeNkkhWX1cEwwXiJgaeGymQ&oe=66F942FB"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6DnfBvbIucAQ7kNvgEikNr5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDYbInag_XY9zU1hvICG18cIzkQky0fiqUqbhmUs-y_yA&oe=66F954BC"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xYy6ck0-6OQQ7kNvgHz_M1c&_nc_ht=scontent.oculuscdn.com&oh=00_AYCW1aj5-tHI-FufzohKh4Zjj_h4RP648PyfLVBpsFky8g&oe=66F9209E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974848_190146123493319_8631192710146771821_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3fFWI5FYCtsQ7kNvgHBHOZ-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNul3KFEWH6VlDPMDdJgP_24ghmlgqp6N7KdAySzlDzw&oe=66F93C52"}]}, "id": "642467400656509", "locale": "en_US", "screenshots": [{"file_name": "5.png", "id": "218423794266674", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974848_218423797600007_8812047711220896242_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kvSIyNgEmDwQ7kNvgHq4D3Z&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnujDr4LcQ7oqBo3uu7LICxeOMBrCOta1D5cf7zQo9Aw&oe=66F94AD8"}, {"file_name": "4.png", "id": "1247617589481297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974441_1247617596147963_4600543940503140675_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M5yAik7vgaMQ7kNvgGPsk_f&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkJtnn-WSzN4n8kyTLbB9Mjk_JPVw5LiODdmuL0RZOaw&oe=66F939DF"}, {"file_name": "3.png", "id": "1079502570104737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031563_1079502573438070_6889708893237732852_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ypyREZwmbBMQ7kNvgE-92as&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdJ-zQV_geBpNLIriQLzrSPkGA4FamCvqkn7v0nixo9A&oe=66F9277A"}, {"file_name": "2.png", "id": "561346586153760", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_561346589487093_6341898473789029941_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GC7AVUDvbRQQ7kNvgEMuiBq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMyPio2Iut0Uh7D0mZ-tRCRgfyXncR4rn7gjO2EgHcuw&oe=66F94937"}, {"file_name": "1.png", "id": "133236666410618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974813_133236669743951_3521471306175933903_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dxGIi5wDa2AQ7kNvgEzGPys&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnlCLiYYfIgRCtsAaCcyLjmRxuX8DDiySH4KEavhc_pw&oe=66F92186"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_co