5YFtg&oe=66D6DEB8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s9FqS7YO94AQ7kNvgEg4jr_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBY0zhtBmgqPZkTJjZvZb9ARmycUIUpPiUlw9sSIczd1g&oe=66D6F2AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgcIdIJEkuQQ7kNvgFPLRfW&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8nTOWHhgX-VWZSimOn8k7Asw_z3opclsB3ujrx9ivIg&oe=66D6F5A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D9ddjpIpxZgQ7kNvgEJKvUA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgiEixUBeSTAQv6euWLkEiVLR0ifw6KPkZUSgXLzQ2Wg&oe=66D6F4DA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E5HWn27C9pYQ7kNvgEnOKTJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJgjcE2OjIBiZ4VREBiR-cmppPXf-Bq_zaOugNGdcRiw&oe=66D6E05E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWKOMSaVX1cQ7kNvgHXgAm5&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgAQdmATcEFJWedDlQGHXEbI9bjtYLuCMHX1jCdU8QYw&oe=66D70819"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0djtDgWGT3IQ7kNvgHknP4s&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8nNlT6RAja7UU3_K8Ovl0RQvWFshmUNil0m99Ul06ng&oe=66D6FBFB"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k99oL3yB_oIQ7kNvgEag1gF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBW9coNEkC8-Ky47M_oes_itzP_Fho6BYdV5Ufi3bAc8Q&oe=66D70DBC"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqMNl0Cnqo8Q7kNvgGY6svl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAn9darxowjhws-AwxSknmkImBTUP5BqF6v1Vp_p0SeGQ&oe=66D6D99E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA