com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SZb4JmMMvNwQ7kNvgH9lcr9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkhIL18HIoq_LwGmHkBHDVp4CLKl2sQtpLyETNHBijPw&oe=670E3994"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_0KalxxLBNUQ7kNvgE_jS0a&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBK-mDn2CE-LuLD1PYTT2uDTC5fEtAVkTJk5EzQLJpR6g&oe=670E6CBB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=foVsC3u2BUEQ7kNvgFKJnis&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAoqPc1pFUamYcDm7I7jj0ui1Yrx-dxcrSwd_1Kf_d7Jw&oe=670E4171"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=leBCTTlDy2UQ7kNvgGEcFU8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCaTq6EfYOMcmHIYYxF3mKPF3fyqWvD7gV2feCFidt6w&oe=670E3DB8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rexMeyEVBIgQ7kNvgGLKWm3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVix-VuCGrZ9LIBNg5H6da2Ju2ZAMgGZKhDMahmqCbGw&oe=670E51AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5r2t6De8RMkQ7kNvgGYTAQI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClqt2MhzzH9DZKuGCT3YCPgrd_nGhTLHyKeiG7vj-ntQ&oe=670E54A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7595744743887217"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_38086558664360705