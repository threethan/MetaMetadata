h=00_AYAcE7YWqcwxd7dRjB0DOp4nnEo6AIXj1dCeHicNbIZO7Q&oe=66E03CB7"}, {"file_name": "1.png", "id": "133236666410618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974813_133236669743951_3521471306175933903_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3TYhNQqBSHQQ7kNvgHOkyjP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR8cfA7sZiQbH-Ht1auXDA8&oh=00_AYBSdQhOrQ9_jsVQ8Qi_Iwhg2Bxiud18Ztp6T2-vXLOoYA&oe=66E01506"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jx6naKGu6EYQ7kNvgHAGTIW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR8cfA7sZiQbH-Ht1auXDA8&oh=00_AYAX1h_-emAoshT7ihYIyh27CW0vdaWqUmxjFHQBryME6g&oe=66E01339"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Fast-paced first-person shooter game, you have to shoot targets in a wide variety of stages.\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\nFEATURES:\n- 28 stages\n- Classic and Insane mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "1514656502659964", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031419_1514656505993297_737730914029555485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DzpYnCaadOsQ7kNvgERKE54&_nc_ht=scontent.oculuscdn.com&_nc_gid=AR8cfA7sZiQbH-Ht1auXDA8&oh=00_AYAADFS