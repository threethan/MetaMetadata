0&oh=00_AYAJNsU1gdtp-Sul6WvhgVJpe3AB3kNJirZ4ZzxZHkVWOA&oe=66E571E8"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UI88ZnTM97UQ7kNvgECqp3u&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYAEyKip1omx5oSBv9MLoaUUOMowfhKYHPWRvGCUb3oW1g&oe=66E55B14"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U7A250d2I_8Q7kNvgEPHpDu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYCyukNmxR0phb_51hDWQVUui-LWM8IhKFZb544u3HOiIg&oe=66E58E3B"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aB9nYxjqK1sQ7kNvgHVheYM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYCDNpHnrJTwTXut6baxClWLeS0jRU-Kn5xXz52Vk38Q8w&oe=66E562F1"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mQqXISM9PhkQ7kNvgH6Vfbn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYBT2NVtG9jxWryk_q0i3E41Nn1jp1-iOo1v3bOCsEnFIg&oe=66E55F38"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0MGUadWSBhsQ7kNvgHFZLbm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYAF4PYrwAEaLh_DM2SkdjUxi_88HXnwg6Y0KiMP61Z_Pg&oe=66E5732F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QjUWQVV_x_gQ7kNvgF3a6Bj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJDHhcJO3NHf9djzgmYXfA0&oh=00_AYDtAjzZxD2_v9tKRjOz8ZgW0H4qI8Vr7qbz8TS9nAoLqQ&oe=66E57621"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULU