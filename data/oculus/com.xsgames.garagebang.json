GilzQ&oe=66D83038"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s9FqS7YO94AQ7kNvgFgMzL1&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7lnDNp7dXR7j_2UGnk6W6w17lRfiDv_kWRaF5UD-cdg&oe=66D8442F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgcIdIJEkuQQ7kNvgHrymTH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC-BXIOLDH9PsgzCeWyiaDr8kTVbKtxuPcdhCT5ueMsQ&oe=66D84721"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D9ddjpIpxZgQ7kNvgH4ymJt&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7eAuk-PSS2pb-oC7QoYYZyN5Z_GWCIAOBPVNQRPTFZQ&oe=66D8465A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E5HWn27C9pYQ7kNvgFoAVEF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPy4S86c9MMjG78V1syuTb2NFjna4GOp-bdA9aQkSOyg&oe=66D831DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RXoq2DKLH-oQ7kNvgGXVS91&_nc_ht=scontent.oculuscdn.com&oh=00_AYARwW8ks3izoh0UfafveNM6-kSfndvUskoCtmtbYY75Ww&oe=66D85999"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=audTFyNK_qYQ7kNvgH4OMMg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCWsn4TZLDy8shlDWWXLxFMBm0_dhvo3bBeiMu1Iw7dQw&oe=66D84D7B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nvo3BwejlVQQ7kNvgFDPgfw&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6xpyteCF8RfSba8i5KGJE4QqEpnEBi7U5y5SE0PdZkA&oe=66D85F3C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqMNl0Cnqo8Q7kNvgG26zcf&_nc_ht=scontent.oculuscdn.com&oh=00_AYBd1pZHOv-4eSNhKh8itXkWNC61V4rTi5wV2mJgk5-1kA&oe=66D82B1E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA