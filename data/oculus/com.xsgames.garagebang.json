471306175933903_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ppl7SNEGBWcQ7kNvgGm6n5J&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBuvirXXhA3V9MRHybn02gUqCbWVTkQZCjGlN3krVYeXg&oe=670142C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LZWJcZDVQrAQ7kNvgGMKEv4&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCr5wJ0mmT17mSHhd6t3HJFt6sMt3738mplsLmw40XOvw&oe=670140F9"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Fast-paced first-person shooter game, you have to shoot targets in a wide variety of stages.\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\nFEATURES:\n- 28 stages\n- Classic and Insane mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "1514656502659964", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031419_1514656505993297_737730914029555485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qxhe3uYcT5wQ7kNvgHpmHGE&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCOy-rC7oGpdp3y5wjWk1xux1NaN7SbloEH15oflZBt0g&oe=67011A64"}, {"file_name": "mini_landscape_coverart.png", "id": "1366456457538723", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031639_1366456460872056_6490869955264152744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_PWJLmpWqc8Q7kNvgFTTppM&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDD58nc7FX-Z9NGH5ATAOgm809Zl6J8oQrfh8pvuVekZw&oe=6701144A"}, {"file_name": "PDP_cover.png", "id": "1273758683569584", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57572946_1273758686902917_3029776345887807998_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CqFcbQBC6AwQ7kNvgGvFzfx&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCOzl6RakE-uD4gjOm3B7AdC4_TqXua8xjrOsOqXCSZ1w&oe=6701421F"}, {"file_name": "square_coverart.png", "id": "979858306537974", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982640_979858309871307_727268071153472120_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jLSWskR2sAIQ7kNvgES3hH0&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD9xu86JJpZIbLFy9Lo-CG5XeJCvhh2zqDaLUEJLj879Q&oe=670143AF"}, {"file_name": "logoTransparent.png", "id": "955770212508078", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984463_955770215841411_3379343552614124445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K863IgdbMaUQ7kNvgHUTU-E&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYADsg0dSJXK7SzYD80qbrrNauloivYNgD85UmcuNqllDw&oe=670126AB"}, {"file_name": "landscape_coverart.png", "id": "779869723710016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569426_779869727043349_8924313598816518583_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KJ-KGcSX3NwQ7kNvgFPU2zE&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBMArHcoRBr7dpJs5rRzp8f80UyYK8Ia-Wg0MqIRPc06A&oe=67012168"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rEaSzmWW2lgQ7kNvgHBi22b&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEO5Cb1Nf0EIhjwHbLke1xB6kLQMI__lDQwasr9i7kCA&oe=670142D4"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z45jmC_2iooQ7kNvgFS75gG&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBK_xR6LY6gHP_fjDde8m_PvXmOIkGSzqrFlDyTl49lw&oe=67013DBB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QKrqaQ2Af7cQ7kNvgFGD5tw&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD__R8bUSgPvd7I646yTxU1PGEc9zDc1kCkDJ7Cu-hFVg&oe=67011271"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jMK-Q7d2m4MQ7kNvgGiGEal&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD445SMvtuMYppFUBC75oqz7cswXVz088Q90Ii7hA-_IA&oe=67010EB8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dmcU-BwSvOMQ7kNvgECvWJf&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCWHBby6JTc6UPy4itJScjzN-j-JfN-Tay2-a_xdBO7mA&oe=670122AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5CIylnYTMqcQ7kNvgH6-HRM&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCwMHN81LzWDFd-4opgbqP2Nhgprx7Nmo4-OOhovw2Euw&oe=670125A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7595744743887217"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0IjUbPIrysAQ7kNvgEOPHoG&_nc_ht=scontent-sjc3-1.oculu