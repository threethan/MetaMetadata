.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GH43XOrpFLcQ7kNvgEhhI7l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmQ0FcPePVwYvLw6xw0H5XRm8M_sKhukJ4Pkxl7lCp9w&oe=674DB9D4"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10Oi7jWjiZkQ7kNvgH-RFuZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCGuxkxBlRt_0Ca9lO-koO5bJTKsNucfZFzs7eB86aDAA&oe=674DB4BB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=II7n9UEyUhYQ7kNvgHybRLk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUz2QxccR77m8jdIoCMTDrg10ZyC8VpUigXjiQkEvdtQ&oe=674D8971"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ozffW6r78d4Q7kNvgEMqJCF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDe-N75tn5aMeuUFE42a7SZt3xM0r7aZMo2UeZaiuvYiw&oe=674D85B8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-iy32_RT2AYQ7kNvgGOyN6Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjR3AIBmSEPz4GinTkYRIXtfU17R7lYjorXSru0lWCwg&oe=674D99AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RJiWQF4H1_oQ7kNvgF-qFOL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYClxsOVaGUxk_kbodY39a-zly63aoGpbGH_7_sJlRyWkA&oe=674D9CA1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YqX5_4BpvE0Q7kNvgEe0dBT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQ0qL4LtaNmjTL54n6Cm22gyWuoAXkUpwG9wnYnDsx-Q&oe=674D9BDA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3UCIoH6__RMQ7kNvgHJ6t14&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDz9biYOJUITJtpZ-Db0w70K67gjCji-AZLslWbX_S-IA&oe=674D875E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734