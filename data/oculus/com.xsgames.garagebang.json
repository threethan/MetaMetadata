.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TTxB3kJSqJcQ7kNvgFf_kKw&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCqylvlLKWJEsyOzwNuQEMMbOPP59di3ik6tZqvKej1Yg&oe=6751AE54"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfcYKLMt6i0Q7kNvgHI5Rlr&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYB4bdWereggq00G8AQ-y3bQxWbjP5gwZO0u_CqfIj4ZEA&oe=6751A93B"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YxIBcrpyz_0Q7kNvgGwZM0X&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDlJYd57lcbMkb0zqUji6HjaOhOJfpyCz0iP6oCK59zIA&oe=67517DF1"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bxm0IkfUNTcQ7kNvgELj61V&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDOhNsxEvXsnZnSIeqmW1Wze8OHcbTjQpuY7FL1zuG1Rw&oe=67517A38"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4BtCT5FHTlcQ7kNvgEUMi1d&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDZbyuusybzqH5R6TMsxrVRDVOfuNT0VrsO9q2IAu2IbA&oe=67518E2F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DP3LpWC6FrMQ7kNvgF2mMlf&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA--Vre1tzWu-eRIPtslA6oPpzVNShFntyLVc1oe3UhMw&oe=67519121"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rwnoPQla4kAQ7kNvgH6gAtC&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDfcGPHws9coMjknqK43dxgBqmEdjDnPknobIMrAf0f9w&oe=6751905A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHXhQc-8eykQ7kNvgEc61j-&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCJ4jep8dGCabhqYfQC4-P65heRzZuwPicRcUW6bUuwJw&oe=67517BDE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734