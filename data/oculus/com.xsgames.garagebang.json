z&oh=00_AYD0qrVqOd_qLWG5eWnXoGJeB-ruoKhTHw-o-8GnFkJyXg&oe=66D44E68"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pg_4GFZ2vvYQ7kNvgFh-Kh-&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYArdgHuVsTbQpPmBMsBIRNOBT6caAvvo9eyqHMHNRTzPw&oe=66D43794"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y20gVoQR_fUQ7kNvgEtMRaz&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYCGzNEVv0R5g5qvecdaa0Srx67qH8hrqgphZ2-xPVQasQ&oe=66D46ABB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SejjuFjyuwgQ7kNvgF7QKa2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYDqTQuSj7PEqskxA2EvHi8aApl0YgVkPEPMuIXNNk0HJQ&oe=66D43F71"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oQTJDr3LvwsQ7kNvgGUCT4l&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYAOa_Wtl_9XIxL85MaV0_TxsuYNstnySHbo7yPswa-cpQ&oe=66D43BB8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEXH1iYwx04Q7kNvgFbcAiO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYCPw6Ny41TLl4qztHXYDLRJ7DK59SUm9QXCB2ugCcQOIw&oe=66D44FAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CXqOUoYzHgwQ7kNvgGlif4l&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATClx_zGIuOO6xQvM3kGLqz&oh=00_AYDTcB5XegmuTmmPmku1Cs_VoXCMZh2xnChC8hwqi1oIHA&oe=66D452A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULU