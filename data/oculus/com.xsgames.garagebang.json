=00_AYCGwM_760IMcKRM-A8l1nbdqL9DRAvar6bJjvYqoDhy2w&oe=66FD305A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CCVrnBBArEgQ7kNvgHbtgpD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCd6vCk3oeh1GZuQ4F7vExPGWiH31vYrSHCPRezRNKAnQ&oe=66FD1BDE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xlMbGrXDkiAQ7kNvgEU3nAM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgEa99V0oCLFvll9QvwXr5ALBLty3udEe1C-XYmN5Ehg&oe=66FD4399"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ozYSWpKAp8Q7kNvgGK9dgZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCeiPpeuOM8K5Krf6xkckhJl4Qu48BMTY5r7KlOHfEsXQ&oe=66FD377B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=79DDLega3IUQ7kNvgHy8EZ_&_nc_ht=scontent.oculuscdn.com&oh=00_AYArUc3ljKA3ZtTJhS06jnrUh6WHpHvncYP437DhDaHsSg&oe=66FD493C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=utl4-orxKRAQ7kNvgHnF2L_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCa6TP0f98cc1Cosj34_rXLnbjTHMHq78HjICMYUE5ozw&oe=66FD4D5E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LANDSCAP