U9EMTxkCf__vSBPw&oe=66D58906"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8tTOI4ijvt0Q7kNvgGnd_2R&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-BqF4QMZxkhhdkGWjCLaLaqzAMzd9eridIPs2EvCioA&oe=66D58739"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Fast-paced first-person shooter game, you have to shoot targets in a wide variety of stages.\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\nFEATURES:\n- 28 stages\n- Classic and Insane mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "1514656502659964", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031419_1514656505993297_737730914029555485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pKREdYiZnCgQ7kNvgH6us9I&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYuYhFRPbRtZFnHuafzhd5azmCCXGF8J28VuXq-03-Ow&oe=66D598E4"}, {"file_name": "mini_landscape_coverart.png", "id": "1366456457538723", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_1366456460872056_6490869955264152744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a2_AH_uX5RoQ7kNvgFRsUse&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQ6fwa1pn91rqBVBqauXdQiZR4Fd5T1XE9-o1wDkvQvA&oe=66D592CA"}, {"file_name": "PDP_cover.png", "id": "1273758683569584", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572946_1273758686902917_3029776345887807998_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e9Lr6KccMxUQ7kNvgEI88Hg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlFuyNc1MA0bABNxAXIcSJ9gyoi0EjxJnYyvwSJOIPtw&oe=66D5885F"}, {"file_name": "square_coverart.png", "id": "979858306537974", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982640_979858309871307_727268071153472120_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6-ZEMNn0_54Q7kNvgHdQ1uy&_nc_ht=scontent.oculuscdn.com&oh=00_AYBu2vdrNz0MBp2hvJNYgKbVXHpe4cgZKONaHT_onbUbHg&oe=66D589EF"}, {"file_name": "logoTransparent.png", "id": "955770212508078", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984463_955770215841411_3379343552614124445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_FQrOJ7048Q7kNvgG7E0et&_nc_ht=scontent.oculuscdn.com&oh=00_AYDOEZ5EwhwyMAXUq6Or2_IkFajtWhwLV6XvQIvagwYU-w&oe=66D5A52B"}, {"file_name": "landscape_coverart.png", "id": "779869723710016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569426_779869727043349_8924313598816518583_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pluTExNkWuQQ7kNvgH4bouZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMbe6JzQnhNwD04VV80WgLIoHKT4MP1Dx9rOAdQEOYPQ&oe=66D59FE8"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pg_4GFZ2vvYQ7kNvgGftuOD&_nc_ht=scontent.oculuscdn.com&oh=00_AYB87sASTer9akolXFi-eybLEBfnwG0eA94FpZoZUS_zFg&oe=66D58914"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y20gVoQR_fUQ7kNvgHYObcF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlLhVc-bPB0pWsLKj3kyxQURqt0nnIQxTfTwU3PfOhAg&oe=66D5BC3B"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SejjuFjyuwgQ7kNvgEqSvEq&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2jDdVe_kL_bkvoELPWqUmDZIXSVxqY37lPsf3X9YzLQ&oe=66D590F1"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TdLslJHN4UkQ7kNvgF1ixxk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZ9umext-ozB9ifYvHhK1gIVUB3Y1715NGH7Fj96BuWw&oe=66D58D38"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEXH1iYwx04Q7kNvgGWfbcJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsiWxz56jawo5_2iitRTdRcZsHoEZjJaxY8EQa5EWiKA&oe=66D5A12F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgcIdIJEkuQQ7kNvgFk20D1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDr-_gt5RC-whWQ7TO1tIf8RFHGVPeeFF831fa4-p3dNw&oe=66D5A421"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7595744743887217"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqMNl0Cnqo8Q7kNvgE-Ihlh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDA_yejjRfjZ84yI_o8Z6zsLOucHMzBEqF5j8FOp5EokA&oe=66D5881E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Garage Bang", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}], "