6BuWw&oe=66D58D38"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEXH1iYwx04Q7kNvgGWfbcJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsiWxz56jawo5_2iitRTdRcZsHoEZjJaxY8EQa5EWiKA&oe=66D5A12F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bgcIdIJEkuQQ7kNvgFk20D1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDr-_gt5RC-whWQ7TO1tIf8RFHGVPeeFF831fa4-p3dNw&oe=66D5A421"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tOXsmma1Vm8Q7kNvgGSlG9V&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqVihA9Qqs_3tExSdAQAErsdGav_gmGp3JXLNxWYsc0Q&oe=66D5A35A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LO6ozf2qiIIQ7kNvgFWu1I5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDH9_TubHpWGKtKjbbFAMu18gC6e-yNB23JHrVsM1cfAw&oe=66D58EDE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWKOMSaVX1cQ7kNvgETakje&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPr3JpBFdvW44TOmRS_EQTWepq1IxYWIpkh6zs7v39_A&oe=66D5B699"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0djtDgWGT3IQ7kNvgGZ4nG6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSDZ9HsYbHo-xlu_N6jVvn9EnjRdaZCfJC5I7JDkefuA&oe=66D5AA7B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k99oL3yB_oIQ7kNvgFNwkCH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDK-JyjotCg9EnuEvl0yJCPWrZcIQN0jE5a7fxNkmmXhw&oe=66D5BC3C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqMNl0Cnqo8Q7kNvgE-Ihlh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhMnDrbJJWWRS0q7ozWBe2NpP7wcx4DlfiD3rVv3D99Q&oe=66D5881E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA