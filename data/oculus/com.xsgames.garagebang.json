.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jy-oWW6fokMQ7kNvgGJ3o4U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDoZrkAaS2bQvmnLSTbvpYD3UNlb97QikGOlNzDK00rBg&oe=6739BB14"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lV4gRqNLfvIQ7kNvgGlae66&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBS5KoL_tJncF4ZNVULlnzTuCS1IUH24fAck2N63fXLLg&oe=6739EE3B"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rarzLPkqShcQ7kNvgGGKod-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgKHsYxLQz_gsi_YS5NB11AsLOaA65fdKSQk7AtfpJiA&oe=6739C2F1"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZCbd32Jsqd0Q7kNvgGQEMrB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEtQkMahqnTcJKU8Vgvphcj3x1ds-U0iSaF4wdho2WLw&oe=6739BF38"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8YtFNPE_rrYQ7kNvgEoYEQV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBN9Cuf08Xv4rPTw4hSjr1dBp4sXQy6hfvJpqkYoi4j2w&oe=6739D32F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q-SsHN3VBO0Q7kNvgHMm9mo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2uXWdehnOA65z_gorI0K-SUMckIeaJRRUyfMHnqmkpA&oe=6739D621"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EE8y0HCg3pcQ7kNvgExHhxz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCGFOSpoG6GQa4flkxsTCJxykCbekxmT4kC7rqRn7u7OQ&oe=6739D55A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9Bo0h6nePykQ7kNvgGXBifp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYOcuAEfrhU87zWFiA0sbJcZXoP-bNsss6FgJmvVS__Q&oe=6739C0DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734