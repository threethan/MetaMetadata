ybJESRJslkJiXXTQ&oe=66E16686"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jx6naKGu6EYQ7kNvgHEMfLx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXXYH99ydkLptBFTypbRa6-eboCshCmpUpmy-oUnI3AQ&oe=66E164B9"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Fast-paced first-person shooter game, you have to shoot targets in a wide variety of stages.\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\nFEATURES:\n- 28 stages\n- Classic and Insane mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "1514656502659964", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031419_1514656505993297_737730914029555485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DzpYnCaadOsQ7kNvgG_DLrN&_nc_ht=scontent.oculuscdn.com&oh=00_AYAmUwlVxH04VcZaCr2hQ0wcKxD1V9jMmFpwbqBT70reIA&oe=66E17664"}, {"file_name": "mini_landscape_coverart.png", "id": "1366456457538723", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031639_1366456460872056_6490869955264152744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VohTzBHvX_MQ7kNvgHoGR5J&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJcztqe0gDFpSujEZv_c6zCqUl5XLxYP0sRCYuNQ4Wxw&oe=66E1704A"}, {"file_name": "PDP_cover.png", "id": "1273758683569584", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572946_1273758686902917_3029776345887807998_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m6HB3tstZIoQ7kNvgF_J3YJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDybh6ypb7AhU0lvYLif2OKf8DubsK3fUSgljOAFA0wxg&oe=66E165DF"}, {"file_name": "square_coverart.png", "id": "979858306537974", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982640_979858309871307_727268071153472120_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OAtnz9bDz08Q7kNvgElBcCe&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXfGTznkcDgavO-Ea7ShHKwfUQ02_y8QhguSOZl5iGyQ&oe=66E1676F"}, {"file_name": "logoTransparent.png", "id": "955770212508078", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984463_955770215841411_3379343552614124445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mPPkNVR5YsoQ7kNvgFKSPRy&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvcEE1mzobJcAMGqm4OFS7kX86X5uHSE5FfVccFeqUvg&oe=66E182AB"}, {"file_name": "landscape_coverart.png", "id": "779869723710016", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569426_779869727043349_8924313598816518583_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k1gjqZTs7hsQ7kNvgFmyhm3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCA_KRwlDAv5iNtXRFgShhYYQ_0CqPXQOTgEqRqX196eQ&oe=66E17D68"}]}, "id": "780150390994839", "locale": "it_IT", "screenshots": [{"file_name": "5.png", "id": "2597680973719056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TTL8eyzPTrAQ7kNvgG7Un_l&_nc_ht=scontent.oculuscdn.com&oh=00_AYAu27c2gI9x-ZaLZUJuucclT8niGgD9g0fYPdmL1T2iWg&oe=66E16694"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J2yV_XSLryAQ7kNvgFV0upD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMd6eX2Pi6NsmkiVZzP93hsbtPBBDC9EMLx8XFc8jvjw&oe=66E199BB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b03DzNH9TA4Q7kNvgGPu143&_nc_ht=scontent.oculuscdn.com&oh=00_AYC9FBhR6cB8k7byHbsT_H-DVfbFlYV0TVl1Rs3Y6NOi2w&oe=66E16E71"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8odzX9AZ4PAQ7kNvgFGvEAz&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvjlH6ZLvW5qgg3pBJpbNqcLqy47ULReDJfBYzqNujMQ&oe=66E16AB8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1__yhCmdBGgQ7kNvgGcfDS3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBanTUR3jOLfT9s6ezXx8qHrzzzdIhVBuyV7AJscWFnhg&oe=66E17EAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=74m8kLmXsP0Q7kNvgFOioWo&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhS60XJTsEQTVa8_NWXNHwgHRMQ1xYDqLDfPsXCoaDIQ&oe=66E181A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7595744743887217"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZRx2DwFmvBQQ7kNvgFijQ7D&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8vEiJg4ll5o88SE2_DK7FHufZ8pujlaBJJbDXrXGMAg&oe=66E1659E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Garage Bang", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}], "