zpwxA&oe=66DAD338"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vo0JgBPUSEgQ7kNvgG2mOr-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKerAojjzYkLfAeryx3TrdXBpv8z2fk1H6TKL9FccpKw&oe=66DAE72F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zc4DRtFvpGAQ7kNvgH4vYmm&_nc_ht=scontent.oculuscdn.com&oh=00_AYABywo02UifOUUqS4qLxSOmXcMTWE5Uxi8HP4AJl8qx6Q&oe=66DAEA21"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Ut5Zm4wxIMQ7kNvgF6Tq32&_nc_ht=scontent.oculuscdn.com&oh=00_AYBP0ZSCCvWgzxYfS-ror0HflthiAyMCck7b_rRjviTyAw&oe=66DAE95A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AkbC39RI8v0Q7kNvgENZrwc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbNZZoneQ_NwtmkVgaQ4-J3p7RqaRY9N0zk1yMyIDG9A&oe=66DAD4DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RXoq2DKLH-oQ7kNvgEKH4AL&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfX2Y-h0lZkeUpwMKHXpul_kf0JxZTV9MgtIxX0HEDAg&oe=66DAFC99"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=audTFyNK_qYQ7kNvgG6WMGk&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtmCft0KkPlZSASSDarxz_HooO-_A8KrhD4k08DQhsCQ&oe=66DAF07B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nvo3BwejlVQQ7kNvgH5Jwss&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhtNsbtCMogg3VVdVrMwkkmsdhXpV3QaD3-9YXt-mkrw&oe=66DB023C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hZuBlxgUsA8Q7kNvgHd7bHo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCytudCTNG1j_GU-fhpq2jlj3V2ebymY1qsWfm0__ot5A&oe=66DACE1E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA