.oculuscdn.com/v/t64.5771-25/75203617_2597680977052389_6304519908929273027_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TUKlJTPJpFQQ7kNvgGAmzAF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvoWRykupYXAwxH4Y9atI-XmZMN6skhZPeIFVkoSx3cQ&oe=674ADE94"}, {"file_name": "3.png", "id": "639314694718075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65229100_639314698051408_735078970792540924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10Oi7jWjiZkQ7kNvgFOIvrh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrC9qhzmmRpSZLesuBdFWWtwdj3AXcrsqBac1KhAU7CQ&oe=674B11BB"}, {"file_name": "2.png", "id": "554501230179619", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75245822_554501233512952_5703012804592129373_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=II7n9UEyUhYQ7kNvgFAO8e3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAr7eXFZPSEoD_P_CQj666O8hbu7166RNCBO5Od66kiNg&oe=674AE671"}, {"file_name": "1.png", "id": "645364133986481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982709_645364137319814_4246812975223359293_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UdmIAs-y4Y0Q7kNvgGMzHot&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHo_yzccNDDcaUF6S5XIhxyggN-SS0RkPbUMexazaaBA&oe=674AE2B8"}, {"file_name": "4.png", "id": "174394518564426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001691_174394521897759_6020770035674439214_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rPeq5U8qYg8Q7kNvgGCcMf9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5Mih3Y3BiIWdgTFrkfCKQrnG_dsvbULd6QSXjxk6G3A&oe=674AF6AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "152283524306145", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982642_152283527639478_7679354497362835353_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HbO0mdDrCagQ7kNvgFmtkrh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxZyNU2Ax0rYIMF6kVNTlHxFkgP6Fv0zG7Btp0rGh0nQ&oe=674AF9A1"}, "display_name": "Garage Bang", "keywords": [], "long_description": "Gioco sparatutto in prima persona frenetico, in garage Bang devi sparare a bersagli in un'ampia variet\u00e0 di stage.\nTutti i bersagli hanno un design a tema cartoon in pixel art e non-violenti. \n\nOgni stage ha un obiettivo diverso, che viene spiegato all'inizio del livello. Si va dal semplice tiro al bersaglio (evitando le bombe) allo sparare ai cattivi (evitando di sparare ai civili), o sparare a specifici bersagli colorati, e cos\u00ec via\n\nCARATTERISTICHE:\n- 28 stage\n- Modalit\u00e0 Classica e Follia\n- Musica di sottofondo diversa a seconda del livello per tenerti concentrato nel gioco\n- Puoi sparare e distruggere tutti gli oggetti nella stanza (questo allontana lo stress)\n\nSei pronto a raggiungere il punteggio pi\u00f9 alto possibile in questa entusiasmante esperienza di tiro?", "short_description": "Preparati per un'emozionante sfida di tiro al bersaglio!"}, {"images": {"nodes": [{"file_name": "portrait_coverart.png", "id": "3374506842766840", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035428_3374506846100173_8011868378582857093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mezYr5yUlbIQ7kNvgEABAhB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAez-A_xm-DlWk3fe5UPdZjzVojq9DpZeLQ8wDw2IrhdQ&oe=674AF8DA"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iNTfaSYS6xkQ7kNvgFHLzmO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4Ts5WIlJNaj2BvpauIiaY-BK44Mvu-UApBr2Ei_0IOw&oe=674AE45E"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734