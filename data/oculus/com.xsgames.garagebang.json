com&oh=00_AYDj0i6CrtpR-_eaukOR2qQwSB2O7DDfigZYiOQYLcZpEQ&oe=66CDBA5A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GkSYYpX0Qa4Q7kNvgEhOWzF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAM5nrfGINTYb3VJr5RRO_vCrRTYTCZfLCLjtF3ehw69g&oe=66CDA5DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Orjc0kImVGMQ7kNvgEK5EZm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBV5EYdQ1g0Mn9takrNx5JKbcpy2Hm5v_03xbIKTU_wbw&oe=66CDCD99"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v2lyJqiRyS4Q7kNvgHprfJB&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4eh0ioGQfo_BwBGpaA76W-FM2TdKkULuxjg-r2VEAGA&oe=66CDC17B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2AhX290yAHUQ7kNvgHASR9j&_nc_ht=scontent.oculuscdn.com&oh=00_AYD0z_duiO1JbSGJ0w_S-z3R3-OVl_kperF6WWwjd6TE6g&oe=66CDD33C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O13dHXxlTscQ7kNvgHu46mg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAozZVXaWj_vUELQ-N9E4q-K5Mvkb8tWpGOepgpccvNxg&oe=66CD9F1E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LA