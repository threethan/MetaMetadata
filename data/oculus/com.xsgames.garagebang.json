-25/38974848_190146123493319_8631192710146771821_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eYLakUzgCGsQ7kNvgH6DfxG&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCxRnrd8xroaxrLDMajEil1Gw0SYj-WaeoWTlmQVbBmVg&oe=675D6E52"}]}, "id": "1282774222847858", "locale": "en_US", "screenshots": [{"file_name": "5.png", "id": "218423794266674", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974848_218423797600007_8812047711220896242_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WTkVmOhT1FAQ7kNvgFPW1dW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDKwCQ8Dwdw028zIFU3PwTKCbrT1jOc5HeLG_sAgu8JCw&oe=675D7CD8"}, {"file_name": "4.png", "id": "1247617589481297", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974441_1247617596147963_4600543940503140675_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pHDC3gcNkuUQ7kNvgFmPafj&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAbOnkjZhuUIcZkVF1l2sg9vwNIN-4SNRAFcseP8_K8JA&oe=675D6BDF"}, {"file_name": "3.png", "id": "1079502570104737", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031563_1079502573438070_6889708893237732852_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kWOoXAzePIsQ7kNvgGDKSAM&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDDxreRvtEU9EQ5Qt9RMALZJbQ-yvBWYosHQZtl78Hwxw&oe=675D597A"}, {"file_name": "2.png", "id": "561346586153760", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974585_561346589487093_6341898473789029941_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=riiDmHlfoNoQ7kNvgE5-V0s&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBSQRDxBlPwccIzZGR8rNmXn_rIplYCVAQPfUNcT62N7A&oe=675D7B37"}, {"file_name": "1.png", "id": "133236666410618", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974813_133236669743951_3521471306175933903_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yux2ICNE-acQ7kNvgGGhMrr&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAxA3DghSO7dTGtrKStT0SN-Pu_SGZGRltt7n9fjLkRlw&oe=675D8BC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_cover.png", "id": "183098317589933", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974585_183098320923266_7214502441744273375_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lVY3IDyf9rEQ7kNvgGnDxl_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDpDMI8zRbeKUa8s2dBhsarvM6kMZboyTzpta4phZZGsA&oe=675D89F9"}, "display_name": "Garage Bang", "keywords": ["shooting", "action", "gun", "pistol", "superhot"], "long_description": "In this fast-paced first-person shooter game, you must shoot targets in various stages.\n\nAll targets have a non-violent, pixel-art cartoon design. Each stage has a different objective, explained at the start of each stage. It goes from simple target shooting (and avoiding bombs) to shooting villains (avoiding shooting civilians), or shooting specific color targets, and so on.\n\n# FEATURES:\n- 28 pixel-art stages\n- **Classic** and **Insane** mode\n- Nice background music to keep you focused on shooting\n- You can shoot & smash all objects in the room (push the stress away)\n\nAre you ready to reach the highest score possible in this exciting shooting experience?", "short_description": "Get ready for an exciting shooting experience!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recomme