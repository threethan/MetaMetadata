=00_AYA2rvhyP1aKeMxO7SRdkgKFrNaEI5rr_YNC7RarE6jQew&oe=66F5475A"}, {"file_name": "landscape_coverart.png", "id": "1297686567452820", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1297686570786153_6881590418655907071_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7usGJ2MMBuMQ7kNvgGsdBp5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDYOTAVJN1CUZ1kofGT9to2G55fLPgUZ2r34Zl-q_y2bQ&oe=66F532DE"}, {"file_name": "logoTransparent.png", "id": "545978171068232", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_545978177734898_5580729734115745410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U2P4VxgBcL8Q7kNvgFC7IRc&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4mHUW79Nn5Cd56aCqHryBlF976-MxI_pUk1KZEAB4Wg&oe=66F55A99"}, {"file_name": "appIcon.png", "id": "533320142343440", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569479_533320149010106_1045257127822412130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y-dop5i1TycQ7kNvgFwpN31&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaHbcYqISXwFoyfdy-iFjflktsgFzt7QBS54nuaR0K8w&oe=66F54E7B"}, {"file_name": "PDP_cover.png", "id": "290824139936929", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_290824146603595_6773963866964372494_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ek_MXlDiISkQ7kNvgEpRTAK&_nc_ht=scontent.oculuscdn.com&oh=00_AYC1_GmWXQbLcKeAL-wEu0lFENgOxgHlT3gWb4Vvpu0v3Q&oe=66F5603C"}, {"file_name": "square_coverart.png", "id": "196532126557199", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221316_196532129890532_3808655866436070596_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_AAwdimpZhgQ7kNvgHSVADO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDu4b99f8FzlmYwYucQ8pLSplzTu7JtfpH1hTU5iieWCQ&oe=66F5645E"}, {"file_name": "mini_landscape_coverart.png", "id": "190146120159986", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974848_190146123493319_8631192710146771821_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BYtGMjXYcUUQ7kNvgH0dznr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAt9Bn1KgGkuBcpQFyBNdj4KNJWf8RrH-WRAEgnM4EvKQ&oe=66F547D2"}]}, "id": "642467400656509", "locale": "en_US", "screenshots": [{"file_name": "5.png", "id": "218423794266674", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974848_218423797600007_8812047711220896242_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IZ3uhluApmEQ7kNvgHQzsJJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBtSNTOcviXlgFP_721kidCaHfDHnwACLNWOFm0LnzaDA&oe=66F55658"}, {"file_name": "4.png", "id": "1247617589481297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974441_1247617596147963_4600543940503140675_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wQK-g7DQBnoQ7kNvgG21h88&_nc_ht=scontent.oculuscdn.com&oh=00_AYABg7CUTTXRIvqZnfplxMagH3bNza8vvrwJ2SV3zNXyeg&oe=66F5455F"}, {"file_name": "3.png", "id": "1079502570104737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031563_1079502573438070_6889708893237732852_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nlNk2ZY6KtMQ7kNvgHJEKTw&_nc_ht=scontent.oculuscdn.com&oh=00_AYCdp8x_upHJ54cPDTh9KevgPgPRJ7WAu32bpJ6k7jmk9A&oe=66F532FA"}, {"file_name": "2.png", "id": "561346586153760", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974585_561346589487093_6341898473789029941_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qe_9QrrcJAsQ7kNvgFJROcc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVSkEo7jRXRvt9fuKgc34QEkLcs7BlZYU3f_8jHPvtuw&oe=66F554B7"}, {"file_name": "1.png", "id": "133236666410618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974813_133236669743951_3521471306175933903_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QNSUGqb7a9gQ7kNvgFEWQFA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPWRZ2HBdpZ0vrmHJ01NqH14Oi5W_OpoRRKOfmyYQkbA&oe=66F56546"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer_co