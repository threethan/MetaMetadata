19673528874_2256517433883663425_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7nUuN9Q7ONIQ7kNvgHxH6Ol&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCsAPjICSHoZs9jwisgw_7C45Lw_dVXun9YAidII9zcGA&oe=674448A4"}, "display_name": "Task force 9 Demo", "keywords": [], "long_description": "Task Force 9 is a cutthroat VR game where players must ruthlessly take out enemies using any means necessary, whether it be through brute force or sneaky tactics. You'll have to strategically maneuver your AI partner while relying on cover, explosives, rappelling, wall breaching, and ambushes to gain the upper hand. This game is not for the faint of heart, as it it not just one more tactical shooter but we aims to sharpen your instincts in the brutal world of close-quarters combat. Are you ready to put your skills to the test?", "short_description": "Get ready for Task Force 9 - a tactical shooter that puts your combat skills to the test. Take down enemies using force or stealth while controlling your AI partner. Use cover, explosives, rappelling, wall breaching, and ambushes to survive. Sharpen your situational awareness in close-quarters combat.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://taskforce9.com/task-force-9-eula-and-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Good Day Studio", "support_website_url": null, "website_url": "https://taskforce9.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": [