r_thumbnail": {"file_name": "pets vr hero 2560x1440.png", "id": "4898704120173794", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984460_4898704123507127_7967018392648686203_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsFtbhqM4kQQ7kNvgHSP9hn&_nc_ht=scontent.oculuscdn.com&oh=00_AYA2Jb11msfG2ORaYRkq46cQuCE7GMtb0ST0mfP2YbgOxg&oe=66EFF81A"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some charming pets are waiting for you to play with them - come and see what they\u2019re up to in Pets VR! \nThere is a lot to do in Pets Resort, some of your duties will include: Petting cute doggo, playing with adorable Cat, making sure that they both have something to snack on and are well rested, walking without a care in the world through beautiful park, playing one of multiple mini games in which you can win special points! \nReady for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!\n", "short_description": "Pets VR - Take care of adorable pets in Your own Pets Resort!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://actum.games/petsvr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actum Games", "support_website_url": null, "website_url": "https://actum.games/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graph