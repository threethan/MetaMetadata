0_AYD-XDVQqCfHb1Fg3hs5k5xCfmS-k6v1lsqb-XEz_8peLQ&oe=66D43887"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some adorable pets are waiting for you to play - come and see what they\u2019re up to in Pets VR! Everyday a pet will join you in all activities such as minigames and when the fun is over you\u2019ll learn about it\u2019s needs and behaviours that you\u2019ll respond to. Is not all in vain - apart from observing the pet\u2019s reactions, you\u2019ll receive points for being a responsible pet parent. Ready for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!", "short_description": "Pets VR - a new dimension of looking after, playing with and training your virtual pet! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://actum.games/petsvr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actum Games", "support_website_url": null, "website_url": "https://actum.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "984539225821664"}}]}, "scheduled_offers": {"count": 3, "nodes": 