L2_EQ7kNvgEYqHlN&_nc_ht=scontent.oculuscdn.com&_nc_gid=An3ZCTpKM6ZTDuTb02pBssU&oh=00_AYB5eS1JUuBRnAyAakjdk_ncVL1acPPj_PBZHrAxnYjZ3A&oe=66F55F1B"}, {"file_name": "5.png", "id": "365263842060951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367594_365263852060950_5957144769962234314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2K8is3hXTAQ7kNvgF_2rwf&_nc_ht=scontent.oculuscdn.com&_nc_gid=An3ZCTpKM6ZTDuTb02pBssU&oh=00_AYAB202B1Qx4MICeW4tYYARZYC2GorCMefXdZkjnLz6bqg&oe=66F550B9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_cover_2560x1440px.png", "id": "883590099151840", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_883590102485173_7728383173360532782_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jrlrt2PfyFkQ7kNvgGMrclR&_nc_ht=scontent.oculuscdn.com&_nc_gid=An3ZCTpKM6ZTDuTb02pBssU&oh=00_AYAg8zTZDEockAr7dC5Hb2ETTUkFlNAgvAT1T9Wp-2Uf_g&oe=66F52E07"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some adorable pets are waiting for you to play - come and see what they\u2019re up to in Pets VR! Everyday a pet will join you in all activities such as minigames and when the fun is over you\u2019ll learn about it\u2019s needs and behaviours that you\u2019ll respond to. Is not all in vain - apart from observing the pet\u2019s reactions, you\u2019ll receive points for being a responsible pet parent. Ready for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!", "short_description": "Pets VR - a new dimension of looking after, playing with and training your virtual pet! "}]}, "developer_name": null, "developer_privacy_policy_u