ra5-1.oculuscdn.com/v/t64.5771-25/75367594_365263852060950_5957144769962234314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SnCP1_ivqu8Q7kNvgHFTunN&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCXMsYciwz_vM78Db1T9CrqdYBTjGmd4RzV6WN5U6wm8g&oe=675199B9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_cover_2560x1440px.png", "id": "883590099151840", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974499_883590102485173_7728383173360532782_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cpB99hqgPJwQ7kNvgFzBFbW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAa4jyPHhHMUU4KXsIdzTglQW8iURCflZIA7gzpiHc2MQ&oe=6751AF47"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some adorable pets are waiting for you to play - come and see what they\u2019re up to in Pets VR! Everyday a pet will join you in all activities such as minigames and when the fun is over you\u2019ll learn about it\u2019s needs and behaviours that you\u2019ll respond to. Is not all in vain - apart from observing the pet\u2019s reactions, you\u2019ll receive points for being a responsible pet parent. Ready for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!", "short_description": "Pets VR - a new dimension of looking after, playing with and training your virtual pet! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://actum.games/petsvr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actum Games", "support_website_url": null, "website_url": "https://actum.games/", "category": "GAMES", "comfort_rating": "NOT_RAT