71-25/39031634_1356917248072621_7555016658380422445_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dBBBE8ye_qMQ7kNvgGImUZE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCC-Td16cxNig2X3EaO_CTL8Rn-0SvA3elBrHQ6rnXW1A&oe=676BF5AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pets vr hero 2560x1440.png", "id": "4898704120173794", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984460_4898704123507127_7967018392648686203_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fz8CYa8tI8EQ7kNvgGF4478&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5GrmDxDluEaiMzS1rcy0ahovRAV_ObWq0ZlsW9xiOjw&oe=676BE51A"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some charming pets are waiting for you to play with them - come and see what they\u2019re up to in Pets VR! \nThere is a lot to do in Pets Resort, some of your duties will include: Petting cute doggo, playing with adorable Cat, making sure that they both have something to snack on and are well rested, walking without a care in the world through beautiful park, playing one of multiple mini games in which you can win special points! \nReady for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!\n", "short_description": "Pets VR - Take care of adorable pets in Your own Pets Resort!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://actum.games/petsvr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actum Games", "support_website_url": null, "website_url": "https://actum.games/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "co