Q&oe=66F7ECEE"}]}, "id": "514316979541325", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "595410051697342", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566679_595410058364008_2046109515579770684_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QSkdhbqR_tMQ7kNvgGLz4Dk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqF0_OwmBIW_T5eMws4QzPFcjxRxHXA7b_p5qdZ0fG7g&oe=66F7EA5F"}, {"file_name": "2.png", "id": "582725736170246", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86634394_582725739503579_6427402106442317236_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4i8BE843_MQ7kNvgHMGfrb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxuQuJsdW6qrVxJ5dwQQlt9J1uDG-KAyuGqQxf3f2JhQ&oe=66F7F949"}, {"file_name": "3.png", "id": "376269917515224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210889_376269920848557_8257096419215980972_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wUfx5nmFzE0Q7kNvgGyZ_UJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-_zgCMnAmy4evkfijLRx7QEYxqg1EhF2ZZdnT9DvZoQ&oe=66F7EF0D"}, {"file_name": "4.png", "id": "269542731766911", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75593946_269542738433577_5223613881306809277_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AS_qrQX-DEMQ7kNvgH0bwqm&_nc_ht=scontent.oculuscdn.com&oh=00_AYANyD7LE1UaCy9pGmTxTzCxvRhiMWvwAzCabH1oqn_HVQ&oe=66F8021B"}, {"file_name": "5.png", "id": "365263842060951", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367594_365263852060950_5957144769962234314_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fM8l7231ZcwQ7kNvgEoHP0f&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5DylAsLyzx4Fq1NTEydDschBi9WSseUvJC7C4v6FfjQ&oe=66F7F3B9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_cover_2560x1440px.png", "id": "883590099151840", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_883590102485173_7728383173360532782_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P50h8I9HAXcQ7kNvgFd9XC_&_nc_ht=scontent.oculuscdn.com&oh=00_AYBb3rb8KRdXuFY0ewLMbxn3umTehihq_01Iz-GmpIC6UQ&oe=66F7D107"}, "display_name": "Pets VR", "keywords": [], "long_description": "Some adorable pets are waiting for you to play - come and see what they\u2019re up to in Pets VR! Everyday a pet will join you in all activities such as minigames and when the fun is over you\u2019ll learn about it\u2019s needs and behaviours that you\u2019ll respond to. Is not all in vain - apart from observing the pet\u2019s reactions, you\u2019ll receive points for being a responsible pet parent. Ready for some challenges? Time for some training! Learn special gestures and instruct your pet to perform different tricks - if you\u2019re consistent it gets easier in time but be aware the pet can also forget some lessons! Reward yourself and your pupil and make it fancy! Exchange points to create your own collection of fun accessories for you and your pet to enjoy. Discover everything Pets VR can offer and most importantly, have fun!", "short_description": "Pets VR - a new dimension of looking after, playing with and training your virtual pet! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://actum.games/petsvr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actum Games", "support_website_url": null, "website_url": "https://actum.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "984539225821664"}}]