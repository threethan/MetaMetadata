d3-2.oculuscdn.com/v/t64.5771-25/38974529_397817817726354_5123164521132720128_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BpxF3XsJaU4Q7kNvgFPEYXp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnsph0XR5gA6-A1P9iR26eghKOD9L_vACEL8KR8JZHLA&oe=6707B209"}, "display_name": "Ultrawings", "keywords": ["Ultrawings", "simulation", "aircraft", "flight", "flying"], "long_description": "In Ultrawings, you'll pilot multiple aircraft using your virtual hands to interact with the flight stick and instruments to complete tons of missions while soaring around beautiful islands.\n\nKey Features:\n\n- Pilot 4 distinct aircraft each with their own handling characteristics!\n\n- Soar around 4 unique, beautifully-stylized islands!\n\n- Earn money to buy new airports and new vehicles! Ultrawings is a VR game with REAL progression!\n\n- Tons of gameplay variety! Pop balloons, participate in thrilling air races, fly through score rings, and even perform emergency landings! Ultrawings is the ultimate hobbyist flight game!\n\n- Full VO support guides you through the game!", "short_description": "Use your virtual hands to pilot the Ultralight, rocket-powered Glider, Sport Plane, and Gee Racer to complete a variety of missions across an island-themed world!"}]}, "developer_name": "Bit Planet Games, LLC", "developer_privacy_policy_url": "https://bitplanetgames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bit Planet Games, LLC", "support_website_url": "https://bitplanetgames.com/contact", "website_url": "https://bitplanetgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "FLYING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommende