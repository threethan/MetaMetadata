inner, enjoy a full course which will take you from the basic notions to the most complex ones."}]}, "developer_name": "AnimatedStudio", "developer_privacy_policy_url": "https://sites.google.com/view/privacypolicypianomaster/pagina-de-pornire", "developer_terms_of_service_url": null, "publisher_name": "AnimatedStudio", "support_website_url": null, "website_url": "https://www.animated.ro/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1463699174109102"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974474_649192509938088_8409191781723476691_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=me8AJu7jg3UQ7kNvgHgCW_t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AosCWCUQ07hElOQXOb7fsKW&oh=00_AYDItTOxBSh6S8--_M_t6UAWviSDrsxQ1AcnUgs-7dX6lw&oe=66E8243F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Piano Master", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1668445740, "lastRevision": {"nodes": [{"id": "4645123022257149", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4645122938923824", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDR