&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6LH8wb5RBasQ7kNvgE4oNVK&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAsBaZJq2Eb9WAAG27XUv_AmoP3xRBoJ9rBobAQF5I1og&oe=671A244B"}, {"file_name": "immagine-2021-12-07-160621.png", "id": "1097588264148206", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031600_1097588267481539_1441771463292176882_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sHpT1i5eHqMQ7kNvgHuFLsl&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAaT5Sm6wX_uRDidpmsLH_wj_pyx2lVIIsdQLIfhe0AcQ&oe=671A33BE"}, {"file_name": "screenshot-bully2 (1).png", "id": "3109815769292844", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38982563_3109815772626177_6284524619823654227_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xi_-q5gtewcQ7kNvgGuRZL7&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDmyuVJGFYpc5geUpiIhnVHKUDzfXNSdkvlrKRikxYEFA&oe=671A379A"}, {"file_name": "screenshot-bully3.png", "id": "732978577649854", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982492_732978580983187_8954213730478558859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0xUpCobx_EQ7kNvgE44RNm&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAMah-wy4JKhGAph5JeDjazYHd6s28utE2VfX6Is1wiYQ&oe=671A45C4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultrasclash V", "keywords": [], "long_description": "Ultrasclash V is a unique blend of three of the most beloved gaming concepts: anime, fighting, and sandbox approach. Combined, they create a fast paced, high octane virtual reality experience, in which you fight hordes of hostile cacti-men in a desperate, yet unmistakably hilarious, fight for survival.\n\nFEATURES\n\nPunch Movement System: we created a VR locomotion system which allows you to roam the map using your fists, punching in the direction you choose to move to!\n\nCrazy Bullet Time fights: just like in The Matrix, freeze time to gain a tactical advantage and defeat your opponents.\n\nPhysical engine: 