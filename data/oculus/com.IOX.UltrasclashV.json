e7a0a&_nc_ohc=WBrD2vDiNzwQ7kNvgF5Y67I&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBg6e125tRrnd6EtQ9kcbUbX8jqcyRCMA-dRbOJETCVyg&oe=676D32CB"}, {"file_name": "immagine-2021-12-07-160621.png", "id": "1097588264148206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031600_1097588267481539_1441771463292176882_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1jKIm_nK-jYQ7kNvgHzG_B0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYtlIOHMhjuN2F7R1Nycp6CitRgmhD4zj0l4p2x8yh9w&oe=676D423E"}, {"file_name": "screenshot-bully2 (1).png", "id": "3109815769292844", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982563_3109815772626177_6284524619823654227_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LgTCsimn5J4Q7kNvgGTBsXF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBaSBm2L9Fp0L1GRz5U1DR8bAGkurZlXEEiV9zD_Fxyvg&oe=676D461A"}, {"file_name": "screenshot-bully3.png", "id": "732978577649854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982492_732978580983187_8954213730478558859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KMDXoJ9lpw4Q7kNvgFMqP9N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6vYoouvv_LKq3_osIYBQj9otxRFk7tYZSz4XTmV1iFA&oe=676D5444"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultrasclash V", "keywords": [], "long_description": "Ultrasclash V is a unique blend of three of the most beloved gaming concepts: anime, fighting, and sandbox approach. Combined, they create a fast paced, high octane virtual reality experience, in which you fight hordes of hostile cacti-men in a desperate, yet unmistakably hilarious, fight for survival.\n\nFEATURES\n\nPunch Movement System: we created a VR locomotion system which allows you to roam the map using your fists, punching in the direction you choose to move to!\n\nCrazy Bullet Time fights: just like in The Matrix, freeze time to gain a tactical advantage and defeat your opponents.\n\nPhysical engine: we bring you accurate physics feedbacks in addition to badass sounds and enemies, all reacting realistically to your punches.\n\nAwesome cartoonish stylized graphics!!!", "short_description": "Ultras Fighter is a sandbox anime fighting game, designed and primed to bring you a unique and creative approach to being a hero, just like in your favourite anime!"}]}, "developer_name": "IOX S.r.l.", "developer_privacy_policy_url": "https://www.ultrasclash.com/3009-2/", "developer_terms_of_service_url": "https://www.ultrasclash.com/terms-of-service/", "publisher_name": "IOX S.r.l.", "support_website_url": null, "website_url": "https://www.ultrasclash.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1990104051447093"}, {"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "ACTION", "DINOSAURS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "264141875928065"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1245272882546973"}, {"status": "PUBLISHED", "id": "1090389105191165"}, {"status": "PUBLISHED", "id": "782085229495208"}, {"status": "PUBLISHED", "id": "855434236134789"}]}, "baseline_offer": {"id": "855434236134789"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649755200, "status": "PUBLISHED", "id": "1245272882546973"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6210228325692446", "version": "0.5"},