_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75371503_313769770932778_2178491407739072518_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yaQkGYuCTA0Q7kNvgGLnBPf&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYClrgPwjmO7T8daWH84qxjgxIYLMsM9k-FjrZZR6QuTOw&oe=670BA87F"}]}, "id": "393013123494386", "locale": "en_US", "screenshots": [{"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0007_Sfondo.png", "id": "404668291519471", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75540505_404668294852804_5420804151185707166_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y4CBu0VO9b4Q7kNvgFVRPQ5&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYArZK9bjgWbAkaDIhExlScLxLRA1CTyiEs_b9GT-4kmtw&oe=670BB849"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0005_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "440950967842489", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75269157_440950971175822_2337400146368738892_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9yf31oXL1kIQ7kNvgH-THzp&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAv2kcQM0n-5s-LbqF6mkDUROE1nomyx14La3_ufJgZSA&oe=670BB015"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0004_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "1042737416444543", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/57566679_1042737419777876_393316241265326341_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ufnbntZMQ8AQ7kNvgGNFGyG&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCkIQ4b0AQZaY5tkc5_OlrMou60HYnlJFTemweZskzXvA&oe=670BC549"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0003_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "346669480787652", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75210886_346669484120985_8527181391040255515_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AlcZWQ5J4Q4Q7kNvgES7SJ9&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDklVdBHmH0-VXhIEdODIw3qMW_SMyDvVPJDu1eVVoDAg&oe=670BC4E4"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0002_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "1630073630707996", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974593_1630073637374662_5124540097702308997_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nkqrSgPFUU4Q7kNvgFEUS9X&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBp_EsaguA8kJgutE6IZeXcTnzVV3VvHb-_LhG8tHiHsA&oe=670BABD5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Ladnscape_Applab_DEF.png", "id": "1318650725290954", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75287555_1318650731957620_4399606145434759838_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EMIrBC_0V9wQ7kNvgFvrsCc&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBlmX3YHkGOe16HZtE6t4-xmEa-L_geb85bwC99xsiM3A&oe=670BA375"}, "display_name": "UltrasClash V", "keywords": [], "long_description": "** THIS PRODUCT IS IN EARLY ACCESS, IT MAY CONTAIN SOME GLITCHES, because we believe that the best way to develop the game is with the help of the community**\n\nUltrasClash V is a physics based, fast paced anime combat!!! Fight hordes of hostile and powerful enemies like cactus head policemen, stupid minionsand giant dinosaur in a desperate, yet unmistakably hilarious, fight for survival.\n\nIn Ultrasclash V the combat is limited only by your own creativity. Choose your fighting style, choose your weapons, chose you powers. Be the powerful fighter you always dreamed of becoming!\n\nFEATURES\n\n\ud83d\udc4aPunch Movement System: we created a VR locomotion system which allows you to move punching in the direction you choose to move to!\n\n\u26a1\ufe0fSpecial Attacks: Charge up your aura to full power and unleash devastating finishing moves!\n\n\u2604\ufe0fPhysical engine: we bring you accurate physics feedbacks in addition to badass sounds and enemies!\n\n\ud83e\uddbeMOD KIT Support coming soon...", "short_description": "UltrasClash V is a sandbox anime action game, designed and primed to bring you a unique and creative approach to being a hero and unleash all your super powers!"}]}, "developer_name": "IOX S.r.l.", "developer_privacy_policy_url": "https://www.ultrasclash.com/3009-2/", "developer_terms_of_service_url": "https://www.ultrasclash.com/terms-of-service/", "publisher_name": "IOX S.r.l.", "support_website_url": null, "website_url": "https://www.ultrasclash.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "ACTION", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7265733820141886"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75294245_4584880964944756_5941096324356415238_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dODXWKYf5tEQ7kNvgGp7HvK&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYATsLshqKyQf_tRWZd_rnetEbydZJW0y1U4RiFGYDkuLA&oe=670BA09F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UltrasClash V", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "RPG (R