&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gnp0uu7Y-8IQ7kNvgHGk3jA&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAyB5jnK2sV8qrtai-yK0J5frM6LQLxezYIGdegTyXaBA&oe=6710E9CB"}, {"file_name": "immagine-2021-12-07-160621.png", "id": "1097588264148206", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031600_1097588267481539_1441771463292176882_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gp6V21-9v5oQ7kNvgFU-a0P&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCR7eMtQKdOae4eXR2xeJ3W76rmyvfoZg82JRI4j3SOMQ&oe=6710F93E"}, {"file_name": "screenshot-bully2 (1).png", "id": "3109815769292844", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982563_3109815772626177_6284524619823654227_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iLgFpyapSPsQ7kNvgFLuzkt&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCD9n5UYqoodypl5Qoww9dQTd-INN7F6Vs2piSWkXre_w&oe=6710FD1A"}, {"file_name": "screenshot-bully3.png", "id": "732978577649854", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982492_732978580983187_8954213730478558859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QJ3-L7GffzQQ7kNvgH4P9s_&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAHSjPXaL4pbKfWDZBSxWghHNZm7RCuoC_WBh-vh5aXlw&oe=67110B44"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultrasclash V", "keywords": [], "long_description": "Ultrasclash V is a unique blend of three of the most beloved gaming concepts: anime, fighting, and sandbox approach. Combined, they create a fast paced, high octane virtual reality experience, in which you fight hordes of hostile cacti-men in a desperate, yet unmistakably hilarious, fight for survival.\n\nFEATURES\n\nPunch Movement System: we created a VR locomotion system which allows you to roam the map using your fists, punching in the direction you choose to move to!\n\nCrazy Bullet Time fights: just like in The Matrix, freeze time to gain a tactical advantage and defeat your opponents.\n\nPhysical engine: 