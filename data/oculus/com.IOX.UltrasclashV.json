&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OIRemx_G-IYQ7kNvgF-WgH4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSvX4IrCHD9b7Xc0uhY2Ox53YVhS72IEJBp1QbsXGnwQ&oe=6717814B"}, {"file_name": "immagine-2021-12-07-160621.png", "id": "1097588264148206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031600_1097588267481539_1441771463292176882_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sHpT1i5eHqMQ7kNvgHjXI9o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkky1qguEIPDE-3y49q83_CLDsZI9-WeP1FPp6vXU5fw&oe=671790BE"}, {"file_name": "screenshot-bully2 (1).png", "id": "3109815769292844", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982563_3109815772626177_6284524619823654227_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXxPDJ1sjGsQ7kNvgE7jHjP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjywBlE5Ot0e7MEPHuaubWgWxtqPOGUQvodbAGKaF5kA&oe=6717949A"}, {"file_name": "screenshot-bully3.png", "id": "732978577649854", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982492_732978580983187_8954213730478558859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0xUpCobx_EQ7kNvgGdc9ZB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqxRK1CnjGGTiY0kn3GrzTn0zwIT-warJLFnMdSNJC1g&oe=6717A2C4"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultrasclash V", "keywords": [], "long_description": "Ultrasclash V is a unique blend of three of the most beloved gaming concepts: anime, fighting, and sandbox approach. Combined, they create a fast paced, high octane virtual reality experience, in which you fight hordes of hostile cacti-men in a desperate, yet unmistakably hilarious, fight for survival.\n\nFEATURES\n\nPunch Movement System: we created a VR locomotion system which allows you to roam the map using your fists, punching in the direction you choose to move to!\n\nCrazy Bullet Time fights: just like in The Matrix, freeze time to gain a tactical advantage and defeat your opponents.\n\nPhysical engine: 