4S1mMN7JA&oe=66F16CF4"}, {"file_name": "16.png", "id": "2926422647650778", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031605_2926422650984111_2550665871534870593_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_aBX0ykvjk4Q7kNvgFC2Lu4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AduwXhc7m-_gnldo6dpTvcs&oh=00_AYDKehGZd8TVT18nXrsstHoHgfdyjltWcsgw5fLd06VqPQ&oe=66F145CB"}, {"file_name": "immagine-2021-12-07-160621.png", "id": "1097588264148206", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031600_1097588267481539_1441771463292176882_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9xK7g7rRNAQ7kNvgHPFPf9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AduwXhc7m-_gnldo6dpTvcs&oh=00_AYBgs2ZWRSX4lyTAetbuBZhk1wRT7fPxzFvtn64XMBMlVw&oe=66F1553E"}, {"file_name": "screenshot-bully2 (1).png", "id": "3109815769292844", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982563_3109815772626177_6284524619823654227_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8EQz0u18dGcQ7kNvgFjY8wa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AduwXhc7m-_gnldo6dpTvcs&oh=00_AYAGp2vX5oEUhBIGZ2ZXVf2Nrd3FWTZLVFE3XOEL3R51Hg&oe=66F1591A"}, {"file_name": "screenshot-bully3.png", "id": "732978577649854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982492_732978580983187_8954213730478558859_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFbJcpPgjosQ7kNvgHyNrkq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AduwXhc7m-_gnldo6dpTvcs&oh=00_AYA5I_aoUJNOapxqLsVIlfV-AHonltjB0i1IgddmZz1nng&oe=66F16744"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Ultrasclash V", "keywords": [], "long_description": "Ultrasclash V is a unique blend of three of the most beloved gaming concepts: anime, fighting, and sandbox approach. Combined, they create a fast paced, high octane virtual reality experience, in which you fight hordes of hostile cacti-men in a desperate, yet unmistakably hilarious, fight for survival.\n\nFEATURES\n\nPunch Movement System: we created a VR locomotion system which allows you to roam the map using your fists, punching in the direction you choose to move to!\n\nCrazy Bullet Time fights: just like in The Matrix, freeze time to gain a tactical advantage and defeat your opponents.\n\nPhysical engine: we bring you accurate physics feedbacks in addition to badass sounds and enemies, all reacting realistically to your punches.\n\nAwesome cartoonish stylized graphics!!!", "short_description": "Ultras Fighter is a sandbox anime fighting game, designed and primed to bring you a unique and creative approach to being a hero, just like in your favourite anime!"}]}, "developer_name": "IOX S.r.l.", "developer_privacy_policy_url": "https://www.ultrasclash.com/3009-2/", "developer_terms_of_service_url": "https://www.ultrasclash.com/terms-of-service/", "publisher_name": "IOX S.r.l.", "support_website_url": null, "website_url": "https://www.ultrasclash.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "ACTION", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "264141875928065"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1245272882546973"}, {"status": "PUBLISHED", "id": "1090389105191165"}, {"status": "PUBLISHED", "id": "782085229495208"}, {"status": "PUBLISHED", "id": "855434236134789"}]}, "baseline_offer": {"id": "855434236134789"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649755200, "status": "PUBLISHED", "id": "1245272882546973"