_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75371503_313769770932778_2178491407739072518_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1IkYMXGqmQEQ7kNvgGs9U3I&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDoOZ4-PzUIDtyExgBwnASrS0OVX-wj0k4NNgFcmWNKkw&oe=67026DFF"}]}, "id": "393013123494386", "locale": "en_US", "screenshots": [{"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0007_Sfondo.png", "id": "404668291519471", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75540505_404668294852804_5420804151185707166_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SgzZpkmBLkMQ7kNvgELCl8T&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAudcDv8juARb7qVyZYmrqB0QFu-PQv00ou_pGCVAu5hA&oe=67027DC9"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0005_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "440950967842489", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75269157_440950971175822_2337400146368738892_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4KrmwtGhmSkQ7kNvgG1GVd2&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCK0NXCsRjHoKWupnv0_y8aaidMi4C4NnKuJl3WN23JxA&oe=67027595"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0004_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "1042737416444543", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/57566679_1042737419777876_393316241265326341_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aNvDzrdArdsQ7kNvgFKTok-&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYA1Kj1VXy3tnUE7ZuGdQ_HctPnEedXcZFv-NrQnYEw7yg&oe=67028AC9"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0003_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "346669480787652", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75210886_346669484120985_8527181391040255515_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1BWBDAy7AzUQ7kNvgHyb9AD&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAcuAtbmXWbxvqAShxn0-Lw0f0QdXK8FHQkfS5kAtYaSg&oe=67028A64"}, {"file_name": "Ultrasclash-vr-virtual-reality-sandbox-anime-fighting-gameplay-1_0002_Ultrasclash-vr-virtual-reality-sandbox-anime-fight.png", "id": "1630073630707996", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974593_1630073637374662_5124540097702308997_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sscG3TKqxK4Q7kNvgEKcING&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC-gFqOklBv4n6ZB1U-Q5YPFmL99UrrnpCXyp52wnbMTQ&oe=67027155"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Ladnscape_Applab_DEF.png", "id": "1318650725290954", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75287555_1318650731957620_4399606145434759838_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N1aB4SVkNS8Q7kNvgFv8Wg_&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCjCwoVPnn9cNl61AqMSU1OW8GZljFQZBNgKzzYeazJuQ&oe=670268F5"}, "display_name": "UltrasClash V", "keywords": [], "long_description": "** THIS PRODUCT IS IN EARLY ACCESS, IT MAY CONTAIN SOME GLITCHES, because we believe that the best way to develop the game is with the help of the community**\n\nUltrasClash V is a physics based, fast paced anime combat!!! Fight hordes of hostile and powerful enemies like cactus head policemen, stupid minionsand giant dinosaur in a desperate, yet unmistakably hilarious, fight for survival.\n\nIn Ultrasclash V the combat is limited only by your own creativity. Choose your fighting style, choose your weapons, chose you powers. Be the powerful fighter you always dreamed of becoming!\n\nFEATURES\n\n\ud83d\udc4aPunch Movement System: we created a VR locomotion system which allows you to move punching in the direction you choose to move to!\n\n\u26a1\ufe0fSpecial Attacks: Charge up your aura to full power and unleash devastating finishing moves!\n\n\u2604\ufe0fPhysical engine: we bring you accurate physics feedbacks in addition to badass sounds and enemies!\n\n\ud83e\uddbeMOD KIT Support coming soon...", "short_description": "UltrasClash V is a sandbox anime action game, designed and primed to bring you a unique and creative approach to being a hero and unleash all your super powers!"}]}, "developer_name": "IOX S.r.l.", "developer_privacy_policy_url": "https://www.ultrasclash.com/3009-2/", "developer_terms_of_service_url": "https://www.ultrasclash.com/terms-of-service/", "publisher_name": "IOX S.r.l.", "support_website_url": null, "website_url": "https://www.ultrasclash.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "ACTION", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7265733820141886"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75294245_4584880964944756_5941096324356415238_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CebcrWJq_EYQ7kNvgGouP0Z&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDJIH-FatTAV10X_1s5pX9MytxpHjfj9PYWLwKTaYoy7Q&oe=6702661F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UltrasClash V", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "RPG (R