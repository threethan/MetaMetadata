670FAD4D"}, {"file_name": "twinsboy3.png", "id": "1031882228359073", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974695_1031882231692406_5194523071872511322_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_ltVoJHDbUwQ7kNvgGa9tFf&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDH0b5B1gLekwpMbdDqBcKE2Q2zW5Uh4PAAuU_h5kNKfg&oe=670F93BC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Demo_\u957f\u65b9\u5f62_2560x1440.png", "id": "1450045072296638", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75272211_1450045075629971_3091531104808597174_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q7DwOpLw4HkQ7kNvgH4xufY&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBYeq0Qhh6-SzwUWLFK-VkS_Ni4PStGlK37Na_X-D1cxg&oe=670F8E49"}, "display_name": "Exorcism Agency Demo", "keywords": ["exorcism", "horror", "multiplayer", "intense"], "long_description": "# Exorcism Agency Demo Overview\nWelcome to the Exorcism Agency Demo! This limited version lets you explore the Hunted Village map solo\u2014a perfect way to test the waters before diving into the full game!\n\nUnlock the Full Experience for Just $9.99! Grab the full version for only $9.99 before November 1st! Level up your ghost-hunting game and discover more thrills.\n\n#Join Our Discord Community!\nDon\u2019t miss out\u2014Join our Discord at https://discord.gg/XTQSvRyuNs! \nIt\u2019s the best place for tips from fellow players and exclusive updates!\n\n#Your Mission Awaits\nAs a recruit at the Exorcism Agency, gather clues inside the haunted building and follow instructions for exorcism. Different ghosts require unique approaches. Collect 6 pieces of evidence and input them into your pad before exorcising\u2014Patience is key!\n\n#Starting Funds and Upgrades\nYou\u2019ll start with $1,500 to buy basic gear. As you improve, earn more cash for better equipment.\n\n# Upgrade to the Full Version\nOnce you gain experience, consider upgrading to the full version of Exorcism Agency. The official release features:\n- 4-player multiplayer mode**.\n- 4 additional maps**.\n- A complete roster of ghost types and all the gear you\u2019ll need.\n\nWe\u2019re excited for you to dive into **Exorcism Agency**! Your supernatural adventure begins now, and with our Discord community, you\u2019ll be ready to tackle any ghost that comes your way. Good luck, and see you in the game!", "short_description": "Exorcism Agency Demo is the limited-function version of Exorcism Agency, featuring a single map, Hunted Village, and a Single Player mode. This demo allows you to experience the game before purchasing the full version.You can still unlock the full version with $9.9 before 1st,Nov!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://developer1ab.github.io/2024/02/02/PRIVACY-POLICY_Exorcism-Agency-Demo/", "developer_terms_of_service_url": null, "publisher_name": "AtomBits Studio", "support_website_url": null, "website_url": "https://developer1ab.github.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "es", "ru", "zh_CN", "de", "ja", "pt"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "28089853693946744"}, "review_messages": ["", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57568673_3399406273702147_6253410451687016555_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0