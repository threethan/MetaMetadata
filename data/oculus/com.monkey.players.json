oculuscdn.com&oh=00_AYC8uEQmWDCu-RZwy2rrYwi5MhMbIcH4O8Tz3nlpiNV1Jg&oe=671E22B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "75307247_1488187795096207_761985499779344499_n.png", "id": "2418574011674639", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75272211_2418574015007972_8038691987207114510_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HRZNZGhnpLIQ7kNvgFl9ZSB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCocAR586wR631MgvI4x8-VO9kOJG_wFkUXC_p1gdkYHA&oe=671E1E7D"}, "display_name": "Scary chase", "keywords": [], "long_description": "\"Scary Chase\" is an exhilarating virtual reality game that thrusts players into a jungle-like environment where they embody agile gorillas navigating through lush, obstacle-laden landscapes. With intuitive VR controls, participants swing through trees, leap across platforms, and engage in heart-pounding chases as they attempt to outmaneuver opponents. Players can tailor their gorilla's appearance and enjoy immersive multiplayer action, strategizing to evade pursuers or become the apex predator. Whether darting through dense foliage or engaging in high-flying acrobatics, \"Scary Chase\" promises adrenaline-pumping thrills and unforgettable VR experiences.", "short_description": "This is a new and fun horror game with a lot of new stuff"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/e5c55470-77b6-46fe-a089-6ddf82a8ff6d", "developer_terms_of_service_url": null, "publisher_name": "S4GE", "support_website_url": null, "website_url": "https://html.cafe/x30bb8e58", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT",