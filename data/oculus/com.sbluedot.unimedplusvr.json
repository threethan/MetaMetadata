-xsp1-2.oculuscdn.com/v/t64.5771-25/38974903_495696369836647_5455943117005468125_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c_G4sskMVxYQ7kNvgEgHW7K&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCnn40SAQjkO6-YzNHf2PZZgYmkEEEE8clCfi04o12Wkw&oe=671A3D8B"}, {"file_name": "com.sbluedot.unimedplusvr-20240227-153249.mp4.00_00_09_08.Still002.png", "id": "1728698787982614", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39035389_1728698791315947_4382483257143647161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lgDtFswrfkoQ7kNvgH_yvPh&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBT5i7sSHTVilHQSCp4ueIeGVx6RsGRrfKqM4V19mRB0Q&oe=671A1950"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main2560_1440-01.png", "id": "1563049480955863", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39031607_1563049484289196_8523769749790803732_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D70IlRLDxsgQ7kNvgFFY-to&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBbiLVlm5aeY-GXgEwoXLc_JGgZbXnCFhjKe_vwMt7X6Q&oe=671A282A"}, "display_name": "UniMed+ solfeggio with VR", "keywords": ["meditation", "therapy", "solfeggio", "528", "mindfulness"], "long_description": "Solfeggio frequency meditation to improve concentration and memory.\nAim for a high score with brain training.\n\nA fantastic stage inspired by the deep sea.\nYou can meditate while experiencing the feeling of diving into the sea.\n\nVirtual Reality\nYou can use VR devices to immerse yourself in a fantasy world and meditate.\n\nWhat are Solfeggio frequencies?\nMeditation mode incorporates Solfeggio frequencies, which are also used in sound therapy.\nAlso known as Nikola Tesla's 3-6-9 theory, it is said to be \"the key to the universe that holds the secrets of energy, vibration, and resonance.\"\nIn sound therapy, it is used to reduce mental stress, have a healing effect, increase motivation, and restore mental strength.\nThe famous frequencies of 396Hz, 417Hz, and 528Hz are also mixed, as well as other Solfeggio frequencies.", "short_description": "Solfeggio frequency meditation to improve concentration and memory.\nAim for a high score with brain training.\nA fantastic stage inspired by the deep sea.\nYou can meditate while experiencing the feeling of diving into the sea.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sbluedot1.wixsite.com/bluedot-studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "BlueDot Studio", "support_website_url": null, "website_url": "https://sbluedot1.wixsite.com/bluedot-studio", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "ko", "zh_CN", "zh_HK", "zh_TW", "it", "es", "pt", "ru", "uk", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7953340781368023"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031335_481935258070914_3271100566143884993_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_W29KCAcUioQ7kNvgFeHQTT&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBmphLHNy-grdVgwlWmGtxUfpXXHntbilwIQ9N2VNTGFw&oe=671A3C2A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UniMed+ solfeggio with VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Health & Fitness", "id": "619566195371476"}], "