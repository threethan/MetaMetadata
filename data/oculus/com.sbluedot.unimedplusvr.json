679", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974850_8726541867409012_3849860040132412855_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZb5HqGfiCMQ7kNvgEGk5DJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDZ6IapLtwuKDrLq7Pd27j1skcCG6rMel9_QpZHIiLVNw&oe=67728227"}, {"file_name": "com.oculus.vrshell-20241105-120938.png", "id": "583258660791828", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974679_583258664125161_3421990995910339195_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bxVZ8B1rbgoQ7kNvgEJeMzx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCxynSGcXV1UdL0iW4yBtb3FNtgylrKS9C4k8UkV8uttA&oe=677287E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main2560_1440-01.png", "id": "1563049480955863", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031607_1563049484289196_8523769749790803732_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3cOS7CNu7BAQ7kNvgGAPXec&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDd-JxfVbiuOI8xwumw5NFRTdbxkUiuOKXH8871ODo7Gg&oe=67727CAA"}, "display_name": "UniMed+ solfeggio with VR", "keywords": ["meditation", "therapy", "solfeggio", "mindfulness", "yoga"], "long_description": "\"Unlock Your Inner Peace with UniMed+.\n\nDive into a transformative journey with our meditation app that harnesses the power of Solfeggio frequencies. Designed for both beginners and seasoned meditators, our app offers a unique experience to elevate your mindfulness practice.\n\nFeatures:\nSolfeggio Mixer.\nBGM Mixer.\nBGM uses spatial audio (3D sound) technology.\nSpatial audio creates an immersive experience by simulating sounds from all directions: above, below, around, behind you.\n\nWhy Solfeggio Frequencies?\nThese ancient sound frequencies are believed to promote healing, balance, and spiritual growth. Each tone resonates with different aspects of your well-being, helping you achieve deeper relaxation and focus.\"", "short_description": "\"Unlock Your Inner Peace with UniMed+.\n\nDive into a transformative journey with our meditation app that harnesses the power of Solfeggio frequencies. Designed for both beginners and seasoned meditators, our app offers a unique experience to elevate your mindfulness practice."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sbluedot1.wixsite.com/bluedot-studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "BlueDot Studio", "support_website_url": null, "website_url": "https://sbluedot1.wixsite.com/bluedot-studio", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "ko", "zh_CN", "zh_HK", "zh_TW", "it", "es", "pt", "ru", "uk", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8636587906376637"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031335_481935258070914_3271100566143884993_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-iPlBV4WPaIQ7kNvgEbqrdv&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAgnbFQr97eaoJ8LdqHvTIEKimJXscTHAgn8WNqtYkcmA&oe=677290AA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UniMed+ solfeggio with VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Fitness & Wellness", "id": "810139357995560"}], "release_date": 1728957540, "lastR