-1.oculuscdn.com&oh=00_AYCFyjZyDjGZPU1rgLdh8WdZumhgD2emdElFooDoUKSm8w&oe=6745ABA1"}, {"file_name": "com.sbluedot.unimedplusvr-20240227-153249.mp4.00_01_19_27.Still007.png", "id": "495696366503314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974903_495696369836647_5455943117005468125_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g52EefoqxigQ7kNvgG2gszA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD82QaHDiFoED2Htt-l5Bme_suIILliAo_trPs-JFsfhw&oe=6745BF0B"}, {"file_name": "com.sbluedot.unimedplusvr-20240227-153249.mp4.00_00_09_08.Still002.png", "id": "1728698787982614", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035389_1728698791315947_4382483257143647161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zkQQn_7-oosQ7kNvgGBWGHC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDMHp6KwHh6LJGICFyMOcMU4N7Qb849QIoJ7_33SWyaGg&oe=67459AD0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main2560_1440-01.png", "id": "1563049480955863", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031607_1563049484289196_8523769749790803732_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KqniW06pSHEQ7kNvgHwtjZW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbYj6z87erAqbo5Iv5rqvHk1eK1rJyp_fDxfk7HerHwg&oe=6745A9AA"}, "display_name": "UniMed+ solfeggio with VR", "keywords": ["meditation", "therapy", "solfeggio", "528", "mindfulness"], "long_description": "Solfeggio frequency meditation to improve concentration and memory.\nAim for a high score with brain training.\n\nA fantastic stage inspired by the deep sea.\nYou can meditate while experiencing the feeling of diving into the sea.\n\nVirtual Reality\nYou can use VR devices to immerse yourself in a fantasy world and meditate.\n\nWhat are Solfeggio frequencies?\nMeditation mode incorporates Solfeggio frequencies, which are also used in sound therapy.\nAlso known as Nikola Tesla's 3-6-9 theory, it is said to be \"the key to the universe that holds the 