27-153249.mp4.00_01_19_27.Still007.png", "id": "495696366503314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974903_495696369836647_5455943117005468125_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nWxVPvRxjbcQ7kNvgHt-Y74&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAo_DIoa5U25KtRFlKkBaejMRWVBLXTs15A7IVx0DX6dA&oe=6723780B"}, {"file_name": "com.sbluedot.unimedplusvr-20240227-153249.mp4.00_00_09_08.Still002.png", "id": "1728698787982614", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035389_1728698791315947_4382483257143647161_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_VsaG15b_0Q7kNvgH5lf8W&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7GVIiRXNKWXzWHABJTBZC4ugN7yxYnfldkj9Lao0KmQ&oe=672353D0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main2560_1440-01.png", "id": "1563049480955863", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031607_1563049484289196_8523769749790803732_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fhXjvU6aPmAQ7kNvgGIMKXW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAajR8iOBp-xOjl4uqaOeHxdD5_GSNvE5O8Of016cRWUA&oe=672362AA"}, "display_name": "UniMed+ solfeggio with VR", "keywords": ["meditation", "therapy", "solfeggio", "528", "mindfulness"], "long_description": "Solfeggio frequency meditation to improve concentration and memory.\nAim for a high score with brain training.\n\nA fantastic stage inspired by the deep sea.\nYou can meditate while experiencing the feeling of diving into the sea.\n\nVirtual Reality\nYou can use VR devices to immerse yourself in a fantasy world and meditate.\n\nWhat are Solfeggio frequencies?\nMeditation mode incorporates Solfeggio frequencies, which are also used in sound therapy.\nAlso known as Nikola Tesla's 3-6-9 theory, it is said to be \"the key to the universe that holds the secrets of energy, vibration, and resonance.\"\nIn sound therapy, it is used to reduce mental stress, have a healing effect, increase motivation, and restore mental strength.\nThe famous frequencies of 396Hz, 417Hz, and 528Hz are also mixed, as well as other Solfeggio frequencies.", "short_description": "Solfeggio frequency meditation to improve concentration and memory.\nAim for a high score with brain training.\nA fantastic stage inspired by the deep sea.\nYou can meditate while experiencing the feeling of diving into the sea.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sbluedot1.wixsite.com/bluedot-studio/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "BlueDot Studio", "support_website_url": null, "website_url": "https://sbluedot1.wixsite.com/bluedot-studio", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "ko", "zh_CN", "zh_HK", "zh_TW", "it", "es", "pt", "ru", "uk", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7953340781368023"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031335_481935258070914_3271100566143884993_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KL1SlXjfJW4Q7kNvgEgCbk-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwqQ53mder3n4jlmj_Tw5exlsh2S7Su2U2NOf0LyzOrA&oe=672376AA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UniMed+ solfeggio with VR", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1728957540, "lastRevision": {"nodes": [{"