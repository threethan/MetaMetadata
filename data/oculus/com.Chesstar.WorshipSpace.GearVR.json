1"}, {"file_name": "migrated_image.png", "id": "3126942180673044", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12386220_1744975242284767_5995458587810332672_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TtLWv7q-alAQ7kNvgF05AHT&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAS1lwibnhKr86K0XEyi4MR7-L_AedVldVlmP7J_JsbbA&oe=673083B6"}, {"file_name": "migrated_image.png", "id": "733857423815394", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/12138999_1634750836562592_1318863506027577344_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iWo74PkOMJ4Q7kNvgH4-JpZ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC6v7F1J0mKH32m8B_s-UztPkL0_4AH5sI3sBKKhG3Q1Q&oe=67308306"}, {"file_name": "migrated_image.png", "id": "252255609118116", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/12331069_363550167474655_4654373964670304256_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mnqZaCIWvs0Q7kNvgGkV8hY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYChgsEh31QvKf1v0cniKlCJoMt2Hkk_1VZVDRKz8aaeug&oe=6730822A"}, {"file_name": "migrated_image.png", "id": "257736325234498", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12427628_437780690013964_1017384250984366080_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y2i33O_rZBwQ7kNvgHj_NEu&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCFp_5r8umkYgMEFzlp5xgbJQUf_FG8oK-YCMOEGJBITQ&oe=6730872C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "237701016805419", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/12138999_237701020138752_3435951000458887168_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gl9hMZK9bAQ7kNvgHLunUJ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBVWN8Xxh4B5_eOOp0dnEOkuBTQGhXzXATECNoxAOoamw&oe=67309C86"}, "display_name": "Worship Space", "keywords": ["Buddhism", "Sutra", "Chant", "Spiritual", "Oriental"], "long_description": "Do you ever want to enjoy a mental clarity and have some rest after a day of hard work, but can\u2019t find your own mediation space. Do you have interest in Buddhism, but don\u2019t know how to get started? Or maybe you have become a devoted Buddhist, but can\u2019t find a space to study Buddhism?\n\nIf you have the above experience, then this app \u2013 Woship Space VR is a perfect suit for you.\n\nWorship Space is a free Buddhism app which using the most advanced Virtual Reality technology, and can help you take advantage of transit time, lunch breaks and other instances of downtime to study Buddhism.\n\nFeatures:\n\nBuddha Offering: Offer fruits to Buddha.\n\nBurn Incense: Burn incense sticks.\n\nSutra Chanting: Recite sutra.\n\nBuddha Amulet: Purchase amulet blessed Buddha.\n\nBuddha Worship: Worship to Buddha.", "short_description": "Worship Space is a free Buddhism app which using the most advanced Virtual Reality technology, and can help you take advantage of transit time, lunch breaks and other instances of downtime to study Buddhism."}]}, "developer_name": "Chesstar studios", "developer_privacy_policy_url": "http://www.chesstar.cn/site/privacy-policy-and-terms-of-service/", "developer_terms_of_service_url": "http://www.chesstar.cn/site/privacy-policy-and-terms-of-service/", "publisher_name": "Chesstar studios", "support_website_url": null, "website_url": "http://www.chesstar.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "UTILITY", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_TW"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "658297428935291"}}]}, "sched