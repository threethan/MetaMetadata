_ohc=YGLcNvI9i0QQ7kNvgH--BJV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJwv6bVJ5yKhPzifuN4aVuc&oh=00_AYAeVnjQPekxS34Lh8B92_EYqToZyB7FuTYfgXNBFoMA0A&oe=66EBFC10"}, {"file_name": "Screenshot_3.png", "id": "874458249778746", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031356_874458253112079_3238502578646108708_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OUc_vYSsseQQ7kNvgEphjwq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJwv6bVJ5yKhPzifuN4aVuc&oh=00_AYAFOBX4-94iYKr96uIuzZFDW34tiYkAjqJtOWDWXTaIKQ&oe=66EC0BE3"}, {"file_name": "Screenshot_1.png", "id": "885734758938773", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_885734762272106_993609447690333919_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WplldEBljtsQ7kNvgERUxom&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJwv6bVJ5yKhPzifuN4aVuc&oh=00_AYCG3Omx3vFOregYbw8rxVUO3BWJO5emVUl30G91GJ-ReQ&oe=66EC08E8"}, {"file_name": "Screenshot_2.png", "id": "271532111232490", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262744_271532117899156_2051566399827067609_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rtkLy3VljHcQ7kNvgGbIdhh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJwv6bVJ5yKhPzifuN4aVuc&oh=00_AYA1-pg2pL-F3bm84OgskEC_6kIZGbdrIM4vVvbW6tcFLg&oe=66EBF425"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Crumbling", "keywords": [], "long_description": "Crumbling is a rogue-like action adventure. You fight plastic monsters that are the minions of B\u00f6se Corp., an evil corporation that kidnaps Crumblings, seals them in blister packages and sells them off as merchandize. As you progress through an onslaught of monsters from one meticulously crafted diorama to the next you grow ever stronger. Ultimately you face the end boss, the B\u00f6sewicht Golem.\n\nThe game is played in third person. You control your character directly with your touch controller, as if it was an action figure in your hand. You can even use the native hand-tracking of the Oculus Quest to use your actual hands instead.", "short_description": "Woosh! Bam! Pow! Remember playing with action figures? Put on your VR headset, grab your favorite Crumbling and fight your way through an onslaught of enemies and epic bosses. Rescue and collect all Crumblings. Their fate is in your hand. Quite literally."}]}, "developer_name": null, "developer_privacy_policy_url": "https://crumbling-game.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Mufflonzucht", "support_website_url": null, "website_url": "https://crumbling-game.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "646182990050241"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "603538287704533"}, {"status": "PUBLISHED", "id": "138068905949536"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1620853140, "status": "PUBLISHED", "id": "603538287704533"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6699386853406007", "version": "0.11.1_demo"}, "id": "754146155234329", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4150531058291612", "is_concept": false, "latest_released_binary": {"__typename"