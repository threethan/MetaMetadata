Leh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYATrWKlaEjhBQ-TXWlSvKpAxC87GXQpwNkiIf3NYTnxOw&oe=66E6E0A4"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "270317005532142", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608441_270317008865475_2566895963270748547_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_243RkY6W5wQ7kNvgHc2Ku6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYBqnu6XJi1IpQ5DEMRgb5ivrNwMpq5d05ps46vumtNBSg&oe=66E6AEE9"}]}, "id": "6686455968032259", "locale": "en_US", "screenshots": [{"file_name": "Blister_2560.png", "id": "1403154956995156", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974819_1403154960328489_2387253771457940173_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iAw0BTTQlawQ7kNvgFTmy7S&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYDT3Gzfv-fwaAdjgozFCRKwrhXpSDANobXHiIfvuJiSrA&oe=66E6CB9D"}, {"file_name": "Blaster_fight_2560.png", "id": "789330506197507", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297584_789330509530840_1280096367936924545_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NgjGUQdbRQMQ7kNvgGrkmNE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYC4thAQa7TQS3Wj39jucou3bzNcDCOkNmgF0_9v9rCrLA&oe=66E6B481"}, {"file_name": "Screenshot_Fight1.png", "id": "459809059154889", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031629_459809062488222_896247959200297444_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7W_ta9a37BQQ7kNvgG6_7WI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYChoVEdRd-RjYj2goRiS_IQ7KmycgABvz0a00a5UF5b_g&oe=66E6DED3"}, {"file_name": "Rewards_2560.png", "id": "778237807302716", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984474_778237810636049_8168769842856354296_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2AQq9uofjhEQ7kNvgElHElR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYBny84VP4_dYT-d1xMI9vcrju7l6XPs2spttyzvCIc1dA&oe=66E6CC81"}, {"file_name": "Screenshot_ReadComic.png", "id": "337738854928558", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982685_337738858261891_4506688399668725068_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=savzxuOF_dcQ7kNvgF8n8HV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYAZ2wqwnEdG5-WLnX3FPJebF3zSQ1hOgTmpozwcgkcF8Q&oe=66E6CB9A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1804923969964834", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222941_1804923973298167_7999747304686780980_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JUknGKAZ0tYQ7kNvgHXC-Cx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYCY8yOIVO7zf8seDX7HTC-gz4dEcovajVSQWT8Vd5kHtA&oe=66E6DE24"}, "display_name": "Crumbling Demo", "keywords": [], "long_description": "Whoosh! Bam! Pow! Remember playing with action figures? Unwrap your Crumbling from its blister package and take its fate into your hand - literally. \n\nCrumbling is a VR rogue-like action adventure where you control your character as if it was an action figure in your hand. Move it around meticulously hand-crafted dioramas using your touch controller. Or use the native hand-tracking of the Oculus Quest. Fight against an onslaught of plastic monsters in hack'n'slash combat that is all about timing. \n\nDiscover the story of the endearing Mr. and Mrs. Crumble through animated and narrated comic books. Learn how the evil B\u00f6se Corp. stole all their magic in order to make their horrible monster toys come alive. \n\nAre you ready to wield your Crumbling against the evil minions of B\u00f6se Corp. and reclaim the magic?", "short_description": "Whoosh! Bam! Pow! Remember playing with action figures? Unwrap your Crumbling from its blister package and take its fate into your hand - literally. \n\nCrumbling is a VR rogue-like action adventure. You fight plastic monsters that are minions of the evil B\u00f6se Corp. As you progress from one meticulously crafted diorama to the next your Crumbling grows ever stronger!\n\nDiscover the story of the endearing Mr. and Mrs. Crumble and the evil B\u00f6se Corp. through animated and narrated comics."}]}, "developer_name": "Crumbling Games", "developer_privacy_policy_url": "https://crumbling-game.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Crumbling Games", "support_website_url": null, "website_url": "https://crumbling-game.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "796142578799764"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608441_270317008865475_2566895963270748547_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_243RkY6W5wQ7kNvgHc2Ku6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZitl3KH6CiwhZWOsIjFFnC&oh=00_AYArrp4hepr50xow5w8c8mvaa_9FjMNiVlWrG8S36IILow&oe=66E6AEE9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crumbling Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": 