YBhr_D7wBQ7cC3W8JJLfK4D6c6AeXpET80tR43BFb_7eA&oe=66F00701"}, {"file_name": "Screenshot_ReadComic.png", "id": "337738854928558", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982685_337738858261891_4506688399668725068_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dyWLhdDS9z0Q7kNvgEU5Ahr&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADnr8ng5FHxWlNQjOXUGwmt&oh=00_AYCt9Wu1sKGHdh0YplqViQfC2uVmGfQvuZs0IMJFRrinGw&oe=66F0061A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1804923969964834", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222941_1804923973298167_7999747304686780980_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CDkdASaHCIcQ7kNvgHuedO8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADnr8ng5FHxWlNQjOXUGwmt&oh=00_AYDqZv6GeeDlSaivCq_Vmn8IbJJmQsyNGOCk4msvgbxXjg&oe=66F018A4"}, "display_name": "Crumbling Demo", "keywords": [], "long_description": "Whoosh! Bam! Pow! Remember playing with action figures? Unwrap your Crumbling from its blister package and take its fate into your hand - literally. \n\nCrumbling is a VR rogue-like action adventure where you control your character as if it was an action figure in your hand. Move it around meticulously hand-crafted dioramas using your touch controller. Or use the native hand-tracking of the Oculus Quest. Fight against an onslaught of plastic monsters in hack'n'slash combat that is all about timing. \n\nDiscover the story of the endearing Mr. and Mrs. Crumble through animated and narrated comic books. Learn how the evil B\u00f6se Corp. stole all their magic in order to make their horrible monster toys come alive. \n\nAre you ready to wield your Crumbling against the evil minions of B\u00f6se Corp. and reclaim the magic?", "short_description": "Whoosh! Bam! Pow! Remember playing with action figures? Unwrap your Crumbling from its blister package and take its fate into your hand - literally. \n\nCrumbling is a VR rogue-like action adventure. You fight plastic monsters that are minions of the evil B\u00f6se Corp. As you progress from one meticulously crafted diorama to the next your Crumbling grows ever stronger!\n\nDiscover the story of the endearing Mr. and Mrs. Crumble and the evil B\u00f6se Corp. through animated and narrated comics."}]}, "developer_name": "Crumbling Games", "developer_privacy_policy_url": "https://crumbling-game.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Crumbling Games", "support_website_url": null, "website_url": "https://crumbling-game.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "796142578799764"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75608441_270317008865475_2566895963270748547_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C7cw_LtQyjsQ7kNvgHbjK6S&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADnr8ng5FHxWlNQjOXUGwmt&oh=00_AYCNVy4vBCHajBJTvvRi0l153s9vqTqGldIG38xKUX0JwQ&oe=66EFE969"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crumbling Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "27104