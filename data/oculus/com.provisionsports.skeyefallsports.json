68716961418100_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EwJ0nFplQmYQ7kNvgH2f8kj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZ4X04lU-1iPDGOE7MuR6dPgbZqSoQno0EAg0QJQASgw&oe=66D856F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_image.png", "id": "309102244373880", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195902_309102247707213_6299735279736006057_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JysA1WuNyRwQ7kNvgGKiYHE&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVhNZ3MB1EqF0OywmZymOh0Q2w0N9LHoB94M-Fw05O9A&oe=66D83C80"}, "display_name": "SKEYEFALL SPORTS - 3 IN 1 - SBASEBALL, COSMIC DODGEBALL, HYPER ARROW", "keywords": [], "long_description": "TRAIN YOUR BRAIN \u2013 IMPROVE YOUR GAME\n\nTrain your vision like pro athletes Steph Curry, Lebron James, Jose Trevino, and many more. \nThis is the first sport vision training game that you\u2019ll want to play.\n\nSkeyefall Sports is the first VR sport vision training system that will make you a better competitor no matter the sport you play (yes, even esports!)\n\nSkeyefall Sports training was designed by world class Sport Vision Doctor Keith Smithson who works with championship winning pro sport teams to train their athletes. \n\nPLAY 3 DIFFERENT GAMES\n\nCOSMIC DODGEBALL\nDodge, Duck, Dive, Catch, and Throw your way through 8 increasingly intense levels across the Solar System. Cosmic Dodgeball will put your mind and body through the ultimate test.\n\nSBASEBALL\nIt's like Baseball, but in Space. Fastballs, Bombs, curveballs. Not to mention the 7 Pitching bosses that you need to beat.\n\nHYPER ARROW\nOur best and most innovative game. Fly through new worlds with this insane twitch fast flying race.", "short_description": "TRAIN YOUR BRAIN \u2013 IMPROVE YOUR GAME\n\nTrain your vision like pro athletes Steph Curry, Lebron James, Jose Trevino, and many more. \nThis is the first sport vision training game that you\u2019ll want to play.\n\nSkeyefall Sports is the first VR sport vision training system that will make you a better competitor no matter the sport you play (yes, even esports!)\n\nSkeyefall Sports training was designed by world class Sport Vision Doctor Keith Smithson who works with championship winning pro teams.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/d679ae80-c566-452b-8a41-9e3a1a934c7d", "developer_terms_of_service_url": null, "publisher_name": "Pro Sports Vision", "support_website_url": "https://www.skeyefallsports.com/", "website_url": "http://skeyefallsports.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1658570461193561"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001671_419232633181146_8208695874053892362_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7scsO4ZvtuYQ7kNvgEiq05t&_nc_ht=scontent.oculuscdn.com&oh=00_AYAw8Nrv1PI6dd5FuKJgem0RsrNoozs3cTF6AVxOsMU6Xw&oe=66D85072"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SKEYEFALL SPORTS - 3 IN 1 - SBASEBALL, COSMIC DODGEBALL, HYPER ARROW", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1651696200, "lastRevision": {"nodes": [{"id": "139369868432383", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4450358181699336", "is_first_party": fa