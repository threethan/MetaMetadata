uscdn.com&oh=00_AYCQjV6AEhlT5cBda_uRd1TIOvYwczirhtzGsr6trG9m3A&oe=67052839"}, {"file_name": "Screenshot 5 (1).png", "id": "1324761171533812", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_1324761174867145_2503484720635118176_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g6V8kCDbeIEQ7kNvgG6aMHJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2tTFWP2xiSdKbjhC3urKds4aXdlKNxnlTQr6DpxsJxA&oe=67052110"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Elemental Arts Cover.png", "id": "431835932838440", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982623_431835936171773_6405462821509476233_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gwNZj-zEkywQ7kNvgE3rLSo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBG-xyMI398evZAgmHHIRDc0tW17GyzbFqdCFtY2j0y1w&oe=67050445"}, "display_name": "Elemental Arts", "keywords": [], "long_description": "Elemental Arts is everything you have wished for since you were young. A game where you can take the Elements of the world and just let loose on some unexpecting Elementals. As of now, the game is a Demo, but in the future, we plan for much more.\n\nThe controls are simple. the (A) button will display a menu that will allow you to pick and choose from all the abilities in the game thus far. When you hit Trigger on either controller a line will appear. This line represents the line of which you \"cast\" abilities. You will find the exact directions to cast each ability on stone walls in the designated area. (Ex. Fire in the red rocks area)", "short_description": "A game were you can harness Water, Fire, Earth, and Air by actually moving of your hands."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/elemental-arts-vr/privacy-policy?authuser=0", "developer_terms_of_service_url": null, "publisher_name": "Victrinity Entertainment", "support_website_url": null, "website_url": "https://sites.google.com/view/elemental-arts-vr/home", "category": null,