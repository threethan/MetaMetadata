ontent.oculuscdn.com/v/t64.5771-25/75617327_315028114912610_761719259808051028_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fkah04TFf9IQ7kNvgHpYSYV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7KfJzZBfjCSn_Ys3snJtmp&oh=00_AYBgH4ZiKllOwSdvbE3319TmJt6QKSJoeeGjOXwM8bEFVA&oe=66E432B9"}, {"file_name": "Screenshot 5 (1).png", "id": "1324761171533812", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001728_1324761174867145_2503484720635118176_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oO5RG1L5lQkQ7kNvgGK_l1c&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7KfJzZBfjCSn_Ys3snJtmp&oh=00_AYDYMLw7YxPNJGAQj96An0zEPQN4xtXGQqxE3hUv8j1Q1Q&oe=66E42B90"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Elemental Arts Cover.png", "id": "431835932838440", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982623_431835936171773_6405462821509476233_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1R7VUsrIkB0Q7kNvgHeBL9V&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7KfJzZBfjCSn_Ys3snJtmp&oh=00_AYAoD5_0OUIcZduBldeQmiJKtmki1OSkcIJJDfF1dCuL4w&oe=66E40EC5"}, "display_name": "Elemental Arts", "keywords": [], "long_description": "Elemental Arts is everything you have wished for since you were young. A game where you can take the Elements of the world and just let loose on some unexpecting Elementals. As of now, the game is a Demo, but in the future, we plan for much more.\n\nThe controls are simple. the (A) button will display a menu that will allow you to pick and choose from all the abilities in the game thus far. When you hit Trigger on either controller a line will appear. This line represents the line of which you \"cast\" abilities. You will find the exact directions to cast each ability on stone walls in the designated area. (Ex. Fire in the red rocks area)", "short_description": "A game were you can harness Water, Fire, Earth, and Air by actually moving of your hands."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/elemental-arts-vr/privacy-policy?authuser=0", "developer_terms_of_service_url": null, "publisher_name": "Victrinity Entertainment", "support_website_url": null, "website_url": "https://sites.google.com/view/elemental-arts-vr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7360375710706584"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036683_911787560737616_7761820554628924283_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nExkvcfIw1kQ7kNvgEQzf3l&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7KfJzZBfjCSn_Ys3snJtmp&oh=00_AYAp5pQ2--OS5i8nrX2TbI78FeUBObgFADBxZ5I4RjVuUQ&oe=66E414C4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Elemental Arts", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1710442800, "lastRevision": {"nodes": [{"id": "7360375720706583", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7360375700706585", "is_first_party": false, "enables_in_app_ads": false, "