TYr6qODtk7sQ7kNvgEJBVy8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBva06_PAgC8eNWRyOe72R71J4lGgP4HOQ88g2yUgntDw&oe=671F8CA9"}, {"file_name": "migrated_image.png", "id": "1852680178195607", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974853_329045047783680_4621363911185137664_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J1mC23InODEQ7kNvgFhpqmO&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXJHJ7YReCwi5U9xgMVCOrzxlK4XPkfIl9fcC8y01fCA&oe=671F6CB8"}, {"file_name": "migrated_image.png", "id": "228176491665924", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974764_337992383584475_1974009575317176320_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vKT4TePVjCsQ7kNvgENAECS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZri-Ic4NvR1-JmpDI7D0-Dtm_e9fnWGzFeJ85MZrXMw&oe=671F8113"}, {"file_name": "migrated_image.png", "id": "1116274965383593", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982574_2249496035262963_8342485858036744192_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L04hj77doAcQ7kNvgGMiXxI&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFvYcOPDJu7gTPQo4mwohndtOsQctkfiddVt9TRTP8GQ&oe=671F60AF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/dodaJH", "id": "432161154034770", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031496_432161157368103_8346455610409091072_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dHnHnet34JgQ7kNvgEByfAG&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtIwWvIDCLs8DDw_L_3niDSQTmWPa_t-7ARZwGHqECvQ&oe=671F7918"}, "display_name": "Guided Tai Chi", "keywords": ["Nature", "Music", "Beat", "Box", "Dance"], "long_description": "Experience a modern reimagining of an ancient practice.\n\nStimulate your mind, body, and spirit. Enjoy flowing exercises, combining elements of several Tai Chi styles. \n\nDelight no matter your current fitness level.\n\n\u2013 EASY TO FOLLOW \u2013 \nNothing to learn or memorize. Simply follow along.\n\n\u2013 FIND YOUR FLOW \u2013\nLet go of tension and stress across 20 sessions. A perfect gateway to the concepts of Tai Chi for beginners. Find yourself in the flow, refreshed and energized. \n\n\u2013 COMPETE GLOBALLY \u2013\nShowcase your skill across 20 arcade sessions. Win points for perfect form, as you climb the leaderboards to become \"King of the Chill\".  Strengthen and tone your body, while relaxing your mind.\n\n\u2013 REFRESH IN NATURE \u2013\nEmbrace the wilds of nature, in the comfort of your own home. Select your ideal environment from beautiful, exotic destinations.\n\nFind your happy place.\u2122", "short_description": "Experience a modern reimagining of an ancient practice.\n\nStimulate your mind, body, and spirit. Enjoy flowing exercises, combining elements of several Tai Chi styles. \n\nDelight no matter your current fitness level."}]}, "developer_name": "Cubicle Ninjas", "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/97894149", "developer_terms_of_service_url": "https://guidedmeditationvr.com/eula/", "publisher_name": "Cubicle Ninjas", "support_website_url": null, "website_url": "http://guidedtaichi.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "361729819114950"}}]}, "scheduled_offers": {"count": 30, "nodes": [{"status": "PUBLISHED", "id": "1606135326908882"}, {"status": "PUBLISHED", "id": "6123