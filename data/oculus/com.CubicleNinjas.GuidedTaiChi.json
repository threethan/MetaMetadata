2742144_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1lTUbaAUBAQ7kNvgGLjNLi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpYeY5bPjGrybNNmM297w-p4BYeGi_KsWBgyiWN-IQYg&oe=6720DEEC"}, {"file_name": "migrated_image.png", "id": "678952969510990", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982598_555799771491968_7250800188955033600_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qgXh9vqUhSEQ7kNvgFHSIRQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArhn8lHDFANmFXmc5JNaZN4wWc7ga4s8uwvjp91FRgow&oe=6720D7F4"}, {"file_name": "migrated_image.png", "id": "633071960586503", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031315_335661294031414_3969392226454208512_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5z6F03P2HQsQ7kNvgH6ujU1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA27w8etZzYL-2tOzLVdza_jezOyOr1S1SO_O0_V4lVOg&oe=6720B2FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982693_1984600275005152_8002693795903851814_n.png", "id": "1250681235769743", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572932_1250681239103076_7590573534474526042_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qSOz7fqUUR4Q7kNvgG3AWRE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCL_ctf7hOF68bISVqFWMmTQzSb3lm_2aELZU07aklIiA&oe=6720DFD7"}, "display_name": "Guided Tai Chi", "keywords": ["Nature", "Fitness", "Meditation", "Box", "Relax"], "long_description": "Refresh your mind, body, and spirit with 200+ Tai Chi inspired workouts across 20 beautiful nature settings!\n\nExperience a modern reimagining of an ancient practice.\n\n\u2013RECHARGE IN BEAUTIFUL NATURE ENVIRONMENTS\u2013\nDiscover the wilds of nature, in the comfort of your own home, with 3-minute to 60-minute sessions.\n\n\u2013FIND YOUR FLOW\u2013\nLet go of tension and stress across 100 meditative sessions in FLOW MODE. A perfect gateway to the concepts of Tai Chi for beginners. Find yourself in the flow, refreshed, and energized.\n\n\u2013COMPETE ACROSS THE GLOBE\u2013\nWin points for perfect form across 100 sessions in ARCADE MODE. Or challenge yourself with the randomized WORLD TOUR MODE, a 15, 30, or 60-minute Tai Chi endurance marathon. Strengthen and tone your body, while relaxing your mind.\n\n\u2013CUSTOMIZE YOUR WORKOUT\u2013\nMake your practice perfect for you through highly adjustable settings. Optional foot, teacher, audio, and vibration refinement to fit your unique needs\n\nFind your happy place.\u00ae", "short_description": "Refresh your mind, body, and spirit with 200+ Tai Chi inspired workouts across 20 beautiful nature settings!\n\nExperience a modern reimagining of an ancient practice."}]}, "developer_name": "Cubicle Ninjas", "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/97894149", "developer_terms_of_service_url": "https://guidedmeditationvr.com/eula/", "publisher_name": "Cubicle Ninjas", "support_website_url": null, "website_url": "http://guidedtaichi.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["RELAXATION_MEDITATION", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "638658148052691"}, "review_messages": ["Approving your update. "]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223473_203750320904999_8041482475885712834_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MIhntyRCmY0Q7kNvgH4wK2p