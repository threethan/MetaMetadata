u7IOWOYbsQ7kNvgHMEot1&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBIJMunDm1dg5Pn7xDd5qG_ExjCVon9UR5nlvukaFf3Kw&oe=670FBAA9"}, {"file_name": "migrated_image.png", "id": "1852680178195607", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974853_329045047783680_4621363911185137664_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s8mAWMV-MPsQ7kNvgEnG1Rs&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYABz-Q_VNMawVsotYOdZBEeb6aTkcw1PSS0Xypaiwescg&oe=670F9AB8"}, {"file_name": "migrated_image.png", "id": "228176491665924", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974764_337992383584475_1974009575317176320_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KGub_2K5tisQ7kNvgFqNnEe&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBK67H8Ff3asOgIoVp9w_f17ZukhR128AdQKSoXPV4X4w&oe=670FAF13"}, {"file_name": "migrated_image.png", "id": "1116274965383593", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982574_2249496035262963_8342485858036744192_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7SpB547yICEQ7kNvgH_9Mje&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDkgNEVOQdfCx5szz-PzZRofkGFKTgwjvpOBbWYXW0a1g&oe=670F8EAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/dodaJH", "id": "432161154034770", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031496_432161157368103_8346455610409091072_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=49grybSma4kQ7kNvgES7odO&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBC_cQBBLOZDta7L9-kpfDdoER-41snklU4Gqp9Ec6ynQ&oe=670FA718"}, "display_name": "Guided Tai Chi", "keywords": ["Nature", "Music", "Beat", "Box", "Dance"], "long_description": "Experience a modern reimagining of an ancient practice.\n\nStimulate your mind, body, and spirit. Enjoy flowing exercises, combining elements of several Tai Chi styles. \n\nDelight no matter your current fitness level.\n\n\u2013 EASY TO FOLLOW \u2013 \nNothing to learn or memorize. Simply follow along.\n\n\u2013 FIND YOUR FLOW \u2013\nLet go of tension and stress across 20 sessions. A perfect gateway to the concepts of Tai Chi for beginners. Find yourself in the flow, refreshed and energized. \n\n\u2013 COMPETE GLOBALLY \u2013\nShowcase your skill across 20 arcade sessions. Win points for perfect form, as you climb the leaderboards to become \"King of the Chill\".  Strengthen and tone your body, while relaxing your mind.\n\n\u2013 REFRESH IN NATURE \u2013\nEmbrace the wilds of nature, in the comfort of your own home. Select your ideal environment from beautiful, exotic destinations.\n\nFind your happy place.\u2122", "short_description": "Experience a modern reimagining of an ancient practice.\n\nStimulate your mind, body, and spirit. Enjoy flowing exercises, combining elements of several Tai Chi styles. \n\nDelight no matter your current fitness level."}]}, "developer_name": "Cubicle Ninjas", "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/97894149", "developer_terms_of_service_url": "https://guidedmeditationvr.com/eula/", "publisher_name": "Cubicle Ninjas", "support_website_url": null, "website_url": "http://guidedtaichi.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "361729819114950"}}]}, "scheduled_offers": {"count": 30, "nodes": [{"status": "PUBLISHED", "id": "1606135326908882"}, {"status": "PUBLISHED", "id": "612373616778000"}, {"status": "