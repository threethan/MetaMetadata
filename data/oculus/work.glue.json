52616348913677_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1xBKvwM_7MMQ7kNvgHsEFV_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVbB1yFp7ovP3lN0E-kr-kirCkx1ZNr5LfPcs7JhLEFw&oe=670A654D"}, {"file_name": "Screenshot_02.png", "id": "642951673659002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_642951683659001_538577593053912230_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S1NoYS3WXgoQ7kNvgEY8BBs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqIIWnsAqxRLgunraPLXjOR9jhlMbwosqe2KKb_rTZWQ&oe=670A52AA"}, {"file_name": "Screenshot_03.png", "id": "693978131610393", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982553_693978134943726_855322277123325506_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bA-ETz5-MI8Q7kNvgGMfSlj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJ9V-a4tRXPMDSCIJtyW67LSKksd6N5Iz3W9d6bk7GFA&oe=670A6EF3"}, {"file_name": "Screenshot_05.png", "id": "3767752379973714", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031379_3767752386640380_8447861101223318170_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-l3dh1j0ZEgQ7kNvgFaHVJA&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBV3Ks3gZJeIL5saJYr6vt3g_TiYd413zvhcKv8q9rPaA&oe=670A6510"}, {"file_name": "Screenshot_01.png", "id": "3421502638137019", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404377_3421502641470352_2710315714562841810_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oJGzuTHvon0Q7kNvgFSuaAx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5ZFH7l-ujcP9HEEy2Yu0jrqrTPuCpwEKpsmOGckZ-gw&oe=670A6232"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "635171461603624", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569444_635171464936957_8156230190308559210_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gPh-iGoCuucQ7kNvgEUJS_T&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBS0Jy6KuxIQuhvkEXoTqXD3vIUHtgYJqNKoC1TViRFJQ&oe=670A519F"}, "display_name": "Glue", "keywords": ["productivity", "collaboration", "multiuser", "meetings", "remote"], "long_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create. Combining the best in immersive 3D graphics, virtual reality and cloud computing technology, Glue empowers teams everywhere to maximize their collaborative potential.\n\nGlue offers both FREE and PAID subscriptions to is remote collaboration platform. Within the app you can create a Glue Team and Glue Account with FREE subscription.\n\nFREE subscription offers you all the features of Glue including customizable 3D avatars, spatial audio, selection of persistent meeting spaces, full suite of collaboration tools and the team files storage for your files. \n\nWith the FREE subscription, you can have up to 10 members in your Glue Team and create up to 10 Team Spaces. FREE subscription has a session time limit of 30 minutes per session.\n\nPAID subscription options and upgrading your subscription at www.glue.work/pricing.", "short_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create.\n\nYou need to be a member of a Glue Team to use this app. You can create a free trial Glue Team within the app."}]}, "developer_name": null, "developer_privacy_policy_url": "https://glue.work/glue-privacy-policy/", "developer_terms_of_service_url": "https://glue.work/terms-and-conditions/", "publisher_name": "Glue Collaboration", "support_website_url": "https://glue.work/support/", "website_url": "https://glue.work/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODU