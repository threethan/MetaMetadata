&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB-8B_-aOsjLTkV8uGivkmpybgrDOeI3-xzd2wGs-qmsw&oe=67839B9F"}, "display_name": "Glue", "keywords": ["productivity", "collaboration", "multiuser", "meetings", "remote"], "long_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create. Combining the best in immersive 3D graphics, virtual reality and cloud computing technology, Glue empowers teams everywhere to maximize their collaborative potential.\n\nGlue offers both FREE and PAID subscriptions to is remote collaboration platform. Within the app you can create a Glue Team and Glue Account with FREE subscription.\n\nFREE subscription offers you all the features of Glue including customizable 3D avatars, spatial audio, selection of persistent meeting spaces, full suite of collaboration tools and the team files storage for your files. \n\nWith the FREE subscription, you can have up to 10 members in your Glue Team and create up to 10 Team Spaces. FREE subscription has a session time limit of 30 minutes per session.\n\nPAID subscription options and upgrading your subscription at www.glue.work/pricing.", "short_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create.\n\nYou need to be a member of a Glue Team to use this app. You can create a free trial Glue Team within the app."}]}, "developer_name": null, "developer_privacy_policy_url": "https://glue.work/glue-privacy-policy/", "developer_terms_of_service_url": "https://glue.work/terms-and-conditions/", "publisher_name": "Glue Collaboration", "support_website_url": "https://glue.work/support/", "website_url": "https://glue.work/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", 