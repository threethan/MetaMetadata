52616348913677_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v8erWa4djGwQ7kNvgEm5Znn&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCefJNJgPEFZexCP36zUj9NwxXfeYNdqyhJ3Uex8R_kYw&oe=67012ACD"}, {"file_name": "Screenshot_02.png", "id": "642951673659002", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982658_642951683659001_538577593053912230_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xDxk7XO13PEQ7kNvgG_aVz_&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCbNKOZLHLSCoh2NX_mTtr4q_zdwRjmxH1Hmr7v8SDMJA&oe=6701182A"}, {"file_name": "Screenshot_03.png", "id": "693978131610393", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982553_693978134943726_855322277123325506_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s2BOnk9OzWYQ7kNvgHai0c5&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDD28LdnfYLncUt6pyGUcyNjwacNl9X2QVAOg1kMtHGmw&oe=67013473"}, {"file_name": "Screenshot_05.png", "id": "3767752379973714", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031379_3767752386640380_8447861101223318170_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yJtOELln6VYQ7kNvgFdtoLk&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBxd4Dm0ZRQxHM1r4LB4Lv3n0Bv77LdBrVzMIxiOx0BzA&oe=67012A90"}, {"file_name": "Screenshot_01.png", "id": "3421502638137019", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75404377_3421502641470352_2710315714562841810_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABVZPvGSn1cQ7kNvgEEl-28&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAzTttlPn1qKIh4q3u_kRyQWeGNi4drlmJ9WDLu1S6QSA&oe=670127B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "635171461603624", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569444_635171464936957_8156230190308559210_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TvayfZ1Z8FkQ7kNvgECjLeC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBYfws6uMo49_ya2u_tk4T9XBwOxCBr11caSYjAtnMS1w&oe=6701171F"}, "display_name": "Glue", "keywords": ["productivity", "collaboration", "multiuser", "meetings", "remote"], "long_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create. Combining the best in immersive 3D graphics, virtual reality and cloud computing technology, Glue empowers teams everywhere to maximize their collaborative potential.\n\nGlue offers both FREE and PAID subscriptions to is remote collaboration platform. Within the app you can create a Glue Team and Glue Account with FREE subscription.\n\nFREE subscription offers you all the features of Glue including customizable 3D avatars, spatial audio, selection of persistent meeting spaces, full suite of collaboration tools and the team files storage for your files. \n\nWith the FREE subscription, you can have up to 10 members in your Glue Team and create up to 10 Team Spaces. FREE subscription has a session time limit of 30 minutes per session.\n\nPAID subscription options and upgrading your subscription at www.glue.work/pricing.", "short_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create.\n\nYou need to be a member of a Glue Team to use this app. You can create a free trial Glue Team within the app."}]}, "developer_name": null, "developer_privacy_policy_url": "https://glue.work/glue-privacy-policy/", "developer_terms_of_service_url": "https://glue.work/terms-and-conditions/", "publisher_name": "Glue Collaboration", "support_website_url": "https://glue.work/support/", "website_url": "https://glue.work/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODU