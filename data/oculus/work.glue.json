616348913677_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Kbgn_hJvp8Q7kNvgH-CJYs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDs4F45scrzg_zRQc1pHW3Q4hZ-AjndWw6O5BoQ8iK7rg&oe=6703CDCD"}, {"file_name": "Screenshot_02.png", "id": "642951673659002", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_642951683659001_538577593053912230_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G5kYoMsBGB4Q7kNvgHUQRxN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2aP6cHF4LG8zSqVoMY-Q8dHEfGlFtWAUhW8V1onGtaA&oe=6703BB2A"}, {"file_name": "Screenshot_03.png", "id": "693978131610393", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982553_693978134943726_855322277123325506_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aVeRSbvAnzUQ7kNvgHhwZV1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZ2TrNHbB3AIz4h8Qpuvul8EYnrQnKYC6pU6N37HC4CA&oe=6703D773"}, {"file_name": "Screenshot_05.png", "id": "3767752379973714", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031379_3767752386640380_8447861101223318170_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7bLNCyZMTf8Q7kNvgHAeW7p&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOGJNFi2vdlXHEz1siNHHpKTs6XQa0QQWshswPNV4usw&oe=6703CD90"}, {"file_name": "Screenshot_01.png", "id": "3421502638137019", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404377_3421502641470352_2710315714562841810_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sGbfBD6B_9gQ7kNvgFHSVxr&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAY7dSl9MbRCHuttYnYTZA-IhzbtP83NCg5FK8nQOxyyQ&oe=6703CAB2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "635171461603624", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569444_635171464936957_8156230190308559210_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BsN99tgo-h0Q7kNvgGnlKQM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuzWx2QuqduL0wY4zzwZhBqN8Ah0Be9VYDR7LpPKAljA&oe=6703BA1F"}, "display_name": "Glue", "keywords": ["productivity", "collaboration", "multiuser", "meetings", "remote"], "long_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create. Combining the best in immersive 3D graphics, virtual reality and cloud computing technology, Glue empowers teams everywhere to maximize their collaborative potential.\n\nGlue offers both FREE and PAID subscriptions to is remote collaboration platform. Within the app you can create a Glue Team and Glue Account with FREE subscription.\n\nFREE subscription offers you all the features of Glue including customizable 3D avatars, spatial audio, selection of persistent meeting spaces, full suite of collaboration tools and the team files storage for your files. \n\nWith the FREE subscription, you can have up to 10 members in your Glue Team and create up to 10 Team Spaces. FREE subscription has a session time limit of 30 minutes per session.\n\nPAID subscription options and upgrading your subscription at www.glue.work/pricing.", "short_description": "Glue is a collaboration platform for teams who need remote meetings to be as great as face-to-face meetings. Glue brings remote teams together to learn, share, plan and create.\n\nYou need to be a member of a Glue Team to use this app. You can create a free trial Glue Team within the app."}]}, "developer_name": null, "developer_privacy_policy_url": "https://glue.work/glue-privacy-policy/", "developer_terms_of_service_url": "https://glue.work/terms-and-conditions/", "publisher_name": "Glue Collaboration", "support_website_url": "https://glue.work/support/", "website_url": "https://glue.work/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP"], "id": "832650831105452"}, "review_messages": ["Approving metadata launch for 10/25 @ 10am PST"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031640_1776440686082037_2077441316718645899_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aI0qmizf0CcQ7kNvgGUnHMb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDjX9k3y4roaI78q1V0Lc2WYESZ5sKoojcQ0ivc3ZgF_g&oe=6703B1ED"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Glue", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}], "release_date": 1612461650, "lastRevision": {"nodes": [{"id": "360556985142114", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3755552521124500", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "416122436067447"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Cover_Portrait.png", "id": "848493212660154", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974518_848493219326820_8973084957245713015_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mzYzujl7BAIQ7kNvgFMYJRa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwIIhKhCZVHKOmLXhqhSFbf65HyJLr0-nA4_QVnwm55w&oe=6703D84D"}, {"file_name": "HeroArt.png", "id": "832687890919466"