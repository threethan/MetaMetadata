uscdn.com/v/t64.5771-25/11162706_126389981330161_2475665642435379200_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9UTso_4xTNsQ7kNvgHV5DHg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBEC9XiNIB_KuH8b5hJ1cy6A-eyZAfUgSCNGPiKu6LeBw&oe=6745A642"}, {"file_name": "migrated_image.png", "id": "550922485546028", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162688_1056738924429050_7143121875625836544_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nWI3jbYu14MQ7kNvgGaj_xi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRZPgGMS6OX0GzvFFWtaZM8EGPsqXeH0C6fuQmRidpSQ&oe=6745B5E8"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MINT VR", "keywords": ["mintpot", "video", "vr", "mintvr"], "long_description": "MINT VR\uc740 \uc138\uacc4\ucd5c\ucd08 VR\uc601\uc0c1\uc5d0\uc11c\uc758 \uc790\ub9c9\uae30\ub2a5\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\uc804 \uc138\uacc4 \ub2e4\uc591\ud55c \uc5b8\uc5b4\uc758 VR\uc601\uc0c1\uc744 4\uac1c\uad6d\uc5b4\ub85c \uac10\uc0c1\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc2e4\uc2dc\uac04\uc73c\ub85c \uace0\ud654\uc9c8\uc758 VR\uc601\uc0c1\uc744 \uac10\uc0c1\ud558\uc138\uc694.\n\n\ub2e4\uc74c\uacfc \uac19\uc740 \uc5b8\uc5b4\ub97c \uc9c0\uc6d0\ud569\ub2c8\ub2e4.\n- \ud55c\uad6d\uc5b4\n- \uc911\uad6d\uc5b4\n- \uc601\uc5b4\n- \uc77c\ubcf8\uc5b4\n\nMINT VR\uc740 \ud3b8\uc548\ud55c \uac10\uc0c1\uc744 \uc704\ud574 \ub2e4\uc74c\uacfc \uac19\uc740 \uae30\ub2a5\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n- \ub192\uc740 \ud654\uc9c8\uc758 \uc2a4\ud2b8\ub9ac\ubc0d \uc11c\ube44\uc2a4(4k)\n- \ud3b8\ud55c \uac80\uc0c9\uc744 \uc704\ud55c \uc601\uc0c1 \uce74\ud0c0\uace0\ub9ac \ubd84\ub958\n- \ucd5c\uadfc \uac00\uc7a5 \uc778\uae30\uc788\ub294 VR\uc601\uc0c1 \ub9ac\uc2a4\ud2b8\n- \ucd5c\uc2e0 \uc5c5\ub85c\ub4dc \ub41c VR\uc601\uc0c1 \ub9ac\uc2a4\ud2b8\n- \uc544\ub984\ub2e4\uc6b4 \uac00\uc0c1\uc758 UI\ud658\uacbd\n- \ud3b8\ub9ac\ud55c \uae30\ub2a5\uc758 VR\uc601\uc0c1 \ud50c\ub808\uc774\uc5b4\n\n\ubc84\uadf8/\uc624\ub958 \uc2e0\uace0 : service@mintpot.net\n\uc601\uc0c1 \uc81c\ud734 \ubb38\uc758 : contents@mintpot.net", "short_description": "MINT VR\uc740 \uc138\uacc4\ucd5c\ucd08 VR\uc601\uc0c1\uc5d0\uc11c\uc758 \uc790\ub9c9\uae30\ub2a5\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\n\uc804 \uc138\uacc4 \ub2e4\uc591\ud55c \uc5b8\uc5b4\uc758 VR\uc601\uc0c1\uc744 4\uac1c\uad6d\uc5b4\ub85c \uac10\uc0c1\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\uc2e4\uc2dc\uac04\uc73c\ub85c \uace0\ud654\uc9c8\uc758 VR\uc601\uc0c1\uc744 \uac10\uc0c1\ud558\uc138\uc694."}, {"images": {"nodes": []}, "id": "1411548032349462", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MINT VR :VR Video with subtitle", "keywords": ["mintpot", "video", "vr", "mintvr"], "long_description": "**MINT VR  provides the world's first VR video\nwith subtitles. VR videos can be viewed in 4 \ndifferent languages. You can enjoy high-quality VR moving images in real time.\n\n1. The following languages \u200b\u200bare:\n-Korean\n-Chinese\n-English\n-Japanese\n\n2. MINT VR  provides the following features for\ncomfortable viewing.\n\n-High quality streaming service (4k)\n-Classified video categories for easy search\n- List of most latest and popular VR videos\n- List of latest uploaded VR moving images\n- Built in virtual user interface (UI) \n- VR video player with convenient functions\"\n\n3. Ways to earn active points\n- You can earn maximum points up to 25P a \nday!\n- Within just 4 days you can earn up to 100P, \na free video!\n- Earn points by being active in using your \napp and watch VR videos for free.\n1) Daily Access : 5P+ (Allowed once a day)\n2) Click Like : 1P+ (Allowed 20 times a day)\n\nContact us / Report a bug\n-E-mail: service@mintpot.net\"", "short_description": "MINT VR  provides the world's first VR video with subtitles. VR videos can be viewed in 4 different languages. You can enjoy high-quality VR moving images in real time."}, {"images": {"nodes": []}, "id": "1387936338045185", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MINT VR - \u5b57\u5e55\u4ed8\u304d\u306eVR\u30b3\u30f3\u30c6\u30f3\u30c4", "keywords": ["mintpot", "video", "vr", "mintvr"], "long_description": "**\u300cMINT VR\u300d\u306f\u4e16\u754c\u3067\u521d\u3081\u3066VR\u30b3\u30f3\u30c6\u30f3\u30c4\u306b\u5bfe\u3059\u308b\u5b57\u5e55\u6a5f\u80fd\u63d0\u4f9b\u3092\u5b9f\u73fe\u3057\u307e\u3057\u305f\u3002\u4e16\u754c\u5404\u56fd\u306e\u591a\u69d8\u306aVR\u30b3\u30f3\u30c6\u30f3\u30c4\u30924\u304b\u56fd\u8a9e\u3067\u3054\u89a7\u3044\u305f\u3060\u3051\u307e\u3059\u3002\u9ad8\u753b\u8cea\u306eVR\u30b3\u30f3\u30c6\u30f3\u30c4\u3092\u30ea\u30a2\u30eb\u30bf\u30a4\u30e0\u3067\u304a\u697d\u3057\u307f\u304f\u3060\u3055\u3044\uff01\n\n1. \u8a00\u8a9e\u5bfe\u5fdc\n\u2010 \u97d3\u56fd\u8a9e\n\u2010 \u4e2d\u56fd\u8a9e\n\u2010 \u82f1\u8a9e\n\u2010 \u65e5\u672c\u8a9e2. \u300cMINT VR\u300d\u3067\u306f\u3088\u308a\u4fbf\u5229\u306a\u3054\u5229\u7528\u306e\u305f\u3081\u6b21\u306e\u3088\u3046\u306a\u6a5f\u80fd\u3092\u63d0\u4f9b\u3057\u3066\u3044\u307e\u3059\u3002\n\u2010 \u9ad8\u753b\u8cea\u306e\u30b9\u30c8\u30ea\u30fc\u30df\u30f3\u30b0\u30b5\u30fc\u30d3\u30b9\n\u2010 \u4fbf\u5229\u306a\u691c\u7d22\u306e\u305f\u3081\u306e\u30b3\u30f3\u30c6\u30f3\u30c4\u306e\u30ab\u30c6\u30b4\u30ea\u30fc\u5206\u985e\n\u2010 \u6700\u8fd1\u4eba\u6c17\u306eVR\u30b3\u30f3\u30c6\u30f3\u30c4\u30ea\u30b9\u30c8\u63d0\u4f9b\n\u2010 \u6700\u65b0\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u3055\u308c\u305fVR\u30b3\u30f3\u30c6\u30f3\u30c4\u30ea\u30b9\u30c8\u63d0\u4f9b\n\u2010 \u30c7\u30b6\u30a4\u30f3\u6027\u306e\u9ad8\u3044UI\u74b0\u5883\n\u2010 \u4fbf\u5229\u306a\u6a5f\u80fd\u6e80\u8f09\u306eVR\u30b3\u30f3\u30c6\u30f3\u30c4\u30d7\u30ec\u30a4\u30e4\u30fc\n\n3. \u30a2\u30d7\u30ea\u5185\u3067\u306f\u69d8\u3005\u306a\u6d3b\u52d5\u3067\u30dd\u30a4\u30f3\u30c8\u3092\u8caf\u3081\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\n\u2010 1\u65e5\u6700\