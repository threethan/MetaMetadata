": "DD Logo (transparent).png", "id": "471042638383878", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75241698_471042641717211_573288942406372636_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qpVtF7Y7jiYQ7kNvgECgHgH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmXPpJvu2whlT1PB4adYNusVhICswH3qqjxSfDAHj17A&oe=66F94B72"}, {"file_name": "DD Cover Art - Square.png", "id": "460411126148669", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348037_460411129482002_5116551172175726143_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YQuWsLgxj6gQ7kNvgEnX5wC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCoF7hrhw0Q4bNd4cuDPjLgX_uII6jYPYtmlkK9KPbtQ&oe=66F92767"}]}, "id": "1156984115003809", "locale": "en_US", "screenshots": [{"file_name": "DD_6.png", "id": "3405028629769973", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001702_3405028633103306_1951113301211083120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l0G5WWAkq5wQ7kNvgGD6JiX&_nc_ht=scontent.oculuscdn.com&oh=00_AYARMr4pambVWOmdg1Lt8BQvAbn5kSFRqwD5KV3S5HeHFQ&oe=66F9566E"}, {"file_name": "DD_3.png", "id": "2265811323597023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031321_2265811326930356_7738878434967932108_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Skw_xKFZXYQQ7kNvgHI67Kz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDG2YU6SLiCmPbNRj5XPa-UApcEAYuxPSrPdCfu7hhG0g&oe=66F923C0"}, {"file_name": "DD_2.png", "id": "1840932986283218", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036614_1840932989616551_5744833253047701719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jptQlhfCdKkQ7kNvgG7v8Px&_nc_ht=scontent.oculuscdn.com&oh=00_AYBLaxLi7SAeQJfyBi1v0W7vgRa7C3F-odeYJVz3I6W6WQ&oe=66F93BFE"}, {"file_name": "DD_4.png", "id": "621413143042193", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982491_621413146375526_1093358764251678158_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsKQlHS8dR4Q7kNvgFIkUSz&_nc_ht=scontent.oculuscdn.com&oh=00_AYABLQKX0937ayOpqIrS0JUycCeY_WU_Sovf7WbAvyJ7sQ&oe=66F950CE"}, {"file_name": "DD_5.png", "id": "723776272644093", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035446_723776275977426_6882373117266150392_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Edp2LsJAowQ7kNvgEvlo8-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDuBhlpnM-6Y2eBVDfeGyUHs7p1gH-PVzdWEtlnzcXWnA&oe=66F93991"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DivineDuel_VideoCover.png", "id": "554342616720334", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451775_554342623387000_587836032314581877_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n-qEet3In2UQ7kNvgFxExU8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbFU_3HtKq9Q-e43zTF42Y29ojnAQcjEfeZrtVPupyLg&oe=66F928EB"}, "display_name": "Divine Duel Release", "keywords": [], "long_description": "Divine Duel is a tactical fighting game that mixes Fantasy and Sci-Fi themes to bring you a fresh take on PVP. Forget about ordinary weaponry and prepare to experience an outlandish arsenal that includes weaponized musical instruments, mythical creatures, and a meteor.\n\nThe game combines fast-paced gameplay with a strategic layer, rewarding players for quick thinking and creative ideas. Duel others in a never-ending struggle for the fate of the Multiverse and prove that you have what it takes to win the Divine Duel.\n\nThe glory is yours to take.\n\nFeatures:\n\u2022 Choose your Celestial and duel players from around the world in real-time\n\u2022 Use over 40 exciting weapons, spells, and summons (dragons included!)\n\u2022 Experiment with your loadout - drop a huge structure on your foe if you have to!\n\u2022 Level up and unlock useful boosters that can improve your fighting potential\n\u2022 Try multiple game modes - classical duel and card-games-inspired draft\n\u2022 Move or die - as simple as that", "short_description": "Divine Duel is a VR fighting game that mixes Sci-Fi and Fantasy themes with crazy weaponry. Step inside the arena and defeat your rivals using a combination of over 40 weapons, spells, and summons at your disposal."}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games", "support_website_url": null, "website_url": "https://www.divineduel.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "748943376800407"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "895536442031210"}, {"status": "PUBLISHED", "id": "855223325588571"}]}, "baseline_offer": {"id": "895536442031210"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1700820900, "status": "PUBLISHED", "id": "895536442031210"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7276010859117113", "version": "1.1.1193"}, "id": "736365001052788", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6010612775656934", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7276010859117113"}, "release_status": "RELEASED"}, "binary_release_ch