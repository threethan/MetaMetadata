.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FhjJ2P0ZCJUQ7kNvgGe2X4J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAO0uJ6bAh2oxrAIXcvoJAStHj53meqHNftAHBL20ZDYw&oe=6745C7CE"}, {"file_name": "DD_5.png", "id": "723776272644093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035446_723776275977426_6882373117266150392_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UmO-Oz_iZ1sQ7kNvgHTlzVq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC9Oin-momn3jeBTjCppEgRR2WJ2N0ORT2DnhSgBr5yNA&oe=6745B091"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover2.png", "id": "2329129487264775", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974549_2329129490598108_7472866384761212676_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9hHsUqQXOC4Q7kNvgHP6vrM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCErvWG2K5gXaVbZuOc5ApTg0Fq-n_Fa5I_mTiwnqshog&oe=6745C786"}, "display_name": "Divine Duel", "keywords": [], "long_description": "Divine Duel is a tactical fighting game that blends Fantasy and Sci-Fi, offering a fresh perspective on PvP. Forget about ordinary weaponry and brace yourself for an extraordinary arsenal, featuring weaponized musical instruments, mythical creatures, and even a meteor.\n\nThe game integrates fast-paced gameplay with a strategic layer, rewarding players for quick thinking and creative ideas. Duel others in a never-ending struggle for the fate of the Multiverse and prove that you have what it takes to win the Divine Duel.\n\nThe glory is yours to take.\n\nFeatures:\n\u2022 Choose your Celestial and engage in real-time duels with players from around the world\n\u2022 Utilize over 40 thrilling weapons, spells, and summons (yes, dragons are included!)\n\u2022 Experiment with your loadout - drop a colossal structure on your foe if necessary!\n\u2022 Level up and unlock valuable boosters that enhance your fighting potential\n\u2022 Explore multiple game modes - from classical duels to card-game-inspired drafts\n\u2022 Embrace the mantra \"move or die\" - it's as straightforward as that", "short_description": "Divine Duel is a VR fighting game that blends Sci-Fi and Fantasy themes with crazy weaponry. Step inside the arena and defeat your rivals using a diverse arsenal of over 40 weapons, spells, and summons at your disposal."}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games", "support_website_url": null, "website_url": "https://www.divineduel.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7010366515681550"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035327_151893124520962_8485738683222463460_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SfUnYksTdE4Q7kNvgGNKc74&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0bjCLly_krjWqsLZIQNXoLWpoWQT6ceAcUD1CAns02w&oe=6745A3E6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Divine Duel", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1677690008, "lastRevision": {"nodes": [{"id": "6010612835656928",