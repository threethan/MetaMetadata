f75u4g&oe=677CF9C0"}, {"file_name": "DD_2.png", "id": "1840932986283218", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036614_1840932989616551_5744833253047701719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vfhZa_ZOeXoQ7kNvgGVeitu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACrQu5M443StbwhodHgQAGm4VjbkGkNMcgpVHeH2TIXQ&oe=677D11FE"}, {"file_name": "DD_4.png", "id": "621413143042193", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982491_621413146375526_1093358764251678158_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQwsGLbmPBIQ7kNvgHQVJbi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGBsMoUTHvd88a2brkFqGdbUSa0pAn50flOAodcC9deQ&oe=677D26CE"}, {"file_name": "DD_5.png", "id": "723776272644093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035446_723776275977426_6882373117266150392_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rRq-yF1geT4Q7kNvgGHk2_G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBU1IA1WnVHTcH88i5NxTE-zARsWDMgOj3QIhvskWRuAw&oe=677D0F91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DivineDuel_VideoCover.png", "id": "554342616720334", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451775_554342623387000_587836032314581877_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mYOE-O4vz2MQ7kNvgEzuO9y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB48xkUgS1AwsSuqRiy4Erxq3udRScPx86azYWNOEq6Rw&oe=677CFEEB"}, "display_name": "Divine Duel Release", "keywords": [], "long_description": "Divine Duel is a tactical fighting game that mixes Fantasy and Sci-Fi themes to bring you a fresh take on PVP. Forget about ordinary weaponry and prepare to experience an outlandish arsenal that includes weaponized musical instruments, mythical creatures, and a meteor.\n\nThe game combines fast-paced gameplay with a strategic layer, rewarding players for quick thinking and creative ideas. Duel others in a never-ending struggle for the fate of the Multiverse and prove that you have what it takes to win the Divine Duel.\n\nThe glory is yours to take.\n\nFeatures:\n\u2022 Choose your Celestial and duel players from around the world in real-time\n\u2022 Use over 40 exciting weapons, spells, and summons (dragons included!)\n\u2022 Experiment with your loadout - drop a huge structure on your foe if you have to!\n\u2022 Level up and unlock useful boosters that can improve your fighting potential\n\u2022 Try multiple game modes - classical duel and card-games-inspired draft\n\u2022 Move or die - as simple as that", "short_description": "Divine Duel is a VR fighting game that mixes Sci-Fi and Fantasy themes with crazy weaponry. Step inside the arena and defeat your rivals using a combination of over 40 weapons, spells, and summons at your disposal."}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games", "support_website_url": null, "website_url": "https://www.divineduel.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "748943376800407"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "895536442031210"}, {"status": "PUBLISHED", "id": "855223325588571"}]}, "baseline_offer": {"id": "895536442031210"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1700820900, "stat