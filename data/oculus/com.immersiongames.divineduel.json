191571604918", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75286676_375191574938251_6815326492660379041_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3AbOjWIIIE8Q7kNvgH1J_Wf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCw3x2JCyyvSayD2UX1XdDkFX0WqpkU-yq6fVov6tzkjA&oe=675D61E4"}, {"file_name": "DD Cover Art - Square.png", "id": "151893121187629", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035327_151893124520962_8485738683222463460_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jBFJ202RUPQQ7kNvgHR8Vko&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAb-Ew6kkuRBbPWQLd5K5A4_wqsPKAN5YX6s3wukcTo4A&oe=675D5EE6"}]}, "id": "871527644279008", "locale": "en_US", "screenshots": [{"file_name": "DD_6.png", "id": "3405028629769973", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001702_3405028633103306_1951113301211083120_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8hNwEpAxEoQ7kNvgEGHtiG&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCIdpB8UTxoH0J00FMiJBB2qf13N4bAcQLhjsqzcuXlWQ&oe=675D886E"}, {"file_name": "DD_3.png", "id": "2265811323597023", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031321_2265811326930356_7738878434967932108_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mdPV67JErnUQ7kNvgEZRLGL&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBShbbCXSNrbHgmTs6UhhDjPGNjxiLus-ypR-aLbzLaFQ&oe=675D55C0"}, {"file_name": "DD_2.png", "id": "1840932986283218", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036614_1840932989616551_5744833253047701719_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qFtYYuVsZfcQ7kNvgEgNTEc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAB1R7xc4QTzx2uFeDPnyuH8IbyqfowR9oxbgEcaz1oSg&oe=675D6DFE"}, {"file_name": "DD_4.png", "id": "621413143042193", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982491_621413146375526_1093358764251678158_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebIw5wW1PGEQ7kNvgHXyZCC&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCw1snKz8TXXxTfjIh9VXj2Q76yXNo26e7yU0VqpYEe-Q&oe=675D82CE"}, {"file_name": "DD_5.png", "id": "723776272644093", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035446_723776275977426_6882373117266150392_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EGV6JmAzrugQ7kNvgE3CzOW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA2p6aE2Cif6vWP0zF0yitBfTsRIUoSRBz8FxCyB-kyjA&oe=675D6B91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover2.png", "id": "2329129487264775", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974549_2329129490598108_7472866384761212676_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JW9ZIbCxhE0Q7kNvgGsct34&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD6JI4zsl5tjugpWw8Kz6HDFnZQEzkxb4h3K88KS1BHQw&oe=675D8286"}, "display_name": "Divine Duel", "keywords": [], "long_description": "Divine Duel is a tactical fighting game that blends Fantasy and Sci-Fi, offering a fresh perspective on PvP. Forget about ordinary weaponry and brace yourself for an extraordinary arsenal, featuring weaponized musical instruments, mythical creatures, and even a meteor.\n\nThe game integrates fast-paced gameplay with a strategic layer, rewarding players for quick thinking and creative ideas. Duel others in a never-ending struggle for the fate of the Multiverse and prove that you have what it takes to win the Divine Duel.\n\nThe glory is yours to take.\n\nFeatures:\n\u2022 Choose your Celestial and engage in real-time duels with players from around the world\n\u2022 Utilize over 40 thrilling weapons, spells, and summons (yes, dragons are included!)\n\u2022 Experiment with your loadout - drop a colossal structure on your foe if necessary!\n\u2022 Level up and unlock valuable boosters that enhance your fighting potential\n\u2022 Explore multiple game modes - from classical duels to card-game-inspired drafts\n\u2022 Embrace the mantra \"move or die\" - it's as straightforward as that", "short_description": "Divine Duel is a VR fighting game that blends Sci-Fi and Fantasy themes with crazy weaponry. Step inside the arena and defeat your rivals using a diverse arsenal of over 40 weapons, spells, and summons at your disposal."}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games", "support_website_url": null, "website_url": "https://www.divineduel.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7010366515681550"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035327_151893124520962_8485738683222463460_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jBFJ202RUPQQ7kNvgHR8Vko&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB_MtATHGYC6WYF6t__YUgx1kaHdGMw3Tyw4-4gNRptog&oe=675D5EE6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Divine Duel", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1677690008, "lastRevision": {"nodes": [{"id": "6010612835656928", 