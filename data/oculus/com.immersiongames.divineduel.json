"621413143042193", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982491_621413146375526_1093358764251678158_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ERcY7CoyX24Q7kNvgGAybY3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBN6g82ta32qvY8_Pzpa0a4Je4lXlML7v9lhFiHj6Pndg&oe=676AB1CE"}, {"file_name": "DD_5.png", "id": "723776272644093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035446_723776275977426_6882373117266150392_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=82Pu0ys8YJMQ7kNvgGpz5oO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnyjJEEK3h1T5k4Ex0qOwP1ilvGR7RV2GZPh2LvtShJA&oe=676A9A91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover2.png", "id": "2329129487264775", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974549_2329129490598108_7472866384761212676_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lvjvxeSTHFkQ7kNvgGDuGTP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUo_kZ7Q__lKQuz5YvfmHH24vQrr4O8gGn7FiKYvle9A&oe=676AB186"}, "display_name": "Divine Duel", "keywords": [], "long_description": "Divine Duel is a tactical fighting game that blends Fantasy and Sci-Fi, offering a fresh perspective on PvP. Forget about ordinary weaponry and brace yourself for an extraordinary arsenal, featuring weaponized musical instruments, mythical creatures, and even a meteor.\n\nThe game integrates fast-paced gameplay with a strategic layer, rewarding players for quick thinking and creative ideas. Duel others in a never-ending struggle for the fate of the Multiverse and prove that you have what it takes to win the Divine Duel.\n\nThe glory is yours to take.\n\nFeatures:\n\u2022 Choose your Celestial and engage in real-time duels with players from around the world\n\u2022 Utilize over 40 thrilling weapons, spells, and summons (yes, dragons are included!)\n\u2022 Experiment with your loadout - drop a colossal structure on your foe if necessary!\n\u2022 Level up and unlock valuable boosters that enhance your fighting potential\n\u2022 Explore multiple game modes - from classical duels to card-game-inspired drafts\n\u2022 Embrace the mantra \"move or die\" - it's as straightforward as that", "short_description": "Divine Duel is a VR fighting game that blends Sci-Fi and Fantasy themes with crazy weaponry. Step inside the arena and defeat your rivals using a diverse arsenal of over 40 weapons, spells, and summons at your disposal."}]}, "developer_name": null, "developer_privacy_policy_url": "https://immersion.games/game-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Immersion Games", "support_website_url": null, "website_url": "https://www.divineduel.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7010366515681550"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035327_151893124520962_8485738683222463460_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YpfeprmQKIwQ7kNvgGHdXZ8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDk2DjbEuxhE0mumk5DpHZtRQrQEhEHpYZQuk0ie4I7A&oe=676A8DE6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Divine Duel", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name