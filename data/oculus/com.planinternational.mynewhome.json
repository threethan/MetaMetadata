whome.plansverige.org/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4827770727260397"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/12504788_166179640872272_3522102967765303296_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G7HGRfn2F3QQ7kNvgEMG4FP&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDdl_nuWULL4eyh0B3AcEqsYz7N_HsLoLdY_aiISsHH9Q&oe=675EDE2D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "My New Home", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1485331200, "lastRevision": {"nodes": [{"id": "300562930292704", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1061939523887646", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2454795081517004", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/12504686_143260382767181_639079597_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PX34yTPjgeEQ7kNvgFfa2TE&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBuGoNvz7cliViy6ChLXj5tc6xafJWG1StTr67_S2PIVg&oe=675EDC5