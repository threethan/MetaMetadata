6-1.oculuscdn.com/v/t64.5771-25/12533842_421748281490722_6952529691093762048_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9k5wE-neS_MQ7kNvgFViqle&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCE2dZNEwIU5ikqtfOszqtC8hpDpZmQXMPMZzgXOCoirA&oe=67163D37"}, {"file_name": "migrated_image.png", "id": "227386628442492", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/12410455_1247752641914939_6651287952036986880_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tnyDOKDGZegQ7kNvgF8VsfE&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCDG-oQvmjjDEGgWGQ7TxLlCpGyX3xw5Br4u1pf0acgnw&oe=67164939"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Kill Ball", "keywords": ["Zuma", "Casual", "Shooter", "Puzzle", "Strategy"], "long_description": "Total-immersion 3D Tracks\n3D tracks of all kinds feature the biggest highlight of KILL BALL. These tracks may show before or around you.\nVarious Tile-matching Tactics\nEach level of KILL BALL offers different experience depending on tracks. For some levels, the ball group will be accelerated when passing certain tracks; for others, 360\u00b0shooting is required to kill all round balls.\n\nAmazing Hit-Feel and Fabulous Pictures\nThanks to global light, changing seasons and sun-moon alternating can be presented to players in the same scene. Coupled with weather system, players can be totally immersed in the magnificent and incredible game world. Ball crashing has 100% reproduced balls\u2019 physical properties when moving on the track. Multiple Combo design, along with breath-taking climate, renders superb hit-feel that will definitely rock you.", "short_description": "Another way to play a matching game"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.firesvr.com/privacy.html", "developer_terms_of_service_url": "http://www.firesvr.com/provision.html", "publisher_name": "FiresVR", "support_website_url": null, "website_url": "http://www.firesvr.com/", "category": "GAME