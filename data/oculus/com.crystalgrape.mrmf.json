t.oculuscdn.com&oh=00_AYBzRGhsiH2P6mBYb58JEOujSAFPw0b0SDoTMPFN38D_xg&oe=66DAD4C0"}, {"file_name": "Screenshot3.png", "id": "1423618075004984", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031518_1423618078338317_5302236212722376612_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vIwBW6J68kQ7kNvgEepydO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSd7kgOnKZBp3_Fsp2C1jcIXNqLN76EpoRumirukMAPA&oe=66DAD6DF"}, {"file_name": "Screenshot4.png", "id": "809076641406483", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982547_809076648073149_6566950714060643996_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LAP5s-LjDZEQ7kNvgEu1mZh&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0lEnXoiopxcZPpoohQIoFg_UktkWA52qHPRVZVHc5nw&oe=66DAFCA0"}, {"file_name": "Screenshot5.png", "id": "1694871534601590", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031551_1694871541268256_1009713101858916267_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WDSK0hfxGbEQ7kNvgHhyuwm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMqNDlHM1pxn3zCThWBihQESjDzx4UNE_Aj9902AjHBA&oe=66DAE11C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monke Run! Monke Fun!", "keywords": ["Gorilla", "Monke", "GorillaLocomotion", "Gamemodes", "Adventure"], "long_description": "(WARNING: The game is still in early access and most stuff you see here is not in the game yet. These stuff are coming in future updates)\n\nJump, Run and have Fun!\n\nWelcome to Monke Run! Monke Fun! A game where you use the classic Gorilla VR Locomotion to move around. \n\nGamemodes\nThis game has gamemodes to offer and if you complete a certaint gamemode, you gonna get free ingame currency.\n\nCustomization\nYou can customize your Monke with colors, face expresions and cosmetics. You can buy cosmetics with ingame currency or you can find collectibles arround the game.\n\nEntities\nWatch out for entities who are trying to get you. Entities can appear in public or in private meet up codes (as long as the private code is known to the public).\n\nNukes\nSurvive Nukes. If you hear the nuke alarm you have to run into the bunker as fast as you can. Only hope is that you know the code...\n\nLore and Story\nYou wanna know the Story that this game has? Try out horror aka. story mode and you will see what's the story behind this game.\n\nWhat are you waiting for? Download the game now to have fun!", "short_description": "Jump, Run and have Fun!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/grape-gaming-guys/mrmf-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "CrystalGrape", "support_website_url": null, "website_url": "https://sites.google.com/view/grape-gaming-guys/monke-run-monke-fun?authuser=0", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8277538162361909"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1159653895293012"}]}, "baseline_offer": {"id": "1159653895293012"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1724765820, "status": "PUBLISHED", "id": "1159653895293012"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8266001110182281", "version": "1.2"}, "id": "850427823352077", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false