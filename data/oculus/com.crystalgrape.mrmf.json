b=1-7&_nc_sid=6e7a0a&_nc_ohc=VJVxyViiT8sQ7kNvgHfdpq0&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6NFn5qG2wluXxy_NTBhMX9z5T0QiGr9xuTXpGkgPLLA&oe=67092C6A"}, {"file_name": "Screenshot2.png", "id": "813705704077889", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974510_813705707411222_238550223869688159_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wUEyNuFMrKgQ7kNvgGpama6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAo_CXdw0Cx5vBVHagu7KKQdT0QzmWexuTGSwAOXVAHqw&oe=6708F940"}, {"file_name": "Screenshot3.png", "id": "1423618075004984", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031518_1423618078338317_5302236212722376612_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NMRYh-MS8DYQ7kNvgHJ8Abf&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAosyF6B0gbyd_EKJmT_8Fph1LD3vVi8Cf8F6YAcgUj-Q&oe=6708FB5F"}, {"file_name": "Screenshot4.png", "id": "809076641406483", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982547_809076648073149_6566950714060643996_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yog5vBXxiYoQ7kNvgHlwXfY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJi4tbEULRh2ZTTOJkgJDN9XXUJ9428DowVBKAwC5K2g&oe=67092120"}, {"file_name": "Screenshot5.png", "id": "1694871534601590", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031551_1694871541268256_1009713101858916267_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kwwf4SgX4_IQ7kNvgHhufq_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZpHfk5UIutlbPr2gspK52Okctqa387AkEw_-YPIro7w&oe=6709059C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Monke Run! Monke Fun!", "keywords": ["Gorilla", "Monke", "GorillaLocomotion", "Gamemodes", "Adventure"], "long_description": "(WARNING: The game is still in early access and most stuff you see here is not in the game yet. These stuff are coming in future updates)\n\nJump, Run and have Fun!\n\nWelcome to Monke Run! Monke Fun! A game where you use the classic Gorilla VR Locomotion to move around. \n\nGamemodes\nThis game has gamemodes to offer and if you complete a certaint gamemode, you gonna get free ingame currency.\n\nCustomization\nYou can customize your Monke with colors, face expresions and cosmetics. You can buy cosmetics with ingame currency or you can find collectibles arround the game.\n\nEntities\nWatch out for entities who are trying to get you. Entities can appear in public or in private meet up codes (as long as the private code is known to the public).\n\nNukes\nSurvive Nukes. If you hear the nuke alarm you have to run into the bunker as fast as you can. Only hope is that you know the code...\n\nLore and Story\nYou wanna know the Story that this game has? Try out horror aka. story mode and you will see what's the story behind this game.\n\nWhat are you waiting for? Download the game now to have fun!", "short_description": "Jump, Run and have Fun!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/grape-gaming-guys/mrmf-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "CrystalGrape", "support_website_url": null, "website_url": "https://sites.google.com/view/grape-gaming-guys/monke-run-monke-fun?authuser=0", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8277538162361909"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED