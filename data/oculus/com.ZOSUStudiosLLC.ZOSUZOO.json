0a&_nc_ohc=X-YIWY3Ep4wQ7kNvgEWgPwe&_nc_ht=scontent.oculuscdn.com&oh=00_AYCY8e81LJyeL_1TSoHOoNknXHwHL-VsxudrwMNvoqVCiQ&oe=66FD335A"}, {"file_name": "39036665_1362218797977565_2391701479039030959_n.png", "id": "1659613264442691", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031387_1659613267776024_1666033661232148010_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z0JRMdcxHY4Q7kNvgGP-pW1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSCv806_3ILZI3ZDwvJv-iwDc4ZB6PyqGMajiFzVMElQ&oe=66FD3A7F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape w zoo.png", "id": "685840855810573", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974728_685840859143906_776594460902552357_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4X4RQKEqg0AQ7kNvgEDOcz7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtsvXrhJsg7Fxbv4eYbZBIMWZB--ajbiZKNR8t8UemxA&oe=66FD431E"}, "display_name": "ZOSU Zoo", "keywords": ["Zoo", "mixedreality", "dinosaur", "handtrack", "animal"], "long_description": "- This is a relaxing zoo experience with over 140 high detailed animals to see and 60 jungle plants.\n- Mixed reality and hand tracking areas allow you to create a zoo home, along with jungle environments.\n- ZOSU Zoo Land and 30 ZOSU Ocean levels are waiting for you to explore in classic VR (controller use only).\n\nAnimals include: lions, sharks, dinosaurs, clown fish, pre-historic fish, bears, wolves, elephants, rhinos, whales, crocodiles, chickens, tigers, octopus, whales, dolphins, horses, cats, dogs, star fish, leopard, cuttlefish, zebras, owls, seals, lion fish, lizards, goats, sun fish, squid, and many more!\n\nThis game received a major update in July 2024 for mixed reality + hand tracking and ocean exploration levels, these updates are available for all version except Quest1 (Quest1 will continue to only have the original ZOSU Zoo land)\n", "short_description": "- This is a relaxing zoo experience with over 140 high detailed animals to see and 60 jungle plants.\n- Mixed reality and hand tracking areas allow you to create a zoo home, along with jungle environments.\n- ZOSU Zoo Land and 30 ZOSU Ocean levels are waiting for you to explore in classic VR.\n\nAnimals include: lions, sharks, dinosaurs, clown fish, pre-historic fish, bears, wolves, elephants, rhinos, whales, crocodiles, chickens, tigers, octopus, whales, dolphins, horses, cats, dogs, and more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "DINOSAURS", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6320113741446100"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974703_415875600447010_8202666949375033340_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vEUIWIt8cXsQ7kNvgGKlcFm&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBaAJPaWfAT8brDewYI4OzqxOHf-Gm_YHgXJGBFXrmOw&oe=66FD47D1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ZOSU Zoo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "27433260359255