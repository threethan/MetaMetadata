_ht=scontent.oculuscdn.com&_nc_gid=AsEMZDKf98Dh-IwBetPP_2M&oh=00_AYCL7T_IGYs2PAFiQMMCXCsI2fSlVvg2BEMoXOWUfWhh9w&oe=66F5581A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SIX_SHOT.png", "id": "807587161551682", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031584_807587164885015_332398316191025752_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P50jw5Zg6YMQ7kNvgF-eXTv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AsEMZDKf98Dh-IwBetPP_2M&oh=00_AYC-bMljsFjJLXBugo3BbKFopSC1XhwEoXqzHWrTnkd6Hg&oe=66F55F22"}, "display_name": "V20 Cricket", "keywords": [], "long_description": "Welcome to the future of cricket. In this immersive Virtual cricket playground, you can bat in different match scenarios, chase down targets and be the master of your own stadium! \nYou\u2019re front and center in a true to life stadium with panoramic 360-degree views. World-class bowling, phenomenal fielding and a 100,000 roaring fans with just you to beat the opposition - Are you up for it? Of course you are, the virtual world is your oyster!\nFeatures: \n\u2022\t360-degree immersive virtual environments\n\u2022\tVarious difficulty levels along with a Practise Mode to get you on your way\n\u2022\t5 bowling options - Face Pacers, Leg Spinners, Off Spinners, Swing bowlers & Mystery spinners\n\u2022\tIndian V20 League \u2013 Covering your favourite Indian Teams\n\u2022\tInternational Tournaments \u2013 Choose your country and win the coveted global trophy\n\u2022\tState of the art graphics & animation\n\u2022\tProfessional Commentary\n", "short_description": "V20 Cricket is the best Virtual Reality Cricket game for all sports enthusiasts!"}]}, "developer_name": "VirtiLens", "developer_privacy_policy_url": "https://gamepolicy.s3.ap-south-1.amazonaws.com/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "VirtiLens", "support_website_url": null, "website_url": "http://www.virtilens.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [],