m the hole at the mini golf courses\nThe multiplayer also includes voice/text chat for you to communicate with other players\n\nWhen in My Room, you will be able to customize your own space. You can choose between 3 different themed templates, explore and change it the way you prefer.\n\n* Find more information about the gameplay itself the app*\n\nUpcoming updates in the near future:\n- Avatars\n- Game monetary system\n- Shop\n- More games\n- More rooms\n\nHave fun!", "short_description": "Play minigames along with your friends in a multiplayer environment or explore and customize your own room with this experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://vresearchlab.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "575409077551853"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6794444130600441", "version": "0.2.11"}, "id": "862705021454796", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "bin