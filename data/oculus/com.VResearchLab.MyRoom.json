g", "id": "921050275807580", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974548_921050279140913_846272164452751718_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1Dz37mNIM0Q7kNvgG6tfFC&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBcEO7pO22Lro-NF2pup_hy9O0tKIkZKQIKZ0qphuA69g&oe=6777C357"}, {"file_name": "Print 2.png", "id": "1288706015050300", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75641339_1288706018383633_3836298053771559642_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QkO9hOgK5XEQ7kNvgHj-JrE&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBRRRN4GkLyiS545Rz7EmM50tw6PzX2Q1aXPXD3uKZyNA&oe=6777CD11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Final v.0.1 (eeve).png", "id": "945385240225978", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974721_945385243559311_50820886768660782_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tKBp2cl0DPgQ7kNvgEo22Ot&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCrEN6lO29i_2cU3AiPoUPNeEE_Q2oTlJe_PK9yDWpnNQ&oe=6777D2BC"}, "display_name": "My Room", "keywords": [], "long_description": "My Room is the game experience that allows you to interact with your friends and also create your own world.\n\nCustomize your character and explore our two game modes: Playground & My Room.\n\nIn the Playground you will find yourself in a multiplayer environment surrounded by minigames that are available to play with others. These games include:\n- Soccer: score as many goals as you can\n- Air Hockey (Arcade): play with the AI or with another player\n- Basketball (Arcade): throw the balls and try to score points\n- Cornhole (Arcade): have fun trying to score as you play with the bean bags\n- Darts (Arcade): practice your aiming in the available stations\n- Mini Golf (Arcade): try to aim the hole at the mini golf courses\nThe multiplayer also includes voice/text chat for you to communicate with other players\n\nWhen in My Room, you will be able to customize your own space. You can choose between 3 different themed templates, explore and change it the way you prefer.\n\n* Find more information about the gameplay itself the app*\n\nUpcoming updates in the near future:\n- Game monetary system\n- Shop\n- More games\n- More rooms\n\nHave fun!", "short_description": "Play minigames along with your friends in a multiplayer environment or explore and customize your own room with this experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://vresearchlab.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6208190105926898"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39036637_730466291957102_4986099473870612760_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=05mqTB3yN8oQ7kNvgE63Rfm&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDyWzxqamU8wIbewouihuvhuYPZ89fyedwHVC6Ng_Pi5A&oe=6777E02B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "My Room", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1679940335, "lastRevision": {"nodes": [{"id": "6506167206094803", "release_type": "SCHEDULED", "administrati