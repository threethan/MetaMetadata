00_AYDOwxm8Gqe_K5TaRaDQ2EZa95MaupAvPoacAe5ZNEGYVA&oe=66F2A8EF"}, {"file_name": "Print 5.png", "id": "921050275807580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_921050279140913_846272164452751718_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NqZIxVgNZX8Q7kNvgHrx1vF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdJznjt07FySffukccOX1q9&oh=00_AYBmL0Eo5QUcSg-hXa6-mk10DuqpRKe-uTdW-0uKbcHswQ&oe=66F29BD7"}, {"file_name": "Print 2.png", "id": "1288706015050300", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641339_1288706018383633_3836298053771559642_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8pNQFGX6Xs0Q7kNvgGMrSkN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdJznjt07FySffukccOX1q9&oh=00_AYCO9jccVDhnUMVFNHT7WpvRANxSYc_BWuIgrfEvoSRoYQ&oe=66F2A591"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Final v.0.1 (eeve).png", "id": "945385240225978", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974721_945385243559311_50820886768660782_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o5YdHB5XuWsQ7kNvgEnvddg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdJznjt07FySffukccOX1q9&oh=00_AYBimgWGTEd21EohZpnWZVcYl35yJ9jRNIOvwR5il3l3BA&oe=66F2AB3C"}, "display_name": "My Room", "keywords": [], "long_description": "My Room is the game experience that allows you to interact with your friends and also create your own world.\n\nCustomize your character and explore our two game modes: Playground & My Room.\n\nIn the Playground you will find yourself in a multiplayer environment surrounded by minigames that are available to play with others. These games include:\n- Soccer: score as many goals as you can\n- Air Hockey (Arcade): play with the AI or with another player\n- Basketball (Arcade): throw the balls and try to score points\n- Cornhole (Arcade): have fun trying to score as you play with the bean bags\n- Darts (Arcade): practice your aiming in the available stations\n- Mini Golf (Arcade): try to aim the hole at the mini golf courses\nThe multiplayer also includes voice/text chat for you to communicate with other players\n\nWhen in My Room, you will be able to customize your own space. You can choose between 3 different themed templates, explore and change it the way you prefer.\n\n* Find more information about the gameplay itself the app*\n\nUpcoming updates in the near future:\n- Game monetary system\n- Shop\n- More games\n- More rooms\n\nHave fun!", "short_description": "Play minigames along with your friends in a multiplayer environment or explore and customize your own room with this experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vresearchlab.com/privacy-policy/", "developer_terms_of_service_url": "https://vresearchlab.com/terms-of-use/", "publisher_name": "VResearch Lab", "support_website_url": null, "website_url": "https://vresearchlab.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "6208190105926898"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036637_730466291957102_4986099473870612760_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z6gUTk3QNXcQ7kNvgGLL9Y_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdJznjt07FySffukccOX1q9&oh=00_AYAKsrlTo4ZGWIZtMGkoP3vpw7nH5j5MXxI_T_eWGNh6LQ&oe=66F2B8AB"}, "is_concept": false, "is_test": false,