_1008x1440_new.png", "id": "670003361926760", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001718_670003365260093_5749224638492881519_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UdEB2mccM7AQ7kNvgE8SuCk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYBX7hR9AxOq7pLPzxb9PWQ13JYN6es_wIUEAgICJNUp4Q&oe=66F4039C"}]}, "id": "1004795930989605", "locale": "en_US", "screenshots": [{"file_name": "amazingKorea_hard_0515.mp4.png", "id": "1376900789640600", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_1376900792973933_6538038862724532423_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HAmm8P60wTkQ7kNvgEEpyQ-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYB0wHy11SKQmU04hHdj0-gcZSEo-s2xw2aiRHoxY6YI_A&oe=66F40ECE"}, {"file_name": "echo_2560.png", "id": "1226373311997855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974662_1226373315331188_4127110669096807875_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=He_Jx9oxZeQQ7kNvgGfL4Od&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYCDfTUwo9yyd5oFag5oVkFrfqkcWwzm8JuHahyS9hPKng&oe=66F3DA8B"}, {"file_name": "NeonSign_hard_0515.mp4.png", "id": "347204594670419", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75322604_347204598003752_4090282025275595888_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vf0QLmU1E6wQ7kNvgHXtxWf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYCnFZ2X7J4lhad0Cywns13y3In0Wy1WxBYTQRy0XflUpw&oe=66F402E3"}, {"file_name": "2024-02-28 19-27-54.mp4.png", "id": "332016526334130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974825_332016533000796_2098751578640501908_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=y9HQmr9UUCgQ7kNvgFS4sjF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYAudvAt0DLnwe1mae2UFxCNHMbdwSz44vYbf_AZ06O_5w&oe=66F3EE3B"}, {"file_name": "NotAlone_hard_0515.mp4.png", "id": "1834560810346274", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75485576_1834560817012940_5193466785641071115_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kC0DO2IoHIAQ7kNvgFPCNiO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYCQUZHI0nmFrrSdKqX_gEBpUXNbXxEGEcHeMSz-EoPKZw&oe=66F3E93A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video_cover.png", "id": "820996726026654", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610562_820996729359987_4412348469651450537_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ZjNGoR3js0Q7kNvgGciuLE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYA4xk8IpnLVcgknRovGKzJaY1itPZvYjabJvUK9PGqjbQ&oe=66F3E0D9"}, "display_name": "Rhythm Pop!", "keywords": [], "long_description": "Rhythm Pop! is an addictive Music Rhythm VR Game using your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nHere's the twist:\nIn our \"Classic RPS Mode\", you would beat the bubbles by making the OPPOSITE gestures.  That's right, Rock beats Scissors, Scissors beat Paper, and Paper beats Rock!\n\nFor those looking for a more conventional rhythm game experience, in \"Copycat\" mode, copy the SAME hand gestures as the bubbles to pop them.  \n\nIt may look simple, but it's hard to master!  How fast can you move your hands?!  This is a hand-tracking only experience.\n\nThe game currently includes 14 fantastic songs with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  The song genre ranges from pop, rock, classical, to EDM.  More songs will be updated in the future as we continue to update the app!", "short_description": "An addictive Music Rhythm VR Game with a twist: use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  This is a hand-tracking only experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypercreative.games/privacy-rhythmpop", "developer_terms_of_service_url": null, "publisher_name": "h