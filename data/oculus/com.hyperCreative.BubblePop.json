384412267833293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375766_384412271166626_2921541519922236002_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p9UB3rwI-_wQ7kNvgHMLU-j&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8PJ_iI69uVFdvhtBvdDQNP&oh=00_AYCRVVB92H18zndwri3va0SiUc_TH_K9TZu0wxa1V7HA9g&oe=66F695DE"}, {"file_name": "mel_lunarSync_2560.png", "id": "789872239248644", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974919_789872242581977_6372004608634830410_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-3Yf2RrGtEQ7kNvgHET6yT&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8PJ_iI69uVFdvhtBvdDQNP&oh=00_AYB_uOouQWewt81VFGJLgpXKDOikTtY9voUberbeqoP5jg&oe=66F69383"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_2560.png", "id": "379905024899686", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001715_379905028233019_3723091916722888668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z0gi1oJxtp8Q7kNvgHGekOg&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8PJ_iI69uVFdvhtBvdDQNP&oh=00_AYBPrSHqaTMOMWQitW4iMzqyYG7wSSlaaEeDn5AkrT2kWw&oe=66F6A441"}, "display_name": "BubblePop! Rock Paper Scissors", "keywords": [], "long_description": "BubblePop! Rock Paper Scissors is an addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nInstead of making the same gesture as the bubbles, you need to make the gesture that beats them.  You've known it since your childhood: Rock beats Scissors, Paper beats Rock, and Scissors beat Paper!  How fast can you move your hands?! \n\n This is a hand-tracking only experience.\n\nThe game includes 1 fantastic song that is free-to-play, with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  You can preview the 13 additional music tracks which are available as in-app-purchase.", "short_description": "An addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  Thi