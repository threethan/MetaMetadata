g", "id": "1609935546490951", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974619_1609935549824284_7155858536066813471_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F34U_snjSxAQ7kNvgEU5X4j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq_bG0SnzcAVsz-0JpKYObLMuD7ZFefMin9kraxUxGuw&oe=67614E39"}, {"file_name": "screenshot_08.png", "id": "384412267833293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375766_384412271166626_2921541519922236002_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2-9nIqJzLzQQ7kNvgFU0308&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKjwiRmKXuRjXIkd3Y4ul8T8OcIilz2qZVxFxHfybAnA&oe=67615F5E"}, {"file_name": "mel_lunarSync_2560.png", "id": "789872239248644", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974919_789872242581977_6372004608634830410_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EBsRwa9M6sUQ7kNvgFqiuGy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC80qe9LOgCcgh6LpgmJL8POoVH6BtWmquXC7yjhYb15g&oe=67615D03"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_2560.png", "id": "379905024899686", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001715_379905028233019_3723091916722888668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yQDM-N4kTV4Q7kNvgHevPfO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCK7Wcx1PxjBEZaBy29crsfGjs21kMgixmebt9kAu7gwQ&oe=67616DC1"}, "display_name": "BubblePop! Rock Paper Scissors", "keywords": [], "long_description": "BubblePop! Rock Paper Scissors is an addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nInstead of making the same gesture as the bubbles, you need to make the gesture that beats them.  You've known it since your childhood: Rock beats Scissors, Paper beats Rock, and Scissors beat Paper!  How fast can you move your hands?! \n\n This is a hand-tracking only experience.\n\nThe game includes 1 fantastic song that is free-to-play, with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  You can preview the 13 additional music tracks which are available as in-app-purchase.", "short_description": "An addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  This is a hand-tracking only experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypercreative.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "hyperCreative Games", "support_website_url": null, "website_url": "http://hyperCreative.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6507184862743546"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1735636357225610"}, {"status": "PUBLISHED", "id": "1046831097043649"}, {"status": "PUBLISHED", "id": "1075541383457179"}, {"status": "PUBLISHED", "id": "395810786633796"}]}, "baseline_offer": {"id": "395810786633796"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1737396000, "status": "PUBLISHED", "id": "1735636357225610"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7384938298301527", "version": "0.8.61"}, "id": "2578340935656857", "channel_name": "LIVE"}]}, "is_for