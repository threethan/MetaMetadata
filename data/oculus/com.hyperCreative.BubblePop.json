g", "id": "1609935546490951", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974619_1609935549824284_7155858536066813471_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d_M2CqxNQOgQ7kNvgFWGe6S&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDohD62VleDrh4x5b97WQXM4lweqOlqOEHqkrbG-cCCUw&oe=675C0839"}, {"file_name": "screenshot_08.png", "id": "384412267833293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375766_384412271166626_2921541519922236002_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jx7DENAq4cAQ7kNvgEfHwLq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBzuhcnDDo0gf4MDdDEr3xLEhz6596y1q1hwpyqOK4PdA&oe=675C195E"}, {"file_name": "mel_lunarSync_2560.png", "id": "789872239248644", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974919_789872242581977_6372004608634830410_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gkxD9YQxJ2MQ7kNvgEH92wA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDq99L5n3EbX8dkFocYeaz252r6PuFKI3bheSXMVbIYJw&oe=675C1703"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_2560.png", "id": "379905024899686", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001715_379905028233019_3723091916722888668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5FSGrCHiLzAQ7kNvgEhieMT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAmzR8DJXfZe_KUIUU7OFgQMTe1aIDajglhmBbnS6RPyA&oe=675C27C1"}, "display_name": "BubblePop! Rock Paper Scissors", "keywords": [], "long_description": "BubblePop! Rock Paper Scissors is an addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nInstead of making the same gesture as the bubbles, you need to make the gesture that beats them.  You've known it since your childhood: Rock beats Scissors, Paper beats Rock, and Scissors beat Paper!  How fast can you move your hands?! \n\n This is a hand-tracking only experience.\n\nThe game includes 1 fantastic song that is free-to-play, with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  You can preview the 13 additional music tracks which are available as in-app-purchase.", "short_description": "An addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  This is a hand-tracking only experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypercreative.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "hyperCreative Games", "support_website_url": null, "website_url": "http://hyperCreative.games/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6507184862743546"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1046831097043649"}, {"status": "PUBLISHED", "id": "1075541383457179"}, {"status": "PUBLISHED", "id": "395810786633796"}]}, "baseline_offer": {"id": "395810786633796"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1046831097043649"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7384938298301527", "version": "0.8.61"}, "id": "2578340935656857", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"n