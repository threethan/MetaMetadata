-iad3-2.oculuscdn.com&oh=00_AYA83IMt7bjngDo65M0s1BqoTXrUGdnY9QUeRyOQM-RVRw&oe=672B51DE"}, {"file_name": "mel_lunarSync_2560.png", "id": "789872239248644", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974919_789872242581977_6372004608634830410_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WhzPVoGaiRkQ7kNvgFuE85k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkcv47jDNvW0348aBAJ0yLg_oWrfwBzBINFRZnd8cnRQ&oe=672B4F83"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_2560.png", "id": "379905024899686", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001715_379905028233019_3723091916722888668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mOxXG9KEPHYQ7kNvgHGLgdM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7qfd5RWAhyIFhalInzDcgvbxr6t6jEf-nnFM3K_4veQ&oe=672B6041"}, "display_name": "BubblePop! Rock Paper Scissors", "keywords": [], "long_description": "BubblePop! Rock Paper Scissors is an addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nInstead of making the same gesture as the bubbles, you need to make the gesture that beats them.  You've known it since your childhood: Rock beats Scissors, Paper beats Rock, and Scissors beat Paper!  How fast can you move your hands?! \n\n This is a hand-tracking only experience.\n\nThe game includes 1 fantastic song that is free-to-play, with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  You can preview the 13 additional music tracks which are available as in-app-purchase.", "short_description": "An addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  This is a hand-tracking only experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.hypercreative.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "hyperCreative Games", "support_website_url": n