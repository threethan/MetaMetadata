384412267833293", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375766_384412271166626_2921541519922236002_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xFRq0oaIHO8Q7kNvgFADrmw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYA0t1XlD8mFVhJKMZvk_kl0tVWosYeWP74YZnVo0IjP7g&oe=66F3F2DE"}, {"file_name": "mel_lunarSync_2560.png", "id": "789872239248644", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974919_789872242581977_6372004608634830410_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-3Yf2RrGtEQ7kNvgEEFwF8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYAmxR1-S2Xr-LXLYvidstY7Olc-tnWNyHKVrEpDd_0msA&oe=66F3F083"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_2560.png", "id": "379905024899686", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001715_379905028233019_3723091916722888668_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2517EJ9DIQYQ7kNvgHubSat&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZryRWb7Mru-YfXoC8VPtQx&oh=00_AYAIRjAngYrqonl1n819RkPuvWRxQMmnFcD5CJG7-RtQkA&oe=66F40141"}, "display_name": "BubblePop! Rock Paper Scissors", "keywords": [], "long_description": "BubblePop! Rock Paper Scissors is an addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!   \n\nInstead of making the same gesture as the bubbles, you need to make the gesture that beats them.  You've known it since your childhood: Rock beats Scissors, Paper beats Rock, and Scissors beat Paper!  How fast can you move your hands?! \n\n This is a hand-tracking only experience.\n\nThe game includes 1 fantastic song that is free-to-play, with 5 difficulty levels (Baby, Easy, Normal, Hard, Crazy).  You can preview the 13 additional music tracks which are available as in-app-purchase.", "short_description": "An addictive Music Rhythm VR Game with a twist:  Use your hands to beat waves of bubbles with Rock, Paper, Scissors hand gestures!  Thi