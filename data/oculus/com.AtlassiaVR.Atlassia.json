.5771-25/38974450_1112008499901765_1042443027956768288_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_ukkXAqbBKoQ7kNvgHku6Yt&_nc_ht=scontent.oculuscdn.com&_nc_gid=At3TZk39kG7b93TyzrNQwVR&oh=00_AYB_DgUpQ-u0hfgl_0pbBNeLsQn93iuuWuz7rZmrbFf7Pw&oe=66EAB394"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Frame 53.png", "id": "485071047332515", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031564_485071050665848_6866340915274874641_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HVMEF9v3RNgQ7kNvgGzzLHU&_nc_ht=scontent.oculuscdn.com&_nc_gid=At3TZk39kG7b93TyzrNQwVR&oh=00_AYCRe38BM3LdGbfJwHJsFvzltS_zXAztDdwaF92gUpudOw&oe=66EAC476"}, "display_name": "ATLAS ENDGAMES", "keywords": ["free", "shooter", "battle", "royale", "fps"], "long_description": "# USE HIGH-POWERED ABILITIES \ud83d\udca5\nUnleash the power of 6 unique heroes and master 18 epic abilities, including drone piloting, portal teleportation, and grappling hooks. Master powerful abilities and become the ultimate champion.\n{440543928908440}\n\n# MASTER THE MOVEMENT SYSTEM \ud83d\udca8\nExperience next-level movement with wall runs, wall bounces, and infinite slides.\n{964672438686645}\n\n# EXPLORE A GIGANTIC MAP \ud83d\uddfa\ufe0f\nExplore a massive and wild environment of 1.5 square mile (4km\u00b2). Fight up to 39 players.\n{791130333148631}\n\n# FIGHT WITH POWERFUL WEAPONS \ud83d\udd2b\nArm yourself with 9 powerful sci-fi weapons and 6 types of grenades, all with realistic physics.\n{1135254451031064}\n\n# SURVIVE THE ARENA \u2694\ufe0f\nBattle in the arena (gulag) for a thrilling second chance to rejoin the match.\n{1524544925154847}\n\n# PILOT VEHICLES \ud83d\udef8\nSpeed through the game with fast, physics-based vehicles like the dropship or the hoverbike.\n{781170470826206}\n\n\n# YOU ARE THE NEW CHAMPION \ud83c\udfc6\nCelebrate your victories with friends as your opponents bow to your supremacy.\n{1011730990316459}\n\n\n\nThe most ruthless fighters in the galaxy are joining the battle royale.\nSome fight for glory, some for money, while others are only interested in revenge. But in the end, the only thing that matters is survival.\n\n\nDo you have what it takes to become the next champion of Atlas Endgames?\n\nAtlas Endgames is in early development but aims to become the ultimate next-gen battle royale experience. The game is receiving constant updates.\n\nJoin our Discord: https://discord.gg/BK5FUz5tGr", "short_description": "Next Generation Hero Battle Royale"}]}, "developer_name": "Atlas XR", "developer_privacy_policy_url": "https://www.atlasendgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Atlas XR", "support_website_url": "https://www.atlasendgames.com/contact", "website_url": "https://atlasendgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8086115761454480"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031606_508537521820977_2553418065210421640_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-UGo3i_3U38Q7kNvgGX9G3e&_nc_ht=scontent.oculuscdn.com&_nc_gid=At3TZk39kG7b93TyzrNQwVR&oh=00_AYCl_OP8thI2ZyA2sArz6jFbeNTs6f_4wSCvIoQutP_HFA&oe=66EAB00E"}, "is_concept": false, "is_test": false, "is_trial_off