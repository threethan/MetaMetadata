AvAhR5XWtF4pVRYV4XkAtKcQs0qKYx1_MQrRhjv2a_Uw&oe=66FE7480"}, {"file_name": "screenshot-4.png", "id": "2106168109764834", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982480_2106168116431500_8241958257704820129_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fIm65AH4lE0Q7kNvgF8xkPc&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9WRTY4TG2TGgL0b5bN6VuhhuITt_sq4b3CSgV6_hDOg&oe=66FE9807"}, {"file_name": "screenshot-5.png", "id": "877337387500712", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031462_877337390834045_922616176089092239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gqG5EA-iilcQ7kNvgGVxF_4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdLpUqCsKFJhQw4bdkVTcvZsggsbgYFGmsoBv_a3m5ew&oe=66FE7188"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Niloom Play", "keywords": [], "long_description": "With Niloom Play the VR projects you\u2019ve created on Niloom.ai are always available for you to enjoy. \nNiloom.ai harnesses Generative AI to make creating (VR) content affordable, fast, and without any coding required. \nWith features and functionalities designed for professional and casual creators alike!\nWith our GenAI, you can create entire projects in minutes vs months! \nWe\u2019ve made it easy with a single-sign-on, one-stop-shop, end-to-end solution.  \nNiloom.ai facilitates the creation of sophisticated, interactive, engaging VR content. We offer real time prototyping and editing, live collaboration, and instant publishing on Meta Quest (Oculus) via Niloom Play.", "short_description": "Niloom Play enables you to play and share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.niloom.ai/legal/privacy-policy", "developer_terms_of_service_url": "https://www.niloom.ai/legal/terms", "publisher_name": "Niloom.ai", "support_website_url": "https://www.niloom.ai/support", "website_url": "https://www.niloom.ai/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1063584910766706"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7625984540794453"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "749516777321222"}]}, "baseline_offer": {"id": "749516777321222"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715103060, "status": "PUBLISHED", "id": "749516777321222"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7882870928439145", "version": "1.4.5"}, "id": "1815445208975494", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7551547398238168", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7882870928439145"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1815445208975494"}]}, "change_log": null, "created_date": 1719441000, "id": "7882870928439145", "version": "1.4.5", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "_