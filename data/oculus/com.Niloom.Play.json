 share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.niloom.ai/legal/privacy-policy", "developer_terms_of_service_url": "https://www.niloom.ai/legal/terms", "publisher_name": "Niloom.ai", "support_website_url": "https://www.niloom.ai/support", "website_url": "https://www.niloom.ai/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1063584910766706"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7625984540794453"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "749516777321222"}]}, "baseline_offer": {"id": "749516777321222"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715103060, "status": "PUBLISHED", "id": "749516777321222"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7882870928439145", "version": "1.4.5"}, "id": "1815445208975494", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7551547398238168", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7882870928439