cdn.com/v/t64.5771-25/39031656_3253268851476796_71866378449033103_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vUJ95Wlgwc0Q7kNvgEHKH_9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0lEskaWz4QbV2G2J8qinkoWAsE_x3V-aNltgtc6r6DA&oe=675C0F00"}, {"file_name": "screenshot-4.png", "id": "2106168109764834", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982480_2106168116431500_8241958257704820129_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mhuqGXMqE44Q7kNvgGlGWjX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCq-x5g5BXYtVue7PYDlQn-JjV2pijCjx1XfPc8ixb6eA&oe=675C3287"}, {"file_name": "screenshot-5.png", "id": "877337387500712", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031462_877337390834045_922616176089092239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=on-ajtK5EGsQ7kNvgH0mrGB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYZavKp0L8q-0p6W5OKQzf3J6B0nl6r36Olvb2BDquJA&oe=675C0C08"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Niloom Play", "keywords": [], "long_description": "With Niloom Play the VR projects you\u2019ve created on Niloom.ai are always available for you to enjoy. \nNiloom.ai harnesses Generative AI to make creating (VR) content affordable, fast, and without any coding required. \nWith features and functionalities designed for professional and casual creators alike!\nWith our GenAI, you can create entire projects in minutes vs months! \nWe\u2019ve made it easy with a single-sign-on, one-stop-shop, end-to-end solution.  \nNiloom.ai facilitates the creation of sophisticated, interactive, engaging VR content. We offer real time prototyping and editing, live collaboration, and instant publishing on Meta Quest (Oculus) via Niloom Play.", "short_description": "Niloom Play enables you to play and share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "develo