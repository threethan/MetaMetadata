cdn.com/v/t64.5771-25/39031656_3253268851476796_71866378449033103_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A3W1qng-mSwQ7kNvgGwtTAC&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAdf56bPAWr6Nlj7dxAFniIUAKkxj33b7VRucT5YtMSPA&oe=67751B80"}, {"file_name": "screenshot-4.png", "id": "2106168109764834", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982480_2106168116431500_8241958257704820129_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kSKMJiuTcxsQ7kNvgEWwHRo&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA-dwhjqzWEjcRRQWd9Cih8BfNZ-sy59Dhyw4sFOpdNmw&oe=67753F07"}, {"file_name": "screenshot-5.png", "id": "877337387500712", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031462_877337390834045_922616176089092239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EN18lpeOR14Q7kNvgGR3lZy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBGeijbTLzHZ0GPoUUJ56Ok_LLQZpe3S9rC5KF4ihu_0Q&oe=67751888"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Niloom Play", "keywords": [], "long_description": "With Niloom Play the VR projects you\u2019ve created on Niloom.ai are always available for you to enjoy. \nNiloom.ai harnesses Generative AI to make creating (VR) content affordable, fast, and without any coding required. \nWith features and functionalities designed for professional and casual creators alike!\nWith our GenAI, you can create entire projects in minutes vs months! \nWe\u2019ve made it easy with a single-sign-on, one-stop-shop, end-to-end solution.  \nNiloom.ai facilitates the creation of sophisticated, interactive, engaging VR content. We offer real time prototyping and editing, live collaboration, and instant publishing on Meta Quest (Oculus) via Niloom Play.", "short_description": "Niloom Play enables you to play and share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "develo