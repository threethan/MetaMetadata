cdn.com/v/t64.5771-25/39031656_3253268851476796_71866378449033103_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8egq-Q9QjuMQ7kNvgGsW2d2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBGMOsQTGVg5RCSyQZSGMi4UmvhUQ4kSFgOOy-8SCrqlA&oe=67727880"}, {"file_name": "screenshot-4.png", "id": "2106168109764834", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982480_2106168116431500_8241958257704820129_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kSKMJiuTcxsQ7kNvgGmIOXf&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC3F4dMU0Nz1Pxly9mluTYTokGELvPUNX4QCNPfp-DLNw&oe=67729C07"}, {"file_name": "screenshot-5.png", "id": "877337387500712", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031462_877337390834045_922616176089092239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EN18lpeOR14Q7kNvgHdxdhB&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCsnwpCh4I-w1lo773VNJcfSmeBWCGh3lT4RQapt43GcQ&oe=67727588"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Niloom Play", "keywords": [], "long_description": "With Niloom Play the VR projects you\u2019ve created on Niloom.ai are always available for you to enjoy. \nNiloom.ai harnesses Generative AI to make creating (VR) content affordable, fast, and without any coding required. \nWith features and functionalities designed for professional and casual creators alike!\nWith our GenAI, you can create entire projects in minutes vs months! \nWe\u2019ve made it easy with a single-sign-on, one-stop-shop, end-to-end solution.  \nNiloom.ai facilitates the creation of sophisticated, interactive, engaging VR content. We offer real time prototyping and editing, live collaboration, and instant publishing on Meta Quest (Oculus) via Niloom Play.", "short_description": "Niloom Play enables you to play and share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "develo