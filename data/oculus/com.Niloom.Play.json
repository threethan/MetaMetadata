cdn.com/v/t64.5771-25/39031656_3253268851476796_71866378449033103_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RroUuBOVT7EQ7kNvgHBs8A4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUrny5GjtlqPjtO3J3GZqcxf2InnSR229xx3-MPDLyPQ&oe=672F3C00"}, {"file_name": "screenshot-4.png", "id": "2106168109764834", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982480_2106168116431500_8241958257704820129_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yM0rqSskgiAQ7kNvgGiXQ8k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXRw4vdGsWTmAhXDOSMXdOKXEJWcvAvg3K2T6cLbS7UQ&oe=672F5F87"}, {"file_name": "screenshot-5.png", "id": "877337387500712", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031462_877337390834045_922616176089092239_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qX_7CRIFaa0Q7kNvgG2C-l_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjAxlpQ2JfE7n4iYL8LuzyTwKLdc1EyKeVUvA94BrEuQ&oe=672F3908"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Niloom Play", "keywords": [], "long_description": "With Niloom Play the VR projects you\u2019ve created on Niloom.ai are always available for you to enjoy. \nNiloom.ai harnesses Generative AI to make creating (VR) content affordable, fast, and without any coding required. \nWith features and functionalities designed for professional and casual creators alike!\nWith our GenAI, you can create entire projects in minutes vs months! \nWe\u2019ve made it easy with a single-sign-on, one-stop-shop, end-to-end solution.  \nNiloom.ai facilitates the creation of sophisticated, interactive, engaging VR content. We offer real time prototyping and editing, live collaboration, and instant publishing on Meta Quest (Oculus) via Niloom Play.", "short_description": "Niloom Play enables you to play and share VR experiences created on your Niloom.ai desktop browser, on your favorite Meta Quest device. Join a community of VR creators, find and view other projects. "}]}, "develo