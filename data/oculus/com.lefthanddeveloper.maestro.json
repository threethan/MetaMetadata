ol the playback speed of your favorite tunes, transforming listening into an interactive and immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1EXl-W85yfBbQ9eMayAFARDxqwywHG_qa6eSY6SfNwW8/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "LefthandDeveloper", "support_website_url": null, "website_url": "https://www.youtube.com/@lefthanddeveloper1522", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}, {"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "800155698254750"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/427258303_797639589176499_852375665819285158_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PWc0z24SqxIQ7kNvgEM1EAL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbTO7S5V3G_3wsbbyRxTE0X&oh=00_AYC3ZcoXVnJy4F96eo7BIPPP-yRvWv2r8qDiKaJAvy40mQ&oe=66EFE5BB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Maestro", "platform": "ANDROID_6DOF", "context_category": {"context_category": "ENTERTAINMENT", "id": "2837265163266059"}, "context_topics": [{"topic_name": "Music", "id": "668538087410124"}, {"topic_name": "Dance", "id": "548013192910304"}, {"topic_name": "Experimental", "id": "541611600222565"}], "release_date": 1719878054, "lastRevis