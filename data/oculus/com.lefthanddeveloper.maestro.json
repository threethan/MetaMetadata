ments. Speed up the tempo by moving your hands faster or slow it down with gentle motions. The power of music is literally in your hands!", "short_description": "Experience music like never before with Maestro on Meta Quest! Use hand-tracking to control the playback speed of your favorite tunes, transforming listening into an interactive and immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1EXl-W85yfBbQ9eMayAFARDxqwywHG_qa6eSY6SfNwW8/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "LefthandDeveloper", "support_website_url": null, "website_url": "https://www.youtube.com/@lefthanddeveloper1522", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}, {"id": "541611600222565"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "800155698254750"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "510257978015046"}]}, "baseline_offer": {"id": "510257978015046"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719878054, "status": "PUBLISHED", "id": "510257978015046"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7934086813296961", "version": "0.1.5"}, "id": "336963871997076", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {