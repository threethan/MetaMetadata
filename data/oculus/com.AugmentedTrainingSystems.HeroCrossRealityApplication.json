Hero4.png", "id": "1264039787537482", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974497_1264039790870815_6975529274299971486_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gidsd7dng48Q7kNvgEquoPU&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYC4usfdUiPj2GhEkd21lWMua07HxkLZstQmPT5qf7OU7A&oe=6787B420"}, {"file_name": "ATSHero3.png", "id": "173908075472949", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031380_173908078806282_4502689455759437130_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Rznf3UX6DAQ7kNvgG4IPVn&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCB_jWQd-QUfcA3OkgRA4g1MwAoS2SclG4p0qCr21FLEA&oe=6787B374"}, {"file_name": "ATSHero6.png", "id": "550949040511942", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974594_550949047178608_2303221778975656937_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vu4AGbjgLXQQ7kNvgFWqBDR&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCSVfeKksv63O0jpWVTlwS1IL3W_9r02MB07xsbW-qJWA&oe=6787AD26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "1597402820780111", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974855_1597402824113444_300435938650011808_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VrPFaYjl_mIQ7kNvgE0Us7a&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYApUrsW2GH8Q2M_R4cCdU0RFqwBQ10uKZ6j-I0Roxnglg&oe=678793DB"}, "display_name": "ATS Hero", "keywords": [], "long_description": "The ATS Hero platform offers the opportunity for professionals in the field of medicine, emergency and rescue services, to get trained on the latest techniques and increase their preparedness from the comfort of their own home. The ATS complete solution provides an engaging, highly interactive, and fully immersive VR environment for remote and mobile training in a variety of response protocols like START Triage, SALT Triage, de-escalation tactics, amongst many other evidence-based strategies. Through the ATS Platform, you have a complete overview of your team\u2019s performance and engagement, on an individual and collective level. Take control of the intensity and the methodology of your team\u2019s training now, by choosing among ATS\u2019 s already implemented scenarios or by requesting your own tailored pipeline.\nCurrent version includes Mass Casualty Incident: First Responders, Mass Violence Event: Health Workforce Preparedness and others.\n \nBe the Hero people deserve.\nBe prepared with ATS.", "short_description": "The ATS Hero platform offers the opportunity for professionals in the field of medicine, emergency and rescue services, to get trained on the latest techniques of active protocols like START Triage, SALT Triage, de-escalation strategies from the comfort of their own home. \nBe the Hero people deserve.\nBe prepared with ATS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atshero.com/General/ATSMetaAppPrivacyPolicy", "developer_terms_of_service_url": "https://atshero.com/general/termofservice", "publisher_name": "Augmented Training Systems", "support_website_url": "https://www.augmentedtrainingsystems.com/", "website_url": "https://www.augmentedtrainingsystems.com/", "category": "APPS", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": ["EDUCATIONAL", "MEDICINE", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7847462535342537"