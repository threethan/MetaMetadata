84335476", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982555_1268408687668809_2405361608083290766_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZzLI1fZvWsQ7kNvgFUFQ3T&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAf52PoFS-WPu7unG1Eu8DJxeMFLJx7gri27Aj6dLbstQ&oe=671F7DE5"}, {"file_name": "5.png", "id": "1906231309875163", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974733_1906231313208496_142215447918733590_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-EQdVAM-h0sQ7kNvgEcxfwv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKrDFcelnX1a7ltrFn8TyqE5n-V24xX7NZ--NDUjK2rQ&oe=671F763C"}, {"file_name": "3.png", "id": "2465683403628345", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984439_2465683406961678_6853611002488330282_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4qFb3ChCDhMQ7kNvgGLzVIB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBaFztowkeGjs3iKK7R3Nc9iCP5B8WVxNlLMEEMZxDvWQ&oe=671F7EF5"}, {"file_name": "1.png", "id": "735556922030024", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572957_735556925363357_7903417601703436133_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i1AZ5viKBn4Q7kNvgG6ltmr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPaGMQUCIklnyfOjsSdEeh_3Evf3QoFn6waYUaDoRR3g&oe=671F7C07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "g\u00fcne\u015f m\u00fcziksiz.00_00_50_02.Still003.png", "id": "3517639078379983", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974502_3517639081713316_7505097868908417163_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6C6J82CXfl8Q7kNvgHlt8Pt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2po7F-SI7_ffSWlEouyVIu5_HjgLy3z2PLYUpI0dvyA&oe=671F7A20"}, "display_name": "Outlaw Clash", "keywords": ["SurvivalGameplay", "StrategicCombat", "Shotter", "Casual", "SinglePlayerAction"], "long_description": "Get ready for an adrenaline-pumping experience in Outlaw Clash, a thrilling action shooter set in the harsh, unforgiving desert. As a skilled gunslinger, you\u2019ll battle your way through dusty canyons and treacherous terrain, facing off against waves of enemies in a series of intense shootouts. Strategy is key\u2014use the environment to your advantage, find cover behind rocks and cacti, and time your shots to take down enemies before they get the drop on you.\n\nThe game offers fast-paced, dynamic combat that keeps you on your toes. With each victory, earn rewards to upgrade your weapons, improve your skills, and unlock new areas to explore. As you progress, you\u2019ll encounter tougher foes, requiring sharper reflexes and smarter tactics to survive. Whether you\u2019re dodging bullets or landing perfect headshots, the thrill of battle is always present.\n\nThe captivating visuals and atmospheric desert landscape immerse you in a world of danger and excitement. With easy-to-learn controls and progressively challenging levels, Outlaw Clash offers an engaging experience for both casual players and seasoned veterans alike. Will you rise to the challenge and become the ultimate outlaw, or fall to the dust? It's time to grab your guns and find out!", "short_description": "Step into the wild desert in Outlaw Clash, an action-packed shooter where you face off against dangerous enemies in a fight for survival. Navigate through rugged canyons, use cover strategically, and outsmart your foes. With intuitive controls, fast-paced combat, and challenging levels, you\u2019ll need quick reflexes and sharp aim to dominate the battlefield. Upgrade your weapons, unlock new areas, and prove you're the ultimate outlaw in this thrilling adventure!"}]}, "developer_name": "ESTI Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ESTI Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/outlaw-clash",