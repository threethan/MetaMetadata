 "427514907009812", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254872_427514910343145_3054424053283233515_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXEUzWZrfcEQ7kNvgELaeBn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYD4hd3I6503fSmWd077eQOHxcIsxATtWswmDrD4nIVgcQ&oe=66E97965"}, {"file_name": "resized_realistic_new_image_1440x1440.png", "id": "388825367350547", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982687_388825374017213_8280779461722903054_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eUwVa6SPWiAQ7kNvgFIGumX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYDv4_QkIK3J0n_tFnIxeWHYX8wfq9Zsv_-1eVqMhiRe8g&oe=66E95CAE"}]}, "id": "381284461514828", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "1076580287470361", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982672_1076580290803694_4044538395584871461_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VuTSDnKFfG8Q7kNvgHDYZME&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYCxcMbAERlseCKRCsbl59SVHPCRx-BTZ0heKW3LFT4lVQ&oe=66E97B7A"}, {"file_name": "2.png", "id": "1268408684335476", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982555_1268408687668809_2405361608083290766_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b3EWT0IHkC8Q7kNvgFSAPJO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYA97-JZTLcKOh5myI7didxplhfv7knr1N74MDVmr2a0HA&oe=66E97065"}, {"file_name": "5.png", "id": "1906231309875163", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974733_1906231313208496_142215447918733590_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mlTSySx-BucQ7kNvgFwV--S&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYAAUO3IxO1ltxvNLUF8SELKnMRCJ3RD3TGnBSy1h_UDhQ&oe=66E968BC"}, {"file_name": "3.png", "id": "2465683403628345", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984439_2465683406961678_6853611002488330282_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t887shwr9AQQ7kNvgFXTzka&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYBHJVPY-1IBhQ4d4N19cJz5yWrk00JGK4eRGQA8n9P3dA&oe=66E97175"}, {"file_name": "1.png", "id": "735556922030024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572957_735556925363357_7903417601703436133_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wf-At3DiWBgQ7kNvgHLKNg3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYCAD00lwfcG42Fd7KJgGZYENtL1ycMN1SjQKXJ4oxq2XA&oe=66E96E87"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "g\u00fcne\u015f m\u00fcziksiz.00_00_50_02.Still003.png", "id": "3517639078379983", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974502_3517639081713316_7505097868908417163_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2HsyGVMlfDgQ7kNvgGXwd6e&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeT7x1jteF8mvuOSlPjhR--&oh=00_AYDQL7GxxJ1yCTTn44oxwH43YuXivSxDDo1UX8J_7nUc5w&oe=66E96CA0"}, "display_name": "Rapid Fire", "keywords": ["SurvivalGameplay", "StrategicCombat", "Shotter", "Casual", "SinglePlayerAction"], "long_description": "Rapid Fire\" is an exhilarating, fast-paced single-player shooter that pushes the boundaries of action gaming. Set in a world where danger lurks around every corner, players must rely on quick reflexes, strategic thinking, and a diverse arsenal of weapons to survive. Whether you're a seasoned gamer or a newcomer to the genre, \"Rapid Fire\" offers a unique and challenging experience that keeps you on the edge of your seat from start to finish. In \"Rapid Fire,\" you take on the role of an elite operative in a dystopian world where chaos reigns supreme. Society has collapsed, and only the strongest survive. As a lone soldier, you are tasked with infiltrating enemy territory, dismantling dangerous factions, and uncovering the truth behind the destruction. Along your journey, you'll encounter hostile forces, treacherous environments, and hidden secrets that will test your resolve and skill.\n\n\"Rapid Fire\" combines fast-paced action with strategic gameplay, offering a variety of mechanics to keep players engaged. The core gameplay revolves around intense gunfights, where precision and timing are key. Players can switch between different weapons, each with its own strengths and weaknesses, and use a range of gadgets to gain the upper hand in battle. The game's difficulty scales with the player's progress, ensuring that every encounter is challenging yet rewarding.", "short_description": "Rapid Fire is a fast-paced single-player shooter that tests your reflexes and strategy. Battle waves of enemies, survive intense firefights, and progress through challenging levels. With enemies lurking around every corner, you must move swiftly, aim precisely, and take down your foes. Equipped with powerful weapons and upgrades, fight for victory in this adrenaline-pumping adventure. Can you be the last one standing?"}]}, "developer_name": "ESTI Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ESTI Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/rapid-fire", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "