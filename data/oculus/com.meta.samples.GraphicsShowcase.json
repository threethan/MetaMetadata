 subpass-based tone mapping solution that is much more performant than traditional techniques. \n\nPress B to cycle through these effects:\n- Day / Night cycle\n- Sepia LUT\n- Reddish LUT\n\nPress A to toggle tonemap subpass off / on\n\nPress Right Trigger to toggle FFR off / high\n\nPress Right Grip to toggle MSAA 1/2/4"}]}, "developer_name": "Oculus Samples", "developer_privacy_policy_url": "https://www.meta.com/legal/quest/privacy-policy/", "developer_terms_of_service_url": "https://www.meta.com/legal/quest/terms-of-service/", "publisher_name": "Meta", "support_website_url": null, "website_url": "https://developer.oculus.com/blog/graphics-showcase-using-vulkan-subpasses-in-ue4-for-performant-tone-mapping-on-quest/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "664036675178569"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974924_904267933926092_690880552232707673_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=onveUu7oBAwQ7kNvgE_wwoA&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYB3_OAOV_IkQu2qa0FTlDV0eIXXPXqKRe-hlyFXXFAlHw&oe=672A17FC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Graphics Showcase", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_top