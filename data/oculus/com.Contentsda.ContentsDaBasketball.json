content-iad3-1.oculuscdn.com/v/t64.5771-25/39003281_346432507926102_7841346697344394245_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bIDhm6fPqpoQ7kNvgGseGDl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDYF210x1EyY8iDXgVQwi0Syx8QYA7jPS8_3t_ENXUV1g&oe=673B219C"}, {"file_name": "08.screenshot2.png", "id": "344989248591152", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974901_344989251924485_5856208753044741210_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pxrMx592faMQ7kNvgFuMjv5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAP5BSrhaww_D4ILEBtOyvuz0LQ7rbEAxMPBm5pPGBp0A&oe=673B122B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "09.coverImage.png", "id": "394862783501752", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575348_394862786835085_5600026916114298015_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YpOJkSIUblkQ7kNvgF5-Ypx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrcxZu0g_vJMOyS9n_lD2Joq3rzqW6FDHLIwXBEXNvGw&oe=673B25FE"}, "display_name": "ContentsDa Basketball", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "It is a cognitive game for cognitive rehabilitation training to help rehabilitate people with cognitive decline and mild cognitive impairment, and is designed to provide two or more cognitive experiences and training in the game. Cognitive basketball game desig