c_ohc=zYGrYWJdFcwQ7kNvgFRhx1y&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC_4YGX9fGN5XrySc7l-LsLJ3TqFoM0oqKFaHUvVUw4ag&oe=67027B30"}, {"file_name": "migrated_image.png", "id": "550310465594032", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/12386356_842744735914187_2856744724671234048_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T0x-xDs-0zIQ7kNvgGvjigr&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDGRSI4KEVKHkvk7GT-3pi3OtVSSqe_7_t5j1T_A6243g&oe=67027BF5"}, {"file_name": "migrated_image.png", "id": "292177521766246", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/12139031_238438533382621_1651807863279976448_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bWMB03bll80Q7kNvgFv9qvT&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDhEqZKWbN13y4ql58wVyFeo6LJCo1KIsWEQkS4s1zn2A&oe=6702826C"}, {"file_name": "migrated_image.png", "id": "210413616851068", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/12448961_451462938622424_2552255934504108032_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QdB3FYrwkbkQ7kNvgHlZbGu&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDDhtTHmlhZJQ2LYZcY8DRb_65l2eYX64uQ-zBtTfcwDA&oe=67028088"}, {"file_name": "migrated_image.png", "id": "143878293646903", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/12331258_2126097634278627_4326513968228073472_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RBitNPSCYl8Q7kNvgFykVXG&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYASzLN-o80gCZ9D6s0ittPIh1Ja-3qACmQ8BGoZ8cwD7A&oe=670277F0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Belt Miners", "keywords": ["scifi", "space", "asteroid", "trek", "spaceship"], "long_description": "Welcome to the Utopia Arura mining ship Tau Ceti. Your overall mission is to mine asteroids for usable resources. Your commander is the android Io. She will brief you on missions and manage your progress.\n\nMissions:\n\u2022 Scan - Scan asteroids for valuable resources.\n\u2022 Deploy - Deploy mining rigs on asteroids.\n\u2022 Retrieve - Retrieve ore from asteroids to the ship.\n\u2022 Trade - Buy and sell ore on the market.\n\u2022 Maintain - Maintaining the ship.\n\nBelt Miners is a simulation game with the goal of providing a relatively accurate simulation of what it would be like to be an Asteroid Belt miner in the future.\n\nEngage in hours of sci-fi asteroid mining experiences in space with 70 missions, scanning asteroids, deploying rigs, retrieving ore, trading, and maintaining the spaceship.\n\nMade with Unity. Music by Stellardrone (ref. terms).\n\nTips:\n\u2022 Drag on the touchpad to walk and turn.\n\u2022 Gamepad: Press the A-button for instructions.\n\u2022 Gamepad (ship): Turn your head towards UI buttons to see the dot.", "short_description": "Welcome to the Utopia Arura mining ship Tau Ceti. Your overall mission is to mine asteroids for usable resources. Your commander is the android Io. She will brief you on missions and manage your progress."}]}, "developer_name": "GridSky Software A/S", "developer_privacy_policy_url": "http://gridsky.com/privacy-beltminers.html", "developer_terms_of_service_url": "http://gridsky.com/terms-bm.html", "publisher_name": "GridSky Software A/S", "support_website_url": null, "website_url": "http://beltminers.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "SIMULATION", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3171594003125289"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https:/