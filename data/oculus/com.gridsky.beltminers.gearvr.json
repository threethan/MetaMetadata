e.png", "id": "1477601252404229", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162702_1856178071378994_6921438521622265856_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8fcZaPx82YQ7kNvgE34_Iy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEPeB7Wxppmu0SYZ8Xessvwnw_2QSkGeEji1RmVq13uA&oe=66D845FD"}, {"file_name": "migrated_image.png", "id": "208127970393794", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162717_1627291597292111_6538379983448965120_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3BBsW8At5wUQ7kNvgF4KPfd&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQZs6ma53Ji6kX6ZvzSHbXvEwmgMYUsLHfij3QOh6NJg&oe=66D8317B"}, {"file_name": "migrated_image.png", "id": "566991347239342", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162694_1718437631521608_6094982192763502592_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_d8_g8lkzFsQ7kNvgH9Xp20&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNI7z7RDd4Ckcjef7XSn85Oyuvu45XB6HV07Wo8qfLaw&oe=66D83D05"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Belt Miners", "keywords": ["scifi", "space", "asteroid"], "long_description": "Welcome to the Utopia Arura mining ship Tau Ceti. Your overall mission is to mine asteroids for usable resources. Your mission commander is the android Pi. She will brief you on all missions and manage your progress.\n\nMissions:\n\u2022 Scan - Scan asteroids for valuable resources.\n\u2022 Deploy - Deploy mining rigs on selected asteroids.\n\u2022 Retrieve - Retrieve ore from asteroids to the main ship.\n\u2022 Trade - Buy and sell ore on the Belt Colony market.\n\u2022 Maintain - Various missions for maintaining the ship.\n\nBelt Miners is a simulation game with the goal of providing a relatively accurate simulation of what it would be like to be an Asteroid Belt miner in the future.\n\nEngage in hours of sci-fi asteroid mining experiences with 50 missions, scanning asteroids, deploying rigs, retrieving ore, trading, and maintaining the main ship.", "short_descriptio