LAnzhiAzrXVK8QcLUoQy_cW0xhd0GDvcxt4iq8UFw&oe=672A019D"}, {"file_name": "MonkiBusinessPage5.png", "id": "527828089905492", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031350_527828093238825_615326198620745687_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IVJ9yax8cuMQ7kNvgF_5Qxi&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAXOD0ruwcaHtQXDYlggBz45c3AZQMVmLp89M0HKxelNA&oe=672A06A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "GameplayTrailerThumbnail.png", "id": "401979989527888", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982491_401979992861221_8193102897001981962_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cULn_Bd0QtgQ7kNvgFkGfYY&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYClYc7uCztFwIcwvohzwncPNs9gLT51O4VDYQszgSKGpQ&oe=6729F6C0"}, "display_name": "Monki Business", "keywords": [], "long_description": "Run, climb, and jump in VR using a unique locomotion method that only needs the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off of surfaces to jump and squeeze them with both hands to climb.\n\nMonki Business provides two Gamemodes.\nCasual - No Tagging, just casually play the game with others in a Public or Private!\nLava Tag - Play Tag back and forth with two players, or play infection with up to 3 or more players! This works for both Public and Privates\n\nRun from the other Monkies, or outmaneuver the survivors to Tag them. Parkour up trees and cliff faces to avoid and chase other Monkies down. Hang out in a virtual jungle with randos or group up in a private room with friends to hang out and play. The stakes are low, so feel free to just chat or make up your own games. The movement is easy to learn, and hard to master.\n\nVisit our store in the Monki Shop, with a rotating inventory of items to buy, play with, and wear to express your true Monki.\n\nReturn to Monki.\n\n\nTerms and Service & Privacy Policy are listed below:\n\nTerms of Service: https://sites.google.com/view/monkibusiness/terms-of-service\n\nPrivacy Policy: https://sites.google.com/view/monkibusiness/privacy-policy", "short_description": "Run, climb, and jump in VR using a unique locomotion method that only needs the movement of your hands and arms. No buttons, no sticks, no teleportation. Push off of surfaces to jump and squeeze them with both hands to climb."}]}, "developer_name": "Bananaverse Studios", "developer_privacy_policy_url": "https://sites.google.com/view/monkibusiness/privacy-policy", "developer_terms_of_service_url": "https://sites.google.com/view/monkibusiness/terms-of-service", "publisher_name": "Zero", "support_website_url": null, "website_url": "https://sites.google.com/view/monkibusiness/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25835704039361470"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982486_1596562591133281_1313940139573391383_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ieOjGcMHKPsQ7kNvgFTFFCg&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBLEz4jB_nz3zE5DrJXNLniKHq7myTZZ420OIuivhoAjQ&oe=672A15E2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Monki Business", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "cont