al reality) maze game for Android mobile phone, where you should collect treasures while several creatures (Mummy, spider,...) try to catch and disturb you in a dark pyramid."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.lebersoftware.hu/policy-mazeofthemummy", "developer_terms_of_service_url": "http://www.lebersoftware.hu/", "publisher_name": "Leber software", "support_website_url": null, "website_url": "http://www.lebersoftware.hu/mazeofthemummy", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "478699536982922"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031407_978427999274599_164283158490928587_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=09CddHZgrigQ7kNvgEjzCvs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdrlEaE8koSt1pEV34b0mEW&oh=00_AYBDm1aHn7Y_23BShL6Oq3-p539VCQ6nxxi2K2Ez8S3Zsw&oe=66F40A46"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Maze Of The Mummy", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1503439523, "lastRevision": {"nodes": [{"id": "1444534248974969", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1427713014002514", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_c