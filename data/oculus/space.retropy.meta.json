cdn.com/v/t64.5771-25/39035399_3829319807386432_8697232045329718283_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YXbm2LpGScgQ7kNvgEn6rqU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQHT9QdLeZdMc8M09dC7cO7bS_Ysi5a6d_PUab2tDEWA&oe=6784E896"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LangScape.png", "id": "1950772375415851", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75207242_1950772378749184_9023911922798697221_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2AeTZUIolkwQ7kNvgH23Ol-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJhHQsIiXqp-Kh68wNaArfSj2FAH3vFU1cEbpEOh3RRQ&oe=6784EAE2"}, "display_name": "Retropy VR Puzzles", "keywords": ["puzzle", "retropy", "puzzling", "puzzles", "scan"], "long_description": "\ud83e\udde9 Become a Puzzle Master. With 16 base puzzles and free monthly content, you will never run out of satisfying 3D jigsaw puzzles to complete. Ranging from easy to complex, there are a variety of themes to enjoy. \n\n{963016575775248}\n\n\ud83e\udde9 Exercise Brain Health. It's no secret that daily puzzles improve brain health. Relax in a whole new world of oddities and detailed puzzles crafted for relaxation and to improve cognitive function. \n\n{1113800780393627}\n\n\ud83e\udde9 Customize Your Puzzle Space. Enjoy detailed objects in your choice of immersive VR environments, change the music from energetic to relaxing, and make it your own!", "short_description": "Retropy VR Puzzles brings you hours of relaxing 3D jigsaw puzzles  in an immersive VR or MR space. Enjoy 16 base puzzles and 2 - 3 puzzles added each month for FREE. \n\nRanging in difficulty from Easy to Hard, adjust the challenge to your comfort and unlock achievements as you complete each puzzle. \n\nFeatures:\n16 Detailed objects to puzzle\nUnique VR environments \nA variety of music \nConstant updates and free content \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://retropy.space/privacy", "developer_