unt": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7189995054371416", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8693604570677116"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733309440, "id": "8682177081819865", "version": "0.1.31", "version_code": 130, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7189995054371416", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8693604570677116"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "945785683870076"}]}, "change_log": "Perhaps the most powerful update we ever shipped with lots of exiting editing features!\n\nNew Features\n\n- Enhanced body rig system: Unified control of head and hands for Quest projects\n- Drag and drop objects in the hierarchy to change the parenting.\n- Collapse and expand hierarchy items.\n- Improved gizmo system with hover highlights for better stability and usability\n- The starting position of the device and body rig are automatically set when transitioning into a new state\n- Added tooltips functionality\n- New wireframe visualisation for environment when toggling physical occlusion\n- Various performance and stability improvements\n\nBug Fixes\n\n- Resolved undo/copy-paste issues\n- Fixed object behavior when modifying position with active lookat\n- Corrected iOS Mirror project switching bug\n- Improved Quest app stability and reduced crashes\n- Restored Blur material functionality in Editor and iOS (Quest still blocked)\n- Updated Occluder material to properly display environment objects as in passthrough\n\nAlways make sure to keep your editor and companion up to date to access new features.\n\nUpdates: macOS 0.1.5 (59) and Quest v0.1.30 (129)", "created_date": 1732210828, "id": "8615067561864151", "version": "0.1.30", "version_code": 129, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7189995054371416", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8693604570677116"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732196867, "id": "8613983585305882", "version": "0.1.30", "version_code": 128, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}