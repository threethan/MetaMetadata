utWZXD4&oh=00_AYCy9IkMN8sI7U2DEnebvIwqPh8Et5FJlbq9SfbDAo3wHg&oe=66EC09D4"}, {"file_name": "Novaris 2560x1440.png", "id": "432290762743892", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031465_432290769410558_4197845911567483928_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DVtma4Pb5vgQ7kNvgG-UpFm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJV6Sf44-HcYPfwsutWZXD4&oh=00_AYA_EoWtJYCuAdpEeV1Tx343odTkOusR6BvoR6s7EammNQ&oe=66EC18B4"}, {"file_name": "Eldoria 2560x1440.png", "id": "781496387307207", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86683380_781496390640540_6096652695932272831_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L2DJl2DPGcIQ7kNvgHTrTw-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJV6Sf44-HcYPfwsutWZXD4&oh=00_AYBYgpny0KvZy04ODLHmt8NNhg2Kx5ZOe8rUsjHlQqsOSA&oe=66EC2507"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Level - Tilted 2560x1440.png", "id": "465194612743524", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_465194616076857_3678342108930056417_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BSjZ9-_KKeoQ7kNvgGi1pEo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJV6Sf44-HcYPfwsutWZXD4&oh=00_AYD-4O_CHdIu5nTxPPGBWAh0dO1Xi84R6-ohvAO6f9qycQ&oe=66EC156C"}, "display_name": "Close Encounters", "keywords": [], "long_description": "Use your controller thumb sticks to deflect one or more balls to targets for collection.\n\nEach planet presents a challenging array of targets that must be collected to the waiting UFO above.\n\nPower-ups become available to assist in the collection process:\n- Extra Ball = Additional ball added to total balls available\n- Multi-Ball = Additional ball launched at location of power up\n- Power Ball = Blows through targets.  Lasts for 30 seconds.\n- Extra Time = Adds 60 to level timer\n\nBall speed increases and paddle size decreases as you progress through each challenge.\n\nPlay all 10 levels from start to finish to maximize your score to get on the leaderboard.\n\nPlay specific levels to