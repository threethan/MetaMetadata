, "screenshots": [{"file_name": "migrated_image.png", "id": "977544259309411", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427452_424268691238693_8115429551485485056_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ji4Yztz1tgoQ7kNvgE5BkGu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYC4zWtUQIs6GFlc0F94Y8W6QDhn8yIuEoZEmhvyJbjMAQ&oe=66EAAB12"}, {"file_name": "migrated_image.png", "id": "917947918663314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331159_165663800591924_7200677031552483328_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ynBrrtOHmyQQ7kNvgHwiKm8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYAAF8IT7o0hNjQC6wRf2OqRa212he-UUWH2fhEPa9Nwcg&oe=66EA9E20"}, {"file_name": "migrated_image.png", "id": "528781337780977", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427537_261622554275917_79703877070356480_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oPGbuDpAZ2EQ7kNvgEsarJD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYCL5Nyo8ddiOho7idxKeaKbRXg03iid9M0aA3fFVs6OTg&oe=66EACDE7"}, {"file_name": "migrated_image.png", "id": "220031429368502", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427528_1851908725034114_6034298380794986496_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vnqu1cVAl3UQ7kNvgGHu5Ny&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYA2uvrdQytqKL5hTZ0sRAqUdjCuugu1ePlZjwVNse1mgg&oe=66EAACB7"}, {"file_name": "migrated_image.png", "id": "208596977023371", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331145_1799651450359390_4608225979888828416_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=409RqhYW_PEQ7kNvgEtS65g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYBTj9ZicZbqyl-5puCvo-stqNG0mlRfQUx25qwMpDSJ8A&oe=66EAA410"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ZQBqMc", "id": "2252789435003606", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974741_2252789438336939_2727406148238966784_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LRI3ThEOOJMQ7kNvgHcZF3l&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYAtr6qArcNZygTq38pJjHxJ_givVdJUOniMAtRrSaYblw&oe=66EAA039"}, "display_name": "SkydiVeR", "keywords": ["skydiving", "flight", "parachuting", "airplane", "ocean"], "long_description": "\"All you need is 20 seconds of insane courage and I promise you something great will come of it\" - B. Mee \n\nSkydiVeR is the first parachuting simulator specifically made for VR. \nCollect your parachuting equipment and board the majestic Lockheed C-130 Hercules aircraft. \n\nLaunch into the sky and literally fly in this graphically stunning 3D environment, driven by a high fidelity physics based system, and land on a cargo ship in the middle of the Pacific Ocean. \n\nWill you be a SkydiVeR? Enjoy this breathtaking experience straight from your home!", "short_description": "\"All you need is 20 seconds of insane courage and I promise you something great will come of it\" - B. Mee \n\nSkydiVeR is the first parachuting simulator specifically made for VR.\nLaunch yourself into the sky like never before!"}, {"images": {"nodes": []}, "id": "545641982723769", "locale": "it_IT", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "SkydiVeR", "keywords": ["paracadutismo", "volo", "paracadute", "aereoplano", "oceano"], "long_description": "\"Tutto ci\u00f2 che serve sono 20 secondi di insano coraggio e ti prometto che qualcosa di incredibile ne verr\u00e0 fuori\" - B.Mee\n\nSkydiVeR \u00e8 il primo simulatore di paracadutismo specificamente pensato per VR. Raccogli l'equipaggiamento e sali a bordo del maestoso aereo Lockheed C-130 Hercules.\n\nLanciati nel cielo e letteralmente vola in questo ambiente 3D graficamente splendido, guidato da un sistema basato sulla fisica ad alta fedelt\u00e0, ed atterra su una nave cargo nel bel mezzo dell'oceano Pacifico.\n\nSarai uno SkydiVeR? Goditi questa esperienza mozzafiato direttamente da casa tua!", "short_description": "\"Tutto ci\u00f2 che serve sono 20 secondi di insano coraggio e ti prometto che qualcosa di incredibile ne verr\u00e0 fuori\" - B.Mee\n\nSkydiVeR \u00e8 il primo simulatore di paracadutismo specificamente pensato per VR.\nLanciati nel cielo come mai prima d'ora!"}]}, "developer_name": "KR Games", "developer_privacy_policy_url": "http://www.krgames.it/privacy-policy/", "developer_terms_of_service_url": "http://www.krgames.it/terms-of-service/", "publisher_name": "Star Consult S.r.L.", "support_website_url": null, "website_url": "http://www.krgames.it/en/games/skydiver", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "654528199030778"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974804_2211543949085126_1580146518629810176_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=69qBgo8y6OEQ7kNvgGP5jek&_nc_ht=scontent.oculuscdn.com&_nc_gid=AL6K9TZX8_b1dNBMCt0KeH3&oh=00_AYC2SZgDafIw2nzOfz2eJ-_fZKbx1mCqPpO1BdIWbmbBZA&oe=66EAA547"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SkydiVeR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1490166000, "lastRevision": {"nodes": [{"id": "1201711619920048", "release_type"