5_7382667924135071039_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T3xJIzaEY1sQ7kNvgGgI-LO&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDtuAWYrJl8I9vM61uURo8YyOWfGQZQ7cen_nfHjVYnTQ&oe=67165141"}, {"file_name": "Roomwrecker__0009_roomwrecker_screens__0011_2023-12-20-12-45-41.mp4.00_03_59_19.Still009.png", "id": "212208048606762", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/86663416_212208055273428_4657440962719506797_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FnrL6Zn0A0EQ7kNvgHp07Va&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCKvWyUZdmqrzIB6yA4MnTE9dGOEWCr1piMj-KkB_anaA&oe=671646DF"}, {"file_name": "Roomwrecker__0007_roomwrecker_screens__0064_2023-12-20-12-25-12.mp4.00_06_55_42.Still025.png", "id": "1095465124981353", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974777_1095465134981352_4573699081517061681_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0_1iragnsUcQ7kNvgFV7gmg&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAS5yb2g1qQbTgwhpIReV9Q5VYtqvQtegDUWzPCj7s6UQ&oe=67163617"}, {"file_name": "Roomwrecker__0000_roomwrecker_screens__0037_2023-12-20-12-45-41.mp4.00_02_34_39.Still034.png", "id": "287664217114570", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035326_287664220447903_3952348847953228022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ThK0JtqJc7YQ7kNvgHTSIk2&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYD_d1-jAwdroLWGxLC_h24lg6pSeAOUojgWWRSRkag66A&oe=67164A58"}, {"file_name": "roomwrecker_screens__0073_2023-12-20-12-25-12.mp4.00_08_18_27.png", "id": "891296669061553", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031588_891296679061552_3394896350236532114_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pU-FLH-xWF4Q7kNvgEUy8DQ&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCE03EIRU7vUSpGl99neOkDqD8WdRl7Ua1afABYCgqTHw&oe=6716382C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mrdigger_trailer_thumbnaIL_22.png", "id": "862518105372389", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031370_862518108705722_8194575130590500736_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-1w87GBqj1gQ7kNvgE5KEoZ&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAMFu0Pjo9AR9jus2l0lxvILb4xyYvy-7Q87pQ1f7sqXg&oe=671627B8"}, "display_name": "Cave Digger Room Wrecker", "keywords": ["cave", "digger", "mr", "mixed"], "long_description": "The early access version of the latest title in the Cave Digger franchise is now out for Meta Quest 3 and Meta Quest Pro!\n\nGo to the caves, scan the surroundings for hidden valuables, and dig them up with a pickaxe. Claim the loot with Loot Vacuum, keep thieves away from your hard-earned riches using a six-shooter, and return home to feed your pet Chompy the living treasure chest! As you feed it, it grows.\n\nCave Digger Room Wrecker, the third installment of the Cave Digger VR game series, takes a light-hearted, arcade, and whimsical approach to the franchise's world while taking advantage of the game-changing MR tech features found in the latest Quest device generation.\n\nSo, take your pickaxe, turn your home into a cave, and start looting while taking care of your own Chompy with the riches you discovered! Experience the wall and groundbreaking Mixed Reality gameplay in the long-standing franchise of Cave Digger!\n\nFor the latest updates, exclusive sneaky-peeks, and 24/7 Saloon talks (memes), join Cave Digger Discord community -> https://discord.com/invite/cavedigger\n\nAlso, check below the other titles in Cave Digger franchise:\n\n- Cave Digger is where it all started! Take your pickaxe and get to the train! For the stone and rock!\nwww.oculus.com/experiences/app/1551165681653074\n\n- The sequel Cave Digger 2 Dig Harder includes the first-ever crossplay at this scale: pretty much all platforms in both VR & standard gaming!\nwww.oculus.com/experiences/app/4687168774709280", "short_description": "Transform your room into a cave, meet your old friend Chompy the living treasure chest, and feed her the loot hidden in your walls. Scan the surroundings for hidden valuables, dig them out with a pickaxe, and keep thieves away from your hard-earned riches! Experience the wall and groundbreaking Mixed Reality gameplay in the long-standing franchise of Cave Digger!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VrKiwi", "support_website_url": null, "website_url": "https://vrkiwi.org/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26239224639057603"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39035326_899136281554377_2444438093766670979_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zlADNQLYPPQQ7kNvgEVlb-2&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBWYX2XVBlb_szr4Kq7xN5CC0Z7OuNgBp0R5NZCesmo-w&oe=6716430B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Cave Digger Room Wrecker", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Arcade", "id": "1592192974313