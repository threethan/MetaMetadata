iToQvDOEr4MYsLg&oe=66D85AC1"}, {"file_name": "Roomwrecker__0009_roomwrecker_screens__0011_2023-12-20-12-45-41.mp4.00_03_59_19.Still009.png", "id": "212208048606762", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86663416_212208055273428_4657440962719506797_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B_IUz7Z_DksQ7kNvgHFILoP&_nc_ht=scontent.oculuscdn.com&oh=00_AYCE1Vuip2AlJUon0sfuGdXYRU2VygfkmKk-CugvIM1cwg&oe=66D8505F"}, {"file_name": "Roomwrecker__0007_roomwrecker_screens__0064_2023-12-20-12-25-12.mp4.00_06_55_42.Still025.png", "id": "1095465124981353", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974777_1095465134981352_4573699081517061681_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wyxLPhzX1HUQ7kNvgHqaotM&_nc_ht=scontent.oculuscdn.com&oh=00_AYBD5MfWgzSTumVIqt4CQORl_NKuECYsOQBM-sPwCWkzFA&oe=66D83F97"}, {"file_name": "Roomwrecker__0000_roomwrecker_screens__0037_2023-12-20-12-45-41.mp4.00_02_34_39.Still034.png", "id": "287664217114570", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_287664220447903_3952348847953228022_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RzlTqf4povcQ7kNvgHFx4X7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAd39sq8UbTuHIAK1F-IsT_Se_OiRwbrkZY-c-kg4wmGQ&oe=66D853D8"}, {"file_name": "roomwrecker_screens__0073_2023-12-20-12-25-12.mp4.00_08_18_27.png", "id": "891296669061553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031588_891296679061552_3394896350236532114_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XxYTpMsQGuUQ7kNvgEDDqyk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBGSVQilZcLnSM0JK3lz9z9n2wTAdC3Sf5AAxBixK7RMg&oe=66D841AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mrdigger_trailer_thumbnaIL_22.png", "id": "862518105372389", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031370_862518108705722_8194575130590500736_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KcO7L9DtECUQ7kNvgHPCD0n&_nc_ht=scontent.oculuscdn.com&oh=00_AYAywZOGdnZR6EXQFu0pv4tM8eAMOieXlsQRgltfDUWyxw&oe=66D83138"}, "display_name": "Cave Digger Room Wrecker", "keywords": ["cave", "digger", "mr", "mixed"], "long_description": "The early access version of the latest title in the Cave Digger franchise is now out for Meta Quest 3 and Meta Quest Pro!\n\nGo to the caves, scan the surroundings for hidden valuables, and dig them up with a pickaxe. Claim the loot with Loot Vacuum, keep thieves away from your hard-earned riches using a six-shooter, and return home to feed your pet Chompy the living treasure chest! As you feed it, it grows.\n\nCave Digger Room Wrecker, the third installment of the Cave Digger VR game series, takes a light-hearted, arcade, and whimsical approach to the franchise's world while taking advantage of the game-changing MR tech features found in the latest Quest device generation.\n\nSo, take your pickaxe, turn your home into a cave, and start looting while taking care of your own Chompy with the riches you discovered! Experience the wall and groundbreaking Mixed Reality gameplay in the long-standing franchise of Cave Digger!\n\nFor the latest updates, exclusive sneaky-peeks, and 24/7 Saloon talks (memes), join Cave Digger Discord community -> https://discord.com/invite/cavedigger\n\nAlso, check below the other titles in Cave Digger franchise:\n\n- Cave Digger is where it all started! Take your pickaxe and get to the train! For the stone and rock!\nwww.oculus.com/experiences/app/1551165681653074\n\n- The sequel Cave Digger 2 Dig Harder includes the first-ever crossplay at this scale: pretty much all platforms in both VR & standard gaming!\nwww.oculus.com/experiences/app/4687168774709280", "short_description": "Transform your room into a cave, meet your old friend Chompy the living treasure chest, and feed her the loot hidden in your walls. Scan the surroundings for hidden valuables, dig them out with a pickaxe, and keep thieves away from your hard-earned riches! Experience the wall and groundbreaking Mixed Reality gameplay in the long-standing franchise of Cave Digger!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vrkiwi.org/what-vr/eula-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "VrKiwi", "support_website_url": null, "website_url": "https://vrkiwi.org/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26239224639057603"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_899136281554377_2444438093766670979_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ebTwpTwZm_IQ7kNvgGQ8WSd&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFrjZg-Qf0wvtgL4M6unZWQK1uQSentdGOAXL7hG_XKg&oe=66D84C8B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Cave Digger Room Wrecker", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1700690400, "lastRevision": {"nodes": [{"id": "9134489069957760", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "9134489056624428", "is_first_party": false