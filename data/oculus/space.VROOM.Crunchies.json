ng", "id": "899000051007330", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974572_899000054340663_4009189873311578622_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_f-68d8_8OgQ7kNvgHIZqUD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkfxB0uUDtEpjftnlhxj0RZ&oh=00_AYB1p-uisI_HjEjxXvN7UvUkT7acQiWnWdTFwbjXm59s1g&oe=66DEE9E7"}, {"file_name": "Screenshot (1).png", "id": "456576609187076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294240_456576612520409_2527700674419884251_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6HobTXh6n-oQ7kNvgHyWZij&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkfxB0uUDtEpjftnlhxj0RZ&oh=00_AYAoCKn1xJC509DfZhHRLCnB83EciRGunVMLu4mUxrHpkg&oe=66DEF37E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt Landscape.png", "id": "974255020135169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982595_974255023468502_7456919079283731752_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BnpTwj0xqzkQ7kNvgEfk5G2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkfxB0uUDtEpjftnlhxj0RZ&oh=00_AYD-nQNfwV5-mKPiyP9nGTOH6pB29ZzVjPzDgHnddXWJ8A&oe=66DEEA48"}, "display_name": "Crunchies", "keywords": [], "long_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life.\n\nCrunchies is an epic action-packed battle for survival aboard a restored Sherman tank as Hank and his crew struggle to survive a zombie apocalypse.\n\nKey Features:\n- Annihilate massive enemy hordes with superior firepower!\n- 16 exciting open environments to explore, chock-full of destructible objects!\n- Simplified controls: thumbstick drives, point to aim, trigger/grip fire cannon/machinegun.\n- Graphics that maximize your Quest's potential, plus tweakable settings for future headsets.\n- 4 levels of difficulty offer great replay value.\n", "short_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://crunchies.space/crunchies/privacy.aspx", "developer_terms_of_service_url": null, "publisher_name": "VROOM", "support_website_url": "https://crunchies.space/", "website_url": "https://crunchies.space/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "292393016380483"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1229567561301813"}, {"status": "PUBLISHED", "id": "517985879909234"}, {"status": "PUBLISHED", "id": "2588171291314157"}]}, "baseline_offer": {"id": "517985879909234"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725130800, "status": "PUBLISHED", "id": "1229567561301813"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5677008942326229", "version": "1.02"}, "id": "2053479558136141", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename"