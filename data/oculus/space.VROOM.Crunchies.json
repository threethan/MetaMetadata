r Quest's potential, plus tweakable settings for future headsets.\n- 4 levels of difficulty offer great replay value.\n", "short_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://crunchies.space/crunchies/privacy.aspx", "developer_terms_of_service_url": null, "publisher_name": "VROOM", "support_website_url": "https://crunchies.space/", "website_url": "https://crunchies.space/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "2691890164460465"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "292393016380483"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "3737722143224471"}, {"status": "PUBLISHED", "id": "1229567561301813"}, {"status": "PUBLISHED", "id": "517985879909234"}, {"status": "PUBLISHED", "id": "2588171291314157"}]}, "baseline_offer": {"id": "517985879909234"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728932400, "status": "PUBLISHED", "id": "3737722143224471"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_resu