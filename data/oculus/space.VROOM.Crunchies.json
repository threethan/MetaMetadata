c_gid=AxqooeE9rj_92nNL4fj-YLt&oh=00_AYAxDqRxRxt0EHUCm7MMunUdbUXk6VN3bwPULcEMu9Kfvw&oe=66F15EE7"}, {"file_name": "Screenshot (1).png", "id": "456576609187076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294240_456576612520409_2527700674419884251_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bB0VK7I6tAYQ7kNvgHuU5ns&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxqooeE9rj_92nNL4fj-YLt&oh=00_AYADn_aUNtoAAa2G52A-XMWsrDmKUi-TgJnF8naYjPhvDg&oe=66F1687E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt Landscape.png", "id": "974255020135169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982595_974255023468502_7456919079283731752_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lnkQJxu32T4Q7kNvgGroM8f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxqooeE9rj_92nNL4fj-YLt&oh=00_AYDPUmaXCr0iCL5pTsPBXRgt4gnCU0SHpzc6_SplbLYd-A&oe=66F15F48"}, "display_name": "Crunchies", "keywords": [], "long_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life.\n\nCrunchies is an epic action-packed battle for survival aboard a restored Sherman tank as Hank and his crew struggle to survive a zombie apocalypse.\n\nKey Features:\n- Annihilate massive enemy hordes with superior firepower!\n- 16 exciting open environments to explore, chock-full of destructible objects!\n- Simplified controls: thumbstick drives, point to aim, trigger/grip fire cannon/machinegun.\n- Graphics that maximize your Quest's potential, plus tweakable settings for future headsets.\n- 4 levels of difficulty offer great replay value.\n", "short_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://crunchies.space/crunchies/privacy.aspx", "developer_terms_of_service_url": null, "publisher_name": "VROOM", "support_website_url": "https://crunchies.space/", "website_url": "https://crunchies.space/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "686823405968454"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_279971887493564_3276505554297456841_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NpCnfNEUiS0Q7kNvgEMIGWt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxqooeE9rj_92nNL4fj-YLt&oh=00_AYDT9QFRscJBY6fjMxL2Y6Fg78ufEgDIiHXrl8xGDhXG8g&oe=66F15BE3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crunchies", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1649509200, "lastRevision": {"nodes": [{"id": "5371447802872137", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5386480711379055", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "443653730685619"}, "iarc_email": n