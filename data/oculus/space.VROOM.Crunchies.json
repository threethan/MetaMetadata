c_gid=AqswdynfNjbq3OwSi38EcI6&oh=00_AYCTibf0d4nfrgUoR-bNSrX7zXdAlHSzSlIWp8Oh76Ch8w&oe=66F401E7"}, {"file_name": "Screenshot (1).png", "id": "456576609187076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294240_456576612520409_2527700674419884251_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tUtrMdZmTrQQ7kNvgHit67x&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqswdynfNjbq3OwSi38EcI6&oh=00_AYAMWG5LReOlL4kv0pA_uSfclzCugkptnZ74fmfhwbi50w&oe=66F40B7E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt Landscape.png", "id": "974255020135169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982595_974255023468502_7456919079283731752_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fWWw4DI0QLsQ7kNvgHzLanr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqswdynfNjbq3OwSi38EcI6&oh=00_AYBEfmW_fG3zXJLn2JKgsvdOYo2sCBH85WFk8OkgSPbKJQ&oe=66F40248"}, "display_name": "Crunchies", "keywords": [], "long_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life.\n\nCrunchies is an epic action-packed battle for survival aboard a restored Sherman tank as Hank and his crew struggle to survive a zombie apocalypse.\n\nKey Features:\n- Annihilate massive enemy hordes with superior firepower!\n- 16 exciting open environments to explore, chock-full of destructible objects!\n- Simplified controls: thumbstick drives, point to aim, trigger/grip fire cannon/machinegun.\n- Graphics that maximize your Quest's potential, plus tweakable settings for future headsets.\n- 4 levels of difficulty offer great replay value.\n", "short_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire