dn.com/v/t64.5771-25/75294240_456576612520409_2527700674419884251_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QlskXodGxw4Q7kNvgGo-S9H&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqrA2Jf5kTkqxDVdeEnSO9NMac5K-TRtkgoSPyivXhsA&oe=670E697E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt Landscape.png", "id": "974255020135169", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982595_974255023468502_7456919079283731752_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nn4B9KCe-EwQ7kNvgEwBsUQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcu0kiGErSLFkwxw9wDeqU3HNXDjXzySQskzoo09RctQ&oe=670E6048"}, "display_name": "Crunchies", "keywords": [], "long_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life.\n\nCrunchies is an epic action-packed battle for survival aboard a restored Sherman tank as Hank and his crew struggle to survive a zombie apocalypse.\n\nKey Features:\n- Annihilate massive enemy hordes with superior firepower!\n- 16 exciting open environments to explore, chock-full of destructible objects!\n- Simplified controls: thumbstick drives, point to aim, trigger/grip fire cannon/machinegun.\n- Graphics that maximize your Quest's potential, plus tweakable settings for future headsets.\n- 4 levels of difficulty offer great replay value.\n", "short_description": "Fight to survive a zombie apocalypse: with a tank!  Experience the action-packed storyline with M4A3 Sherman \"Cherry Bomb\" and her stalwart crew.  Vaporize hordes of enemies with cannon-fire or crush them beneath steel treads!  A colorful cast of characters bring the adventure to life."}]}, "developer_name": null, "developer_privacy_policy_url": "https://crunchies.space/crunchies/privacy.aspx", "developer_terms_of_servic