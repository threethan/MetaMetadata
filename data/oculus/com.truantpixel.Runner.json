227523849_1958680144486627270_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=67KGT8hhekEQ7kNvgFk7CVM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A39L5UU1WZn93C9Jn3KGnjn&oh=00_AYAfWeFQFyoN-dXcyouMUNHMoT1v5J8impAgaPGQS5pgGQ&oe=66F14BC3"}, {"file_name": "sc_4.png", "id": "1239317000214777", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_1239317003548110_2822747083612760688_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7U-W_j64gjMQ7kNvgFNpLh2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A39L5UU1WZn93C9Jn3KGnjn&oh=00_AYCHPyOrqnrMh3wrUHvy16HFgMAEhJFpnEgd4L5VY4uY7Q&oe=66F14E09"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "3183829855264952", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294243_3183829858598285_4745021175035128889_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p0NGLsEUdYMQ7kNvgGqZgx7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A39L5UU1WZn93C9Jn3KGnjn&oh=00_AYBjIxHkewwifiS4DEBywFG2PV5AOFCMdKWsj3RSibKfDw&oe=66F16B5C"}, "display_name": "<RUNNER>", "keywords": ["Synthwave", "Anime", "Motorcycle", "Manga", "retro"], "long_description": "<RUNNER> features visceral first-person arcade driving combat that embraces the unique visual style of late 1980\u2019s prestige anime.\n\n\u204d Freeform 360-degree VR shooting\n\u204d Blisteringly fast motorcycle combat with full maneuvering control\n\u204d Unlockable bikes with unique attributes and abilities\n\u204d Intuitive gameplay with upgradeable sidearm mods\n\u204d Combine mounted gun upgrades to create unique weapons\n\u204d Utilize missiles and grenades as part of your arsenal\n\u204d Deflect incoming fire with the energy saber\n\u204d Execute time-bending special moves with R.U.S.H. mode\n\u204d 7 Procedurally-generated levels unique to every playthrough\n\u204d High-speed encounters with varied enemy types\n\u204d Chain together combos for massive scores\n\u204d Enormous and intense boss encounters\n\u204d Fully-voiced narrative single-player experience\n\u204d Featuring the voices of Steve Blum, Sandra Saad and Richard Epcar\n\u204d Accessibility and comfort modes for novice players\n\u204d Hidden achievements and global leaderboards\n\u204d Dynamic soundtrack by Fat Bard \n\n", "short_description": "<RUNNER> is an anime-inspired motorcycle action arcade game. Players take on the role of Mina, a rogue mod-courier at the center of a massive city-wide pursuit. Beginning in the heart of the Presidium, the neon-drenched capitol of the mining colony planet N-351, Mina\u2019s only means of escape is the \u201cThoroughfare,\u201d a massive highspeed expressway that snakes through the entirety sprawling colony complex. \n\nWhen there's nowhere left to hide, the only way out is through."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.truantpixel.com/privacypolicy2020.pdf", "developer_terms_of_service_url": null, "publisher_name": "Truant Pixel, LLC", "support_website_url": null, "website_url": "http://www.truantpixel.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "497554628610491"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PUBLISHED", "id": "1212389966467111"}, {"status": "PUBLISHED", "id": "1188692165602255"}, {"status": "PUBLISHED", "id": "962001512327833"}, {"status": "PUBLISHED", "id": "959082015295835"}, {"status": "PENDING", "id": "2542781532545187"}, {"status": "PUBLISH