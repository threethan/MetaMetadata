scontent.oculuscdn.com/v/t64.5771-25/75367586_1156233861628680_2894728255428788512_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=du3Q_iygwagQ7kNvgHozAIF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFasZhuuMo3LtqC5wJH9zyTMva3xiNMv-S6ZKS-wWDng&oe=66DDA0AE"}, {"file_name": "screen_B2.png", "id": "541312714424883", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036698_541312717758216_2711815540609582462_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q6YF7xjerYMQ7kNvgHEcsi2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBku50Sqr0v4uKzBpUdCCWAh0dkkDpzHPzJ6uayAXe9Og&oe=66DD8241"}, {"file_name": "screen_F.png", "id": "1802116610155078", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035330_1802116616821744_8345846180277977662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJNaa_0IdCkQ7kNvgEZwWvU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBX-nqlTvtRJl2ZZ5giL4MJZ0IbmIYzj3Hq-80BBXPw2g&oe=66DD88A1"}, {"file_name": "screen_D.png", "id": "669399220857183", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982466_669399227523849_1958680144486627270_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hAJb4X4_D2MQ7kNvgFnuMbD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCN4sskG84kwiYrnlXiNR_FVo_XMZL0edQDv6oXAqoatw&oe=66DD8543"}, {"file_name": "sc_4.png", "id": "1239317000214777", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568680_1239317003548110_2822747083612760688_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sRy4TXfPC4YQ7kNvgHd47T6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDyXcrkdtHlgS7OshEbwKexCuqYX8CRV9_7v_-ZAXmLVg&oe=66DD8789"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "3183829855264952", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294243_3183829858598285_4745021175035128889_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJ07sXn_wvEQ7kNvgFOi8Mt&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4TBEcBM0oMWGoTTUoID7-Obw3YG3gw4pj30TTj-uRIg&oe=66DDA4DC"}, "display_name": "RUNNER", "keywords": ["cyberpunk", "shooter", "arcade", "fighting", "action"], "long_description": "RUNNER features visceral first-person arcade driving combat that embraces the unique visual style of late 1980\u2019s prestige anime. Featuring high-speed combat, intense encounters and an incredible throwback soundtrack.\n\nWhen there's nowhere left to hide, the only way out is through.\n\n\u204d Freeform 360-degree VR shooting\n\u204d Blisteringly fast motorcycle combat with full maneuvering control\n\u204d Unlockable bikes with unique attributes and abilities\n\u204d Intuitive gameplay with upgradeable sidearm mods\n\u204d Combine mounted gun upgrades to create unique weapons\n\u204d Utilize missiles and grenades as part of your arsenal\n\u204d Deflect incoming fire with the energy saber\n\u204d Execute time-bending special moves with R.U.S.H. mode\n\u204d 7 massive levels unique to every playthrough\n\u204d 3 Additional bonus stages now available, with more to come\n\u204d Revisit stages at your leisure with the Level Select +\n\u204d Try 'Cruising' mode: just you, the music, and the road\n\u204d High-speed encounters with varied enemy types\n\u204d Chain together combos for massive scores\n\u204d Enormous and intense boss encounters\n\u204d Fully-voiced narrative single-player experience\n\u204d Featuring the voices of Steve Blum, Sandra Saad and Richard Epcar\n\u204d Multiple difficulty and comfort options\n\u204d Hidden achievements and global leaderboards\n\u204d Now Meta Quest 3 enhanced, featuring 2K native resolution.\n\u204d Features enhanced immersion with native bHaptics support\n\u204d Includes a dynamic high-speed soundtrack by Fat Bard \n\n\n", "short_description": "RUNNER is an anime-inspired motorcycle action arcade game. Players take on the role of Mina, a rogue mod-courier at the center of a massive city-wide pursuit. Beginning in the heart of the Presidium, the neon-drenched capitol of the mining colony planet N-351, Mina\u2019s only means of escape is the \u201cThoroughfare,\u201d a massive highspeed expressway that snakes through the entirety sprawling colony complex. \n\nWhen there's nowhere left to hide, the only way out is through."}, {"images": {"nodes": [{"file_name": "Logo_immersive.png", "id": "1317021395667036", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974875_1317021399000369_2769813411264470963_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=Pw2q44ig7uUQ7kNvgGqGn2u&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXJRbS7-z4paKKZN4USs4iSwr9M68EjSAeVyRPAAA79Q&oe=66DDA3EA"}, {"file_name": "backdrop_immersive.png", "id": "1229318405125805", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210393_1229318408459138_4846347856674865363_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUmT_Sw8x6IQ7kNvgFKloK3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBY8m13VePDu44TGEOtiaW0I76FjXpUefY9iwvcq_12Tg&oe=66DD8627"}, {"file_name": "landscape.png", "id": "1033659731216639", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031613_1033659734549972_7099219646918327941_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fMEeuLlb5y0Q7kNvgHs_TUB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDk8FjK-8BntFRFaZvvI7sNG19nQg18LCajAgyo7cr2_A&oe=66DD83F6"}, {"file_name": "immersive_left.png", "id": "1032806544605059", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035416_1032806547938392_2914311954028745326_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DjlyqM1Fxu0Q7kNvgFBvlJj&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5XBLifbqpHnjyqT3R649Cd9D0GV_8ckMx289FilyO5Q&oe=66DD720B"}, {"file_name": "Logo.png", "id": "943275807212922", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572927_943275810546255_7236572106514556660_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nu_KJKKzrwEQ7kNvgEjvHyl&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdzl0