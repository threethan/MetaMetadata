_name": "screen_E.png", "id": "1156233851628681", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367586_1156233861628680_2894728255428788512_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=19H2rueV8wYQ7kNvgHZaUvs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRmXIbVHQoMD3ylO1QQ92IjU2Uw7hZMT5kM4USb4Q7lg&oe=6703DC2E"}, {"file_name": "screen_B2.png", "id": "541312714424883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036698_541312717758216_2711815540609582462_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xglZTJ_liMMQ7kNvgFzQEHR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWKnqegkfTGUwjU4DRikAGuNA_0JQkKz5a0vN7bcsqnQ&oe=6703BDC1"}, {"file_name": "screen_F.png", "id": "1802116610155078", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035330_1802116616821744_8345846180277977662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1jIGEfEPFasQ7kNvgGIh7Lc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_awlgwpHddXKIhc7_wvD-XzOdTTXt3W578xIuTRNr0w&oe=6703C421"}, {"file_name": "screen_D.png", "id": "669399220857183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_669399227523849_1958680144486627270_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DTOsTmcY5OsQ7kNvgGsmo0P&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOowfl-tryjz4mV9kZUJ6mu8a32BMhbVr9QAZatKHt0Q&oe=6703C0C3"}, {"file_name": "sc_4.png", "id": "1239317000214777", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568680_1239317003548110_2822747083612760688_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EId7mqt_wqkQ7kNvgEWiDj8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOy7YcdDu1m1p6eJNAaE191SsyM4_p0THrpnY1jF3O2w&oe=6703C309"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "3183829855264952", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294243_3183829858598285_4745021175035128889_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d_YkD6jcci8Q7kNvgHgK0mp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbgMMTm4DclUCqLejDDyuB50pGazohVI44SfRz9A7zmw&oe=6703E05C"}, "display_name": "<RUNNER>", "keywords": ["Synthwave", "Anime", "Motorcycle", "Manga", "retro"], "long_description": "<RUNNER> features visceral first-person arcade driving combat that embraces the unique visual style of late 1980\u2019s prestige anime.\n\n\u204d Freeform 360-degree VR shooting\n\u204d Blisteringly fast motorcycle combat with full maneuvering control\n\u204d Unlockable bikes with unique attributes and abilities\n\u204d Intuitive gameplay with upgradeable sidearm mods\n\u204d Combine mounted gun upgrades to create unique weapons\n\u204d Utilize missiles and grenades as part of your arsenal\n\u204d Deflect incoming fire with the energy saber\n\u204d Execute time-bending special moves with R.U.S.H. mode\n\u204d 7 Procedurally-generated levels unique to every playthrough\n\u204d High-speed encounters with varied enemy types\n\u204d Chain together combos for massive scores\n\u204d Enormous and intense boss encounters\n\u204d Fully-voiced narrative single-player experience\n\u204d Featuring the voices of Steve Blum, Sandra Saad and Richard Epcar\n\u204d Accessibility and comfort modes for novice players\n\u204d Hidden achievements and global leaderboards\n\u204d Dynamic soundtrack by Fat Bard \n\n", "short_description": "<RUNNER> is an anime-inspired motorcycle action arcade game. Players take on the role of Mina, a rogue mod-courier at the center of a massive city-wide pursuit. Beginning in the heart of the Presidium, the neon-drenched capitol of the mining colony planet N-351, Mina\u2019s only means of escape is the \u201cThoroughfare,\u201d a massive highspeed expressway that snakes through the entirety sprawling colony complex. \n\nWhen there's nowhere left to hide, the only way out is through."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.truantpixel.com/privacypolicy2020.pdf", "developer_terms_of_service_url": null, "publisher_name": "Truant Pixel, LLC", "support_website_url": null, "website_url": "http://www.truantpixel.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "497554628610491"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PUBLISHED", "id": "1212389966467111"}, {"status": "PUBLISHED", "id": "1188692165602255"}, {"status": "PUBLISHED", "id": "962001512327833"}, {"status": "PUBLISHED", "id": "959082015295835"}, {"status": "PENDING", "id": "2542781532545187"}, {"status": "PUBLISHED", "id": "899541644693765"}, {"status": "PUBLISHED", "id": "313549744731760"}, {"status": "PENDING", "id": "1710683832710932"}, {"status": "PUBLISHED", "id": "1156675428340870"}, {"status": "PENDING", "id": "836465744788206"}, {"status": "PUBLISHED", "id": "517846576840283"}, {"status": "PUBLISHED", "id": "918857883250979"}, {"status": "PENDING", "id": "1315428569330031"}]}, "baseline_offer": {"id": "517846576840283"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1212389966467111"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24063032983341049", "version": "1.5"}, "id": "436245938217906", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_applica