e=6703DCC2"}]}, "id": "320823914026386", "locale": "en_US", "screenshots": [{"file_name": "screen_E.png", "id": "1156233851628681", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367586_1156233861628680_2894728255428788512_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=19H2rueV8wYQ7kNvgHZaUvs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRmXIbVHQoMD3ylO1QQ92IjU2Uw7hZMT5kM4USb4Q7lg&oe=6703DC2E"}, {"file_name": "screen_B2.png", "id": "541312714424883", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036698_541312717758216_2711815540609582462_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xglZTJ_liMMQ7kNvgFzQEHR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWKnqegkfTGUwjU4DRikAGuNA_0JQkKz5a0vN7bcsqnQ&oe=6703BDC1"}, {"file_name": "screen_F.png", "id": "1802116610155078", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035330_1802116616821744_8345846180277977662_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1jIGEfEPFasQ7kNvgGIh7Lc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_awlgwpHddXKIhc7_wvD-XzOdTTXt3W578xIuTRNr0w&oe=6703C421"}, {"file_name": "screen_D.png", "id": "669399220857183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_669399227523849_1958680144486627270_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DTOsTmcY5OsQ7kNvgGsmo0P&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOowfl-tryjz4mV9kZUJ6mu8a32BMhbVr9QAZatKHt0Q&oe=6703C0C3"}, {"file_name": "sc_4.png", "id": "1239317000214777", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568680_1239317003548110_2822747083612760688_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EId7mqt_wqkQ7kNvgEWiDj8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOy7YcdDu1m1p6eJNAaE191SsyM4_p0THrpnY1jF3O2w&oe=6703C309"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "3183829855264952", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294243_3183829858598285_4745021175035128889_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d_YkD6jcci8Q7kNvgHgK0mp&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbgMMTm4DclUCqLejDDyuB50pGazohVI44SfRz9A7zmw&oe=6703E05C"}, "display_name": "RUNNER", "keywords": ["cyberpunk", "shooter", "arcade", "fighting", "action"], "long_description": "RUNNER features visceral first-person arcade driving combat that embraces the unique visual style of late 1980\u2019s prestige anime. Featuring high-speed combat, intense encounters and an incredible throwback soundtrack.\n\nWhen there's nowhere left to hide, the only way out is through.\n\n\u204d Freeform 360-degree VR shooting\n\u204d Blisteringly fast motorcycle combat with full maneuvering control\n\u204d Unlockable bikes with unique attributes and abilities\n\u204d Intuitive gameplay with upgradeable sidearm mods\n\u204d Combine mounted gun upgrades to create unique weapons\n\u204d Utilize missiles and grenades as part of your arsenal\n\u204d Deflect incoming fire with the energy saber\n\u204d Execute time-bending special moves with R.U.S.H. mode\n\u204d 7 massive levels unique to every playthrough\n\u204d 3 Additional bonus stages now available, with more to come\n\u204d Revisit stages at your leisure with the Level Select +\n\u204d Try 'Cruising' mode: just you, the music, and the road\n\u204d High-speed encounters with varied enemy types\n\u204d Chain together combos for massive scores\n\u204d Enormous and intense boss encounters\n\u204d Fully-voiced narrative single-player experience\n\u204d Featuring the voices of Steve Blum, Sandra Saad and Richard Epcar\n\u204d Multiple difficulty and comfort options\n\u204d Hidden achievements and global leaderboards\n\u204d Now Meta Quest 3 enhanced, featuring 2K native resolution.\n\u204d Features enhanced immersion with native bHaptics support\n\u204d Includes a dynamic high-speed soundtrack by Fat Bard \n\n\n", "short_description": "RUNNER is an anime-inspired motorcycle action arcade game. Players take on the role of Mina, a rogue mod-courier at the center of a massive city-wide pursuit. Beginning in the heart of the Presidium, the neon-drenched capitol of the mining colony planet N-351, Mina\u2019s only means of escape is the \u201cThoroughfare,\u201d a massive highspeed expressway that snakes through the entirety sprawling colony complex. \n\nWhen there's nowhere left to hide, the only way out is through."}, {"images": {"nodes": [{"file_name": "Logo_immersive.png", "id": "1317021395667036", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974875_1317021399000369_2769813411264470963_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=Z3yhmX-0CAkQ7kNvgH6ae3q&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdJeblD0xSnULjsRmUcLfDw0iouEtGhLJ0zaFv_N7VIA&oe=6703DF6A"}, {"file_name": "backdrop_immersive.png", "id": "1229318405125805", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210393_1229318408459138_4846347856674865363_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ITWi1Ibvfz4Q7kNvgGAXR3K&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDs6_h51uCPfiXgTEfIoanygEER1dnoQN4F1i9Fq4YRyw&oe=6703C1A7"}, {"file_name": "landscape.png", "id": "1033659731216639", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031613_1033659734549972_7099219646918327941_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jz5Te5vI644Q7kNvgFmTloL&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDt2ruq-JFEeG33b5QldeLPsvLbI3MydAUOsrgDw6Dt6w&oe=6703BF76"}, {"file_name": "immersive_left.png", "id": "1032806544605059", "image_type": "APP_IMG_IMMERSIVE_LAYER_OBJECT_LEFT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035416_1032806547938392_2914311954028745326_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NrXo5YxtzzMQ7kNvgFvC8Td&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBrtIkibVU4soFXGE6w7mbIlqmusJSoihDb7xjqhD53Ew&oe=6703AD8B"}, {"file_name": "Logo