18_307582657943088676_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y7RD2x_xG9IQ7kNvgEetCBm&_nc_ht=scontent.oculuscdn.com&oh=00_AYDexKATxw0aaj1MY5YiKxo_eIU0YdDaWEHjGkNkolxz9Q&oe=66CC6B82"}, {"file_name": "Thumbnail v4.png", "id": "1602989480245946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982646_1602989483579279_4751523469378912253_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PdxoAnwSV6UQ7kNvgGbA1uc&_nc_ht=scontent.oculuscdn.com&oh=00_AYASTaimyGsiRs8eLHfcz0SkvPS61Ymnivfo3Jf9ux1Z8Q&oe=66CC5D8F"}, {"file_name": "Thumbnail v5.png", "id": "512101907858770", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568672_512101914525436_2620631732554717966_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SF-6AiULbTwQ7kNvgGBG5hN&_nc_ht=scontent.oculuscdn.com&oh=00_AYB8HranPQFiZfQADbuTniZ0SQg8IhYn_KyTKmp1TxgKeg&oe=66CC7B5D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1155860682370660", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245821_1155860685703993_2941264832331171296_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qOM39rCsU9kQ7kNvgGohZJe&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaHNM6R1B1QB4Gm7gu18s1foyX_t8SXxeGxKMthfr1ew&oe=66CC68AA"}, "display_name": "The Floor Is Lava", "keywords": [], "long_description": "Do you like action, trolling, fighting or just playing a challenging game? Well, then this is the perfect game for you! This game utilizes your hands to climb, grab, and swing around the map to avoid the rising lava. The game Is compact with features, Ropes, Ziplines, fighting and so much more. Avoid the lava in many different maps. Become the best in the world by being on top of the global leaderboard. Meet the other contestants, fight them, or team up. There is no mercy in this game. Their blood is on your hands.", "short_description": "Floor Is Lava is a fun, competitive game that will make your blood boil. Play different maps. Troll your friends. This game utilizes your hands to grab, climb, and swing around the map to avoid the lava. Become the best in the world by being on top of the global leaderboard."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1xVz06lnxs8s3oY1Fdzr52PsSjv1PO3HbM_uVrBrHiDo/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Turkey", "support_website_url": null, "website_url": "https://sites.google.com/view/official-great-apes-site/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1573854509480616"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7900474150038303"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "847716006864901"}]}, "baseline_offer": {"id": "847716006864901"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723227265, "status": "PUBLISHED", "id": "847716006864901"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7534425203309868", "version": "0.0.1"}, "id": "357279107289225", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7336440866441637", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7534425203309868"}, "release_status": "RELEASED"