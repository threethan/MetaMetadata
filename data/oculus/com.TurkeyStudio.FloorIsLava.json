5436_2620631732554717966_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DTgASzlCizwQ7kNvgF8r3j6&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBO7me4yMbukYqn8r_gHJ67WTbVMNkUX-goWv8uNp9wbg&oe=6728C45D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Thumbnail.png", "id": "1155860682370660", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75245821_1155860685703993_2941264832331171296_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X0mTVeVYnV8Q7kNvgG2wx9H&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYD7rHgj0L7p8MhV5w6XaVEbZgeaULKCGc9643Pe5EBrbw&oe=6728B1AA"}, "display_name": "The Floor Is Lava", "keywords": [], "long_description": "Do you like action, trolling, fighting or just playing a challenging game? Well, then this is the perfect game for you! This game utilizes your hands to climb, grab, and swing around the map to avoid the rising lava. The game Is compact with features, Ropes, Ziplines, fighting and so much more. Avoid the lava in many different maps. Become the best in the world by being on top of the global leaderboard. Meet the other contestants, fight them, or team up. There is no mercy in this game. Their blood is on your hands.", "short_description": "Floor Is Lava is a fun, competitive game that will make your blood boil. Play different maps. Troll your friends. This game utilizes your hands to grab, climb, and swing around the map to avoid the lava. Become the best in the world by being on top of the global leaderboard."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1xVz06lnxs8s3oY1Fdzr52PsSjv1PO3HbM_uVrBrHiDo/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Turkey", "support_website_url": null, "website_url": "https://sites.google.com/view/official-great-apes-site/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"},