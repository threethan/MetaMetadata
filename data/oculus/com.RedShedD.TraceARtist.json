A0A2"}, {"file_name": "Dislay Image Controlls Showcase 1440p.png", "id": "506325961942843", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035440_506325965276176_5750312318943529827_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mbweNiFtSP0Q7kNvgG3B1mz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0JGJuClomyk-LV6H3f326VcNQu9UmJN5g7yl27lNspg&oe=6745CB1F"}, {"file_name": "Display Image Results Comparison 1440p.png", "id": "857984372922092", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974695_857984376255425_2790413782976331108_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_wwLYhgZtaUQ7kNvgFqbNAe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZIMj2bxyDeyl9nFYovMGRLjLq57V1xCgRgDZ-aOhhOw&oe=6745CDF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "taVideoCoverImage.png", "id": "429078766875890", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035376_429078770209223_1902136036190637908_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUJEuTdmvo4Q7kNvgHik2f6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4hACO6ZQLMn6iHs4OCp0H0VCyfskNJ1ol_MaNz5mrtw&oe=67459CAD"}, "display_name": "TraceARtist", "keywords": ["tracing", "drawing", "ar", "learn"], "long_description": "\nTraceARtist is an augmented reality application for Meta Quest 3 that overlays images onto the user's physical environment for tracing purposes.\nUsers can trace these digital images directly on paper or other drawing surfaces.\nThe app offers both pre-loaded image categories and support for custom uploads, providing a versatile digital reference tool for artists.\n# Key features include:\n\n- **Diverse image sources**: pre-loaded collections with high quality images in lossless SVG format (famous paintings, architecture/castles, animals), and support for custom uploads\n- **Spatial anchoring** for consistent image placement\n- **Environmental integration** with shadow rendering and collision detection\n- **Drawing assistance tools**: opacity adjustment, desk calibration, and intuitive image manipulation\n\nTraceARtist is optimized for Meta Quest 3, offering native resolution support and a responsive AR environment. It accommodates artists of all skill levels, from beginners to experienced professionals.\n\nFor technical support or inquiries: \n\ntraceartistapp@gmail.com\n", "short_description": "TraceARtist is a Meta Quest 3 app that overlays digital images onto real-world surfaces for direct paper drawing. This AR tool bridges traditional techniques with mixed reality, helping artists of all levels enhance their skills through digital-to-physical creation."}]}, "developer_name": "RedShedD", "developer_privacy_policy_url": "https://traceartist.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "RedShedD", "support_website_url": null, "website_url": "https://traceartist.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8840151726043676"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035448_1520655638822366_6998324515052376060_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gVWB1Eq-lG8Q7kNvgHbGKkU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6LkyRd-dr-3zFCQCytAwgLre-G96qelhYV_32VlfRLw&oe=6745A475"}, "is_concept": false