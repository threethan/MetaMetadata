ts": [{"file_name": "Display Image Castle Unfinished 1440p.png", "id": "379564291829112", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982719_379564295162445_4209363066835316117_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LmWNF0HGzNIQ7kNvgHkldBH&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAle9wVvQoRIVAIag7K-2uGE6pVBSmAEYk33UvvQLofRg&oe=670FBF19"}, {"file_name": "Display Image UI Showcase 1440.png", "id": "1194483065030514", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003251_1194483068363847_1993841801514370982_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=241ZMx7MJZoQ7kNvgG-ekQ8&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC-f5QTQUABwIzwAVL4gKUSDKIUDd2H-biCa9fjQSuaig&oe=670F9E51"}, {"file_name": "Display Image Spatial Integration 1440p.png", "id": "856226899378119", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031367_856226902711452_9038896631676001597_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSbxwb6dxAUQ7kNvgGHV3S8&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCDxYTnrXE8wY6QznjJjWdOWNG7c6bItPR0nrOXuAkEEw&oe=670FB90D"}, {"file_name": "Dislay Image Controlls Showcase 1440p.png", "id": "506325961942843", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035440_506325965276176_5750312318943529827_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vUhWo1G8-2IQ7kNvgGOArK4&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBEsKizeSG_vX7tC4LMdC9RJNLv0-waqiPWaAM5JrlHOg&oe=670FBD9F"}, {"file_name": "Display Image Results Comparison 1440p.png", "id": "857984372922092", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974695_857984376255425_2790413782976331108_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l8FYaAE39vUQ7kNvgF3Go8w&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD83uXIxjQvNU5ZsDn4uvNp8B6tZ7HJ71KpzBlkCNflxA&oe=670F8835"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TraceARtist", "keywords": ["tracing", "drawing", "ar", "learn"], "long_description": "\nTraceARtist is an augmented reality application for Meta Quest 3 that overlays images onto the user's physical environment for tracing purposes.\nUsers can trace these digital images directly on paper or other drawing surfaces.\nThe app offers both pre-loaded image categories and support for custom uploads, providing a versatile digital reference tool for artists.\n# Key features include:\n\n- **Diverse image sources**: pre-loaded collections with high quality images in lossless SVG format (famous paintings, architecture/castles, animals), and support for custom uploads\n- **Spatial anchoring** for consistent image placement\n- **Environmental integration** with shadow rendering and collision detection\n- **Drawing assistance tools**: opacity adjustment, desk calibration, and intuitive image manipulation\n\nTraceARtist is optimized for Meta Quest 3, offering native resolution support and a responsive AR environment. It accommodates artists of all skill levels, from beginners to experienced professionals.\n\nFor technical support or inquiries: \n\ntraceartistapp@gmail.com\n", "short_description": "TraceARtist is a Meta Quest 3 app that overlays digital images onto real-world surfaces for direct paper drawing. This AR tool bridges traditional techniques with mixed reality, helping artists of all levels enhance their skills through digital-to-physical creation."}]}, "developer_name": "RedShedD", "developer_privacy_policy_url": "https://traceartist.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "RedShedD", "support_website_url": null, "website_url": "https://traceartist.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRE