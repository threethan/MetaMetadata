068363847_1993841801514370982_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pCr56aykN50Q7kNvgHTCUCX&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6yA6z_l_IrK_IKFVMVviVf9GdJ5aN2dCzeBVqvW9FYQ&oe=66EEA8D1"}, {"file_name": "Display Image Spatial Integration 1440p.png", "id": "856226899378119", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031367_856226902711452_9038896631676001597_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jmfdjt_XfckQ7kNvgG0eu6u&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8-lsokCelrEJzQcURPs3sD0tjuqwChIyL4GAXnP0nuw&oe=66EEC38D"}, {"file_name": "Dislay Image Controlls Showcase 1440p.png", "id": "506325961942843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035440_506325965276176_5750312318943529827_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ADY8XmpwF7UQ7kNvgG4OvyQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgDBPTGixnKLlraUAS0f_qAd-aJ_4LKext3S6hdTqkUg&oe=66EE8FDF"}, {"file_name": "Display Image Results Comparison 1440p.png", "id": "857984372922092", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974695_857984376255425_2790413782976331108_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kdU0PgILtikQ7kNvgEsdWfH&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5StPujQtITvIQHutNJe-bGnQOTennl_raTC-lewJ0kA&oe=66EE92B5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TraceARtist", "keywords": ["tracing", "drawing", "ar", "learn"], "long_description": "\nTraceARtist is an augmented reality application for Meta Quest 3 that overlays images onto the user's physical environment for tracing purposes.\nUsers can trace these digital images directly on paper or other drawing surfaces.\nThe app offers both pre-loaded image categories and support for custom uploads, providing a versatile digital reference tool for artists.\n# Key features include:\n\n- **Diverse image sources**: pre-loaded collections with high quality images in lossless SVG format (famous paintings, architecture/castles, animals), and support for custom uploads\n- **Spatial anchoring** for consistent image placement\n- **Environmental integration** with shadow rendering and collision detection\n- **Drawing assistance tools**: opacity adjustment, desk calibration, and intuitive image manipulation\n\nTraceARtist is optimized for Meta Quest 3, offering native resolution support and a responsive AR environment. It accommodates artists of all skill levels, from beginners to experienced professionals.\n\nFor technical support or inquiries: \n\ntraceartistapp@gmail.com\n", "short_description": "TraceARtist is a Meta Quest 3 app that overlays digital images onto real-world surfaces for direct paper drawing. This AR tool bridges traditional techniques with mixed reality, helping artists of all levels enhance their skills through digital-to-physical creation."}]}, "developer_name": "RedShedD", "developer_privacy_policy_url": "https://traceartist.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "RedShedD", "support_website_url": null, "website_url": "https://traceartist.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8230528547006000"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "509907201627982"}]}, "baseline_offer": {"id": "509907201627982"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723759140, "status": "PUBLISHED", "id": "509907201627982