8t1mScdZUa1l84vKHvFtIZhb4gNOwNg&oe=672C935C"}, {"file_name": "Screenshot 1.png", "id": "3764282367140241", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75608443_3764282370473574_1005041458116167541_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OKS2tx4RUlUQ7kNvgEOvY_2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMwTEyoOhI9X8K7l5NcaW7CY2CCj0kciTQbR2viflpRA&oe=672CB7FF"}, {"file_name": "Screenshot 3.png", "id": "1075269113692064", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982530_1075269117025397_6447006048606872967_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e6EXsnSfVU4Q7kNvgGfv3rf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAdwSG3zh2mqAIH_nAEe26TbqDGvod5wiWv48T3mS_LlQ&oe=672C9D51"}, {"file_name": "Screenshot 5.png", "id": "401946459048030", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974744_401946462381363_835392156508568465_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MchVli8egJYQ7kNvgHviCwG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJbhNiuFuqRRQ7CbepvqecA3Lcp0-vRypcZv6yMUxuWA&oe=672CB0A9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "AU Text  2560x1440 Format.png", "id": "706845304976591", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036616_706845308309924_8280624660867497005_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=npOEtR-F1ewQ7kNvgE6Xco6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1WyyI6256i_oc32-jS4ARiQpeBs5SWflxhcVVa9ljQQ&oe=672C92DA"}, "display_name": "Ancients Unleashed", "keywords": [], "long_description": "You\u2019ve been slighted for the last time.\n\nMinor demi-god or not, why should the fools on Olympus get all the praise, all the glory...and all the gold and virgins?\n \nCenturies ago, it is said Zeus stripped the divine essence from all of the gods, consolidating the Pantheon\u2019s power under his grasp.\n\nSince then, the balance of the universe has been lost with no one to challenge the Great God\u2019s will or temper his petty whims. It\u2019s time for that to change. \n\nBut to overthrow the godhead, you must amass your own power. Topple the great Titans, \ndestroy the vile demi-gods and slaughter mass hordes to challenge Olympus. For the sake of mortals and gods alike.\n\nWill you fulfill your destiny?", "short_description": "Immerse yourself in a relentless battleground of mythical hordes, divine chaos and epic landscapes. Challenge heroes to gain skills, hone divine powers and take your seat as a god.  Will you rise to the occasion, chosen one? Your odyssey has only just begun."}]}, "developer_name": "Avrio Analytics", "developer_privacy_policy_url": "https://retrogodz.com/privacy-policy", "developer_terms_of_service_url": "https://retrogodz.com/user-license-agreement", "publisher_name": "RetroGodz", "support_website_url": null, "website_url": "https://www.retrogodz.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7562835923768136"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2733781486779203"}, {"status": "PUBLISHED", "id": "1136868027681886"}]}, "baseline_offer": {"id": "2733781486779203"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712785380, "status": "PUBLISHED", "id": "2733781486779203"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"_