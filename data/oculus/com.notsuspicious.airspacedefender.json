=1-7&_nc_sid=6e7a0a&_nc_ohc=Hk32S1CciiwQ7kNvgEvCvpI&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDk7rlbuqze9HHCGdSyahCk43WfjNPy_tsnuFoD_FvPzQ&oe=6728BD6B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Airspace Defender Cover.png", "id": "517110117410509", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/39031602_517110120743842_3140714957862057636_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XyptU1Hf1HAQ7kNvgG-Uym5&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAN3JZtxTnxgqoUM4xW7XeRlV-T29zvYzrpWL5qGVj79w&oe=6728B949"}, "display_name": "Airspace Defender", "keywords": ["tabletop", "arcade", "shooter", "retro", "combat"], "long_description": "# ENTER THE WAR ROOM\nDefend your airspace in thrilling tabletop mixed reality!\n\nManage your city's defenses and protect your citizens by thwarting enemy attacks with carefully timed retaliatory strikes.\n\n{514318767857857}\n\n# PURCHASE UPGRADES\nIf your Headquarters survives the onslaught, you'll be rewarded with new turrets and discretionary funds to spend on upgrades and reconstruction. Earn glory and rise through the ranks to unlock faster turrets.\n\n{1211293443352041}\n\n# FACE MOUNTING CHALLENGES\nAs you survive past early levels, you'll encounter increasingly fierce opposition. Will you achieve eternal glory on the leaderboards, or will your city fall under siege? The fate of your airspace rests in your hands!\n\n{1576284476260137}", "short_description": "Airspace Defender is a 3D tabletop arcade game in mixed reality. Manage your city's defenses and thwart enemy attacks with carefully timed retaliatory strikes!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.notsuspicious.biz/privacy", "developer_terms_of_service_url": null, "publisher_name": "Not Suspicious", "support_website_url": "https://www.notsuspicious.biz/discord", "website_url": "https://www.notsuspicious.biz/airspace-defender", "category": null, "comfort_rating": "COMFORTABLE_FO