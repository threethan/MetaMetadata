46110}\n\n# FACE MOUNTING CHALLENGES\nAs you survive past early levels, you'll encounter increasingly fierce opposition. Will you achieve eternal glory on the leaderboards, or will your city fall under siege? The fate of your airspace rests in your hands!\n\n{1058682659256666}", "short_description": "Airspace Defender is a 3D tabletop missile defense game in mixed reality. Manage your city's defenses and thwart enemy attacks with carefully timed retaliatory strikes!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.notsuspicious.biz/privacy", "developer_terms_of_service_url": null, "publisher_name": "Not Suspicious", "support_website_url": "https://www.notsuspicious.biz/discord", "website_url": "https://www.notsuspicious.biz/airspace-defender", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8213187215432490"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2827699974198020"}, {"status": "PUBLISHED", "id": "1558979678027702"}]}, "baseline_offer": {"id": "1558979678027702"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "2827699974198020"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8929006030517268", "version": "0.1"}, "id": "736184498719905", "channel_name": "LIVE"