2_3047236528094911763_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XY-OD2X-RiAQ7kNvgHcqLYa&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD7os4IZCWMj41BMxV3m2-aJUex0OVkP87Twj9kbNqOUQ&oe=67582154"}, {"file_name": "build_178_ss2_.png", "id": "1133884188074233", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75250457_1133884191407566_1152689678558865883_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hZHvBlASX7EQ7kNvgGMc8tW&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAnULSwc-zieIcEUxjbD0yuAYRtZn4jq-2QxOd-ytS68Q&oe=67582D35"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Airspace Defender Cover.png", "id": "517110117410509", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031602_517110120743842_3140714957862057636_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=35JUDVIs9QAQ7kNvgGexMzn&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAlqCTSwPmbpRRDvZehyxSfFvDPLhJqaPkeOYbtL2Q79Q&oe=67582F49"}, "display_name": "Airspace Defender", "keywords": ["tabletop", "arcade", "retro", "combat", "military"], "long_description": "# ENTER THE WAR ROOM\nDefend your airspace in thrilling tabletop mixed reality!\n\nManage your city's defenses and protect your citizens by thwarting enemy attacks with carefully timed retaliatory strikes.\n\n{1209565883674718}\n\n# ACQUIRE UPGRADES\nIf your Headquarters survives the onslaught, you'll be rewarded with new turrets and discretionary funds to spend on upgrades and reconstruction. Earn glory and rise through the ranks to unlock faster turrets.\n\n{439655972206404}\n\n# FACE MOUNTING CHALLENGES\nAs you survive past early levels, you'll encounter increasingly fierce opposition. Will you achieve eternal glory on the leaderboards, or will your city fall under siege? The fate of your airspace rests in your hands!\n\n{908217047621802}", "short_description": "Airspace Defender is a 3D tabletop arcade game in mixed reality. Manage your city's defenses and thwart enemy attacks with carefully timed retaliatory strikes!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.notsuspicious.biz/privacy", "developer_terms_of_service_url": null, "publisher_name": "Not Suspicious", "support_website_url": "https://www.notsuspicious.biz/discord", "website_url": "https://www.notsuspicious.biz/airspace-defender", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1676485315806614"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8709142715836935"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39001671_758489706390731_317277346532944294_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L1Il7YmCgbcQ7kNvgE0d_Sf&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBG-ORoNPRUiJMIQ3dxRpDZM60x7XoTyuULM7M306Dl7g&oe=675822DC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Airspace Defender", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Tabletop", "id": "1676485315806614"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1729270800, "lastRevision": {"nodes": [{"id": "7523170247767527", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata":