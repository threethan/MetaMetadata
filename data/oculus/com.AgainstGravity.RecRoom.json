}, {"file_name": "migrated_image.png", "id": "879220352504253", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974700_2294029747526916_4543496476231204864_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NgyumC_8_84Q7kNvgGK1nMr&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAOHYRHsknFhXlgPLWTTxqtv8Pebn-yhQ5snGLSowLQhg&oe=670BBB05"}, {"file_name": "migrated_image.png", "id": "265014867827352", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001701_2127280937309636_2505982790080659456_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LP_5YgVaVXAQ7kNvgEuxmJf&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBDELet95enhevRICayJEVjMm88brShfshZ-dvtdSjxhw&oe=670BA523"}, {"file_name": "migrated_image.png", "id": "670182240418361", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974858_279781586264931_1680185837486080000_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9wfi8vnFhawQ7kNvgGsmZjV&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBzSfBtTDEyc3nn2B3CIQSG_xJftsM29kTgQrASsEwPjw&oe=670BA86E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/ap1nsy", "id": "391430578073655", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974852_391430581406988_3443800272235659264_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zMOx5Gv_0PQQ7kNvgHqbtr9&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBKxVgzqCC6nChssUNI1bQXQCxwL65lFbSWfBusFR921g&oe=670BAB43"}, "display_name": "Rec Room", "keywords": ["recroom", "rec", "room", "social", "roblox"], "long_description": "Rec Room is the best place to hang out with friends from all around the world! Play intense multiplayer games like Paintball or just chill with friends in the park. There are thousands of player-created game and event rooms for you to discover, with new ones added daily. You can even build your own rooms with your friends. Rec Room is cross platform and free, so come and join the fun!\n\nFeatures:\n\n-A fun and welcoming community\n-Robust moderation tools so you can manage your experience\n-Customize your look with clothing and accessories\n-Rich 3D and game creation tools that you build and share your own custom rooms\n-Share photos and manage your account on rec.net\n-Rec Room is updated frequently to add more fun stuff to do, so check back often!", "short_description": "Rec Room is the best place to hang out with friends from all around the world! Play intense multiplayer games like Paintball or just chill with friends in the park. There are thousands of player-created game and event rooms for you to discover, with new ones added daily. You can even build your own rooms with your friends. Rec Room is cross platform and free, so come and join the fun!"}]}, "developer_name": "Against Gravity\u00ae", "developer_privacy_policy_url": "https://www.againstgrav.com/privacy-policy/", "developer_terms_of_service_url": "https://www.againstgrav.com/terms-of-service/", "publisher_name": "Against Gravity\u00ae", "support_website_url": "https://recroom.happyfox.com/", "website_url": "http://www.againstgrav.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "SHOOTER", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "290514969730527"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "914469256213799"}, {"status": "PENDING", "id": "969192594045079"}, {"status": "PENDING", "id": "801490547027757"}, {"status": "PUBLIS