-2.oculuscdn.com&oh=00_AYB3pKVBaPbcKfCE6ULkz2Nw3RkdtvWD2HA9MG5CEktb-Q&oe=67543E6F"}, {"file_name": "Screenshot_06.png", "id": "493976249467977", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568668_493976252801310_4205887329934943301_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0iCHoUcQZRkQ7kNvgFhSwhy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBP0YYFwtklj9tKUKJg0ihJoypgEtWURdtu_nDnmnc-w&oe=67543EED"}, {"file_name": "Screenshot_07.png", "id": "708948140661335", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974756_708948143994668_2326257315352504436_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7zhWVc6Z-cQ7kNvgGfuR3k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgCF8xXQpp-o9EMFecgrj1ELV1pSRIAz86fZOIa2-FaA&oe=67542737"}, {"file_name": "Screenshot_04.png", "id": "834216941025124", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974557_834216944358457_5754573898347202634_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w2bSRmLuB0kQ7kNvgFHHR4M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgQQohZEfOtn6xi9BltlG_ZUmCNIxFuzdD5kZuvGpoSQ&oe=6754488F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "08_Trailer_Cover_2560x1440px.png", "id": "414890254042624", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75324645_414890257375957_784108811026964713_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4VSWVxdaY3AQ7kNvgEMJied&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXG18u4HXwYH9_5TmYoDxxkA8QQl9xt2PL8YCdw90piQ&oe=6754249A"}, "display_name": "Catch Up", "keywords": [], "long_description": "Catch Up is a casual virtual reality arcade game in which you play as a farmer, where the main goal is to catch eggs in a basket and not lose.\n\nThe game has 4 modes with support for the rating system:\n\u2022 Infinity mode - the easiest mode where you can practice and get used to catching eggs;\n\u2022 Time mode - here your time is limited, so try to catch as many eggs as possible in the time you have;\n\u2022 Count mode - in this mode, the number of eggs is limited. Try to catch as many eggs as possible and not lose;\n\u2022 Sequence mode includes time mode and score mode, as well as a fun boss fight and his little helpers.\n\nTry catching right now!", "short_description": "Catch Up is a casual virtual reality arcade game in which you play as a farmer, where the main goal is to catch eggs in a basket and not lose.\n\nThe game has 4 modes with support for the rating system:\n\u2022 Infinity mode (great for training);\n\u2022 Time mode (limited game time);\n\u2022 Count mode (limited number of eggs);\n\u2022 Sequence mode (time mode and score mode, as well as a boss fight)."}, {"images": {"nodes": []}, "id": "573048221365297", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Catch Up", "keywords": [], "long_description": "Catch Up \u2013 \u044d\u0442\u043e \u043a\u0430\u0437\u0443\u0430\u043b\u044c\u043d\u0430\u044f \u0430\u0440\u043a\u0430\u0434\u043d\u0430\u044f \u0438\u0433\u0440\u0430 \u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0432\u044b \u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0437\u0430 \u0444\u0435\u0440\u043c\u0435\u0440\u0430, \u0433\u0434\u0435 \u0433\u043b\u0430\u0432\u043d\u0430\u044f \u0446\u0435\u043b\u044c \u2013 \u043f\u043e\u0439\u043c\u0430\u0442\u044c \u044f\u0439\u0446\u0430 \u0432 \u043a\u043e\u0440\u0437\u0438\u043d\u043a\u0443 \u0438 \u043d\u0435 \u043f\u0440\u043e\u0438\u0433\u0440\u0430\u0442\u044c.\n\n\u0412 \u0438\u0433\u0440\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e 4 \u0440\u0435\u0436\u0438\u043c\u0430 \u0441 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u043e\u0439 \u0440\u0435\u0439\u0442\u0438\u043d\u0433\u043e\u0432\u043e\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b:\n\u2022 \u0411\u0435\u0441\u043a\u043e\u043d\u0435\u0447\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c \u2013 \u0441\u0430\u043c\u044b\u0439 \u043f\u0440\u043e\u0441\u0442\u043e\u0439 \u0440\u0435\u0436\u0438\u043c, \u0433\u0434\u0435 \u0432\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u0442\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u0438 \u043f\u0440\u0438\u043d\u043e\u0440\u043e\u0432\u0438\u0442\u044c\u0441\u044f \u043a \u043b\u043e\u0432\u043b\u0435 \u044f\u0438\u0446;\n\u2022 \u0412\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0439 \u0440\u0435\u0436\u0438\u043c \u2013 \u0437\u0434\u0435\u0441\u044c \u0432\u0430\u0448\u0435 \u0432\u0440\u0435\u043c\u044f \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043e, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u043f\u043e\u0441\u0442\u0430\u0440\u0430\u0439\u0442\u0435\u0441\u044c \u043f\u043e\u0439\u043c\u0430\u0442\u044c \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435 \u044f\u0438\u0446 \u0437\u0430 \u043e\u0442\u0432\u0435\u0434\u0435\u043d\u043d\u043e\u0435 \u0432\u0430\u043c \u0432\u0440\u0435\u043c\u044f;\n\u2022 \u0420\u0435\u0436\u0438\u043c \u0441\u0447\u0435\u0442\u0430 \u2013 \u0432 \u044d\u0442\u043e\u043c \u0440\u0435\u0436\u0438\u043c\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u044f\u0438\u0446. \u041f\u043e\u0441\u0442\u0430\u0440\u0430\u0439\u0442\u0435\u0441\u044c \u043f\u043e\u0439\u043c\u0430\u0442\u044c \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435 \u044f\u0438\u0446 \u0438 \u043d\u0435 \u043f\u0440\u043e\u0438\u0433\u0440\u0430\u0442\u044c;\n\u2022 \u041f\u043e\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c \u0432\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0432 \u0441\u0435\u0431\u044f \u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e\u0439 \u0440\u0435\u0436\u0438\u043c \u0438 \u0440\u0435\u0436\u0438\u043c \u0441\u0447\u0435\u0442\u0430, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0437\u0430\u0431\u0430\u0432\u043d\u0443\u044e \u0431\u0438\u0442\u0432\u0443 \u0441 \u0431\u043e\u0441\u0441\u043e\u043c \u0438 \u0435\u0433\u043e \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u043c\u0438 \u043f\u043e\u043c\u043e\u0449\u043d\u0438\u043a\u0430\u043c\u0438.\n\n\u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u043f\u043e\u0439\u043c\u0430\u0442\u044c \u043f\u0440\u044f\u043c\u043e \u0441\u0435\u0439\u0447\u0430\u0441!", "short_description": "Catch Up \u2013 \u044d\u0442\u043e \u043a\u0430\u0437\u0443\u0430\u043b\u044c\u043d\u0430\u044f \u0430\u0440\u043a\u0430\u0434\u043d\u0430\u044f \u0438\u0433\u0440\u0430 \u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0432\u044b \u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0437\u0430 \u0444\u0435\u0440\u043c\u0435\u0440\u0430, \u0433\u0434\u0435 \u0433\u043b\u0430\u0432\u043d\u0430\u044f \u0446\u0435\u043b\u044c \u2013 \u043f\u043e\u0439\u043c\u0430\u0442\u044c \u044f\u0439\u0446\u0430 \u0432 \u043a\u043e\u0440\u0437\u0438\u043d\u043a\u0443 \u0438 \u043d\u0435 \u043f\u0440\u043e\u0438\u0433\u0440\u0430\u0442\u044c.\n\n\u0412 \u0438\u0433\u0440\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e 4 \u0440\u0435\u0436\u0438\u043c\u0430 \u0441 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u043e\u0439 \u0440\u0435\u0439\u0442\u0438\u043d\u0433\u043e\u0432\u043e\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b:\n\u2022 \u0411\u0435\u0441\u043a\u043e\u043d\u0435\u0447\u043d\u044b\u0439 \u0440\u0435\u0436\u0438\u043c (\u043e\u0442\u043b\u0438\u0447\u043d\u043e \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u0434\u043b\u044f \u0442\u0440\u0435\u043d\u0438\u0440\u043e\u0432\u043a\u0438);\n\u2022 \u0412\u0440\u