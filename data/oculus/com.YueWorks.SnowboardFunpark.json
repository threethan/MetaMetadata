1_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a3ywvJzBgroQ7kNvgE2g-EO&_nc_ht=scontent.oculuscdn.com&oh=00_AYD71P8uJVUa-Uqufb0ycXKA68RF7nB5HhZDF7HSwVwmHw&oe=66FD484F"}, {"file_name": "Screen5.png", "id": "739627660821037", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86659800_739627664154370_9042240874013208312_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKRMO1oC7NUQ7kNvgGQ7Lb8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMziwcsPxXtbRs4k4rCGDQAeC8Lrff4IwmNcoOuSYeKw&oe=66FD3DF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "2268441033310093", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75392879_2268441039976759_1469796674550560470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WLsVrfpL5tcQ7kNvgEwj_7x&_nc_ht=scontent.oculuscdn.com&oh=00_AYADXdpMTMKZV9ZYVD619G5IaswZuM44eJrMNQXMdv8aXQ&oe=66FD3A36"}, "display_name": "Snowboard Funpark", "keywords": [], "long_description": "Riding a snowborad in virtual reality is fun, but doing tricks on ramps, rails and curbs is addicting.\n\nWith our physics-based approach, we managed to create an experience that every snowboarder will instantly feel familiar with. \nThe board can be oriented by swinging the arms to gain momentum.\nThe orientation of the hands determine the angle relative to the hill, that is used to decide if the board follows a direction or not. \nJust like a real snowboard.\n\nWhen approaching a rail or curb the snowboarder will keep his spinning momentum due to the low friction on the rails or curbs material, the same is true for air-time, what allows you to do spins on rails, curbs or in air-time.\n\nGameplay\n\u2022 Level System (only one level at the moment)\n\u2022 Score System\n\u2022 To-Do-List for each map\n\u2022 Map - \"Mount Pee Pee\"\n\u2022 Map - \"Ski-Hall\"\n\u2022 Map - \"City Spot\"\n\u2022 Freestyle-Mode\n\u2022 Recording and Reviewing\n\u2022 Board Editor\n\n\u2022 [upcoming] Mini Challenges", "short_description": "Snowboard Funpark is a virtual reality snowboard experience. Do slides, grinds, spins and more in \"Snowboard Funpark\"."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/snowboardfunpark-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "YueWorks", "support_website_url": null, "website_url": "https://yue-beifong.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "563093798782668"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sJlsEhidQn4Q7kNvgESbgWU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDb1Uor6gdvB2pMrk6vvXtQfRqGhPr1kfcdcqLtjQ6SjA&oe=66FD45E8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snowboard Funpark", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1655676000, "lastRevision": {"nodes": [{"id": "5320554204699200", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5320554141365873", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "392109186313667"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"ima