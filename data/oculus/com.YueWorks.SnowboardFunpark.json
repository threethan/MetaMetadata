uluscdn.com&oh=00_AYAJMeWYNuUexvgBRKikxCVamsRbVkiq5XEBcbKkZxBT5g&oe=673C613C"}, {"file_name": "Screen4.png", "id": "783888029443659", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367594_783888032776992_2460747146712332551_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wDm7z63ACXcQ7kNvgFfQaPT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYANW1r_3Yq5w9nJFCIC-omY9gFiZK32R2QCLS0HJrxA&oe=673C904F"}, {"file_name": "Screen5.png", "id": "739627660821037", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659800_739627664154370_9042240874013208312_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o9q6i0diRJkQ7kNvgGfRX9J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8CZaw1v9XKn6_yf7QZii0k5tXGM_HwCOtkLAsJzSibQ&oe=673C85F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "2268441033310093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392879_2268441039976759_1469796674550560470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6XMsjG82ge4Q7kNvgE6T4zR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrtCbNf7PMWWKOCKJa2IGAMT9x3UfXItPAcpZm1Hmtng&oe=673C8236"}, "display_name": "Snowboard Funpark", "keywords": [], "long_description": "Riding a snowborad in virtual reality is fun, but doing tricks on ramps, rails and curbs is addicting.\n\nWith our physics-based approach, we managed to create an experience that every snowboarder will instantly feel familiar with. \nThe board can be oriented by swinging the arms to gain momentum.\nThe orientation of the hands determine the angle relative to the hill, that is used to decide if the board follows a direction or not. \nJust like a real snowboard.\n\nWhen approaching a rail or curb the snowboarder will keep his spinning momentum due to the low friction on the rails or curbs material, the same is true for air-time, what allows you to do spins on rails, curbs or in air-time.\n\nGameplay\n\u2022 Level System (only one level at the moment)\n\u2022 Score System\n\u2022 To-Do-List for each map\n\u2022 Map - \"Mount Pee Pee\"\n\u2022 Map - \"Ski-Hall\"\n\u2022 Map - \"City Spot\"\n\u2022 Freestyle-Mode\n\u2022 Recording and Reviewing\n\u2022 Board Editor\n\n\u2022 [upcoming] Mini Challenges", "short_description": "Snowboard Funpark is a virtual reality snowboard experience. Do slides, grinds, spins and more in \"Snowboard Funpark\"."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/snowboardfunpark-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "YueWorks", "support_website_url": null, "website_url": "https://yue-beifong.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "563093798782668"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HIriDGFnLFQQ7kNvgEX4P-y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtcWWejd1mZ0DJk0omj_5EjYjesl9GBv4FbI3ZVzGQuQ&oe=673C8DE8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snowboard Funpark", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "3315291881322