1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cASHsINzNe8Q7kNvgGt_sZJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQg4eorDSlTUBoT2-8DuAArFDH4AF30g0wKn3S-1AcMA&oe=67090935"}, {"file_name": "Hero.png", "id": "423439799648221", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974506_423439806314887_5065469878910066262_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DI6fNWKPMRcQ7kNvgGEIuqv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClpjQCEUgkxCIyUm6b2f8ywGkAuiuSC1epjXgaRnbSeQ&oe=670910BD"}, {"file_name": "Square1440.png", "id": "402240488339129", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_YNokjLAFyMQ7kNvgFVAjjj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzMCi4Kvw6lkrX19HeGwASjkinPjjiFGvtWwi8glBq3Q&oe=67092368"}]}, "id": "1061965098025418", "locale": "en_US", "screenshots": [{"file_name": "Screen1.png", "id": "555515649407339", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294245_555515656074005_7518822137939250394_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oYzFWY7FgmYQ7kNvgHvr8tg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQ1N_kkdOa0zNqACABpQV9YHJh5CN50dR2kvMWuPhlCA&oe=67090E65"}, {"file_name": "Screen2.png", "id": "3790640827828489", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_3790640831161822_8129658188914418857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hHS191Vlui0Q7kNvgEw5Xih&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwi1TqMuUf542k7UKJQaouXsO1z_RRV7qqjSEXcCrWgw&oe=6708F715"}, {"file_name": "Screen3.png", "id": "764179388347028", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520134_764179391680361_836927880708408671_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZZZQlwRaSYQ7kNvgFlF9xN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAnVB2DhH9ztSkScT-ImJR9hP1nC5dIMOs7duyv4Elg8g&oe=6708F6BC"}, {"file_name": "Screen4.png", "id": "783888029443659", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367594_783888032776992_2460747146712332551_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p_1KOXP5PMcQ7kNvgHBclKu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB43u0qM0zYip6o3N7fVvU2USvMwRpXn-_hqNUhT_8CMg&oe=670925CF"}, {"file_name": "Screen5.png", "id": "739627660821037", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659800_739627664154370_9042240874013208312_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y7CwTCFvrSQQ7kNvgGa3e4f&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC92Bkdbc3YfgQjx6phcpWuTBV0v6OAzE_47xM-ZZelCw&oe=67091B73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "2268441033310093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392879_2268441039976759_1469796674550560470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EwAdLQ5NNTIQ7kNvgF2AUK8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRWrKgnm6J0n5c6EGimzhYer0Z9biovP6q68fMshLh5g&oe=670917B6"}, "display_name": "Snowboard Funpark", "keywords": [], "long_description": "Riding a snowborad in virtual reality is fun, but doing tricks on ramps, rails and curbs is addicting.\n\nWith our physics-based approach, we managed to create an experience that every snowboarder will instantly feel familiar with. \nThe board can be oriented by swinging the arms to gain momentum.\nThe orientation of the hands determine the angle relative to the hill, that is used to decide if the board follows a direction or not. \nJust like a real snowboard.\n\nWhen approaching a rail or curb the snowboarder will keep his spinning momentum due to the low friction on the rails or curbs material, the same is true for air-time, what allows you to do spins on rails, curbs or in air-time.\n\nGameplay\n\u2022 Level System (only one level at the moment)\n\u2022 Score System\n\u2022 To-Do-List for each map\n\u2022 Map - \"Mount Pee Pee\"\n\u2022 Map - \"Ski-Hall\"\n\u2022 Map - \"City Spot\"\n\u2022 Freestyle-Mode\n\u2022 Recording and Reviewing\n\u2022 Board Editor\n\n\u2022 [upcoming] Mini Challenges", "short_description": "Snowboard Funpark is a virtual reality snowboard experience. Do slides, grinds, spins and more in \"Snowboard Funpark\"."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/snowboardfunpark-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "YueWorks", "support_website_url": null, "website_url": "https://yue-beifong.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "563093798782668"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_YNokjLAFyMQ7kNvgFVAjjj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByAkRwYSS4kWzLQoxbSRKdyunKRP1DPZGl8QbzgWlucw&oe=67092368"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snowboard Funpark", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1655676000, "lastRevision": {"nodes": [{"id": "5320554204699200", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5320554141365873", "is_first_part