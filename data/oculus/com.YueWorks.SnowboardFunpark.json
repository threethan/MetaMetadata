1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yxjCLQVLmCQQ7kNvgHgI4bH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgHIk-Frlb0d5W2SszmEqJzhM-A5J4oOQ32ZMOXU3l3w&oe=6718DB35"}, {"file_name": "Hero.png", "id": "423439799648221", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974506_423439806314887_5065469878910066262_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=60h0cFeXZhIQ7kNvgH_6ZLp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCH1l6CJgOK0Os2risbSjYkzqPqwvnDQfzlNC8Dw6Meaw&oe=6718E2BD"}, {"file_name": "Square1440.png", "id": "402240488339129", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7aVQFm4HvVoQ7kNvgHtZPwW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWSmDwQQP1FoAvZ4hiDlWTfXDp-TVgF0NQhXuGyp03rA&oe=6718F568"}]}, "id": "1061965098025418", "locale": "en_US", "screenshots": [{"file_name": "Screen1.png", "id": "555515649407339", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294245_555515656074005_7518822137939250394_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xHa9oREi_xkQ7kNvgFmeKak&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6LVKY96f3fDYuCQbanccVu08_PyFhl-RWwOat8D9rsA&oe=6718E065"}, {"file_name": "Screen2.png", "id": "3790640827828489", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003282_3790640831161822_8129658188914418857_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WZdpbNAlktYQ7kNvgFOy5vg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBWc2fix0MI8ZzzTSaFv7k6GmvY32B5pgkW3WCIQOdZYw&oe=6718C915"}, {"file_name": "Screen3.png", "id": "764179388347028", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520134_764179391680361_836927880708408671_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lb4z3q5x1HAQ7kNvgGBTmTt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRx7KqEvjSTOeBKT6NUnPlP_4hcmpCbXT6eQTzht_LWg&oe=6718C8BC"}, {"file_name": "Screen4.png", "id": "783888029443659", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367594_783888032776992_2460747146712332551_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jecjVD4ljCUQ7kNvgEfgp52&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDoBy9g8eqpSF5UCtYRDDw59WYXNcjgTEmKaD1OpfIZdA&oe=6718F7CF"}, {"file_name": "Screen5.png", "id": "739627660821037", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659800_739627664154370_9042240874013208312_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4b2u7iKmixgQ7kNvgHK8VXh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqaDXMZAdtBqwFClVDOeE32M_X4ZfDPbhcPqyh4WmTJg&oe=6718ED73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "2268441033310093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392879_2268441039976759_1469796674550560470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4g61jvWidnIQ7kNvgHTH6E_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDaVYypYV4WkpjxUzGpI59seG5HpIrs0Ob1Ur7ZFr7IgA&oe=6718E9B6"}, "display_name": "Snowboard Funpark", "keywords": [], "long_description": "Riding a snowborad in virtual reality is fun, but doing tricks on ramps, rails and curbs is addicting.\n\nWith our physics-based approach, we managed to create an experience that every snowboarder will instantly feel familiar with. \nThe board can be oriented by swinging the arms to gain momentum.\nThe orientation of the hands determine the angle relative to the hill, that is used to decide if the board follows a direction or not. \nJust like a real snowboard.\n\nWhen approaching a rail or curb the snowboarder will keep his spinning momentum due to the low friction on the rails or curbs material, the same is true for air-time, what allows you to do spins on rails, curbs or in air-time.\n\nGameplay\n\u2022 Level System (only one level at the moment)\n\u2022 Score System\n\u2022 To-Do-List for each map\n\u2022 Map - \"Mount Pee Pee\"\n\u2022 Map - \"Ski-Hall\"\n\u2022 Map - \"City Spot\"\n\u2022 Freestyle-Mode\n\u2022 Recording and Reviewing\n\u2022 Board Editor\n\n\u2022 [upcoming] Mini Challenges", "short_description": "Snowboard Funpark is a virtual reality snowboard experience. Do slides, grinds, spins and more in \"Snowboard Funpark\"."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/snowboardfunpark-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "YueWorks", "support_website_url": null, "website_url": "https://yue-beifong.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "563093798782668"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974505_402240491672462_5622991982874876217_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7aVQFm4HvVoQ7kNvgHtZPwW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnTjId2A5Oy2ZAEOWY87Np7w9reAdfK0CWekxPCDBgYQ&oe=6718F568"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snowboard Funpark", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1655676000, "lastRevision": {"nodes": [{"id": "5320554204699200", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5320554141365873", "is_first_part