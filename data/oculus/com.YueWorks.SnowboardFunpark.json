culuscdn.com/v/t64.5771-25/75367594_783888032776992_2460747146712332551_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jecjVD4ljCUQ7kNvgEfgp52&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDoBy9g8eqpSF5UCtYRDDw59WYXNcjgTEmKaD1OpfIZdA&oe=6718F7CF"}, {"file_name": "Screen5.png", "id": "739627660821037", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659800_739627664154370_9042240874013208312_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4b2u7iKmixgQ7kNvgHK8VXh&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqaDXMZAdtBqwFClVDOeE32M_X4ZfDPbhcPqyh4WmTJg&oe=6718ED73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Querformat.png", "id": "2268441033310093", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75392879_2268441039976759_1469796674550560470_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4g61jvWidnIQ7kNvgHTH6E_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDaVYypYV4WkpjxUzGpI59seG5HpIrs0Ob1Ur7ZFr7IgA&oe=6718E9B6"}, "display_name": "Snowboard Funpark", "keywords": [], "long_description": "Riding a snowborad in virtual reality is fun, but doing tricks on ramps, rails and curbs is addicting.\n\nWith our physics-based approach, we managed to create an experience that every snowboarder will instantly feel familiar with. \nThe board can be oriented by swinging the arms to gain momentum.\nThe orientation of the hands determine the angle relative to the hill, that is used to decide if the board follows a direction or not. \nJust like a real snowboard.\n\nWhen approaching a rail or curb the snowboarder will keep his spinning momentum due to the low friction on the rails or curbs material, the same is true for air-time, what allows you to do spins on rails, curbs or in air-time.\n\nGameplay\n\u2022 Level System (only one level at the moment)\n\u2022 Score System\n\u2022 To-Do-List for each map\n\u2022 Map - \"Mount Pee Pee\"\n\n\u2022 [up coming] Map - \"Ski-Hall\"\n\u2022 [up coming] Map - \"Woods\"\n\u2022 [up coming] Freestyle-Mode\n\u2022 [up coming] Recording & Filming\n\u2022 [up coming] Freestyle-Mode\n\u2022 [up coming] Board Editor", "short_description": "Snowboard Funpark is a virtual reality snowboard experience. Do slides, grinds, spins and more in \"Snowboard Funpark\"."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/snowboardfunpark-privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "YueWorks", "support_website_url": null, "website_url": "https://yue-beifong.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "430646418950439"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "802609904515723"}]}, "baseline_offer": {"id": "802609904515723"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1655676000, "status": "PUBLISHED", "id": "802609904515723"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5399840543437232", "version": "0.1.5"}, "id": "744055540121608", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5320554141365873", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5399840543437232"}, "relea