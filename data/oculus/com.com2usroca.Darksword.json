ohc=rBRqwijFs88Q7kNvgHnN13j&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPQJRD9Z6rkgEo4I8GOb419739QXSkr0QdI1-7bsz3yg&oe=66FD457A"}, {"file_name": "screenshot_05.png", "id": "198112269362847", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572917_198112279362846_2456562122820696967_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZwAQtsogalIQ7kNvgHZeQQm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAk5RMEvsx0MJnELKo0z-LCzWKR3DOpB_HcnOggBOTKgw&oe=66FD27BB"}, {"file_name": "screenshot_01.png", "id": "945604886677024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036689_945604890010357_6645096181083707186_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azxGI4TnX9QQ7kNvgEORVun&_nc_ht=scontent.oculuscdn.com&oh=00_AYANmKINxUBDsAeTVtSF0e1kvDZ_Ep6qQaKJyVGJqnDZ8w&oe=66FD1C8A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Meta_CoverLandscape_2560x1440_v2.png", "id": "606856991356702", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974671_606856994690035_4314101343653197317_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jZGxAuX_uv0Q7kNvgFBKsZO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOMUgu5vz4sP1-kacQlZdkgzX0QQE0kSzbY3HJccW9Kg&oe=66FD3F1C"}, "display_name": "Darksword: Battle Eternity", "keywords": ["Action", "RPG", "Fantasy", "roguelike", "multiplayer"], "long_description": "Darksword is an exciting, original non-stop VR action RPG.  Venture deep into the world of the Twisted Corridors and defeat your enemies in style.  Develop your own style of combat, exploit enemy weakness, and collect materials to get more powerful weapons! \n\nPlay the story mode and compete globally through the leaderboard system!  Show off your skills, build teamwork, and get even more rewards in the multiplayer Co-Op mode!\n\n- Fun, entertaining, and enjoyable hack-and-slash experience for all!\n\n- Grow as you play.  Collect items during battle.  Buy, craft, and upgrade weapons to become even more powerful!\n\n- Single-player & Multiplayer Ready: Whether solo or as a party, Darksword offers players to enjoy the game in any way they can!\n\n- Updates and New Features to Come: Until the curse of the Darksword is lifted, the battle must continue!", "short_description": "Darksword is an exciting, original non-stop VR action RPG.  Venture deep into the world of the Twisted Corridors and defeat your enemies in style.  Develop your own style of combat, exploit enemy weakness, and collect materials to get more powerful weapons!  \nPlay the story mode and compete globally through the leaderboard system!  Show off your skills, build teamwork, and get even more rewards in the multiplayer Co-Op mode!"}, {"images": {"nodes": [{"file_name": "DS_EN_LOGO.png", "id": "6273378419391078", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001654_6273378429391077_4033243582940025113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=68qQiLUI1GgQ7kNvgF-hRCJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBS19SH77tgA22OaWVUUx-5NrT7zwJlJRNeLWVksIXOJQ&oe=66FD22E9"}, {"file_name": "DS_3000_900_EN.png", "id": "1391331114995379", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451774_1391331118328712_8608683857693696149_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U55Z-ps04zkQ7kNvgETJ-Er&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXXbf4mbgdYQSv2cJxR63OPlKhIDpDftnDK0cnSBuNdQ&oe=66FD3C0C"}, {"file_name": "DS512_512_en.png", "id": "1293098167953385", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75630192_1293098171286718_3269047772630194375_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2p-tvlXb3TkQ7kNvgFr6Kts&_nc_ht=scontent.oculuscdn.com&oh=00_AYC20jS1dOkUGRtix026T7BZVdGbSM3CEAc7icwstq3Sqw&oe=66FD2764"}, {"file_name": "Meta_CoverSquare_1440x1440_v3.png", "id": "1228418001208293", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222944_1228418004541626_4480062699278916759_n.png?_nc_cat=104&ccb=1-7&_nc_sid=