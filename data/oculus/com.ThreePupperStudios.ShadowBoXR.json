id": "639821284353405", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_639821287686738_8660328866217059455_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NWba5RL5LQQ7kNvgEusrN3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBukPQ3ngH2zc_5MVETC_x4jOVDQxfhICnXyUmHuqhm3w&oe=66FA9AF7"}, "display_name": "Shadow BoXR", "keywords": [], "long_description": "Get fit while rocking out to your favorite music. Shadow BoXR is a rhythm boxing game intended to make working out fun. With a massive library of community content music, you are sure to find what you love. Each song offers 7 different modes and difficulties for everyone this game is sure to knock your socks off.\nPunch the targets and dodge the obstacles all while rocking out to your favorite music. This is your workout built by you for you.", "short_description": "Shadow BoXR is a rhythm boxing game intended to make working out fun. Punch the targets and dodge the obstacles all while rocking out to your favorite music. This is your workout built by you for you."}]}, "developer_name": null, "developer_privacy_policy_url": "http://benbryanricks.artstation.com/pages/3pupperstudiospp", "developer_terms_of_service_url": null, "publisher_name": "Three Pupper Studios LLC", "support_website_url": null, "website_url": "https://BenBryanRicks.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USE