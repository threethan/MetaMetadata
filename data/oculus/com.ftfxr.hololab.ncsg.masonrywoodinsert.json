.5771-25/75245822_1017662280066806_3140249560059418966_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vz8nb3O-wskQ7kNvgH_2Cmo&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAubqJsa9vKs3qpovWPo6V1mbFaS5TdzlgDU5nLqaNMAQ&oe=677E640F"}, {"file_name": "screen-5.png", "id": "1132731301130632", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/75375083_1132731304463965_2489209119133489696_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3rUEY_RJp58Q7kNvgH4Rwy-&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBTljxEjVlH3gp8CspQpehRAISC1bSPJTxs0ZOMgq0qEQ&oe=677E7649"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mod2_Title.png", "id": "1212771323096726", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39036673_1212771326430059_1176351761076307841_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yl0vJdBoidMQ7kNvgEntyAB&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBJqwlKKr05F_nRkkoXnlpzCY4TpLkDmRUl4hgLGSiPzw&oe=677E6708"}, "display_name": "Hololab VR - NCSG Inspection Foundation Module 2: Masonry Wood Insert", "keywords": [], "long_description": "**Hololab NCSG Module 02 Wood Burning Fireplace Inserts VR Application**\n\nThe Hololab National Chimney Sweep Guild VR application trains users in the critical skills needed to inspect and maintain wood-burning fireplace inserts to NCSG standards. The course features interactive slides, desktop activities, real-world simulations, and integrates with a Learning Management System. It challenges students with inspections of randomized issues in a virtual residential setting, ensuring they follow all necessary procedures.\n\n**VR Controls and PPE \u2013** Learn how to navigate the virtual environment while getting acquainted with essential personal protective equipment.\n\n**Responsibility & Worksite Hazard Assessment \u2013** Operate in a simulated environment to identify and mitigate hazards commonly encountered during inspections of wood-burning fireplace inserts.\n\n**Familiarization \u2013** Understand different types of wood-burning fireplace inserts and their common features.\n\n**Fireplace Insert Inspection \u2013** Utilize the official NCSG checklist to thoroughly inspect wood-burning fireplace inserts.\n\n**Real-World Simulation \u2013** Complete the inspection by correctly identifying issues with maximum safety awareness and forensic skills.\n\nData reports for review are saved and stored for engagement metrics and simulation performance analysis.\n\nAny off-platform monetization of content accessible in this app conforms to the Oculus Bulk IAP or Subscription Licenses app policy outlined here: https://developer.oculus.com/policy/app-policies", "short_description": "The Hololab National Chimney Sweep Guild Wood Burning Fireplace Inserts VR application equips users with the critical skills necessary to inspect and maintain wood-burning fireplace inserts according to NCSG standards. This in-depth course includes interactive slide content, desktop-based activities, realistic simulations, and comprehensive testing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ftfvr.com/privacy-app", "developer_terms_of_service_url": null, "publisher_name": "From the Future", "support_website_url": null, "website_url": "https://ftfvr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8051709714946212"}}]}