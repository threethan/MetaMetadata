ent-lhr8-1.oculuscdn.com/v/t64.5771-25/75422370_383592477729888_2385279731780875299_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O0kcyAMGnswQ7kNvgFoU9Kp&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAOhkwES6d4K5bK5h0Ftf3sy5zRHwSmfIwtpbuIjtiOPw&oe=67162C87"}, {"file_name": "screen-3.png", "id": "1003454831259726", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75441584_1003454834593059_4414683215204598073_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IiSVfkM3cpoQ7kNvgE3SRwV&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDl1rzX5EQQ_Gtr2_PV-o1Sp-FteNvHg4xRA9PFzSRYRw&oe=671637DE"}, {"file_name": "screen-4.png", "id": "1017662276733473", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75245822_1017662280066806_3140249560059418966_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Wtz7mY-2EIQ7kNvgFyn26i&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAPJ3VK0vZZ9s0N5SIzfpluujWWUCH0smA4ualDQUYprA&oe=67163D8F"}, {"file_name": "screen-5.png", "id": "1132731301130632", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75375083_1132731304463965_2489209119133489696_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-c-6iiVoPtsQ7kNvgG6p-NW&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBSJx1_31kJh9pZzMa_wwUGOQIO87ZefSzgJpE8JkILsA&oe=67164FC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mod2_Title.png", "id": "1212771323096726", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39036673_1212771326430059_1176351761076307841_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKNiq6F0uiMQ7kNvgHSXCsV&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDE9f9pImGM6Xrl7pKoSlLY8B-do0ll5LsEyNvQmbD7cw&oe=67164088"}, "display_name": "Hololab VR - NCSG Inspection Foundation Module 2: Masonry Wood Insert", "keywords": [], "long_description": "**Hololab NCSG Module 02 Wood Burning Fireplace Inserts VR Application**\n\nThe Hololab National Chimney Sweep Guild VR application trains users in the critical skills needed to inspect and maintain wood-burning fireplace inserts to NCSG standards. The course features interactive slides, desktop activities, real-world simulations, and integrates with a Learning Management System. It challenges students with inspections of randomized issues in a virtual residential setting, ensuring they follow all necessary procedures.\n\n**VR Controls and PPE \u2013** Learn how to navigate the virtual environment while getting acquainted with essential personal protective equipment.\n\n**Responsibility & Worksite Hazard Assessment \u2013** Operate in a simulated environment to identify and mitigate hazards commonly encountered during inspections of wood-burning fireplace inserts.\n\n**Familiarization \u2013** Understand different types of wood-burning fireplace inserts and their common features.\n\n**Fireplace Insert Inspection \u2013** Utilize the official NCSG checklist to thoroughly inspect wood-burning fireplace inserts.\n\n**Real-World Simulation \u2013** Complete the inspection by correctly identifying issues with maximum safety awareness and forensic skills.\n\nData reports for review are saved and stored for engagement metrics and simulation performance analysis.\n\nAny off-platform monetization of content accessible in this app conforms to the Oculus Bulk IAP or Subscription Licenses app policy outlined here: https://developer.oculus.com/policy/app-policies", "short_description": "The Hololab National Chimney Sweep Guild Wood Burning Fireplace Inserts VR application equips users with the critical skills necessary to inspect and maintain wood-burning fireplace inserts according to NCSG standards. This in-depth course includes interactive slide content, desktop-based activities, realistic simulations, and comprehensive testing."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ftfvr.com/privacy-app", "developer_terms_of_service_url": null, "publisher_name": "From the Future", "support_website_url": null, "