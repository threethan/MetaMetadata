le_name": "2560x1440 (1).png", "id": "1242580393405131", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974594_1242580396738464_7600342908274045866_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AjeLmE9WagMQ7kNvgGLrxRl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdvuPNQBKI9Jce3CVX6YJQvGz05YDZZrkUKsgFLF-CPQ&oe=6731EAFB"}, {"file_name": "2560x1440 (3).png", "id": "866033444949053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974681_866033448282386_1060735077748256107_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYon_Lsl5XMQ7kNvgEpqi1r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAF04VS8gcj7wb0qrXBl_bDegv4nj2WxjKAnSLdD7qNCQ&oe=6731E598"}, {"file_name": "2560x1440 (4).png", "id": "443547678685303", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974547_443547682018636_6322347026334124666_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t-E8ZbV9CKEQ7kNvgGxKrGs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfyNoC6oumjrMnFQxeOPcqtzK_Sdemx-xoLlTrDCZPzg&oe=673208B4"}, {"file_name": "2560x1440 (5).png", "id": "878891567525558", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_878891570858891_8040644650588623139_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RYLgwN57ba0Q7kNvgGrVN5j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfXflnKsLsH3x-aL62tDRrMSuud59YeDmLZjDBI6Fqig&oe=6731E781"}, {"file_name": "2560x1440 (6).png", "id": "522360993660696", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974782_522361000327362_1265686494838610386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-RdsFqWz-AwQ7kNvgFXvYzy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJ9IhQzoHzsI3qocSmXQzE5JyzicpsJSIxu2hs1hMeOw&oe=6731E9C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (7).png", "id": "859600769565255", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65228806_859600772898588_578693433817766136_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d8I_c5wa_rYQ7kNvgH1C2A2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB06dcKAJNVVP6RSuxQOPMDL6IJ_7fcbUgL00bZkOFYfA&oe=6731FD9A"}, "display_name": "Feeling Fire Gun", "keywords": ["FeelingFireGun", "TTTcorporation"], "long_description": "\"Feeling Fire Gun\" is a groundbreaking VR application that seamlessly melds hyper-realistic firearm simulation with boundless creativity in a vast virtual playground. This immersive experience offers users the unique opportunity to wield meticulously crafted digital firearms that mirror their real-world counterparts in look, feel, and function, complete with authentic sounds and recoil.\n\nBut \"Feeling Fire Gun\" goes far beyond simple target practice. It empowers users to become architects of their virtual realms, allowing them to conjure, manipulate, and interact with a diverse array of objects. From crafting intricate structures to designing challenging obstacle courses, the only limit is the user's imagination.\n\nSet in an expansive, multi-terrain world, players can traverse their creations through various modes of locomotion, be it walking, teleporting, or even defying gravity. This freedom of movement complements the app's versatile gameplay modes, which include a sandbox-style free mode for uninhibited exploration and creation, a series of skill-testing challenges, and a dynamic multiplayer environment for shared experiences.", "short_description": "\"Feeling Fire Gun\" isn't just a game; it's a platform that bridges the gap between realistic simulation and creative expression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tttcorporation.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TTTcorporation", "support_website_url": null, "website_url": "https://tttcorporation.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context