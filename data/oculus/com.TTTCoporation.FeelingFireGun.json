6QHGmHrVJjf9s0-OyGALZRj47Nw&oe=66DD8AFB"}, {"file_name": "2560x1440 (3).png", "id": "866033444949053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974681_866033448282386_1060735077748256107_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mU892GJxK8sQ7kNvgEWAH7O&_nc_ht=scontent.oculuscdn.com&oh=00_AYBe9ibBCwQfhw437WFw88_ntnQXQsdNLm4Cf5dpdy62FA&oe=66DD8598"}, {"file_name": "2560x1440 (4).png", "id": "443547678685303", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974547_443547682018636_6322347026334124666_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tzbg9-e_0D8Q7kNvgHWMFvc&_nc_ht=scontent.oculuscdn.com&oh=00_AYBLgqGtBF_S-zHarCfL9hxo-C82-T8qSm4MyVn2hT1LPw&oe=66DD7074"}, {"file_name": "2560x1440 (5).png", "id": "878891567525558", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974867_878891570858891_8040644650588623139_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZTY0DilVPmcQ7kNvgF6S6eu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDAMsaeZONENGjfhN2ADuQYTzvQuJCJudNv6Q1vdjAsIA&oe=66DD8781"}, {"file_name": "2560x1440 (6).png", "id": "522360993660696", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974782_522361000327362_1265686494838610386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=evdpPchmvtcQ7kNvgE6aqqJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVI8i3NGmALXzaYaNmqDw_Jp5Y4GNlbPr9DzHhfIWhyg&oe=66DD89C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (7).png", "id": "859600769565255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65228806_859600772898588_578693433817766136_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P2Lx4PYWJF8Q7kNvgFhQlz2&_nc_ht=scontent.oculuscdn.com&oh=00_AYAl9L_AvJ7cwtCC3Y2kvi_Ll5QQukRpQx9af8k7hQ4yZA&oe=66DD9D9A"}, "display_name": "Feeling Fire Gun", "keywords": ["FeelingFireGun", "TTTcorporation"], "long_description": "\"Feeling Fire Gun\" is a groundbreaking VR application that seamlessly melds hyper-realistic firearm simulation with boundless creativity in a vast virtual playground. This immersive experience offers users the unique opportunity to wield meticulously crafted digital firearms that mirror their real-world counterparts in look, feel, and function, complete with authentic sounds and recoil.\n\nBut \"Feeling Fire Gun\" goes far beyond simple target practice. It empowers users to become architects of their virtual realms, allowing them to conjure, manipulate, and interact with a diverse array of objects. From crafting intricate structures to designing challenging obstacle courses, the only limit is the user's imagination.\n\nSet in an expansive, multi-terrain world, players can traverse their creations through various modes of locomotion, be it walking, teleporting, or even defying gravity. This freedom of movement complements the app's versatile gameplay modes, which include a sandbox-style free mode for uninhibited exploration and creation, a series of skill-testing challenges, and a dynamic multiplayer environment for shared experiences.", "short_description": "\"Feeling Fire Gun\" isn't just a game; it's a platform that bridges the gap between realistic simulation and creative expression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tttcorporation.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TTTcorporation", "support_website_url": null, "website_url": "https://tttcorporation.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCAL