yfzX-H4usIAWW1KFyN6Y0Okc4jQ&oe=66E6C57B"}, {"file_name": "2560x1440 (3).png", "id": "866033444949053", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974681_866033448282386_1060735077748256107_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XseohHU-Vg0Q7kNvgH2uUBK&_nc_ht=scontent.oculuscdn.com&oh=00_AYD-Ypqpmi_HFKt1-ByHLIwqkwlhc3crnOza8Ax1zVYELQ&oe=66E6C018"}, {"file_name": "2560x1440 (4).png", "id": "443547678685303", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974547_443547682018636_6322347026334124666_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pHthS-36izEQ7kNvgEkWrRX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAESWqiDndkQu86LPJ3aATbola_EyXzmUKE5IJbxBQQQg&oe=66E6AAF4"}, {"file_name": "2560x1440 (5).png", "id": "878891567525558", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974867_878891570858891_8040644650588623139_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0xq4sbvq6W4Q7kNvgEl4Mx4&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCL_96zLOVi_jPUwBV7BvvCgW_Bxf8CjnrysKHmry8Hg&oe=66E6C201"}, {"file_name": "2560x1440 (6).png", "id": "522360993660696", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974782_522361000327362_1265686494838610386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1PDgyXBzdCoQ7kNvgEL0xI5&_nc_ht=scontent.oculuscdn.com&oh=00_AYAATwyWVHKd7HqbwhiDWwxwxiAYin2GltDN7e3StBbyUQ&oe=66E6C442"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (7).png", "id": "859600769565255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65228806_859600772898588_578693433817766136_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gji9Srh75YEQ7kNvgFHRGr8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHQJ0WfN57ZunOnzNis-EE7aYjRQHylitk8kT7DuxPUg&oe=66E6D81A"}, "display_name": "Feeling Fire Gun", "keywords": ["FeelingFireGun", "TTTcorporation"], "long_description": "\"Feeling Fire Gun\" is a groundbreaking VR application that seamlessly melds hyper-realistic firearm simulation with boundless creativity in a vast virtual playground. This immersive experience offers users the unique opportunity to wield meticulously crafted digital firearms that mirror their real-world counterparts in look, feel, and function, complete with authentic sounds and recoil.\n\nBut \"Feeling Fire Gun\" goes far beyond simple target practice. It empowers users to become architects of their virtual realms, allowing them to conjure, manipulate, and interact with a diverse array of objects. From crafting intricate structures to designing challenging obstacle courses, the only limit is the user's imagination.\n\nSet in an expansive, multi-terrain world, players can traverse their creations through various modes of locomotion, be it walking, teleporting, or even defying gravity. This freedom of movement complements the app's versatile gameplay modes, which include a sandbox-style free mode for uninhibited exploration and creation, a series of skill-testing challenges, and a dynamic multiplayer environment for shared experiences.", "short_description": "\"Feeling Fire Gun\" isn't just a game; it's a platform that bridges the gap between realistic simulation and creative expression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tttcorporation.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TTTcorporation", "support_website_url": null, "website_url": "https://tttcorporation.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCAL