le_name": "2560x1440 (1).png", "id": "1242580393405131", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974594_1242580396738464_7600342908274045866_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qeiDskLFaN0Q7kNvgGjl14N&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEBwihMHTCCRBVNoDOJAp8eFWzqjz50YWbHtvLjdgoGQ&oe=677678FB"}, {"file_name": "2560x1440 (3).png", "id": "866033444949053", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974681_866033448282386_1060735077748256107_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJibPTXcUuEQ7kNvgH5U8n7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB_fH267tAdDhiRgLjxKpXwevv1DMLHO85ChMX1cL0nBA&oe=67767398"}, {"file_name": "2560x1440 (4).png", "id": "443547678685303", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974547_443547682018636_6322347026334124666_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_xey0QW1eBQQ7kNvgFDXrzH&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBwaGcqFgiYbtYAPpISFZ_6wem2qlywoH0OEFS6e42lvQ&oe=677696B4"}, {"file_name": "2560x1440 (5).png", "id": "878891567525558", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974867_878891570858891_8040644650588623139_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ACIg7RzI80Q7kNvgF4ON_t&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBCiAWHdgw5yzQmt2rbOn1t3e_-fu2rPSnr6AXTvSucaA&oe=67767581"}, {"file_name": "2560x1440 (6).png", "id": "522360993660696", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974782_522361000327362_1265686494838610386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s1FcA3vHHdcQ7kNvgGnA-ZO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCPcC1f0xsqDNtqcxhANbge3HQmufYE5YBOhziYQdojng&oe=677677C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (7).png", "id": "859600769565255", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/65228806_859600772898588_578693433817766136_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r5gv8aS1oyIQ7kNvgHZauYm&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDVOQWrZ09yd4jMdyqQpuzlIHWaIL8u4lRkFKOkYeF1SA&oe=67768B9A"}, "display_name": "Feeling Fire Gun", "keywords": ["FeelingFireGun", "TTTcorporation"], "long_description": "\"Feeling Fire Gun\" is a groundbreaking VR application that seamlessly melds hyper-realistic firearm simulation with boundless creativity in a vast virtual playground. This immersive experience offers users the unique opportunity to wield meticulously crafted digital firearms that mirror their real-world counterparts in look, feel, and function, complete with authentic sounds and recoil.\n\nBut \"Feeling Fire Gun\" goes far beyond simple target practice. It empowers users to become architects of their virtual realms, allowing them to conjure, manipulate, and interact with a diverse array of objects. From crafting intricate structures to designing challenging obstacle courses, the only limit is the user's imagination.\n\nSet in an expansive, multi-terrain world, players can traverse their creations through various modes of locomotion, be it walking, teleporting, or even defying gravity. This freedom of movement complements the app's versatile gameplay modes, which include a sandbox-style free mode for uninhibited exploration and creation, a series of skill-testing challenges, and a dynamic multiplayer environment for shared experiences.", "short_description": "\"Feeling Fire Gun\" isn't just a game; it's a platform that bridges the gap between realistic simulation and creative expression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tttcorporation.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TTTcorporation", "support_website_url": null, "website_url": "https://tttcorporation.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context