le_name": "2560x1440 (1).png", "id": "1242580393405131", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974594_1242580396738464_7600342908274045866_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TNA9gAOXslQQ7kNvgH_MdKz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtdtjGULwXlAQgcK1D140vRKDXPUjtyFhWpIlYfOj_8A&oe=671F75FB"}, {"file_name": "2560x1440 (3).png", "id": "866033444949053", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974681_866033448282386_1060735077748256107_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLva98svjvcQ7kNvgFR4CFf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUqX9QQDtr3NWjmoRmirGQ6Tn4ULZJaosvQ6d25R9gSg&oe=671F7098"}, {"file_name": "2560x1440 (4).png", "id": "443547678685303", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974547_443547682018636_6322347026334124666_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8NGjp--CuEkQ7kNvgG8Atju&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANLi8zxy-S6aPz-cguyIZ8ves3zgnNrGLNFd5HEi95RA&oe=671F93B4"}, {"file_name": "2560x1440 (5).png", "id": "878891567525558", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_878891570858891_8040644650588623139_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vy7gQsZkBlQQ7kNvgG_DEjW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5NN38VSql0xbbm_rwE9Sn7Kg52q7aUcq7LRLeXLbc8A&oe=671F7281"}, {"file_name": "2560x1440 (6).png", "id": "522360993660696", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974782_522361000327362_1265686494838610386_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7hPyYw4jwg4Q7kNvgF9EDNv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoMdcbIYdRHU7gHb-qSRjTGAq8FAp1pENU23JO7WYBWg&oe=671F74C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 (7).png", "id": "859600769565255", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65228806_859600772898588_578693433817766136_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wOwgRFubvtgQ7kNvgEASCMY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBH_kj0OPFqzoxql7AnWPnLGOOu79K0lo3kVgiI7r164Q&oe=671F889A"}, "display_name": "Feeling Fire Gun", "keywords": ["FeelingFireGun", "TTTcorporation"], "long_description": "\"Feeling Fire Gun\" is a groundbreaking VR application that seamlessly melds hyper-realistic firearm simulation with boundless creativity in a vast virtual playground. This immersive experience offers users the unique opportunity to wield meticulously crafted digital firearms that mirror their real-world counterparts in look, feel, and function, complete with authentic sounds and recoil.\n\nBut \"Feeling Fire Gun\" goes far beyond simple target practice. It empowers users to become architects of their virtual realms, allowing them to conjure, manipulate, and interact with a diverse array of objects. From crafting intricate structures to designing challenging obstacle courses, the only limit is the user's imagination.\n\nSet in an expansive, multi-terrain world, players can traverse their creations through various modes of locomotion, be it walking, teleporting, or even defying gravity. This freedom of movement complements the app's versatile gameplay modes, which include a sandbox-style free mode for uninhibited exploration and creation, a series of skill-testing challenges, and a dynamic multiplayer environment for shared experiences.", "short_description": "\"Feeling Fire Gun\" isn't just a game; it's a platform that bridges the gap between realistic simulation and creative expression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tttcorporation.xyz/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TTTcorporation", "support_website_url": null, "website_url": "https://tttcorporation.xyz/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context