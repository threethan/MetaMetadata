 audio. This experience is designed for headphones.\n\nSisters is an official Sundance 2016 Selection and will be shown at New Frontiers in January along with the next chapter of the Sisters' story.\n\n-Designed specifically for mobile VR\n-Simple look-based controls that allows for easy pick up and play\n-Look around 360 degrees in a spooky digitally-painted environment\n-An environment that knows and responds to what you are looking at\n-Binaural and directional audio", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "Otherworld Interactive", "support_website_url": null, "website_url": "http://otherworldinteractive.com/project-view/sisters/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "679642293189045"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1537189409697720", "version": "1.6"}, "id": "1042811322430952", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "956122117804455", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1537189409697720"}, "release_status": "RELEASED