set": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2307085352735834", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8635730473204592"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2379584879036490"}]}, "change_log": null, "created_date": 1720099954, "id": "7590773897700260", "version": "2.2.260639-release", "version_code": 202260639, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2307085352735834", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8635730473204592"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2379584879036490"}]}, "change_log": "Hello everyone!\nHere are some additional hotfix changes for the 2.2 patch, primarily concerning passthrough.\nUnfortunately, to fix the passthrough issues we've seen, we've had to reduce the supported refresh rate for Quest 3 from 120 Hz to 90 Hz.\nWe'll see if we can increase the refresh rate on Quest 3 again in the future, without reintroducing any passthrough issues.\nYou can still enforce a 120 Hz refresh rate yourself through external means, like you can on Quest 2.\n\n## Game Updates\n- Reduced the supported refresh rate for Quest 3 from 120 Hz to 90 Hz.\n- Made the Passthrough toggle in the Settings menu toggle passthrough for matches again, rather than simply enabling passthrough-toggling by pressing X+A in matches.\n- Made pressing X+A toggle the passthrough setting when in the main menu too, making it clear that the UI toggle and X+A are equivalent.\n\n## Bug Fixes\n- Fixed an issue where toggling passthrough on Quest 3 could freeze the game.\n- Fixed an issue with passthrough only showing black after visiting the Ozo Lounge.\n- Reduced the risk of the Resolution Discover menu button remaining in matches.", "created_date": 1704961051, "id": "6820831438027847", "version": "2.2.240432-release", "version_code": 202240432, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}