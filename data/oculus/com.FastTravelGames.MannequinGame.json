02631119827554"}]}, "id": "226569076087947"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "6179032068838054"}]}, "id": "4223501191020606"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4046879905345967"}]}, "id": "1023867758136635"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2169117459856176"}]}, "id": "2801619166571092"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2562090053828017"}]}, "id": "445075516196597"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2439217169469931"}]}, "id": "382467702471701"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2339909156084669"}]}, "id": "422776951666188"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2096570290365140"}]}, "id": "1959178447469481"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1713028385425037"}]}, "id": "2097291253838043"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1255051101208827"}]}, "id": "648248292041754"}]}}, "firstRevision": {"nodes": [{"application": {"id": "7028027297235918", "release_date": 1726156740, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 4}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8518974368141196"}, "id": "3578542799081562"}]}}, "binary": null, "live_binary": null, "created_date": 1726557260, "id": "8444456248926342", "is_initial_release": false, "name_with_fallback": "v16", "pdp_metadata_with_fallback": {"version": 16, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8444614355577198"}, "release_status": "RELEASED", "id": "7028027297235918"}, "id": "8444614355577198", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7028027297235918", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "139645169217120"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "8424270184296635", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mannequin", "keywords": ["mannequin", "aliens", "multijugador", "escondidas", "cazadeobjetos"], "long_description": "**Mannequin** es un juego de sigilo de RV y multijugador de hasta 2c3.\n\nDos agentes de \u00e9lite deben cazar mannequins: aliens metamorfos que se esconden y simulan ser estatuas. \n\nAs\u00ed sorprenden a los agentes desprevenidos y los congelan. Los agentes, que deber\u00e1n diferenciar aliados de enemigos, usan tecnolog\u00eda de vanguardia para escanear a los mannequins y eliminarlos.\n\n{1132185024719502}\n\nSi le disparan a un humano, sus armas se atascar\u00e1n y quedar\u00e1n expuestos. El \u00faltimo equipo en pie gana el juego.\n\n{2834702530013123}\n\n# EL MUNDO PARALIZADO\nEl mundo est\u00e1 en crisis. Algunos lugares se detuvieron en el tiempo y la gente se convirti\u00f3 en estatuas. Una presencia alien est\u00e1 detr\u00e1s de esto, por lo que se envi\u00f3 a agentes especiales para eliminar esta amenaza antes de que se conviertan en las pr\u00f3ximas v\u00edctimas. \n\n{7275895139186656}\n\n\n# POSA POR TU VIDA\n{7674903165905243}\nCazados por los humanos, los mannequins usan habilidades supernaturales para burlar a los agentes. Usa tu casco y tus controles para posar y camuflarte entre ellos, at\u00e1calos cuando menos lo esperen y cong\u00e9lalos al tocarlos.\n\n\n# ELIMINA LA AMENAZA\nLos agentes est\u00e1n a la caza. Sus lectores CEM apuntan a los mannequins, pero distinguir entre aliado y enemigo ser\u00e1 cuesti\u00f3n de instinto. Con munici\u00f3n limitada, si disparas a un aliado, tu arma se atascar\u00e1, por lo que los mannequins podr\u00e1n atacarte.\n\n{1570182393567047}\n\n\n# COLABORA EN EQUIPO, MUERE EN SOLITARIO\nEl trabajo en equipo es clave. Como alien, usa los extractores de energ\u00eda para ver las ubicaciones de los agentes. Si no act\u00faas con rapidez, los agentes tendr\u00e1n la ventaja.\n\n{943422967577230}", "short_description": "Mannequin es un juego de sigilo de RV multijugador de hasta 2c3.\n\nDos agentes de \u00e9lite deben cazar mannequins: aliens metamorfos que se esconden y simulan ser estatuas. \n\nAs\u00ed sorprenden a los agentes desprevenidos y los congelan con un toque. Los agentes, que deber\u00e1n diferenciar a los aliados de los enemigos, usan tecnolog\u00eda de vanguardia para escanear a los mannequins y eliminarlos. Si le disparan a un humano, sus armas se atascar\u00e1n y quedar\u00e1n expuestos. El \u00faltimo equipo en pie gana el juego."}, {"images": {"nodes": []}, "id": "3874300466230435", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mannequin", "keywords": ["mannequin", "aliens", "multiplayer", "prophunt", "versteckspiel"], "long_description": "Mannequin ist ein Stealth-VR-Spiel f\u00fcr bis zu 2 gegen 3 Spieler.\n\nZwei Elite-Agenten jagen Mannequins: Aliens, die sich als menschliche Statuen tarnen.\n\nSie \u00fcberfallen unachtsame Agenten und k\u00f6nnen sie mit der kleinsten Ber\u00fchrung einfrieren lassen. Agenten nutzen daher High-Tech-Scanner, um die Mannequins zu enttarnen und zu erschie\u00dfen. \n\n{315771294929971}\n\nWer ist Freund, wer ist Feind? Wer versehentlich einen Menschen trifft, kann nicht mehr schie\u00dfen! Welches Team gewinnt das Katz-und-Maus-Spiel?\n\n{955549766049508}\n\n# DIE WELT STEHT STILL\nKrisen ersch\u00fcttern die Welt. An einigen Orten hat die Zeit angehalten, Menschen werden zu leblosen Statuen. Dahinter stecken au\u00dferirdische Wesen! Spezialagenten werden ausgesandt: K\u00f6nnen sie die Bedrohung ausl\u00f6schen, bevor sie selbst zu Opfern werden?\n\n{734731378733130}\n\n\n# W\u00c4HLE DEINE POSE\nMannequins k\u00f6nnen dank au\u00dferirdischer F\u00e4higkeiten die Agenten \u00fcberrumpeln. Nutze Headset und Controller, um \u00fcberzeugende Posen einzunehmen und nicht aufzufallen. Schlage zu, wenn die Agenten es am wenigstens erwarten, und friere sie mit deiner Ber\u00fchrung ein.\n\n{7554132404694026}\n\n\n# HALTE DIE ALIEN-BEDROHUNG AUF\nMit ihren EMF-Ger\u00e4ten k\u00f6nnen Agenten die Mannequins aufsp\u00fcren, doch am Ende kommt es auf den Instinkt an. Die Munition ist begrenzt und versehentliche Sch\u00fcsse auf Menschen st\u00f6ren deine Waffe, was den Mannequins die perfekte Gelegenheit zum Angriff gibt.\n\n{962951232207873}\n\n\n# K\u00c4MPFT GEMEINSAM\nTeamwork ist alles. Nehmt als Aliens strategisch die Energie-Extraktoren ein, die Agenten-Standorte aufdecken. Doch seid ihr zu langsam, haben die Agenten die Oberhand!\n\n{1127597248446616}", "short_description": "Mannequin ist ein Stealth-VR-Spiel f\u00fcr bis zu 2 gegen 3 Spieler.\n\nZwei Elite-Agenten jagen Mannequins: Aliens, die sich als menschliche Statuen tarnen.\n\nSie \u00fcberfallen unachtsame Agenten und k\u00f6nnen sie mit der kleinsten Ber\u00fchrung einfrieren lassen. Agenten nutzen daher High-Tech-Scanner, um die Mannequins zu enttarnen und zu erschie\u00dfen. Wer ist Freund, wer ist Feind? Wer versehentlich einen Menschen trifft, kann nicht mehr schie\u00dfen! Welches Team gewinnt das Katz-und-Maus-Spiel?"}, {"images": {"nodes": []}, "id": "1531613470783398", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mannequin", "keywords": ["\u30de\u30cd\u30ad\u30f3", "\u30a8\u30a4\u30ea\u30a2\u30f3", "\u30de\u30eb\u30c1\u30d7\u30ec\u30a4", "\u304b\u304f\u308c\u3093\u307c", "\u9b3c\u3054\u3063\u3053"], "long_description": "\u6700\u59272v3\u3067\u904a\u3079\u308b\u30bd\u30fc\u30b7\u30e3\u30eb\u30b9\u30c6\u30eb\u30b9VR\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30b2\u30fc\u30e0\u3001\u300eMannequin\u300f\u3002\n\n\u5909\u8eab\u80fd\u529b\u3092\u6301\u3064\u30a8\u30a4\u30ea\u30a2\u30f3\u300c\u30de\u30cd\u30ad\u30f3\u300d\u3092\u72e9\u308b\u306e\u306f\u3001\u3075\u305f\u308a\u306e\u51c4\u8155\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u3060\u3002\u30de\u30cd\u30ad\u30f3\u306f\u4eba\u9593\u306e\u5f6b\u50cf\u306e\u3088\u3046\u306a\u30dd\u30fc\u30ba\u3092\u3068\u308a\u306a\u304c\u3089\u8eab\u3092\u6f5c\u3081\u3066\u3044\u308b\u3002\n\n\u30de\u30cd\u30ad\u30f3\u305f\u3061\u306f\u6cb9\u65ad\u3057\u305f\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306b\u8972\u3044\u304b\u304b\u308a\u3001\u305f\u3063\u305f\u4e00\u5ea6\u89e6\u308c\u305f\u3060\u3051\u3067\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306e\u52d5\u304d\u3092\u6b62\u3081\u3066\u3057\u307e\u3046\u3002\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306f\u6700\u5148\u7aef\u306e\u88c5\u5099\u3092\u99c6\u4f7f\u3057\u3066\u30de\u30cd\u30ad\u30f3\u3092\u63a2\u3057\u3060\u3057\u3001\u5c04\u6bba\u3059\u308b\u306e\u304c\u4efb\u52d9\u3060\u3002\n\n{503730118655555}\n\n\u305d\u306e\u305f\u3081\u306b\u306f\u6575\u3068\u5473\u65b9\u3092\u898b\u5206\u3051\u306a\u3051\u308c\u3070\u306a\u3089\u306a\u3044\u3002\u4eba\u9593\u3092\u6483\u3064\u3068\u9283\u304c\u4f7f\u3048\u306a\u304f\u306a\u3063\u3066\u3057\u307e\u3044\u3001\u6226\u95d8\u529b\u304c\u4f4e\u4e0b\u3059\u308b\u3002\u6700\u5f8c\u307e\u3067\u6b8b\u3063\u3066\u3044\u305f\u30c1\u30fc\u30e0\u304c\u3053\u306e\u72c2\u6c17\u306e\u304b\u304f\u308c\u3093\u307c\u30b2\u30fc\u30e0\u306e\u52dd\u8005\u3068\u306a\u308b\u3002\n\n{467725579108296}\n\n# \u6642\u304c\u6b62\u307e\u3063\u305f\u4e16\u754c\n\u5730\u7403\u306f\u5371\u6a5f\u306b\u7015\u3057\u3066\u3044\u308b\u3002\u4e00\u90e8\u306e\u5730\u57df\u306e\u6642\u304c\u6b62\u307e\u308a\u3001\u4eba\u9593\u306f\u307e\u3063\u305f\u304f\u52d5\u304b\u306a\u3044\u5f6b\u50cf\u306e\u3088\u3046\u306b\u306a\u3063\u3066\u3057\u307e\u3063\u305f\u306e\u3060\u3002\u3053\u306e\u7570\u5e38\u4e8b\u614b\u306b\u306f\u30a8\u30a4\u30ea\u30a2\u30f3\u304c\u7d61\u3093\u3067\u3044\u308b\u3002\u30a8\u30a4\u30ea\u30a2\u30f3\u305f\u3061\u304c\u6b21\u306a\u308b\u72a0\u7272\u8005\u3092\u751f\u3080\u524d\u306b\u3001\u30b9\u30da\u30b7\u30e3\u30eb\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u304c\u6d3e\u9063\u3055\u308c\u305f\u3002\n\n{1825845184584234}\n\n\n# \u30dd\u30fc\u30ba\u3092\u6c7a\u3081\u308d\n\u4eba\u9593\u306b\u72e9\u3089\u308c\u308b\u3053\u3068\u3068\u306a\u3063\u305f\u30de\u30cd\u30ad\u30f3\u305f\u3061\u306f\u3001\u8d85\u5e38\u80fd\u529b\u3092\u99c6\u4f7f\u3057\u3066\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u3068\u6226\u3046\u3002\u30d8\u30c3\u30c9\u30bb\u30c3\u30c8\u3068\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u3092\u4f7f\u3063\u3066\u30dd\u30fc\u30ba\u3092\u6c7a\u3081\u3001\u4eba\u9593\u305f\u3061\u306e\u4e2d\u306b\u6eb6\u3051\u8fbc\u3082\u3046\u3002\u6cb9\u65ad\u3057\u305f\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u3092\u898b\u3064\u3051\u305f\u3089\u3001\u4e00\u6c17\u306b\u99c6\u3051\u5bc4\u3063\u3066\u30bf\u30c3\u30c1\u3057\u3066\u52d5\u304d\u3092\u6b62\u3081\u308d\u3002\n\n{421293970707058}\n\n\n# \u30a8\u30a4\u30ea\u30a2\u30f3\u306e\u8105\u5a01\u3092\u99c6\u9010\u305b\u3088\n\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306f\u30cf\u30f3\u30bf\u30fc\u3067\u3042\u308b\u3002EMF\u6e2c\u5b9a\u6a5f\u306f\u30de\u30cd\u30ad\u30f3\u304c\u3044\u308b\u65b9\u5411\u3092\u6559\u3048\u3066\u306f\u304f\u308c\u308b\u304c\u3001\u6575\u3068\u5473\u65b9\u3092\u898b\u5206\u3051\u308b\u306b\u306f\u76f4\u611f\u306b\u983c\u308b\u3057\u304b\u306a\u3044\u3002\u5f3e\u6570\u306f\u9650\u3089\u308c\u3066\u3044\u308b\u3046\u3048\u306b\u3001\u4eba\u9593\u3092\u6483\u3064\u3068\u9283\u304c\u4f7f\u3048\u306a\u304f\u306a\u308b\u3002\u305d\u3046\u306a\u308c\u3070\u30de\u30cd\u30ad\u30f3\u3069\u3082\u306e\u990c\u98df\u3060\u3002\n\n{2748208675335854}\n\n\n# \u5354\u529b\u305b\u3088\u3002\u5b64\u7acb\u306f\u6b7b\u3092\u62db\u304f\n\u52dd\u5229\u306e\u9375\u306f\u30c1\u30fc\u30e0\u30ef\u30fc\u30af\u3002\u30a8\u30a4\u30ea\u30a2\u30f3\u3068\u3057\u3066\u6226\u7565\u7684\u306b\u30a8\u30cd\u30eb\u30ae\u30fc\u3092\u62bd\u51fa\u3057\u3001\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306e\u5c45\u5834\u6240\u3092\u628a\u63e1\u3057\u3088\u3046\u3002\u30e2\u30bf\u30e2\u30bf\u3057\u3066\u3044\u308b\u3068\u3001\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306b\u5148\u3092\u884c\u304b\u308c\u3066\u3057\u307e\u3046\u3060\u308d\u3046\u3002\n\n{792574816155816}", "short_description": "\u6700\u59272v3\u3067\u904a\u3079\u308b\u30bd\u30fc\u30b7\u30e3\u30eb\u30b9\u30c6\u30eb\u30b9VR\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u30b2\u30fc\u30e0\u3001\u300eMannequin\u300f\u3002\n\n\u5909\u8eab\u80fd\u529b\u3092\u6301\u3064\u30a8\u30a4\u30ea\u30a2\u30f3\u300c\u30de\u30cd\u30ad\u30f3\u300d\u3092\u72e9\u308b\u306e\u306f\u3001\u3075\u305f\u308a\u306e\u51c4\u8155\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u3060\u3002\u30de\u30cd\u30ad\u30f3\u306f\u4eba\u9593\u306e\u5f6b\u50cf\u306e\u3088\u3046\u306a\u30dd\u30fc\u30ba\u3092\u3068\u308a\u306a\u304c\u3089\u8eab\u3092\u6f5c\u3081\u3066\u3044\u308b\u3002\n\n\u30de\u30cd\u30ad\u30f3\u305f\u3061\u306f\u6cb9\u65ad\u3057\u305f\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306b\u8972\u3044\u304b\u304b\u308a\u3001\u305f\u3063\u305f\u4e00\u5ea6\u89e6\u308c\u305f\u3060\u3051\u3067\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306e\u52d5\u304d\u3092\u6b62\u3081\u3066\u3057\u307e\u3046\u3002\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8\u306f\u6700\u5148\u7aef\u306e\u88c5\u5099\u3092\u99c6\u4f7f\u3057\u3066\u30de\u30cd\u30ad\u30f3\u3092\u63a2\u3057\u3060\u3057\u3001\u5c04\u6bba\u3059\u308b\u306e\u304c\u4efb\u52d9\u3060\u3002\u305d\u306e\u305f\u3081\u306b\u306f\u6575\u3068\u5473\u65b9\u3092\u898b\u5206\u3051\u306a\u3051\u308c\u3070\u306a\u3089\u306a\u3044\u3002\u4eba\u9593\u3092\u6483\u3064\u3068\u9283\u304c\u4f7f\u3048\u306a\u304f\u306a\u3063\u3066\u3057\u307e\u3044\u3001\u6226\u95d8\u529b\u304c\u4f4e\u4e0b\u3059\u308b\u3002\u6700\u5f8c\u307e\u3067\u6b8b\u3063\u3066\u3044\u305f\u30c1\u30fc\u30e0\u304c\u3053\u306e\u72c2\u6c17\u306e\u304b\u304f\u308c\u3093\u307c\u30b2\u30fc\u30e0\u306e\u52dd\u8005\u3068\u306a\u308b\u3002"}, {"images": {"nodes": []}, "id": "860365932734423", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mannequin", "keywords": ["\ub9c8\ub124\ud0b9", "\uc678\uacc4\uc778", "\uba40\ud2f0\ud50c\ub808\uc774\uc5b4", "\uc228\ubc14\uaf2d\uc9c8", "\uc0ac\ubb3c\ud654\uc228\ubc14\uaf2d\uc9c8"], "long_description": "Mannequin\uc740 2vs3 \uad6c\ub3c4\uc758 \uc18c\uc15c \uc7a0\uc785 VR \uba40\ud2f0\ud50c\ub808\uc774\uc5b4 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\n\ub9c8\ub124\ud0b9\uc740 \uc778\uac04 \ud749\ub0b4\ub97c \ub0b4\uba74\uc11c \uad70\uc911\uc5d0 \uc11e\uc778 \ucc44 \uc790\uc2e0\uc744 \uc228\uae30\ub294 \ubcc0\uc2e0\ud615 \uc678\uacc4\uc778\uc73c\ub85c, \uc774\ub7ec\ud55c \ub9c8\ub124\ud0b9\uc744 \ub450 \uba85\uc758 \uc815\uc608 \uc5d0\uc774\uc804\ud2b8\uac00 \uc218\uc0c9\ud558\uac8c \ub429\ub2c8\ub2e4. \n\n\ub9c8\ub124\ud0b9\uc740 \ubc29\uc2ec\ud55c \uc5d0\uc774\uc804\ud2b8\ub97c \uc2b5\uaca9\ud574 \ub2e8 \ud55c \ubc88\uc758 \uc811\ucd09\ub9cc\uc73c\ub85c \uc5d0\uc774\uc804\ud2b8\ub97c \uc5bc\ub824\ubc84\ub9ac\ub294 \ub2a5\ub825\uc774 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9ac\uace0 \uc5d0\uc774\uc804\ud2b8\ub294 \ucd5c\ucca8\ub2e8 \uc7a5\ube44\ub85c \ubb34\uc7a5\ud574 \ub9c8\ub124\ud0b9\uc744 \uc2a4\uce94\ud55c \ub4a4 \ucc98\uce58\ud574 \ubc84\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \n\n{1221163549265503}\n\n\uc989, \uc5d0\uc774\uc804\ud2b8\uc5d0\uac8c \ud53c\uc544\uc2dd\ubcc4\uc740 \ud544\uc218\ub77c\uace0 \ud560 \uc218 \uc788\uaca0\uc8e0. \uc778\uac04\uc744 \ub9de\ucd94\uac8c \ub418\uba74 \ucd1d\uae30\uac00 \ubb34\ub825\ud654\ub418\uba74\uc11c \uc5d0\uc774\uc804\ud2b8 \uc5ed\uc2dc \ucde8\uc57d\ud574\uc9d1\ub2c8\ub2e4. \uadf8\ub807\uac8c \ucad3\uace0 \ucad3\uae30\ub294 \uad11\ub780\uc758 \uac8c\uc784\uc740 \ub9c8\uc9c0\ub9c9\uae4c\uc9c0 \ub0a8\uc740 \ud300\uc774 \uc2b9\ub9ac\ub97c \uac70\uba38\uc950\uac8c \ub429\ub2c8\ub2e4.\n\n{1104764347451120}\n\n# \uba48\ucdb0\ubc84\ub9b0 \uc138\uc0c1\n\uc704\uae30\uac00 \uc804 \uc138\uacc4\ub97c \ub4a4\ub36e\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc77c\ubd80 \uc9c0\uc5ed\uc758 \uc2dc\uac04\uc740 \uba48\ucd98 \uc0c1\ud0dc\ub85c, \uc0ac\ub78c\ub4e4\uc744 \uc6c0\uc9c1\uc774\uc9c0 \uc54a\ub294 \ub3d9\uc0c1\uc73c\ub85c \ub9cc\ub4e4\uc5b4 \ubc84\ub9ac\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9ac\uace0 \uc774\ub7ec\ud55c \uc774\uc0c1 \ud604\uc0c1\uc758 \ubc30\ud6c4\uc5d0\ub294 \uc678\uacc4\uc758 \uc874\uc7ac\uac00 \uc790\ub9ac \uc7a1\uace0 \uc788\uc2b5\ub2c8\ub2e4. \uc790\uc2e0\ub4e4\uc774 \ub2e4\uc74c \ud76c\uc0dd\uc591\uc774 \ub418\uae30 \uc804\uc5d0 \uc774\ub7ec\ud55c \uc704\ud611\uc744 \uadfc\uc808\ud558\uae30 \uc704\ud574 \ud2b9\uc218 \uc5d0\uc774\uc804\ud2b8\uac00 \ud30c\uacac\ub429\ub2c8\ub2e4.\n\n{1184966555718660}\n\n\n# \uc790\uc138\ub97c \ucde8\ud558\ub77c\n\uc778\ub958\uc758 \uc0ac\ub0e5\uac10\uc774 \ub41c \ub9c8\ub124\ud0b9\uc740 \ucd08\uc790\uc5f0\uc801\uc778 \ub2a5\ub825\uc744 \uc0ac\uc6a9\ud574 \uc5d0\uc774\uc804\ud2b8\ub97c \uc0c1\ub300\ub85c \uc6b0\uc704\ub97c \uc810\ud569\ub2c8\ub2e4. \ud5e4\ub4dc\uc14b\uacfc \ucee8\ud2b8\ub864\ub7ec\ub97c \uc0ac\uc6a9\ud574 \uc790\uc138\ub97c \ucde8\ud558\uace0 \uad6c\uae09\ub300\uc6d0\ub4e4 \uc0ac\uc774\uc5d0 \uc11e\uc5ec\ubcf4\uc138\uc694. \uc5d0\uc774\uc804\ud2b8\uac00 \ubc29\uc2ec\ud558\uace0 \uc788\uc744 \ub54c \uacf5\uaca9\ud558\uc138\uc694. \uc55e\uc73c\ub85c \ub6f0\uccd0\ub098\uac00 \uc190\uc73c\ub85c \ud130\uce58\ud574 \uc5d0\uc774\uc804\ud2b8\ub97c \uc5bc\ub9ac\ub294 \uac83\ub3c4 \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\n{3788924631336258}\n\n\n# \uc678\uacc4\uc758 \uc704\ud611\uc744 \uc800\uc9c0\ud558\ub77c\n\uc5d0\uc774\uc804\ud2b8\uac00 \uc0ac\ub0e5\uc5d0 \ub098\uc12d\ub2c8\ub2e4. \ubb3c\ub860 \uc5d0\uc774\uc804\ud2b8\uac00 \ub4e4\uace0 \uc788\ub294 \uc804\uc790\uae30\ud30c \ud310\ub3c5\uae30\uac00 \ub9c8\ub124\ud0b9\uc758 \uc704\uce58\ub97c \uc9c0\uc2dc\ud574 \uc8fc\uae30\ub294 \ud558\uc9c0\ub9cc \uacb0\uad6d \ud53c\uc544\uc758 \uad6c\ubd84\uc740 \ubcf8\ub2a5\uc5d0 \ub9e1\uaca8\uc57c \ud569\ub2c8\ub2e4. \ud0c4\uc57d\uc774 \uc81c\ud55c\ub41c \ub370\ub2e4\uac00 \uc778\uac04\uc744 \uc3d8\uba74 \ucd1d\uae30\uac00 \ubb34\ub825\ud654\ub418\uc5b4 \ub9c8\ub124\ud0b9\uc774 \uacf5\uaca9\ud560 \uae30\ud68c\uac00 \uc0dd\uae38 \ud14c\ub2c8\uae4c\uc694.\n\n{359082756720082}\n\n\n# \ud568\uaed8 \uc77c\ud558\uace0, \ud640\ub85c \uc8fd\uc5b4\ub77c\n\ud300\uc6cc\ud06c\ub294 \ud544\uc218\uc785\ub2c8\ub2e4. \uc678\uacc4\uc778\uc758 \uc785\uc7a5\uc774\ub77c\uba74 \uc5d0\ub108\uc9c0 \ucd94\ucd9c\uae30\ub97c \uc810\ub839\ud558\uc5ec \uc5d0\uc774\uc804\ud2b8\uc758 \uc704\uce58\ub97c \ud30c\uc545\ud560 \uc218 \uc788\ub3c4\ub85d \uc804\ub7b5\uc744 \uc138\uc6b0\uc138\uc694. \uc2e0\uc18d\ud558\uac8c \ud589\ub3d9\ud558\uc9c0 \uc54a\ub294\ub2e4\uba74, \uc5d0\uc774\uc804\ud2b8\uc5d0\uac8c \uc6b0\uc704\ub97c \ube8f\uae30\uac8c \ub429\ub2c8\ub2e4.\n\n{327874256800989}", "short_description": "Mannequin\uc740 2vs3 \uad6c\ub3c4\uc758 \uc18c\uc15c \uc7a0\uc785 VR \uba40\ud2f0\ud50c\ub808\uc774\uc5b4 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\n\ub9c8\ub124\ud0b9\uc740 \uc778\uac04 \ud749\ub0b4\ub97c \ub0b4\uba74\uc11c \uad70\uc911\uc5d0 \uc11e\uc778 \ucc44 \uc790\uc2e0\uc744 \uc228\uae30\ub294 \ubcc0\uc2e0\ud615 \uc678\uacc4\uc778\uc73c\ub85c, \uc774\ub7ec\ud55c \ub9c8\ub124\ud0b9\uc744 \ub450 \uba85\uc758 \uc815\uc608 \uc5d0\uc774\uc804\ud2b8\uac00 \uc218\uc0c9\ud558\uac8c \ub429\ub2c8\ub2e4. \n\n\ub9c8\ub124\ud0b9\uc740 \ubc29\uc2ec\ud55c \uc5d0\uc774\uc804\ud2b8\ub97c \uc2b5\uaca9\ud574 \ub2e8 \ud55c \ubc88\uc758 \uc811\ucd09\ub9cc\uc73c\ub85c \uc5d0\uc774\uc804\ud2b8\ub97c \uc5bc\ub824\ubc84\ub9ac\ub294 \ub2a5\ub825\uc774 \uc788\uc2b5\ub2c8\ub2e4. \uadf8\ub9ac\uace0 \uc5d0\uc774\uc804\ud2b8\ub294 \ucd5c\ucca8\ub2e8 \uc7a5\ube44\ub85c \ubb34\uc7a5\ud574 \ub9c8\ub124\ud0b9\uc744 \uc2a4\uce94\ud55c \ub4a4 \ucc98\uce58\ud574 \ubc84\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc989, \uc5d0\uc774\uc804\ud2b8\uc5d0\uac8c \ud53c\uc544\uc2dd\ubcc4\uc740 \ud544\uc218\ub77c\uace0 \ud560 \uc218 \uc788\uaca0\uc8e0. \uc778\uac04\uc744 \ub9de\ucd94\uac8c \ub418\uba74 \ucd1d\uae30\uac00 \ubb34\ub825\ud654\ub418\uba74\uc11c \uc5d0\uc774\uc804\ud2b8 \uc5ed\uc2dc \ucde8\uc57d\ud574\uc9d1\ub2c8\ub2e4. \uadf8\ub807\uac8c \ucad3\uace0 \ucad3\uae30\ub294 \uad11\ub780\uc758 \uac8c\uc784\uc740 \ub9c8\uc9c0\ub9c9\uae4c\uc9c0 \ub0a8\uc740 \ud300\uc774 \uc2b9\ub9ac\ub97c \uac70\uba38\uc950\uac8c \ub429\ub2c8\ub2e4."}, {"images": {"nodes": []}, "id": "718888107090570", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mannequin", "keywords": ["mannequin", "extraterrestres", "multijoueur", "cachecache", "chasseauxaccessoires"], "long_description": "**Mannequin** est un jeu en RV multijoueur social et furtif en 2 contre 3.\n\nDeux agents d'\u00e9lite traquent les mannequins, des extraterrestres m\u00e9tamorphes qui se font passer pour des statues humaines.\n\n{863906755567648}\n\nIls tendent des embuscades aux agents, les figeant d'un seul geste. Les agents utilisent une technologie de pointe pour scanner et tuer les mannequins. Ils doivent distinguer les alli\u00e9s des ennemis et leurs armes s'enrayent s'ils tirent sur un humain. Les survivants gagnent la partie.\n\n{947965570454310}\n\n# UN MONDE IMMOBILE\nC'est la crise mondiale. Des lieux sont fig\u00e9s dans le temps, peupl\u00e9s de statues inertes. Cette anomalie est due \u00e0 une pr\u00e9sence extraterrestre. Des agents sp\u00e9ciaux sont envoy\u00e9s pour \u00e9radiquer la menace avant d'en devenir les prochaines victimes.\n\n{360445060372423}\n\n\n# PRENEZ LA POSE\nLes mannequins utilisent leurs pouvoirs surnaturels pour se d\u00e9barrasser des agents qui les traquent. Utilisez votre casque et vos manettes pour prendre la pose et vous fondre dans le paysage. Attaquez les agents par surprise pour les figer de la main.\n\n{969083838060419}\n\n\n# EXTERMINEZ LES EXTRATERRESTRES\nLes agents sont en chasse. Les d\u00e9tecteurs de CEM localisent les mannequins, mais distinguer les alli\u00e9s des ennemis rel\u00e8ve de l'instinct. Les munitions sont limit\u00e9es et tirer sur un humain enraye votre arme, ce qui permet \u00e0 l'ennemi de r\u00e9agir.\n\n{434286089343791}\n\n\n# UNIS DANS L'EFFORT, SEUL DANS LA MORT\nLa collaboration est vitale. Trouvez des strat\u00e9gies pour r\u00e9cup\u00e9rer les extracteurs d'\u00e9nergie afin de localiser un agent. Faites vite ou les agents prendront l'avantage.\n\n{362646336703724}", "short_description": "Mannequin est un jeu en RV multijoueur social et furtif en 2 contre 3.\n\nDes agents d'\u00e9lite traquent les mannequins, des extraterrestres m\u00e9tamorphes qui se font passer pour des statues humaines.\n\nIls tendent des embuscades aux agents, les figeant sur place d'un seul geste. Les agents utilisent une technologie de pointe pour scanner et tuer les mannequins. Ils doivent distinguer leurs alli\u00e9s de leurs ennemis et leurs armes s'enrayent s'ils tirent sur un humain. Les survivants gagnent la partie."}, {"images": {"nodes": [{"file_name": "Mannequin_Meta_CoverPortrait_1008x1440.png", "id": "8275649235823677", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035469_8275649242490343_1026974330520491470_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mVXZ9NkBqksQ7kNvgHW0wvN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjdc0tAOuwfup9Gbad4ZvWLT1HwoGB-Opgj4wt_QartA&oe=66FE7CFD"}, {"file_name": "Mannequin_Meta_Logo(transparent)_ 5815x1440.png", "id": "2124251417941676", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566684_2124251421275009_783431658026725640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aCO6Ojq9X9IQ7kNvgGnuaSZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYC99Jzi14DTO9NzMHt4XXyh7fwpeEJUcWVyoQNwmjD0FQ&oe=66FE77EE"}, {"file_name": "Mannequin_Meta_CoverSquare_1440x1440.png", "id": "1038499447514929", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75435286_1038499450848262_7903938542273711187_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rhtNUF7tUC0Q7kNvgHhAcJP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXsww1NzB835XzSfUFxAXe3fIPoCWvmpqCnzzEjSMwXA&oe=66FE9A4F"}, {"file_name": "Mannequin_Meta_MiniLandscape_1080x360.png", "id": "989703136242173", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75240109_989703139575506_3635942121109820153_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bS-IJueN-u8Q7kNvgHPdUas&_nc_ht=scontent.oculuscdn.com&oh=00_AYCD7H3vsR6UYtrHDwt9D-LNNO8LGUuC3dLNiwZoy1TOPA&oe=66FE69E4"}, {"file_name": "Mannequin_Meta_CoverLandscape_2560x1440.png", "id": "535780298818308", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_535780302151641_5155635155753622107_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=doNXz-qP4XEQ7kNvgFdqdW9&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOpKUi7eDOVKAOrl8uFdU2DbkUyHfYR853rP2A0RVb9g&oe=66FE97D3"}, {"file_name": "Mannequin_Meta_HeroCover_3000x900.png", "id": "525262886659138", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036663_525262889992471_6962185119280668171_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0is1T7h7XbkQ7kNvgEzzplW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDt4yLGfe1Ghc_JUUFD7Uf5-TrUoXheE4YSQdDH1mBMeA&oe=66FE7DF2"}, {"file_name": "Mannequin_Meta_Icon_512x512.png", "id": "479974294992186", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974482_479974298325519_5912965332893233718_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8VGbuPnEKwQ7kNvgGxjuC1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFpEUtrqLZ2aNV-Xmycq7jrmpHOVfjWvotYtqWTmSKjA&oe=66FE8B8B"}]}, "id": "452589947813334", "locale": "en_US", "screenshots": [{"file_name": "Mannequin_Screenshot_1.png", "id": "1303193950879469", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031331_1303193954212802_2728484553215051766_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dADXlL9XLDUQ7kNvgFJ-Hcp&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVA5ViDU30czsZSUOcMFdTlG2QEzk9zT_rn9quD_RzGQ&oe=66FE776F"}, {"file_name": "Mannequin_Screenshot_2.png", "id": "1222110222444811", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001656_1222110225778144_5222375355824254929_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tsQ42yoY0lsQ7kNvgFfUsXS&_nc_ht=scontent.oculuscdn.com&oh=00_AYCl_-TetxooC1HZ1OWiSYnc9OpGBLAhRxi2ULTMHOhrGQ&oe=66FE87FB"}, {"file_name": "Mannequin_Screenshot_3.png", "id": "1174469906989168", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982598_1174469910322501_2111842809779599020_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pUDiVyCdqcsQ7kNvgE-rxZQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBk2awcC8FaIMfXtShkf_N_BbojllvMGBq2qmPXBqVSHw&oe=66FE8EC0"}, {"file_name": "Mannequin_Screenshot_4.png", "id": "8207658809327642", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75295751_8207658815994308_5707435043023654255_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bqQDy5qhxKsQ7kNvgG4t82N&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCORCeqI5ZSyIZdSIu7Yr0CY-T7vY_FRTrkTFFZSkqWA&oe=66FE68F5"}, {"file_name": "Mannequin_Screenshot_5.png", "id": "1559785364889309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982598_1559785368222642_9052543604262657421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=66cBQz3okdkQ7kNvgEW2uVp&_nc_ht=scontent.oculuscdn.com&oh=00_AYByaXWqKikpgBMxsE89K-3JHLecteu5EkhStIYZnrWVYA&oe=66FE70C7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mannequin_Launch_Trailer_Thumbnail_2560x1440.png", "id": "530029326183514", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035465_530029329516847_4779225406743813002_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xi-8ojzQ3a4Q7kNvgELPpNY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDb5xeszPQZT_mWTkEr7jXGzAGlgIq7u1B83NAOqhaoxw&oe=66FE6F83"}, "display_name": "Mannequin", "keywords": ["mannequin", "aliens", "multiplayer", "hideandseek", "prophunt"], "long_description": "Mannequin is an up to 2v3 Hide-And-Seek VR FPS multiplayer game.\n\nTwo elite Agents hunt for Mannequins - shape-shifting aliens hiding in plain sight and blending in by posing as human statues. \n\nThey ambush unsuspecting Agents, freezing them in place with a single touch. Agents use cutting edge tech to scan for Mannequins, then shooting to kill. \n\n{384779571278821}\n\nThey must decipher friend from foe. Hit a human and their gun jams, leaving them vulnerable. Last team standing wins in this frantic game of cat and mouse.\n\n{921185979756702}\n\n\n# THE WORLD STANDS STILL\nCrisis engulfs the globe. Select sites have frozen in time, turning people into motionless statues. An alien presence is behind these anomalies. Special Agents are dispatched to eradicate this threat before they become the next victims. \n\n{425153783564662}\n\n\n# STRIKE A POSE\nHunted by mankind, Mannequins use supernatural abilities to get the drop on Agents. Use your headset and controllers to pose and blend in among first responders. Strike when Agents least suspect, dashing forward and freezing them with a touch of a hand.\n\n{649107037377241}\n\n\n# EXTERMINATE THE ALIEN THREAT\nAgents are on the hunt. Their EMF Readers point them towards Mannequins, but telling friend from foe is down to instinct. Not only is ammunition limited, but shooting a human jams your gun, giving Mannequins an opportunity to strike.\n\n{943217627290743}\n\n\n# WORK TOGETHER, DIE ALONE\nTeamwork is essential. Strategize to seize energy extractors as aliens, letting you see an Agent\u2019s location. If you\u2019re not fast enough, Agents gain the upper hand.\n\n{463319056044771}", "short_description": "Mannequin is an up to 2v3 Hide-And-Seek VR FPS game.\n\nTwo elite Agents hunt for Mannequins - shape-shifting aliens hiding in plain sight and blending in by posing as human statues. \n\nThey ambush unsuspecting Agents, freezing them in place with a single touch. Agents use cutting edge tech to scan for Mannequins, then shooting to kill. They must decipher friend from foe. Hit a human and their gun jams, leaving them vulnerable. Last team standing wins in this frantic game of cat and mouse."}]}, "developer_name": "Fast Travel Games", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games", "support_website_url": null, "website_url": "https://www.mannequingame.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8444614355577198"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75435286_1038499450848262_7903938542273711187_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rhtNUF7tUC0Q7kNvgHhAcJP&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvegWiSFJjA2k4nCgzB5DMWLMe_cqNz_R2vmah7QxhzA&oe=66FE9A4F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mannequin", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "15