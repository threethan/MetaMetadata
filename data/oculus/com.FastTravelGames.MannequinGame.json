mwHc-7x-kMO6YohQA1wWIg&oe=66FE74B1"}, {"file_name": "Mannequin_Meta_Screenshot_4_2560x1440.png", "id": "459902636464949", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982665_459902639798282_2001882102406604330_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oP7r17aeq64Q7kNvgGBGmsg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTLwHVcwxcGQ44ZzHN-QatHTKpmNRT2kuKG5Hz1ASuhg&oe=66FE6DFB"}, {"file_name": "Mannequin_Meta_Screenshot_3_2560x1440.png", "id": "939380181226784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035465_939380184560117_1602318544702461580_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qxlQPqAZgCgQ7kNvgH3V-OU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHxxBsATUwokMT9oOuMHzQ813n2xBgSf0Eg3m5p74xsg&oe=66FE8DDE"}, {"file_name": "Mannequin_Meta_Screenshot_5_2560x1440.png", "id": "1728354604234691", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75488372_1728354607568024_8874781946439511479_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rWYqA1fsWnIQ7kNvgEfGb0f&_nc_ht=scontent.oculuscdn.com&oh=00_AYDoo5KeOeD8nBhGWBalpFPGq6ckHVSW_I5usrSxqf-ytA&oe=66FE92E3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mannequin_Gameplay_Sneak-Peek_Thumbnail_2560x1440.png", "id": "2669567039858268", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035392_2669567043191601_6432890739675890615_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2c4L1xKxoCUQ7kNvgFsJSU3&_nc_ht=scontent.oculuscdn.com&oh=00_AYAywoE-pVLTHliTEYw73r_rXKRXv6KqVuLfs0wNgg3T2Q&oe=66FE9F2B"}, "display_name": "Mannequin", "keywords": [], "long_description": "Mannequin is an up to 2v3 asymmetrical VR multiplayer game! Two elite Agents hunt for Mannequins - shape-shifting aliens hiding in plain sight and blending in by posing as human statues. They ambush unsuspecting Agents, freezing them in place with a single touch.\n\nAgents use cutting edge tech to scan for Mannequins, then shooting to kill. They must decipher friend from foe. Hit a human and their gun jams, leaving them vulnerable. Last team standing wins in this frantic game of cat and mouse.\n\nTHE WORLD STANDS STILL\nCrisis engulfs the globe. Select sites have frozen in time, turning people into motionless statues. An alien presence is behind these anomalies. Special Agents are dispatched to eradicate this threat before they become the next victims. \n\nSTRIKE A POSE\nHunted by mankind, Mannequins use supernatural abilities to get the drop on Agents. Use your headset and controllers to pose and blend in among first responders. Strike when Agents least suspect, dashing forward and freezing them with a touch of a hand.\n\nEXTERMINATE THE ALIEN THREAT\nAgents are on the hunt. Their EMF Readers point them towards Mannequins, but telling friend from foe is down to instinct. Not only is ammunition limited, but shooting a human jams your gun, giving Mannequins an opportunity to strike.\n\nWORK TOGETHER, DIE ALONE\nTeamwork is essential. Strategize to seize energy extractors as aliens, letting you see an Agent\u2019s location. If you\u2019re not fast enough, Agents gain the upper hand.", "short_description": "Mannequin is an up to 2v3 asymmetrical VR multiplayer game! Two elite Agents hunt for Mannequins - shape-shifting aliens hiding in plain sight and blending in by posing as human statues. They ambush unsuspecting Agents, freezing them in place with a single touch.\n\nAgents use cutting edge tech to scan for Mannequins, then shooting to kill. They must decipher friend from foe. Hit a human and their gun jams, leaving them vulnerable. Last team standing wins in this frantic game of cat and mouse."}]}, "developer_name": "Fast Travel Games", "developer_privacy_policy_url": "https://www.fasttravelgames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Fast Travel Games", "support_website_url": null, "website_url": "https://www.mannequingame.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "274332603592553