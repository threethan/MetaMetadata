"1638987447017488", "locale": "en_US", "screenshots": [{"file_name": "Catheter Care Simulator_Screenshot_01.png", "id": "604569332231916", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86601734_604569335565249_5743671413200307060_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jO3B39iq9z8Q7kNvgEwbbDL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjqN3xZQVoZ_ExGKr4COgEb9PlqenVnfeh2XogC5f03g&oe=67790EC4"}, {"file_name": "Catheter Care Simulator_Screenshot_02.png", "id": "1643877593215576", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570294_1643877596548909_1069295414423836973_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SI72WsvOwjsQ7kNvgG0OO4q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAwOC9wSHyItSdpIIj75EkhBd0hUeUUA-cz0t08rwTmQ&oe=67790F7E"}, {"file_name": "Catheter Care Simulator_Screenshot_03.png", "id": "933827335373778", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031461_933827338707111_9124653754634805751_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5REEPhDyqFQQ7kNvgF80LmJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuvbjWO46sxtAJ24spTifVjfb499jsIyJ1V54zHayp0Q&oe=67793093"}, {"file_name": "Catheter Care Simulator_Screenshot_04.png", "id": "901820985483286", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982509_901820988816619_6425774836864429240_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02cy_nzbD1YQ7kNvgGJfq4g&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApN0uQzMJUZCpB9hC6KST2B8w7d0PAsDUKLDBd0D6JZA&oe=6779067B"}, {"file_name": "Catheter Care Simulator_Screenshot_05.png", "id": "886121617014550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974527_886121620347883_7839254585831453722_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Txulr6xq6bgQ7kNvgGGEWOJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDII0UY3NLhuKuUIITv7pc0Za_-652Yu1JEJ1FFvuPYow&oe=67792EAB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Catheter Care Simulator_Screenshot_03.png", "id": "2094131637668134", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974455_2094131641001467_8869428404872748230_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pK-jIpvi0poQ7kNvgHg0fZE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxQPcX4afgKEPkFmBHJLvGeWDs82EdTLQMFqIfWwdyVA&oe=67791F5B"}, "display_name": "Catheter Care Simulator", "keywords": ["CNA", "nurse", "nursing", "Catheter", "healthcare"], "long_description": "The Catheter Care Simulator tutorial immerses Certified Nursing Assistant (CNA) trainees in a virtual environment where they can practice and master the essential techniques for providing proper catheter care. This application guides users through the steps of maintaining hygiene, preventing infections, and handling catheter equipment correctly. \n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n#  Learning Objectives:  \n- Remembering the protocols for catheter care \n- Understanding the importance of preventing infections and ensuring patient comfort \n- Applying the correct techniques for cleaning and handling catheters \n- Evaluating the effectiveness of the care provided  \n\nThis thorough approach ensures CNAs are well-prepared to perform catheter care competently and confidently in clinical settings.", "short_description": "Designed to train CNAs in providing proper catheter care through interactive, hands-on practice with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "29103273819286114"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974783_1314556886639641_817213481579079294_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bm8cXsdpXG8Q7kNvgGjqEzW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAErlJ4BBy8rjhUgKggL8XJ_kdLV0Og9N1oTkKK_UlKGQ&oe=67792113"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Catheter Care Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1722615237, "lastRevision": {"nodes": [{"id": "27328969416716572", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"d