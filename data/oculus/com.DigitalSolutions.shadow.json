_sid=6e7a0a&_nc_ohc=o_EuEM8FfAUQ7kNvgF9KG43&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBM0OwmpZASREr-vUgK0NUWsgxMYx1VmSjm9MkKCl5K0g&oe=6703B097"}, {"file_name": "5.png", "id": "1158447621850397", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035353_1158447625183730_6458765565871963951_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oRjS7b6xjJUQ7kNvgFAK9bP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAV2YENKK4gVK0u4XJRDqzPg_zyOJzXsNCE7plnpu9QmQ&oe=6703AEA1"}, {"file_name": "3.png", "id": "430710953030699", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982609_430710956364032_6150975977529824521_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3QzCIkV7_50Q7kNvgHAcIrE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUGQtUMXK86YiDaXdx93iB4_IGPXkdNLvSRoan_SLgfA&oe=6703D517"}, {"file_name": "2.png", "id": "837774275033767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982616_837774278367100_4897090437410338032_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hy0sO_qaHE8Q7kNvgHyxwIP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSoxiES4LaiV-EfQT2lo9v7XtjGTU90EROCxVH5ax1mw&oe=6703DBA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "land-2560x1440.png", "id": "801538871433377", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984470_801538874766710_7104644288614866285_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sVso0LWjetUQ7kNvgEdE1C1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLdmWOJKg1W0rD2BzoQFD77G28a8l1fss8Y_8jw1zR4A&oe=6703C7EE"}, "display_name": "shadow", "keywords": [], "long_description": "Travel through a series of increasingly complex levels, each designed to test your ability to visualize and manipulate 3D structures in a VR environment. With intuitive controls, you can directly interact with the cube and tubes, manipulating them with precision to create clear paths that abide by the rules.\nShadow is not just a game; it's a brain-teasing journey that unfolds within a minimalist, visually stunning universe that evolves as you progress. Each successful connection not only brings satisfaction but also unlocks new levels and complexities. This game ensures that every solution is a burst of dopamine as you see your spatial reasoning skills visibly improve.\nImmersive VR Experience: Feel the thrill of manipulating complex 3D puzzles in a fully immersive VR environment.\nChallenging Gameplay: Master the art of connecting points without intersection, crafting a continuous path through various angles and perspectives.\nProgressive Difficulty: As you advance, the puzzles increase in complexity, offering endless hours of engaging gameplay.\nEducational and Fun: Perfect for puzzle enthusiasts and those looking to sharpen their spatial thinking and geometry skills.\n\nPrepare to stretch your mind and enjoy a unique blend of puzzle-solving and construction in Shadow, where every level is a new opportunity to prove your ingenious problem-solving prowess in the virtual world!", "short_description": "Embark on a mesmerizing puzzle adventure in the virtual world of Shadow, where logic and creativity intertwine. Dive into an immersive experience where you must connect the vertices of a seemingly simple cube using tubes based on orthographic projections. But there's a twist\u2014ensure the tubes do not intersect and remain continuous, challenging your spatial awareness and problem-solving skills."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "