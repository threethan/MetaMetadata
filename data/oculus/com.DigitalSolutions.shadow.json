kNvgHAcIrE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUGQtUMXK86YiDaXdx93iB4_IGPXkdNLvSRoan_SLgfA&oe=6703D517"}, {"file_name": "2.png", "id": "837774275033767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982616_837774278367100_4897090437410338032_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hy0sO_qaHE8Q7kNvgHyxwIP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSoxiES4LaiV-EfQT2lo9v7XtjGTU90EROCxVH5ax1mw&oe=6703DBA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "land-2560x1440.png", "id": "801538871433377", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984470_801538874766710_7104644288614866285_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sVso0LWjetUQ7kNvgEdE1C1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLdmWOJKg1W0rD2BzoQFD77G28a8l1fss8Y_8jw1zR4A&oe=6703C7EE"}, "display_name": "shadow", "keywords": [], "long_description": "Travel through a series of increasingly complex levels, each designed to test your ability to visualize and manipulate 3D structures in a VR environment. With intuitive controls, you can directly interact with the cube and tubes, manipulating them with precision to create clear paths that abide by the rules.\nShadow is not just a game; it's a brain-teasing journey that unfolds within a minimalist, visually stunning universe that evolves as you progress. Each successful connection not only brings satisfaction but also unlocks new levels and complexities. This game ensures that every solution is a burst of dopamine as you see your spatial reasoning skills visibly improve.\nImmersive VR Experience: Feel the thrill of manipulating complex 3D puzzles in a fully immersive VR environment.\nChallenging Gameplay: Master the art of connecting points without intersection, crafting a continuous path through various angles and perspectives.\nProgressive Difficulty: As you advance, the puzzles increase in complexity, offering endless hours of engaging gameplay.\nEducational and Fun: Perfect for puzzle enthusiasts and those looking to sharpen their spatial thinking and geometry skills.\n\nPrepare to stretch your mind and enjoy a unique blend of puzzle-solving and construction in Shadow, where every level is a new opportunity to prove your ingenious problem-solving prowess in the virtual world!", "short_description": "Embark on a mesmerizing puzzle adventure in the virtual world of Shadow, where logic and creativity intertwine. Dive into an immersive experience where you must connect the vertices of a seemingly simple cube using tubes based on orthographic projections. But there's a twist\u2014ensure the tubes do not intersect and remain continuous, challenging your spatial awareness and problem-solving skills."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "mn"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25925491753731653"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572923_428548853100115_4208435210927938740_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U24ZLduVM7QQ7kNvgG2BbEm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC-MjfClk3bUdpKT6Rf94lACzHNNnaUnJMloTI