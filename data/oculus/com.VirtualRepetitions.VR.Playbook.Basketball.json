ly to explore the play from any angle. Interact with your plays in a whole new way, and move from X\u2019s and O\u2019s to a new virtual way to prepare.", "short_description": "Create plays through our Web Application (vreps.us), and watch them through the app in 3D. Experience plays from the perspective of any player on the court, or roam freely to explore the play from any angle. Interact with your plays in a whole new way, and move from X\u2019s and O\u2019s to a new virtual way to prepare."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vreps.us/privacy/", "developer_terms_of_service_url": "https://www.vreps.us/terms/", "publisher_name": "Virtual Repetitions LLC", "support_website_url": "https://www.vreps.us/support/", "website_url": "https://www.vreps.us/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "SPORTS", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4258815724220465"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "999349950869380"}]}, "baseline_offer": {"id": "999349950869380"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1623699960, "status": "PUBLISHED", "id": "999349950869380"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes":