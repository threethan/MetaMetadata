.com&oh=00_AYDH245bZgXwf_I5kRRehvLKfu663y5qwjybvmhcK3wiEw&oe=66CB1F83"}, {"file_name": "screen2.png", "id": "184510720326374", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371509_184510726993040_1864538332546951408_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wV8AflJ1lpkQ7kNvgFzcwuE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQELctMAzw50E4KIY1BBnHOUNoINQ1xiA_wmpopGD4qw&oe=66CB0FDF"}, {"file_name": "screen4.png", "id": "1463964963959026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404387_1463964967292359_1209601555307377530_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SUScQrIQIlwQ7kNvgG8vPlo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCig2J3lohag53UWmGsmzEuThnF7ckwbk8105AWemeagg&oe=66CB0C68"}, {"file_name": "screen3.png", "id": "258935755667723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297580_258935759001056_2813863870203173318_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=coHmxy1CGYgQ7kNvgHkh3e8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEm1zUzORs6p-PAHHnyqlD5WkPqYFaMdwhQD8H0SAxZQ&oe=66CAFCD2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982658_535757437737335_5271675859752528110_n.png", "id": "816059002445368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210893_816059005778701_1392764768497568274_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5UU4wKvKQ24Q7kNvgGsv-Un&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUVPqjbYjiwfs7PZwauf_ByGiJwMPU0VE0V3g92fCcnQ&oe=66CB2AD3"}, "display_name": "The Secret of Retropolis Demo", "keywords": [], "long_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere.\n\nEXPERIENCE IN COMFORT.\nAs a seated experience with intuitive controls, first time VR users will find this game engaging and easy to play. Experienced VR users will find this game casual and relaxing.\n\nSTORY. ART. MUSIC.\nEnter a sprawling retro-futuristic cityscape with an original score, ensemble of voice actors and detailed hand drawn (in VR!) environments.\n\nGOOD \u2018OL ADVENTURE GAME\nBoot up that nostalgia for your favorite 90's point-and-click adventure games. Look around. Find items. Solve puzzles. Keep the past alive.\n\n\n* No robots were harmed in the making of this game.", "short_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://peanutbutton.net/privacy", "developer_terms_of_service_url": null, "publisher_name": "Peanut Button", "support_website_url": "http://peanutbutton.net/", "website_url": "http://peanutbutton.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "PUZZLE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "462641452012006"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031587_556896002160062_6576043756821935546_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NOieJxRM-PoQ7kNvgFpqNXk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpbHyJvCx1XT5Xov4kitJDr90UrqwA4hUQJPklmr3TwQ&oe=66CB1CA1"}, "is_concept": true, "is_test": fa