.com&oh=00_AYDipzyd0B9JO64F7X8W42bldK9x0P0ldoqt0sFe0fiCNQ&oe=66D5AB83"}, {"file_name": "screen2.png", "id": "184510720326374", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371509_184510726993040_1864538332546951408_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJa6XgriLI0Q7kNvgEOIudm&_nc_ht=scontent.oculuscdn.com&oh=00_AYDp_SQhKjJf9n_winqctejWmpteVDzjtS0oy6dpfyMRwQ&oe=66D59BDF"}, {"file_name": "screen4.png", "id": "1463964963959026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404387_1463964967292359_1209601555307377530_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdQP7c5ZioQQ7kNvgGUHPOm&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5vggLqL-c_olsw25589pMaMIZF-BwHb4AYNePZHDfqA&oe=66D59868"}, {"file_name": "screen3.png", "id": "258935755667723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297580_258935759001056_2813863870203173318_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mOuYoSXO6e4Q7kNvgEamYf6&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5NbglW9TQ7zlrWKRr-2gP-Zo0XESjR9uYWGA7ncYkAA&oe=66D588D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38982658_535757437737335_5271675859752528110_n.png", "id": "816059002445368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210893_816059005778701_1392764768497568274_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LowjoPigXo8Q7kNvgHcD1Rp&_nc_ht=scontent.oculuscdn.com&oh=00_AYBssx-32Zz7aBJLx7gW6DDDwYkTpvDdXpjWSd6q8gE43w&oe=66D5B6D3"}, "display_name": "The Secret of Retropolis Demo", "keywords": [], "long_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere.\n\nEXPERIENCE IN COMFORT.\nAs a seated experience with intuitive controls, first time VR users will find this game engaging and easy to play. Experienced VR users will find this game casual and relaxing.\n\nSTORY. ART. MUSIC.\nEnter a sprawling retro-futuristic cityscape with an original score, ensemble of voice actors and detailed hand drawn (in VR!) environments.\n\nGOOD \u2018OL ADVENTURE GAME\nBoot up that nostalgia for your favorite 90's point-and-click adventure games. Look around. Find items. Solve puzzles. Keep the past alive.\n\n\n* No robots were harmed in the making of this game.", "short_description": "The Secret of Retropolis is a VR narrative game of a new kind, a blend of classic point-and-click adventure with immersive cinematography. Embody the witty protagonist of a film noir plot. Meet unforgettable characters. Solve puzzles. Lose yourself in the retro-futuristic atmosphere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://peanutbutton.net/privacy", "developer_terms_of_service_url": null, "publisher_name": "Peanut Button", "support_website_url": "http://peanutbutton.net/", "website_url": "http://peanutbutton.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "PUZZLE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "462641452012006"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031587_556896002160062_6576043756821935546_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pGRLP9HwHFUQ7kNvgG-BZkh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCixLLPR8D24JPywWtcVxGvHZDFwLJk7W2VpnDyTpsJtw&oe=66D5A8A1"}, "is_concept": true, "is_test": fa