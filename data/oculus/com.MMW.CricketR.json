n.com/v/t64.5771-25/39036627_859503166124371_4975963449023296542_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fN6nhZOXQpYQ7kNvgGfbw4t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYD8Sva9WnWwIlggbHHKUIr&oh=00_AYBezU17OfjaT5b1ETk3rjnjjmM6-q_5HGx-P4Nso1fWxQ&oe=66F008CA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 1.png", "id": "851297053639671", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_851297056973004_739677971646288748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jGmssorxm5cQ7kNvgGUnnJ4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYD8Sva9WnWwIlggbHHKUIr&oh=00_AYBlG46TV1e_BD4BvtPqmIi6hlwlfJ0OPZKKMzYyDRMVIA&oe=66EFFEF5"}, "display_name": "CricketR - The Virtual Reality Cricket Game", "keywords": ["Cricket", "CricketSimulation", "VRcricket", "CricketTournaments", "CricketLeague"], "long_description": "Step into the world of CricketR, the most immersive VR cricket experience! With the latest domestic tournament update, you can compete in thrilling local leagues and rise through the ranks from grassroots cricket to championship glory. Practice your batting, bowling, and fielding in world-class stadiums designed to capture every detail of the sport. Whether facing high-stakes tournament matches or honing your skills, CricketR offers a realistic and dynamic cricket experience like never before. Prepare to master the game and become a virtual cricket legend!", "short_description": "Immerse yourself in the latest VR cricket experience with the new domestic tournament update! Hone your skills in realistic stadiums, compete in exciting leagues, and rise through the ranks to become a cricket champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://cricketr.in/privacy", "developer_terms_of_service_url": null, "publisher_name": "Madras MindWorks", "support_website_url": null, "website_url": "http://cricketr.in/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_catego