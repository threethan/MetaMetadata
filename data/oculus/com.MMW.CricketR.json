culuscdn.com&oh=00_AYC46k8qZ5bPHXv8W4KCTjFq1z5jnL261enmz8oMoHIigw&oe=677E6EF6"}, {"file_name": "5.png", "id": "859503162791038", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39036627_859503166124371_4975963449023296542_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kfkSK8eTJIMQ7kNvgHkx-kV&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYA513f2tfENK9NgQHEG8ys7ZXnM5ZOdE2X1c0xA0DbIHA&oe=677E6ACA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 1.png", "id": "851297053639671", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38974663_851297056973004_739677971646288748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z2fHl7tE_McQ7kNvgFB3-YX&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYDxpsmffUYllDF8ACvRORuF2aBEkM-tqXtYbmhh6ce4SA&oe=677E60F5"}, "display_name": "CricketR - The Virtual Reality Cricket Game", "keywords": ["Cricket", "CricketSimulation", "VRcricket", "CricketTournaments", "CricketLeague"], "long_description": "Step into the world of CricketR, the most immersive VR cricket experience! With the latest domestic tournament update, you can compete in thrilling local leagues and rise through the ranks from grassroots cricket to championship glory. Practice your batting, bowling, and fielding in world-class stadiums designed to capture every detail of the sport. Whether facing high-stakes tournament matches or honing your skills, CricketR offers a realistic and dynamic cricket experience like never before. Prepare to master the game and become a virtual cricket legend!", "short_description": "Immerse yourself in the latest VR cricket experience with the new domestic tournament update! Hone your skills in realistic stadiums, compete in exciting leagues, and rise through the ranks to become a cricket champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://cricketr.in/privacy", "developer_terms_of_service_url": null, "publisher_name": "Madras MindWorks", "support_website_ur