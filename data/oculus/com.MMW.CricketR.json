om&oh=00_AYDD8MOt8mL8h6R9XF-kuwRsKpsMc80umbhRo-NKt0n7pQ&oe=67431B76"}, {"file_name": "5.png", "id": "859503162791038", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036627_859503166124371_4975963449023296542_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OlqHwKpxPOkQ7kNvgFxzrv0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBb5qCy8ZiGw-1fkkOpcIr9txKMeRuog_htPl53kiCfw&oe=6743174A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440 1.png", "id": "851297053639671", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974663_851297056973004_739677971646288748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ny_T9QZcI8IQ7kNvgFs_-mp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCLFtPmSLrXqFgIG0B8QxM6yQVKqpKT9HgozFPbwl-Kiw&oe=67430D75"}, "display_name": "CricketR - The Virtual Reality Cricket Game", "keywords": ["Cricket", "CricketSimulation", "VRcricket", "CricketTournaments", "CricketLeague"], "long_description": "Step into the world of CricketR, the most immersive VR cricket experience! With the latest domestic tournament update, you can compete in thrilling local leagues and rise through the ranks from grassroots cricket to championship glory. Practice your batting, bowling, and fielding in world-class stadiums designed to capture every detail of the sport. Whether facing high-stakes tournament matches or honing your skills, CricketR offers a realistic and dynamic cricket experience like never before. Prepare to master the game and become a virtual cricket legend!", "short_description": "Immerse yourself in the latest VR cricket experience with the new domestic tournament update! Hone your skills in realistic stadiums, compete in exciting leagues, and rise through the ranks to become a cricket champion."}]}, "developer_name": null, "developer_privacy_policy_url": "http://cricketr.in/privacy", "developer_terms_of_service_url": null, "publisher_name": "Madras MindWorks", "support_website_url": null, "w