A&oe=66D44B35"}, {"file_name": "(2).png", "id": "392736832379884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_392736835713217_9091262205406837122_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5PdlMee4mEEQ7kNvgHyXbwU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfPScs4op73xB7PuGzYxJytO_6eQrEBIj0SdI0fX3DnQ&oe=66D43C57"}, {"file_name": "(1).png", "id": "1885539654952581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974883_1885539658285914_1019396935637988106_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5p1-idLcry8Q7kNvgFVqyEg&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-rR7L3XGsNFMt83YimH7BGz1Nr7GkYnm9ZVzDky_PiA&oe=66D45313"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "(\ub370\ubaa8)2560_1440(211006).png", "id": "3049660518656719", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001681_3049660521990052_5013043365891433031_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sn6Y57qIo3UQ7kNvgGvJyGv&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgFAAx_5GOt5Zb2iA9RNkn09XRQdpz-Mk12d3hn9WyIw&oe=66D46887"}, "display_name": "The Client VR Demo", "keywords": [], "long_description": "Save the slippers that are hanging in the maze of nightmares!\n\nAs you watch the maze,\nHe opened the way for them and knocked down a scary daemon.\nIt can help slippers get out of nightmares!\n\nKeep that in mind!\nSlippers sometimes get lost and sometimes stubborn as they learn how to walk.\nBut you'll be able to save all the slippers.\n\nA new concept of shooting puzzle game.\nIt is a shooting puzzle game that makes a way for AI characters wandering in a maze to move easily and safely.\n\n100 stages with various solutions.\nVarious maze shapes, slippers, objects, and daemons are combined, so each stage can be played differently each time.", "short_description": "Save the slippers that are hanging in the maze of nightmares!"}, {"images": {"nodes": [{"file_name": "(\ub370\ubaa8)(\ud55c\uae00)3000_900.png", "id": "429007318575366", "image_type": "APP_IMG_