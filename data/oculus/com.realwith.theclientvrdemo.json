_description": "Save the slippers that are hanging in the maze of nightmares!"}, {"images": {"nodes": [{"file_name": "(\ub370\ubaa8)(\ud55c\uae00)3000_900.png", "id": "429007318575366", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_429007321908699_4258283118475983943_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7wXWdm7TbwUQ7kNvgGxpLik&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxADwLfO0J20DiaSffOs1pb&oh=00_AYAmIKsBuqWbaIw-A9QmK7LDVaihANoJ5qkzOOTwsVbW3w&oe=66F3FAAA"}, {"file_name": "\ub354\ud074\ub77c\uc774\uc5b8\ud2b8\ub85c\uace0(\ud55c\uae00).png", "id": "3213236945564295", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_3213236948897628_4786406447797518072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Y2YdQkwVIIQ7kNvgFQ9L17&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxADwLfO0J20DiaSffOs1pb&oh=00_AYBJ4132wpDyyH6A1QfWMFnTPxT60fAAtCGTPwVd8JU2cw&oe=66F40D5E"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)2560_1440.png", "id": "1042171706627527", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429288_1042171713294193_695814847444454466_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Hdr8HHsKSwQ7kNvgFA4BEj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxADwLfO0J20DiaSffOs1pb&oh=00_AYAWgCkB-QEF5YjRdIBiaMpXkQy_KA8nYVJhNlEhD2jnJA&oe=66F3FC31"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)1080_360.png", "id": "938165583721864", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195905_938165587055197_7689133019531011071_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6D8Yl2p2lIYQ7kNvgETyk6j&_nc_ht=scontent.oculuscdn.com&_nc_gid=AxADwLfO0J20DiaSffOs1pb&oh=00_AYBv-atWqDqohTtU7GKOeGV0s_k2TJiXCT9TI3InC9Gk0g&oe=66F3FFB8"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)1008_1440.png", "id": "433985214997675", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/