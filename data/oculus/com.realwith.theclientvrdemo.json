ohc=kN0J7YrLZLgQ7kNvgHoP1Pt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1-Ai2VU5BM34Gm8Ngs-lHgLMsA0riO_EQrk8GeeQ9uw&oe=670E5580"}, {"file_name": "(3).png", "id": "860710021271563", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031518_860710024604896_1320960559219304020_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1otMxeUtLfYQ7kNvgHOGEU8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCK6_81x-L2OfspqO52m1nuaLr4EbaoTe41435olLlOPQ&oe=670E538B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)2560_1440.png", "id": "600320077683487", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974526_600320081016820_2006069223403520286_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zcl0nipmWCQQ7kNvgFwi5yy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEYtmI-daYTMy6iEkmS0rSS0W5vwuSnS0u0EU8En9EKw&oe=670E6707"}, "display_name": "The Client VR Demo", "keywords": [], "long_description": "\uc545\ubabd\uc758 \ubbf8\ub85c\uc5d0\uc11c \ud574\ub9e4\uace0 \uc788\ub294 \uc2ac\ub9ac\ud37c(Sleeper)\ub4e4\uc744 \uad6c\ud574\uc8fc\uc138\uc694!\n\n\ub2f9\uc2e0\uc740 \ubbf8\ub85c\ub97c \uc9c0\ucf1c\ubcf4\uba74\uc11c,\n\uadf8\ub4e4\uc5d0\uac8c \uae38\uc744 \uc5f4\uc5b4\uc8fc\uace0, \ubb34\uc11c\uc6b4 \ub370\ubaac\uc744 \uc4f0\ub7ec\ub728\ub824\uc11c\n\uc2ac\ub9ac\ud37c\ub4e4\uc744 \uc545\ubabd\uc5d0\uc11c \ubc97\uc5b4\ub098\uac8c \ub3c4\uc640\uc904\uc218 \uc788\uc5b4\uc694!\n\n\uba85\uc2ec\ud558\uc138\uc694!\n\uc2ac\ub9ac\ud37c\ub4e4\uc740 \uae38\uc744 \ubc30\uc6b0\uba74\uc11c \ub54c\ub85c\ub294 \ud5e4\uba54\uae30\ub3c4 \ub54c\ub85c\ub294 \uace0\uc9d1\uc744 \ubd80\ub9ac\uae30\ub3c4\ud574\uc694\n\ud558\uc9c0\ub9cc \ub2f9\uc2e0\uc774\ub77c\uba74 \uc2ac\ub9ac\ud37c\ub4e4\uc744 \ubaa8\ub450 \uad6c\ud574\ub0bc\uc218 \uc788\uc744 \uaebc\uc608\uc694.\n\n\uc0c8\ub85c\uc6b4 \uac1c\ub150\uc758 \uc288\ud305 \ud37c\uc990 \uac8c\uc784\n\ubbf8\ub85c \uc18d\uc744 \ud5e4\uba54\ub294 AI \uce90\ub9ad\ud130\uac00 \uc27d\uace0 \uc548\uc804\ud558\uac8c \uc774\ub3d9\ud560 \uc218 \uc788\ub3c4\ub85d \uae38\uc744 \ub9cc\ub4dc\ub294 \uc288\ud305 \ud37c\uc990 \uac8c\uc784\uc785\ub2c8\ub2e4.\n\n\ub2e4\uc591\ud55c \ud574\ubc95\uc758 100\uac1c\uc758 \uc2a4\ud14c\uc774\uc9c0\n\uc5ec\ub7ec\uac00\uc9c0 \ubbf8\ub85c \ud615\ud0dc, \uc2ac\ub9ac\ud37c, \uc624\ube0c\uc81d\ud2b8, \ub370\ubaac\ub4e4\uc774 \uc870\ud569\ub418\uc5b4 \uac01 \uc2a4\ud14c\uc774\uc9c0\ub294 \ub9e4\ubc88 \ub2e4\ub974\uac8c \ud50c\ub808\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.", "short_description": "\uc545\ubabd\uc758 \ubbf8\ub85c\uc5d0\uc11c \ud574\ub9e4\uace0 \uc788\ub294 \uc2ac\ub9ac\ud37c(Sleeper)\ub4e4\uc744 \uad6c\ud574\uc8fc\uc138\uc694!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://en.realwith.com/theclientvr-privacy-policy", "developer_terms_of_service_url": "https://en.realwith.com/termsofservice", "publisher_name": "Realwith Inc", "support_website_url": "https://en.realwith.com/service-inquiry", "website_url": "https://en.realwith.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "PUZZLE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "950013339208281"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031504_214027530705068_8789935822009210962_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pdF9ZdtO978Q7kNvgHXKnbw&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJthERJwSA3vu