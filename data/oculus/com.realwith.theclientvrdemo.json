A&oe=66DD85B5"}, {"file_name": "(2).png", "id": "392736832379884", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_392736835713217_9091262205406837122_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EgBVJTnnDYMQ7kNvgGDC1BH&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZCRqcUOnEg7PiqHHzYR7uX5eAnmtFIo8aSwsDz8DKWg&oe=66DD76D7"}, {"file_name": "(1).png", "id": "1885539654952581", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974883_1885539658285914_1019396935637988106_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YY4wFXvs--UQ7kNvgHwTTK3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbPz2AJO82IHovRKgL86L4lAiGngT5U0u04CCZjMvTAA&oe=66DD8D93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "(\ub370\ubaa8)2560_1440(211006).png", "id": "3049660518656719", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001681_3049660521990052_5013043365891433031_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ulgdCEiU_N0Q7kNvgFkU-iQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDDH5FCAt_HUe7CJE8lENqEaRCxATlhWKqV6yEvgh4gVg&oe=66DDA307"}, "display_name": "The Client VR Demo", "keywords": [], "long_description": "Save the slippers that are hanging in the maze of nightmares!\n\nAs you watch the maze,\nHe opened the way for them and knocked down a scary daemon.\nIt can help slippers get out of nightmares!\n\nKeep that in mind!\nSlippers sometimes get lost and sometimes stubborn as they learn how to walk.\nBut you'll be able to save all the slippers.\n\nA new concept of shooting puzzle game.\nIt is a shooting puzzle game that makes a way for AI characters wandering in a maze to move easily and safely.\n\n100 stages with various solutions.\nVarious maze shapes, slippers, objects, and daemons are combined, so each stage can be played differently each time.", "short_description": "Save the slippers that are hanging in the maze of nightmares!"}, {"images": {"nodes": [{"file_name": "(\ub370\ubaa8)(\ud55c\uae00)3000_900.png", "id": "429007318575366", "image_type": "APP_IMG_