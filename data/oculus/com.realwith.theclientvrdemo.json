_description": "Save the slippers that are hanging in the maze of nightmares!"}, {"images": {"nodes": [{"file_name": "(\ub370\ubaa8)(\ud55c\uae00)3000_900.png", "id": "429007318575366", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_429007321908699_4258283118475983943_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10DAVFFqSdoQ7kNvgH-cMdr&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8U-Xu20nxZ7yGFQLu3aEsm&oh=00_AYD4LsCj-3EN83et4-PTy64JOCzC8GP7NW8DZDkSjsuvcg&oe=66F157AA"}, {"file_name": "\ub354\ud074\ub77c\uc774\uc5b8\ud2b8\ub85c\uace0(\ud55c\uae00).png", "id": "3213236945564295", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_3213236948897628_4786406447797518072_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Y2YdQkwVIIQ7kNvgEzxSqG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8U-Xu20nxZ7yGFQLu3aEsm&oh=00_AYAmbzo8bE_rxerXoOBYnIdj_UKTtcO-ljM9BiXKJ_CXAQ&oe=66F16A5E"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)2560_1440.png", "id": "1042171706627527", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429288_1042171713294193_695814847444454466_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Ud-YV--rEEQ7kNvgFG7EiN&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8U-Xu20nxZ7yGFQLu3aEsm&oh=00_AYB6Ji62-sYIZIfxsS4Ea8CKgdAzacWRpK-eIUXki35P6w&oe=66F15931"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)1080_360.png", "id": "938165583721864", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195905_938165587055197_7689133019531011071_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YP-rGTJAJ00Q7kNvgFNKd__&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8U-Xu20nxZ7yGFQLu3aEsm&oh=00_AYBVRH_jAFPuUy0ysvUQTWzaoJZhrsmnqFGYUpRoebJD1w&oe=66F15CB8"}, {"file_name": "(\ub370\ubaa8)(\ud55c\uae00)1008_1440.png", "id": "433985214997675", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/