GnEbyQwca_OChE8DdueUZF2rvN0DLwA7mXSFw&oe=66DEEEAF"}, {"file_name": "screenshot2024-04-1301-42-24 (1).png", "id": "291759414018368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974835_291759417351701_7146207551072222007_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bc6wcx2e_l0Q7kNvgGR-mKt&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARF0DOdYhOYzaQlSdsQPXep&oh=00_AYDCGx8g4PiYZhX-pWQP3i-pI88w7_uTJ4TAkOQjuedoSA&oe=66DEE142"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CebusFullBanner.png", "id": "802668325252242", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001704_802668328585575_4457659710256740950_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UovZYjOd4SwQ7kNvgG_ZIAd&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARF0DOdYhOYzaQlSdsQPXep&oh=00_AYCQeSeLG1KNEQsLELn8UUb1eMn-yRm4FjT55pfw3YFLtw&oe=66DEC795"}, "display_name": "Cebus", "keywords": [], "long_description": "Welcome to Cebus, a VR multiplayer game that offers an immersive open-world environment teeming with silly characters and endless possibilities.\n\nIn Cebus, you can customize your character to reflect your unique style and personality. With countless maps to explore, each offering a distinct environment and challenges, you\u2019ll never run out of new places to discover.\n\nOur game stands out with its unique visual style, designed to captivate and engage players of all ages. The vibrant colors, detailed environments, and quirky character designs make Cebus silly a visual treat.\n\nCebus offers a variety of unique game modes to keep you entertained. Navigate through a flooded jungle, race against time and other players, or reach the highest point in our vertical challenge. For those who prefer a more relaxed experience, our sandbox mode allows you to explore and interact with the world at your own pace.\n\nOne of the key features of Cebus is our scoring system, CPoints. As you participate in activities and overcome challenges, you\u2019ll earn CPoints. These points allow you to advance and secure your spot on the global leaderboard. Whether you\u2019re a competitive player aiming for the top or someone who enjoys the thrill of progression, our scoring system adds an extra layer of excitement to your gaming experience.\n\nJoin us in Cebus and embark on an unforgettable virtual adventure!", "short_description": "Dive into the world of Cebus, a VR multiplayer game filled with whimsical characters and an expansive open world. Customize your character, explore countless maps, and immerse yourself in our unique visual style. Compete in diverse game modes, from racing to reaching the top in a flooded jungle. Earn CPoints and climb the global leaderboard. Your adventure awaits in Cebus!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/cebus-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "Sora_vr", "support_website_url": null, "website_url": "https://sites.google.com/view/sl-studios/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8324785464211817"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982551_1760480827694772_6421310387724875309_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=465gCT_RtvcQ7kNvgGl3qrD&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARF0DOdYhOYzaQ