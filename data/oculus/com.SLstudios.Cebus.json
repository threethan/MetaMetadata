, "id": "291759414018368", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974835_291759417351701_7146207551072222007_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n1z8sC86nWEQ7kNvgE2oRXu&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCuSEsO-Mmi1KRmeMtfWegV3xHhZV36Z_V8bF9ECPnSKQ&oe=67767DC2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CebusFullBanner.png", "id": "802668325252242", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001704_802668328585575_4457659710256740950_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=28Y35xOqZ4oQ7kNvgHwZ9On&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA2eTyuGKLhvVuzG1AG6ugUEblP2hVkG5jL1KaTuO5VdA&oe=67766415"}, "display_name": "Cebus", "keywords": [], "long_description": "Welcome to Cebus, a VR multiplayer game that offers an immersive open-world environment teeming with silly characters and endless possibilities.\n\nIn Cebus, you can customize your character to reflect your unique style and personality. With countless maps to explore, each offering a distinct environment and challenges, you\u2019ll never run out of new places to discover.\n\nOur game stands out with its unique visual style, designed to captivate and engage players of all ages. The vibrant colors, detailed environments, and quirky character designs make Cebus silly a visual treat.\n\nCebus offers a variety of unique game modes to keep you entertained. Navigate through a flooded jungle, race against time and other players, or reach the highest point in our vertical challenge. For those who prefer a more relaxed experience, our sandbox mode allows you to explore and interact with the world at your own pace.\n\nOne of the key features of Cebus is our scoring system, CPoints. As you participate in activities and overcome challenges, you\u2019ll earn CPoints. These points allow you to advance and secure your spot on the global leaderboard. Whether you\u2019re a competitive player aiming for the top or someone who enjoys the thrill of progression, our scoring system adds an extra layer of excitement to your gaming experience.\n\nJoin us in Cebus and embark on an unforgettable virtual adventure!", "short_description": "Dive into the world of Cebus, a VR multiplayer game filled with whimsical characters and an expansive open world. Customize your character, explore countless maps, and immerse yourself in our unique visual style. Compete in diverse game modes, from racing to reaching the top in a flooded jungle. Earn CPoints and climb the global leaderboard. Your adventure awaits in Cebus!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/cebus-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "Sora_vr", "support_website_url": null, "website_url": "https://sites.google.com/view/sl-studios/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8324785464211817"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982551_1760480827694772_6421310387724875309_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gy6VjKpLrNoQ7kNvgHTC6kk&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAfXWFUN5W5KDLiNZoRt7--MPz22_bRFatOUEv5sjC5xA&oe=67768363"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_nam