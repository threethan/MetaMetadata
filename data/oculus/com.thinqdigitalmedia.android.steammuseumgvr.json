1676251695_4757862245344477184_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uWIqV0n9v4UQ7kNvgGUF8hk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXgc7KZvs_r1z0pLvyGew2G&oh=00_AYCJ3EV8QNopuoLFR0Vc21eMwiS5ZGgJ-zcUFkTFZFTqCw&oe=66ED73EE"}, {"file_name": "migrated_image.png", "id": "194973208467587", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12139031_362168807600396_4963161935496347648_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qV3KtC0lk38Q7kNvgFz-zIX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AXgc7KZvs_r1z0pLvyGew2G&oh=00_AYD3gPGE0PGBdaSXLUwY22uxlx1I8Oz8DgjH6HvRYEOUCA&oe=66ED6327"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Steam Museum", "keywords": ["London", "Museum", "Water", "Steam", "Engine"], "long_description": "London Museum of Water & Steam is an independent museum founded in 1975 as the Kew Bridge Steam Museum.\n\nSituated on the site of the old Kew Bridge Pumping Station in Brentford, near Kew Bridge on the River Thames in West London, England, the museum is centred on a collection of stationary water pumping steam engines dating from 1820 to 1910. It is the home of the world\u2019s largest collection of working Cornish engines, including the Grand Junction 90 inch, the largest such engine in the world. The site is an anchor point on the European Route of Industrial Heritage (ERIH).", "short_description": "A companion app for the London Museum of Water & Steam. This experience shows the steam machines installed at the museum and demonstrates their functioning."}]}, "developer_name": "ThinQ Digital Media Limited", "developer_privacy_policy_url": "http://www.thinqdigitalmedia.com/privacy-policy", "developer_terms_of_service_url": "http://www.thinqdigitalmedia.com/terms", "publisher_name": "ThinQ Digital Media Limited", "support_website_url": null, "website_url": "http://www.thinqdigitalmedia.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topic