EzEJyMiIGQIQUO5TkSE0yw&oe=66CB0038"}, {"file_name": "Image_in game_Crazy Cook 05.png", "id": "4803213709745083", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003274_4803213719745082_7532899763361456943_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=02yJkswKHjEQ7kNvgEwc7dA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFGC9hXWEr9OsK2dkJsyPMw&oh=00_AYAB6vYOF1INYasKz5zWvBUx6Mg8IIGZq61R-I24qASv6Q&oe=66CB19AB"}, {"file_name": "Image_in game_Crazy Cook 04.png", "id": "258352849677262", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_258352853010595_5266040499216685002_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FUW8CZwXuJAQ7kNvgGzTjSw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFGC9hXWEr9OsK2dkJsyPMw&oh=00_AYBTfHXyCQsDTQZOaWxlzxPQ_TjmbJgpA0Yf7tE1UA3H8g&oe=66CB0F41"}, {"file_name": "Image_in game_Crazy Cook 06.png", "id": "709619533780292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982619_709619540446958_1947670398060919437_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Gkma87tpe0Q7kNvgFepGiz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFGC9hXWEr9OsK2dkJsyPMw&oh=00_AYA1l3YYPwLPWwELxnJAUWbcegwuhWMbnoQPVHNeCCYJww&oe=66CB1E8E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Trailer_crazy_cook_32bit.png", "id": "1038189767039681", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_1038189780373013_631460889995462255_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ATUTvIkla3AQ7kNvgGrs9CJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AFGC9hXWEr9OsK2dkJsyPMw&oh=00_AYAcekNq-CdXSPUoa-64Lnxc_9-le7g0xSyxO5xns8V7hQ&oe=66CB1643"}, "display_name": "Crazy Cook", "keywords": ["cooking", "party", "family", "crazy", "cook"], "long_description": "Crazy Cook\u00ae is a fun and crazy cooking game in VR for the whole family !\nYour goal is to create great recipes\u2026with a twist : the ingredients are a bit hostile !\nSlice a chickenosaurus, peel a smiling onion, avoid a killer tomato, smash a garlic grenade with a hammer or pepper spray (literally) a flying punk pig : that's part of your job as a master chef.\nAre you ready to slice with a knife (workshop 1), peel or block with a peeler (workshop 2), smash with a hammer (workshop 3), season or shoot with a one-of-a-kind salt mill (workshop 4) or avoid monsterish ingredients coming from a canon with your wild kitchen tools to score the top of the charts ?\n10 recipes, with 4 workshops each, are included : that's 40 ways to have crazy fun ! \nFor now it's a solo game but we are working on making it a multiplayer game. \nIt's only the beginning ! We will regularly add new features, music, recipes, new tools and new workshops. \nThank you for purchasing the game. It means the world !", "short_description": "Crazy Cook\u00ae is a fun and crazy cooking game for the whole family !\nYour goal is to create great recipes\u2026with a twist : the ingredients are a bit hostile !\nSlice a chickenosaurus, peel a smiling onion, avoid a killer tomato, smash a garlic grenade with a hammer or pepper spray (literally) a flying punk pig : that's part of your job as a master chef.\n10 recipes, with 4 workshops each, are included : that's 40 ways to have crazy fun ! \nAre you ready to score the top of the charts ?"}, {"images": {"nodes": []}, "id": "661548015107496", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Crazy Cook", "keywords": [], "long_description": "Crazy Cook\u00ae est un jeu fun et un peu fou pour toute la famille ! ", "short_description": "Crazy Cook\u00ae est un jeu fun et un peu fou pour toute la famille ! \n"}, {"images": {"nodes": []}, "id": "527734402268659", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Crazy Cook", "keywords": [], "long_description": "Crazy Cook\u00ae is a fun and crazy cooking game in VR for the whole family !\nYour goal is to create great recipes\u2026with a twist : the ingredients are a bit hostile !\nSlice a chickenosaurus, peel a smiling onion, avoid a killer tomato, smash a garlic grenade with a hammer or pepper spray (literally) a flying punk pig : that's part of your job as a master chef.\nAre you ready to slice with a knife (workshop 1), peel or block with a peeler (workshop 2), smash with a hammer (workshop 3), season or shoot with a one-of-a-kind salt mill (workshop 4) or avoid monsterish ingredients coming from a canon with your wild kitchen tools to score the top of the charts ?\nFor now it's a solo game but we are working on making it a multiplayer game. \nIt's only the beginning ! We will regularly add new recipes, new tools and new workshops. \nThank you for purchasing the game. It means the world !", "short_description": "Crazy Cook\u00ae is a fun and crazy cooking game for the whole family !\nYour goal is to create great recipes\u2026with a twist : the ingredients are a bit hostile !\nSlice a chickenosaurus, peel a smiling onion, avoid a killer tomato, smash a garlic grenade with a hammer or pepper spray (literally) a flying punk pig : that's part of your job as a master chef.\nAre you ready to slice, peel, smash, season (shoot) or avoid monsterish ingredients with your wild kitchen tools to score the top of the charts ?"}]}, "developer_name": "Jungle Games", "developer_privacy_policy_url": "https://junglegames.io/politique-de-confidentialite/", "developer_terms_of_service_url": "https://junglegames.io/conditions-de-service-eula/", "publisher_name": "Jungle Games", "support_website_url": null, "website_url": "https://junglegames.io/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "FOOD"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages":