FT4Uh_jConUQ7kNvgFNqyZw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDj12VGQkZy1wcP-2tbk1DSa7pxafDQj_KNe1hBlPq5BA&oe=66E163CD"}, {"file_name": "Screenshot5.png", "id": "744711806517064", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031599_744711813183730_4949083976702748278_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YD6yNZwTmHIQ7kNvgHIkItv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBv7ZDG5enH8rhNuFK3kFQallLwxLU_N3vMzSRLfHkpEg&oe=66E1909A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "614824873441818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75505861_614824883441817_5563202159333149085_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GE9GjPsWUDsQ7kNvgFXIdqy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC4dVLYAnRcLPu48PTS-IUTLBMsV4b9fH0KKh5jBmR4Q&oe=66E1778E"}, "display_name": "The World Beyond", "keywords": [], "long_description": "Discover an engrossing new world of mixed reality, where your play space merges with a virtual landscape. Interact with Oppy and The World Beyond using your hands and voice.  Use a magic flashlight to find energy orbs in your own room, hidden behind Passthrough. Grab them with your hands, tossing them into your space as Oppy navigates around your furniture and room. Use voice commands to ask Oppy to jump or come, or just say hi!  Feed her energy orbs so she can return home!\n\nThe World Beyond is a 5 minute tech demo of Presence Platform features. As such, a full game experience should not be expected; it's instead meant to inspire developers to build mixed reality experiences!\n\nIf you get a black screen while running The World Beyond, please update and restart your headset.", "short_description": "Discover a mixed reality world in this Presence Platform experience."}]}, "developer_name": "Oculus Samples", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_na