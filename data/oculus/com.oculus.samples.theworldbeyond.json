t.oculuscdn.com&_nc_gid=AY-DzVlhzgFwIP4U2ooXHBR&oh=00_AYBl64a3rAkIkbLjBNfEC8mgnDZt2M7kIGP1KeLZUQJCVw&oe=66D85543"}, {"file_name": "Screenshot4.png", "id": "372631791530999", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570299_372631794864332_196636858292637840_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JpuGd6eXjjAQ7kNvgHf7d-N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY-DzVlhzgFwIP4U2ooXHBR&oh=00_AYDLCuwPu9YZxnPSMztWBwlpehy31yYoTG1vDsNmh3KWww&oe=66D8294D"}, {"file_name": "Screenshot5.png", "id": "744711806517064", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031599_744711813183730_4949083976702748278_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mUbTTDAEA1UQ7kNvgET5-aO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY-DzVlhzgFwIP4U2ooXHBR&oh=00_AYCG9Nod7pkt-8CrY4NrPVaA02n_XvaKAxFRpNasCLV0-A&oe=66D8561A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "614824873441818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75505861_614824883441817_5563202159333149085_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2r6xd0R3Xg8Q7kNvgHHyPHw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY-DzVlhzgFwIP4U2ooXHBR&oh=00_AYAQH0w4QD6VtS6eW4R0mGk6QRAfZHtrDxllQjjVgHTeTw&oe=66D83D0E"}, "display_name": "The World Beyond", "keywords": [], "long_description": "Discover an engrossing new world of mixed reality, where your play space merges with a virtual landscape. Interact with Oppy and The World Beyond using your hands and voice.  Use a magic flashlight to find energy orbs in your own room, hidden behind Passthrough. Grab them with your hands, tossing them into your space as Oppy navigates around your furniture and room. Use voice commands to ask Oppy to jump or come, or just say hi!  Feed her energy orbs so she can return home!\n\nThe World Beyond is a 5 minute tech demo of Presence Platform features. As such, a full game experience should not be expected; it's instead meant to inspire developers to build mixed reality experiences!\n\nIf you get a black screen while running The World Beyond, please update and restart your headset.", "short_description": "Discover a mixed reality world in this Presence Platform experience."}]}, "developer_name": "Oculus Samples", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "642295010750473"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86784920_460859162743021_8199386066998329358_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mF3f49lKpJAQ7kNvgGD1rR_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AY-DzVlhzgFwIP4U2ooXHBR&oh=00_AYAkGTULatZGqM0SNEFpNRngtXbux0EbH_vTKh9_I13BUw&oe=66D8576B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The World Beyond", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1653381002, "lastRevision": {"nodes": [{"id": "684625549339462", "release_type": "SCHEDULED", "administration_status": "APPRO