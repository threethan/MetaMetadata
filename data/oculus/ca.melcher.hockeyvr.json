shot_03.png", "id": "782691895754867", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031412_782691899088200_510939158115906243_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D484i9YWsVwQ7kNvgHGowVD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBStdjdEllC6QxRkw7wXMzsjilLi8MEQxhfwr0OAlqbGQ&oe=66DAF053"}, {"file_name": "screenshot_04.png", "id": "859156061364961", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429286_859156064698294_8956635866154707258_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bkht7popjF0Q7kNvgGBk1vQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDsBkNLwdmx8iU5oRK_CH8JhSpDNkM5p7FAJ6EE3fWFVg&oe=66DACE8A"}, {"file_name": "screenshot_05.png", "id": "308130437606371", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974479_308130440939704_1193682448122380628_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vxvG8kVItl8Q7kNvgFaR4ld&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_Vwy1r_N9brYyyI7gUvOSKHbqzI307gz74Wxw8wbI7A&oe=66DAF676"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage.png", "id": "306982834411154", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974796_306982837744487_4784221076414747996_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=70TMQyVfbwMQ7kNvgEjwscx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBsRKs0Al5zzSv5sRGt2QO82Z0K8uVU3X3X4HkOatNKRw&oe=66DAFBF6"}, "display_name": "Hockey VR", "keywords": [], "long_description": "The most realistic and advanced physics-based hockey simulation available! \nFeatures:\n-    Advanced virtual reality puck and stick physics using Unreal Engine\n-    Multiple control layouts available, Use both Touch controllers for more realistic puck handling\n-    2 Game Types: Shoot from either 4 or 5 different ice locations and Choose between Timed or Shot Count modes\n-    3 different environments: Small Town Hockey Arena, Mountain Ice Rink, Forest Night Rink\n-    2 Game modes: Shoot against Targets or Face-to-Face against an AI Goalie that watches your every move!\n-    Choose from Left or Right-handed sticks with curve\n-    Shot Assist mode to help you hone your skills\n-    Local Leaderboard; Play against friends for bragging rights\n-    Play using your real hockey stick! Upgrade your game and visit www.melcher.ca/HockeyVR to purchase a controller mount that will connect your controller to your real hockey stick", "short_description": "Strap on your skates, step up to the blue line and test your skills in the most realistic physics-based hockey simulation available! Try your hand at Target Practice or see how many goals you can score against the AI goalie. Choose between Timed or Shot Count game modes. Play in three different environments. Turn on Shot Assist mode to help you score those breath-taking goals. Upgrade your experience and bring your real hockey stick into the game with our 3d printed controller mount."}]}, "developer_name": "Melcher Studios", "developer_privacy_policy_url": "https://www.melcher.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Melcher Studios", "support_website_url": null, "website_url": "https://www.melcher.ca/hockeyvr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "311094444311472"}}]}, "scheduled_offers": {"count": 19, "nodes": [{"status": "PUBLISHED", "id": "1242747533286437"}, {"status": "PUBLISHED", "id": "848984553763391"}, {"status": "PUBLISHED", "id": "1398150514171770"}, {"status": "PUBLISHED", "id": "1