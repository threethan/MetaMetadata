ically for you!\n\nImmerse yourself in a virtual world where you'll navigate through different rooms, each simulating real-life scenarios you'll encounter during your internship in the restaurant sector. \n\nThis game is acts as an addition to your VET studies, providing practical training and enhancing your skills in a virtual environment.\n\nPrepare to level up your learning journey!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ludusxr.com/privacy-policy-for-vet-vr-virtual-reality-app/", "developer_terms_of_service_url": null, "publisher_name": "LudusXR", "support_website_url": null, "website_url": "https://www.vetvracademy.eu/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "da", "de", "fr", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7128837230487908"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1085235302515758"}]}, "baseline_offer": {"id": "1085235302515758"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710417600, "status": "PUBLISHED", "id": "1085235302515758"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7432967543408207", "version": "1.0.1"}, "id": "537003161323319", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_applica