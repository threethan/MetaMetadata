evice collaboration and sharing using your own content."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.makesea.com/privacy-policy", "developer_terms_of_service_url": "https://community.makesea.com/terms-of-service", "publisher_name": "makeSEA", "support_website_url": "https://www.makesea.com/contact-us", "website_url": "https://www.makeSEA.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1063584910766706"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL", "PRODUCTIVITY", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "684871539349370"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3966533663454306"}]}, "baseline_offer": {"id": "3966533663454306"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1621878180, "status": "PUBLISHED", "id": "3966533663454306"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7620900531329890", "version": "6.0h-catapult-publicdist-clownfish"}, "id": "4020119558007422", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3794900333929948", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id