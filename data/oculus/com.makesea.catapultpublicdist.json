dn.com/v/t64.5771-25/75245822_286585229813045_1229947654193876712_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lpo0OXPbie4Q7kNvgFwk-0k&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwFfcRWRrtYjmIIef75GQNzo3viI5UxxhF3-E6594zQg&oe=66FE7CE6"}, "display_name": "Catapult", "keywords": [], "long_description": "Catapult and makeSEA.com allow you to share and collaborate live using content you produce. You can mix many sources, at any scale, and save every collaboration space layout for future recall. \n\nSharing and collaborating is as easy as:\n1.  Create a Project at makeSEA.com\n2.  Save any 3D content from your favorite 3D creative tool in GLB, STL, OBJ, or FBX or MP4 (video), or other compatible format to your Project's Assets collection\n3.  Add Team Members if you like,  and set your preferred sharing mode: Private, Public, etc. (!IMPORTANT Team members cannot see assets in Draft mode).\n4.  Launch Catapult (this application), login with your makeSEA credentials, and choose a Project to join the Project\u2019s collaboration space. Note that only Team Members can join Projects marked Private.\n\nFor detailed instructions and release notes please see http://www.makesea.com/how-to", "short_description": "makeSEA + Catapult is the easiest way to get your content on to Oculus for cross-device collaboration and sharing using your own content."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.makesea.com/privacy-policy", "developer_terms_of_service_url": "https://community.makesea.com/terms-of-service", "publisher_name": "makeSEA", "support_website_url": "https://www.makesea.com/contact-us", "website_url": "https://www.makeSEA.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}, {"id": "323450648956687"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["SOCIAL