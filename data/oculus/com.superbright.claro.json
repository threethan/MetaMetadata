482392_1768029899915234_6359863692175081472_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GWe5WlJFN3kQ7kNvgHkmcrv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCt3vJZ03Qo6U4i1m8CEGcfv4ruN6yIq1Wjm2hf2E0yQ&oe=676E9421"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Claro", "keywords": ["puzzle", "relaxing", "zen", "best", "great"], "long_description": "Oculus Go Only! Play through beautiful, zen-like miniature worlds where you manipulate the sun to grow a tree in each of the 38 puzzles - it's a perfect VR game for everyone.\n\nHAND CRAFTED\n\nEvery puzzle feels like a unique, hand-crafted tiny world floating in the sky. Making excellent use of VR, you are put right into a responsive, tangible, elegant place.\n\nEASY TO USE\n\nUsing the Oculus Go controller, intuitive controls allow you to manipulate the position of the Light and rotate objects. It has been designed to be easy for everyone to pick up, enjoy and complete.\n\nATMOSPHERIC\n\nAudio provides a rich backdrop, highlighting every action and creating a soothing experience.\n\nGREAT EVOLVING VR EXPERIENCE\n\nClaro is a perfect introduction to VR for anyone! Frequent updates ensure the title continues to improve and take advantage of the latest VR has to offer.", "short_description": "Oculus Go Only! Play through beautiful, zen-like miniature worlds where you manipulate the sun to grow a tree in each of the 38 puzzles - it's a perfect VR game for everyone."}]}, "developer_name": "Superbright", "developer_privacy_policy_url": "http://superbright.org/tos.html", "developer_terms_of_service_url": "http://superbright.org/tos.html", "publisher_name": "Superbright", "support_website_url": null, "website_url": "http://superbright.org/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ad