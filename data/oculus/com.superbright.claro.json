.org/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "617793819524152"}}]}, "scheduled_offers": {"count": 23, "nodes": [{"status": "PUBLISHED", "id": "355388515555911"}, {"status": "PUBLISHED", "id": "363026931097667"}, {"status": "PUBLISHED", "id": "351889022224690"}, {"status": "PUBLISHED", "id": "2049937375026496"}, {"status": "PUBLISHED", "id": "1780022412116693"}, {"status": "PUBLISHED", "id": "675471252927198"}, {"status": "PUBLISHED", "id": "580403982387377"}, {"status": "PUBLISHED", "id": "265629647548410"}, {"status": "PUBLISHED", "id": "407955669770398"}, {"status": "PUBLISHED", "id": "2250668991815611"}, {"status": "PUBLISHED", "id": "2643493775900276"}, {"status": "PUBLISHED", "id": "2692923684086119"}, {"status": "PUBLISHED", "id": "2047772168636519"}, {"status": "CANCELLED", "id": "805580216318052"}, {"status": "PUBLISHED", "id": "287999042013848"}, {"status": "PUBLISHED", "id": "363717950987169"}, {"status": "PUBLISHED", "id": "1002949039902893"}, {"status": "PUBLISHED", "id": "2289304061304333"}, {"status": "PUBLISHED", "id": "253967485171127"}, {"status": "PUBLISHED", "id": "360325421285788"}, {"status": "PUBLISHED", "id": "2314714035415961"}, {"status": "PUBLISHED", "id": "1422266611275314"}, {"status": "PUBLISHED", "id": "433278590777649"}]}, "baseline_offer": {"id": "1780022412116693"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1604340000, "status": "PUBLISHED", "id": "355388515555911"}]}, "liveChannel": {"no