5863", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/429074245_1014772647019196_3390967560152079404_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kWFmzPAn9GQQ7kNvgGhjj0R&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0-lakiWBJ_1V09i25pEfAM1UxUU8Ug1VCPfbXz4Lj6Q&oe=6741D214"}, {"file_name": "2560x1440-screenshot (20).png", "id": "847842650554392", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982711_847842653887725_696319983927984337_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dbBxN35MtYEQ7kNvgFansJ7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCH72KpKkVt2fVxP-y69t5GckYvCqjUVqQT3vEsXdbdgg&oe=6741DB23"}, {"file_name": "2560x1440-screenshot (31).png", "id": "3488520701438927", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65396053_3488520704772260_4983707929608241508_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fqXjBeoX_pkQ7kNvgEbMti0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6QGoZF9eJrHvm0HgwOouyChNUHumPf-2F8uox4HNZlg&oe=6741A94A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unhidden: Cozy Hidden Object Game", "keywords": [], "long_description": "\"Unhidden: Cozy Hidden Object\" is a relaxing Game offering intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\n**Captivating Visuals:** Each scene comes to life with beautiful animations and intricate details as you discover hidden items. This artistic exploration provides a sense of satisfaction and wonder with every completed level.\n\n**Relaxing Hidden Object Challenges:** Take a break from the chaos of everyday life with our soothing hidden object gameplay. The intuitive design allows for a stress-free and enjoyable experience, perfect for unwinding.\n\n**Constant Updates:** Keep your experience fresh with regular updates introducing new hidden object scenes and challenges. There's always something new to find, ensuring endless entertainment.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b", "short_description": "\"Unhidden\" is a relaxing hidden object puzzle game that uses intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.drukry.com/meta-privacy", "developer_terms_of_service_url": null, "publisher_name": "Drukry", "support_website_url": null, "website_url": "https://www.drukry.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749928368418685"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "917753036904662"}, {"status": "PUBLISHED", "id": "1429836224359771"}, {"status": "CANCELLED", "id": "471167292553256"}, {"status": "CANCELLED", "id": "486576887450714"}, {"status": "PUBLISHED", "id": "529857012937822"}, {"status": "PUBLISHED", "id": "992457089177122"}]}, "baseline_offer": {"id": "529857012937822"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "917753036904662"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8532919596786221", "version": "1.0.32"}, "id": "344430285365371", "channel_name": "LIVE"}]}, "is_for_oculus_ke