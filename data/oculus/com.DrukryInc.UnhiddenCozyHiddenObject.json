 "keywords": [], "long_description": "\"Unhidden: Cozy Hidden Object\" is a relaxing Game offering intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\n**Captivating Visuals:** Each scene comes to life with beautiful animations and intricate details as you discover hidden items. This artistic exploration provides a sense of satisfaction and wonder with every completed level.\n\n**Relaxing Hidden Object Challenges:** Take a break from the chaos of everyday life with our soothing hidden object gameplay. The intuitive design allows for a stress-free and enjoyable experience, perfect for unwinding.\n\n**Constant Updates:** Keep your experience fresh with regular updates introducing new hidden object scenes and challenges. There's always something new to find, ensuring endless entertainment.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b", "short_description": "\"Unhidden\" is a relaxing hidden object puzzle game that uses intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.drukry.com/meta-privacy", "developer_terms_of_service_url": null, "publisher_name": "Drukry", "support_website_url": null, "website_url": "https://www.drukry.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"