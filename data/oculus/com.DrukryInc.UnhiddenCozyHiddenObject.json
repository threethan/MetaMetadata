esigned for users over the age of 13.\n\n\u200b", "short_description": "\"Unhidden\" is a relaxing hidden object puzzle game that uses intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.drukry.com/meta-privacy", "developer_terms_of_service_url": null, "publisher_name": "Drukry", "support_website_url": null, "website_url": "https://www.drukry.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7749928368418685"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "917753036904662"}, {"status": "PUBLISHED", "id": "1429836224359771"}, {"status": "CANCELLED", "id": "471167292553256"}, {"status": "CANCELLED", "id": "486576887450714"}, {"status": "PUBLISHED", "id": "529857012937822"}, {"status": "PUBLISHED", "id": "992457089177122"}]}, "baseline_offer": {"id": "529857012937822"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "917753036904662"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8532919596786221", "version": "1.0.32"}, "id": "344430285365371", "channel_name": "LIVE"}]}, "is_for_oculus_k