KUVaJBUQ7kNvgGFJvZ5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCXZHQWhjYFiWMkyTrBfYk3s43PSRtYU3YjLkTj-kDiwQ&oe=67504724"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_1271.png", "id": "1540054334055432", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031553_1540054337388765_26345155038243721_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWNDZyldFVsQ7kNvgFbkH_1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCDsvVag4GiFjIG_u2I7opM15wAl6getuic7ZzTvDX-Q&oe=67504DD8"}, "display_name": "Unhidden: Cozy Hidden Object Game", "keywords": ["puzzle", "relax", "cozy", "adventure", "quest"], "long_description": "\"Unhidden: Cozy Hidden Object\" is a relaxing Game offering intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\n**Captivating Visuals:** Each scene comes to life with beautiful animations and intricate details as you discover hidden items. This artistic exploration provides a sense of satisfaction and wonder with every completed level.\n\n**Relaxing Hidden Object Challenges:** Take a break from the chaos of everyday life with our soothing hidden object gameplay. The intuitive design allows for a stress-free and enjoyable experience, perfect for unwinding.\n\n**Constant Updates:** Keep your experience fresh with regular updates introducing new hidden object scenes and challenges. There's always something new to find, ensuring endless entertainment.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b", "short_description": "\"Unhidden\" is a relaxing hidden object puzzle game that uses intuitive mechanics to uncover hidden items within beautifully crafted scenes.\n\nAge restriction: the game is designed for users over the age of 13.\n\n\u200b"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.drukry.com/meta-privacy", "developer_terms_of_service_url": null, "publisher_name": "Drukry", "support_website_url": null, "website_u