9500"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734116400, "status": "PUBLISHED", "id": "1213618186406104"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9210776272287988", "version": "1.04"}, "id": "4491927887575046", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5338554639510190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9210776272287988"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4491927887575046"}]}, "change_log": "Exciting Updates in Hush!\n\ud83d\udc7e More Thrilling Levels\n\nNew introduction level: Discover the dark side of the Lumirios while everything seems friendly\u2026 at first!\nA quick and efficient tutorial: Learn everything you need in just one level.\n\ud83c\udf1f More Interaction and Challenges\n\nSee what\u2019s missing to complete stars directly from the lobby.\nNew abilities! Control two characters with unique powers:\nFlash grenade: Temporarily blinds Vibros.\nGrappling hook: Swing across obstacles in style.\nTime Stop: Slows down the vibros for a few seconds.\n\ud83c\udfad A More Immersive Story\n\nFind Lumirios\u2019 notes revealing their sinister plans.\nJamie\u2019s calls now show a distorted version of their face, adding more mystery!\n\ud83c\udfae Gameplay Enhancements\n\nVibros and Lumirios have improved vision zones that adapt to walls and doors.\nTired of waiting? Speed up time!\n\ud83c\udfb5 Unique Music in Each Level\n\nEvery level features its own soundtrack to keep the experience fresh.\n\ud83d\udee0\ufe0f Level Editor Ready\n\nThe level editor is now available, so you can start creating your own adventures!\n\ud83c\udf25\ufe0f A More Beautiful Lobby\n\nNew cloud designs blend with the previous ones for a magical look.\n\ud83c\udf0c Tougher Enemy Challenges\n\nVibros and Lumirios now behave unpredictably\u2026 get ready for surprises!\nDive into the world of Hush, create, explore, and enjoy! \ud83c\udfae\u2728\n\n", "created_date": 1732837881, "id": "9210776272287988", "version": "1.04", "version_code": 170, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5338554639510190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9210776272287988"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4491927887575046"}]}, "change_log": null, "created_date": 1703874011, "id": "7396556493709984", "version": "1.02", "version_code": 168, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5338554639510190", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "9210776272287988"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "4491927887575046"}]}, "change_log": null, "created_date": 1701397179, "id": "7288603774505257", "version": "1.01", "version_code": 167, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__type