AWYuIcTK6FbIXhwATaQLejRFz-S0cJsx4ahhCifEg3w&oe=670509B9"}, {"file_name": "2.png", "id": "757288149579872", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003271_757288152913205_7342296507944513087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tvpo-Jz9btYQ7kNvgHArvQk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBBL-kl94i2-hMfnJnGvpjADfRh1q5JKjLZy1l6Nf3a-w&oe=67050E2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "689845179995120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974855_689845183328453_919185214266887576_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwbDxf7mfwEQ7kNvgFm2qZM&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCY8yvBAOlv0KHpf415c9DomygRPVfO-g0YCEaOhI7BQ&oe=67050670"}, "display_name": "Secret History of Mongolia", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rati