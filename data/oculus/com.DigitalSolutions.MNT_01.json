v/t64.5771-25/38982659_1152941142342216_3213769251215245474_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8DGGsKBxDFQQ7kNvgGbAgN0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWY9hAZp4ufrMZ38gcFY0r9&oh=00_AYBwHLEFOjjbUq6lqvFZxCaNrWJRUZb8vC1YvdznwIbrdw&oe=66E17139"}, {"file_name": "2.png", "id": "757288149579872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003271_757288152913205_7342296507944513087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZL8QY4MqWaoQ7kNvgE1Nj2s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWY9hAZp4ufrMZ38gcFY0r9&oh=00_AYBSEkZQi1ED6CcGIluokbixUPc7LwYVKYkyu2r6izmE1g&oe=66E175AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "689845179995120", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974855_689845183328453_919185214266887576_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6aJTYzAKs_cQ7kNvgFhNC5W&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWY9hAZp4ufrMZ38gcFY0r9&oh=00_AYAdeCRM8aNsIfzBb4ROA54HDgoSA692Q6Pl4pes1CfMoA&oe=66E16DF0"}, "display_name": "Secret History of Mongolia", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_pol