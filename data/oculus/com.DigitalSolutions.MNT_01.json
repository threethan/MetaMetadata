_sid=6e7a0a&_nc_ohc=FofxhubHZDsQ7kNvgFUWzED&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDPHablpsF0fkCzR_BkrUjtOIBLRMHNp23UF-fa_lqxmw&oe=67308B39"}, {"file_name": "2.png", "id": "757288149579872", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003271_757288152913205_7342296507944513087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgEi53ryiH0Q7kNvgEA3lus&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBFV0SZBrS7yzboUxoUVIJYqU1etPlXdGNQmNRHE2GCyg&oe=67308FAC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "689845179995120", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974855_689845183328453_919185214266887576_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sn7DKH4u8foQ7kNvgHVnPI7&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYByUC9mTJuiCru3U7FBHBnSLf460NNwA6Y4-OcE5hYxhQ&oe=673087F0"}, "display_name": "Secret History of Mongolia", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolu