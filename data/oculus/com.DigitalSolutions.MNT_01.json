_sid=6e7a0a&_nc_ohc=Yfmm5vLY0ZkQ7kNvgEMPmvL&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCm5B0yCPtrdr2W_IxpJsE6RCOacIJGtRxmCsa9h6vPQg&oe=67162D39"}, {"file_name": "2.png", "id": "757288149579872", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39003271_757288152913205_7342296507944513087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8fp_xsjhGQgQ7kNvgF1HF5E&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDgDs0ttV3clp_7CCq0IxS-Emk2g-Bdtt3TIxEBiiKhZQ&oe=671631AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "689845179995120", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974855_689845183328453_919185214266887576_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cqNcK5TUP9IQ7kNvgGYU-tD&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYDr92gEH1uGRk8pmF4Z4COckNPtFxNk7nyUpMoC6Uts6A&oe=671629F0"}, "display_name": "Secret History of Mongolia", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolu