id": "1118798249479058", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031435_1118798252812391_2526204309401277244_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gg7_tb1OcCQQ7kNvgHs7ChL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKIBzKaXYSScZnYU5OYipZeKZUWDXyGVCeSI4wN3ut0g&oe=67334AB6"}, {"file_name": "5.png", "id": "1152941139008883", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982659_1152941142342216_3213769251215245474_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hl8hcKu3jWsQ7kNvgGSuyCH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn-0yuKwnCAmOoKveUBmPZM38DOCCpjWahBK1b8UQYGg&oe=67332E39"}, {"file_name": "2.png", "id": "757288149579872", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003271_757288152913205_7342296507944513087_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgEi53ryiH0Q7kNvgG67RWR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZOZQeqlLM-7PEiYMd4NhYvUw6Y07AzX8KgsEN4CL6OA&oe=673332AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "689845179995120", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974855_689845183328453_919185214266887576_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rGWgX69AVNAQ7kNvgHBmITY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvXEnccIHySVaXOGToZnD-1dyqSxmT5M2z1i4BhnopMQ&oe=67332AF0"}, "display_name": "Secret History of Mongolia", "keywords": [], "long_description": " As users navigate through the app, they are transported to different sites, each meticulously rendered to provide a realistic sense of presence in those places. Accompanying these visual experiences are detailed explanations and narratives, shedding light on the historical importance of each location, its role in the \"Secret History of Mongolia\", and insights into the Mongolian culture and heritage. This app is a unique blend of history, technology, and storytelling, offering users an engaging and educational journey through Mongolia's rich past.", "short_description": "The VR app focused on the places mentioned in the \"Secret History of Mongolia\" is an immersive educational experience. It features stunning 360-degree images of various historical and culturally significant locations associated with the Mongolian Empire's history."}]}, "developer_name": null, "developer_privacy_policy_url": "https://digitalsolutions.mn/policy.html", "developer_terms_of_service_url": null, "publisher_name": "DigitalSolutionsVR", "support_website_url": null, "website_url": "https://digitalsolutions.mn/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["mn"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7003096893093299"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "904545728092618"}]}, "baseline_offer": {"id": "904545728092618"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709751480, "status": "PUBLISHED", "id": "904545728092618"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7182634821806171", "version": "1.0"}, "id": "1562089661254769", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6989317311137924", "is_concept"