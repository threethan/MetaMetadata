iad3-2.oculuscdn.com/v/t64.5771-25/57568679_610644554205069_6546097349031153076_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RdGwMm7hIn0Q7kNvgGSGrCo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDX2JbExsNvG6bmxaOlmEUfF-a0qwrHmQh1d-SJKCQ93g&oe=671799D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TBC_LandscapeDemo.png", "id": "799202501382844", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982567_799202504716177_5159505871863248409_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1961YzeD4fkQ7kNvgGFqVNT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBX5Kw0AL1_2mWc4QK5nHC1IDF73yFiiy2NSIwD-U0qAg&oe=67177519"}, "display_name": "Tube Be Continued Demo", "keywords": [], "long_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels in the full game! \u2b50\n\nGet the full game: https://www.oculus.com/experiences/quest/5556605911096889/\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nThis is only a demo, but the full game contains the following TUBE-Based Benefits:\n\u2022 60 levels across 3 themed floors: Hamster Hangout, Smart Home Slide & Bakery Blitz!\n\u2022 Customize your hamster\u2019s appearance!\n\u2022 Classic and slide-based tube puzzles!\n\u2022 Numerous Mini-Puzzles including our new hamster cannon!\n\u2022 Chat with the BOSS and help him deal with important \u201cbusiness decisions\u201d!\n\u2022 Relaxed-pace gameplay with no time pressure.\n\u2022 Supports seated, standing, or room scale play.\n\nYour destination for Tube-Based entertainment awaits!\n\nSincerely,\nThe BOSS", "short_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels in the full game! \u2b50\n\nGet the full game: https://www.oculus.com/experiences/quest/5556605911096889/\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nSincerely,\nThe BOSS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bluemonttechnology.com/game%20privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bluemont Technology & Research, Inc.", "support_website_url": null, "website_url": "https://tubebecontinued.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7046588612041026"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982542_654788152794412_1031166648201758805_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ojsskk460VgQ7kNvgHZB_m2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-mrRqJUu5-_rVnvikeqmanSGlCT_WOn2Dqs5MzzgoIQ&oe=67179E37"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Be Continued Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1646256470, "lastRevision": {"node