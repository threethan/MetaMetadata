iad3-2.oculuscdn.com/v/t64.5771-25/57568679_610644554205069_6546097349031153076_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TcRy4_9ivkEQ7kNvgGYzpS9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA46Ny2pVm402pODI_d4ukCExfKsNctEAGvc-n397xtOw&oe=672CB1D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TBC_LandscapeDemo.png", "id": "799202501382844", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982567_799202504716177_5159505871863248409_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZcLer46SDS0Q7kNvgFLx14S&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-dzLSk7FlgTm9bYTbXp5ehw3txn0JYeFZShTq6LmB_w&oe=672C8D19"}, "display_name": "Tube Be Continued Demo", "keywords": [], "long_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels in the full game! \u2b50\n\nGet the full game: https://www.oculus.com/experiences/quest/5556605911096889/\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nThis is only a demo, but the full game contains the following TUBE-Based Benefits:\n\u2022 60 levels across 3 themed floors: Hamster Hangout, Smart Home Slide & Bakery Blitz!\n\u2022 Customize your hamster\u2019s appearance!\n\u2022 Classic and slide-based tube puzzles!\n\u2022 Numerous Mini-Puzzles including our new hamster cannon!\n\u2022 Chat with the BOSS and help him deal with important \u201cbusiness decisions\u201d!\n\u2022 Relaxed-pace gameplay with no time pressure.\n\u2022 Supports seated, standing, or room scale play.\n\nYour destination for Tube-Based entertainment awaits!\n\nSincerely,\nThe BOSS", "short_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels in the full game! \u2b50\n\nGet the full game: https://www.oculus.com/experiences/quest/5556605911096889/\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nSincerely,\nThe BOSS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bluemonttechnology.com/game%20privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bluemont Technology & Research, Inc.", "support_website_url": null, "website_url": "https://tubebecontinued.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7046588612041026"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982542_654788152794412_1031166648201758805_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_-KBsUVBSDQQ7kNvgFt975j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgkPaMprtxMaASLodX6gDrPE2zNNx8xoI4I-nAleL-ig&oe=672CB637"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Be Continued Demo", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1646256470, "lastRevision": {"nodes": [{"id": "4406050806144937", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {