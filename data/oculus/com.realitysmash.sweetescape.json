74629_351553250307076_2549245020728720751_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2tYLHyszvVAQ7kNvgEZ3pbx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDezjbaU3hIlJC-jGGhmcvkLKi7B8YAh1HM-gVWish3ZQ&oe=6773C973"}, {"file_name": "sevr_scrn_0004_pic2.png", "id": "1347057492477104", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974751_1347057495810437_4355619307576092085_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZsvAuCx3w20Q7kNvgHrGVeC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDaIulMjMfIBNMTUxI5nvQzViVCaANMsw5JDzEIIllHCg&oe=6773EA21"}, {"file_name": "sevr_scrn_0002_pic4.png", "id": "3197392223817536", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031484_3197392227150869_6455689560338806111_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=weJPU1bzp1kQ7kNvgEtfz7c&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCpvfaQTVIleqZPjqK_BZIwj6CnHcEyoFPK6-OJY7J0_A&oe=6773C211"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031421_1157411304642245_1954904826581793879_n.png", "id": "1938046916369651", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035380_1938046919702984_3695788427288717242_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ov3IsnSp0YMQ7kNvgHA2RL0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzRMAeHXmMVfnNtSLq9Nvj0DqMrmd03sy6Nj_J6Hngbw&oe=6773E589"}, "display_name": "Sweet Escape", "keywords": [], "long_description": "Race against friends and family around the globe in this psychedelic climbing landscape of candy imagination.  Tick tock, time is not on your side!  Utilize your agility and master your fear of heights as you swing from licorice vines, climb over tricky candybar obstacles, and launch yourself over great distances onto narrow targets.  This delicious race will sling you up to lofy summits, so brace yourself because the sensation of falling from dizzying heights is real!  First one to the finish line wins, but beware: one bad slip could be your end...and you definitely don't want to be last!  Survive to tell the tale and make the ultimate choice - party or death!", "short_description": "You and your friends are fighting to escape this treacherous candy land. Reach the lollipop to win in this active VR game experience. Climb chewy gumdrops, monkeybar over great heights, jump from candy bar to candy bar, and be careful not to lose your grip. Falling to your doom is a real sensation; your survival is in your hands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sweetescapevr.com/privacy", "developer_terms_of_service_url": "https://www.sweetescapevr.com/terms-of-service", "publisher_name": "Reality Smash", "support_website_url": null, "website_url": "http://www.sweetescapevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "717390992749024"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "501268295009531"}]}, "baseline_offer": {"id": "501268295009531"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1651856400, "status": "PUBLISHED", "id": "501268295009531"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4822107091135241", "version": "0.06"}, "id": "3080383342209881", "channel_name": "LIVE"}]}, "is_for_oculus_ke