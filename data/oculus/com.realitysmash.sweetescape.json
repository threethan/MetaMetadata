4355619307576092085_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=db52l3vgVC8Q7kNvgG2Tthj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiDMJ_fV9pHifVxAAlQs0wi&oh=00_AYA9DL4kYZ9kdmuk3IemXu8DYlfGumvThvbFXxcJoPMnfg&oe=66F408A1"}, {"file_name": "sevr_scrn_0002_pic4.png", "id": "3197392223817536", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031484_3197392227150869_6455689560338806111_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=esdb2BVj3wIQ7kNvgEQ4rXY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiDMJ_fV9pHifVxAAlQs0wi&oh=00_AYBOf95gqV7ESwhb81XUAbilQzPJfUnqUnaelErw-4_HTQ&oe=66F3E091"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39031421_1157411304642245_1954904826581793879_n.png", "id": "1938046916369651", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035380_1938046919702984_3695788427288717242_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5EngLuFoYS8Q7kNvgG7Scc3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiDMJ_fV9pHifVxAAlQs0wi&oh=00_AYDl-WUmEkd2PLAoywezVy55brjvX2DXsgW3dyL15P0SgQ&oe=66F40409"}, "display_name": "Sweet Escape", "keywords": [], "long_description": "Race against friends and family around the globe in this psychedelic climbing landscape of candy imagination.  Tick tock, time is not on your side!  Utilize your agility and master your fear of heights as you swing from licorice vines, climb over tricky candybar obstacles, and launch yourself over great distances onto narrow targets.  This delicious race will sling you up to lofy summits, so brace yourself because the sensation of falling from dizzying heights is real!  First one to the finish line wins, but beware: one bad slip could be your end...and you definitely don't want to be last!  Survive to tell the tale and make the ultimate choice - party or death!", "short_description": "You and your friends are fighting to escape this treacherous candy land. Reach the lollipop to win in this active VR game experience. Climb chewy gumdrops, monkeybar over great heights, jump from candy bar to candy bar, and be careful not to lose your grip. Falling to your doom is a real sensation; your survival is in your hands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sweetescapevr.com/privacy", "developer_terms_of_service_url": "https://www.sweetescapevr.com/terms-of-service", "publisher_name": "Reality Smash", "support_website_url": null, "website_url": "http://www.sweetescapevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7623104937702095"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_168613365284707_8686747004859718579_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUeON57f7ZIQ7kNvgEU_t__&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiDMJ_fV9pHifVxAAlQs0wi&oh=00_AYCQt3EEoGn8ZbdTS5usvqClBBhuxIgHHDoloEPVBfzrrA&oe=66F3F479"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sweet Escape", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Racing", "id": "673385183287495"}], "release_date": 1651856400, "lastRevision"