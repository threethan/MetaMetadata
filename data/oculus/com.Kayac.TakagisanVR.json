ent-sea1-1.oculuscdn.com/v/t64.5771-25/75223471_3387807621274750_3212255111683571144_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o0U34h9Ym-MQ7kNvgHgQn0A&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBcMaTuzKZquwOUOAMkgKTn3Go0Je3UifUKe2h6sQLOMQ&oe=670FBFD5"}, {"file_name": "10_05_\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8_2560x1440px.png", "id": "285077272819915", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75230041_285077276153248_3625297943080459283_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aZGfA2p-Ui4Q7kNvgGxbIVR&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCzZLBK4XKyFy9HtPkqzCgRdO3zGYTjA1ZIFHbh0TVY5g&oe=670FBAC5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "01_\u80cc\u666f\u753b\u50cf_2560 x 1440_32bit .png", "id": "696838147612635", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75334066_696838150945968_6670342023668292073_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iAVog3sOijcQ7kNvgHUxxEG&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDcPmRdVSLGjFRmoMCf_qBNjcjJ_TAyesC7KOLj8XNrxQ&oe=670FB941"}, "display_name": "Teasing Master Takagi-san VR 1st & 2nd Semesters", "keywords": ["takagisan", "takagi", "teasing", "karakai"], "long_description": "Virtually experience the playful and relentless teasing of our heroine, Takagi-san, in Teasing Master Takagi-san VR 1st & 2nd Semesters (Karakai Jouzu no Takagi-san VR 1&2 Gakki). With sales of the original comic series exceeding 8.7 million copies and two anime seasons broadcast in Japan, we are pleased to make the romantic comedy available on VR platforms as a VR animation.\n\nIn assuming the role of the main character, Nishikata, not only will you have the honor of being the target of Takagi-san's affection(!?!), you'll engage in a new VR animation experience by becoming a part of the comic series' world. Go heads up in poker with Takagi-san, play at the beach, go fishing together, and more!\n\nIn addition to popular scenes from the original series, Teasing Master Takagi-san VR features original scenarios you can only experience here.\n\nIf you ever wanted to trade places with Nishikata and get teased by Takagi-san, this is the animation for you!", "short_description": "Virtually experience the playful and relentless teasing of our heroine, Takagi-san, in Teasing Master Takagi-san VR 1st & 2nd Semesters (Karakai Jouzu no Takagi-san VR 1&2 Gakki). With sales of the original comic series exceeding 8.7 million copies and two anime seasons broadcast in Japan, we are pleased to make the romantic comedy available on VR platforms as a VR animation."}]}, "developer_name": "KAYAC Inc.", "developer_privacy_policy_url": "https://vr-takagi3.com/privacy", "developer_terms_of_service_url": "https://vr-takagi3.com/terms", "publisher_name": "KAYAC Inc.", "support_website_url": null, "website_url": "https://vr-takagi3.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "NARRATIVE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "623601062226471"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982568_372293217162588_2696759669612379256_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlqFKzyuA7gQ7kNvgG1sciQ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAIK5ZPS_gzwKB34TdQtKE9NulA29JnnDQkHx3xI5EA0w&oe=670F8D56"}, "i