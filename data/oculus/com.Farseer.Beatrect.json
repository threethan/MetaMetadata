4_5852021513359262335_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cK4xMGBrhWUQ7kNvgF-xWU7&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYA5o-P1pHmWyhTGOXv_nv24AOw3iNuRXyQCsmNX__U79Q&oe=675EDBE2"}, {"file_name": "230823165557.png", "id": "380417504758430", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75221322_380417508091763_3784107229769999007_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9n1wuXumQ1sQ7kNvgHZ7lhS&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYC_9MRDK1A0tokxSlb98Qadyb_mkwD6gJBsSRdUxlJ_7A&oe=675EB0F5"}, {"file_name": "230823165530.png", "id": "1012736133882182", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75303836_1012736137215515_1159597745498380348_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XWP9KKcnTjUQ7kNvgGGUJEZ&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBwEuazb--KDsVTZxB6qJC2MJHk7RUIrv4-IcFoXTbvUw&oe=675EBB45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560.png", "id": "513234611364089", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75221322_513234614697422_7535125650319054398_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gHGWaa3lj5UQ7kNvgH9gCa9&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYC84-jtqDFFPLhk8Bxi4hxX69-1QhR_1ZXzOpFG4iiJOg&oe=675ED8D3"}, "display_name": "Beatrect", "keywords": [], "long_description": "# Introducing Beatrect\nthe Rhythm Action Game for music lovers and note-slashers both old and new!\n\n\nTired of precisely aiming for the notes?\n\nJust wanna enjoy music without overthinking?\n\nLet the music take over, and get your body moving!\n\n\n\n**Features**\n\n- **Beatrect is easy to play!**\n\nJump into the action without complicated rules - Perfect for beginners and casual players!\n\n- **Hone your skills and challenge yourself!**\n\nFind your own way to play the levels and move up in the ranks!\n\n- **Get ready for the never-before-seen visuals!**\n\nThis new ray-tracing based graphic technology will shock and amaze you!\n\n- **Create your own original levels!**\n\nEveryone has a chance to be featured on the official levels page!\n\n\nPlay with no hesitation!\nPlay for the love of music!", "short_description": "Introducing Beatrect!\nthe Rhythm Action Game for music lovers and note-slashers both old and new!\nSlash the notes without complicated rules. Experience a whole new ray-tracing based graphic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/77792f91-721d-441d-b29d-c505a4e07e86", "developer_terms_of_service_url": "https://ash-tulip-d32.notion.site/EULA-23d1bd1f5fb34fc3a9b69f9d2f0f926c?pvs=4", "publisher_name": "Farseer Co., Ltd.", "support_website_url": null, "website_url": "https://ash-tulip-d32.notion.site/f794e58b49eb440fa2c8eda3faa76259", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7781552705284619"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "984565193419168"}, {"status": "PUBLISHED", "id": "450650087804288"}]}, "baseline_offer": {"id": "450650087804288"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "984565193419168"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []