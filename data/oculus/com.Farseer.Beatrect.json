ADF5"}, {"file_name": "230823165530.png", "id": "1012736133882182", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75303836_1012736137215515_1159597745498380348_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VEhz4YLMDIsQ7kNvgGpEQxP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7vzv1Bmq17tq7kf9r7FUGIAWsdbrXrOHtSwZZ05x4bg&oe=6707B845"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560.png", "id": "513234611364089", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221322_513234614697422_7535125650319054398_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uLCOMKeWhlwQ7kNvgHnQ6qT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsL-R-XFHFVVTCwVwE7k9E3WSXo7UJUynrWhESrW4N9g&oe=6707D5D3"}, "display_name": "Beatrect", "keywords": [], "long_description": "# Introducing Beatrect\nthe Rhythm Action Game for music lovers and note-slashers both old and new!\n\n\nTired of precisely aiming for the notes?\n\nJust wanna enjoy music without overthinking?\n\nLet the music take over, and get your body moving!\n\n\n\n**Features**\n\n- **Beatrect is easy to play!**\n\nJump into the action without complicated rules - Perfect for beginners and casual players!\n\n- **Hone your skills and challenge yourself!**\n\nFind your own way to play the levels and move up in the ranks!\n\n- **Get ready for the never-before-seen visuals!**\n\nThis new ray-tracing based graphic technology will shock and amaze you!\n\n- **Create your own original levels!**\n\nEveryone has a chance to be featured on the official levels page!\n\n\nPlay with no hesitation!\nPlay for the love of music!", "short_description": "Introducing Beatrect!\nthe Rhythm Action Game for music lovers and note-slashers both old and new!\nSlash the notes without complicated rules. Experience a whole new ray-tracing based graphic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/77792f91-721d-441d-b29d-c505a4e07e86", "developer_terms_of_service_url