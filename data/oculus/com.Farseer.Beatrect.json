2_397243559909651_7802946928558808798_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qIk5lQYBiYIQ7kNvgG6EsJw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDjsPMBuM0vJnV9Sby2On51zskbWik5zywnu33y0IFJkw&oe=677BBAE7"}]}, "id": "522830550552981", "locale": "en_US", "screenshots": [{"file_name": "230823165442.png", "id": "1210747013453360", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974860_1210747016786693_4337269772176518993_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kgo4JtGJblEQ7kNvgG-ieCV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD13uKWWB1zeiMnPuoS_dG87NR526MXu2AqyPrcIKGyOw&oe=677BAF1A"}, {"file_name": "230823165855.png", "id": "1227713785071508", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974901_1227713788404841_5664366822082674976_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x7wqo1XPeFYQ7kNvgEt2iUY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCCQlTagsJoVWTYw42h2ENH9j3C37pNJRRwS_tREVbNlw&oe=677BD357"}, {"file_name": "230823165755.png", "id": "848193913551268", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035410_848193920217934_5852021513359262335_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iQKAcmc-jU4Q7kNvgG-x1IP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDlJ4p2wNcUn9hTKfL1pFDtlVRr2Xn09SE-1SyBYmcdUA&oe=677BDCE2"}, {"file_name": "230823165557.png", "id": "380417504758430", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75221322_380417508091763_3784107229769999007_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KO1h_jaKbR8Q7kNvgHu02tc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDivVOvrS1nwiX_JBrF7FNDVpflcDn0Ui9hE6v1fp5meQ&oe=677BB1F5"}, {"file_name": "230823165530.png", "id": "1012736133882182", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75303836_1012736137215515_1159597745498380348_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VIS7CZaA3NkQ7kNvgFCUZCw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCMljYxEf_eA8hCKdwx3pe88JA9ytNGjADe8a6tjqnUIw&oe=677BBC45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560.png", "id": "513234611364089", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75221322_513234614697422_7535125650319054398_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jze_Fvcl6goQ7kNvgE8dTHx&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCPecbXt16DFT4asL54NbntbtvLjXsCTbCHf2qqSSQLkg&oe=677BD9D3"}, "display_name": "Beatrect", "keywords": ["music", "rhythm", "beat", "casual", "exercise"], "long_description": "# Welcome to Beatrect!\n\nWhere Music Meets Ray-Traced Graphics in VR!\n\n\n\n# \ud83c\udfb5 Pure Musical Freedom\n\nForget everything you know about rhythm games! No more stress about perfect timing or precise movements. Just feel the music and let your body flow naturally.\n\n\n# \u2728 Revolutionary Ray-Traced Visuals\n\nExperience rhythm action in a whole new light with our innovative ray-tracing technology. Every level brings you into a stunning visual environment that elevates your musical journey.\n\n\n\n# \ud83c\udfae Features That Set Us Apart\n\n**Pick Up and Play**\n\nJump right into the action - no tutorials needed\n-\nIntuitive controls that feel natural from the first beat\n-\nPerfect for both VR beginners and rhythm game veterans\n\n**Your Style, Your Way**\n\nFind your own rhythm and playing style\n-\nNo pressure for perfection - just pure enjoyment\n-\nPlay at your own pace and discover new techniques\n\n**Level Creator**\n\nDesign your own unique levels\n-\nShare your creations with the community\n-\nChance to be featured on our official levels page!\n\n\n**Visual Excellence**\n\nNext-gen ray-tracing graphics\n-\nUniquely designed visual environments\n-\nImmersive VR experience\n\n\n\nReady to experience a new kind of rhythm game?\n-\nDon't think, just feel - Let the music guide you in Beatrect!", "short_description": "Step into Beatrect's Ray-Traced Rhythm World!\nVR's most accessible rhythm game meets stunning visuals. No complicated rules - just slash, feel the beat, and enjoy the spectacle!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/77792f91-721d-441d-b29d-c505a4e07e86", "developer_terms_of_service_url": "https://ash-tulip-d32.notion.site/EULA-23d1bd1f5fb34fc3a9b69f9d2f0f926c?pvs=4", "publisher_name": "Farseer Co., Ltd.", "support_website_url": null, "website_url": "https://ash-tulip-d32.notion.site/f794e58b49eb440fa2c8eda3faa76259", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "MUSIC"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8148327031940516"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75210398_1218098759483763_8731799394832124520_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hNdJ8T-RArYQ7kNvgEajDKC&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAHp-afvvu4AxfkaQBjQoL0_ol8lNFRA-W1bOCmT9CI2w&oe=677BAC5D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Beatrect", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Rhythm", "id": "1672577396871977"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1727342040, "lastRevision": {"nodes": [{"id": "478910766