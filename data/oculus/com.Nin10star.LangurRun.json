3-1.oculuscdn.com&oh=00_AYB46jzKmkGh4AiPBYVAnl97XjQ9bwHHgIcycGs-cS802A&oe=67471A66"}, {"file_name": "New Project - 2024-10-21T142237.644.png", "id": "1297151588379077", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984472_1297151591712410_1325249115902179592_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HGRAq8AXytUQ7kNvgGUWoNE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFM-0lZCc3irk_sXZD2uAj6Lgxeqp1-e-3vsHPMDUgvQ&oe=6746FC42"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Langur Run", "keywords": ["Run", "Horror", "Monkey"], "long_description": "Welcome to Langur run! Run around and explore the maps in game! Or check out the other game modes like Nextbots horror!\nLangur run is similar to Gorilla Tag, meaning you move with your hands. Make sure to check out the shop with multiple cosmetics you \ncan put on to style your Langur! Or, if you are basic, just change your colors.\nLangur Run is still brand new, so expect bugs. \n\nHave fun!", "short_description": "This is Langur Run, an experience similar to Gorilla Tag! Check out the brand-new shop! \nwith a whole bunch of cosmetics to put on and style your Langur, be careful don't spend all of your money!"}]}, "developer_name": "star.mp4", "developer_privacy_policy_url": "https://docs.google.com/document/d/1QurlQWMRUzCsKiDm8TAioVnUPAja2EDaUWmd-ZDEzKg/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "star.mp4/Doritoz", "support_website_url": null, "website_url": "https://www.youtube.com/@LangurRun", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "528142316460358"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recomm