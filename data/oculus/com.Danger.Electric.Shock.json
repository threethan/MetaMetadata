], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{\u904a\u6232\u8aaa\u660e}\n\n\u76ee\u6a19\n\u624b\u6301\u96fb\u6d41\u6025\u6025\u68d2\u7a7f\u904e\u901a\u96fb\u9053\u4e26\u62b5\u9054\u7d42\u9ede\u7dda\u3002\n\n\u901a\u96fb\u9053\n\u7531\u901a\u4e0a\u96fb\u6d41\u7684\u91d1\u5c6c\u6846\u7d44\u6210\u3002\n\n\u904a\u6232\u73a9\u6cd5\n\u63a7\u5236\u96fb\u6d41\u6025\u6025\u68d2\uff0c\u5207\u52ff\u78b0\u89f8\u91d1\u5c6c\u6846\u3002\n\n\u5099\u8a3b\n\u5728\u9014\u4e2d\u63a8\u62c9\u96fb\u6d41\u6025\u6025\u68d2\u4ee5\u8df3\u904e\u969c\u7919\u5c31\u7b97\u8f38\u3002", "short_description": "\u9583\u907f\u5371\u96aa\u9677\u9631\u4e26\u5b8c\u6210\u6b64\u904a\u6232\uff01\uff01"}, {"images": {"nodes": []}, "id": "954690198815109", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{\u6e38\u620f\u8bf4\u660e}\n\n\u76ee\u6807\n\u5e26\u7740\u4e00\u6839\u68d2\u5b50\u7a7f\u8fc7\u4e00\u6761\u901a\u9053\uff0c\u5230\u8fbe\u7ec8\u70b9\u7ebf\u3002\n\n\u901a\u9053\n\u7528\u91d1\u5c5e\u6846\u505a\u6210\uff0c\u91d1\u5c5e\u6846\u4e2d\u6709\u7535\u6d41\u6d41\u52a8\u3002\n\n\u6e38\u620f\u73a9\u6cd5\n\u63a7\u5236\u68d2\u5b50\uff0c\u4f7f\u5176\u4e0d\u78b0\u5230\u91d1\u5c5e\u6846\u3002\n\n\u6ce8\u610f\u4e8b\u9879\n\u5982\u679c\u60a8\u63a8\u62c9\u68d2\u5b50\u4e2d\u9014\u8df3\u8fc7\uff0c\u5219\u6e38\u620f\u7ed3\u675f\u3002", "short_description": "\u907f\u5f00\u5371\u9669\u7684\u9677\u9631\uff0c\u5b8c\u6210\u8fd9\u4e2a\u6e38\u620f\uff01"}, {"images": {"nodes": []}, "id": "639922570772092", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{Instructions de jeu}\n\nBut:\nSuivez un parcours jusqu'\u00e0 la ligne d'arriv\u00e9e avec une tige.\n\nParcours:\nCompos\u00e9 d'armatures en m\u00e9tal dans lesquelles passe un courant \u00e9lectrique.\n\nD\u00e9roulement du jeu:\nContr\u00f4lez la tige pour ne pas toucher les cadres m\u00e9talliques.\n\nRemarque:\nSi vous poussez ou tirez la tige afin de sauter le milieu des parcours, la partie est termin\u00e9e.", "short_description": "\u00c9vitez les pi\u00e8ges dangereux et terminez ce jeu !"}, {"images": {"nodes": [{"file_name": "icon.png", "id": "1869809403214014", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001707_1869809406547347_6887606735657821599_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXvWYd20V9kQ7kNvgHSH6F1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC38BKcWdGujBlXcOPnXLQdKyo0VtYbK5NisLllEpX7kw&oe=671E133A"}, {"file_name": "seihoukei_cover.png", "id": "1578026155878263", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036700_1578026159211596_338271830850509098_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vE4cL9idtCcQ7kNvgHVfwyN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQhu__dEPyCsEbRQNsYXL84b4fvy1h5fusEBlEf_ifUw&oe=671E3B0C"}, {"file_name": "yokonaga_cover.png", "id": "1240561843078098", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395601_1240561846411431_4887466305539088189_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hL8LKt3npgUQ7kNvgETVDFy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqI1PEr1-YhEd2XITaxenseIKMm0QzXwI3Nwj3zleuLQ&oe=671E277E"}, {"file_name": "yokonaga_cover_mini.png", "id": "930274564509275", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982691_930274567842608_5766273061022504980_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9SQIe2xemJYQ7kNvgEj0thh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAmwMBokdszyONJopLJyX60vRXhGn9tU-XXoS1PEZwdsw&oe=671E2E38"}, {"file_name": "LOGO.png", "id": "888100301817418", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86625130_888100305150751_555978932806110321_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o8MQRpEwRIIQ7kNvgHRsWfr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2NJ9jbX3zxEB2JansdibYIMxpTvqzEhOWEg-iJA3rfA&oe=671E1403"}, {"file_name": "tategata_cover.png", "id": "595419838486713", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035438_595419841820046_7744875834505400073_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zQr0tPNShhAQ7kNvgGGGu_L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCGERm-fTqZ4jvgMrFScGytFxPwhz89wtQmQhiLfQ2XVw&oe=671E3D19"}, {"file_name": "hero_cover.png", "id": "158763436390785", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035310_158763439724118_8440205559282746779_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dPnuH3GAHkYQ7kNvgENpEAo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCb-GtfxRb0MCOutBmSKM4-VJ9NTmypatgiTEWC5L4iQ&oe=671E4174"}]}, "id": "615651099489769", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "328559578697467", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982562_328559582030800_3964552395773029908_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9V6-d-RShvwQ7kNvgH4duBr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZijPuIZ6caLoRZTybrKeQTrnpnfP2T8dY7s9hKgSMSg&oe=671E34E2"}, {"file_name": "2.png", "id": "3952378214882167", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_3952378221548833_1639886503750349976_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HfEcMscwZccQ7kNvgGrlTKs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXwmju8qVclSqAvvF8Mj-zVC_13QI8NgR3KrUBaECaoQ&oe=671E34D6"}, {"file_name": "3.png", "id": "858438364711668", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974708_858438368045001_8746315837893413292_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I3GF0a5jMXMQ7kNvgGDi12C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDFCs539XNzdvSLkaLFONERZ31WejdhGWrX8uhekgaYjg&oe=671E39A9"}, {"file_name": "4.png", "id": "303527271475290", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974703_303527274808623_6292384198010957693_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x7bJ9rZ6SWUQ7kNvgEejgvv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwA69JQmvEKClFy3Z2L8OgEhP6vrUlDvGtApqOmNfh5A&oe=671E2E4B"}, {"file_name": "5.png", "id": "238945707979780", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982473_238945711313113_6153747575536235554_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0CIL552indkQ7kNvgFFkmig&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcO5jkaUoggBHoIx4qE7WcTXet1xfcrXGLir8fbSEtfw&oe=671E24A0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "334694281412482", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974654_334694284745815_8646794835019241827_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WgEBh8YDt78Q7kNvgG5LoYV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCR1AdYhvjSbdclq3Kb5onlNyJOLIl9tSlng7larq2viw&oe=671E0E11"}, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{Game Instructions}\n\nObject:\nGo through a course to the finish line with a rod.\n\nCourse:\nMade up with metal frames in which an electric current flows.\n\nGame Play:\nControl the rod not to touch metal frames.\n\nNote:\nIf you push or pull the rod in order to skip the middle of courses, the game is over.", "short_description": "Don't touch the metal frame. You have to dodge the dangerous traps and reach the goal!"}, {"images": {"nodes": []}, "id": "460748882285122", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{Spielanleitung}\n\nZiel\nGehe mit einem Stab durch den Kurs zur Ziellinie.\n\nKurs\nBesteht aus Metallrahmen, in denen elektrischer Strom flie\u00dft.\n\nSpielverlauf\nKontrolliere den Stab, damit er nicht die Metallrahmen ber\u00fchrt.\n\nHinweis\nWenn du den Stab ziehst oder schiebst, um die Mitte des Kurses zu \u00fcberspringen, ist das Spiel vorbei.", "short_description": "Weiche den gef\u00e4hrlichen Fallen aus und bew\u00e4ltige dieses Spiel!!"}, {"images": {"nodes": []}, "id": "450297229894162", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "\u30b2\u30fc\u30e0\u306e\u76ee\u7684\u306f\u3001\u30b3\u30fc\u30b9\u3092\u901a\u3063\u3066\u3001\u30ed\u30c3\u30c9\u3092\u30b4\u30fc\u30eb\u307e\u3067\u904b\u3076\u3053\u3068\u3067\u3059\u3002\u30b3\u30fc\u30b9\u3092\u56f2\u3080\u91d1\u5c5e\u67a0\u306b\u306f\u96fb\u6d41\u304c\u6d41\u308c\u3066\u3044\u3066\u3001\u30ed\u30c3\u30c9\u304c\u89e6\u308c\u308b\u3068\u7206\u767a\u3057\u3001\u30b2\u30fc\u30e0\u30aa\u30fc\u30d0\u30fc\u3068\u306a\u308a\u307e\u3059\u3002\u307e\u305f\u3001\u30b3\u30fc\u30b9\u306e\u5916\u306b\u306f\u307f\u51fa\u3057\u3066\u3082\u5931\u6557\u3068\u306a\u308b\u306e\u3067\u3001\u6ce8\u610f\u3057\u307e\u3057\u3087\u3046\u3002\u30ed\u30c3\u30c9\u3092\u4e0a\u624b\u306b\u64cd\u4f5c\u3057\u306a\u304c\u3089\u3001\u5371\u967a\u306a\u308f\u306a\u3092\u907f\u3051\u3001\u30b2\u30fc\u30e0\u3092\u30af\u30ea\u30a2\u3057\u3066\u304f\u3060\u3055\u3044\u3002", "short_description": "\u30b7\u30f3\u30d7\u30eb\u306a\u30a2\u30af\u30b7\u30e7\u30f3\u30d1\u30ba\u30eb\u30b2\u30fc\u30e0\u3067\u3059\u3002\u5371\u967a\u306a\u308f\u306a\u3092\u907f\u3051\u306a\u304c\u3089\u3001\u30ed\u30c3\u30c9\u3092\u904b\u3093\u3067\u30b4\u30fc\u30eb\u3092\u76ee\u6307\u3057\u307e\u3057\u3087\u3046\uff01"}, {"images": {"nodes": []}, "id": "287409586682055", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "DANGER: ELECTRIC SHOCK", "keywords": [], "long_description": "{Instrucciones del juego}\n\nObjeto\nAtraviesa un recorrido hasta la l\u00ednea de meta con una barra.\n\nRecorrido\nFormado por armazones met\u00e1licos por los que circula una corriente el\u00e9ctrica.\n\nJuego\nControla que la barra no toque los marcos met\u00e1licos.\n\nNota\nSi empujas o tiras de la barra para saltarte la mitad de los recorridos, el juego se acaba.", "short_description": "\u00a1\u00a1Esquiva las peligrosas trampas y completa este juego!!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://redream-studio.jimdosite.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Redream Studio", "support_website_url": null, "website_url": "https://redream-studio.jimdosite.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "en", "fr", "zh_TW", "ja", "es_MX", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "398227958743039"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036700_1578026159211596_338271830850509098_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vE4cL9idtCcQ7kNvgHVfwyN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYrE3Kqo_mqeXiOrU5VjMnFZslKtHzO8EyZHfCtzkq6g&oe=671E3B0C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name":