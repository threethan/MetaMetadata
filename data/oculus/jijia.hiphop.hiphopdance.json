der which are not in list, E-Mail: \n408077086@qq.com", "short_description": "Hiphop dance is about hiphop dance workout VR app on Oculus Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Hiphop_Dance_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.cqplanb.com/ccc/Hiphop_Dance_info.txt", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "548013192910304"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SPORTS", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1151609255527827"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6067428473347745", "version": "2"}, "id": "204268105213776", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4659050097518930", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6067428473347745"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "204268105213776"}]}, "change_log": null, "created_date": 16788699