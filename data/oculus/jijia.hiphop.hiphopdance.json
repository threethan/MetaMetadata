.com/v/t64.5771-25/38982563_1796732487333308_5948835401682752735_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nl3C_-zaHZ8Q7kNvgE90AGY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdzPWCzxhCfNmSiR-zBbKDxV6WPTy5z8ZWcpaDI4t8-g&oe=676BF673"}, {"file_name": "\u80cc\u666f03.png", "id": "820967482605357", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569432_820967485938690_6817707012483217898_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULL72d80MeAQ7kNvgHwRElB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7xVA2KWLM2OOVc2iAROYVFvyOsQThGqQQaVG5K5DHWQ&oe=676C0201"}, {"file_name": "songlist.png", "id": "1277578999771089", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982460_1277579003104422_2101560975653113732_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXyZo-Jpk5sQ7kNvgG9v5bq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHBeqm9H3wOgwQs-3QJ4xMEuLeHBNc7hzAuq1340YyTg&oe=676BDA1B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440-3.png", "id": "1147540379134189", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575363_1147540382467522_3617361818081974463_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SJfBCOd0ckYQ7kNvgEFexEm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAERheQgEF011D2TxkbzSOKIqPGPoK3vGk13WbZwRgOEQ&oe=676BEB69"}, "display_name": "Hiphop dance", "keywords": [], "long_description": "1.  Hiphop dance is an dance VR app on Oculus Quest. We can see clearly virtual characters dance from any position, that is big difference from just video.\n2.  Song list is here:\nhttp://www.cqplanb.com/ccc/Hiphop_Dance-songlist.html\n3. We use microphone to react with rhythm, So If you refuse to open microphone permissions when first open app,there won't be reaction with rhythm. App still can work.\n3. Please make sure to review your surroundings and clear any obstacles in your play area before starting this game.\n4. You 'd better have sweat proof sleeve on your Quest headset, you will sweat a lot happily when playing this.\n5.  Due to Copyright of music, we don't include music tracks in this app. We support custom import .mp3 file songs into Quest and play.  This is how to https://www.youtube.com/watch?v=QfIdWHGalTY\n6. Will update new dance time and time,  If there are songs you wonder which are not in list, E-Mail: \n408077086@qq.com", "short_description": "Hiphop dance is about hiphop dance workout VR app on Oculus Quest."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Hiphop_Dance_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.cqplanb.com/ccc/Hiphop_Dance_info.txt", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SPORTS", "ACTION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1151609255527827"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974721_590011062755261_4968994622717830477_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2AjRxDiKPksQ7kNvgFoorrE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0R6i4-BJkocXHkDjP-LlYu991WmQsdVGFBiC8DkzAtg&oe=676BD431"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hiphop dance", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "