-3cselj4CjMlO-LhnoKElvCVAQcmjTy_Q&oe=6730B5A2"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LE2PEmKKwcQQ7kNvgH5nL6F&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDqdkYoJRgP_ithaoZzDwSD_T1PW9G23Nu4aG0yP4KoGg&oe=67308577"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=taJaGbX3LlgQ7kNvgGok6Wf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD5wxPHfehqVpijwQtQzhPz_biLCnsZKPZhbm0t25laAA&oe=6730AB18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "558206456169730", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984448_558206459503063_3938835359603651822_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PDj11vNlNX8Q7kNvgFMQrWD&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB8Hk58BdZ-PRErJPzag7Ac2XU_tsQiIg_61cLJblxTtA&oe=6730AFB6"}, "display_name": "Flight 74", "keywords": [], "long_description": "Do you have what it takes to survive and become the ultimate pilot?\n\nFly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will keep you thinking.  \n- Interactive cockpit. Flip switches, press buttons, and manipulate levers with your hand.\n- Make use of your belongings in the cockpit including sun glasses, coffee, and a hand gun.  \n- Solve puzzles in a flight game! \n- Movie style campaign and missions\n- 7 Airports and over 2,000 square miles of scenery\n- Explore vast landscapes ", "short_description": "Do you have what it takes to survive and become the ultimate pilot?\n\nFly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest. \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "https://www.tasappsystems.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "704899683851867"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "1736007273814766"}, {"status": "PUBLISHED", "id": "343163672210301"}, {"status": "PUBLISHED", "id": "1039918437332915"}, {"status": "PUBLISHED", "id": "411054491850755"}, {"status": "PUBLISHED", "id": "816671239881800"}, {"status": "PUBLISHED", "id": "299588912599546"}, {"status": "PUBLISHED", "id": "350444164617664"}, {"status": "PUBLISHED", "id": "475931238049137"}, {"status": "CANCELLED", "id": "795960795205367"}, {"status": "PUBLISHED", "id": "1041647110690849"}, {"status": "PUBLISHED", "id": "86848225