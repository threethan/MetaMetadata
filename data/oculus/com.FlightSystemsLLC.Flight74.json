dn.com/v/t64.5771-25/86615895_466098646181176_383379222211346210_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEW4TEMIm_AQ7kNvgH8n0wm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHSUr2s2vfsopYUHIHePmjxTZono9w_hIws8TaxrvShg&oe=6779221B"}, {"file_name": "IconNew.png", "id": "432530909874940", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974912_432530913208273_2024200231294476904_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iT5-16eatkUQ7kNvgHZtw5_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3IJdPuYoJXznFd3bFonSFstSIvL_urTZyAnhyq8aSHg&oe=677921B6"}]}, "id": "2054263368356184", "locale": "en_US", "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6izbJsX9ogMQ7kNvgFKlpSQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxq3UZC1Bp3wp11KUIKv6riOYcZWA_JfKkzYReMXiHIQ&oe=67790974"}, {"file_name": "Multi1.png", "id": "1270517173980349", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974902_1270517177313682_4082952557762720495_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1R4aiyhOko8Q7kNvgH61uxi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDKOJWq9mI1FIshWTzxX5f_kxPwhmoJlNWuwaOb8QUbSQ&oe=6779031F"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=slhMD5ZH6VgQ7kNvgFpKQji&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAd2d0QQF6qVJnnHUJKsbq3OfM_3IpZ1GMb-1SSOKBNZQ&oe=677907F7"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D0wRi50ouTMQ7kNvgEek8l7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2I4Oac8eGAfo4Bumfs1ESb0JiCDLOmYpJOmH6UZ31vQ&oe=67793822"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eFdvgF0-SVgQ7kNvgH2i7fm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYEjFjsV-UcW0C8VPeY39qtC26vTKyr5jIpPPkI-eMig&oe=67792D98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_NewLarge.png", "id": "906137537640817", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974750_906137540974150_1695977931889531979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zNP-ZclVbI4Q7kNvgHeQJVm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDlD5n_o955gDz52HGCIIRCqTT7iaiSTD17-EMZ6LqjA&oe=6779203F"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n\n- Multiplayer! Dogfight against your friends! \n\n{574744495234388}\n\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "https://www.tasappsystems.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8128293847272576"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86615895_466098646181176_383379222211346210_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEW4TEMIm_AQ7kNvgH8n0wm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAK6NHWkP4ssS4FyMtGpSwBERugA2WzYag-cOY_fzebcA&oe=6779221B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Flight 74", "platform": "ANDROID_6DOF", "c