dn.com/v/t64.5771-25/86615895_466098646181176_383379222211346210_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEW4TEMIm_AQ7kNvgGr2UIG&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCVopa5UkImhHfoHWOMKWeiv8dCk9cfg6Z5L-elck25WA&oe=6777D09B"}, {"file_name": "IconNew.png", "id": "432530909874940", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974912_432530913208273_2024200231294476904_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iT5-16eatkUQ7kNvgFVDpfi&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDDrYtVkGuZFY1vj9NG5l0Xv8YQjxhwdjDvVB8wK_Z2kw&oe=6777D036"}]}, "id": "2054263368356184", "locale": "en_US", "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZpMIiHd9wTcQ7kNvgEWHVdV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYADAsKbi8WeGniT6AeCpgGaSE3eSK-RJtO6bhKsv5s3-w&oe=6777B7F4"}, {"file_name": "Multi1.png", "id": "1270517173980349", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974902_1270517177313682_4082952557762720495_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1R4aiyhOko8Q7kNvgGJqBo5&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBA6zjPnuJ7tRwUqE6-k3Kdiqj8NvtN5z_9qzG9VnAHJA&oe=6777B19F"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=slhMD5ZH6VgQ7kNvgENbu0_&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAFMgACeNqx1pLvZjWjnaUWxzabshWymYu8ooz0vpjMjQ&oe=6777B677"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D0wRi50ouTMQ7kNvgGiZE_R&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBrbi2SrT2J0ofb10dZWgfgD-z_kT7ZqwLEuuEmHp1iiA&oe=6777E6A2"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eFdvgF0-SVgQ7kNvgE0TbgI&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDOEuXhME8kEhwKRa4faWI129rciVBKuXH2LQAY7KrKdA&oe=6777DC18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_NewLarge.png", "id": "906137537640817", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974750_906137540974150_1695977931889531979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zNP-ZclVbI4Q7kNvgHamHro&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCMjoxje1RV7jjZy-mCRWJUOlEh7j9SGXsir_F6vrGvRg&oe=6777CEBF"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n\n- Multiplayer! Dogfight against your friends! \n\n{574744495234388}\n\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "https://www.tasappsystems.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8128293847272576"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/86615895_466098646181176_383379222211346210_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEW4TEMIm_AQ7kNvgGr2UIG&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAjNIky3OZAEIx8E_gOxqqFI6qTWJcuNNdwxHdv4hzSmw&oe=6777D09B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Flight 74", "platform": "ANDROID_6DOF", 