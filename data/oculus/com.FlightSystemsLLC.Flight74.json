n.com&oh=00_AYAxd15F6ivBPfOi-T_YCeBpssbUzLV18Bh59RE7aKMA2Q&oe=67600A55"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UIGfB60Wh-MQ7kNvgHZKFZi&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAtV3oJ-FvhM8KYKp0oAkCAOS4BfMHF0OZhRuLsMSDzrg&oe=67602BA2"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kxApSkMSbOsQ7kNvgGXSV1O&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAtfClrzfENG0ib9rm7aBeKuzq5yEuPmS5D-5-8yz4Msw&oe=675FFB77"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aAlYZyTqti0Q7kNvgEDTlPu&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAq7zbLKumKbZUBm3FRA8k2xdt49NZ2bkSEHlEH2WS78g&oe=67602118"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "558206456169730", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38984448_558206459503063_3938835359603651822_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HPrt5vurtHcQ7kNvgGrGIXg&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAQKrQeyq4WzRlG0p-TaQapDl1p1Rnymnm_RqrIcT3bTw&oe=676025B6"}, "display_name": "Flight 74", "keywords": [], "long_description": "Do you have what it takes to survive and become the ultimate pilot?\n\nFly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will keep you thinking.  \n- Interactive cockpit. Flip switches, press buttons, and manipulate levers with your hand.\n- Make use of your belongings in the cockpit including sun glasses, coffee, and a hand gun.  \n- Solve puzzles in a flight game! \n- Movie style campaign and missions\n- 7 Airports and over 2,000 square miles of scenery\n- Explore vast landscapes ", "short_description": "Do you have what it takes to survive and become the ultimate pilot?\n\nFly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest. \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "https://www.tasappsystems.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "704899683851867"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "1736007273814766"}, {"status": "PUBLISHED", "id": "343163672210301"}, {"status": "PUBLISHED", "id": "1039918437332915"}, {"status": "PUBLISHED"