, "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mHp6b_qnzQUQ7kNvgEs4eco&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYAJPqp_NqZ0i07-KuqxezOtA-x6wz-mGl-8jpYHJvUtGQ&oe=66E6B2F4"}, {"file_name": "Screen.png", "id": "1261955487684864", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031346_1261955491018197_4241196221176186705_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g7l2z_JGVp4Q7kNvgEB_5t4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYAStJUIVyKFi0Pz2N-66Am2i6cxjyRo4isWKBh9yki_tw&oe=66E6C055"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MBAlLbtXoHIQ7kNvgFkXX73&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYDujP3Fhrlv9811ukDZhEpjVP-QYoIzWfvBcdpC0hFwxA&oe=66E6A962"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sbO9OK4o-qUQ7kNvgEYlfQ1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYCExoYUViGQi4t5lj-JNL5MDh6GUg18od5lN16wwDHPpA&oe=66E6B177"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9079mHmSid4Q7kNvgEyWgBO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYD0uKRHklioKL4xXm4SZf85VNxcfkSuzDv9q8z_4YuUsQ&oe=66E6D718"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "558206456169730", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_558206459503063_3938835359603651822_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gtjQL39VapoQ7kNvgEPsndj&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3EQX8IB6vPlsLWwWhk_AVL&oh=00_AYB4nuGnZBKh_J2VN1oihwHh434O8vg1NuvxH4-1ZfHsEQ&oe=66E6DBB6"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity Youtube Channel!\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}\n\n- Multiplayer coming in September!", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com