/38974442_498783155892972_5209911665256971307_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7FUGVvyTy-AQ7kNvgHQWozB&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCt5esiAbX8BbYhe9PRTSOc8NTm4eSBrVVPaF5xrz7VcQ&oe=6724DA81"}]}, "id": "2210436979356432", "locale": "en_US", "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oOU8GGHgzOIQ7kNvgEasUpM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB7-l3KUKvTihHk9sweh-9XgVlUhVVeSGwaWHfFBghl1w&oe=6724A974"}, {"file_name": "Screen.png", "id": "1261955487684864", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031346_1261955491018197_4241196221176186705_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UQoUxvvD2rMQ7kNvgGjanIi&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCD09eW-PcsZxfwAJXmCmgDc6_0Y9u-7p44VXwK4j9Jvg&oe=6724B6D5"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUmoIDRUdp8Q7kNvgF6khRZ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAO1-zhePevYYzoawxrQwYMd5X52y4Om3HTetG7PcRoIQ&oe=6724D822"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mkfvdWWvYbIQ7kNvgFFBlxx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDNi04KFpNPC6UAyVKlVcXpv-TI_uCUEVOaJTeR0zwAaQ&oe=6724A7F7"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2C8YKN80RC0Q7kNvgHnAZfG&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBvyLfP-yoX523r3Eo9hjoU9rt-GUpNthy7KD2FuQwzlw&oe=6724CD98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_NewLarge.png", "id": "906137537640817", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974750_906137540974150_1695977931889531979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U8kWpneIAZAQ7kNvgFba22-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAeQc8PSet6rv7La7-KtifH9_97-YiQ81Ioz6hj8cRaFA&oe=6724C03F"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n\n- Multiplayer! Dogfight against your friends! \n\n{1772212713585476}\n\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}\n\n", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine fai