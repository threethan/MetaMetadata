scontent-iad3-2.oculuscdn.com&oh=00_AYB5lrhgsLYZADzLAXzMDDsPOn6yr-SJlY2DP7W9Ii5nQg&oe=6720E601"}]}, "id": "2210436979356432", "locale": "en_US", "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A_RsYEeU5XUQ7kNvgE6g7Hb&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCe9x0vBBbixuZEC3c8H5gFdPxTaU3kfuCsM18NiWl6kA&oe=6720B4F4"}, {"file_name": "Screen.png", "id": "1261955487684864", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031346_1261955491018197_4241196221176186705_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k7PMywDK2j0Q7kNvgFnq5fe&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDFGwplDQjfatUj4ZNG2lHQnAnJRTTtTXZ1ljQDRCylXw&oe=6720C255"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ep8mKqsYRuUQ7kNvgEOdUHa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnrdYB66qHJIKycxUkrmlSjY7yVBgRgbSr9pK6kKcmvw&oe=6720E3A2"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t8YRrAzmpYwQ7kNvgEVWE43&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrMZSQF8Z0vEVWyHj5-vOK_93DBLstYcOShOItWvt8jw&oe=6720B377"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-C3fsY5UJjcQ7kNvgHBG38A&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8o5I0dD-JxatEGMjYY3JvNQ7GTJpOuyEehNeQii8Ctg&oe=6720D918"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_NewLarge.png", "id": "906137537640817", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974750_906137540974150_1695977931889531979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LUpvfkhES1MQ7kNvgFb-DTj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAU1OzFX2I7_OI5onprpB_GUnKUGayxAAlbnScLeM9Og&oe=6720CBBF"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n\n- Multiplayer! Dogfight against your friends! \n\n{1772212713585476}\n\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}\n\n", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_nam