5/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K68N2OQyk8gQ7kNvgHw3mu0&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCrYhABH_QwsRRl-WAptB2NW_Mew11JvK2e7uNvLDfRkQ&oe=671A1D74"}, {"file_name": "Screen.png", "id": "1261955487684864", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39031346_1261955491018197_4241196221176186705_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I6D5jBSyQA4Q7kNvgFKro9f&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBAzyWi_i8_3YJ4F2kre8k-Nofa4_3Mf08GMrhuAGZpyg&oe=671A2AD5"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o7gLQEi0KhYQ7kNvgHODv1Q&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCsd2PQeeGE3TxZtXHwZStt3e0qF5ctkcXNALBHY1y52A&oe=671A4C22"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pun52u3tvw8Q7kNvgEnck9t&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYD5a-_zE3hWS-5ndInQI0h-3nclNrlL8tPZjeuayEJF3g&oe=671A1BF7"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hj7Ow26FNz0Q7kNvgEAt5l9&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDBM0af1N105vVUEgyMt2OK_suH-sSNeSDqY5bq_J8c5A&oe=671A4198"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "558206456169730", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38984448_558206459503063_3938835359603651822_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=11iPJw27vTcQ7kNvgFH9Fa6&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDqkvzf-WFBUKHHchbSMjBiKuszsLA1S_TosrXsF7ZoLQ&oe=671A4636"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}\n\n- Multiplayer coming in September!", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tasappsystems.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "TAS Systems Corp", "support_website_url": null, "website_url": "https://www.tasappsystems.com/", "category": null, "comf