m/v/t64.5771-25/38974912_432530913208273_2024200231294476904_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=31IbyzlKjKAQ7kNvgH6Nuqz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAftPdnPjfTsN9gsSM_Tp9D-hgBISx9Zu7dduLaZTM3oA&oe=67309F36"}]}, "id": "1771181096752885", "locale": "en_US", "screenshots": [{"file_name": "Trees.png", "id": "876081273523944", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031512_876081280190610_3954857504188214429_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r77L6vxed-sQ7kNvgHTIY2v&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDfqf9TrFCT1Ol5arDZK49Pfn4bz073D6ePpcbjM7nIKQ&oe=673086F4"}, {"file_name": "Screen.png", "id": "1261955487684864", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031346_1261955491018197_4241196221176186705_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tB-qIntJ9C8Q7kNvgEW8OvE&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAOUvpVGL7UUxcMoxpM-yYE9_wWUDca4TkcFLjrP0U0xA&oe=67309455"}, {"file_name": "water.png", "id": "681223590152886", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031565_681223593486219_5916754183577692195_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ca9Jax2zz-4Q7kNvgF9R4A5&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAokg5k27t6o-3cselj4CjMlO-LhnoKElvCVAQcmjTy_Q&oe=6730B5A2"}, {"file_name": "Airport.png", "id": "548530253852441", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974759_548530257185774_3873336191968563335_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LE2PEmKKwcQQ7kNvgH5nL6F&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDqdkYoJRgP_ithaoZzDwSD_T1PW9G23Nu4aG0yP4KoGg&oe=67308577"}, {"file_name": "Drone.png", "id": "518820930051489", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974554_518820933384822_1330063616294728279_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=taJaGbX3LlgQ7kNvgGok6Wf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD5wxPHfehqVpijwQtQzhPz_biLCnsZKPZhbm0t25laAA&oe=6730AB18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_NewLarge.png", "id": "906137537640817", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974750_906137540974150_1695977931889531979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mv3GybFBZPYQ7kNvgEu0gt9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDDeKxYO7f7LKyJgKLdhaeRgvp-T4c00wJ0NtGd3MW7hw&oe=67309DBF"}, "display_name": "Flight 74", "keywords": ["Flight", "Simulator", "Flying", "Airplane", "Sim"], "long_description": "Do you have what it takes to survive and become the ultimate pilot? Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  Rated one of the Top 50 Games on Quest by Vrelity.\n\nYour plane has experienced engine failure and you're forced to land at an unmarked runway off in the distance. Unfortunately for you, the runway is operated by a notoriously dangerous South American Cartel. Your only chance for survival is to work with the cartel and prove your worth.\n\nFeatures:\n- Complex missions that will test your skills\n\n{2750905198401036}\n\n- Hand Tracking! Put down the controller and play with your hands.  Interactive cockpit. Flip switches, press buttons, punch windows, and more!\n\n{849356023396469}\n\n- Multiplayer! Dogfight against your friends! \n\n{1772212713585476}\n\n- Quest 3 Graphics Updates and Improvements\n\n{1503648260255664}\n\n- Make use of your belongings in the cockpit including sun glasses, coffee, and guns!\n\n{498783152559639}\n\n- Solve puzzles in a flight game! Movie style campaign and missions!\n\n{1664355374355543}\n\n- Free Flight Mode with 7 Airports and over 2,000 square miles of scenery\n\n{764494538995077}\n\n- Cars, Birds, Cartels, Explosions and more! \n\n{1643006099819731}\n\n", "short_description": "Fly missions for the cartel and experience a new genre of VR Flight Simulator, exclusively for the Quest.  \n\nYour plane has experie