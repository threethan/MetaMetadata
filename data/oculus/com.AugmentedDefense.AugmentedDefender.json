=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-9FbXTzLGoQ7kNvgHhkwLt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDv4n97RXAp3TXio2G3CPINypQVDp47JkItt9ypCwoSgg&oe=677D1058"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCoverImage.PNG", "id": "1660353114371441", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982695_1660353117704774_5041858368859999884_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BXtb2icvpAkQ7kNvgFndNwB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVTOOBxUYs2X6HSD44yB5awrUHJIy8-tOAvrVIG2RtVQ&oe=677D227B"}, "display_name": "Augmented Defender", "keywords": ["Action", "Shooting", "Simulation", "zombie", "survival"], "long_description": "Looking for reality based trigger time, that incorporates your home in the experience? We create hardware and software to ground the experience even more in the real world, for the most immersive XR weapon handling experience out there. Once you have the basics down, add stress to the experience by trying to hold off a zombie hoard, trying to invade your home.\n\nCustom Stocks (All) - Full customization\nRecommended: XR Pistol, XR-15, Ace Pistol Handset \n\nHaptic Integration supported:\nProtube, Bhaptics\n\nMultiplayer is currently in closed Alpha Testing, Drop by the Discord if interested in joining: https://discord.com/invite/GgQy6qugZU", "short_description": "Ready for the end of the world? Lets find out. Target practice and guided drills provide trigger time to help you prepare for waves of hostiles coming to invade your home!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://augmenteddefense.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Augmented Defense", "support_website_url": "https://www.reddit.com/r/AugmentedDefense/", "website_url": "https://augmenteddefense.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_