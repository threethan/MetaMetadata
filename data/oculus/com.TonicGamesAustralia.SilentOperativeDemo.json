14301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HGg4kqdGzwoQ7kNvgGd_tld&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIrvpkVa-a41X7WVkTtSnQUKNsaAWbUqZmQJ4UouZo6g&oe=66F7E652"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pi3mpgeH_EYQ7kNvgGiPa5D&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUiAtaI_Oq8KDInaTp_TLaf7VH0woR69KlZIva1MxFuA&oe=66F7DA6B"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-privacypolicy.html", "developer_terms_of_service_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-termsandconditions.html", "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"i