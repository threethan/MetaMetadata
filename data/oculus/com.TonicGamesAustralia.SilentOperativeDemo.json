uluscdn.com&oh=00_AYALvJpDGwWsBBwd2Yr0ephas-rge0drVGuamLLO8h1M1g&oe=670F8A91"}, {"file_name": "Screenshots5.png", "id": "1074451510968401", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001663_1074451514301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fNGJebQW6OYQ7kNvgGrh3IR&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYChzIVWAoWFFDt5Etm7252gHG02zs5uoFg4aBWpgv91Kg&oe=670FA152"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GJgpSNfvGHAQ7kNvgGz4BAK&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDq2OZ5aCmP_1h4AkiL_sM1XIE4dqrjbNprxlO8Ngz0xA&oe=670F956B"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-privacypolicy.html", "developer_terms_of_service_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-termsandcondit