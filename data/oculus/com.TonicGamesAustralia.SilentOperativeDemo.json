0558411_3218234859466557792_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jHvHyd9MVLQQ7kNvgE30amY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7BHjG3wKMPHLvHyXl-ZaZfa5GNkEJg3NFJZznV7xKdQ&oe=671CB991"}, {"file_name": "Screenshots5.png", "id": "1074451510968401", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001663_1074451514301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XaAUpjxGMlgQ7kNvgGWnDy4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBy2MRBPiYN1SUxu4Xjcsm1k1O95DPLIqX57wQ40aDoIw&oe=671CD052"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T60PVKPGxx4Q7kNvgH8Ffnp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKk-MZGScQ81_xinzIoL-Ab4LV0oUVZcC_41peLJZb4g&oe=671CC46B"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaus