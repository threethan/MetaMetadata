0558411_3218234859466557792_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oOx9zhrWFvsQ7kNvgFIlZwV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQSPw20_VV9Cd-hrSxrbD-1wDdCsEgRcA2BBgPDrPipg&oe=676A8211"}, {"file_name": "Screenshots5.png", "id": "1074451510968401", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001663_1074451514301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VK1ezBZMvFQQ7kNvgHQD1uQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8EIypARvtl99wkh494SGy8Eb3osB8--3OGaUoz7wwqg&oe=676A98D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GdqDIbupqBQQ7kNvgHd8mU6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqkHJko72rH7fX_bYQ8O1heu9sy-eBVNS4nGlZRiIGFw&oe=676A8CEB"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaus