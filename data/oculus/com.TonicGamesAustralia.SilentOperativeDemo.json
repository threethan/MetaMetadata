14301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UX6saE_0l3gQ7kNvgELlinx&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5cY5e7oyIQ4rRO4rY8j5o-iDKY5tG8JOaxN_iogOkYw&oe=66E965D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DeRGL3F6Xp8Q7kNvgGGdjel&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrs6gJf6YBvalMdP09-ZTgRPU8JiiMCgt9uHgRGjjc-Q&oe=66E959EB"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-privacypolicy.html", "developer_terms_of_service_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-termsandconditions.html", "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"i