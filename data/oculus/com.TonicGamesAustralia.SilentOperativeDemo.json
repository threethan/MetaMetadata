0558411_3218234859466557792_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aihGcVh87QQQ7kNvgFt9UvL&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCtPW5z68Y6prApHvDpeHL7sokQ867bx7wvlhUsKLrfGQ&oe=67584551"}, {"file_name": "Screenshots5.png", "id": "1074451510968401", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39001663_1074451514301734_8857042524484054552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cIA7QWJLpaIQ7kNvgHtulWm&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAJ64IP86-9LbXBXm7GkO5fNlVY-kDihLdTow5CV01JWg&oe=675823D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeMeta.png", "id": "1870123156840153", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982517_1870123160173486_1027101132353454696_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ChhHSedmBBIQ7kNvgGprnvQ&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDhgXKu-pwVwOpkIQhR_y4BNoo2VXBT0Yh4bmCcx4Kpkg&oe=675817EB"}, "display_name": "Silent Operative Demo", "keywords": ["demo", "silent", "operative", "free", "shooter"], "long_description": "Elite Secret Agent Experience: Immerse yourself in thrilling VR stealth-action gameplay.\n\nHigh-Stakes Missions: Navigate through intense missions using weapons, gadgets, and strategic skills.\n\nIntense Combat and Stealth: Engage in firefights, execute silent takedowns, and employ advanced espionage techniques.\n\nStrategic Planning and Execution: Plan your approach, assess enemy patrols, and exploit environmental opportunities.\n\nStunning Visuals and Immersive Gameplay: Experience stunning visuals and immersive gameplay.\n\nAre you ready to become the ultimate secret agent?", "short_description": "The Silent Operative Demo thrusts players into the shoes of a secret agent, where they must utilize a versatile arsenal of weapons and gadgets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaus