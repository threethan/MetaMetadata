ets to navigate through dynamic and challenging missions.\n"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-privacypolicy.html", "developer_terms_of_service_url": "https://tonicgamesaustralia.com/SilentOperativeDemo-termsandconditions.html", "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26552409024402868"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035352_796588262595652_560790925109922209_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DLW8c7S46_sQ7kNvgGccUjD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlXNa6yUEnOC_0taH9UKnrX&oh=00_AYC6EVBbXpspwP51C3C8UtEakNFMu_n-FC52QwsBDEEopA&oe=66F5353B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Silent Operative Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1721462400, "lastRevision": {"nodes": [{"id": "25