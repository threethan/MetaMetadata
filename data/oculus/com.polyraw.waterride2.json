eme edition of the most incredibly realistic Water Rollercoaster of the world, that will brind you to the next level of andrenaline into virtual reality.\n\n\nWelcome to the exteme edition of the world most amazing Water Roller Coaster reproduction of the main water ride of theme parks"}]}, "developer_name": "Tecworks", "developer_privacy_policy_url": "http://jined.great-site.net/privacypolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Tecworks/Polyraw", "support_website_url": null, "website_url": "http://jined.great-site.net/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "RACING", "ROLLER_COASTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7269886133056940"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974468_2226821184301473_5527348865268711424_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k6EIi36luTYQ7kNvgGr7X9_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnIlPHafqOrtP1uMKQ8JJLVoKA6Fx2XUArIKdy7wR04w&oe=67641EF4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Water Ride Extreme", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1548180000, "lastRevision": {"nodes": [{"id": "1992797884112025", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "20021185898337