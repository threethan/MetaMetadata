67993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036690_791771061701326_4587678695224666393_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TxKbR11NoXUQ7kNvgE-ZdCj&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwL1CphHtrF45mLvu2G3sQiQkwecT1v3qDU0ADnsU0Sg&oe=66F7CECD"}, {"file_name": "x-booster_001.png", "id": "998197854254517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984443_998197857587850_5704094498029065403_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hMlhMnrPFYkQ7kNvgGzrXr1&_nc_ht=scontent.oculuscdn.com&oh=00_AYATjAl1LBYtl0VGJe8HFnrOLEWQcoRdEFulpGlF140uaw&oe=66F7EE5F"}, {"file_name": "scr_16.png", "id": "907107946700595", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031322_907107950033928_2161283847196508593_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=buvVEIWdxp0Q7kNvgGIN7ah&_nc_ht=scontent.oculuscdn.com&oh=00_AYAHe6PiH_he3pRiEgPtDpmtdY-GvtUi0eiNdzmrngaIXg&oe=66F7E8AB"}, {"file_name": "scr_2.png", "id": "478084063581508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_478084066914841_7574135440889036949_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zyfA0gnYJuAQ7kNvgFEo8bh&_nc_ht=scontent.oculuscdn.com&oh=00_AYBO7lx0rXXmjQruRJj6PDvyGcHBgaZ81ZmPDWFL0N9Mqw&oe=66F7F45F"}, {"file_name": "scr_1.png", "id": "2062074523923454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984464_2062074527256787_301239079180693449_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dDu2ko8ah_kQ7kNvgEkQ92x&_nc_ht=scontent.oculuscdn.com&oh=00_AYBafyStoaG44LQOl47T38unI5qXxnxmit3mQ0b_BKcUBw&oe=66F7CF68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "demo_splash.png", "id": "2385733884896368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031609_2385733888229701_1887006760644483219_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kffv0PUzgEgQ7kNvgFGfQJq&_nc_ht=scontent.oculuscdn.com&oh=00_AYAeyId1FNKAoFVCY4gY2IB88wiH0uGiGtzHZ6kzYOyVsQ&oe=66F7FD5E"}, "display_name": "X-Fitness DEMO", "keywords": [], "long_description": "X-Fitness is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-Fitness supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-Fitness is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/nivision-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://www.facebook.com/groups/xboostercommunity", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr