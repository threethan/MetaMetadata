uscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYDi9xHJ2lnSnbxFDsny6ljtMp4SbMrSum__UPvKPUDl4Q&oe=66EC06AA"}]}, "id": "463955868634554", "locale": "en_US", "screenshots": [{"file_name": "x-booster_002.png", "id": "791771058367993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036690_791771061701326_4587678695224666393_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKIhCZoJnpUQ7kNvgGQnQPP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYAvvDDaBoFzMyXd5bANQgwStFH9A8qHMBX6tpBCp27ULQ&oe=66EC298D"}, {"file_name": "x-booster_001.png", "id": "998197854254517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984443_998197857587850_5704094498029065403_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EnorV-4DsG4Q7kNvgHanAE3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYBkBVzykUtH50r-VDKrQ2EHQiap5mNYmshuLUbOSK7f7g&oe=66EC10DF"}, {"file_name": "scr_16.png", "id": "907107946700595", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031322_907107950033928_2161283847196508593_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzRjsT5ym1cQ7kNvgGO6FAV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYC8ypJgKGzSQiO9Z9H-3jUkgQbx3CcBFZBbJCgtK4DVIg&oe=66EC0B2B"}, {"file_name": "scr_2.png", "id": "478084063581508", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_478084066914841_7574135440889036949_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sXXqimhOGagQ7kNvgGHjrGx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYCcCIyl9tK1XbN_TSxvTP6zUiUBQGGuM2EWUOE2CFIL6A&oe=66EC16DF"}, {"file_name": "scr_1.png", "id": "2062074523923454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984464_2062074527256787_301239079180693449_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=chxePIzQONEQ7kNvgGGKvsi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYBZoartvd1v_M21vBXloUppvlmnld3RvJxfyd9kjEAxDg&oe=66EC2A28"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "demo_splash.png", "id": "2385733884896368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031609_2385733888229701_1887006760644483219_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1gGewIph2iUQ7kNvgEt2-s9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYDXuHTRaXxMoulhNAV8Qdwe_Q8aDTX-Xm9AaY4f1j824Q&oe=66EC1FDE"}, "display_name": "X-Fitness DEMO", "keywords": [], "long_description": "X-Fitness is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-Fitness supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-Fitness is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/nivision-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://www.facebook.com/groups/xboostercommunity", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_ta