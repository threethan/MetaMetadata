0D2DF"}, {"file_name": "scr_7.png", "id": "1077721782639922", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86615257_1077721785973255_1881847905213356415_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BXHvs71iey4Q7kNvgHB1i8_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD1iqB3Mqkxcvm5nuJxIk2zsiG9cAV00hML6KLrWoaR-w&oe=6720D4B1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "demo_2560x1440.png", "id": "3890773997620942", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974677_3890774000954275_6999002797222852641_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXSIbM65tW4Q7kNvgHrsxWl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdWm4VCZKuOBqoOZUe1TfqAguIx2LI-aAwjuvdWJTKdg&oe=6720C15B"}, "display_name": "X-BOOSTER DEMO", "keywords": [], "long_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-BOOSTER supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.nivision.org/x-booster-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NiVision", "support_website_url": null, "website_url": "https://www.nivision.org/x-booster?lang=pl", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "423791972872307"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "181055146956471"}]}, "baseline_offer": {"id": "181055146956471"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1615999800, "status": "PUBLISHED", "id": "181055146956471"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4597369660341179", "version": "3.50"}, "id": "783829859153669", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3640513506026804", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4597369660341179"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1643282385, "id": "4772712562806887", "version": "3.51", "version