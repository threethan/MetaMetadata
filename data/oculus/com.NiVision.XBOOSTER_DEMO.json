nt.oculuscdn.com/v/t64.5771-25/86615257_1077721785973255_1881847905213356415_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qm8ZtUw2Cz4Q7kNvgELje9z&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYB_zpy8VpuD-GLGA8eqv6Q9wFJPc0g1o4acuxyw2thUQA&oe=66EC18B1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "demo_2560x1440.png", "id": "3890773997620942", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974677_3890774000954275_6999002797222852641_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Vpv6tQX-_UQ7kNvgG_fkYY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkO-PcU5GYq5QolXyFz6ZJs&oh=00_AYDcofkrp9r3-GFFHc8eoYaDnrdCjZa1YQ51JDpNybLJHA&oe=66EC055B"}, "display_name": "X-BOOSTER DEMO", "keywords": [], "long_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout!\nSelect any of our handcrafted original tracks to get your groove on to and start burning those calories!\nWant to jam out to your own set of tunes? \nNo problem, X-BOOSTER supports your own MP3 files as well. \n\nStand and fight off the pounds in the virtual arena! \nPunch, cut, block, and dodge your way to a slimmer you.\nHit all the beats by moving fast and aiming precise blows with your gloves.\nGrab projectiles by using the shield. \nAvoid obstacles by bending and dodging.\n\nSpeed and strength are also a factor. Punch as hard as you can to get the highest score!\nExtensive statistics show your results and progress. \nMatch the training level to your personal skills: \n - warm-up or train with your favorite workout, \n - for challenges choose the most intense mode, \n - or create your own training and go at your own pace.", "short_description": "X-BOOSTER is a fun and innovative way to enjoy an intensive VR full-body workout! \nStand and fight off the pounds in the virtual arena. Punch, cut, block, and dodge your way to a slimmer you! Start burning those calories with handcrafted tracks or your own MP3 files."}]}, "developer_name