1975739920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3rFDr393gwQ7kNvgE5o7sC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJsHwILV04dciN-5otnjZ96&oh=00_AYDt4PXBv3MYwwTNG3Xn5zub9i9wSPpahG8Hr6-r4lqFiQ&oe=66E1851E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dOLRUK9wYKkQ7kNvgHoCxiI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJsHwILV04dciN-5otnjZ96&oh=00_AYBK47KwrVlIi3YE3B4BeY6-t87CMDe2ap0Fk-TzX8VwEA&oe=66E18FA6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2BtvDXXKg1kQ7kNvgH7ZfEA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJsHwILV04dciN-5otnjZ96&oh=00_AYDxc18uurtoQ4JUT7DtO-5Ymn46PvYn_WaYKO5-lnl0SA&oe=66E18E7D"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_s