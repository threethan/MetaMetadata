9920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wMx-whwx_MQ7kNvgFR1kxK&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALzPzDWAL8xcESPzRzALzO6&oh=00_AYDXRnVZOxSyIOmT-bu3aVCI_0m94O_NK-TDipjrO_tegg&oe=66F3FA1E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eQHQ5y9vCFcQ7kNvgG2NSBR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALzPzDWAL8xcESPzRzALzO6&oh=00_AYDCwvODkUtLVnr912RDJQLVEzoeTWFrJqsGWY3AshWZIA&oe=66F404A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJBVzoRC-uwQ7kNvgHj33Z9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALzPzDWAL8xcESPzRzALzO6&oh=00_AYBCmyL2EiZUSjJrh9Y5QtPPdApQYYm7FRK6MqfqN6gZ9w&oe=66F4037D"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service