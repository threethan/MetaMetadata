42741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NbdDCoqPxK8Q7kNvgFRXjHv&_nc_ht=scontent.oculuscdn.com&oh=00_AYBbo8maZS2SiHO1pOLXo8_yvFoSFgqPISeR4NYs7NKD3g&oe=66D460A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKQMaT8ZOD4Q7kNvgEnHwlE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAspIRQGxgd4Pe_6bW8EaNj4tnih2_dEdRTuGYAcXYFbw&oe=66D45F7D"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Fonster", "support_website_url": null, "website_url": "http://f0nster.com/zap.html", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED"