3", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974702_1101337108234776_5101326466679987088_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PUM57AcIjTgQ7kNvgE3IZuz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyd7iRW5XEH_xhLhSc_PfFqaRkIX0PtNMLyCHA9DIImQ&oe=67695FA8"}, {"file_name": "Logo_ZAPsy.png", "id": "543810031833136", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031427_543810035166469_4522342917961267166_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPPWgq7vjHIQ7kNvgEdeIMT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDC1q4rJ0f3m12W61ljpn8AtDSC6P6i9svJVKcYWJqNqg&oe=676950DF"}]}, "id": "1091884085932484", "locale": "en_US", "screenshots": [{"file_name": "StoreShot_2.png", "id": "570135115360534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_570135118693867_7035685137998896964_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2XrfmCh-VQAQ7kNvgFu-GKr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgrPnplGb9NR7gcWMbMa0ySYkIGgABp7RV-vAAuvDP8w&oe=6769478D"}, {"file_name": "StoreShot_1.png", "id": "1072765247717589", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75272215_1072765251050922_4758062684767070629_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lqtQ1SrnsoYQ7kNvgFwx1MH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB-8qAUDUedbAX198hxvC7yEenWIxr94g5oBcc_nNTlSw&oe=67693C8E"}, {"file_name": "StoreShot_3.png", "id": "754426583496315", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974758_754426586829648_261525823422325319_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vg7AeTeLUGUQ7kNvgHSAuK_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM2-rwH1mG_iwsm-cF6pCoicjznMgEB2kzvYoQlaWZ8w&oe=676967FF"}, {"file_name": "StoreShot_5.png", "id": "1060579662530481", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035405_1060579665863814_3026570350454008856_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vrS5H5lLbCsQ7kNvgGennE4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5piqu6vRxWPfcMk5bhubB4xOUB38_RM7qL7q7MRNSQQ&oe=676951D2"}, {"file_name": "StoreShot_4.png", "id": "406101072548397", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982476_406101079215063_8421779914901899528_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tFBYQSTcPkQ7kNvgFgSe-Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnPHGR7hAgZd_Lb7MfbjZz31u9M0IYAFGFwzWFK9nh-Q&oe=67693D95"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Keyart_Guns_2560_Baked.png", "id": "1097110581857687", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974562_1097110585191020_7452520209657660678_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rnfz2sg6pBQQ7kNvgGX0FNS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5f5X6xDNf3hkc-anObZ7ZSeyAw3T__Qein3-iQLBhhw&oe=676931F9"}, "display_name": "ZAP", "keywords": ["puzzle", "shooter", "coop", "cooperative", "2player"], "long_description": "# Get ready to dive into ZAP\n\nWhether you're flying solo or teaming up in co-op with a friend, ZAP offers **23** thrilling stages designed to push your aim, reflexes and situational awareness to their limits.\n\nFrom competitive to laid-back levels, there\u2019s something for everyone. Whether you're chasing the global leaderboard or simply soaking in the stunning visuals, we got you covered.\n\n{839344524831082}\n\n# No motion sickness\nWe designed this experience  to run always smoothly and with limited artificial movement. It's the game you should play with the friend that's new to VR.\n\n# Zapper UI\nThe back of your gun tells you lots the vital information about your current situation. Your ammo, time left and the strikes. Tree strikes will fail a level. Strikes can be caused by failing to avoid projectiles, shooting protected targets etc.\n\n# Secret bonuses\nEvery level has some hidden bonuses that can be unlocked for more points. If you found any they will be visible in your victory stats.\n\n{493455766460001}\n\n# 2 Player mode\nWe have all the good stuff you'd expect like voice chat, animated avatars and detailed stats to see who's excelling in what.\n\n\n\n\n\n\n\n\n", "short_description": "Stimulating arcade shooter with online 2 player co-op"}]}, "developer_name": null, "developer_privacy_policy_url": "https://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Fonster", "support_website_url": null, "website_url": "http://f0nster.com/zap.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "9087566057931509"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_3525393317758273_4837435145992929720_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UOusz5zh5t4Q7kNvgFqQBUD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBiwi2XYAk0uRYg7ZF-xsiU2JFDI2ih8OnzWK3LClv2OA&oe=6769453C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ZAP", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}, {"topic_name": "Action"