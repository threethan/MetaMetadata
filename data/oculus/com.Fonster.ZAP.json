923_866272358183315_9035167842481638199_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hyHyjhRoCxEQ7kNvgFf4ct6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2NTDWfKqy-bnyV9iFJMK-g8PBHy2KsnPeMLN74wMzLw&oe=673F206F"}, {"file_name": "Flushed_Down.png", "id": "650408100303032", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223483_650408103636365_67369455735121626_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u04J78o7F0QQ7kNvgHEpxvO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQFZWSpZWLS_TAlyW_NtKpcV_6v3Qq6-nQtnZBH5rvSw&oe=673F0B8A"}, {"file_name": "Shearpleasure.png", "id": "233081856187432", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210889_233081859520765_6131975739920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X5zt-Ogv2hIQ7kNvgGog0Ow&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASbDHJ64KxmuMrMvEQYyWvjDu1WRYx0JHxEeIWHYxorA&oe=673F1F9E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oe64Nk30TOoQ7kNvgEDK-YY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANNSUmKghhD5hlFicAGA_R4O8CqVhjmdWoswgi2Kc8fw&oe=673F2A26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iPSY8MuLNKsQ7kNvgFwTnMz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7e_l71h5QbR-XOZwxGnM-qrYeZgoeEtjOA0J8kI_yaQ&oe=673F28FD"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Fonster", "support_website_url": null, "website_url": "http://f0nster.com/zap.html", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "2590358747770977"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6622906767730796", "version": "0.91"}, "id": "537122071969734", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_applicat