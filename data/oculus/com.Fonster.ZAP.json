5739920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HF8juXB4NjkQ7kNvgFC0XMF&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDlcZVdzkh3K8Vq0oe0gHAVFx8Of8puKyVRth6mBi-F-w&oe=6751949E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J_YGL6MUuNIQ7kNvgFI_RrK&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAHelD3PEuiBlcDJ1LOYD0juN_3uh-xcCjH5osOyqReYw&oe=67519F26"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8GWQ23H8mgYQ7kNvgEJ6tdp&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYC4vpJnzpCgv26r6dVPgcw-_FvSFzBnyhukCk5VZ8Ebhg&oe=67519DFD"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": 