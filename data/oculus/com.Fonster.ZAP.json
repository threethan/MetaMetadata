5739920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B6584XFWs2sQ7kNvgGbmf_W&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGuv7slq9I1FoDNmamE2zHzbDC2MzsJ0ZQ92MQ10pX2A&oe=6749AB9E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_KzW3j0hQ4AQ7kNvgEGPTNS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDE_w6MiZWZ1i-PEhCoNRD_3dnPmdEvqpgpw8eoqIL32w&oe=6749B626"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wfr6qgx6SMkQ7kNvgEtjqEY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1eCIexpv5QOnqiyF-ePKZYhlUaQEVZVJQO5EWVLZEdQ&oe=6749B4FD"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": 