9920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wMx-whwx_MQ7kNvgFK86ik&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoZCW1Tbt3e4zS5qAjF_JHp&oh=00_AYCIPRnkepU2oVBXkB9QWn1Nx7mAKzLcvgYvqO_w9MC6jw&oe=66F54B9E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_jXl1H-Bw_AQ7kNvgFgvpwq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoZCW1Tbt3e4zS5qAjF_JHp&oh=00_AYBw8KSlGM_Qe6LXTn3n2-0ovVfFfFXjXZV5brIrc53CnQ&oe=66F55626"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h2CLvGUFjGEQ7kNvgG1Taqw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoZCW1Tbt3e4zS5qAjF_JHp&oh=00_AYCJw2NH_LipjKoCWp_27rtYqDdAbvbUuJA5qIYiZkfzIQ&oe=66F554FD"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service