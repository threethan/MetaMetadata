rn8eaA&oe=6787A2EF"}, {"file_name": "Flushed_Down.png", "id": "650408100303032", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75223483_650408103636365_67369455735121626_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IvrdckWAxlYQ7kNvgGpWMLT&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAKCZLKcgRb62cGYFXvecKtinhW7qktKcrSqPiLXPv1ag&oe=67878E0A"}, {"file_name": "Shearpleasure.png", "id": "233081856187432", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75210889_233081859520765_6131975739920930185_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YEXmXNkocr8Q7kNvgGx4cnd&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYB0F3y2tjwHGolmniXsUMoG-PW95_yEPbkL7lgCkFi5JA&oe=6787A21E"}, {"file_name": "PicklePackingCompany.png", "id": "1242741823047564", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75520119_1242741826380897_8231855154482961425_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vG4dEc7G3FwQ7kNvgFAKC--&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAPw_9ZP3TjWPOj51F7I-QH5ssRPkqC6YLFmD-pJS_T7g&oe=6787ACA6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "zap_video_cover.png", "id": "682117720421726", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38984448_682117723755059_1132448842383316809_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=27nTLwuNvjMQ7kNvgFlvlC4&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCh-QXGeN18BelNGdEjbXRjuZMkRfv72Q21r6CHe6Z4Tg&oe=6787AB7D"}, "display_name": "ZAP", "keywords": [], "long_description": "Behold, a new action packed situation shooter has arrived! Play solo or co-op with a friend, ZAP offers you 32 levels set in 20 unique stages that will test your reflexes, aiming and situational awereness. The game is straight to the point and gives you a proper challenge in levels that are trimmed to give you the most exhilarating experience every time.\n\nWe are dedicated in making continuous updates to the game with new things to shoot in new stages, game modes and other fun events. This is just the start. We would love to hear your feedback and ideas on what kind of scenarios you would love to see in the game in the future. \n\nThis game is a letter of love to the VR gaming community by a small Finnish indie studio F\u00f6nster.", "short_description": "A co-op puzzle-shooter with classic arcade vibes <3"}]}, "developer_name": null, "developer_privacy_policy_url": "http://f0nster.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Fonster", "support_website_url": null, "website_url": "http://f0nster.com/zap.html", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "2590358747770977"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "591946436693776"}, {"status": "PUBLISHED", "id": "1275858846348795"}]}, "baseline_offer": {"id": "591946436693776"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1731956221, "status": "PUBLISHED", "id": "591946436693776"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9019199494768166", "version": "1.06"}, "id": "537122071969734", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__ty