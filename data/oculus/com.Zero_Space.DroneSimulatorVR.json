nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7D3oraDpsDIQ7kNvgHR10_r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUHVDotmXQAv1YfJ3ZnX944UIH62qzcguhXLqzBfKC0A&oe=67447728"}, {"file_name": "Stage.png", "id": "769351738500108", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974466_769351741833441_3471868736328826853_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l73aes15ioQQ7kNvgG4lnt7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBA-uzJl6P_gKeN_iv5ECM_xwArDF4zefgznfIoiTg8yQ&oe=6744539E"}, {"file_name": "Crash.png", "id": "406302435476314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035345_406302438809647_8568981630473616411_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UouUO43Ulf4Q7kNvgEwi0G5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsCoWC5ZNcqzsNjvOkErlX_3YliSf8mfev_oZ7Fq5tYg&oe=67446DC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Start.png", "id": "964762261316057", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003227_964762264649390_2253446905750202459_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vK-UqQVJzz0Q7kNvgFUC-K1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtiQjG9kNFLwEO-rKGMtEukVRXK9qGzfhTOupy6o7DZw&oe=674454EC"}, "display_name": "DroneSimulatorVR", "keywords": [], "long_description": "The DroneSimulatorVR is designed to facilitate and enhance the training of drone pilots.  To practice the handling of a UAS, many important basic functions of current drone technology are included. Particularly important are flight and gimbal controls, as well as the navigation and coordination of drones. Another distinctive feature of the simulator is a lifelike representation of distance and angle of view between the pilot and the aircraft. In addition to training, the simulator is also intended to arouse interest in the exciting subject area surrounding the drone. It is neither cheap to purchase a UAS, nor is it easy to meet the necessary conditions to put it into operation. The drone simulator is intended to provide a virtual reality for anyone who has the necessary hardware, in which they can enjoy flying a drone without worry and in a relaxed manner. ", "short_description": "The simulator is designed to learn the functions and control of a drone"}]}, "developer_name": "0Space", "developer_privacy_policy_url": "https://www.termsfeed.com/live/4dec8f1c-b379-41ee-abf7-800ab053de04", "developer_terms_of_service_url": null, "publisher_name": "0Space", "support_website_url": null, "website_url": "http://dronesimulatorvr.de/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25701794759436456"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1326652172078329"}, {"status": "PUBLISHED", "id": "1730898897756453"}, {"status": "PUBLISHED", "id": "6258079210880004"}]}, "baseline_offer": {"id": "1326652172078329"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728409921, "status": "PUBLISHED", "id": "1326652172078329"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27193014793647771", "version": "1.6.12"}, "id": "353607312647721", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary