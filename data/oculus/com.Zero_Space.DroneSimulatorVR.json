60_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kGR53ptgNDIQ7kNvgHXDm7o&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOiguTFZQ13R2GHc7ZQkKpmoIirjdjgdGH23Ivsyyldg&oe=670CF4BB"}, {"file_name": "UserArea.png", "id": "496165209641945", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566680_496165212975278_2480959363764695006_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nL1lDK-8GE8Q7kNvgEIWQDv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_uMHAb65E8oWvSqM9X3Nvd6hblrxqMOg5Nqnwn4MX_A&oe=670D03D2"}, {"file_name": "POV.png", "id": "1271284617221684", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001725_1271284620555017_1603823488254779480_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GN86ejkXH8QQ7kNvgF5k47C&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLTqrke3RicKTl9LENeCWc2i48EDzNlNOw3C9yw5xxWA&oe=670CED17"}, {"file_name": "Photospot.png", "id": "1045184803658579", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262745_1045184806991912_6255618480758222611_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wy5MIc9yB4oQ7kNvgFDqS_M&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBLaISTllpnfPEHgMC0-PhpwxsEBWsGJ_yh2qOYPO9PzA&oe=670D0978"}, {"file_name": "Crash.png", "id": "406302435476314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035345_406302438809647_8568981630473616411_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U9qqLAqUit4Q7kNvgGCRRn1&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWr6Q7wEwMcKhqb8DNaKPbK-JLtOgtLKhCgUVA6J0-eQ&oe=670D0EC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KeyArt_V2.png", "id": "429287386791246", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210889_429287390124579_3815976343446104451_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3vuWQJe39FYQ7kNvgHlROax&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbXvJIe8_I88eFuGdGocaGLcEAbfmi5hjW2SGNw1h8nA&oe=670D1A93"}, "display_name": "Drone Simulator VR", "keywords": ["drone", "simulator", "camera", "remote", "training"], "long_description": "Whether you\u2019re a beginner or an experienced pilot, DroneSimulatorVR offers the amazing opportunity to gain your first flying experience or refine your skills. \n\n# REALISTIC DRONE BEHAVIOR\nThe drone's behavior is physically accurate, simulating the real-world flight dynamics of an actual drone. With three control modes and the flight modes Tripod, Position, and Sport, you can practice different flying techniques and fully explore the drone\u2019s diverse handling characteristics.\n{8644232955607683}\n\n# EXPLORE MAPS AND COMPLETE CHALLENGES\nExplore unique maps filled with exciting challenges. Practice using the drone camera at numerous photospots and capture the perfect shot with zoom and gimbal settings or discover hidden collectibles to unlock new colors for your drone.\n{2533794363497465}\n\n#  THRILLING TIME TRIALS\nPut your skills to the test in thrilling time trials and prove you\u2019re fast enough to earn a gold medal on every track. Each race varies in difficulty and requires different maneuvering techniques to master.\n{1015933173644376}", "short_description": "Whether you\u2019re a beginner or an experienced pilot, DroneSimulatorVR offers the amazing opportunity to gain your first flying experience or refine your skills."}]}, "developer_name": "0Space", "developer_privacy_policy_url": "https://www.termsfeed.com/live/4dec8f1c-b379-41ee-abf7-800ab053de04", "developer_terms_of_service_url": null, "publisher_name": "0Space", "support_website_url": null, "website_url": "http://dronesimulatorvr.de/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQ