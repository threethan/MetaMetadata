tent-iad3-2.oculuscdn.com&oh=00_AYCjL4AJyArw8Fu2h1zUxIw4uvkmlV2EAkkqaKjGbO86Wg&oe=675AD746"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Start.png", "id": "964762261316057", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003227_964762264649390_2253446905750202459_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i_xSN8S7mhQQ7kNvgE9dpYb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8hNcvXCaJT5GXgGR4UCdpqvEGokgIkLlRwGUDtf8CDQ&oe=675ABE6C"}, "display_name": "DroneSimulatorVR", "keywords": [], "long_description": "The DroneSimulatorVR is designed to facilitate and enhance the training of drone pilots.  To practice the handling of a UAS, many important basic functions of current drone technology are included. Particularly important are flight and gimbal controls, as well as the navigation and coordination of drones. Another distinctive feature of the simulator is a lifelike representation of distance and angle of view between the pilot and the aircraft. In addition to training, the simulator is also intended to arouse interest in the exciting subject area surrounding the drone. It is neither cheap to purchase a UAS, nor is it easy to meet the necessary conditions to put it into operation. The drone simulator is intended to provide a virtual reality for anyone who has the necessary hardware, in which they can enjoy flying a drone without worry and in a relaxed manner. ", "short_description": "The simulator is designed to learn the functions and control of a drone"}]}, "developer_name": "0Space", "developer_privacy_policy_url": "https://www.termsfeed.com/live/4dec8f1c-b379-41ee-abf7-800ab053de04", "developer_terms_of_service_url": null, "publisher_name": "0Space", "support_website_url": null, "website_url": "http://dronesimulatorvr.de/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}