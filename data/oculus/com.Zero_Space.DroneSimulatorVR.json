Q7kNvgEYZ_0w&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXLEVNYO4VN05M7eDDTtXQ9WyZDMCnKmXD9S5j7CIQ9A&oe=66E18D46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Start.png", "id": "964762261316057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_964762264649390_2253446905750202459_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q-MHdJPm41IQ7kNvgFxzEFX&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWUJeVkVIyr3Ya3KnNzK5sKT2uC2-28wHk3IRtV_XAzg&oe=66E1746C"}, "display_name": "DroneSimulatorVR", "keywords": [], "long_description": "The DroneSimulatorVR is designed to facilitate and enhance the training of drone pilots.  To practice the handling of a UAS, many important basic functions of current drone technology are included. Particularly important are flight and gimbal controls, as well as the navigation and coordination of drones. Another distinctive feature of the simulator is a lifelike representation of distance and angle of view between the pilot and the aircraft. In addition to training, the simulator is also intended to arouse interest in the exciting subject area surrounding the drone. It is neither cheap to purchase a UAS, nor is it easy to meet the necessary conditions to put it into operation. The drone simulator is intended to provide a virtual reality for anyone who has the necessary hardware, in which they can enjoy flying a drone without worry and in a relaxed manner. ", "short_description": "The simulator is designed to learn the functions and control of a drone"}]}, "developer_name": "0Space", "developer_privacy_policy_url": "https://www.termsfeed.com/live/4dec8f1c-b379-41ee-abf7-800ab053de04", "developer_terms_of_service_url": null, "publisher_name": "0Space", "support_website_url": null, "website_url": "http://dronesimulatorvr.de/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25701794759436456"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1730898897756453"}, {"status": "PUBLISHED", "id": "6258079210880004"}]}, "baseline_offer": {"id": "1730898897756453"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725481561, "status": "PUBLISHED", "id": "1730898897756453"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "26656722283943694", "version": "1.5.1"}, "id": "353607312647721", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5294103097298922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26656722283943694"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "353607312647721"}]}, "change_log": "Important Hotfix Update:\n\nFixed a game-breaking bug in Industrial Area Map .\nZoom level now allows the completion of photospot (graffiti) again.", "created_date": 1725490115, "id": "26656722283943694", "version": "1.5.1", "version_code": 10510, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5294103097298922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26656722283943694"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "353607312647721"}]}, "change_log": "DRONE:\n\n\u2022 Drone physics reworked: Experience more realistic and responsive flight behavior.\n\u2022 Control modes: Choose between three different modes to suit your flying style.\n\u2022 Speed modes: Available speed modes are \"T\" (Tripod), \"P\" (Positioning), and \"S\" (Sport).\n\u2022 Idle hover animation: New hover animation when the drone is idling.\n\u2022 Indicator lights: Added indicator lights to show the drone's orientation and improve visibility.\n\nMAPS:\n\n\u2022 New map \u2013 Industrial Area: Explore a brand new map set in an industrial environment.\n\u2022 New map \u2013 Castle Ruin: Navigate through medieval castle ruins located in a natural, scenic environment.\n\u2022 Reworked standard map: Enhancements and updates made to the existing map.\n\nCHALLENGES:\n\n\u2022 Photospots: Complete photo challenges to unlock new maps.\n\u2022 Collectables: Gather hidden items to unlock new drone colors.\n\u2022 New races: Additional time trials with medals to unlock.\n\nUSER AREA:\n\n\u2022 Progress Overview Board: Track your progress on a new overview board.\n\u2022 Meta-avatar: Use your Meta-avatar as your in-game character.\n\u2022 Large map display: A big map for better navigation and planning.\n\u2022 Updated Control Panel: Improved user interface for easier control.\n\nPERFORMANCE AND QUALITY:\n\n\u2022 Higher render resolution: Improved graphics resolution across all devices.\n\u2022 Optimized for Quest 2: Device-specific optimizations for better performance.\n\u2022 Reduced loading times: Experience faster loading times for smoother gameplay.\n\u2022 Sharper textures: Improved texture quality for greater clarity.\n\nAUDIO:\n\n\u2022 Ambience audio for each map: Each map now features unique atmospheric sound effects.\n\u2022 Improved sound design: Updated audio feedback for a more immersive experience.\n\u2022 Reworked drone SFX: Drone sound effects dynamically respond better to different flight movements.", "created_date": 1725222724, "id": "26623507793931810", "version": "1.5.0", "version_code": 10500, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5294103097298922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26656722283943694"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "353607312647721"}]}, "change_log": "Drone:\n\n-Drone physics extensively reworked: Experience significantly more realistic and responsive flight behavior.\n-Three control modes: Choose between three different control modes (1, 2, 3) to suit your flying style.\n-Three speed modes: Available speed modes are \"T\" (Tripod), \"P\" (Positioning), and \"S\" (Sport).\n-Idle hover animation: New hover animation when the drone is idling.\n-Indicator lights: Added indicator lights to show the drone's orientation and improve visibility.\n\nMaps:\n\n-New map: Industrial Area: Explore a brand new map set in an industrial environment.\n-New map: Castle Ruin: Navigate through medieval castle ruins located in a natural, scenic environment.\n-Standard map reworked: Enhancements and updates made to the existing map.\n\nChallenges:\n\n-Photospots: Complete specific photo challenges to unlock new maps.\n-Collectables: Gather hidden items to unlock new drone skins.\n-New time trials: Additional time trials with medals to unlock.\n\nUser Area:\n\n-Progress Overview Board: Track your achievements on a new overview board.\n-Bigscreen Map: A large map display for better navigation and planning.\n-Updated Control Panel: Improved user interface for the control panel.\n-Meta-avatar: Use your Meta-avatar as your in-game character.\n\nPerformance and Quality:\n\n-Higher render resolution: Improved graphics resolution across all devices.\n-Performance optimizations: Enhanced performance and smoother gameplay across all supported devices.\n-Optimizations for Quest 2: Specific enhancements tailored for better performance on Quest 2.\n-Reduced loading times: Experience faster loading times for a smoother gaming experience.\n-Sharper textures: Improved texture quality for greater visual clarity.\n\nAudio:\n\n-Ambience audio for each map: Each map now features unique atmospheric sound effects.\n-New sound design for buttons and interactions: Updated audio feedback for a more immersive interaction experience.\n-Reworked drone SFX: Drone sound effects now dynamically respond to different flight movements.", "created_date": 1725213149, "id": "26622313060717950", "version": "1.5", "version_code": 10407, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5294103097298922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "26656722283943694"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "353607312647721"}]}, "change_log": null, "created_date": 1718059635, "id": "25778135778469020", "version": "1.4.0", "version_code": 10400, "release_status": "RELEASE