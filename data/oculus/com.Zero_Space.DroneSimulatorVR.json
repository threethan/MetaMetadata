t=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G320dA_PCokQ7kNvgEP_vXq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBXqCR5nVr9XIV_C9QGhGcc0ZTLcjYpcJ5Z6B_Iy6wwIA&oe=66DD7324"}, "display_name": "DroneSimulatorVR", "keywords": [], "long_description": "Lets dive into the world of drone piloting! Experience educational and exciting remote flights, time trials, and local high scores. Enjoy the art of drone flying with realisitc sound and visual effects, and of course, destroy your Drones on collisions without any real-world risks. The Drone Simulator VR is a custom-made simulator perfect for students and drone enthusiasts.\n\nFly drones remotely via a display, just like controlling real ones. The game keeps things simple and focused, giving you a pure and solid simulation.\n\nThis Simulator offers full motion control, a proper gimbal camera with zoom and tilt, and awesome sound and visual effects. Practice your piloting skills, try new maneuvers, use the minimap to navigate, or just watch your drone getting destroyed by collisions... Adversity is the school of wisdom\n", "short_description": "Lets dive into the world of drone piloting! Experience educational and exciting remote flights, time trials, and local high scores. Enjoy the art of drone flying with realisitc sound and visual effects, and of course, destroy Drones on collisions without any real-world risks. The Drone Simulator VR is a custom-made simulator perfect for students and drone enthusiasts."}]}, "developer_name": "0Space", "developer_privacy_policy_url": "https://www.termsfeed.com/live/4dec8f1c-b379-41ee-abf7-800ab053de04", "developer_terms_of_service_url": null, "publisher_name": "0Space", "support_website_url": null, "website_url": "http://dronesimulatorvr.de/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscripti