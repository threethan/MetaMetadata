B0"}, {"file_name": "MovieDeck_SS2_1440.png", "id": "860978618839023", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/86619816_860978622172356_5894905729873993793_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M62z9XQ1uqwQ7kNvgGDtvuh&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDBprdotOsFe9AJIKdgg2aVD57ixPTzn0J6GU2B2plWDA&oe=67583815"}, {"file_name": "MovieDeck_SS3_1440.png", "id": "873128401019086", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031587_873128404352419_2315145967782909780_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6V2AGlAbKrgQ7kNvgExpDoT&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAd_rdLVeNL4IqV1COiI11PlWmRpbP2D3t2YVq4PSL6kw&oe=67583CB2"}, {"file_name": "MovieDeck_SS4_1440.png", "id": "1360611784627850", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57575360_1360611787961183_1495942460005126294_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3mlAuE-nVZwQ7kNvgE4Nhs7&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCEGcITc9IzRVWzx-8in0bv6C8O_qO2AZKJ6rjrwr49UA&oe=67581269"}, {"file_name": "MovieDeck_SS5_1440.png", "id": "324581870354098", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031429_324581873687431_6516287977684510180_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cu4PGMjDW8EQ7kNvgGdO1qP&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBHtly3ICr-32GFkkt84UmxRtTAqIOW2zgl92Yi06TwOA&oe=6758302E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "3628112477400638", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031587_3628112480733971_7669182366300195534_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kxssL5LlGOkQ7kNvgEePqf3&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYC6djbkKhDERszmAMXPhKWAh3LSTl-FnZiYBfp4vZ3i7Q&oe=675813C4"}, "display_name": "Movie Deck for Plex", "keywords": [], "long_description": "Movie Deck for Plex is a full featured State-of-the-art 3D Plex client for Oculus headsets.\n\nFeatures:\n- Stream your Plex library from anywhere\n- Browse your library with poster artwork or folders\n- 3D controls with sliders and buttons that can be interacted with using your hands or controllers\n- Full control over the position, size, scale, tilt, aspect ratio, and X/Y curvature of the screen.\n- Full control over hue, brightness, contrast, saturation and gamma.\n- Choose from multiple backgrounds including passthrough\n- Dim your surroundings to focus on the movie\n- Anchor the screen to a position with roomscale tracking lets you walk around, on, or through the screen\n- Supports different subtitles and audio tracks\n- Automatically recognizes projection mode (180, 360, side by side, top/bottom) from filenames\n- Adjust the curve of 180 degree videos\n- Once the movie is playing you can turn off the menus, put the controllers down and just see your hands tracked without interfering with the controls.  Enjoy your food and drinks while watching the movie!\n- 4K and higher resolution support\n- Easy control using joysticks for fast forward, reverse, pause, and step frame\n", "short_description": "Movie Deck for Plex is a full featured State-of-the-art 3D Plex client for Oculus headsets.\n\nMain Features:\n- Stream your Plex library from anywhere\n- Browse your library with poster artwork or folders\n- 3D controls with sliders and buttons that can be interacted with using your hands or controllers\n- Full control over the position, size, scale, tilt, aspect ratio, and X/Y curvature of the screen.\n- Full control over hue, brightness, contrast, saturation and gamma."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rockingpocketgames.com/MovieDeck/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Egerter Software", "support_website_url": null, "website_url": "http://www.RockingPocketGames.com/MovieDeck", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {