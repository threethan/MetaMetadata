_sid=6e7a0a&_nc_ohc=Cu4PGMjDW8EQ7kNvgGdO1qP&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBHtly3ICr-32GFkkt84UmxRtTAqIOW2zgl92Yi06TwOA&oe=6758302E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "3628112477400638", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031587_3628112480733971_7669182366300195534_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kxssL5LlGOkQ7kNvgEePqf3&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYC6djbkKhDERszmAMXPhKWAh3LSTl-FnZiYBfp4vZ3i7Q&oe=675813C4"}, "display_name": "Movie Deck for Plex", "keywords": ["plex", "movie", "media", "video", "player"], "long_description": "Movie Deck for Plex is a full featured State-of-the-art 3D media player for Oculus headsets.\n\nFeatures:\n- Stream your Plex library from anywhere\n- Also supports DLNA, SMB, and local device playback \n- Browse your library with poster artwork or folders\n- Choose between 2D and 3D user interfaces \n- Full control over the position, size, scale, tilt, aspect ratio, and X/Y curvature of the screen.\n- Full control over hue, brightness, contrast, saturation and gamma.\n- Choose from multiple backgrounds including passthrough\n- Dim your surroundings to focus on the movie\n- Anchor the screen to a position with roomscale tracking lets you walk around, on, or through the screen\n- Supports different subtitles and audio tracks\n- Automatically recognizes projection mode (180, 360, side by side, top/bottom) from filenames\n- Adjust the curve of 180 degree videos\n- Once the movie is playing you can turn off the menus, put the controllers down and just see your hands tracked without interfering with the controls.  Enjoy your food and drinks while watching the movie!\n- 4K and higher resolution support\n- Easy control using joysticks for fast forward, reverse, pause, and step frame\n- User ratings, watchlist, and marking movies as watched/unwatched\n- Easily find movies using filters by text search, user rating, watchlist and watch status\n- AR support. Use with green screen videos to remove the background\n- Virtual seating and cinema scenery\n- Embedded and external SRT subtitle support\n- Transcoding support", "short_description": "Movie Deck for Plex is a full featured State-of-the-art 3D media player for Oculus headsets.\n\nMain Features:\n- Stream your Plex library from anywhere\n- Also supports DLNA, SMB, and local device playback \n- Browse your library with poster artwork or folders\n- Choose between 2D and 3D user interfaces \n- Full control over the position, size, scale, tilt, aspect ratio, and X/Y curvature of the screen.\n- Full control over hue, brightness, contrast, saturation and gamma.\n- Virtual Cinema\n- And More!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.MovieDeck.ca/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Egerter Software", "support_website_url": null, "website_url": "http://www.MovieDeck.ca/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8001972386592396"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031566_1031096031832236_9045260497996013372_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xUpcT56N-WgQ7kNvgEsW0HU&_nc_zt=3&_nc_ht=scontent-lga3-