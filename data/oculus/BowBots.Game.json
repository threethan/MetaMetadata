01.png", "id": "1109953173343735", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340706_1109953176677068_8460734397512451474_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HbZAAOkPd-IQ7kNvgGdfBgp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATPWwIVwmVU8qpMji7-Z9Ve_W5wCTWSL5gRNNSeg4Zrg&oe=671E124F"}, {"file_name": "ScreenShot02.png", "id": "2039715176413982", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035349_2039715179747315_3666820418221366030_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jsTbSrZgJh0Q7kNvgGXfQCf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNqaV_O3zp4vj3YjWHcDHuSex4lostNKNmSafDyK6AIQ&oe=671E330E"}, {"file_name": "ScreenShot04.png", "id": "7419233568110284", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974824_7419233571443617_228829691485305948_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IbCVZfrJ3b4Q7kNvgECuqgg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5xD0OheEizk_2KfpCyp5VZcg4sOqktsy_xPplIpCECA&oe=671E2795"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ScreenShot03.png", "id": "1138883017098340", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003259_1138883020431673_6838173099459925758_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mKulGw4xPAAQ7kNvgFRJL-c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCXcl_Vh_XUbELI0sdK9cIK00YAgMhGyu_6AB8_JnyKrA&oe=671E1221"}, "display_name": "Bow-Bots", "keywords": [], "long_description": "Bow-Bots is a VR Multiplayer shooter where you take on the role of a powerful bow-wielding robot. \n\nBow bots have a unique item system. By hitting targets scattered across the map, you can acquire powerful arrows. Such as Explosive, Emp, or Sniper Arrow. Aim for the golden bullseye to unlock even stronger Tier 2 arrows, giving you a competitive advantage.\n\nBut beware, your shields are constantly depleting. To stay protected, shoot shield bots scattered throughout the map to recharge your shields. Don't worry shield bots are harmless. ( most of the time). Keep an eye out for golden shield bots, which grant double the shield replenishment.\n\nAmidst the chaos, don't overlook the power-ups that can turn the tide of battle. Unleash the freedom of flight with the jet pack, gain a burst of speed with the speed boost, or reinforce your defenses with the formidable Bow Shield.\n\nTeam up with your friends in epic 3v3 battles or 6-player free for all. \n\nBow-Bots offers fast-paced, action-packed gameplay where skill and strategy are key to victory. ", "short_description": "Bow-Bots is a VR Multiplayer Bow and Arrow Shooter with a unique item system. Shoot targets to gain powerful arrows or recharge your shields. The better your aim the better the reward."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bow-bots.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Siege Industries", "support_website_url": null, "website_url": "https://www.bow-bots.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "24646416871668532"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1511550579498264"}, {"status": "PUBLISHED", "id": "860602035978749"}, {"status": "PUBLISHED", "id": "896748308839785"}, {"status": "PUBLISHED", "id": "6986413