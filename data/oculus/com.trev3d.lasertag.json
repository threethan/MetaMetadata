9RG1cAnj_YR5tTLxA_yw&oe=6707ADF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-07-05-01h50m12s022.png", "id": "1516054399284451", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75308614_1516054402617784_5735280563245233829_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bABpFIzJwgsQ7kNvgHiCl2f&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjHsssH7bz0uVryXm3ec_09K-xyPmQCiylotscc76L7g&oe=6707C1D5"}, "display_name": "Lasertag", "keywords": [], "long_description": "# Convenient setup - no room scanning needed!\nOn Quest 3 the game uses live depth estimation for laser bullet collision and special effects. Nobody has to scan or map their space so setup is quick & convenient! (Quest 3 only)\n\n# Play with friends IRL\nYou play Lasertag with friends in the same physical space. We recommend playing in a large open indoor area such as a gymnasium.\n\n# Automatic LAN connection\nHeadsets can find and connect to each other automatically (on non-enterprise WiFi networks). \n\n# Team Deathmatch & King of the Hill\nThe game currently features two game modes to beat your friends at!\n\n# Early access\nThis is more of a tech-demo than a full game at the moment, but we're actively working on making the game more engaging with fleshed-out gamemodes and graphics.\n\n# Discord\nWe have a Discord server if you have questions, issues, ideas, etc. http://discord.gg/DgTqG5A6BD", "short_description": "Turn any space into a laser tag arena for you and your friends."}]}, "developer_name": "Anaglyph", "developer_privacy_policy_url": "https://anagly.ph/privacy", "developer_terms_of_service_url": null, "publisher_name": "Anaglyph", "support_website_url": null, "website_url": "https://anagly.ph/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subs