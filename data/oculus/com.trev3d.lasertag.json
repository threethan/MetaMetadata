4.5771-25/57566678_406951332179851_2576479591581266691_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jq7h3sSkOZ0Q7kNvgHK1nwg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiCdt4b0Y130fqnpozzAnjm&oh=00_AYD7LDfGWDOXWdkpDYEmXWWHz47zffpgIghsYFX3AWSk-Q&oe=66E6B873"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-07-05-01h50m12s022.png", "id": "1516054399284451", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75308614_1516054402617784_5735280563245233829_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03LSHlxW7CcQ7kNvgETwI6l&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiCdt4b0Y130fqnpozzAnjm&oh=00_AYCe8PuVcK-c55FEjI0QUBkkIddHX1PDJ40gEopUP_zMDQ&oe=66E6CC55"}, "display_name": "Lasertag", "keywords": [], "long_description": "# Convenient setup - no room scanning needed!\nOn Quest 3 the game uses live depth estimation for laser bullet collision and special effects. Nobody has to scan or map their space so setup is quick & convenient! (Quest 3 only)\n\n# Play with friends IRL\nYou play Lasertag with friends in the same physical space. We recommend playing in a large open indoor area such as a gymnasium.\n\n# Automatic LAN connection\nHeadsets can find and connect to each other automatically (on non-enterprise WiFi networks). \n\n# Team Deathmatch & King of the Hill\nThe game currently features two game modes to beat your friends at!\n\n# Early access\nThis is more of a tech-demo than a full game at the moment, but we're actively working on making the game more engaging with fleshed-out gamemodes and graphics.\n\n# Discord\nWe have a Discord server if you have questions, issues, ideas, etc. http://discord.gg/DgTqG5A6BD", "short_description": "Turn any space into a laser tag arena for you and your friends."}]}, "developer_name": "Anaglyph", "developer_privacy_policy_url": "https://anagly.ph/privacy", "developer_terms_of_service_url": null, "publisher_name": "Anaglyph", "support_website_url": null, "website_url": "https://anagly.ph/", "category": null