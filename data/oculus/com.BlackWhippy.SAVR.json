644224377_2522373337874894263_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jlY5gF5Caz4Q7kNvgH3pEy1&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFVd188lKBr6S9I20eKdjC2nD3neSySlqYw9SXvoV7pQ&oe=66D9A206"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SAVRCoverLandscape.png", "id": "313076350713137", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_313076354046470_4219684967553276951_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=89bWFDxA4boQ7kNvgGinC3F&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZn7XSwj2CwFFsOwdohe8KHXIf7GyQ74e2ScnBYbV2Cg&oe=66D9868F"}, "display_name": "SaVR", "keywords": [], "long_description": "The year is 2121. Humans have colonised various planets in the solar system. This has caught the eye of a mysterious alien species who wish to enslave the humans and turn them into killing machines by kidnapping them up and reprogramming them. The humans on the each planet are under threat! You are the SAVR (pronounced 'Savior') - Sentient Autonomous Virtual Robot, a hi-tech drone controlled virtually from earth using quantum entanglement communication whose mission is to save all the humanoids on the planet before they are enslaved by the aliens. You must pick up all the humans and destroy all the aliens in each zone before moving to the next set of humans in peril. Good luck!", "short_description": "SaVR (or 'Savior') is a fast paced FPS Inspired by 80's arcade games like Defender and JetPac. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/e/2PACX-1vRo0Q1LvVk7WvFg3bIcQxYvHAJSn3pnkyc0CDk3gD2sQLNd680NU1dHNIqkbTTL9-QRDnqMAWU7lPZ-/pub", "developer_terms_of_service_url": null, "publisher_name": "BlackWhippy", "support_website_url": null, "website_url": "https://blackwhippy.itch.io/savr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "SHOOTER", "AC