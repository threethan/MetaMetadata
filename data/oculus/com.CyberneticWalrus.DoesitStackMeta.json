90106229500_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MKrP8RBYJsIQ7kNvgFGj7Y6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUYPunr6TnKFA7HXCpXTuhBjoGDnTjUmUg_UN6Te2cuw&oe=673F1E9F"}, {"file_name": "KeyArt_V3.1_CoverSquare_Safe.png", "id": "485209857422297", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75269597_485209864088963_4023150124637405160_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oGkfD44Nct0Q7kNvgFcvk3M&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWK3lG00PItVU7BSnmCeYEvW-FEWqISpllDNFTdJTKyw&oe=673F3794"}]}, "id": "912904597452748", "locale": "en_US", "screenshots": [{"file_name": "DIS_AR_2024_01.png", "id": "537584845277840", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223483_537584848611173_8806968797985361077_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=opxYbeiW8qEQ7kNvgGA0bXH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGj3w3DjpT-JyEFSlXJ9cizNAWxNfsEM9SKyD1akorLw&oe=673F17FC"}, {"file_name": "DIS_VR_01.png", "id": "1021235832988115", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367587_1021235836321448_7744617516895630285_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sIO8m_IhDv4Q7kNvgHk_7Eo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkFoKRX96hWasnudAEkP7lCiD_kp4uJIjg6B3MKg5G6A&oe=673F2862"}, {"file_name": "DIS_AR_2024_05.png", "id": "975542937591242", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982593_975542940924575_723574546824994168_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fp90oRaFGZEQ7kNvgGZNEPj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA70zeq0LhK3fSUNbXa5gclLAIGmzqewCAbuyEXP6oTGg&oe=673F2C9B"}, {"file_name": "DIS_VR_02.png", "id": "927476529183500", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974579_927476532516833_7278511836135823018_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hhvgzgyS0r8Q7kNvgG_6vHK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeMKgnrG29qtgluOuOIPsjuj76cw2UtzOmAjYmwQ9S3A&oe=673F327A"}, {"file_name": "AR_Screenshot_05.png", "id": "995095888788717", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302220_995095892122050_3225244634523290964_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v91-7OqCCCAQ7kNvgEDoCii&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDc81cu_71GXoK2HGXMd_6xyXgCwE-Ft_uJApnFnWY5g&oe=673F1362"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DIS_Keyart_V3_3840_2160 (2).png", "id": "349954004577170", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299158_349954007910503_1833769832880075911_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rSEZikJVhVsQ7kNvgHSMQDa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAuqzKbp2iVdZFI8ESBdVjNazMHLIGX3pVzSux-ocQzzA&oe=673F0BF8"}, "display_name": "Does It Stack?", "keywords": ["puzzle", "stacking", "coop", "partygame", "physics"], "long_description": "Does It Stack? lets players create ridiculous towers by stacking an assortment of items atop one another. Play solo, or together in virtual- or augmented reality. Are you a stacking master or a stacking disaster?\n\n{383171848203466}\n\n# Create wacky towers\nCan you build a tower of toy cars with a bicycle on top? Can you balance a fish on a bowling ball? Maybe this is the rare occasion where you should put the fork in the toaster? But watch out! If two objects of the same color touch each other, they go BOOM! Be careful, or you might get a heart-a-stack!\n\n{1257651048587175}\n\n# Play in augmented- or virtual reality\nChoose between augmented reality (AR) and virtual reality (VR). Immerse yourself in VR worlds or mix digital elements into your real surroundings with AR. The choice is yours!\n\n{1474879109856394}\n\n# Stack together in local co-op mode \nStack solo or team up with friends in local co-op mode. Whether you prefer tackling challenges on your own or working together to solve puzzles, you can enjoy the fun your way\u2014solo or with others, all in the same room.\n\n{1517634328955115}\n\n# Features \n- 60 levels with 3 challenges each\n- 150 unlockable objects \n- Get creative with your unlocked items and gizmos in the sandbox mode\n- Try to beat your friends' height scores\n- Compete in the daily challenge mode\n- You can use voice chat through Meta's People app", "short_description": "Get creative in Does It Stack? \u2014 a physics-based puzzle game with an explosive twist where you\u2019ll craft increasingly absurd towers that joyfully defy the laws of physics using a treasure trove of unusual building objects. Play solo, or together in virtual- or augmented reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doesit.games/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Cybernetic Walrus", "support_website_url": null, "website_url": "https://doesit.games/does-it-stack/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "8693285717396579"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974581_1496382257740278_4357188624007100883_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rxS5qhPs1QoQ7kNvgFgCIkb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4HAwtCQIO2mRlQGwn8R7eMLdOM80d_HwYKzyQb_jKiA&oe=673F0A5C"}, "is_con