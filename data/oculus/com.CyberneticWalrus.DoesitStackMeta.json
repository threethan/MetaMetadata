.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bov4_hvHYuoQ7kNvgGF4UgQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlugo0ACmK5ZGHjTmuQH0t-UYt__M-e3E3u99q1HACGQ&oe=6765717A"}, {"file_name": "AR_Screenshot_03.png", "id": "1595669787943700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982574_1595669791277033_5016373124860295737_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LJiwHlTbs_kQ7kNvgG-Mxr-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEl2I9If4ssXJPpWdBbE7GXnJxK45K8k3u8msNW3N8tQ&oe=6765543E"}, {"file_name": "AR_Screenshot_06.png", "id": "477468198098610", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75612002_477468201431943_2336277708116321394_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJRhiVxzJCcQ7kNvgEs7Tut&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAiRfxlPBUMNbFxpndskve2qCDvyVdWKQN94LyAMQNhw&oe=6765457C"}, {"file_name": "AR_Screenshot_05.png", "id": "995095888788717", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302220_995095892122050_3225244634523290964_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TsEEuCssCv0Q7kNvgGGADXC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBtKs06lmOZzfTrpmVVNX3mmWEgK_qqbknBlL8C_cmW5A&oe=67654EE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DIS_Keyart_V3_3840_2160 (2).png", "id": "349954004577170", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75299158_349954007910503_1833769832880075911_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=575enmmMEZUQ7kNvgHrCext&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8YEynIMKUlhrb2S8bbcb57AwbWg-rMj1DoNjzjyjVLw&oe=67654778"}, "display_name": "Does It Stack?", "keywords": ["puzzle", "stacking", "coop", "partygame", "physics"], "long_description": "Does It Stack? lets players create ridiculous towers by stacking an assortment of items atop one another. \n\n{1457525708209224}\n\n# Create wacky towers\nCan you build a tower of toy cars with a bicycle on top? Can you balance a fish on a bowling ball? Maybe this is the rare occasion where you should put the fork in the toaster? But watch out! If two objects of the same color touch each other, they go BOOM! Be careful, or you might get a heart-a-stack!\n\n{1597905861066084}\n\n# Features \n- 60 levels with 3 challenges each\n- 150 unlockable objects \n- Play in augmented- or virtual reality\n- Stack together in local co-op mode \n- Get creative with your unlocked items and gizmos in the sandbox mode\n- Try to beat your friends' height scores\n- Compete in the daily challenge mode\n- You can use voice chat through Meta's People app\n\n{319138587924564}\n", "short_description": "Get creative in Does It Stack? \u2014 a physics-based puzzle game with an explosive twist where you\u2019ll craft increasingly absurd towers that joyfully defy the laws of physics using a treasure trove of unusual building objects. Play solo, or together in virtual- or augmented reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doesitstack.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Cybernetic Walrus", "support_website_url": null, "website_url": "https://www.cyberneticwalrus.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP", "MULTI_USER"], "id": "7753404538051373"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id":