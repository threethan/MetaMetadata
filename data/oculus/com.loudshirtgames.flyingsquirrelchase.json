ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWyBvuQXbRqxrLc13lKgBd9Rfhql5BGAHweC0-yGnB3g&oe=6709262F"}, "display_name": "Flying Squirrel Chase", "keywords": [], "long_description": "Spread your wings and glide effortlessly through the air by flapping your hands! Compete or explore with friends in multiplayer mode, complete with voice chat to stay connected mid-flight. Dive into the excitement and see what makes this game so much fun. \n\nJoin us in Early Access and experience the skies like never before!", "short_description": "Take to the skies like never before in this thrilling multiplayer VR adventure! With voice-chat enabled, team up with friends or challenge rivals as you soar through immersive landscapes. Whether you're racing or free-flying, the excitement never stops. Get ready for high-flying action in Early Access\u2014come fly with us!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://loudshirtgames.com/privacypp.html", "developer_terms_of_service_url": null, "publisher_name": "Loud Shirt Games", "support_website_url": null, "website_url": "http://loudshirtgames.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "388572352490011"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "ADVENTURE", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8409967549065644"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974643_493840576756667