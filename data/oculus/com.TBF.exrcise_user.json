scrren3.png", "id": "6994497137232231", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Ni5fwgw_rwQ7kNvgHL1ujC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNY0Oa4tAxP3KCXQ7gecq5YTM5iR4khBNDhTkeLPHf-g&oe=67178499"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QWpvps-XKEoQ7kNvgH2MRlT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBb0jAWwCRwLkmqu3rPxtFWTAMY4xUssiSTzKuZvfz5Bw&oe=6717A0DF"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UUaML47Vw7YQ7kNvgGR2VnZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD04ivSGsmOB_tEXYV4uh1L7DzRTbTlj0233qDnqlmJBA&oe=6717848C"}, {"file_name": "Cover Portrait (1).png", "id": "1029738121275803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001702_1029