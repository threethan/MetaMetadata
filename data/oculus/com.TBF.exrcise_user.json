null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_bcCWG6MF-EQ7kNvgEDLeIz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCbsXdOgSBbBxOyuQIrb4cGMcY6ZujGhrY_Xysv-5F6MA&oe=670E665F"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VduTtZmttiMQ7kNvgGmjBbW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDl0Eu_dNbHKhbTm0eERoh3U0xZnfSF8TP1qhtEmodMpA&oe=670E4A0C"}, {"file_name": "Cover Portrait (1).png", "id": "1029738121275803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001702_1029738124609136_1954560374588661011_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3mgvjA_zTkUQ7kNvgFftU5p&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxdqyjDZRlx72VsIQrZO0QeIdpYPh9feZFQjgmvho9Jg&oe=670E4E3B"}, {"file_name": "Mini Landscape (1).png", "id": "663383675677594", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.