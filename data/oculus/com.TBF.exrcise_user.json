.png", "id": "821871586178046", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_821871592844712_1448396291330821220_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZC7iPMBaMWYQ7kNvgF1VhnO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3Z6GVisFQ4FSUYRkXfRCWe&oh=00_AYA_mx_KJnQbltbsg9bnsW2vqxVZqJXVLAKQkKZK5gztZg&oe=66E17758"}, {"file_name": "scrren3.png", "id": "6994497137232231", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QdskCZa4ZCoQ7kNvgHdTL34&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3Z6GVisFQ4FSUYRkXfRCWe&oh=00_AYA8mvksDOwXg21m7-TLW3cZB48SNlTS1EdHmAyn4FwfLQ&oe=66E17719"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zEqzKNMUHo0Q7kNvgH4iBbG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3Z6GVisFQ4FSUYRkXfRCWe&oh=00_AYBvGXjg5yR7bVRVp4130ueZiYZ2IB3a-KbHfS2d09me-A&oe=66E1935F"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_