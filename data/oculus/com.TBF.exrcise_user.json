vgFi6UVv&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5F0QTJAboagGpI4BwuQNTX&oh=00_AYBKqKSLpTRkZIqOJlzqY34iO4RSZWhAD0pHxcHx3Uu2MQ&oe=66EEA9B2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "743636291213721", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031402_743636294547054_976382135093600499_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rdw1lxqIEIoQ7kNvgG1OqIz&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5F0QTJAboagGpI4BwuQNTX&oh=00_AYB8uzJQWTIQhhFhXtPcrl2czCuyyH_8Nu04X007BW2QHg&oe=66EEA8AD"}, "display_name": "eXRcise", "keywords": [], "long_description": "Take care of your health by training with virtual reality! An app designed to make your exercise routine fun, with workouts designed by professionals that take full advantage of VR technologies. In eXRcise you will find a wide variety of cardio, strength and mobility workouts, plus a challenged mode focused on boxing!\n\n\ud83c\udfafTrain according to your GOALS\n\n\ud83d\udccaGet STATISTICS on your performance\n\n\ud83c\udfdd\ufe0fChoose your favorite SCENARIO for an immersive experience: a virtual gym, the beach, or even the moon!\n\n\ud83e\udd4aTrain against yourself with our CHALLENGE mode\n\n\ud83d\udcaa\ud83c\udffdWorkouts created by PROFESSIONAL TRAINERS with guidance throughout the exercise\n\nAnd.. GYM CLASSES! Train as if you were in a fitness class from any location.\n\n If you have any questions, please contact us at exrciseads-support@exrciser.com\n", "short_description": "Let your eXRcise flow\u2728"}, {"images": {"nodes": [{"file_name": "Cover Portrait.png", "id": "2355158141346439", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_2355158148013105_696099369441686769_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B1mgOzrWymMQ7kNvgHfTT2I&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5F0QTJAboagGpI4BwuQNTX&oh=00_AYCePVuDKRIwvbcNDZ1kFW3-2fDjsLXvli4U0sOD36tqYw&oe=66EEAFE5"}, {"file_name": "Logo.png", "id