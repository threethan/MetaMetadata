&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xlrGY1OixMMQ7kNvgH5ZrY0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBAe0Lff-D_zZ5S_dJbwlx5Uprkm8RCFLigBE-eyA7AXQ&oe=6780F587"}]}, "id": "1140970600442174", "locale": "es_LA", "screenshots": [{"file_name": "01.png", "id": "707632024662955", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001654_707632027996288_958646455304166617_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Mqm-_HTZs4Q7kNvgFIIrax&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBq_ponLavgikzfK9SDVTClPQBEj7XsjHbvaOdiCEBfwQ&oe=67812008"}, {"file_name": "02.png", "id": "7391223817639212", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974468_7391223824305878_4779749747531224103_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F-JP6WrPsMYQ7kNvgF3X23w&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCpShSfYBlEzyMWsP3j2HQlXCXEFAyj5FHy38DPzNR_5g&oe=67810D44"}, {"file_name": "03.png", "id": "992580305909069", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031379_992580312575735_1082182157877683339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ErfBbaQdkgsQ7kNvgHZHR3i&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAN4okZoqx5RF8GGG6KWDcg0oH8RVOvUtTnW3u2pvN7pA&oe=67811512"}, {"file_name": "04.png", "id": "983692356479671", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75223476_983692359813004_7557367347621088005_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I2PwtNdIkbwQ7kNvgGmHo4h&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDeA-JTmNJD5g_TUfizrWBHzVH8sdfm5wq1T_UitKVPKw&oe=6780FECF"}, {"file_name": "05.png", "id": "451372747457171", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984456_451372750790504_2680730408523464405_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nP4ChqgWakgQ7kNvgHIoKBS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAglDlDOcX4qWIt5HZhA4x8XG-VFLqa7GYZOGiTsf8GNg&oe=678107FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape.png", "id": "2605954682911136", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974593_2605954686244469_8788118017839344906_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aNfNQLKYKWUQ7kNvgEUxOtN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD3mJOTp6iumRb-8K4uitpqPIeZfs_qCSsamHidIVHB6g&oe=67810A16"}, "display_name": "eXRcise", "keywords": [], "long_description": "\u00a1Cuida tu salud entrenando con Realidad Virtual! Una app dise\u00f1ada para que tu rutina de ejercicios sea divertida, con entrenamientos dise\u00f1ados por profesionales que aprovechan al m\u00e1ximo las tecnolog\u00edas de RV. En eXRcise encontrar\u00e1s una gran variedad de entrenamientos de cardio, fuerza y movilidad, \u00a1adem\u00e1s de un modo desaf\u00edo centrado en el boxeo!\n\n\ud83c\udfafEntr\u00e9nate seg\u00fan tus OBJETIVOS\n\n\ud83d\udccaObt\u00e9n ESTAD\u00cdSTICAS de tu rendimiento\n\n\ud83c\udfdd\ufe0fElige tu ESCENARIO favorito para una experiencia inmersiva: un gimnasio virtual, la playa, \u00a1o incluso la luna!\n\n\ud83e\udd4aEntr\u00e9nate contra ti mismo con nuestro modo RETO\n\n\ud83d\udcaa\ud83c\udffdEntrenamientos creados por ENTRENADORES PROFESIONALES, con orientaci\u00f3n durante todo el ejercicio.\n\nY... \u00a1CLASES DE GIMNASIO! Entrena como si estuvieras en una clase de fitness desde cualquier lugar.\n\n Si tienes alguna duda, ponte en contacto con nosotros en exrciseads-support@exrciser.com\n", "short_description": "Let your eXRcise flow\u2728"}]}, "developer_name": "XR First Tech Investments SL", "developer_privacy_policy_url": "https://exrcise.app/Privacy_Policy_eXRcise_EN.pdf", "developer_terms_of_service_url": "https://exrcise.app/Terms_Conditions_eXRcise.pdf", "publisher_name": "XR First Tech Investments SL", "support_website_url": "https://exrciser.com/contact", "website_url": "https://exrcise.app/", "category": "APPS", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_c