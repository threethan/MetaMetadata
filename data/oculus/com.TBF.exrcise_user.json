uluscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oIWm9lxF9TUQ7kNvgFoVa1y&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBP-GxDsDpSVuCvdOgWpBrsNseMAOFOrEJCfTbgdSe8BA&oe=67275699"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxX1w5FrJj0Q7kNvgGcmmHv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCglbrkheOhDuN9SufaaItY0fhRAYMO650fe-8qe4q4JA&oe=672772DF"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IGqgx2ntC68Q7kNvgGq90o4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2f_4szyLK_brr9T4DsP801xbTCmEaHSPb1agKLiYk4w&oe=6727568C"}, {"file_name": "Cover Portrait (1).png", "id": "1029738121275803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001702_1029738124609136_1954560374588661011_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&