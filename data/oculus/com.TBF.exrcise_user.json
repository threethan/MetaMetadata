uluscdn.com&_nc_gid=AnVecBAQUFsfnL5NkHktLAD&oh=00_AYB9gndXmNLSBGClq50YZvNKVncuunWv0nmfkYalKBgN9w&oe=66E97401"}, {"file_name": "scrren3.png", "id": "2584053388410623", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001721_2584053391743956_3500946753024280021_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r0a4Q87qZ-EQ7kNvgH45k5N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnVecBAQUFsfnL5NkHktLAD&oh=00_AYBNDAESBTGvnhz1YDe6MbLS5_rEY1064xK92rWfuay4mA&oe=66E9625F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (4).png", "id": "636567375108119", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982635_636567378441452_960187589548057727_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4c2mZyWlkzEQ7kNvgGE2s7F&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnVecBAQUFsfnL5NkHktLAD&oh=00_AYAmjgjeTID7ZGPeamH8k3dDy5k4LwdPGHhlMlh8NARFHQ&oe=66E96A0A"}, "display_name": "eXRcise", "keywords": [], "long_description": "Puedes ejercitarte y disfrutar de entrenamientos profesionales solo, con un entrenador real o con tus amigos. Divi\u00e9rtete y ponte a prueba en el modo arcade, elige tu sesi\u00f3n diaria entre varios entrenamientos y ejercicios predefinidos dise\u00f1ados por profesionales cualificados. \n\nMejora tu t\u00e9cnica y tu salud gracias a los ejercicios y a los comentarios de los profesionales.\n\nNo olvides elegir el mejor entorno, puede ser una playa, lo alto de la ciudad o incluso la luna. \n\nTe acompa\u00f1aremos en toda tu experiencia en eXRcise, disfrutalo!!! ", "short_description": "Una aplicacion para el entrenamiento fisico, mental y social. "}]}, "developer_name": "XR First Tech Investments SL", "developer_privacy_policy_url": "https://exrcise.app/Privacy_Policy_eXRcise_EN.pdf", "developer_terms_of_service_url": "https://exrcise.app/Terms_Conditions_eXRcise.pdf", "publisher_name": "XR First Tech Investments SL", "support_website_url": "https://exrciser.com/contact", "website_url": "https://exrcise.app/", "category": "APPS", "