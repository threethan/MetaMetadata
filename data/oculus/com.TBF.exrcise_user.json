scrren3.png", "id": "6994497137232231", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Ni5fwgw_rwQ7kNvgFdPZXk&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBXzQGySUwKK6bEj42QPDKBTJdq3SG7dW-ZqkMsXuxg_Q&oe=67163319"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QWpvps-XKEoQ7kNvgFOW9JU&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYC8ogzQiK8CW_sumS7rQ-ID_oT_Lg529l8Q3ummniUD2w&oe=67164F5F"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UUaML47Vw7YQ7kNvgFK4YAE&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCpwHJD-h0lI6qrsPwr-_n73Cs0roHvJGV5iSnwXf4JEQ&oe=6716330C"}, {"file_name": "Cover Portrait (1).png", "id": "1029738121275803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39001702_1029