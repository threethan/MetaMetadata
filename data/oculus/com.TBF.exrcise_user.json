uluscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZXPPkX3U0gQQ7kNvgGK7DO5&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBUHR4G9PnHTZJIO60AUEeq07xy-URrDPejwuW67YuMyA&oe=67406319"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s6jtZGZT7ykQ7kNvgHDyCnH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBmGeUwQ1_7Jynx894o1Ha2dzSBL0G56NXvZ0DvE7eaow&oe=67407F5F"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KCj5aMm3EyMQ7kNvgEAqALC&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCwKo7cZqexxCAa01wOUtmH2yjPIqe-7tsf9oXoWSzbsg&oe=6740630C"}, {"file_name": "Cover Portrait (1).png", "id": "1029738121275803", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001702_1029738124609136_1954560374588661011_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&