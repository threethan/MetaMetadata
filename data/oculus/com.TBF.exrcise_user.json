.png", "id": "821871586178046", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_821871592844712_1448396291330821220_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XPw-U9UlQ9sQ7kNvgHHcA6D&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3BRD6TNuih6mYR4AzxGJE0&oh=00_AYB1Dx49GLZkVgwFb6reR31ZPP_RGKM4HDEB_WFmKOzY7A&oe=66E6BD58"}, {"file_name": "scrren3.png", "id": "6994497137232231", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003228_6994497140565564_8705618406685575580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M16vPE-b5m4Q7kNvgGPmXK1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3BRD6TNuih6mYR4AzxGJE0&oh=00_AYBsI_rjLgLLqLEZdbghwPud8iuE0TBPP16AQu683E30jg&oe=66E6BD19"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape (2).png", "id": "6349061095186670", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974716_6349061098520003_4346703762718443865_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3tUz7bjYAKAQ7kNvgGX_doc&_nc_ht=scontent.oculuscdn.com&_nc_gid=A3BRD6TNuih6mYR4AzxGJE0&oh=00_AYDof6aEUkEm0Y3liorZcNkFJK8QQdWj33QdoJjAss2P0w&oe=66E6D95F"}, "display_name": "eXRcise", "keywords": [], "long_description": "You can exercise and enjoy professional workouts on your own, with a real trainer, or with your friends. Have fun and get challenged in the arcade mode, choose your daily session from several predefined workouts and exercises designed by qualified professionals. \n\nImprove your technique and health. Get exercises and feedback from sports and fitness professionals.\n\nDon't forget to choose the best environment, it can be a beach, the top of the city or even the moon. \n\nWe are with you throughout your eXRcise experience, have fun!\n", "short_description": "VR app for physical, social and mind health"}, {"images": {"nodes": [{"file_name": "Icon (1).png", "id": "1207821500616500", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982544_1207821503949833_7279465545522210509_n.png?_