_name": "migrated_image.png", "id": "219286585939944", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162788_1657386201223280_2120778112584122368_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y6FmJuhpN-YQ7kNvgG0ttok&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZzS6f3N4xOUonRjtloQEBRXD822N-Nz4-TtFP8aKzBQ&oe=6767F324"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Domino VR", "keywords": ["DominoVR", "Domino", "Paramlabs", "VRDomino", "Dominoes"], "long_description": "Take a trip down memory lane or indulge in your favorite pastime as you play with dominoes on your phone. \nChoose to enter \u201cFree Mode\u201d and express your creativity or enter the \u201cGuided Mode\u201d and have fun building some interesting formations \u2013 all within the convenience of your phone.\nWith Domino VR you don\u2019t have to worry about your creations taking up space inside your house or office, you can simply save unfinished creations and work on them later to create awesome and complex shapes. \nRelive the experience of watching the dominoes fall without having to create the whole line again, and in case you get stuck, refer to our helpful tutorial to guide you along the way.", "short_description": "Simplistic and mesmerizing; the definitive dominoes simulation."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.paramlabs.com/privacypolicy.htm", "developer_terms_of_service_url": "http://www.paramlabs.com/privacypolicy.htm", "publisher_name": "ParamLabs Private Limited", "support_website_url": null, "website_url": "http://www.paramlabs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "PUZZLE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "suppo