 {"file_name": "4.png", "id": "834380678113860", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031348_834380681447193_8420668529833112098_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XweyK7LDkP8Q7kNvgGVO9Dt&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFfpsSyOsjIUn73Z_72IUUE6kpck5hdlVu-KyibyQ9Og&oe=66D9AFDE"}, {"file_name": "3.png", "id": "280764721788602", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031375_280764725121935_207776903341773007_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GXiMP-V-UL8Q7kNvgHZ4K9J&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZ5K0042oh9MmUPjNfFok2pNRuUz-fGNmcr5OIgDLH9A&oe=66D9AAE8"}, {"file_name": "2.png", "id": "1853414455170371", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75451773_1853414458503704_9155539287420568111_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2kGUVDvoYogQ7kNvgHgrGLc&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKU41k67VdlVBwRFp_RGyPmKbJ_SrXGSmKkwo4O8mALg&oe=66D98BFD"}, {"file_name": "1.png", "id": "1823599864789996", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_1823599868123329_3086197029441937060_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PHBs7HB4L5YQ7kNvgGHssAT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwT-2bHi0ezwwQyDhJ6sNS6cBbZLXbJnFr5cEnIOFSHw&oe=66D9883C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1154861575752039", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974581_1154861579085372_2296516147183997508_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mi2Et8J6OR4Q7kNvgFEqwbI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgBQ04uRFYfQQkkP3RfDB4JByqymIO7yzYKdcq2FU7dQ&oe=66D9B0A8"}, "display_name": "VRzomOLTrial", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": "Holo", "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Holoren", "support_website_url": null, "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "7850424621689264"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "26781769688076898"}]}, "baseline_offer": {"id": "26781769688076898"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1719537818, "status": "PUBL