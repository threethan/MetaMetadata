uscdn.com&oh=00_AYCMueNWiqbav3qK3Egxw4owQK9vJUHhNkTeA1Z90Ak03A&oe=676FF5E8"}, {"file_name": "2.png", "id": "1853414455170371", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451773_1853414458503704_9155539287420568111_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fM1z6hCJmEsQ7kNvgHUX9Uo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3fu9NYqbJ_skNELBkxxrboeX8pevYwdmyV0jsemTlng&oe=676FD6FD"}, {"file_name": "1.png", "id": "1823599864789996", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982518_1823599868123329_3086197029441937060_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZjWa46Sw2qwQ7kNvgEbYQ93&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBQs6S6rcopTdabVKKRweLtMPEUDuf-ui6NPab25nykgQ&oe=676FD33C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "1154861575752039", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974581_1154861579085372_2296516147183997508_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UFqKm0Rl5jsQ7kNvgHCVS_C&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjrVfsNUswqIRnWJkhZTKRd1ql_Cmx2ZU4NEhlD0se0Q&oe=676FFBA8"}, "display_name": "VR Zombie Escape Demo", "keywords": [], "long_description": "The VRzomOl is a VRFPS game that focuses on PVP network online biochemical battle mode, an improvement from the original CS's popular biochemical mode. The game features two modes: zombie escape and biochemical infection. In these modes, online players must play as either humans or zombies. Within a limited time frame, humans must either annihilate all zombies or save themselves, while zombies aim to infect all humans through an all-out attack.\n1. Biochemical infection: Within a limited timeframe, humans must eliminate all zombies using firearms or evade them in order to prolong survival, while the zombies actively seek out humans to infect them.\n2. Zombie escape: Within a restricted time frame, humans are required to fend off zombies with firearms for self-preservation and successfully reach the designated endpoint in order to achieve successful escape. The immediate infection of all human players by zombies results in victory.", "short_description": "The first VR Biochemical frenzy online battle in history, Multiplayer shooter in VR with zombies escape, officially opened"}]}, "developer_name": "Holo", "developer_privacy_policy_url": "https://vrdanceyinsi.webnode.page/", "developer_terms_of_service_url": null, "publisher_name": "Holoren", "support_website_url": null, "website_url": "https://renrenren.webnode.page/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER"], "id": "8974799525918429"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86774300_1137791800985329_7840399038059654241_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4BZmAf9WrmYQ7kNvgE38T1U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4qQSlM0tbZQr-3zMaStSuVCT-ibYM2fi3DZx37EYYJQ&oe=676FCE5B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Zombie Escape Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1719537818, "lastRevision": {"nodes": [{"id": "7821371357927924", "release_type"