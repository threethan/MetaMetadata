.png", "id": "855322562831216", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_855322566164549_4363188022118813260_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xwGM303-T-MQ7kNvgGFxIxd&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbPh9fXVLwRG60XbU4XHKS7-tO80wtRwkHfDAsCea3Cg&oe=66FA9AC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot5.png", "id": "189180370856841", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035411_189180374190174_2041119517261467595_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rvlnyDRbc1IQ7kNvgFvEMUg&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6jZWSGbx2hDC71qPLQ5Dmjp4m4Z6tHeMaMV6l4iC3zA&oe=66FA979D"}, "display_name": "Child's Play", "keywords": [], "long_description": "Child's Play is a VR environment where you can create various shapes of different sizes and colors.  You can stack blocks, throw balls at towers, or just enjoy the various moving objects within the scenery.  Child's Play does not require any instructions, setup, or configurations to play.  All you need is to put on your VR headset and play around.  Child's Play is perfect for anyone who is new to VR and just wants to simply interact with VR objects in a fun and safe environment.", "short_description": "From stacking blocks to throwing balls, Child's Play is a simple VR environment that allows you to play and interact with different shapes.  Child's Play allows you to bring out your inner child."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.damionmullins.com/childsplay#privacyPolicy", "developer_terms_of_service_url": null, "publisher_name": "Damion Mullins", "support_website_url": null, "website_url": "https://www.damionmullins.com/childsplay", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_