eGrab_Interactions.png", "id": "1152693381975879", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031619_1152693388642545_4707446576890666511_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pzEMqbl8Vi8Q7kNvgGdPvF0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKFbBn9rRuLl9DCpWcy4qZwRFB108IYoCS-jhi8xcq3g&oe=66FE7B5D"}, {"file_name": "HandGrabUse_SprayBottle.png", "id": "790969798771574", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476758_790969805438240_384180907024125179_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXvvWXwd4k8Q7kNvgHARdRM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPmo6pJlxymh2eZaXPFJdDtnXKieky4e0W4M5q2fqLPg&oe=66FE9B7A"}, {"file_name": "HandGrab_Torch.png", "id": "466751461745726", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86817056_466751465079059_7395397905970885120_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lXbqB_v5lcAQ7kNvgED9myQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMgjD5-kogLXrrnNRq2aVyAlv2MPD2oT2gQazoHTSvoQ&oe=66FE7A0E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArtLandscape (2).png", "id": "627544722090317", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036606_627544725423650_8657003459039286021_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a04N62Ojj_4Q7kNvgHx4HM-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBw-5PQvB0DSYdV5iM1yH44W3OppCrlFlSz4S3hVy7m3Q&oe=66FE911E"}, "display_name": "Interaction SDK Samples", "keywords": [], "long_description": "The Interaction SDK samples are the official reference for all interactions available in the Presence Platform Interaction SDK package. Interaction SDK is a library of modular, composable interaction components that makes it simpler, faster and easier for developers to build high-quality interactions in virtual or augmented reality. Start here along with First Hand to understand the possibilities of using Interaction SDK in your project. Consult the samples as a reference as you develop your own experience. Interactions shown in these samples include poke, hand grab, touch grab, ray, distance grab, post recognition, transformers, gestures and use grab.\n\nInterested in using Interaction SDK in your Unity project? You can learn more about Interaction SDK and get started by visiting the Overview page. ", "short_description": "The Interaction SDK samples are the official reference for all interactions available in the Presence Platform Interaction SDK package."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "465481292257154"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036680_1428907447584690_7727723258978760440_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Da66HebFj70Q7kNvgGgC8PI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKV71OtorI8a_wORrwQKIDo-GiIIerlm9HCnhb6LhDuw&oe=66FE9C24"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Interaction SDK Samples", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1663351077, "lastRevision": {"nodes": [{"id": "5605166219514977", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_me