ality interactions in virtual or augmented reality. Start here along with First Hand to understand the possibilities of using Interaction SDK in your project. Consult the samples as a reference as you develop your own experience. Interactions shown in these samples include poke, hand grab, touch grab, ray, distance grab, post recognition, transformers, gestures and use grab.\n\nInterested in using Interaction SDK in your Unity project? You can learn more about Interaction SDK and get started by visiting the Overview page. ", "short_description": "The Interaction SDK samples are the official reference for all interactions available in the Presence Platform Interaction SDK package."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://developer.oculus.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "465481292257154"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "622164852956754"}]}, "baseline_offer": {"id": "622164852956754"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1663351020, "status": "PUBLISHED", "id": "622164852956754"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8365169603514611", "version"