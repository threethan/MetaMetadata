ce. Interactions shown in these samples include poke, hand grab, touch grab, ray, distance grab, post recognition, transformers, gestures and use grab.\n\nInterested in using Interaction SDK in your Unity project? You can learn more about Interaction SDK and get started by visiting the Overview page. ", "short_description": "The Interaction SDK samples are the official reference for all interactions available in the Presence Platform Interaction SDK package."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.meta.com/legal/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Meta Quest Samples", "support_website_url": null, "website_url": "https://developers.meta.com/horizon/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}, {"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8881182321913334"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036680_1428907447584690_7727723258978760440_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oo8lzgq3PDgQ7kNvgHBfVer&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUXjUSWN8K-A7Zezc5B3jZ8lorImDBX72WFv4xna_fow&oe=676965A4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Interaction SDK Samples", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "