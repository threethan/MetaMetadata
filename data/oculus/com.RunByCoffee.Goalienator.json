49469034722891", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974507_449469038056224_7047051976711508592_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c4vX_9dWDm4Q7kNvgFSeCg-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcaSPdTXWYGH5j9pZNjTnfv&oh=00_AYCj0KmSDbloUGciRuT1SFohOoYi2VxvbKaCTMseG5p3JQ&oe=66F4056E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoImage.png", "id": "1055870819595594", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75630190_1055870822928927_4610539069664301359_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ik8aXtgIB28Q7kNvgGzyf6n&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcaSPdTXWYGH5j9pZNjTnfv&oh=00_AYC42F7o80WmBmfzqE9RLv-AJHjvpmC9cmtEdz1mjylP3w&oe=66F3F9AD"}, "display_name": "Goalienator", "keywords": [], "long_description": "Goalienator is an arcade-style reflex training game for all skill levels. In fast-paced, sport-like environments, you will face a variety of challenging game modes that will test your reflexes and hand-eye coordination.\n\nTraining mode allows players to access all game modes, offering them a large number of options to tweak their gameplay and match their skill levels. \n\nChallenge mode offers players to compete against other player leaderboard scores with pre-defined set of gameplay related options. Completing each challenge with the required scores rewards players with \"Goalie Points\" and allows them to unlock achievements, including new customization options for their player gear. \n\nPlayers progress through the ranks by completing various tasks. Each new level unlocks Goalie Points, achievements, and unique customization options for their goalie gear, trophies, and more! \n\n* Goalienator is not designed to be realistic sport simulator, but casual goaltending game with familiar elements from different sports", "short_description": "Goalienator is an arcade-style reflex training game for all skill levels. In fast-paced, sport-like environments, you will face a variety of challenging game modes that will test your reflexes and hand-eye coordination."}]}, "developer_name": null, "developer_privacy_policy_url": "https://runbycoffee.com/goalienator-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "RunByCoffee", "support_website_url": "https://runbycoffee.com/", "website_url": "https://runbycoffee.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8227923860601006"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/427391793_463729109745176_9002765802424578536_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3bt8e7jTmhUQ7kNvgEDcwlR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcaSPdTXWYGH5j9pZNjTnfv&oh=00_AYDEAZiKpxSjh2cDfjp1CrAJYvj-RA9KGoc9S4Ju3bCtvA&oe=66F3EEBD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Goalienator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1617898297, "lastRevision": {"nodes": [{"id": "3955458491145226", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": 