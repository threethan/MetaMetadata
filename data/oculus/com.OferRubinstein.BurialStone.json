pells and skills, gain XP, level up and improve your abilities.\n\nThe combat is \"you move, the others move with you\" tactical style combat, reminiscent of a rogue like game.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://burialstone.computerrpg.com/BurialStone/privacy-policy-burial-stone/", "developer_terms_of_service_url": null, "publisher_name": "Ofer Rubinstein", "support_website_url": null, "website_url": "https://burialstone.computerrpg.com/BurialStone/burial-stone/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1555662444917056"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031399_861024218317130_871372309150919907_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dS8uuxp793wQ7kNvgHvN3Fs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBw8S7qUgvgihXtv5Wsk-MnK4RhF5EQyqxHkNmxdojEiA&oe=6741B729"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Burial Stone", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Fighting", "id": "2710427532541308"}], "release