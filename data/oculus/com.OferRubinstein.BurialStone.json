rHvkw&oe=672A142C"}, {"file_name": "Screen8.png", "id": "1282654859128883", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39031619_1282654865795549_1172631852289006950_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C9YjnWe-BBMQ7kNvgEKJUW4&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCw7dc4OM562-h5sobhN3eL5ma8086HMXETn8RC6D347A&oe=6729EC7B"}, {"file_name": "Screen9.png", "id": "1520539288474763", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035404_1520539295141429_4484106663629885399_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DKnDjY15100Q7kNvgExXsKH&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBCMrtfPTqRrxgcAWa3bHTjLoXl36g1DcgvyWEkDYTQxA&oe=672A1B3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screen7.png", "id": "3344748279127585", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75280177_3344748282460918_1685165233192286841_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ibK7Ki3baUQ7kNvgGsjkUF&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYChyJuETUrfVUkJCcna_iisVU1-zIXJsLuinAoyddDoRg&oe=672A1873"}, "display_name": "Burial Stone", "keywords": [], "long_description": "Delve into a damp dark dungeon, with your torch as your only light source, in Burial Stone.\n\nBurial Stone is a VR tile based, tactical dungeon crawl. Fight terrifying monsters from a first person perspective, acquire equipment, weapons and gold.\nLearn spells and skills, gain XP, level up and improve your abilities.\n\nThe combat is \"you move, the others move with you\" tactical style combat, reminiscent of a rogue like game.\n\nThere is a sense of horror to these dungeons with some surprises along the way. Tread carefully.", "short_description": "Delve into a damp dark dungeon, with your torch as your only light source, in Burial Stone.\n\nBurial Stone is a VR tile based, tactical dungeon crawl. Fight terrifying monsters from a first person perspective, acquire equipment, weapons and gold.\n\nLearn spells and skills, gain XP, level up and improve your abilities.\n\nThe combat is \"you move, the others move with you\" tactical style combat, reminiscent of a rogue like game.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://burialstone.computerrpg.com/BurialStone/privacy-policy-burial-stone/", "developer_terms_of_service_url": null, "publisher_name": "Ofer Rubinstein", "support_website_url": null, "website_url": "https://burialstone.computerrpg.com/BurialStone/burial-stone/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1555662444917056"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031399_861024218317130_871372309150919907_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ARh1dvC39hEQ7kNvgHrJ3dR&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAs9waqwbdcuYjpEzk3v3lhOo75HQhlNw7AP4UMTPcZOA&oe=6729FC29"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Burial Stone", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Fighting", "id": "2710427532541308"}], "release