eon crawl. Fight terrifying monsters from a first person perspective, acquire equipment, weapons and gold.\n\nLearn spells and skills, gain XP, level up and improve your abilities.\n\nThe combat is \"you move, the others move with you\" tactical style combat, reminiscent of a rogue like game.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://burialstone.computerrpg.com/BurialStone/privacy-policy-burial-stone/", "developer_terms_of_service_url": null, "publisher_name": "Ofer Rubinstein", "support_website_url": null, "website_url": "https://burialstone.computerrpg.com/BurialStone/burial-stone/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1555662444917056"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031399_861024218317130_871372309150919907_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j06mZg3U9AgQ7kNvgF_4Neq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ak0pIYZogzSpOEhCBmNg87H&oh=00_AYDq6BN8Z_vr1GfLsLsJBqI_2otqUkccO4NTV_7L8J0Yiw&oe=66EEA8A9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Burial Stone", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "RPG (Role Playing Games)", "id": "961172191044986"}], "release_date": 1676312433, "