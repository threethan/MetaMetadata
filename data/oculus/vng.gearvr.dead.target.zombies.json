ore intensive! Think twice before you go in. Consider 10 times dangerous than last year.", "short_description": "Survive the Zombie Intensified, Face to Dead and Fear"}]}, "developer_name": null, "developer_privacy_policy_url": "http://deadtarget.com/", "developer_terms_of_service_url": "http://deadtarget.com/", "publisher_name": "VNG CORP", "support_website_url": null, "website_url": "http://deadtarget.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ADVENTURE", "FIGHTING", "HORROR", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1249732012191924"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1540784886003589"}]}, "baseline_offer": {"id": "1540784886003589"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1513188000, "status": "PUBLISHED", "id": "1540784886003589"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1756962604345689", "version": "0.1.8"}, "id": "121307991841607", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1676554809053136", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1756962604345689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "121307991841607"}]}, "change_log": null,