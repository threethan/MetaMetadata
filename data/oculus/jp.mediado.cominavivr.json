3245_519104589382361_8529479973072104305_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QhqPiKlIXoIQ7kNvgFKu5o2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYlgrigHgiNzqHeFrdFJnFXuSulcPJOxzDzPHEcSEpbQ&oe=66D442C5"}, {"file_name": "Screenshot_4.png", "id": "564593604673225", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982525_564593608006558_429365138704557303_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GpaT1jglYmIQ7kNvgGwRwHA&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTxAwNJhVi357e5g9QMmNVSQJZIuXp21LW2gU2KvorzQ&oe=66D45AA1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_New_210928.png", "id": "454334329243649", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003231_454334332576982_2840156253641573150_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fezEVG5MQS8Q7kNvgGecTUm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgryhoMYsSgcW3g2kBK7VdMZfzLWEfdzFWFZQd-j2W1Q&oe=66D44FE0"}, "display_name": "\u30b3\u30df\u306a\u3073VR\uff08COMINAVI VR\uff09", "keywords": [], "long_description": "The World's First Manga Platform for Enjoying Japanese Manga Comics in VR\n\nFeatures.\nThe position and size of the manga can be changed freely.\nYou can switch between various backgrounds in the reading space.\nYou can add new manga in the VR space.\nYou can add new comics in the VR space - Can be used offline (need to download comics in advance)\n\nCominavi account is required. For details, please check (https://mechacomi.jp/).", "short_description": "\u65e5\u672c\u306e\u30de\u30f3\u30ac\u30b3\u30df\u30c3\u30af\u3092VR\u3067\u697d\u3057\u3081\u308b\u4e16\u754c\u521d\u306e\u30de\u30f3\u30ac\u30fb\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\nThe World's First Manga Platform for Enjoying Japanese Manga Comics in VR"}, {"images": {"nodes": []}, "id": "550875112877386", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u30b3\u30df\u306a\u3073VR", "keywords": [], "long_description": "\u65e5\u6