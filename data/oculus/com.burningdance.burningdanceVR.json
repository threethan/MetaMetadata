scdn.com/v/t64.5771-25/38974797_421048739385069_350828070638166146_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=54H__DV3IqoQ7kNvgF2PUYh&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDIcjuPdBopjBLc62dkzCsZFstc0hoDfaHrXipGl3kGnA&oe=6701128F"}, {"file_name": "2560x1440-4.png", "id": "270810048259690", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036680_270810051593023_6290647092584061241_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5MDslLLYXFQQ7kNvgHqRyYs&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAxpR2oNuGq91e143P0Oh3Vl5X4PyhXvrU3eJFfwjfrBA&oe=670143E8"}, {"file_name": "2560x1440-3.png", "id": "198468039060241", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031540_198468042393574_5253626776570562223_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mkypsY3GDSUQ7kNvgHmOTbJ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBesl1hrZvIdBBWieNPGQAkBJAZQuFBYLCgJWK7KuQ-Cg&oe=6701327D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440kongchangjing.png", "id": "390658766103031", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982666_390658769436364_2302287055393307583_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k6L-4hTg_74Q7kNvgFbLlup&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAQuKp-RCoShbvX0zEigTQQfKvNOGiGc0OIGIC_EwgOJA&oe=67013CD4"}, "display_name": "Burning Shoes VR", "keywords": [], "long_description": "1.  Burning Shoes VR is an dance VR app on Oculus Quest. We can see clearly virtual characters dance by your side.  We enjoy life, we love music,so we love dance!\n2.  Song list is here:\nhttps://www.cqplanb.com/ccc/burningshoes-songlist.html\n3. We use microphone to react with rhythm, So If you refuse to open microphone permissions when first open app,there won't be reaction with rhythm. App still can work.\n3. Make sure to review your surroundings and clear any obstacles in your play area before starting this game.\n4. You 'd better have sweat proof sleeve on your Quest headset, you will 