n.com/v/t64.5771-25/39036680_270810051593023_6290647092584061241_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fL8KlOoiSd8Q7kNvgGKzd4V&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJcKvyGEfPEfrvJXYJhcFXmrcgW4HZTQRh4hUBxWE38Q&oe=66F922A8"}, {"file_name": "2560x1440-3.png", "id": "198468039060241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_198468042393574_5253626776570562223_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hWssO1uSWSMQ7kNvgH_Mlnr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEoInDhm1vOrWj9Q7HbM7eXcicGZ6pfu1Nfk5JG7tk4Q&oe=66F9497D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440kongchangjing.png", "id": "390658766103031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_390658769436364_2302287055393307583_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EZWbnUcykncQ7kNvgGKjOQ-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgEQi6sltreCete-L_DY_jAMxhMOY6BpramumuD8WK2w&oe=66F953D4"}, "display_name": "Burning Shoes VR", "keywords": [], "long_description": "1.  Burning Shoes VR is an dance VR app on Oculus Quest. We can see clearly virtual characters dance by your side.  We enjoy life, we love music,so we love dance!\n2.  Song list is here:\nhttps://www.cqplanb.com/ccc/burningshoes-songlist.html\n3. We use microphone to react with rhythm, So If you refuse to open microphone permissions when first open app,there won't be reaction with rhythm. App still can work.\n3. Make sure to review your surroundings and clear any obstacles in your play area before starting this game.\n4. You 'd better have sweat proof sleeve on your Quest headset, you will sweat a lot happily when playing this.\n5. Some actions are more suitable for people with basic dance foundation.\n6. Any cooperation is welcome,please contact us.     \n7. Will update new dance every month,  If there are songs you wonder which are not in list, Please don't hesitate to contact us immediately via E-Mail: \n408077086@qq.com", "short_description": "Burning Shoes