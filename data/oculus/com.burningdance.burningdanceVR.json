=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lD3X20VjglYQ7kNvgHOMoj9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCl6jD5JB3MLk7rn12kjz0mQkYjieqpkc__ZWxA-llk6w&oe=6705070F"}, {"file_name": "2560x1440-4.png", "id": "270810048259690", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036680_270810051593023_6290647092584061241_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hsLyzJ-ax6wQ7kNvgElRHID&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDc5DJvjq8uWnqWy69tVaTo2Gjjt3liBx3VxxnLKb8BBA&oe=67050028"}, {"file_name": "2560x1440-3.png", "id": "198468039060241", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031540_198468042393574_5253626776570562223_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1imkMOBZlJMQ7kNvgFUXko_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwr4MWFwysQxIAx-T0RYJX_smSjX5BnGEU3eaBuRIuNw&oe=670526FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440kongchangjing.png", "id": "390658766103031", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982666_390658769436364_2302287055393307583_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LCK99juSHLAQ7kNvgEE7Gqc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB4RYrcDia2Jh83HvvUeF8RLy10QDsJ4NDUf-G9yuLcoA&oe=67053154"}, "display_name": "Burning Shoes VR", "keywords": [], "long_description": "1.Song list is here: \nhttp://www.cqplanb.com/ccc/burningshoes-songlist.html\n\n2.We use microphone to react with rhythm, So If you refuse to open microphone permissions when first open app,there won't be reaction with rhythm. App still can work.\n\n3.Make sure to review your surroundings and clear any obstacles in your play area before starting this game.\n4.You 'd better have sweat proof sleeve on your Quest headset, you will sweat a lot happily when playing this.\n5.Some actions are more suitable for people with basic dance foundation.More difficult for beginners. Search this \"Dance workout VR(Junior)\" for beginners.\n6.Due to Copyright of music, we don't include music in this app. But we support custom import .mp3 into Quest and play. \nSee how to: https://www.youtube.com/watch?v=ZGbSDxOCHMs\n\n7.You can use touches in hands get scores, also you can drop them.\n\n8.If there are songs you wonder which are not in list, Please don't hesitate to contact us immediately via E-Mail: 408077086@qq.com\n", "short_description": "Burning Shoes VR is an dance VR app on Oculus Quest. We can see clearly virtual characters dancer teacher by your side.  This is more suitable for middle-level with basic dance foundation\uff01Maybe difficult for beginners.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cqplanb.com/ccc/Burning_Shoes_VR.txt", "developer_terms_of_service_url": null, "publisher_name": "jijia", "support_website_url": null, "website_url": "http://www.023d.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "991454055053572"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974583_274645694439013_6752270984683066269_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3yNRFJUw7ocQ7kNvgGRh4Kh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2WWGSnRxyxXkhDeEX2x6sp-YT88MSdrH5zO0iJ65KYw&oe=67051752"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Burning Shoes VR", "platform": "ANDROID_6DOF", "c