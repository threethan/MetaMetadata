739184562748_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4-ewiK69IwQ7kNvgFI-Nwi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOpXbp8dqRDOCt8qKQd3oOX&oh=00_AYDDcjjqoxqcEA9QPwRSrQVFEpIQANSXqxaBrciq9vEGWQ&oe=66E6AE4F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover.png", "id": "1119789582682685", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_1119789586016018_2562619597780840680_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K-CU2r93c_0Q7kNvgH762Hw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOpXbp8dqRDOCt8qKQd3oOX&oh=00_AYCDRAjEWZRjAJt_kWbqs10bVis5fclA6dPMVtL6p1-yCg&oe=66E6CA54"}, "display_name": "UNDERDOGS", "keywords": ["physics", "mech", "roguelike", "fighting", "cyberpunk"], "long_description": "Wrap yourself in 5 tons of metal and go smashing through a dark scene of UNDERGROUND MECH FIGHTS!\n\nBash, crush, maul and rip apart enemy bots and mechs - it\u2019s full-on metal-on-metal violence in this first of its kind physics-based mech brawler.\n\nBut rampaging through the pits ain\u2019t all - this is a Roguelike. \nGear up with 100+ items and power tools, hire hackers and saboteurs, hustle and deal with the gangsters and psychos who run these streets as you claw your way up the food chain.\n\nThis city is a dog-eat-dog s#@^ show, but luckily you ain't alone.\nYour little bruv King is in your corner - hacking your enemies and giving you lip while you fight like a wild animal, smashing car sized pit bots that wanna kill you dead to the deafening roars of the blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital of the World.\nThis is UNDERDOGS.", "short_description": "Strap into 5 tons of metal & go smashing through a dark scene of UNDERGROUND MECH FIGHTS! Bash, crush & tear your enemies - it\u2019s full-on metal-on-metal violence in this physics-based mech brawler.\n\nGear up with 100+ items, hire hackers & saboteurs, hustle & deal with the gangsters running these streets, and fight up the food chain to the roars of blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital.\nThis is UNDERDOGS."}]}, "developer_name": null, "developer_privacy_policy_url": "https://underdogs-public.s3.us-west-1.amazonaws.com/underdogs-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "One Hamsa", "support_website_url": null, "website_url": "https://www.underdogsgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8137445383005933"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974548_1892813381193417_8375927524945661028_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdjqPjEHEYAQ7kNvgEufOaW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AOpXbp8dqRDOCt8qKQd3oOX&oh=00_AYDAGGbbd7pAf5tCYuGAms-Luo-06Ff2QMPyFGIDm5JqmA&oe=66E6B8AD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "UNDERDOGS", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1706205600, "lastRevision": {"nodes": [{"id": "5302178643199302", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata