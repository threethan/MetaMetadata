lg&oe=67123AD7"}, {"file_name": "Screenshot Combat 4.png", "id": "783219326461232", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/43931333_783219329794565_6798415521313857273_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XglFuSUbZ54Q7kNvgEDIegW&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYASDK_fRP3ZZ2StEhD8bbvHQ44cnjtZSdfZiZtrFr1H2A&oe=671245C3"}, {"file_name": "Screenshot Zikitta.png", "id": "1177654182914639", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39001732_1177654186247972_3518134454436079482_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=85dhDBjVbHIQ7kNvgFs3x3C&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDTAZscCOfV6V3i-mtrQa-Y3O3RyYwn-GxJTTjHgpU3Kg&oe=671238D8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Image.png", "id": "291876823163268", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75294237_291876826496601_1798322164409634651_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E86Vmsz0eIoQ7kNvgGfND_F&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAgvYR9sA9Rb5jppEXfBQKgGPROv4y_dk7FjccRtgkPUQ&oe=67125C33"}, "display_name": "UNDERDOGS", "keywords": ["physics", "mech", "roguelike", "fight", "cyberpunk"], "long_description": "Wrap yourself in 5 tons of metal and go smashing through a dark scene of underground pit fights!\n\nBash, crush, maul and rip apart enemy bots and mechs - it\u2019s full-on metal-on-metal violence in this first of its kind physics-based mech brawler.\n\nBut rampaging through the pits ain\u2019t all - this is a Roguelike. \nGear up with 100+ items including power tools like chainsaws and wrecking balls, hire hackers and saboteurs, hustle and deal with the gangsters and psychos who run these streets as you claw your way up the food chain.\n\nThis city is a dog-eat-dog s#@^ show, but luckily you ain't alone.\nYour little bruv King is in your corner - hacking your enemies and giving you lip while you fight like a wild animal, smashing car sized pit bots that wanna kill you dead to the deafening roars of the blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital of the World.\nThis is UNDERDOGS.\n\nWelcome to the jungle. \nWishlist now!", "short_description": "Strap into 5 tons of metal & go smashing through a dark scene of underground pit fights! Bash, crush & tear your enemies - it\u2019s full-on metal-on-metal violence in this physics-based mech brawler.\n\nGear up with 100+ items including chainsaws & wrecking balls, hire hackers & saboteurs, hustle & deal with the gangsters running these streets, and fight up the food chain to the roars of blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital.\nThis is UNDERDOGS.\n\nWelcome to the jungle."}]}, "developer_name": null, "developer_privacy_policy_url": "https://underdogs-public.s3.us-west-1.amazonaws.com/underdogs-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "One Hamsa", "support_website_url": null, "website_url": "https://www.underdogsgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "620570659262196"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "9143594035667045"}, {"status": "CANCELLED", "id": "835613052038354"}, {"status": "PUBLISHED", "id": "718013470451502"}, {"status": "PUBLISHED", "id": "1024341615717818"}, {"status": "PUBLISHED", "id": "38