me": "Screenshots Jungle.png", "id": "1401277690637913", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982494_1401277693971246_177314821947097266_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OMJIrP7uKQQQ7kNvgFXhcAF&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_N2nd55vMP0gE_oMmkS906&oh=00_AYCdvqziVW_UH5T7xQTEsyGvHgBNE1jBS9i8tRdhHWOzeQ&oe=66CDACD7"}, {"file_name": "Screenshot Combat 4.png", "id": "783219326461232", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931333_783219329794565_6798415521313857273_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MslzRfEtwicQ7kNvgHDqLyH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_N2nd55vMP0gE_oMmkS906&oh=00_AYAa1e5TTo3Nz4rvpi2jqs0xEg1aZ5YbtdmkppKEsBG3xA&oe=66CDB7C3"}, {"file_name": "Screenshot Zikitta.png", "id": "1177654182914639", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001732_1177654186247972_3518134454436079482_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6D6TKGw1EZMQ7kNvgGiMphW&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_N2nd55vMP0gE_oMmkS906&oh=00_AYD6WvBksMnX51PYzvFdsgnp8SWi1T5EfYz9RA_psDL2sg&oe=66CDAAD8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Image.png", "id": "291876823163268", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75294237_291876826496601_1798322164409634651_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lbzQ7Y8cEQ4Q7kNvgF4UKOa&_nc_ht=scontent.oculuscdn.com&_nc_gid=A_N2nd55vMP0gE_oMmkS906&oh=00_AYANi_vB5YGg1b6aVm3g__Y7M3uS-BvOgcN1T4suY6lj0Q&oe=66CDCE33"}, "display_name": "UNDERDOGS", "keywords": ["physics", "mech", "roguelike", "fight", "cyberpunk"], "long_description": "Wrap yourself in 5 tons of metal and go smashing through a dark scene of underground pit fights!\n\nBash, crush, maul and rip apart enemy bots and mechs - it\u2019s full-on metal-on-metal violence in this first of its kind physics-based mech brawler.\n\nBut rampaging through the pits ain\u2019t all - this is a Roguelike. \nGear up with 100+ items including power tools like chainsaws and wrecking balls, hire hackers and saboteurs, hustle and deal with the gangsters and psychos who run these streets as you claw your way up the food chain.\n\nThis city is a dog-eat-dog s#@^ show, but luckily you ain't alone.\nYour little bruv King is in your corner - hacking your enemies and giving you lip while you fight like a wild animal, smashing car sized pit bots that wanna kill you dead to the deafening roars of the blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital of the World.\nThis is UNDERDOGS.\n\nWelcome to the jungle. \nWishlist now!", "short_description": "Strap into 5 tons of metal & go smashing through a dark scene of underground pit fights! Bash, crush & tear your enemies - it\u2019s full-on metal-on-metal violence in this physics-based mech brawler.\n\nGear up with 100+ items including chainsaws & wrecking balls, hire hackers & saboteurs, hustle & deal with the gangsters running these streets, and fight up the food chain to the roars of blood thirsty crowds.\n\nThis is New Brakka - The Mech Fighting Capital.\nThis is UNDERDOGS.\n\nWelcome to the jungle."}]}, "developer_name": null, "developer_privacy_policy_url": "https://underdogs-public.s3.us-west-1.amazonaws.com/underdogs-privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "One Hamsa", "support_website_url": null, "website_url": "https://www.underdogsgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROO