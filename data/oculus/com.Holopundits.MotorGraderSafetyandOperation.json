ull, "video_trailer_thumbnail": {"file_name": "motor grader - trailer cover.png", "id": "840143774838027", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86597262_840143778171360_6047656471363500610_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xrnZJzdsdyMQ7kNvgEFgywa&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA30TWUUdeljAn8pEetAiQX18aV1wPM79LtmopP9tyl2w&oe=677BAE10"}, "display_name": "Motor Grader Safety and Operation", "keywords": [], "long_description": "Motor graders are versatile machines that play a pivotal role in various projects. Participants will operate a bulldozer and complete various tasks on an active worksite as part of this engaging simulation. \n\n**Overview & Activities:**\n\nParticipants begin with an overview that provides context and helps identify key parts and components outside and inside the vehicle, safety tips, and the basics of a walk-around inspection performed before using any heavy machinery. Participants engage in a sort-and-match activity to reinforce essential controls and their location inside the vehicle. They are then asked to perform a single task to become familiar with operating the vehicle in a VR environment. \n\n**Participant Simulation:**\n\nBefore starting their simulation tasks, participants must wear personal protective equipment (PPE), conduct a walk-around inspection of the vehicle, and complete one task to familiarize themselves with the vehicle's operation. Finally, participants are challenged to complete tasks at an active worksite, including leveling a small hill, moving piles of dirt into targeted areas, and filling a trench with rocks and stones. \n\n**Benefits & Key Features:**\n- Manipulative simulations provide hands-on practice in risk-free environments  \n- Instant feedback provides \u201ccorrect\" or \"try again\" responses to guide participants  \n- Flexible choice points allow participants to revisit any part of the simulation as needed \n- Realistic 3D tools, equipment, environments, and animations  ", "short_description": "Motor graders are versatile machines that play a pivotal role in various projects. Participants will operate a bulldozer and complete various tasks on an active worksite as part of this engaging simulation. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7303238916454008"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569457_447718910973282_2584863672054203103_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rCT8Q98c0QsQ7kNvgHb8MR4&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC9XHXHyJzQp4dP9ulxrHViP_HibAjqMiDkqwo94Z9HQQ&oe=677BC252"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Motor Grader Safety and Operation", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1727462340, "lastRevision": {"nodes": [{"id": "722896929