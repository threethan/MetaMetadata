_2800x1440.png", "id": "244834198114433", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001731_244834201447766_6675510070487884968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dphd3hI3eGoQ7kNvgHjyLuP&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYAulPxDgAIIROD70sO6omLCRRfTzFEJPjwMLxyjrZ9xDg&oe=66F2AFB9"}]}, "id": "502012282758934", "locale": "en_US", "screenshots": [{"file_name": "SSVR_Screenshot_1.png", "id": "1682746182296031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974452_1682746185629364_4974977310978005522_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MJy68EnjZiYQ7kNvgGIM57e&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYCZr9blavBXDgZbIHIopOmqRm-ajlqy1nbb559bBzW77Q&oe=66F2A9A7"}, {"file_name": "SSVR_Screenshot_2.png", "id": "331489900048323", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974688_331489903381656_1826260269304134480_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UWekeV0oSk0Q7kNvgE83xuD&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYB0fq5b9WRHUSmU-9mYjT0Ta1WuuWRm-NTP_B50VQSs5A&oe=66F29CCE"}, {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "8470734036344552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001728_8470734039677885_953160153654568979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ip1epu_1vSwQ7kNvgGNRzmB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYBRz3ldTHZhxB0WScG747pUoTymZ8W-LriESzkQyf3Oeg&oe=66F29510"}, {"file_name": "vlcsnap-2024-09-06-18h32m26s611.png", "id": "547154881166687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036703_547154884500020_1057514946239049650_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CZk_98CYdBUQ7kNvgH7touT&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYBefuqf0Ec5N2lBYBJ2rF23hzkX_RbP1IaTgumt3tRqvw&oe=66F2BC5C"}, {"file_name": "SSVR_Screenshot_5.png", "id": "844024577847278", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031335_844024584513944_2157433220101409974_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=usp2TfwmRrYQ7kNvgG-SyRv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYBgxMOSx__iJSJlGV2m79Lmx0bif0u4HpPcfg7hvl9uiA&oe=66F2AE0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "774542061350006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_774542064683339_1442673231097597450_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AoSOM9nrwicQ7kNvgHal_zv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArJrQSJ2a-v6J6KV8Bi_C3z&oh=00_AYD5_qsXmhQ0ZW9N3idXWy_veNxB9TpDvoYBP7NJbcqpuA&oe=66F29A34"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "SkyStrikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in SkyStrikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "SkyStrikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://cham