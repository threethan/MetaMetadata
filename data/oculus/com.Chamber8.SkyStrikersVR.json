00_AYBtwOdTHGQ5EOnz8jYzZg4lR_LjOic8zH48agaRUD-hdA&oe=66E57791"}, {"file_name": "4.png", "id": "691854536074443", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031380_691854542741109_9014558749420272728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-splbgx-cnsQ7kNvgFZH-KL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuoW29KrXY2Vw25tQivYjoW&oh=00_AYAKNwktPQs3QT4EgwMC_iZuNbgOKXsFjaaPDNKFCsz-VQ&oe=66E56DBC"}, {"file_name": "2.png", "id": "242166038325417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031308_242166044992083_2078288526299866743_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffdlS8OBytQQ7kNvgGhHOqW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuoW29KrXY2Vw25tQivYjoW&oh=00_AYBsUxyecth9B0wk_XsIc6-8xtfNb0bQEyj8Vm4VDSmdsg&oe=66E55EF6"}, {"file_name": "3.png", "id": "3520226214920033", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_3520226218253366_4154317622672811193_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ro1Bx4WGP3AQ7kNvgFx3Z8Y&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuoW29KrXY2Vw25tQivYjoW&oh=00_AYAdZW6FMDIuNOs2DRsvh8F0yRCHLo91_oxgYF1GDQmy8g&oe=66E576F9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SkyStrikers_Trailer_v2.3_cover_2560x1440.png", "id": "776048423875244", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250454_776048427208577_2761780277987214305_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qtK8Qoa7Xi8Q7kNvgGgQIUm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuoW29KrXY2Vw25tQivYjoW&oh=00_AYATUZwGyTPY0U2QmvloHjNrqpXgwiO-dDWobzdiAWpLLg&oe=66E58513"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "Sky Strikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in Sky Strikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "Sky Strikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://chamber-8.com/privacy.txt", "developer_terms_of_service_url": null, "publisher_name": "Chamber8 Studio", "support_website_url": null, "website_url": "http://chamber-8.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "729820595179114"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "579442944189420"}]}, "baseline_offer": {"id": "579442944189420"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1684378800, "status": "PUBLISHED", "id": "579442944189420"}]}, "liveCh