_2800x1440.png", "id": "244834198114433", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001731_244834201447766_6675510070487884968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fLoOtz3q3HQQ7kNvgEBCo-g&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYCSeWfkU3Gl4hqZFR4_T7lXxARyOrcJRZiW8H7M69XuUg&oe=66ED69B9"}]}, "id": "502012282758934", "locale": "en_US", "screenshots": [{"file_name": "SSVR_Screenshot_1.png", "id": "1682746182296031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974452_1682746185629364_4974977310978005522_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mxyeyabW4TgQ7kNvgFwqhLy&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYDyqoS4_HnqqGfu59bil4oSAzuaFoi6a5UV3HWFNlN_Bg&oe=66ED63A7"}, {"file_name": "SSVR_Screenshot_2.png", "id": "331489900048323", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974688_331489903381656_1826260269304134480_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eti5MqpkkLUQ7kNvgEbfZmZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYD4hZLN_OuRoU2FfVaiNTVI2d7Ris_rwXY6-vrBbjKjHw&oe=66ED56CE"}, {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "8470734036344552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001728_8470734039677885_953160153654568979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sL4W-nQD6m4Q7kNvgHWq0Sl&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYBc0LIAAs6Sd67lDEvtM4INPHdfyJT6oOlpxqIfmsGt6w&oe=66ED4F10"}, {"file_name": "vlcsnap-2024-09-06-18h32m26s611.png", "id": "547154881166687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036703_547154884500020_1057514946239049650_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8rGYZuH7iiwQ7kNvgGrkh_5&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYBK8yxf5BE7JwDAw51SjDedTuISw2yycm-kODbS6mkvKw&oe=66ED765C"}, {"file_name": "SSVR_Screenshot_5.png", "id": "844024577847278", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031335_844024584513944_2157433220101409974_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EI-lQcw2We0Q7kNvgGwdFGc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYBTOgbviefWkxB5GyTb0EZW5b8uDjkkDr_TZK6tP_EO5Q&oe=66ED680A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "774542061350006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_774542064683339_1442673231097597450_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eVdS5fVZZTMQ7kNvgEYquL9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYCQqEclq1RxI635QaEMUU1Eotz52Yl8yTSMbXxmJw5zig&oe=66ED5434"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "SkyStrikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in SkyStrikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "SkyStrikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chamber8.gg/#/privacy", "developer_terms_of_service_url": null, "publisher_name": "Chamber8 Studio", "support_website_url": null, "website_url": "https://chamber8.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8898644736830928"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036637_249611497534397_6122488536859775553_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=85gKMIJQchMQ7kNvgF6kxz8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADlS2yg9wjI1qAPM7UEpCNN&oh=00_AYA_hRtJRL71G1Poz9CCwgR5JuPK5B1AXf9xO22wlRrMpw&oe=66ED5DF3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sky Strikers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1684378800, "lastRevision": {"nodes": [{"id": "6538347472860678", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6538347462860679", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_c