 "id": "691854536074443", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031380_691854542741109_9014558749420272728_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-fyEVvjoBtQQ7kNvgEbcvDW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCwthtSjqeheIMfhdCpIoWHdQQ4Fl13Rs0m3LrHnWdJFg&oe=676A953C"}, {"file_name": "2.png", "id": "242166038325417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031308_242166044992083_2078288526299866743_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qvUrWxLnYjQQ7kNvgELq1p9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkfe5Xrwgxyq2Tqz970w6sU_IxMG-h-NrOAfOZpTIB5Q&oe=676A8676"}, {"file_name": "3.png", "id": "3520226214920033", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_3520226218253366_4154317622672811193_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GT_-kl1Is24Q7kNvgHWqxjN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwQ55Ev7h69rLB7NpOhf4ksUaBexa8FfU_4jfmGJ9Jpw&oe=676A9E79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SkyStrikers_Trailer_v2.3_cover_2560x1440.png", "id": "776048423875244", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75250454_776048427208577_2761780277987214305_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wF3CaNbzHFcQ7kNvgFtB-kK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFQ9uQE_7Hjg-33YxBsf0A6tuQWUbCyp85HdGp9NcDmA&oe=676AAC93"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "Sky Strikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in Sky Strikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "Sky Strikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://chamber-8.com/privacy.txt", "developer_terms_of_service_url": null, "publisher_name": "Chamber8 Studio", "support_website_url": null, "website_url": "http://chamber-8.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "729820595179114"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "579442944189420"}]}, "baseline_offer": {"id": "579442944189420"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729785000, "status": "PUBLISHED", "id": "579442944189420"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9570992529596142", "version": "24.4.73"}, "id": "1228983