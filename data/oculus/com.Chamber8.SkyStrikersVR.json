_2800x1440.png", "id": "244834198114433", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001731_244834201447766_6675510070487884968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KDq2EQ-1OmkQ7kNvgEbAQCv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYBE51_QUwqFjE63eyTlERAOW9FqyBPS-4Ga0s0pEVlrrw&oe=66F552B9"}]}, "id": "502012282758934", "locale": "en_US", "screenshots": [{"file_name": "SSVR_Screenshot_1.png", "id": "1682746182296031", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974452_1682746185629364_4974977310978005522_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xXn3Sna78X4Q7kNvgF_Juci&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYA_AnJSCz67m12ZmLEt7ya3X4AeB_djPOTdk4PrtRDI3g&oe=66F54CA7"}, {"file_name": "SSVR_Screenshot_2.png", "id": "331489900048323", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974688_331489903381656_1826260269304134480_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KsCLasgKl9cQ7kNvgHRxNKm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYD9v2-5Uv3l8oR00MPcPnGHnvMBWomQO0ue88WKXZeCBg&oe=66F53FCE"}, {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "8470734036344552", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001728_8470734039677885_953160153654568979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ip1epu_1vSwQ7kNvgFIFhgb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYCqZyxr2wKlsTPVdzz_aRgiyX3ohGHnZ9c78ISXSQR8Xw&oe=66F53810"}, {"file_name": "vlcsnap-2024-09-06-18h32m26s611.png", "id": "547154881166687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036703_547154884500020_1057514946239049650_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GULL8xiL28cQ7kNvgG30Liq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYAQpY4oEtJpQpqYHK2hiSoi4JiCphSXQ2siP1zBX6fM6w&oe=66F55F5C"}, {"file_name": "SSVR_Screenshot_5.png", "id": "844024577847278", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031335_844024584513944_2157433220101409974_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=usp2TfwmRrYQ7kNvgEqZAsf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYCitnCyI2QvqOA9mZfBc_MEWUr6e0HWaNYxFiQoqpiEDQ&oe=66F5510A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "774542061350006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982495_774542064683339_1442673231097597450_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1FLJcZfcQOoQ7kNvgGbZPM1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYALaz5M3A78pz7c_82uBfpOJacY5HpLKlshsj0NnE65rA&oe=66F53D34"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "SkyStrikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in SkyStrikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "SkyStrikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chamber8.gg/#/privacy", "developer_terms_of_service_url": null, "publisher_name": "Chamber8 Studio", "support_website_url": null, "website_url": "https://chamber8.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8898644736830928"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036637_249611497534397_6122488536859775553_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0hyDDum9XWMQ7kNvgHlIeWM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AC-c9JGyH1o7CT0q_qL720p&oh=00_AYD-iPGC1DnOGNqsqfEOphtB8A_7wh8V16r9x7F0sAbjIQ&oe=66F546F3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sky Strikers", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1684378800, "lastRevision": {"nodes": [{"id": "6538347472860678", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6538347462860679", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_c