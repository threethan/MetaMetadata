-iad3-1.oculuscdn.com/v/t64.5771-25/39001731_244834201447766_6675510070487884968_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1d4gc7aj_wEQ7kNvgEzjqia&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrkFMaSDW_7t5pqsEHY3vbshMgMfkSI63Vjwxk7Y-rBA&oe=6703D339"}]}, "id": "505055932365046", "locale": "en_US", "screenshots": [{"file_name": "SSVR_Screenshot_1.png", "id": "1682746182296031", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974452_1682746185629364_4974977310978005522_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=idkQH5syOj4Q7kNvgEuhusa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUyjNBqQwxmpfvRQYgsafCuZrEXwLjT8yD80W6hhTdvg&oe=6703CD27"}, {"file_name": "SSVR_Screenshot_2.png", "id": "331489900048323", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974688_331489903381656_1826260269304134480_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g5mKSKEHYPEQ7kNvgE-dwTW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQjKZR7zGpscTg-9JDTIeo8u_ir1PplYqpIR0rxgAU1w&oe=6703C04E"}, {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "8470734036344552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001728_8470734039677885_953160153654568979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3-ZOcPSgbdMQ7kNvgHga356&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6x9apP-bEcwMJuWgWTEhdGb0xlQcOljkD7njaAXMh2A&oe=6703B890"}, {"file_name": "vlcsnap-2024-09-06-18h32m26s611.png", "id": "547154881166687", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036703_547154884500020_1057514946239049650_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sgmm4GQ5j_AQ7kNvgF8i0AD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlkggnylrhWrNkQVteRUNae3kiKCtpHKXEM7V3E_mfrQ&oe=6703DFDC"}, {"file_name": "SSVR_Screenshot_5.png", "id": "844024577847278", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031335_844024584513944_2157433220101409974_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QRNihv2_gDAQ7kNvgGziYnv&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6Zb7afBhhMagNS4ddj-uQqnGm_ZN-baYkN_XFkbKXGw&oe=6703D18A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2024-09-06-18h36m20s027.png", "id": "774542061350006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982495_774542064683339_1442673231097597450_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZcxJB9TP78Q7kNvgHMuGGX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAv1WUw2V5hOKdkVaetAWKp6spUz_tDK3LRyXqsVPWf9g&oe=6703BDB4"}, "display_name": "Sky Strikers", "keywords": [], "long_description": "SkyStrikers combines the thrill of sports games with the immersive experience of virtual reality. Watch the ball soar through the sky, anticipate its trajectory, and make your move. With a powerful boost from your rocket, you'll soar into the air and make your strike. Get ready to experience the ultimate \"moment\" in SkyStrikers. This is how sports games should feel in VR.\n\nPlay With Your Friends\nJoin a multiplayer lobby in Free Play mode and compete with up to 6 players in a casual, non-competitive environment. The host can select from various game rules for organized play, so you can play with your friends the way you want. The game currently doesn't have a ranking system. Imagine playing with your friends on a neighborhood court, but with a whole new level of immersion. \n\nContact Us\nJoin our Discord server to share your feedback and suggestions, or to report any issues you may encounter.", "short_description": "SkyStrikers merges sports excitement with immersive VR. Anticipate ball flight, boost with your rocket, and strike for the ultimate \"moment\" in sports gaming. Experience it for yourself!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chamber8.gg/#/privacy", "developer_terms_of_service_url": null, "publisher_name": "Chamber8 Studio", "support_website_url": null, "website_url": "https://chamber8.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_