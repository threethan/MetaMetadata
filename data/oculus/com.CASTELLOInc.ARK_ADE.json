_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAUGXcwNjCXtvfpUGrbqTUuf_3bMWVT3mh6-5agyGlZNQ&oe=67726A71"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_Landscape_2560x1440.png", "id": "1002665716930295", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566678_1002665720263628_8704289160894096720_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_uzY_MPIuwoQ7kNvgGbVa_a&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDt0G1yAvLurh5KwSPSRe5qK89QB5D31BmiJF6PVc1Mqg&oe=677294DD"}, "display_name": "ARK-ADE", "keywords": [], "long_description": "Have you ever dreamt about being inside an old Arcade Machine?\n\nInspired by the major 80\u2019s Pop Culture references, ARK-ADE harmonizes the old fast-paced Run \u2018n\u2019 Gun games with the new era of VR technology, diving you into an iconic setting to strafe enemies, protect ARK and defeat ADE.\n\nFEATURES\nChoose between Free Locomotion and Teleport Movement to enjoy the game without the risk of motion sickness\nProtect ARK from ADE\u2019s army\nMorphing weapon\nEnjoy destructible environment and covers\nCollect all the secrets and defeat ADE for good\nImmerse into the nostalgic 80\u2019s Low-poly Sci-Fi setting\nShoot to the beat of our original soundtrack", "short_description": "Have you ever dreamt about being inside an old Arcade Machine? ARK-ADE is a fast-paced VR First Person Shooter. Plunge into the retro vibes and shoot your way out through an evocative low-poly 80\u2019s Sci-Fi setting to protect ARK and defeat ADE."}]}, "developer_name": null, "developer_privacy_policy_url": "https://castelloinc.it/wp-content/uploads/2021/04/Castello-inc-Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "CASTELLO INC", "support_website_url": null, "website_url": "https://castelloinc.it/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "gen