s": [], "long_description": "Have you ever dreamt about being inside an old Arcade Machine?\n\nInspired by the major 80\u2019s Pop Culture references, ARK-ADE harmonizes the old fast-paced Run \u2018n\u2019 Gun games with the new era of VR technology, diving you into an iconic setting to strafe enemies, protect ARK and defeat ADE.\n\nFEATURES\nChoose between Free Locomotion and Teleport Movement to enjoy the game without the risk of motion sickness\nProtect ARK from ADE\u2019s army\nMorphing weapon\nEnjoy destructible environment and covers\nCollect all the secrets and defeat ADE for good\nImmerse into the nostalgic 80\u2019s Low-poly Sci-Fi setting\nShoot to the beat of our original soundtrack", "short_description": "Have you ever dreamt about being inside an old Arcade Machine? ARK-ADE is a fast-paced VR First Person Shooter. Plunge into the retro vibes and shoot your way out through an evocative low-poly 80\u2019s Sci-Fi setting to protect ARK and defeat ADE."}]}, "developer_name": null, "developer_privacy_policy_url": "https://castelloinc.it/wp-content/uploads/2021/04/Castello-inc-Privacy-Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "CASTELLO INC", "support_website_url": null, "website_url": "https://castelloinc.it/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "348695116894190"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "791625714859817"}, {"status": "PUBLI