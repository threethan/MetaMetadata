", "coaster", "shooter", "park", "free"], "long_description": "Epic Fun is a collection of theme park-inspired attractions.\n\nRoller coasters are our main attractions! There are six in total and each one has a unique theme and comes with an exclusive rail shooting game!\n\nBe sure to test your fear of heights in our freefall tower, and take a leisurely ride on our event-filled ferris wheel.\n\nCompete for the best position in the different rankings of each of the three games: Shooting, Dart and Hammer.\n\nTry a roller coaster, a moving shooting game, a free fall tower and a sledgehammer game for free.", "short_description": "Epic Fun is a VR Theme Park based attractionsEpic Fun is a collection of theme park-inspired attractions.\n\nRoller coasters are our main attractions! There are six in total and each one has a unique theme and comes with an exclusive rail shooting game!\n\nBe sure to test your fear of heights in our freefall tower, and take a leisurely ride on our event-filled ferris wheel.\n\nCompete for the best position in the different rankings of each of the three games: Shooting, Dart and Hammer."}]}, "developer_name": "B4T Games", "developer_privacy_policy_url": "http://b4t.games/pp", "developer_terms_of_service_url": "http://b4t.games/tos", "publisher_name": "B4T Games", "support_website_url": "http://fb.me/b4t.games", "website_url": "http://b4t.games/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ROLLER_COASTER", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interactio