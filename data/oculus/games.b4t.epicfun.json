2493_771491193282909_8623363074084044800_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yu2_GOGSYb0Q7kNvgFqAic9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDOUtNv7I2A2b2Gv0NbL3YtoIeYYRlwAiTSuMwdia4qVw&oe=6767EA03"}, {"file_name": "migrated_image.png", "id": "196250655010046", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982636_1419837064833297_6934363611519254528_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2T6ZK3TPyS8Q7kNvgEPiW1l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDhFGTShm1BRrOyq66Kt5c8Q00KXCqDsulKwhOlfbVIQ&oe=6767F918"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/NEtpnb", "id": "2905966889423196", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031569_2905966892756529_491074526126276608_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FFEu-FjO_NgQ7kNvgE_cSn0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEZnWI_0aIuymEx3OOKXJThAyH7ZODaZVHVtE4Q-JH_Q&oe=6767E791"}, "display_name": "Epic Fun", "keywords": ["roller", "coaster", "shooter", "park", "free"], "long_description": "Epic Fun is a collection of theme park-inspired attractions.\n\nRoller coasters are our main attractions! There are six in total and each one has a unique theme and comes with an exclusive rail shooting game!\n\nBe sure to test your fear of heights in our freefall tower, and take a leisurely ride on our event-filled ferris wheel.\n\nCompete for the best position in the different rankings of each of the three games: Shooting, Dart and Hammer.\n\nTry a roller coaster, a moving shooting game, a free fall tower and a sledgehammer game for free.", "short_description": "Epic Fun is a VR Theme Park based attractionsEpic Fun is a collection of theme park-inspired attractions.\n\nRoller coasters are our main attractions! There are six in total and each one has a unique theme and comes with an exclusive rail shooting game!\n\nBe sure to test your fear of heights in our freefall tower, and take a leisurely 