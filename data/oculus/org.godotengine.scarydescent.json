.png", "id": "3656800017907206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982516_3656800021240539_5008511035473175295_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-pd0-OEuC8Q7kNvgH24ZJ6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBt83-Rj74SZeokIXC4oJRfPohoOTfZLxxXq0zP2Hcf8w&oe=670E4634"}, "display_name": "Scary Descent", "keywords": [], "long_description": "As you descend deeper into the darkness, uncover the grim secrets of the company's past and confront the malevolent entities that still haunt its corridors. Time is of the essence, for every moment spent in the abyss brings you closer to an inevitable confrontation with unspeakable terror", "short_description": "WARNING: FLASHING LIGHTS AND INTENSE JUMPSCARES\n\nArmed only with your wits and a flickering flashlight, you'll navigate through eerie corridors, dimly lit offices, and long-forgotten research labs, each holding fragments of the company's dark history.\n\nTHANK YOU ALL FOR TRYING MY GAME. As promised I am working on bringing multiplayer. Expect it to take a week to a month, i am a solo dev.\n\nThis game is still under development im open to suggestions\ntrevorblythe82@gmail.com"}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/TrevorBlythe/ScaryDescentPrivacyPolicy/blob/main/README.md", "developer_terms_of_service_url": null, "publisher_name": "Trevor Blythe", "support_website_url": null, "website_url": "https://sidequestvr.com/app/34104/scary-descent", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS