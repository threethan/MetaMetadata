JBUI6YkjnUQ7kNvgEygOq-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_pfapuvp4Qfn7TVzfHR8N6Cf7bbJm4YL70XzTVQhwfw&oe=673B16FE"}, {"file_name": "Customization-Texans-Tee_V2_2560x1440(24-Bit).png", "id": "1173568540419211", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974643_1173568543752544_3323716229641737128_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kKcxulWLGm4Q7kNvgEJqWSP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBE2MXpqIuHW6rgELqIjd_ZhKhf5_l0NSgXJT4sdjE5YA&oe=673B2963"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "STOREFRONT_24BIT_16x9_OFFICIAL-LAUNCH-TRAILER-Thumbnail_2560X1440.png", "id": "1457380538313902", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974864_1457380544980568_8735745560737692089_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zY4m5haPEHAQ7kNvgEsN5TW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9k3w9jOipBwQI8Qn60rHuSx9dX-wkBq2iQBmgrELTzw&oe=673B2AB5"}, "display_name": "NFL PRO ERA", "keywords": ["NFL", "FOOTBALL", "NFLPROERA", "STATUSPRO", "SPORTS"], "long_description": "Step onto the field and begin your legacy in the latest NFL and NFLPA-licensed VR experience, NFL PRO ERA. This season, you\u2019re not only running the offense as a quarterback but also showcasing your skills on defense by calling plays and filling gaps as a linebacker in single-player mode. This year brings a new level of immersion, putting you inside the rush of an NFL game like never before. In the huddle, your teammates are locked in on you, responding to your play calls and reacting to your leadership style. This year, every play feels different with an active atmosphere. When it\u2019s 4th and goal, you feel the magnitude of the moment as the intensity rises and the stadium comes to life. Off the field, Freeplay is revamped and reloaded with mini-games designed to sharpen your skill set on both offense and defense.\n\nMore personal than ever, NFL PRO ERA lets you customize your avatar\u2019s movements and appearance on the field, lacing them up in gear that will stand out from the crowd. Taking inspiration from the best facilities in the NFL, the state-of-the-art sports complex is your place to check out the hardware you\u2019ve collected over the years and catch up with online friends. With an updated DLC model delivering new gear, stadiums, and gameplay modes, NFL PRO ERA brings more to your headset throughout the season. \n\nThis year, the game has changed. Are you ready to make this your era?", "short_description": "Rewrite the game and leave your legacy in the latest NFL and NFLPA-licensed VR experience, NFL PRO ERA. This season, take control as a linebacker in single-player mode, calling plays and dominating the field. Customize your avatar's movements and appearance, standing out with unique gear. Feel the intensity with situational awareness on every play. Off the field, sharpen your skills in revamped mini-games and explore the state-of-the-art sports complex. The game has changed. This era is yours."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.status.pro/privacy-policy", "developer_terms_of_service_url": "https://status.pro/terms-of-service", "publisher_name": "StatusPRO, Inc.", "support_website_url": null, "website_url": "https://www.proera.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracki