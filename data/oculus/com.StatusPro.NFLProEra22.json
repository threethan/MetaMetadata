A&oe=67092877"}, {"file_name": "PE22_Sceenshot200720_03.png", "id": "297653548434707", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974631_297653555101373_8390093107327459085_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o8fvqpQT-JMQ7kNvgEL2Lk2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB8CXJUo4AO74czb2Iv86ryx8J_m7Bg-E7H6d7Cd2rIpg&oe=6709003D"}, {"file_name": "PE22_Sceenshot200720_02.png", "id": "4096020187110797", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974594_4096020190444130_3213418019965990784_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lcx3lRbrP_cQ7kNvgEfQkRm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwzjnekXV5JscAWyAlTlbeslk3MvSRb_kKBfo-wDdqvQ&oe=67092525"}, {"file_name": "PE22_Sceenshot200720_05.png", "id": "172517161562237", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974602_172517164895570_1635706975153396871_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ivFzwcD3fUQ7kNvgFYEwDe&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCSwFEkQPbTubA9wF10QTvdDkuv-RVtaHXWvNRLCvtJHw&oe=670908D7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "ProERA'22", "keywords": ["NFL", "FOOTBALL", "NFLPROERA", "STATUSPRO", "SPORTS"], "long_description": "NFL PRO ERA is the first fully licensed NFL virtual reality (VR) simulation game that lets players experience what it\u2019s like to compete as the QB of their favorite NFL team. Coming this fall and utilizing real-time NFL game data, NFL PRO ERA is one of the most authentic and immersive first-person VR football games ever to come to market. Athletes will be able to step under center and see if they have what it takes to compete at the highest level and make the big plays. \nLead your team to a Super Bowl, improve your QB skills by participating in drills, or play catch virtually with your friends in your favorite NFL stadium.  As a NFL QB you\u2019ll feel the excitement of what it\u2019s like to lead your team and compete under the bright lights with thousands of screaming fans. \nDeveloped by StatusPRO, Inc., a company founded by athletes with a mission to democratize the professional athlete experience, NFL PRO ERA brings fans closer to the gridiron than they've ever been before.\n", "short_description": "NFL PRO ERA is the first fully licensed NFL virtual reality (VR) simulation game that lets players experience what it\u2019s like to compete as the QB of their favorite NFL team. \nLead your team to a Super Bowl, improve your QB skills by participating in drills, or play catch virtually with your friends in your favorite NFL stadium.  As a NFL QB you\u2019ll feel the excitement of what it\u2019s like to  compete under the bright lights with thousands of screaming fans."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sp-privacy-policy.s3.amazonaws.com/StatusPro-Privacy_Policy-April+2022.pdf", "developer_terms_of_service_url": null, "publisher_name": "StatusPRO, Inc.", "support_website_url": null, "website_url": "https://www.status.pro/#status-pro", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1658099997857536"}}]}, "scheduled_offers": {"count": 17, "nodes": [{"status": "CANCELLED", "id": "1681181136004351"}, {"status": "CANCELLED", "id": "1950232618812143"}, {"status": "PUBLISHED", "id": "12164