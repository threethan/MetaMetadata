36064_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z3D9KtJJa4cQ7kNvgHiBa64&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTen-10QAq9zUBwCAN0PJwDRJedJxbbLmbay3hW1l5cQ&oe=67542302"}, {"file_name": "migrated_image.png", "id": "642612559910664", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974484_2437156973170661_3039945738638327808_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b1fi9isuCRcQ7kNvgH7WnrM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9gBUEOjAevGb_W7kWo06Pu-pE987JxislGzywQPyg7w&oe=67542C76"}, {"file_name": "migrated_image.png", "id": "1258136861058540", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031555_528605850876405_541850355349061632_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WnFYctvNTDAQ7kNvgHaCiqB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXHZZlCtNLia9Ce8mKgMU9Y7UZU9VnQdtphubauj_Whg&oe=675450EA"}, {"file_name": "migrated_image.png", "id": "939446689806922", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974525_1147190902108007_3658820401091313664_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=64_e8ilbyHkQ7kNvgHyHTrM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVp-HUpgdFaMNrIxoPbB5JF_I76aoGPjDzEG_l9jje_w&oe=67544A2C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/0pEXF2", "id": "348908762445652", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974522_348908765778985_6388749069522567168_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NegWlP6tOHIQ7kNvgEbe8Ia&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2Sn_OhmW7gqo_FL95NuWcbe_wi6rHMIxjT551a232aw&oe=67545189"}, "display_name": "Racket: Nx", "keywords": ["racket", "sports", "arcade", "space", "action"], "long_description": "Racquetball meets Breakout inside a giant pinball machine! \n\nRacket: Nx is a new kind of game that challenges the limits of what you can do with a racket and ball in VR. \n\nThe game is played inside a giant glass dome, the walls of which light up with targets you must destroy with the ball.\nBut this is no ordinary ball. \nHit it with force and it will slam into the wall, rolling across it and bulldozing everything in its path. \nUse your racket's tractor beam to pull it back, or simply to line up your next shot exactly where you want it. \n\nTargets appear in Waves, and your goal is to destroy them all before your energy runs out. But targets aren't the only thing in the arena. \n\nSo be quick, accurate and smart. Plan your shots well. Learn to control the ball to perfection.", "short_description": "Racquetball meets Breakout inside a giant pinball machine! Racket: Nx is new kind of game that challenges the limits of what you can do with a racket and ball in VR."}]}, "developer_name": "One Hamsa", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "https://onehamsa.com/", "publisher_name": "One Hamsa", "support_website_url": null, "website_url": "https://racketnx.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ARCADE", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1012032726059508"}}]}, "scheduled_offers": {"count": 47, "nodes": [{"status": "PUBLISHED", "id": "449461158170782"}, {"status": "PUBLISHED", "id": "822538190088413"}, {"status": "PUBLISHED", "id": "524085436638244"}, {"status": "PUBLISHED", "id": "571384771346101"}, {"status": "