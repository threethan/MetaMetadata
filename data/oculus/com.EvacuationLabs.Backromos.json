dn.com/v/t64.5771-25/39031506_1021822482864135_1417739966399285523_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NRhfrjPhQQoQ7kNvgHnXzQ7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUFEI3NqrkJOu-jJxWGFjaZ&oh=00_AYBZ-cRSS__u07JCeYFT-_QSckOGH4kee30HbAWBO6wDPQ&oe=66EEA4E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "image_2_2560x1440.png", "id": "2698180763688730", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001664_2698180767022063_8334646456514757824_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qv6GI9FRQqYQ7kNvgEd6eSg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUFEI3NqrkJOu-jJxWGFjaZ&oh=00_AYDh3aAf0UoiAzR_tJ26eD3HrXrufOKrsG4wQXoG6Fsicg&oe=66EEB3AB"}, "display_name": "LiminalityVR", "keywords": [], "long_description": "LiminalityVR is a fan-made VR game inspired by Gorilla Tag's locomotion, but with a thrilling twist into the realm of horror. Players navigate through eerie environments filled with suspenseful moments and unexpected scares, all while utilizing the dynamic parkour mechanics reminiscent of Gorilla Tag. The game combines the adrenaline-pumping action of virtual reality with the tension and atmosphere of a horror experience, offering a unique blend of excitement and fear that keeps players on the edge of their seats. LiminalityVR aims to deliver a spine-chilling adventure that pushes the boundaries of immersive VR gaming.", "short_description": "LiminalityVR is a fan-made VR game inspired by Gorilla Tag's locomotion, but with a thrilling twist into the realm of horror. Players navigate through eerie environments filled with suspenseful moments and unexpected scares, all while utilizing the dynamic parkour mechanics reminiscent of Gorilla Tag."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/liminalityvr", "developer_terms_of_service_url": null, "publisher_name": "Nutriii", "support_website_url": null, "website_url": "https://sites.google.com/view/liminalityvr", "category": null, "comf