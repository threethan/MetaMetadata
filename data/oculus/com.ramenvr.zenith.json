Mr8enZi-SMMnbFTCOtCYlnSrAF1MSIw&oe=672CA04C"}, {"file_name": "ZenithTheLastCity_Screenshot_01.png", "id": "439053681040969", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982596_439053684374302_1112108776765823666_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=36MBOd6R9BsQ7kNvgEUkqZK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiODN997zSiwPE6kPyiOuyZfPwKv9uloXBRF9WgQRpMw&oe=672CB4DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZenithIRTrailerThumbnail 2560px.png", "id": "711772474140500", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982569_711772477473833_2942796963051377578_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPbola44vvIQ7kNvgHFmwFE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyKCSFp6Lrn8KAW_nFPIpKerjHf8HWdI1kIjaeaPgeeQ&oe=672C9D3B"}, "display_name": "Zenith: Nexus", "keywords": ["action", "adventure", "multiplayer", "social", "rpg"], "long_description": "Unleash your inner warrior, rise up as an agent of Zenith!\n\nZenith: Nexus has two action-packed game modes:\n\nInfinite Realms (Free to Play)\nParty up with friends in a free online action-adventure RPG! Slash mobs with magic and race across parkour challenges in quick session-based runs. Meet up with other players in the city to upgrade your gear or just hangout and shoot hoops before your next run. Sessions stays fresh with daily and weekly content rotations.\n\nThe Last City (DLC)\nPlay the most popular VR MMO, with hundreds of hours of content including epic boss battles and sick loot + 3 amazing classes to play. Team up with friends to tackle perilous dungeons, compete in PVP, or just explore a gorgeous anime world together.", "short_description": "Party up with friends in a free online action-adventure RPG! Slash mobs with magic and race across parkour challenges in quick session-based runs. Meet up with other players in the city to upgrade your gear or just hangout and shoot hoops before your next run. Sessions stays fresh with daily and weekly content rotations."}]}, "developer_name": null, "developer_privacy_policy_url": "https://skywave.zenithmmo.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Ramen VR", "support_website_url": "https://zenithmmo.happyfox.com/", "website_url": "https://www.zenithmmo.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "RPG"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7405317606191847"}, "review_messages": ["Approving for release on 7/27 Tuesday at 10am PST"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982618_864664542336518_2586839537252352155_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vvWMvA5lO0AQ7kNvgFa2R3i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7dkb_BlHwOUdTv94udV144X69znttOZAGGc3bttEtUw&oe=672CC199"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Zenith: Nexus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Role Playing", "id": "821934236779161"}], "release_date": 1643306354, "lastRevision": {"nodes": [{"id": "3502363176468436", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3594982710558708", "is_first_party