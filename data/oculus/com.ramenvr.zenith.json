38974653_860865207917513_1698906477247925623_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z2Z_EHYTy80Q7kNvgGpvGd2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCevYWBz3h4Hz0FTLFnB2bAbxopqK1Dxzl966el50JYJw&oe=677126E5"}, {"file_name": "ZenithTheLastCity_Screenshot_05.png", "id": "992115731370790", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031571_992115734704123_6674344783913041335_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PB7wkkqUKR0Q7kNvgGm23cH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDtLFUbhLD93FqgKOhFrRSICbgXRht-9U2VU5RTmD5LdA&oe=67714F87"}, {"file_name": "ZenithTheLastCity_Screenshot_06.png", "id": "1026246621270981", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982666_1026246624604314_4242369469662944086_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m9dX33mYvYYQ7kNvgGv73EO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCiacLCzuEjkEUQikPW2gCn0-LGoozlvYPiucabcr_3lQ&oe=67714377"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZenithTheLastCity_Trailer Cover Image (2).png", "id": "4807942282597640", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031505_4807942285930973_3488686570901783834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zKgS9pABS1MQ7kNvgFWD7yk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3Q_URfuiIN39s7rlr7-b6hnWUYKdyVLVHr_d3whs_-w&oe=67711CE4"}, "display_name": "Zenith: The Last City", "keywords": ["mmorpg", "action", "adventure", "multiplayer", "social"], "long_description": "The world of Zenith crawls with monsters that have been empowered by a dark and mysterious god -- but glory and treasures await those brave enough to unveil Zenith's mysteries.\n \nExperience action-packed combat as you battle monsters that know how to dodge your blows and respond with ferocity.  Forge alliances in guilds, join epic raids and world events, and blaze a path to become the most powerful Agent Zenith has ever known. \n\nFeatures:\n- Explore an ever expanding massive open world through flying, climbing, ziplining, and even swimming!\n- Discover a deep combat system that takes both time and practice to master -- shoot, swing, and cast your way to glory.\n- Synthesize powerful items using the spoils of battle and enhance them to become a legendary Agent.\n- Discover the joy of cooking -- learn delicious recipes, gather ingredients, and share them with your friends.\n- Play together -- conquer Zenith\u2019s greatest challenges, including epic boss battles, public events and dungeons.\n\n", "short_description": "Endless adventure awaits in Zenith, an exhilarating open-world VR MMO!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://skywave.zenithmmo.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Ramen VR", "support_website_url": "https://zenithmmo.happyfox.com/", "website_url": "https://www.zenithmmo.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "RPG"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "927856617919517"}}]}, "scheduled_offers": {"count": 32, "nodes": [{"status": "PUBLISHED", "id": "633936461365575"}, {"status": "PUBLISHED", "id": "943275356801656"}, {"status": "CANCELLED", "id": "333290222095662"}, {"status": "PUBLISHED", "id": "1323856698399754"}, {"status": "PUBLISHED", "id": "260355496220818"}, {"status": "PENDING", "id": "958460698679346"}, {