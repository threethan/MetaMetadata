00&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qf0IXv-ye78Q7kNvgF00AiX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASJLSLYIT7yyl66oCIw2AJuVf5EDlxCONjSXLmycfT8A&oe=676FDB3A"}, {"file_name": "Screenshot_VROO6.png", "id": "2169394943393371", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974513_2169394946726704_833013698734162480_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pf5EPbBMIJUQ7kNvgE03h4y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDV98M0jA2VgQ-2Isx2zcluUzW8hticUP5_YtzBDiFUw&oe=676FDD0A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover image.png", "id": "1048298189708781", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003240_1048298193042114_5639017989450219791_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EejoYHTuDygQ7kNvgHJll5K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmQWCj8iCYEgnFssJsNzKCQS2OJJBO3ISEtu07hCjx9g&oe=676FD83D"}, "display_name": "VROO 360", "keywords": [], "long_description": "VROO est une solution cl\u00e9-en-main pour pr\u00e9senter des films 360\u00b0 \u00e0 votre public sur les appareils Meta Quest. Notre agence vous accompagne dans la cr\u00e9ation d\u2019un programme VR parfait pour votre \u00e9v\u00e9nement !\n> S\u00e9lectionnez vos films dans notre catalogue. VROO offre plus de 30 exp\u00e9riences (Fiction, Documentaire, Exp\u00e9rimental, Nature & D\u00e9couverte, Enfants, etc.) ;\n> Lancer l\u2019application et t\u00e9l\u00e9chargez vos films en utilisant un code PIN;\n> Profitez de votre application VROO personnalis\u00e9e : Une interface simple et ergonomique en mode kiosque qui permet \u00e0 vos spectateurs de d\u00e9marrer les films en utilisant leur regard.\n\nPour plus d\u2019informations, contactez notre \u00e9quipe :  hello@diversioncinema.com\n\n\nVROO is a simple solution to showcase 360\u00b0 movies to your audience on Meta Quest devices. Our agency helps you build the perfect VR program for your event!\n> Choose your movies from our catalog. VROO offers more than 30 experiences (Fiction, Documentary, Experimental, Nature & Discovery, Kids, etc.);\n> Launch the application and download your movies using a pin code;\n> Enjoy your personalized VROO app: A simple and ergonomic interface in kiosk mode that allows your spectators to play the movies using their gaze. \nFor more information, contact our team: hello@diversioncinema.com", "short_description": "Pr\u00e9sentez des films 360\u00b0 \u00e0 votre publique en toute simplicit\u00e9 !\nThe easiest way to showcase 360 VR movies to your audience!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vroo.io/Legal-Notice", "developer_terms_of_service_url": null, "publisher_name": "Diversion cinema", "support_website_url": null, "website_url": "https://www.diversioncinema.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24227285436919426"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982470_1409175136359750_2053770576100173681_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pBsgPsspH7YQ7kNvgGWenKH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDE_AGMNpjwsUrURjSnckvnSaaJcQio5JdZ3vrzNRM5pQ&oe=676FCB63"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VROO 360", "platform": "ANDROID_6DOF", "context_catego