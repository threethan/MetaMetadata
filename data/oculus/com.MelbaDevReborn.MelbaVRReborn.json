_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GhwHsZpR6A4Q7kNvgETZ5qp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwksws21ViMfT8rYn1KaXfj83Uxso9Vih2XyHAECdvug&oe=67641033"}, "display_name": "MelbaVR Reborn", "keywords": [], "long_description": "MelbaVR Reborn invites you into a stunning virtual jungle where you embody a powerful gorilla fighting against human threats. With captivating VR graphics and intuitive controls, swing through trees, roar defiantly, and navigate perilous challenges. Explore a rich narrative, forge alliances, and confront moral dilemmas. Whether a VR enthusiast or novice, experience adrenaline-pumping gameplay and endless adventure. Answer the call of the wild and become the jungle's hero in MelbaVR Reborn.", "short_description": "Immerse yourself in the world of MelbaVR Reborn, a thrilling virtual reality adventure where you become a mighty gorilla fighting to save your jungle home from human encroachment. Unleash your primal power in this epic VR experience"}]}, "developer_name": "mmo0nVR", "developer_privacy_policy_url": "https://sites.google.com/view/melbavrrebornpolicy/home", "developer_terms_of_service_url": null, "publisher_name": "mmo0nVR", "support_website_url": "https://sites.google.com/view/melbavrrebornpolicy?usp=sharing", "website_url": "https://sites.google.com/view/melbareborn?usp=sharing", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interacti