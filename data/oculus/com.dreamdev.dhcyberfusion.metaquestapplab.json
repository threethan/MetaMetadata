641864_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFhrNZw6pWgQ7kNvgGnr8fj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC6Hu-sdnl6pFSowflgvIG3jpe-mUvqGnQnP15AQ9l0Dw&oe=674EF42F"}, {"file_name": "Screen2.png", "id": "808727554646613", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974861_808727557979946_6826512932184847798_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X4tQtyYELKsQ7kNvgFWnUuO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACfD-rttcbcIQrjhV0DE9Fzpmcfbx0Xe1YHehXRnioyA&oe=674F0BF3"}, {"file_name": "Screen3.png", "id": "754288236894427", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222942_754288240227760_6722172717040299156_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfi96DmCv14Q7kNvgG02f3K&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAuAntXDfwELITesTiuBvthnC6UsZ0TI39OFu_LKtYdhA&oe=674EF7E2"}, {"file_name": "Screen4.png", "id": "961777285546337", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982690_961777288879670_7226004792964779064_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mdssRoDkiI8Q7kNvgG1O8XK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALGQfUpCVAKO5_KCIUlzxru7wLfkRg1DETHHglX0UN1Q&oe=674EFDC9"}, {"file_name": "Screen5.png", "id": "1066995201063669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75416835_1066995204397002_9084394167452956918_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sTOAPm02rDMQ7kNvgExTsAQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC7cUPvST7ggSD3veYaD_fi6FZW3jPjRcRcmygMiXo_UA&oe=674ED806"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Death Horizon: Cyberfusion", "keywords": [], "long_description": "Welcome to the year 2045 in the United States, during which the last two decades have witnessed a transformation in human life through cutting-edge technologies. \n\n*FEATURES*\n\n- Improve your abilities with various cyber implants.\n- Physics-based interactions between players, enemies and weapons.\n- Full-body player character;\n- Each game level is unique;\n- Possibility to upgrade any weapon.\n\nA groundbreaking innovation in military technology is cybernetic prosthetics \u2013 AKA turning ordinary individuals into super soldiers, greatly enhancing their battlefield effectiveness.\n\nYet in truth, the most powerful prostheses are linked to the lab's global artificial intelligence, aiding soldiers in utilizing their enhanced capabilities on the battlefield and assisting scientists with their goal of developing new prosthetic technologies.\n\nUnfortunately, playing \u201cGod\u201d has consequences. Problems arise within Horizon Lab when the lab's AI goes rogue, seizing control of all implant wearers it can influence, essentially turning them into obedient zombies!\n\nThe company's board of directors chooses to conceal the fact that they've lost control of the laboratory from all customers. Consequently, the lab continues to operate and produce prosthetics, with the only question being how to retrieve them.\n\nTo address this challenge, the company hires \"team managers,\" unskilled employees dispatched to the lab to collect prosthetics, akin to mushroom foraging.\n\nCongratulations, you are now a new team manager. Welcome aboard!", "short_description": "Roguelike, physics-based, full-body FPS with randomly generated levels. \n\nOne impressive standout feature of the game is each player's ability to customize specific body parts (such as hands) to gain unique skills within the game itself.\n\n*FEATURES*\n\n- Improve your abilities with various cyber implants.\n- Physics-based interactions between players, enemies, weapons, and the game environment.\n- Full-body player character;\n- Each game level is unique;\n- Possibility to upgrade any weapon."}]}, "developer_name": null, "developer_privacy_policy_url": "https://deathhorizon.com/privacy-policy/", "developer_terms_of_service_url": "https://deathhorizon.com/terms-of-use/", "publisher_name