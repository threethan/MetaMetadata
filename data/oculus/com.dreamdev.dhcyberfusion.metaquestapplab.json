le_name": "Screen2.png", "id": "808727554646613", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974861_808727557979946_6826512932184847798_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UvinR9xIg5gQ7kNvgEmExiv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiXxa5VTmtq80e5C6792G4jejG3ds8YGVgWGStNEvw-g&oe=67487473"}, {"file_name": "Screen5.png", "id": "1066995201063669", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75416835_1066995204397002_9084394167452956918_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pqxLToBGd4oQ7kNvgGc_ahk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD-Xpna1a8987-pvTQoueo4DItqvBW5MvXOiP9AfFhpsw&oe=67484086"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440back_available_now.png", "id": "1951595098676963", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031340_1951595102010296_3176652085854675773_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XHi4YuoT-iAQ7kNvgErN6JD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_LKTepAP6wqN8D0NFGhBB0tB7hrQdkzofEdD8pQ87nA&oe=67486FA8"}, "display_name": "Death Horizon: Cyberfusion", "keywords": ["Cyberpunk", "Zombie", "Shooter", "Survival", "Physics"], "long_description": "**Step into the future** where cutting-edge technology meets human potential!\n\nAt the pinnacle of cybernetic enhancement, Horizon Lab is pioneering the fusion of human and machine to create the ultimate innovations of tomorrow.\n\n{1645450999348487}\n\n# **FEATURES:**\n\n- **Enhance Your Skills:** Equip a range of cyber implants to boost your abilities beyond human limits.\n\n- **Dynamic Combat:** Experience realistic, physics-based interactions between players, enemies, and weapons for thrilling battles.\n\n{1213468206332683}\n\n- **Full-Body Immersion:** Play as a fully-rendered character, bringing a new level of immersion.\n\n- **Diverse Levels:** Embark on a journey through a multitude of randomly generated game levels, each presenting unique challenges and surprises for players to navigate through.\n\n- **Weapon Evolution:** Upgrade any weapon to unleash its full potential and customize your arsenal to suit your playstyle.\n\n{778331741078399}\n\n**Horizon Lab invites you** to experience the future of technology, where your body becomes the ultimate tool.\n\nAre you ready to harness the power within and become a legend?\n\n**Join the revolution! Embrace the future!**", "short_description": "Step into the future where cutting-edge technology meets human potential!\n\nAt the pinnacle of cybernetic enhancement, Horizon Lab is pioneering the fusion of human and machine to create the ultimate innovations of tomorrow.\n\n*FEATURES*\n\n- Improve your abilities with various cyber implants.\n- Physics-based interactions between players, enemies, weapons, and the game environment.\n- Full-body player character;\n- Each game level is unique;\n- Possibility to upgrade any weapon.\n\nEmbrace the future!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deathhorizon.com/privacy-policy/", "developer_terms_of_service_url": "https://deathhorizon.com/terms-of-use/", "publisher_name": "Dream Dev Studio LLP", "support_website_url": null, "website_url": "https://deathhorizon.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8560650924042240"}, "rev