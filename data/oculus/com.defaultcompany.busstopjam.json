tV8JXR525QTwlu_ywkknz2Be2EchA&oe=66F53532"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss4.png", "id": "403964452719205", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251816_403964456052538_7498835160053423268_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Dqc1FAN5h8Q7kNvgH0nPaH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgZYthn-cr8ZOqucBwzZXTNhjOX2BR0oRM0tAVWhWeLQ&oe=66F55BAC"}, "display_name": "Bus Rush", "keywords": ["Puzzle", "casual", "hybridcasual", "hypercasual", "comfort"], "long_description": "Bus Rush is a vibrant and engaging puzzle game that challenges players to match passengers with the correct buses. Each passenger is color-coded, and your task is to tap on the passenger and direct them to the bus of the same color. As you progress, the game introduces more passengers, buses, and increasingly complex puzzles that test your quick thinking and problem-solving abilities.\n\nWhat starts as a simple matching game quickly turns into a brain-teasing adventure as new challenges arise. You'll need to manage the growing number of passengers and ensure each one reaches the correct bus without mistakes. The gameplay is fast-paced and addictive, offering a rewarding experience for puzzle enthusiasts.\n\nBus Rush features bright, colorful visuals and smooth controls, making it an enjoyable experience for all types of players. Whether you're looking for a quick game to pass the time or aiming to complete more difficult puzzles, Bus Rush offers plenty of content and challenge. Perfect for those who enjoy logic-based games with a twist, Bus Rush will keep you entertained as you guide passengers to their destination!", "short_description": "Bus Rush is an engaging puzzle game where players match passengers to the correct color buses. Tap on the passengers and guide them to their corresponding bus to complete each level. As the game progresses, the puzzles become more challenging, requiring quick thinking and strategic planning. With its simple mechanics and vibrant visuals, Bus Rush offers a fun and addictive experience that tests your logic and reaction skills in a fast-paced environment."}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/bush-rush", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8365459863474706"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "533173859202872"}]}, "baseline_offer": {"id": "533173859202872"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765141, "status": "PUBLISHED", "id": "533173859202872"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8293594917327868", "version": "2"}, "id": "1032643845264577", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8293446464009380", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", 