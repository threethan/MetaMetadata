02968_486484087609024_4948351600968474969_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dxmDEvvebfYQ7kNvgH0mv3d&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTn7FnWkN4pekvD6Aw-7-SMDRKcqDNUCfxJDi9TsWcKg&oe=66F53E48"}, {"file_name": "ss5.png", "id": "394508853685659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_394508857018992_7841388119865608757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F6gEatwiH3AQ7kNvgH5b-24&_nc_ht=scontent.oculuscdn.com&oh=00_AYBYWsb2B0SKH2-BDecC4jvkC-otTdSnN6pG-JeMhf7JGg&oe=66F53C6D"}, {"file_name": "ss1.png", "id": "969502661651254", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574720_969502664984587_8217661950069340269_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ACAhi-dCx9oQ7kNvgFzSziy&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-fj2qPlEBn30ptADNV39bVtIMflJUo1jXlNC06dRiAg&oe=66F54AC8"}, {"file_name": "ss3.png", "id": "484781821186171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035426_484781827852837_5789066403699868727_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NY1oxAOmNTwQ7kNvgHcp8vR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhnNrIwHnltP25r8qNE1GiA-PkU0wRsxMpDsfMKsTBjw&oe=66F53A15"}, {"file_name": "ss2.png", "id": "1045786987210476", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031518_1045786993877142_7224196659772259562_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2p_3qr_urHEQ7kNvgF8Ql0X&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0Q5pw7Q-dpPNRgtV8JXR525QTwlu_ywkknz2Be2EchA&oe=66F53532"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss4.png", "id": "403964452719205", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251816_403964456052538_7498835160053423268_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Dqc1FAN5h8Q7kNvgH0nPaH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgZYthn-cr8ZOqucBwzZXTNhjOX2BR0oRM0tAVWhWeLQ&oe=66F55BAC"}, "display_name": "Bus Rush", "keywords": ["Puzzle", "casual", "hybridcasual", "hypercasual", "comfort"], "long_description": "Bus Rush is a vibrant and engaging puzzle game that challenges players to match passengers with the correct buses. Each passenger is color-coded, and your task is to tap on the passenger and direct them to the bus of the same color. As you progress, the game introduces more passengers, buses, and increasingly complex puzzles that test your quick thinking and problem-solving abilities.\n\nWhat starts as a simple matching game quickly turns into a brain-teasing adventure as new challenges arise. You'll need to manage the growing number of passengers and ensure each one reaches the correct bus without mistakes. The gameplay is fast-paced and addictive, offering a rewarding experience for puzzle enthusiasts.\n\nBus Rush features bright, colorful visuals and smooth controls, making it an enjoyable experience for all types of players. Whether you're looking for a quick game to pass the time or aiming to complete more difficult puzzles, Bus Rush offers plenty of content and challenge. Perfect for those who enjoy logic-based games with a twist, Bus Rush will keep you entertained as you guide passengers to their destination!", "short_description": "Bus Rush is an engaging puzzle game where players match passengers to the correct color buses. Tap on the passengers and guide them to their corresponding bus to complete each level. As the game progresses, the puzzles become more challenging, requiring quick thinking and strategic planning. With its simple mechanics and vibrant visuals, Bus Rush offers a fun and addictive experience that tests your logic and reaction skills in a fast-paced environment."}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/bush-rush", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_cat