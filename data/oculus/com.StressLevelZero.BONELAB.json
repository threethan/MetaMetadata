e7a0a&_nc_ohc=s-F5UTREHPYQ7kNvgHuOkxg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrmzTNkYPm3_3lGjsobmDE62kB6Nk6BSoRD3uin2mNCg&oe=6739DE91"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tzSdR2QqzAUQ7kNvgHRObKw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoUgi-8VrlzP6DFNkrUKGcDy-pCZfGQbDCcvir4UrODg&oe=6739EB66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Lab_Quest_Landscape_004.png", "id": "805233717145179", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974736_805233720478512_5465263039459601720_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NtAQOn0tEIAQ7kNvgE2dC84&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6sT5jL2yyV0TnMVCH6ldWzy8G5qhOcKuyMvbNgex5eg&oe=6739E6B1"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate, discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n- Physics to the core: Boneworks' realistic physics systems have been fully improved and polished. Interact with the game world with consistent confidence.\n- Visceral VR combat: Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n- Be anyone you want: Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n- Layered Narrative: After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.\n\nMATURE CONTENT WARNING\n\nPlayer uses physical combat, including firearms, melee weapons, and bare hands, to fight enemies ranging from robots to humans. Enemies will exhibit blood splats on their bodies and the environment around them. Player is able to harm and kill themselves as well as be damaged and killed by their environment.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1164512577437209"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001655_477515283886048_5069769453484627912_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eK1C5nX6IkQQ7kNvgGNGbIG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAB1wNFtBjsk7Dnf_9DNMY3-Yh6JltHyVCFOw3pYuovNg&oe=6739D387"},