at=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1UHk_BD6nR0Q7kNvgH9ZtuE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTxMzs18Vy22QYP1dCOHaY8PUJY_dGmw3PUNkbSio3og&oe=66F7E46A"}, {"file_name": "LAB_Stills_Q2_001sg_00004.png", "id": "310500637820553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031643_310500641153886_7852521238477763029_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FbiH2yJTZfUQ7kNvgFrBbG9&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6_FTYqKBZ9pMfIhE607KItt4-xu3KJf75H0kO3C4rfw&oe=66F7F391"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xvrM5Yhn63oQ7kNvgGErRtG&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQ94jLqps_Kh66sYTmgdjLMx3oF1rZ6FKnId2179Oe5g&oe=66F80066"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape02.png", "id": "678227726773583", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031473_678227730106916_8073633749074926407_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aHJbo6jhcL4Q7kNvgE7tRb-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAbIhiGspXPxl36RUMseSN1QTFX-TlhvAwzz1qFrr-S2w&oe=66F7F7C5"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate. Discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n-Physics to the core. Boneworks' realistic physics systems fully improved and polished. Interact with the game world with consistent confidence.\n-Visceral VR combat. Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n-Be anyone you want. Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n-Layered Narrative. After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "705177533987367"}}]}, "scheduled_offers": {"count": 33, "nodes": [{"status": "PUBLISHED", "id": "1147344013036940"}, {"status": "PUBLISHED", "id": "974815394185185"}, {"status": "PENDING", "id": "6465859146778623"}, {"status": "PUBLISHED", "id": "254687780232408"}, {"status": "PUBLISHED", "id": "1056792825337412"}, {"status": "PUBLISHED", "id": "995995025052671"}, {"status": "PUBLISHED", "id": "156143824076583"}, {"status": "PENDING", "id": "235371275510272"}, {"stat