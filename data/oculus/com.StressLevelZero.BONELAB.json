t_BoneLab_outline.png", "id": "326554222847622", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_326554226180955_6750642091224725689_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iwsRBwpihuMQ7kNvgHwyyU7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzbpQ7pXbSoHX_V8xYrEmcyjrZM8nvGpzn2zCl7AAQig&oe=66DACEFA"}]}, "id": "677349257350812", "locale": "en_US", "screenshots": [{"file_name": "LAB_Stills_Q2_001sg_00002.png", "id": "7240420402699190", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984469_7240420406032523_1252736468771184626_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Ed5KuaZg5gQ7kNvgEAUMgn&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVtWIYeo7tFVG3oJMXc7L9sLeKRt9EmtLMI_yhBZc_sg&oe=66DB03AF"}, {"file_name": "LAB_Stills_Q2_001sg_00003.png", "id": "389127249462025", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_389127252795358_5040822551071372763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m792NTK3qOsQ7kNvgF2YHOL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBstlblPKYwiPNhVIelamTGbjoLj8CXUz7eLiZiUxP__A&oe=66DAEDA0"}, {"file_name": "LAB_Stills_Q2_001sg_00000.png", "id": "308755411392186", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982719_308755414725519_1672085077156382453_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fVrN-SN-fkoQ7kNvgF81dAG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvCsZEo3LFUihL3N8rY2WHWB1CuJAX2UpKh1EWZ9Q6Xw&oe=66DAE36A"}, {"file_name": "LAB_Stills_Q2_001sg_00004.png", "id": "310500637820553", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031643_310500641153886_7852521238477763029_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2HM963TQEuAQ7kNvgFlfXmq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpNJ305lv93vcyypB9N2PZQP5VxST5xuS4aEEryO84vA&oe=66DAF291"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fADaq8zLOYIQ7kNvgGiQROI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAo-9m7EpnqFUaU2FoZf0TezRfM2fXFVPKI2vPDGXg7Og&oe=66DAFF66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Lab_Quest_Landscape_004.png", "id": "805233717145179", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974736_805233720478512_5465263039459601720_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sf_sOZy701oQ7kNvgEiT5Wx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsIP3_K_j6Q3IWyygQlLh2w0r9KGRf5ojmKIs6QNCiBw&oe=66DAFAB1"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate, discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n- Physics to the core: Boneworks' realistic physics systems have been fully improved and polished. Interact with the game world with consistent confidence.\n- Visceral VR combat: Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n- Be anyone you want: Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n- Layered Narrative: After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.\n\nMATURE CONTENT WARNING\n\nPlayer uses physical combat, including firearms, melee weapons, and bare hands, to fight enemies ranging from robots to humans. Enemies will exhibit blood splats on their bodies and the environment around them. Player is able to harm and kill themselves as well as be damaged and killed by their environment.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1164512577437209"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001655_477515283886048_5069769453484627912_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=62kxXod2zA4Q7kNvgEHygy2&_nc_ht=scontent.oculuscdn.com&oh=00_AYDNXrZX3B7oCKjeDjwWdQIxSh9EzSLTP-zcDQM9AtFD7Q&oe=66DAE787"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BONELAB", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 16644707