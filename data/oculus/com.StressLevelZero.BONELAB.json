_389127252795358_5040822551071372763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9kKwzvbpHNwQ7kNvgGlRPXa&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCV0NyX3YiPsAD6aSBT1SgrUQqCtu1td9Yor7AdclezIg&oe=670FA9A0"}, {"file_name": "LAB_Stills_Q2_001sg_00000.png", "id": "308755411392186", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982719_308755414725519_1672085077156382453_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JvJRZvgoEyUQ7kNvgFNMsk_&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAwLn6mfG_qeDBbQg039iW94Bf6JlZCYWHex0Fqe5Yw1A&oe=670F9F6A"}, {"file_name": "LAB_Stills_Q2_001sg_00004.png", "id": "310500637820553", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031643_310500641153886_7852521238477763029_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AgtPhE5GjWEQ7kNvgEATiN-&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAdbPDir0RNhNj1h9hZkpWwPjVFn14ppdPR4WS0b473bQ&oe=670FAE91"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z5rRqc8ejR0Q7kNvgHiMkub&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDSXI54LQkRjsApTbznMt89ZM800yZVty0pvxhc92ksJQ&oe=670FBB66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape02.png", "id": "678227726773583", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031473_678227730106916_8073633749074926407_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dyC1oMilEskQ7kNvgGyWAok&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCzHvfr_gJtVaqzXuNxlzI2m2qjcsgCEO5QJpTSk0xudQ&oe=670FB2C5"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate. Discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n-Physics to the core. Boneworks' realistic physics systems fully improved and polished. Interact with the game world with consistent confidence.\n-Visceral VR combat. Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n-Be anyone you want. Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n-Layered Narrative. After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "705177533987367"}}]