t=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdsKk6jNBnn1cBMbwuvn8JdTctein7EwO9GwSJEzMUuA&oe=671E402F"}, {"file_name": "LAB_Stills_Q2_001sg_00003.png", "id": "389127249462025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974460_389127252795358_5040822551071372763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Av7d_pxXXMQ7kNvgEA2ABO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB--oUPfcb89SAsASVoUtlH5CwZJoKaqAicZSGHCkeuKQ&oe=671E2A20"}, {"file_name": "LAB_Stills_Q2_001sg_00000.png", "id": "308755411392186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982719_308755414725519_1672085077156382453_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lxdgzZH9k8Q7kNvgEtxAyF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCuukJ9oTrsyBTKuQbpk3zO7N8tZ_fy2wvUh9WDuNMKUQ&oe=671E1FEA"}, {"file_name": "LAB_Stills_Q2_001sg_00004.png", "id": "310500637820553", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031643_310500641153886_7852521238477763029_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RLORcCF6h7QQ7kNvgGnL89U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmneCvwJYoirLHHI19AtS2XV5fqqfCzG5k-s88oXeDjw&oe=671E2F11"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSvylRcsxAAQ7kNvgE_gWd_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5cfDnzDWisW_uo-3SS18XUIY9-B8vT_7eavAdG5SNIQ&oe=671E3BE6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape02.png", "id": "678227726773583", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031473_678227730106916_8073633749074926407_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aBHDZPSduFYQ7kNvgHcZQVM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqBaDY_qmjzZRBL6v9QNjllH0FeW9onYN4ZgwBiRKT8A&oe=671E3345"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate. Discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n-Physics to the core. Boneworks' realistic physics systems fully improved and polished. Interact with the game world with consistent confidence.\n-Visceral VR combat. Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n-Be anyone you want. Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n-Layered Narrative. After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memo