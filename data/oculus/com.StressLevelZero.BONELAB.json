dn.com/v/t64.5771-25/39031340_432015365359077_5946876252945148095_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FQl7q-mDaEsQ7kNvgF2u8cr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDqqp6iuKtYyQmYQ_2LtI09kUsLWo1_zJxtMSgz9KjS6Q&oe=6769341D"}, {"file_name": "Logo_Transparent_BoneLab_outline.png", "id": "326554222847622", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974493_326554226180955_6750642091224725689_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t358gOjSnh4Q7kNvgF2mSNx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASExZzO-p4AWBohFAV-wkxpmSQT4xZvWXjzN4joEJmWg&oe=6769693A"}]}, "id": "1243225793626483", "locale": "en_US", "screenshots": [{"file_name": "LAB_Stills_Q2_001sg_00002.png", "id": "7240420402699190", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984469_7240420406032523_1252736468771184626_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ipb5FAWUKgwQ7kNvgG40CtZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTvND3KJ4TIt8Fa29KAeEremdZO_jDG6dCXK_Qg-z6DQ&oe=676965AF"}, {"file_name": "LAB_Stills_Q2_001sg_00003.png", "id": "389127249462025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974460_389127252795358_5040822551071372763_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gFC8_97LslcQ7kNvgHWxhHE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPYmf4grNrN9yT9V4PixDXs_KbxAWWGtSqG5rp0J0t1w&oe=67694FA0"}, {"file_name": "LAB_Stills_Q2_001sg_00000.png", "id": "308755411392186", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982719_308755414725519_1672085077156382453_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bpSIGHU2zTwQ7kNvgHfVCy5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxRkWLzqDF7PeYP8srNoqw0yUsAdFwhuf52X_GDEWiFg&oe=6769456A"}, {"file_name": "LAB_Stills_Q2_001sg_00004.png", "id": "310500637820553", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031643_310500641153886_7852521238477763029_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GoyqJDQu9q4Q7kNvgGzSwRt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBl0fPycWM1ad7vBV4NYtyUqiVQeexrgBCgbVTFCu0eGQ&oe=67695491"}, {"file_name": "LAB_Stills_Q2_001sg_00001.png", "id": "703799244078928", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982468_703799247412261_7316423863849915105_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VLq4EVEUyboQ7kNvgE7k-Z7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYChOoZ18fJPPcqf_A8IF7mD0eWClvcpWDuoflNvT2OcWA&oe=67696166"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Lab_Quest_Landscape_004.png", "id": "805233717145179", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974736_805233720478512_5465263039459601720_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1vcXtsz-WqoQ7kNvgE7k7da&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQkcVxYXQIFTMJsobFhAcxsEeHsixtwJB5rz6ffbvfJA&oe=67695CB1"}, "display_name": "BONELAB", "keywords": ["Action", "Adventure", "Physics", "Boneworks", "Shooter"], "long_description": "Sentenced to death, you embody an outcast escaping fate, discovering a pathway to a hidden underground research facility. A series of challenging experiments and discoveries await. A road to the truth calls from the void. \n- Physics to the core: Boneworks' realistic physics systems have been fully improved and polished. Interact with the game world with consistent confidence.\n- Visceral VR combat: Using a variety of ranged, melee, and exotic physics weapons, engage enemy encounters with an entire armory at your disposal.\n- Be anyone you want: Custom avatar importing enables you to play through the game looking however you want, with physical stats to match. \n- Layered Narrative: After discovering an underground lab in MythOS city, you will have access to a variety of game locations including arenas, obstacle courses, tactical trials, sandboxes, experimental modes, and user generated levels. Collecting items, avatars, and clues from these locations enable you to progress through the mysterious story.\n\nMATURE CONTENT WARNING\n\nPlayer uses physical combat, including firearms, melee weapons, and bare hands, to fight enemies ranging from robots to humans. Enemies will exhibit blood splats on their bodies and the environment around them. Player is able to harm and kill themselves as well as be damaged and killed by their environment.", "short_description": "BONELAB is an experimental physics action game. Explore a mysterious lab filled with weapons, enemies, challenges and secrets. Escape your reality, or wreak havoc. No wrong answers. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://stresslevelzero.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Stress Level Zero", "support_website_url": null, "website_url": "http://www.stresslevelzero.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7955317117904055"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035347_553786614235318_8928231225316295918_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrdxOD2qq2sQ7kNvgHmCR-l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&