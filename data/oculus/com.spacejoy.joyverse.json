53838191249585_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XhwPP-qRJ4AQ7kNvgGJl03Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyK8vIbqVNE4xKUJQ3zKH0LPtiHp-09bNB1danq8IWSA&oe=67824235"}, {"file_name": "Virtual Assistance.png", "id": "763683188853860", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/65402515_763683192187193_5727074074602548941_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pf0Zc5UXEYoQ7kNvgHoT4Z3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYACIIEonZ0dhrSCvZROAKQcuXxohypeygHMmelM7P-Hvw&oe=6782650A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art-Landscape (7).png", "id": "647727747563638", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210401_647727750896971_7020544145163601099_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SXlzf6dh7EEQ7kNvgGWY2lE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqG3vyb29P4fDvXsgXvBIesZYFAgj5Uq5cxev4IIXOUw&oe=678256A0"}, "display_name": "Joyverse", "keywords": ["interiors", "furniture", "decor", "interiordesign", "shopping"], "long_description": "Design Your Dream Space in 3D!\nWelcome to Joyverse, the ultimate interior design experience in the Oculus Store. Powered by Spacejoy, the leading interior design platform, Joyverse is your portal to a new world of design, blending innovation, community, and immersive technology.\n\n\ufffd Design Your Actual Space:\nDesign your actual space with furniture and decor from top brands. Every detail is under your control, making design an entirely new experience.\n\n\ufffd Access Curated Designer Furniture & Decor:\nChoose from an extensive collection of real furniture and decor curated by top designers. Each piece is carefully selected to inspire your creativity and elevate your designs.\n\n\ufffd Experiment:\nExpress your inner designer with our intuitive 3D tools. Move, swap, rotate, and experiment with furniture and decor until you find the perfect arrangement. It's not just design; it's an art form.\n\n\ufffd Connect with Fellow Design Enthusiasts:\nDesign is a collaborative journey. Connect with like-minded designers and enthusiasts in a dynamic multiplayer environment. Share ideas, collaborate on projects, and be inspired by the creativity of others.\n\n\ufffd Learn & Grow with AI-Powered Assistance:\nWhether you're a novice or a design aficionado, our AI-powered Virtual Assistant is your guide.\n\n\ufffd Connect with Us:\nHave questions, feedback, or simply want to chat? Reach out to us at hello@spacejoy.com. Your insights drive our constant innovation.\n\nYour dream space is waiting to be crafted!", "short_description": "Design Your Room\nPowered by Spacejoy, pioneers in design e-commerce, Joyverse is your gateway to groundbreaking interior design in the Oculus Store.\n\n- Design Your Actual Space: Add furniture and decor in your own room in Mixed Reality.\n- Designer Furniture: Access handpicked furniture/decor from top brands.\n- AI-Driven: Learn with our AI Virtual Assistant.\n- Multiplayer Creativity: Collaborate with friends to design a space.\n\nReady to dive into design like never before? Download Joyverse Now!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.spacejoy.com/joyverse-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Neo Design Labs Inc", "support_website_url": null, "website_url": "https://www.spacejoy.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes