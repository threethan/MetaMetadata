_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBM3Yc3t2HIw0s1UUELOsCZHK50rCUpnk1Z4_Rh6czwdg&oe=674B0146"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen-01.png", "id": "1400905847283487", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203621_1400905850616820_2665291355757939808_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cirFgoeVUX8Q7kNvgELyiqV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyXqtga_YgqbDsh6eYvns0WkYMnb0TxL4o8A1E2VuSbw&oe=674AE64A"}, "display_name": "MUXR - Umme x WAR", "keywords": [], "long_description": "# MUXR - Umme x WAR\nThis app was made to provide a meaningful audience experience for the original 360 degree live music video of WAR performing their song Samsa. All efforts where driven by friendship and our mutual passion for music and extended realities.\n\n# Project Website\nwww.companion.digital/muxr-umme-war\n\n# Usage\n\nThe app will start in passthrough to teach you the basic controls, which are:\n\nOne Handed:\n- [Any Button] Select (keep pressed for grab)\n\nTwo Handed - Spell:\n- Bring your hands close together\n- Press and hold [Any Button] on both controllers\n- Move your hands apart\n\nYou may want to watch the playthrough if you require further guidance. You can find all related material on the project website.\n\n# Local Multiplayer (Requires Windows Server App)\nThis app supports local multiplayer sessions via a custom server. For the related server app and setup instructions visit the project website.", "short_description": "\"MUXR - Umme x WAR\" is an interactive (social) XR music experience accompanying the recording of a live music session"}]}, "developer_name": "Sebastian M\u00fchlhaus", "developer_privacy_policy_url": "https://www.companion.digital/privacy-policy", "developer_terms_of_service_url": "https://www.companion.digital/privacy-policy", "publisher_name": "companion.digital Inh. Sebastian M\u00fchlhaus", "support_website_url": "https://www.companion.digital/muxr-umme-war", "website_url": "https://www.companion.digital/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8238064289541325"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982488_2921922264616075_3015646385786900683_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UbzntzmL6TQQ7kNvgHTjFln&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBw0VZtQQ_fqu3aQMu5J7ScuPA8TgNJM-YImuTNM3U1Fw&oe=674AF0A9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MUXR - Umme x WAR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Media", "id": "434961926215971"}], "release_date": 1714509840, "lastRevision": {"nodes": [{"id": "8227150010632753", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8227149950632759", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1472796453308493"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "app-icon-sq.png", "id": "2921922257949409", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/389824