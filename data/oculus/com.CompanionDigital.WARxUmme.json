o_trailer": null, "video_trailer_thumbnail": {"file_name": "screen-01.png", "id": "1400905847283487", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75203621_1400905850616820_2665291355757939808_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uHYyX36W8pcQ7kNvgH5KG_e&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBatJ3AgS7xCjQZwvkZVYjx-KvxyCgn6cDUVmSHXAwlbQ&oe=670B9E4A"}, "display_name": "MUXR - Umme x WAR", "keywords": [], "long_description": "# MUXR - Umme x WAR\nThis app was made to provide a meaningful audience experience for the original 360 degree live music video of WAR performing their song Samsa. All efforts where driven by friendship and our mutual passion for music and extended realities.\n\n# Project Website\nwww.companion.digital/muxr-umme-war\n\n# Usage\n\nThe app will start in passthrough to teach you the basic controls, which are:\n\nOne Handed:\n- [Any Button] Select (keep pressed for grab)\n\nTwo Handed - Spell:\n- Bring your hands close together\n- Press and hold [Any Button] on both controllers\n- Move your hands apart\n\nYou may want to watch the playthrough if you require further guidance. You can find all related material on the project website.\n\n# Local Multiplayer (Requires Windows Server App)\nThis app supports local multiplayer sessions via a custom server. For the related server app and setup instructions visit the project website.", "short_description": "\"MUXR - Umme x WAR\" is an interactive (social) XR music experience accompanying the recording of a live music session"}]}, "developer_name": "Sebastian M\u00fchlhaus", "developer_privacy_policy_url": "https://www.companion.digital/privacy-policy", "developer_terms_of_service_url": "https://www.companion.digital/privacy-policy", "publisher_name": "companion.digital Inh. Sebastian M\u00fchlhaus", "support_website_url": "https://www.companion.digital/muxr-umme-war", "website_url": "https://www.companion.digital/", "category": null, "comfort_rating": null, "comfort_tags": [], 