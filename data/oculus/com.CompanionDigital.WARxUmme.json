59L-kHWKbnclqAVZLX1hpk1XbQ&oe=67839592"}, {"file_name": "screen-01.png", "id": "1117622622777725", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001733_1117622626111058_3805883782844647266_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lV9tBNR1SsMQ7kNvgH2-b2f&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA07m3z7r3mYuGjKx7prJXdcayOmfMLm_HO1D9_2kq4-A&oe=6783B1C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen-01.png", "id": "1400905847283487", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203621_1400905850616820_2665291355757939808_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pwek23JFkLQQ7kNvgEkHnwR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCV3Kqh3Uq1ICUNDqYCmTn_BiRu3qx894aKtGD0WJQjsQ&oe=678396CA"}, "display_name": "MUXR - Umme x WAR", "keywords": [], "long_description": "# MUXR - Umme x WAR\nMUXR - Umme x WAR\" is an interactive (social) XR music experience accompanying the recording of a live music session of the band WAR performing their song Samsa. This app was made to provide a meaningful audience experience for the original 360 degree live music video of WAR performing their song Samsa. All efforts where driven by friendship and our mutual passion for music and extended realities.\n\n# Project Website\nwww.companion.digital/muxr-umme-war\n\n# Usage\n\nThe app will start in passthrough to teach you the basic controls, which are:\n\nOne Handed:\n- [Any Button] Select (keep pressed for grab)\n\nTwo Handed - Spell:\n- Bring your hands close together\n- Press and hold [Any Button] on both controllers\n- Move your hands apart\n\nYou may want to watch the playthrough if you require further guidance. You can find all related material on the project website.\n\n# Local Multiplayer (Requires Windows Server App)\nThis app supports local multiplayer sessions via a custom server. For the related server app and setup instructions visit the project website.", "short_description": "\"MUXR - Umme x WAR\" is an interactive (social) XR music experience accompanying the recording of a live music session"}]}, "developer_name": "Sebastian M\u00fchlhaus", "developer_privacy_policy_url": "https://www.companion.digital/privacy-policy", "developer_terms_of_service_url": "https://www.companion.digital/privacy-policy", "publisher_name": "companion.digital Inh. Sebastian M\u00fchlhaus", "support_website_url": "https://www.companion.digital/muxr-umme-war", "website_url": "https://www.companion.digital/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8227149983966089"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "411620961738926"}]}, "baseline_offer": {"id": "411620961738926"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1714509840, "status": "PUBLISHED", "id": "411620961738926"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8229499590397795", "version": "1.3.1"}, "id": "1150864402729537", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8227149950632759", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8229499590397795"}, "release_sta