=6e7a0a&_nc_ohc=l_pGYDasX-oQ7kNvgHUIR-Z&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUqKRaizN91cZrhEvscoRgtxjrbitnt15_S4TDXiRHng&oe=671E2B7F"}, {"file_name": "Foto1.png", "id": "1291109828714163", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974460_1291109832047496_6644369868139321040_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FeV4Ktu0UdoQ7kNvgHD3xNd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaGlk0DGFwKCA3QwuSo0mgx53zJQun5HLMVCvolymS4w&oe=671E1084"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover 2560 x 1440.png", "id": "3093595777459974", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982477_3093595784126640_7181492309590107870_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_k2GED_66dQQ7kNvgEMEFXi&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDJX8yOGAIGCNHtM2duJp-sq1MVfqwFjI7oZHaBs6yOg&oe=671E34BE"}, "display_name": "Solar System Explorer", "keywords": ["Sun", "Space", "VR", "Solar", "Moon"], "long_description": "# Welcome to **Solar System Explorer**, an immersive educational experience designed for Meta Quest!\n\n\ud83c\udf0d **Explore the Universe Like Never Before**\n\nStep into the vastness of **space** and experience our **solar system** in stunning detail. **Solar System Explorer** lets you travel among planets, witness moons in orbit, and see the cosmic dance of celestial bodies\u2014including the **Sun**, **Earth**, and **Moon**\u2014all in real-time VR.\n\n\u2728 **Key Features**\n\n- Accurate 3D Model of the entire **solar system**\n- Orbit Simulator: Watch **planets** and **moons** move in real-time\n- Time Acceleration to reveal the dynamic motion of **planetary** bodies\n- Educational insights on the **Sun**, **planets**, **moons**, and the **solar system**\n\n\ud83c\udf93 **Engaging for Learners 10 and Up**  \nIdeal for students, educators, and space enthusiasts aged 10 and above. Whether you're curious about **space**, studying **astronomy**, or fascinated by the **Earth**, **Sun**, and **planets**, this app makes learning both engaging and interactive.\n\n\ud83d\udc68\u200d\ud83c\udfeb **Great for Educational Settings**  \nTeachers can use **Solar System Explorer** to transform lessons into virtual journeys across the **solar system**, exploring the **planets** like **Earth**, **Mars**, and more, sparking curiosity and inspiring future astronomers.\n\n\ud83d\udd2d **Coming Soon**\n\n- Detailed info panels for each **planet**\n- Quizzes and **space** challenges\n- Guided **solar system** tours", "short_description": "Explore the Universe Like Never Before\n\nStep into the vastness of space and embark on a journey that brings our solar system to life in stunning detail. Solar System Explorer lets you travel among the planets, witness the beauty of their moons, and experience the cosmic dance of celestial bodies\u2014all in real-time VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.ravit.dev/solar-system-privacy/", "developer_terms_of_service_url": "https://www.ravit.dev/solar-system-terms/", "publisher_name": "Ravit Dev", "support_website_url": null, "website_url": "https://www.ravit.dev/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8245044298957783"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75221323_9736922278