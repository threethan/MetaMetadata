ility allows you to experience in VR situations encountered at work by people with disabilities"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bienvivreledigital.orange.fr/autonomie", "developer_terms_of_service_url": "https://bienvivreledigital.orange.fr/autonomie", "publisher_name": "Orange SA", "support_website_url": null, "website_url": "https://bienvivreledigital.orange.fr/autonomie", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ar", "ru", "pl", "pt", "es", "ro", "nl", "sk"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "476058987412073"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162688_170685306812522_8804527126796566528_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bwrdHj-orwUQ7kNvgE_L8kc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALjU-w8DKDKQ0tYvdwfZp2D&oh=00_AYAYQydA8_zY01L6Srn1w3UZhsHmrNin2RaJurNwAvlJEw&oe=66EEA338"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Appility", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1504717200, "lastRevision": {"nodes": [{"id": "1950223421877055", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1465930903478165", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "150564972136374"}, "iarc_email": null, "msrp"