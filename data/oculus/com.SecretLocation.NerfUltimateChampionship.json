1875886_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yWyQqqwXBksQ7kNvgFCF_Ev&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYBnirl9iVXoFWehHvchJn-Jq5ucIn0WbKAHoPe49jXodg&oe=66D5AAC9"}, {"file_name": "S1_Socialhub_002.png", "id": "1059248428052784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1059248431386117_7247227545314486527_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Z_LbOvkmQQQ7kNvgH2rqP4&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYDSb1X7VkvlqzRk3wmiKgIvjhQLHSdJW7JB3M4Qk-y73w&oe=66D592CC"}, {"file_name": "S2_Mesa_FPS_Elimination_002.png", "id": "1102768533956589", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982570_1102768537289922_302906860161398910_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t0CVv-dZYocQ7kNvgEE9No_&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYCgh-bX4c1lkWAiOxd7QMTrW-zNNn1Sa6h2rUOjFhFjvg&oe=66D5A391"}, {"file_name": "PRO_Season1_Map_Broadcast_01.png", "id": "866202458097024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974711_866202461430357_7963220389565184709_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WdHsLgrQ6NMQ7kNvgGY7kCi&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYBfnzrDQ6xPeeW2Qxyt0H1D2hRnmwL7AtprsDMOutpbSQ&oe=66D5B2F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MA_NerfUC_S1_Banners_Landscape (1).png", "id": "786464279244548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974878_786464282577881_8676115409890534977_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDbSKx6OADkQ7kNvgFC43Zm&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYCDqFx8tujMYyYQrknoXCPEWMVGGpRvJyA1ePxlBUmunw&oe=66D5A8E6"}, "display_name": "NERF Ultimate Championship", "keywords": ["shooter", "action", "fps", "sports", "arcade"], "long_description": "IMPORTANT NOTE: GAME SALES WILL END MARCH 1ST AND GAME SERVICES WILL STOP AUGUST 31ST, 2023! \n\nSquad up and blast your way to victory in action-packed 4v4 multiplayer NERF battles! Master the unique mechanics of an ever-expanding stash of real-life NERF blasters and rule the arenas of the future by wall-running, ricocheting, and slam-firing a storm of darts down on your opponents across 5 challenging maps and 3 game modes.   \n\nFREE SEASON PASSES: Unlock original skins! A snarling shark running down the side of your blaster! How about Steampunk inspired gear?   \n\nAUTHENTIC NERF BLASTERS: Master their priming and reload mechanics, perfect your aim with unique dart physics, and storm the competition with dual-wield capabilities!   \n\nLOCOMOTION: Parkour style-movement, wall-running, and double jumping! \n", "short_description": "Squad up and blast your way to victory in action-packed 4v4 multiplayer NERF battles! Master the unique mechanics of an ever-expanding stash of real-life NERF blasters and rule the arenas of the future by wall-running, ricocheting, and slam-firing a storm of darts down on your opponents. Hone your skills in the practice facility and unlock multiple skins with FREE season passes, as you dominate your way across 5 maps and 3 game modes to become the NERF Ultimate Champion! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://secretlocation.com/privacy", "developer_terms_of_service_url": "https://secretlocation.com/eula", "publisher_name": "Secret Location Inc.", "support_website_url": "https://www.nerfvr.com/", "website_url": "https://www.nerfvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_mem