BJaz&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYCJqVfC1EqeHsRovtm2Zu4rCsWOlw-czkG3tDIQ9EoCMg&oe=66D58FCD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MA_NerfUC_KeyArt_Banners_Landscape.png", "id": "1164719054094765", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974676_1164719060761431_1861419464183408641_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LK8FlSATLLIQ7kNvgHlVReJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACAZlg_4JaD3POENxJ0S3Qe&oh=00_AYBslqFdA513pyrnwRfw87zu8M_oaqe99P7a0_L8i60ZgQ&oe=66D5A6BC"}, "display_name": "NERF Ultimate Championship", "keywords": ["shooter", "action", "fps", "sports", "arcade"], "long_description": "Squad up and blast your way to victory in action-packed 4v4 multiplayer NERF battles! Master the unique mechanics of an ever-expanding stash of real-life NERF blasters and rule the arenas of the future by wall-running, ricocheting, and slam-firing a storm of darts down on your opponents. Hone your skills in the practice facility, unlock multiple skins with FREE season passes and become the NERF Ultimate Champion! \n\nBATTLE IT OUT WITH 10 UNIQUE NERF BLASTERS, AND PLENTY MORE ON THE WAY: \n\nFREE SEASON PASSES: Unlock original skins! A snarling shark running down the side of your blaster! How about Steampunk inspired gear?  \n\nAUTHENTIC NERF BLASTERS: Master their priming and reload mechanics, perfect your aim with unique dart physics, and storm the competition with dual-wield capabilities! \n\nLOCOMOTION: Parkour style-movement, wall-running, and double jumping! \n\nINTENSE BATTLES: 4 challenging maps and 3 game modes. \n\nSOCIAL HUB: Form a party, customize your gear, and master your skills! ", "short_description": "Squad up and blast your way to victory in action-packed 4v4 multiplayer NERF battles! Master the unique mechanics of an ever-expanding stash of real-life NERF blasters and rule the arenas of the future by wall-running, ricocheting, and slam-firing a storm of darts down on your opponents. Hone your skills in the practice facility and unlock multiple skins with FREE season passes, as you dominate your way across 4 maps and 3 game modes to become the NERF Ultimate Champion! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://secretlocation.com/privacy", "developer_terms_of_service_url": "https://secretlocation.com/eula", "publisher_name": "Secret Location Inc.", "support_website_url": "https://www.nerfvr.com/", "website_url": "https://www.nerfvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "653089542708561"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8218370351537889", "version": "1.0.0.25217"}, "id": "1008226229998800", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6380416095333333", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8218370351537889"}, "release_status": "SCHEDULED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1667279679, "id": "8239282949446629", "version": "1.0.0.25215", "version_co