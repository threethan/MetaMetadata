66CB164F"}]}, "id": "1238432933839687", "locale": "en_US", "screenshots": [{"file_name": "\ub85c\ube44.png", "id": "1654349458656567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75221317_1654349461989900_6443390884144565454_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kn2Kmes4b8MQ7kNvgGKGz6J&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQSj18j5RZJXjy0PKVBrkof4Wt_YLI4q-KEw03Omf0gg&oe=66CB1DD4"}, {"file_name": "\uc5b4\ub4dc\ubca4\ucc981.png", "id": "1188942895577363", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001725_1188942898910696_8825051925609596167_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UJ6oxC5oAMIQ7kNvgHX60v4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBC6oKHsR8fQvbUGqSA2YliIP3mXuZuytz06fAnUGcseg&oe=66CB02C3"}, {"file_name": "\ud53c\ud2b83.png", "id": "1623081861846398", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_1623081865179731_5581912769610856685_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jwLwBS4nlGQQ7kNvgG0dU_S&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXKjcKNQyRsLXmknVZPMjiloC0LwFT1qpFJ0dPZ7OEvw&oe=66CB1C99"}, {"file_name": "\uba54\ub5141.png", "id": "406227885172224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974631_406227888505557_3063331170412477625_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M-chet_Rk5oQ7kNvgFfmgaB&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPQxvLxxrkvQuD7TNqy7eHKp20jggiYQHp_de7bE0_Fg&oe=66CB03A6"}, {"file_name": "\uc885\ud569\uacb0\uacfc.png", "id": "358677977037703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75520134_358677980371036_1851137502176237916_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nAShTw9EWoEQ7kNvgGp1zna&_nc_ht=scontent.oculuscdn.com&oh=00_AYCasQEaRCsMioraCWISFAfVukX7ZFbFM2Nit2ki5f8u1w&oe=66CB186D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1-1.LandScape2560x1440.png", "id": "1157659582109584", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75441573_1157659585442917_6878925975191081974_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xi276Yub47MQ7kNvgFTL1lc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVM9MADRa4UE-lyRRa54QO9XtM0yuH7gk4uTgb0qNs1Q&oe=66CB22F7"}, "display_name": "T-ON FITNESS", "keywords": [], "long_description": "# For a more realistic and immersive experience in VR!\n# Now, anytime and anywhere\n# Active Life is T-ON\n\n\u3164\n\n# Website : https://vr.tioncare.com/\n\n\n# Discord : https://discord.gg/m4MmxKqh\n\n\n\u3164\n# Episode 2 Japan Release \ud83c\udf89\n- Adventure: New scenario added\n- Fitness: New workout moves and map added\n- Meditation: New meditation and yoga moves added\n{1208344610482069}\n{890797932886928}\n{473226985446786}\n{523504060129865}\nYou can check the purchase screen after selecting Adventure Island in T-ON Fitness!\n{3877865252539751}\n\n\u3164\n# Customized workout programs you can only experience at T-ON!\n- Choose from a variety of content in three concepts, Adventure, Fitness, and Meditation to enhance your workout enjoyment with the content that suits you best!\n{471515915482331}\n\n# Adventure with T-ON Friends!\n- Adventure mode where you enjoy clearing scenarios and missions with T-ON Friends!\n\n\n- Comprising a running-focused Activity mode and a turn-based Stage mode, enjoy without boredom and boost your workout effectiveness!\n{1009916523615167}\n\n# High-intensity fitness with your personal trainer, KIKI!\n- Fitness mode enjoyed with coaching from your personal trainer, KIKI!\n- Based on the user's fitness assessment results, the six customized exercise programs for different physical factors reduce the risk of injury and make workouts more efficient!\n{1302146471170825}\n\n# Cool down meditation for the relaxation of body and mind!\n- Meditation mode combining cool-down stretches and mindfulness relaxation after workouts! \n- Embark on a journey to find peace of mind, experiencing the effects of step-by-step meditation against beautiful backdrops such as sunsets, the sea, and campfires\n{868676071769341}", "short_description": "Experience Unique Healthcare with T-ON Fitness!\nNow, enjoy T-ON Care's personalized exercise programs in VR"}, {"images": {"nodes": [{"file_name": "\uc5b4\ub4dc\ubca4\ucc98_\uc77c\ubcf82.png", "id": "1956183801523023", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003224_1956183804856356_4156409700116056171_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=py8WRfIxDakQ7kNvgEkKCfo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkZQ2BzeCNJi9ptN81UXIs9KA5LeBQQwQ0LshR_JS2EA&oe=66CB14AD"}, {"file_name": "\uc5b4\ub4dc\ubca4\ucc98_\uc77c\ubcf8.png", "id": "1616630038908222", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982676_1616630042241555_1234258292738228956_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wZb3z_mygcUQ7kNvgGXJnUj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAufWPNONfNtZrJZH2EN__nzFFAbCOpwHwqy3Fr8u41lQ&oe=66CB2C89"}, {"file_name": "\ud53c\ud2b81.png", "id": "1611526779641449", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75287553_1611526782974782_6104676734363015199_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IBuq4joCHK8Q7kNvgEOQ8we&_nc_ht=scontent.oculuscdn.com&oh=00_AYBjtynHsrEdCCytaJeWzILDf9yrVAdTvARob49cZ9Hv-Q&oe=66CB306F"}, {"file_name": "\uba54\ub5141.png", "id": "1536340803954928", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262741_1536340807288261_741120748059442881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbIJyL6k6pQQ7kNvgG0tTAR&_nc_ht=scontent.oculuscdn.com&oh=00_AYBmlc61k_AxK-ACgp3HswIQZ3h-FzBBqLaULMZx_AbwqQ&oe=66CB1486"}, {"file_name": "\uc5d0\ud53c\uc18c\ub4dc-\uc120\ud0dd.png", "id": "1228511945000610", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974463_1228511948333943_3272947843242231154_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AAeByC6ZFh0Q7kNvgFW861P&_nc_ht=scontent.oculuscdn.com