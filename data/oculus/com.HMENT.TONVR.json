450756347772348", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_450756351105681_730780254258026684_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gqNDs-I2dZQQ7kNvgHx0Lwx&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuumyu6pE7_mg4GENu8NedGqJbF_mJySElrrb5QPrieg&oe=66CB26E8"}, {"file_name": "\uc5b4\ub4dc\ubca4\ucc982.png", "id": "444129638527793", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_444129641861126_5477001723622850255_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YHbetzEI8fUQ7kNvgFZuhlR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKK3BgpIL0VT_l5T2nSYf_ZC6wDiU6n0_sznmj_SGXcA&oe=66CB26A5"}]}, "id": "506541655095577", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ud2f0\uc628 \ud53c\ud2b8\ub2c8\uc2a4", "keywords": [], "long_description": "# VR\uc5d0\uc11c \ub354 \uc2e4\uac10\ub098\uace0 \ubab0\uc785\ub418\uac8c! \n# Active Life is T-ON\n\n\u3164\n\n# \ud648\ud398\uc774\uc9c0 : https://vr.tioncare.com/\n\n\n# \ub514\uc2a4\ucf54\ub4dc : https://discord.gg/m4MmxKqh\n\u3164\n# \uc5d0\ud53c\uc18c\ub4dc 2 \uc77c\ubcf8 \ucd9c\uc2dc \ud83c\udf89\n- \uc5b4\ub4dc\ubca4\ucc98 : \uc2e0\uaddc \uc2dc\ub098\ub9ac\uc624 \ucd94\uac00\n- \ud53c\ud2b8\ub2c8\uc2a4 : \uc2e0\uaddc \uc6b4\ub3d9 \ub3d9\uc791, \ub9f5 \ucd94\uac00\n- \uba54\ub514\ud14c\uc774\uc158 : \uc2e0\uaddc \uba54\ub514\ud14c\uc774\uc158, \uc694\uac00 \ub3d9\uc791 \ucd94\uac00\n{485235490819990}\n{1956183801523023}\n{506876868545229}\n{1004071528059617}\n- \ud2f0\uc628 \ud53c\ud2b8\ub2c8\uc2a4 \uc2e4\ud589 \ud6c4 \uc5b4\ub4dc\ubca4\ucc98 \uc12c \uc120\ud0dd \uc2dc \uad6c\ub9e4\ucc3d \ud655\uc778 \uac00\ub2a5!\n{1228511945000610}\n\u3164\n# \ud2f0\uc628\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub9de\ucda4\ud615 \uc6b4\ub3d9 \ud504\ub85c\uadf8\ub7a8!\n- \uc5b4\ub4dc\ubca4\ucc98, \ud53c\ud2b8\ub2c8\uc2a4, \uba54\ub514\ud14c\uc774\uc158\uc73c\ub85c \uad6c\uc131\ub41c \uc138 \uac00\uc9c0 \ucee8\uc149\uc758 \ub2e4\uc591\ud55c \ucf58\ud150\uce20 \uc911 \ub0b4 \ub9d8\uc5d0 \uc3d9 \ub4dc\ub294 \ucf58\ud150\uce20\ub97c \uc120\ud0dd\ud558\uc5ec \uc6b4\ub3d9\uc758 \uc990\uac70\uc6c0\uc744 \ub192\uc5ec\ubcf4\uc138\uc694!\n{450756347772348}\n\n# \ud2f0\uc628\ud504\ub80c\uc988\uc640 \ud568\uaed8\ud558\ub294 \uc5b4\ub4dc\ubca4\ucc98!\n- \ud2f0\uc628\ud504\ub80c\uc988\uc640 \ud568\uaed8 \uc2dc\ub098\ub9ac\uc624\uc640 \ubbf8\uc158\uc744 \ud074\ub9ac\uc5b4\ud574 \uac00\uba70 \uc990\uae30\ub294 \uc5b4\ub4dc\ubca4\ucc98 \ubaa8\ub4dc!\n\n\n- \ub7ec\ub2dd \uc911\uc2ec\uc758 \uc561\ud2f0\ube44\ud2f0 \ubaa8\ub4dc\uc640 \ud134\uc81c \ud615\uc2dd\uc758 \uc2a4\ud14c\uc774\uc9c0 \ubaa8\ub4dc\ub85c \uad6c\uc131\ub418\uc5b4 \uc9c0\ub8e8\ud568 \uc5c6\uc774 \uc990\uae30\uace0 \uc6b4\ub3d9 \ud6a8\uacfc\ub294 UP!\n{507450124957045}\n\n# \ud37c\uc2a4\ub110 \ud2b8\ub808\uc774\ub108 \ud0a4\ud0a4\uc640 \ud568\uaed8 \uace0\uac15\ub3c4 \ud53c\ud2b8\ub2c8\uc2a4!\n- \ud37c\uc2a4\ub110 \ud2b8\ub808\uc774\ub108 \ud0a4\ud0a4\uc758 \ucf54\uce6d\uc5d0 \ub530\ub77c \uc990\uae30\ub294 \ud53c\ud2b8\ub2c8\uc2a4 \ubaa8\ub4dc! \n- \uc0ac\uc6a9\uc790\uc758 \uccb4\ub825 \uce21\uc815 \uacb0\uacfc\ub97c \ubc14\ud0d5\uc73c\ub85c \uc81c\uacf5\ub418\ub294 6\uc885 \uc2e0\uccb4 \uc694\uc778\ubcc4 \ub9de\ucda4 \uc6b4\ub3d9 \ud504\ub85c\uadf8\ub7a8\uc73c\ub85c \ubd80\uc0c1 \uc704\ud5d8\uc740 \uc904\uc774\uace0 \uc6b4\ub3d9\uc740 \ub354\uc6b1 \ud6a8\uc728\uc801\uc774\uac8c!\n{1611526779641449}\n\n# \ubab8\uacfc \ub9c8\uc74c\uc758 \uc774\uc644\uc744 \uc704\ud55c \ucfe8 \ub2e4\uc6b4 \uba54\ub514\ud14c\uc774\uc158!\n- \uc6b4\ub3d9 \ud6c4 \ucfe8 \ub2e4\uc6b4 \uc2a4\ud2b8\ub808\uce6d\uacfc \ub9c8\uc74c \uc774\uc644 \uba85\uc0c1\uc744 \uacb0\ud569\ud55c \uba54\ub514\ud14c\uc774\uc158 \ubaa8\ub4dc! \n- \ub178\uc744, \ubc14\ub2e4, \ubaa8\ub2e5\ubd88 \ub4f1 \ub2e4\uc591\ud55c \ucee8\uc149\uc758 \uc544\ub984\ub2e4\uc6b4 \uacbd\uad00\uc744 \ubc30\uacbd\uc73c\ub85c \ub