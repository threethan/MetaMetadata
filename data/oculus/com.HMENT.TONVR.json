450756347772348", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982695_450756351105681_730780254258026684_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ynyYkgG6ln0Q7kNvgHI862Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnYJHo-RYf-mVuLagXnexsHlBpLNmRo-KwpUGiNqNVmw&oe=66D70468"}, {"file_name": "\uc5b4\ub4dc\ubca4\ucc982.png", "id": "444129638527793", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974771_444129641861126_5477001723622850255_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uz06iVl2fZQQ7kNvgG3KTwc&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0eYldWp802J9mWikp9TSb7SlEcjFvL7SqXw-5dZZivg&oe=66D70425"}]}, "id": "506541655095577", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ud2f0\uc628 \ud53c\ud2b8\ub2c8\uc2a4", "keywords": [], "long_description": "# VR\uc5d0\uc11c \ub354 \uc2e4\uac10\ub098\uace0 \ubab0\uc785\ub418\uac8c! \n# Active Life is T-ON\n\n\u3164\n\n# \ud648\ud398\uc774\uc9c0 : https://vr.tioncare.com/\n\n\n# \ub514\uc2a4\ucf54\ub4dc : https://discord.gg/m4MmxKqh\n\u3164\n# \uc5d0\ud53c\uc18c\ub4dc 2 \uc77c\ubcf8 \ucd9c\uc2dc \ud83c\udf89\n- \uc5b4\ub4dc\ubca4\ucc98 : \uc2e0\uaddc \uc2dc\ub098\ub9ac\uc624 \ucd94\uac00\n- \ud53c\ud2b8\ub2c8\uc2a4 : \uc2e0\uaddc \uc6b4\ub3d9 \ub3d9\uc791, \ub9f5 \ucd94\uac00\n- \uba54\ub514\ud14c\uc774\uc158 : \uc2e0\uaddc \uba54\ub514\ud14c\uc774\uc158, \uc694\uac00 \ub3d9\uc791 \ucd94\uac00\n{485235490819990}\n{1956183801523023}\n{506876868545229}\n{1004071528059617}\n- \ud2f0\uc628 \ud53c\ud2b8\ub2c8\uc2a4 \uc2e4\ud589 \ud6c4 \uc5b4\ub4dc\ubca4\ucc98 \uc12c \uc120\ud0dd \uc2dc \uad6c\ub9e4\ucc3d \ud655\uc778 \uac00\ub2a5!\n{1228511945000610}\n\u3164\n# \ud2f0\uc628\uc5d0\uc11c\ub9cc \uacbd\ud5d8\ud560 \uc218 \uc788\ub294 \ub9de\ucda4\ud615 \uc6b4\ub3d9 \ud504\ub85c\uadf8\ub7a8!\n- \uc5b4\ub4dc\ubca4\ucc98, \ud53c\ud2b8\ub2c8\uc2a4, \uba54\ub514\ud14c\uc774\uc15