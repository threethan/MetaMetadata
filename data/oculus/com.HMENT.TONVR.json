: "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982695_1623081865179731_5581912769610856685_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k_-T3JEernEQ7kNvgHOjgVY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDDWY13xqtAzgBd9ZZ64Qal3r5u6R1cEKM2sDo9FJir-g&oe=673B2C19"}, {"file_name": "\uba54\ub5141.png", "id": "406227885172224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974631_406227888505557_3063331170412477625_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2EDlEz6i9Y0Q7kNvgEQvYJB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5MnoupAEK1mGy9dTjXypPtT_uNshiEWHRgq7IgRjsxw&oe=673B1326"}, {"file_name": "\uc885\ud569\uacb0\uacfc.png", "id": "358677977037703", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75520134_358677980371036_1851137502176237916_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SagN6Htpht0Q7kNvgG8zN_3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-3oYsyZeCUH189Dy9ssiziaFTpqBQz0S_MOez6ke3Vg&oe=673B27ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape, Cover Image 2560x1440.png", "id": "1240935830584710", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569468_1240935833918043_4774514257844889553_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9leSy8b4S94Q7kNvgEh3gwe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALLyoAIPx0o0KhtVl8ERGZ7nLzkDyWLO1rTYCnS-A5Pw&oe=673B36BD"}, "display_name": "T-ON FITNESS", "keywords": ["diet", "health", "healthcare", "sports", "fitness"], "long_description": "# Now, anytime and anywhere\n# Active Life is T-ON\n\n\u3164\n\n# Episode 3 Guam Scenario Update \ud83c\udf89\n# Episodes 1, 2, and 3 are now available together as a unified experience, with no separate DLC!\n\n\u3164\n\n# Website : https://vr.tioncare.com/\n# Discord : https://discord.gg/h7SxDcVV7k\n# Youtube : https://www.youtube.com/@official_tion\n\n\n\n\n\u3164\n# Customized workout programs you can only experience at T-ON!\n- Choose from a variety of content in three concepts, Adventure, Fitness, and Meditation to enhance your workout enjoyment with the content that suits you best!\n{471515915482331}\n\n# Adventure with T-ON Friends!\n- Adventure mode where you enjoy clearing scenarios and missions with T-ON Friends!\n\n\n- Comprising a running-focused Activity mode and a turn-based Stage mode, enjoy without boredom and boost your workout effectiveness!\n{1009916523615167}\n{3834557000192720}\n\n# High-intensity fitness with your personal trainer, KIKI!\n- Fitness mode enjoyed with coaching from your personal trainer, KIKI!\n- Based on the user's fitness assessment results, the six customized exercise programs for different physical factors reduce the risk of injury and make workouts more efficient!\n{8264305883608389}\n{473226985446786}\n\n# Cool down meditation for the relaxation of body and mind!\n- Meditation mode combining cool-down stretches and mindfulness relaxation after workouts! \n- Embark on a journey to find peace of mind, experiencing the effects of step-by-step meditation against beautiful backdrops such as sunsets, the sea, and campfires\n{868676071769341}\n\n", "short_description": "Experience Unique Healthcare with T-ON Fitness!\nNow, enjoy T-ON Care's personalized exercise programs in XR"}]}, "developer_name": "T-ON", "developer_privacy_policy_url": "https://vr.tioncare.com/en/privacy", "developer_terms_of_service_url": null, "publisher_name": "T-ON", "support_website_url": null, "website_url": "https://vr.tioncare.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["e