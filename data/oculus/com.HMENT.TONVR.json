8\uc73c\ub85c \uad6c\uc131\ub41c \uc138 \uac00\uc9c0 \ucee8\uc149\uc758 \ub2e4\uc591\ud55c \ucf58\ud150\uce20 \uc911 \ub0b4 \ub9d8\uc5d0 \uc3d9 \ub4dc\ub294 \ucf58\ud150\uce20\ub97c \uc120\ud0dd\ud558\uc5ec \uc6b4\ub3d9\uc758 \uc990\uac70\uc6c0\uc744 \ub192\uc5ec\ubcf4\uc138\uc694!\n{450756347772348}\n\n# \ud2f0\uc628\ud504\ub80c\uc988\uc640 \ud568\uaed8\ud558\ub294 \uc5b4\ub4dc\ubca4\ucc98!\n- \ud2f0\uc628\ud504\ub80c\uc988\uc640 \ud568\uaed8 \uc2dc\ub098\ub9ac\uc624\uc640 \ubbf8\uc158\uc744 \ud074\ub9ac\uc5b4\ud574 \uac00\uba70 \uc990\uae30\ub294 \uc5b4\ub4dc\ubca4\ucc98 \ubaa8\ub4dc!\n\n\n- \ub7ec\ub2dd \uc911\uc2ec\uc758 \uc561\ud2f0\ube44\ud2f0 \ubaa8\ub4dc\uc640 \ud134\uc81c \ud615\uc2dd\uc758 \uc2a4\ud14c\uc774\uc9c0 \ubaa8\ub4dc\ub85c \uad6c\uc131\ub418\uc5b4 \uc9c0\ub8e8\ud568 \uc5c6\uc774 \uc990\uae30\uace0 \uc6b4\ub3d9 \ud6a8\uacfc\ub294 UP!\n{507450124957045}\n\n# \ud37c\uc2a4\ub110 \ud2b8\ub808\uc774\ub108 \ud0a4\ud0a4\uc640 \ud568\uaed8 \uace0\uac15\ub3c4 \ud53c\ud2b8\ub2c8\uc2a4!\n- \ud37c\uc2a4\ub110 \ud2b8\ub808\uc774\ub108 \ud0a4\ud0a4\uc758 \ucf54\uce6d\uc5d0 \ub530\ub77c \uc990\uae30\ub294 \ud53c\ud2b8\ub2c8\uc2a4 \ubaa8\ub4dc! \n- \uc0ac\uc6a9\uc790\uc758 \uccb4\ub825 \uce21\uc815 \uacb0\uacfc\ub97c \ubc14\ud0d5\uc73c\ub85c \uc81c\uacf5\ub418\ub294 6\uc885 \uc2e0\uccb4 \uc694\uc778\ubcc4 \ub9de\ucda4 \uc6b4\ub3d9 \ud504\ub85c\uadf8\ub7a8\uc73c\ub85c \ubd80\uc0c1 \uc704\ud5d8\uc740 \uc904\uc774\uace0 \uc6b4\ub3d9\uc740 \ub354\uc6b1 \ud6a8\uc728\uc801\uc774\uac8c!\n{1611526779641449}\n\n# \ubab8\uacfc \ub9c8\uc74c\uc758 \uc774\uc644\uc744 \uc704\ud55c \ucfe8 \ub2e4\uc6b4 \uba54\ub514\ud14c\uc774\uc158!\n- \uc6b4\ub3d9 \ud6c4 \ucfe8 \ub2e4\uc6b4 \uc2a4\ud2b8\ub808\uce6d\uacfc \ub9c8\uc74c \uc774\uc644 \uba85\uc0c1\uc744 \uacb0\ud569\ud55c \uba54\ub514\ud14c\uc774\uc158 \ubaa8\ub4dc! \n- \ub178\uc744, \ubc14\ub2e4, \ubaa8\ub2e5\ubd88 \ub4f1 \ub2e4\uc591\ud55c \ucee8\uc149\uc758 \uc544\ub984\ub2e4\uc6b4 \uacbd\uad00\uc744 \ubc30\uacbd\uc73c\ub85c \ub