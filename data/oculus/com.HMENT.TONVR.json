189782", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974850_963874475523115_6846654992698111220_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhd-EuZVGIgQ7kNvgEmJGlv&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgOI472mkb2W049Pvi3LDmvQQeYNmky6NV0TU3Y1nsjw&oe=66DC4A4E"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-5.png", "id": "1557718724790046", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404378_1557718728123379_8855967828987972887_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ht9DOoWsPjkQ7kNvgF42Xtq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkyn44h2v7rOJyGddl9aclGbyVzy0sFEMP39PC9bO-Sw&oe=66DC3328"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-4.png", "id": "1186270412394220", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272208_1186270415727553_34814620172200406_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EmelZUr1aqQQ7kNvgE7ZkFd&_nc_ht=scontent.oculuscdn.com&oh=00_AYBM0cnu7bpCtToZFW96UwW6s90qVRVw_WZw2AYe9jVHNQ&oe=66DC4164"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-2.png", "id": "3701426626767416", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974649_3701426630100749_5875758967025126077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z_jo_7ePdyMQ7kNvgH6BtnL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCha92h00JDn43T-MbPZLc05V-7lU_Aas--iOSUpLE7BQ&oe=66DC20E8"}, "display_name": "T-ON FITNESS", "keywords": [], "long_description": "\u25aa Adventure with T-ON Care\nYour avatar syncs with you to exercise together.\nEnjoy activity modes focused on running and turn-based stage modes according to the main scenario.\n\n\u25aa Personalized Intensive Workout\nFitness\nFitness provides customized exercises by analyzing user exercise data collected through the avatar's personal training in the intensive workout mode.\n\n\u25aa Healing Your Day\nMeditation\nMeditation offers visualized meditations that enhance relaxation and restfulness of the body after exercise.\n\n\u25aa 15 Expert-Researched Exercise Movements\nThe 15 exercise movements included in the content are designed based on expert research.\n\n\u25aa Say Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\nFrom T-ON Friends' dialogues to movement guides, rich BGM, and narration add to the fun of exercising.", "short_description": "Experience Unique Healthcare at T-ON Fitness\nTry T-ON Fitness's Personalized Workout Programs\n\nExplore T-ON Fitness for a unique healthcare experience with our customized exercise programs designed just for you.\n\nMore Realistic and Immersive in VR\nActive Life is T-ON Anytime, Anywhere\n\nExperience a more realistic and immersive workout with T-ON in VR. With Active Life, T-ON is available to you anytime and anywhere.\n\nSay Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\n"}]}, "developer_name": "T-ON", "developer_privacy_policy_url": "https://vr.tioncare.com/en/privacy", "developer_terms_of_service_url": null, "publisher_name": "T-ON", "support_website_url": null, "website_url": "https://vr.tioncare.com/en", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7728012847287186"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "866107605408196"}, {"status": "PUBLISHED", "id": "3757318004513576"}]}, "baseline_offer": {"id": "866107605408196"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722469801, "status": "PUBLISHED", "id": "866107605408196"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8141339689287831", "version": "0.1.9"}, "id": "328103760094267", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8141339689287831"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.9 Version Update \ud83d\udce2\n\nHello, dear players!\nThank you for your continuous love and enjoyment of our product.\n\nIn this update, we have made the following changes:\n\n\u2022 Added User Fitness Assessment and 9 Customized Workout Programs \ud83d\udd25\nCheck your fitness level through the new assessment program!\nCollected fitness and workout data are analyzed by Well-Fit AI to provide 9 personalized workout programs tailored to different fitness goals! \n\n\u2022 Now enjoy with your family too! Multi-profile feature added.\ud83d\udc68\u200d\ud83d\udc69\u200d\ud83d\udc66\u200d\ud83d\udc66\nNow you can create up to 4 profile accounts!\nEnjoy T-ON Fitness with friends, family, and partners!\n\n\u2022 Boost the Fun of Exercise!\nClear missions and scenarios in Adventure mode,\ncollect Health Stones, and enjoy the added excitement of working out! \n\nThank you for your understanding.", "created_date": 1725007249, "id": "8141339689287831", "version": "0.1.9", "version_code": 10, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8141339689287831"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.8 Version Update \ud83d\udce2\n\nHello, dear players!\nThank you for your continuous love and enjoyment of our product.\n\nIn this update, we have made the following changes:\n\n\u25aa Bug Fix\nFix for abnormal display bug of some buttons when playing with Meta Quest 2 device\n\nThank you for your understanding.", "created_date": 1722928064, "id": "7999100296845105", "version": "0.1.8", "version_code": 9, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8141339689287831"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": null, "created_date": 1722472749, "id": "7968089189946216", "version": "0.1.7", "version_code": 8, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8141339689287831"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"chann