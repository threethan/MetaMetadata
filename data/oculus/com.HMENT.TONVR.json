ame": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-2.png", "id": "963874472189782", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974850_963874475523115_6846654992698111220_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SefjUMf5kLsQ7kNvgGhk1U3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZGaXhiBinjfZgG6rcUqzYIXDvd5-08JbkEGMFvcMUiA&oe=6738934E"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-5.png", "id": "1557718724790046", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404378_1557718728123379_8855967828987972887_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hgmbq9DVp5MQ7kNvgFuHvXy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4a-elnz5yguULaPb1-khMIADCz6o4dJZwCAhREXjwyA&oe=67387C28"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-4.png", "id": "1186270412394220", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272208_1186270415727553_34814620172200406_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h0l0tH59HaIQ7kNvgExKcAI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAH0GcmDnSZckDeogM0BzrTJJ4DBWo2D4GJk_qaaIqCMg&oe=67388A64"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-2.png", "id": "3701426626767416", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974649_3701426630100749_5875758967025126077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0aSom-RkAacQ7kNvgECnrLo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSbjKYrvvBQUHe8icKXX2YyUjqgpfSe73fJJJcpiaWjg&oe=673869E8"}, "display_name": "T-ON FITNESS", "keywords": [], "long_description": "\u25aa Adventure with T-ON Care\nYour avatar syncs with you to exercise together.\nEnjoy activity modes focused on running and turn-based stage modes according to the main scenario.\n\n\u25aa Personalized Intensive Workout\nFitness\nFitness provides customized exercises by analyzing user exercise data collected through the avatar's personal training in the intensive workout mode.\n\n\u25aa Healing Your Day\nMeditation\nMeditation offers visualized meditations that enhance relaxation and restfulness of the body after exercise.\n\n\u25aa 15 Expert-Researched Exercise Movements\nThe 15 exercise movements included in the content are designed based on expert research.\n\n\u25aa Say Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\nFrom T-ON Friends' dialogues to movement guides, rich BGM, and narration add to the fun of exercising.", "short_description": "Experience Unique Healthcare at T-ON Fitness\nTry T-ON Fitness's Personalized Workout Programs\n\nExplore T-ON Fitness for a unique healthcare experience with our customized exercise programs designed just for you.\n\nMore Realistic and Immersive in VR\nActive Life is T-ON Anytime, Anywhere\n\nExperience a more realistic and immersive workout with T-ON in VR. With Active Life, T-ON is available to you anytime and anywhere.\n\nSay Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\n"}]}, "developer_name": "T-ON", "developer_privacy_policy_url": "https://vr.tioncare.com/en/privacy", "developer_terms_of_service_url": null, "publisher_name": "T-ON", "support_website_url": null, "website_url": "https://vr.tioncare.com/en", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7728012847287186"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "2635941366598046"}, {"status": "PUBLISHED", "id": "866107605408196"}, {"status": "PUBLISHED", "id": "3757318004513576"}]}, "baseline_offer": {"id": "2635941366598046"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730447520, "status": "PUBLISHED", "id": "2635941366598046"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8684026558352472", "version": "0.1.15"}, "id": "328103760094267", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8684026558352472"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.15 Version Update \ud83d\udce2 \nHello, dear players! Thank you for your continuous love and enjoyment of our product. \nIn this update, we have made the following changes: \n\n1. Added age verification API\n\n2. Updated IARC certification", "created_date": 1731289675, "id": "8684026558352472", "version": "0.1.15", "version_code": 16, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8684024245019370"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8684026558352472"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.14 Version Update \ud83d\udce2 \nHello, dear players! Thank you for your continuous love and enjoyment of our product. \nIn this update, we have made the following changes: \n\n1. Bug fixes based on the November 1st release version\n\n2. Fitness Results UI - Workout list modification\n(Previously, the same exercise appeared 3 times in a row -> adjusted to display each exercise only once)\n\n3. Fixed issue where users who have not played after purchasing the product could not access the profile scene\n", "created_date": 1730714705, "id": "8641136035974858", "version": "0.1.14", "version_code": 15, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8641133989308396"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8684026558352472"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.13 Version Update \ud83d\udce2\n\nHello, dear players!\nThank you for your continuous love and enjoyment of our product.\n\nIn this update, we have made the following changes:\n\n1. Episode 3: Guam Update\nEpisode 3: Guam content has finally been updated! \nFrom the majestic Love's Cliff to the adventure of finding the Health Stones, \nthe Guam journey is packed with a variety of exciting challenges and missions waiting for you. \nLog in now to discover new missions and storylines!!\ud83c\udfc3\u200d\u2642\ufe0f\n\n2. DLC Integration Service Announcement\nGreat news! You no longer need to purchase Episode 2: Japan and Episode 3: Guam separately as DLC! \nBoth episodes are now integrated, allowing you to enjoy all the content with a single purchase. \nExperience the richness of our unified service!\nFor those who have already purchased, rest assured\u2014you can still enjoy both Episode 2 and Episode 3 content at no additional cost! \ud83c\udf89", "created_date": 1730445780, "id": "8620963304658798", "version": "0.1.13", "version_code": 14, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8620958237992638"}, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8684026558352472"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "\n0.1.12 Version Update \ud83d\udce2\n\nHello, dear players!\nThank you for your continuous love and enjoyment of our product.\n\nIn this update, we have made the following changes:\n\n1. The bug preventing profile selection when creating a profile in T-ON VR after signing up for the T-ON CARE app using Google login has been fixed.\nPlease delete any profiles created before this patch and create a new profile. \ud83d\ude14\n\n2. The bug causing the battle with Minji to not progress smoothly in Adventure Episode 1 - Section 1 has been fixed.\n\nWe apologize for the inconvenience and are working to resolve this as quickly as possible.\nThank you for your understanding. \ud83d\ude14", "created_date": 1727682633, "id": "8380679982020466", "version": "0.1.12", "version_code": 13, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7558892170865922", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8684026558352472"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "328103760094267"}]}, "change_log": "0.1.11 Version Update \ud83d\udce2\n\nHello, dear players!\nThank you for your continuous love and enjoyment of our product.\n\n\nIn this update, we have made the following changes:\n\n1\ufe0f\u20e3 General - Added descriptions for opening and closing the settings button when viewing the controller.\n\n2\ufe0f\u20e3 General - Improved object element rendering to match the user's field of view distance.\n\n3\ufe0f\u20e3 Lobby - Added an automatic workout mode.\n\n4\ufe0f\u20e3 Lobby - Added the option to exit T-ON Fitness.\n\n5\ufe0f\u20e3 Fitness - Improved the UI position of the fitness measurement point.\n\n6\ufe0f\u20e3 Automatic Workout Mode - Added fitness measurement.\n\nWe apologize for any inconvenience caused due to some bugs. \ud83d\ude2d\nThank you for your understanding.", "created_date": 1726205532, "id": "8227322824022850", "version": "0.1.11", "version_code": 12, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}