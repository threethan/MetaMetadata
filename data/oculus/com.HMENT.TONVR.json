189782", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974850_963874475523115_6846654992698111220_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ulkEV2IMluoQ7kNvgGLLi38&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvuPLs2DjfpRN89ZPX8FsceKxsTm-NX_LDsvInfe9vdw&oe=66D30FCE"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-5.png", "id": "1557718724790046", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404378_1557718728123379_8855967828987972887_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oaQPjF5Js0oQ7kNvgFgI0R_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbkSuUWUj-cxLqvMfrVQxRJlXKbzukfcmviuNdEIMyCg&oe=66D2F8A8"}, {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-4.png", "id": "1186270412394220", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272208_1186270415727553_34814620172200406_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3rq1-HGVbFIQ7kNvgGiwFSM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUlqZuY2M7QC3swGlE_q4WmLJkdKK8loHaa9cppUTO9w&oe=66D306E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "3.\uc2a4\ud06c\ub9b0\uc0f72560x  1440-2.png", "id": "3701426626767416", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974649_3701426630100749_5875758967025126077_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rVnBgwfmJdMQ7kNvgGN0Q7o&_nc_ht=scontent.oculuscdn.com&oh=00_AYAwS_CiGT8tjQqxZSvi7Sii_zixDFhE2hWnqnzh0L_5rg&oe=66D2E668"}, "display_name": "T-ON FITNESS", "keywords": [], "long_description": "\u25aa Adventure with T-ON Care\nYour avatar syncs with you to exercise together.\nEnjoy activity modes focused on running and turn-based stage modes according to the main scenario.\n\n\u25aa Personalized Intensive Workout\nFitness\nFitness provides customized exercises by analyzing user exercise data collected through the avatar's personal training in the intensive workout mode.\n\n\u25aa Healing Your Day\nMeditation\nMeditation offers visualized meditations that enhance relaxation and restfulness of the body after exercise.\n\n\u25aa 15 Expert-Researched Exercise Movements\nThe 15 exercise movements included in the content are designed based on expert research.\n\n\u25aa Say Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\nFrom T-ON Friends' dialogues to movement guides, rich BGM, and narration add to the fun of exercising.", "short_description": "Experience Unique Healthcare at T-ON Fitness\nTry T-ON Fitness's Personalized Workout Programs\n\nExplore T-ON Fitness for a unique healthcare experience with our customized exercise programs designed just for you.\n\nMore Realistic and Immersive in VR\nActive Life is T-ON Anytime, Anywhere\n\nExperience a more realistic and immersive workout with T-ON in VR. With Active Life, T-ON is available to you anytime and anywhere.\n\nSay Goodbye to Boring Workouts,\nFun for Everyone, Young and Old\n"}]}, "developer_name": "T-ON", "developer_privacy_policy_url": "https://vr.tioncare.com/en/privacy", "developer_terms_of_service_url": null, "publisher_name": "T-ON", "support_website_url": null, "website_url": "https://vr.tioncare.com/en", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7728012847287186"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "866107605408196"}, {"status": "PUBLISHED", "id": "3757318004513576"}]}, "baseline_offer": {"id": "866107605408196"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 172246