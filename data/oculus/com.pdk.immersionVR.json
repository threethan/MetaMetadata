 is a media reader designed specifically for the world of Virtual Reality."}]}, "developer_name": "immersionVR Studio", "developer_privacy_policy_url": "https://immersion-vr-studio.jimdosite.com/privacy-policy", "developer_terms_of_service_url": "http://www.immersionVR-reader.com/terms-of-service", "publisher_name": "immersionVR", "support_website_url": "https://immersionvr-reader.com/contact", "website_url": "http://www.immersionVR-reader.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY", "EXPERIENCE_360_NON_GAME", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "ja"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25033985352915494"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974622_500690804149989_7034695576562171904_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vhjQUXHxrhsQ7kNvgEoVgHV&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aqn0Cg4hVH8tHLsD_QkFGwQ&oh=00_AYDu5LKW4n5FXB_aiM-mpL46dPpo1adN2B3KtdXEiDuv2Q&oe=66F686F5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "immersionVR reader", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1510857000, "lastRevision": {"nodes": [{"id": "752768441552480", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1397503436990351", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "i