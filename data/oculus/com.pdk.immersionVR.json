 world without removing the VR headset.", "short_description": "immersionVR reader is an eBook reader designed specifically for the world of Virtual Reality."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.immersionVR-reader.com/privacy", "developer_terms_of_service_url": "http://www.immersionVR-reader.com/terms-of-service", "publisher_name": "immersionVR", "support_website_url": null, "website_url": "http://www.immersionVR-reader.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EDUCATIONAL", "UTILITY", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "458978375762415"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PUBLISHED", "id": "509026282817470"}, {"status": "PUBLISHED", "id": "508638053009902"}, {"status": "PUBLISHED", "id": "310584936093450"}, {"status": "CANCELLED", "id": "1860941274216535"}, {"status": "PUBLISHED", "id": "270577503968047"}, {"status": "PUBLISHED", "id": "104303003695434"}, {"status": "PUBLISHED", "id": "1708349989341687"}, {"status": "PUBLISHED", "id": "1239947789474763"}, {"status": "PUBLISHED", "id": "2055861744472337"}, {"status": "PUBLISHED", "id": "1209189612564609"}, {"status": "PUBLISHED", "id": "1587745538004759"}, {"status": "PUBLISHED", "id": "530676371185279"}, {"status": "PUBLISHED", "id": "102623513893661"}]}, "baseline_offer": {"id": "509026282817470"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1510854900, "status": "PUBLISHED", "id": "509026282817470"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "