d5\u30a9\u30f3\u30c8\u306e\u5909\u66f4\u3001\u30b3\u30f3\u30c8\u30ed\u30fc\u30eb\u30aa\u30fc\u30c7\u30a3\u30aa\u3084\u8aad\u66f8\u74b0\u5883\u306b\u5229\u7528\u53ef\u80fd\u306a\u30b3\u30f3\u30c8\u30ed\u30fc\u30eb", "short_description": "immersionVR \u30ea\u30fc\u30c0\u30fc\u306f\u3001\u30d0\u30fc\u30c1\u30e3\u30eb\u30ea\u30a2\u30ea\u30c6\u30a3\u306e\u305f\u3081\u306b\u8a2d\u8a08\u3055\u308c\u305f\u30e1\u30c7\u30a3\u30a2\u30ea\u30fc\u30c0\u30fc\u3067\u3059\u3002"}, {"images": {"nodes": []}, "id": "1076856770037234", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "immersionVR reader", "keywords": ["\u9605\u8bfb", "\u4e66", "\u6d78\u6ce1", "\u6709\u58f0\u8bfb\u7269", "\u6f2b\u753b"], "long_description": "\u6c89\u6d78\u5f0fVR\u9605\u8bfb\u56682.0\u662f\u4e13\u4e3a\u865a\u62df\u73b0\u5b9e\u8bbe\u8ba1\u7684\u5a92\u4f53\u9605\u8bfb\u5668\u3002\n\n\u6c89\u6d78\u5f0fVR\u9605\u8bfb\u5668\u5141\u8bb8\u60a8\u9605\u8bfb\u4e66\u7c4d\uff0c\u6f2b\u753b\uff0c\u56fe\u5f62\u5c0f\u8bf4\uff0c\u751a\u81f3\u542c\u6709\u58f0\u8bfb\u7269\u5728\u8bb8\u591a\u865a\u62df\u73af\u5883\u4e2d\u4e4b\u4e00\u3002\n\n\u2022 \u73b0\u5728\u652f\u6301kindle azw3\u548cmobi\uff0cepub\uff0c\u6587\u672c\u548cpdf\u683c\u5f0f\u7684\u4e66\u7c4d\uff0ccbr\u548ccbz\u683c\u5f0f\u7684\u6f2b\u753b\u6216\u56fe\u5f62\u5c0f\u8bf4\u548cmp3\u683c\u5f0f\u7684\u6709\u58f0\u8bfb\u7269\n\u2022 \u53cc\u9875\u6f2b\u753b\u3001PDF \u548c\u6587\u672c\u56fe\u4e66\u67e5\u770b\u4ee5\u53ca PDF \u5206\u8fa8\u7387\u8c03\u6574\n\u2022 \u65b0\u7684\u9605\u8bfb\u73af\u5883\n\u2022 \u5185\u5bb9\u7684\u53ef\u6392\u5e8f\u56fe\u5f62\u5e93\n\u2022 \u5bf9\u63a7\u5236\u5668\u6216\u6ce8\u89c6\u63a7\u5236\u7684\u65b0\u5b8c\u5168\u652f\u6301\n\u2022 \u7528\u4e8e\u80cc\u666f\u97f3\u9891\u7684\u65b0\u97f3\u4e50\u64ad\u653e\u5668\n\u2022 \u65b0\u7684\u53ef\u9690\u85cf\u9009\u9879\n\u2022 \u5f39\u51fa\u5185\u5bb9\u548c\u4e66\u7c4d\u56fe\u50cf\u8868\n\u2022 \u53ef\u7528\u4e8e\u7f29\u653e\u3001