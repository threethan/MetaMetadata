_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDP8shAXF7AjFX-38Wdm0p1HQycEwC6oaf_wSXKlhIC9w&oe=675AD88A"}, {"file_name": "flyingskull.png", "id": "277205357411577", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974901_277205360744910_1639449321890515552_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BtXY3B4CYmoQ7kNvgFOS-_b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBMJ-99RfftDsK_A4rZg1sXYZGuOTLHnANm1RNq-lUyuQ&oe=675ABDF6"}, {"file_name": "homebase.png", "id": "242737410566009", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982528_242737413899342_5609633577083105504_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nDG4Odi5Q2kQ7kNvgEuBTcd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdnbtnlJ1ZW_JSHZ9XBIoRJKBI4bq6A997Whx3ir7RWA&oe=675AC6B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "beta_advr_splash_2560x1440.png", "id": "305682507732462", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001725_305682511065795_8302410367893980210_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CADHzvqIovUQ7kNvgEcKdCe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB1Te4UwBHvaxQlhmLbuMFqh9azBw96w-2Uj1BDzqFMeg&oe=675ADB89"}, "display_name": "Ancient Dungeon Beta", "keywords": [], "long_description": "Grab your gear and delve into this rogue-lite dungeon crawler!\n\nThe Ancient Dungeon is known throughout the land; a place of malice and danger to all but a few brave souls. These men and women - adventurers, explorers, even scholars - enter the dungeon in pursuit of legendary fortunes and objects of immense power, all believing themselves more capable than those who have gone before...but few return.\n\nYou would follow them? So be it, but take care: the dungeon will twist and shift behind as you pass, confounding any escape. To survive, you must find a way through, for there is no way back.\n\nExplore a vast dungeon of ever-changing paths!\nSwing swords, throw knives, and shoot arrows as if you held the weapons yourself!\nUncover the lost history of the dungeon!\nClimb over deep pits, dodge lethal traps, and search for hidden treasures!\nSmash pots. Break crates. It\u2019s just good fun.!\n", "short_description": "Ancient Dungeon Beta is a rogue-lite dungeon crawler with randomly generated dungeons. Uncover its secrets and challenge powerful bosses!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://erthu.de/pp_advr.html", "developer_terms_of_service_url": null, "publisher_name": "ErThu", "support_website_url": null, "website_url": "http://erthu.de/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1074387269772008"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974717_502277224492166_4092470969978979820_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZKm5iYI7IIQ7kNvgHCW2D0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUxr2h2msI_3PUWYLWCxTKcUCovbLMNmueAmFrUekRzQ&oe=675AE22F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ancient Dungeon Beta", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "