3Q5_0inwq1xONqp10NF-SQ&oe=6767F559"}, {"file_name": "boss.png", "id": "2740805429581819", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982545_2740805432915152_6076322470190024035_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cCNgTnBQtEsQ7kNvgHOZLzc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3LHi7NeOdGlhbeTa_UHP-kDfiaNF9mzEerkbh7fIfrw&oe=6768078A"}, {"file_name": "flyingskull.png", "id": "277205357411577", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974901_277205360744910_1639449321890515552_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZOHTkFqssncQ7kNvgGryiIK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBbTyo2Tk8jqqsOAm-PrcM4y6oyDeZ1Qim4Eq-2dJa7SA&oe=6767ECF6"}, {"file_name": "homebase.png", "id": "242737410566009", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982528_242737413899342_5609633577083105504_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8D8GF1DJr5UQ7kNvgGH66dA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6ll2wqIWMArveZiwPFEcCHQDxjimuyrzZWgmKGc6P2A&oe=6767F5B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "advr_splash_2560x1440.png", "id": "742365666718584", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982545_742365670051917_4570731962930008271_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L9BUp8OrGykQ7kNvgGXDiET&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB80WlGBE3e2H9pvLENsFQ1KKyEu_HrHF3BHP_n-Mu4Lw&oe=6767FD7C"}, "display_name": "Ancient Dungeon", "keywords": [], "long_description": "Grab your gear and delve into this rogue-lite dungeon crawler!\n\nThe Ancient Dungeon is known throughout the land; a place of malice and danger to all but a few brave souls. These men and women - adventurers, explorers, even scholars - enter the dungeon in pursuit of legendary fortunes and objects of immense power, all believing themselves more capable than those who have gone before...but few return.\n\nYou would follow them? So be it, but take care: the dungeon will twist and shift behind as you pass, confounding any escape. To survive, you must find a way through, for there is no way back.\n\nExplore a vast dungeon of ever-changing paths!\nSwing swords, throw knives, and shoot arrows as if you held the weapons yourself!\nUncover the lost history of the dungeon!\nClimb over deep pits, dodge lethal traps, and search for hidden treasures!\nSmash pots. Break crates. It\u2019s just good fun.!\n", "short_description": "Ancient Dungeon is a rogue-lite dungeon crawler with randomly generated dungeons. Uncover its secrets and challenge powerful bosses!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://erthu.de/pp_advr.html", "developer_terms_of_service_url": null, "publisher_name": "ErThu", "support_website_url": null, "website_url": "http://erthu.de/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "253860676894450"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "463387678154269"}, {"status": "CANCELLED", "id": "396466304786079"}]}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1611945840, "status": "PUBLISHED", "id": "463387678154269"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes":