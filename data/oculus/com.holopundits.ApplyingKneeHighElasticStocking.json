102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ml_pRTFpzmYQ7kNvgGcDGSk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCc_7G0WJ_DPpTArOWzGesDai_TwaVKQIFmddQiTaKbKA&oe=676691E4"}, {"file_name": "Screenshot_High_elastic_new_02.png", "id": "1273265680658411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468730755_1273265683991744_3265241681089444724_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NX0n7Hhp2MMQ7kNvgGfjz-6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5Aow-JGJ9HqwCe1KF4ekPW5iPpYwq3SOrMrV3GnBkZA&oe=6766A35D"}, {"file_name": "Screenshot_High_elastic_new_03.png", "id": "1091815492638172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_1091815495971505_3614664701729651405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6kur67up0AQ7kNvgHIMgY4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBq7EV2_Gb1nBLgbgpZBIYnl2xvh0WGYiq1GyAuTI7ZQw&oe=6766A6FC"}, {"file_name": "Screenshot_High_elastic_new_04.png", "id": "9080326328699152", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982671_9080326332032485_8504855555445065433_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WRh5zXxO1iUQ7kNvgGAC_ym&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDN_07k9Hahfr7Sys_v4zIE8867jJEJYY_o_Fx7MLZAjw&oe=67669590"}, {"file_name": "Screenshot_High_elastic_new_05.png", "id": "564284309797801", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982446_564284313131134_1841207582380824520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61kj1RGW8VsQ7kNvgFHh20z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_tujN5C1GL84NYD-Qe3-k6t51MPhOnU2qU7zjUEAzug&oe=6766A9EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_High_elastic_new_04.png", "id": "1107512761065735", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75292490_1107512764399068_8861289260875416316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ljAWTVQGgsQ7kNvgFxTWmm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5bCljCtOHYZQgWFd1qwbsA8Pw4yPFILkBaUqIg97pPQ&oe=6766C1C4"}, "display_name": "Applying Knee \u2013 High Elastic Stocking", "keywords": ["CNA", "nursing", "nurse", "training", "ElasticStocking"], "long_description": "This VR simulation teaches the skill of applying knee-high elastic stocking, focusing on patient comfort and effective circulation support. The tutorial includes preparation, communication, application of stocking, and final checks.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives: \n- Remember the steps and safety protocols for applying knee-high elastic stocking. \n- Understand the importance of proper application in promoting circulation and preventing complications. \n- Apply the stocking correctly to ensure patient comfort and effectiveness. \n- Analyze the patient's condition to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and supportive environment for patients needing elastic stocking. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the correct technique for applying knee-high elastic stocking to promote patient comfort and circulation with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_