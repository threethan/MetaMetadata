889329570_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_w4XpO1Pk7oQ7kNvgGAXTAS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPvUoYn3bvk5hYlLDuVmOQhX3QhAcung1ssfC_cvc0rg&oe=66E58B72"}, {"file_name": "Screenshot_High_elastic_04.png", "id": "439076331802792", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556280_439076335136125_8016914236888413588_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=738wuCOKlW4Q7kNvgEb7NXs&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUWenEWXyLO3zVuv1ifRNthwiNaahPMqkRl05jDO0DQQ&oe=66E55918"}, {"file_name": "Screenshot_High_elastic_05.png", "id": "1786530601875661", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974447_1786530605208994_413204783601365735_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=908hAvXFGmcQ7kNvgFgZVXd&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_Gohp7Thkg9y3IFNZM6bGIIwD3owJWuq5FMgUk5hl9A&oe=66E56498"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "1053603966163731", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031307_1053603969497064_6274887578004208063_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f8sl9bxtYHYQ7kNvgErV2pU&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEDK0bi2pvexHO8wIBP1POFzh_JeBxt2DZ_AdP8MBsuw&oe=66E5578A"}, "display_name": "Applying Knee \u2013 High Elastic Stocking", "keywords": ["CNA", "nursing", "nurse", "training", "ElasticStocking"], "long_description": "This VR simulation teaches the skill of applying knee-high elastic stocking, focusing on patient comfort and effective circulation support. The tutorial includes preparation, communication, application of stocking, and final checks.  \n\n# Learning Objectives: \n- Remember the steps and safety protocols for applying knee-high elastic stocking. \n- Understand the importance of proper application in promoting circulation and preventing complications. \n- Apply the stocking correctly to ensure patient comfort and effectiveness. \n- Analyze the patient's condition to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and supportive environment for patients needing elastic stocking. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the correct technique for applying knee-high elastic stocking to promote patient comfort and circulation."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8066563946763313"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_423491657407921_7685638987582058814_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xEGewzUSRC8Q7kNvgFt55Ls&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPuT92Nu6fkL2J5nbn_kJBak__2SAEl0HgRWG75xhUtg&oe=66E5884A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Applying Knee \u2013 High Elastic Stocking", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS"