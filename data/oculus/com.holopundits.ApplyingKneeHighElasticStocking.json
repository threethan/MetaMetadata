67983388401187", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_High_elastic_new_01.png", "id": "1111733670645850", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974524_1111733673979183_903984537095166445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F4ZrZxXwGCAQ7kNvgEpP3C1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCPB5vNw8PviAor0wfp2YExDzexiI4dR_t1nhqRgLjEg&oe=676E7AE4"}, {"file_name": "Screenshot_High_elastic_new_02.png", "id": "1273265680658411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468730755_1273265683991744_3265241681089444724_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J_nIvnb5g40Q7kNvgF0fCs-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB50H7-LA5WGBya5DDP9l5bYbdlRAJzXEZ26fYApCdCgw&oe=676E8C5D"}, {"file_name": "Screenshot_High_elastic_new_03.png", "id": "1091815492638172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_1091815495971505_3614664701729651405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6gfi8fqdCAgQ7kNvgEEioGz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEayz_6j6Rl2qAzL5ni5snkJDNo340ElwaLaxBdZRNew&oe=676E8FFC"}, {"file_name": "Screenshot_High_elastic_new_04.png", "id": "9080326328699152", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982671_9080326332032485_8504855555445065433_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MTr6nPNKE64Q7kNvgGZNYMD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCexJEn3aJGbJqhR86yb8VgtkO1kVDbc5c7Q5yvgXYOEw&oe=676E7E90"}, {"file_name": "Screenshot_High_elastic_new_05.png", "id": "564284309797801", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982446_564284313131134_1841207582380824520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiFmnfmSQPYQ7kNvgE4-91d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjIQ_fnticnz0t2uBA7K3xTJl23Pf5GtF25KObSeJTzA&oe=676E92EA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_High_elastic_new_04.png", "id": "1107512761065735", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75292490_1107512764399068_8861289260875416316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aoqlmHKL1QMQ7kNvgF-xrfL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQ3CuI4fwCUFJuo8LxGh416GWcKW4Ffqaxh4KT1Kc4Bw&oe=676EAAC4"}, "display_name": "Applying Knee \u2013 High Elastic Stocking", "keywords": ["CNA", "nursing", "nurse", "training", "ElasticStocking"], "long_description": "This VR simulation teaches the skill of applying knee-high elastic stocking, focusing on patient comfort and effective circulation support. The tutorial includes preparation, communication, application of stocking, and final checks.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives: \n- Remember the steps and safety protocols for applying knee-high elastic stocking. \n- Understand the importance of proper application in promoting circulation and preventing complications. \n- Apply the stocking correctly to ensure patient comfort and effectiveness. \n- Analyze the patient's condition to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and supportive environment for patients needing elastic stocking. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the correct technique for applying knee-high elastic stocking to promote patient comfort and circulation with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8772185709534463"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982612_1786625475441188_1899597151501297910_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t4kh8m8reaIQ7kNvgGNYEaP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-_MDBnz-V3dPtb_tKEHxDZ9X0z9gcpSYIHNCt0tEk6g&oe=676E7E08"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Applying Knee \u2013 High Elastic Stocking", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "104310754736248