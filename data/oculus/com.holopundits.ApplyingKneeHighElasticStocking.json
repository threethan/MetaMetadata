102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4WqLIRPsEmEQ7kNvgGJL_lw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJaUydYxdhL2s_ONqNzFaZNn_6OlTEFEbi9qHd_zsOwQ&oe=6767E364"}, {"file_name": "Screenshot_High_elastic_new_02.png", "id": "1273265680658411", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/468730755_1273265683991744_3265241681089444724_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NX0n7Hhp2MMQ7kNvgGDseyj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDjuMzlIwV9Fyjb5UTc8RUpNssV8ceYN9B151S0_FOMEA&oe=6767F4DD"}, {"file_name": "Screenshot_High_elastic_new_03.png", "id": "1091815492638172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982539_1091815495971505_3614664701729651405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t6kur67up0AQ7kNvgETvtb6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBc6kbCVdLu9QR0T5FbnnGmn-TABs6U-02Y2TOkRvdZlA&oe=6767F87C"}, {"file_name": "Screenshot_High_elastic_new_04.png", "id": "9080326328699152", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982671_9080326332032485_8504855555445065433_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jHA2ji8tDFcQ7kNvgEh-G_n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAU3MDmvpSGjqkUbHVXz2cFsNXjAUIPRHaJkxMw3wr5WA&oe=6767E710"}, {"file_name": "Screenshot_High_elastic_new_05.png", "id": "564284309797801", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982446_564284313131134_1841207582380824520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UnrifOm779UQ7kNvgFPzurY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCdMDyhIAAPsmvfb-8mqb_VTDJHJd0EpOLUDaPQnWzgw&oe=6767FB6A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_High_elastic_new_04.png", "id": "1107512761065735", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75292490_1107512764399068_8861289260875416316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C1dPQyfb8U8Q7kNvgH0x75J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4Wk4F0XiR_qLB7vYzrKzlt6kNTuuPauwqVHbqJf-xVw&oe=67681344"}, "display_name": "Applying Knee \u2013 High Elastic Stocking", "keywords": ["CNA", "nursing", "nurse", "training", "ElasticStocking"], "long_description": "This VR simulation teaches the skill of applying knee-high elastic stocking, focusing on patient comfort and effective circulation support. The tutorial includes preparation, communication, application of stocking, and final checks.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives: \n- Remember the steps and safety protocols for applying knee-high elastic stocking. \n- Understand the importance of proper application in promoting circulation and preventing complications. \n- Apply the stocking correctly to ensure patient comfort and effectiveness. \n- Analyze the patient's condition to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and supportive environment for patients needing elastic stocking. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the correct technique for applying knee-high elastic stocking to promote patient comfort and circulation with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_