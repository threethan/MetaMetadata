67983388401187", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_High_elastic_new_01.png", "id": "1111733670645850", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974524_1111733673979183_903984537095166445_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XpjTnmHXcGAQ7kNvgGBpxKJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCHOZdAFIZ3L5DFiemK5_b8RWiqqWQ9-AnaVT0lAF5nSg&oe=67726F64"}, {"file_name": "Screenshot_High_elastic_new_02.png", "id": "1273265680658411", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/468730755_1273265683991744_3265241681089444724_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fJeS2nNSD8wQ7kNvgGscHFR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAc1NfdN50dOwC6japVRINuijZ52Z92msWC3vAu918tDg&oe=677280DD"}, {"file_name": "Screenshot_High_elastic_new_03.png", "id": "1091815492638172", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982539_1091815495971505_3614664701729651405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bvcAE0wqE-IQ7kNvgF2dK4i&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQDKM_XRU-6Ln6oXCLiTlvA-Hm345upv3XjgJ_u2DIIQ&oe=6772847C"}, {"file_name": "Screenshot_High_elastic_new_04.png", "id": "9080326328699152", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982671_9080326332032485_8504855555445065433_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nNo6aMVz4nQQ7kNvgHac4iq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBoiKtSvj8pHRWcyYIaHGQPq2LhkY4gPbEW9NkcOPC-qA&oe=67727310"}, {"file_name": "Screenshot_High_elastic_new_05.png", "id": "564284309797801", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982446_564284313131134_1841207582380824520_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61Kq1lrCvgEQ7kNvgGaGPZ5&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB20S3PL0TPnK2yjIqvuoCSTd7w8BTGa0WigQXYg1vyyg&oe=6772876A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_High_elastic_new_04.png", "id": "1107512761065735", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75292490_1107512764399068_8861289260875416316_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EAve7p-isPoQ7kNvgHjd16r&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB0hVk7xFB4-eRJYnOQN0OibTB8wk_s0PYpQRnrKRBqIg&oe=67729F44"}, "display_name": "Applying Knee \u2013 High Elastic Stocking", "keywords": ["CNA", "nursing", "nurse", "training", "ElasticStocking"], "long_description": "This VR simulation teaches the skill of applying knee-high elastic stocking, focusing on patient comfort and effective circulation support. The tutorial includes preparation, communication, application of stocking, and final checks.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n\n# Learning Objectives: \n- Remember the steps and safety protocols for applying knee-high elastic stocking. \n- Understand the importance of proper application in promoting circulation and preventing complications. \n- Apply the stocking correctly to ensure patient comfort and effectiveness. \n- Analyze the patient's condition to adjust the approach as needed. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a comfortable and supportive environment for patients needing elastic stocking. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the correct technique for applying knee-high elastic stocking to promote patient comfort and circulation with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8772185709534463"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982612_1786625475441188_1899597151501297910_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YY9VaZLGi3wQ7kNvgEmMwfA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAK-3wDaZV6JmxLmvagIcQ4r9fbXKreCti0j2GvlDFB0g&oe=67727288"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Applying Knee \u2013 High Elastic Stocking", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "104310754736248