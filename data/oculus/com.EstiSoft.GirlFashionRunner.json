PkYZg&oe=671B7902"}, {"file_name": "ss4.png", "id": "433855069243351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974685_433855072576684_2340185511442621748_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GJozS3m3hpIQ7kNvgHrYxPt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCVPAOIeXgdGfRHZbjiXrlQp-OekVZy78lPVv9f4osUGQ&oe=671B7ED1"}, {"file_name": "ss5.png", "id": "461973340217178", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035327_461973343550511_6205070325425064320_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zuul0wqswgMQ7kNvgHGH4q_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqyJKkU-GEV-Qr9vk-PWQvS7968fVUzs4M9-Fg8KxIrg&oe=671B9D99"}, {"file_name": "ss2.png", "id": "553127020624706", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035391_553127023958039_1128535947407948369_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pDgrB0zkJ9cQ7kNvgGKicjj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClsDDbdJDz0cpN9WiVJ2iHLHLLniqQYi_5f7546N4dOQ&oe=671B77E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ss2.png", "id": "1584779142249097", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982448_1584779145582430_8209235675842875346_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ujdMU4SjiJ0Q7kNvgGrXvZR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDLdzVkvytBVoGTN-K6u2l6byryPntfjuWeDhpNi5AmvQ&oe=671B8B16"}, "display_name": "Girl Fashion Runner", "keywords": ["runner", "hypercasual", "casual", "comfort", "girls"], "long_description": "Welcome to \"Girl Fashion Runner,\" an exhilarating virtual reality game that blends high fashion with high-speed adventure! Step into a world where your style choices propel you forward through dynamic 3D environments, from trendy urban streets to lush countryside settings. As you dash and dodge, you\u2019ll gather exclusive fashion items that not only score points but also unlock stylish outfits and accessories for your avatar.\n\nIn \"Girl Fashion Runner,\" every level is a runway, and each run is an opportunity to showcase your fashion sense. Customize your character with the latest trends as you challenge yourself with increasingly difficult obstacles. Master the art of swift navigation to avoid barriers and collect valuable fashion pieces that boost your score.\n\nThis game is designed for fashion enthusiasts and VR gamers alike, offering intuitive controls and engaging gameplay. Whether you\u2019re a seasoned runner or a style savant, you\u2019ll find joy in the unique combination of fashion and athleticism. Enjoy the rush of speeding through picturesque settings while dressing up in high-end fashion\u2014where your look is as important as your speed!\n\nWith vibrant graphics and a compelling progression system, \"Girl Fashion Runner\" offers endless hours of fun. Compete against friends, beat high scores, and climb the fashion leaderboards. Embrace the thrill of the chase and become a trendsetter in the virtual world!", "short_description": "Dive into the glamorous world of \"Girl Fashion Runner,\" a thrilling VR experience where style meets speed! Navigate through bustling cityscapes and stunning landscapes, collecting fashion items and avoiding obstacles. Customize your avatar with chic outfits and accessories to enhance your run. Perfect for fashionistas seeking adventure, this game combines immersive environments with heart-pounding action. Join the runway, where every race is a fashion statement!"}]}, "developer_name": "Esti Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/girl-fashion-runner", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topi