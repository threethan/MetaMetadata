scdn.com&oh=00_AYB37yVT-SFidJ4GbJ6Q-GBaO3uLWxaIPMH_5KDJDtDVVg&oe=66CDBAE7"}, {"file_name": "3.png", "id": "1149556342979727", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036613_1149556346313060_1538299774149696427_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DfMKMpFzEFsQ7kNvgHMOHH-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiX_mK3XT4Fd5nqDcWBv9ChTVuRf28UpqJkrzzh8aKLA&oe=66CDBDAF"}, {"file_name": "5.png", "id": "1209840896675943", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1209840900009276_5266600235134752213_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3dCAZVb2FnEQ7kNvgGGolgh&_nc_ht=scontent.oculuscdn.com&oh=00_AYA7965jorlRiA_HMYr4gtvzz0CmE8ekK0FYLu0ezTiXtg&oe=66CDA32A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Winter2560x1440.png", "id": "983170023345228", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569445_983170026678561_1189495338873688012_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U3-x_ileBSgQ7kNvgGRPZA1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXSpDnfie6wrbn2aQYKbtiggJWCktiEjrxni33h-pqEw&oe=66CDA5D8"}, "display_name": "Classic Music VR - Winter", "keywords": [], "long_description": "From a passion for classical music and the VR world comes 'Classic Music VR'. We transform music videos of the greatest composers into immersive and interactive experiences. Each song becomes a magical journey!\n\nFeatures: Experience Vivaldi's \"Winter\" like never before in a fully immersive VR environment.\nHigh-quality visuals and audio to enhance the classical music experience.\n\n\n\nRights and Ownership: All music and visual content used in 'Classic Music VR' is fully licensed and used with permission from the respective copyright holders. Song is Pubblic domain version via commons.wikimedia.org.\n\nExperience the magic of classical music in VR and embark on an unforgettable musical journey!\n\n", "short_description": "There is a new way to listen, a new way to live Classical Music! Today, we will take 