3-2.oculuscdn.com&oh=00_AYApS16dU4K0YtU66QdHk8eR-gKuxyj9N25sh5NjSAIaoQ&oe=6737195E"}]}, "id": "509039866447576", "locale": "en_US", "screenshots": [{"file_name": "nKSUV0.png", "id": "1107146129664546", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422390_1107146132997879_6054428845266698240_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sTcU8A29nLwQ7kNvgE9f_nj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2Ms_Qzq5-MvG9RV-WkwXC8AL0AO-X1Dt_kYXySbm_Gw&oe=67373366"}, {"file_name": "0TZzRH.png", "id": "283446259350475", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75481468_283446266017141_7928782251465113600_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ORvgo6k2iiYQ7kNvgHLmc2J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKh6swJv-qj_FRH6TiwZpS-CNLZSeJPMedXt0faFDUFw&oe=67372B72"}, {"file_name": "ABUM5D.png", "id": "228776561894537", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86625128_228776565227870_6829144489089564672_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2IQ9nGljfxAQ7kNvgE2mVb9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAgem26mAgjutrMYnr-NZQEP8pFmulcAtIp-ea6f8YU-A&oe=673741F2"}, {"file_name": "KyXTWv.png", "id": "1183600715317474", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572923_1183600718650807_7154576334360936448_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Oqnk42Rq6AQ7kNvgHgetah&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_wowF-FFXLFcef-3Hkad7p34I6iJjR4XZizThc84Kew&oe=67372BDD"}, {"file_name": "t6PN5n.png", "id": "2865002846882803", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974799_2865002850216136_7325932395461345280_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wr1uRZMlxa0Q7kNvgFil304&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDDQaHvIUUrRsuPtQFfs2Jjjde4RdMDrz-h0Z9H6-u8Q&oe=67373C18"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "The Line", "keywords": ["Handtracking", "Movies", "Family", "Animation", "Cinema"], "long_description": "Have you ever felt like you were living in a ceaseless repetition? Set within a scale model of 1940s S\u00e3o Paulo, \u201cThe Line\u201d is an interactive story about love and fear of change, allowing you to unlock an enchanted maquette of two miniature dolls, Pedro and Rosa.\n \nThis roomscale experience invites you to pull on knobs and even crawl under the scale model to unfold the story of these figurines who are perfect for each other but reluctant to live out their love. \n \n\"The Line\" is great to showcase VR for first-time users. \n \nNarrated by Rodrigo Santoro (Westworld) and directed by Ricardo Laganaro, \u201cThe Line\u201d was awarded the \u201cBest VR Immersive Experience\u201d prize at the 76th Venice International Film Festival. \n \nAdditional modes: \nHand Tracking: Using your own hands for natural interaction \nRoom scale and seated mode : Freely around the maquette, or experience the story around you for those with limited space or reduced mobility. \nNarration and SDH subtitles in English and Portuguese. ", "short_description": "Set within a scale model of 1940s S\u00e3o Paulo, \u201cThe Line\u201d is an interactive story about love and fear of change, inviting you to the enchanted world of Pedro and Rosa. Pull on knobs or crawl under the maquette to unfold the story of these miniature dolls who are perfect for each other but reluctant to live out their love. \nThe piece is great to showcase VR for first-time users. Narrated by Rodrigo Santoro, \u201cThe Line\u201d won \u201cBest VR Experience\u201d at the 76th Venice Film Festival. Hand tracking enabled."}]}, "developer_name": "ARVORE Immersive Experiences", "developer_privacy_policy_url": "https://arvore.io/privacy-policy/the-line/", "developer_terms_of_service_url": "https://arvore.io/terms-of-service/the-line/", "publisher_name": "ARVORE Immersive Experiences", "support_website_url": "https://www.arvore.io/", "website_url": "https:/