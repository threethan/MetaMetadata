rivacypolicy/", "developer_terms_of_service_url": "http://www2.ual.es/neotrie/termsandconditions/", "publisher_name": "Virtual Dor, Universidad de Almer\u00eda", "support_website_url": "http://www2.ual.es/neotrie/contact/", "website_url": "http://www2.ual.es/neotrie", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "385666506786398"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "795765455161318"}]}, "baseline_offer": {"id": "795765455161318"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1652306400, "status": "PUBLISHED", "id": "795765455161318"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8484518198272784", "version": "4.7.1"}, "id": "909472782930303", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4121567677901213", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8484518198272784"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "909472782930303"}]}, "change_log": "Fixed bug: Paste figures in Multiplayer Mode\nFixed bug: Creation of tillings in Multiplayer Mode\nFixed bug: Creation of fractals in single Mode\nBug not yet fixed: Creation of fractals in multiplayer mode.", "created_date": 1726919390, "id": "8484518198272784", "version": "4.7.1", "version_code": 123, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4121567677901213", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8484518198272784"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "909472782930303"}]}, "change_log": "Version  4.7.0: Major update\n\nGeneral improvements:\nImproved shaders of figures, compatibility with Meta Quest.\nNew interaction ray with tools, objects, and menu buttons. Press the side button.\nAdded temple in \u201cVery low\u201d and \u201cLow\u201d graphics level.\nImproved graphical models of tools and their interaction with objects.\nImproved hand actions menu.\nImproved pasting of figures.\nNew Saving System (version 10) for neot files.\n\nCopy tool: \nImproved copy tool to copy figures with green dependent points.\n\nTool Intersections:\nNew cut between two circles in space in general.\n\nNew tool Edge with Angle:\nCan build an edge with a given angle, with respect to another edge and contained in a given plane.\n\nLabelling:\nImproved labels keyboard to add math functions.\n[Formula=Sin( <label=e1>) * Cos(<label=e2>)] will multiply the sinus of the value in label e1 with the cosine of the value in label e2.\nCorrected special labels associated with mathitems.\nNew label \u201cAngle\u201d on arcs.\n\n3d Graphing calculator: \nMore efficient calculator to get smoother curves and surfaces.\nLabel values can be used inside the panel as <label=e1>, etc.\nCurves and surfaces in internal mode can be updated and moved with sliders.\nCorrected bug on interpolation of surfaces.\n\nMultiplayer mode:\nSynchronized all buttons and functions of the 3d graphing calculator.\nSynchronized STL and OBJ object loading.\nSynchronized angle of protractor.\nSynchronized glue stick figure joining.\nSynchronized unbinding tool.\nBUG: fractals do not work in multiplayer mode", "created_date": 1726582413, "id": "8448976678493603", "version": "4.7.0", "version_code": 122, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4121567677901213", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8484518198272784"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1713364885, "id": "7599103593480920", "version": "4.6.99", "version_code": 121, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4121567677901213", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8484518198272784"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1712598951, "id": "7560894403968506", "version": "4.6.98", "version_code": 120, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename"