68", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982473_250912256218734_3911875050923360256_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5F01FKVizkwQ7kNvgFX-tcF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBNsrDjG0C_5Ctz6F08T00Q9lI-w0aw8WIucyh3OdXc6w&oe=675C2944"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Horror Maze", "keywords": ["horror", "maze", "dungeon", "generator", "procedural"], "long_description": "ATTENTION: If you have any heart or epilepsy problems do not play this horror game! Be warned.\n\nYou must escape the horror dungeon before a creepy creature put hands on you!\n\nEvery playthrough will be unique due to the procedural maze generator.\nWhen you start the game a new world will be generated, you wake up in a dark cell...\nTry to make it out alive and avoid to make any noise because the creepy maze monster could hear and chase you...\nHide and try to stay safe, find items or tools to succeed and escape with the elevator.\nHeadphones are recommended for ultimate immersion.\n\n\nNew Features coming soon! (Tell us what you would like to play, we love feedback!)\n\nIf you are experiencing any bugs feel free to contact us, we're still learning.", "short_description": "You must escape the horror dungeon before a creepy creature put hands on you!\nEvery playthrough will be unique due to the procedural maze generator."}]}, "developer_name": "Tom Foerster", "developer_privacy_policy_url": "http://forstech.de/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Tom Foerster", "support_website_url": null, "website_url": "http://www.forstech.de/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "HORROR", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "re