pe (1).png", "id": "163971826638546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_163971829971879_2698801498208849649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hj0487yVgKEQ7kNvgEJlDsa&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgxqVt8XzEmXZrNolMOG3LnVYUW_kR-WPADfSmNzuIYg&oe=66F7FED0"}, "display_name": "Rooms of Realities", "keywords": [], "long_description": "\ud83e\udde9Join unique puzzle adventures in Rooms of Realities! \ud83e\udde9\nRooms of Realities offers unique and well-balanced puzzles to solve alone or with friends! Enter the mysterious levels full of logic, mechanics, precision, memory, cooperation, cipher, and skill-based challenges! And don\u2019t worry if you get stuck - our smart, yet non-invasive hint system will help you get back on track.\n\n\ud83d\udd0d Play solo or with your friends! \ud83d\udd0d\nThe game offers both co-op and single-player modes. Solve all the puzzles by yourself or play with your friends! Work together, help each other and, what\u2019s most important, communicate to finish the adventures.\n\n\ud83d\udd0dPlay 9 different levels in 3 unique environments in Full Game! \ud83d\udd0d\nOn the release, you can expect 9 levels full of puzzles set in 3 different environments! An ancient pyramid, an underwater station, and even an asylum; you will be able to explore all of these wild places! Each environment holds its own story and 3 atmospheric levels to play.\n\n\ud83d\udd0d Post-launch support \ud83d\udd0d\nYou are right, that\u2019s not all! We plan to further develop the game and add even more levels and settings post-launch. So, what are you waiting for? Wishlist the game and stay tuned!\n", "short_description": "Rooms of Realities is a universe of puzzle adventures set in distinctive and atmospheric environments. Join the game in co-op or single-player mode and solve all the secrets inspired by award-winning real-world Escape Rooms!"}]}, "developer_name": "Bluekey", "developer_privacy_policy_url": "https://gamedust.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gamedust", "support_website_url": null, "website_url": "https://gamedust.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "153115097736660"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1451613089022823"}, {"status": "PUBLISHED", "id": "955066682577016"}]}, "baseline_offer": {"id": "1451613089022823"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1700244000, "status": "PUBLISHED", "id": "1451613089022823"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "24747802088167611", "version": "1.1.136.1046557.live"}, "id": "148949618033082", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9310428738998196", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "24747802088167611"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "148949618033082"}]}, "change_log": null, "created_date": 1706632204, "id": "24747802088167611", "version": "1.1.136.104655