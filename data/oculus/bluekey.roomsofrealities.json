a&_nc_ohc=fvyFd1SsgccQ7kNvgHPD_Ic&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo4VqP9J6W6fvankEwuxDulIYKuO6KHnL1RXisNY8S3A&oe=66DD7A76"}]}, "id": "781762643614602", "locale": "en_US", "screenshots": [{"file_name": "avatar-P2-gallery-02 (2) (1).png", "id": "580673087227126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982520_580673093893792_3375852287352260752_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VKdfwmh5uLoQ7kNvgFbq0Du&_nc_ht=scontent.oculuscdn.com&oh=00_AYBDoejBufUzU8HzwPwPN54pU4m4DZlnOUGPQXTxGodNLQ&oe=66DD91CF"}, {"file_name": "avatar-N2-bridge-02 (1) (1).png", "id": "266514842510873", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_266514845844206_5195890454856783355_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UiZx3RLcTOwQ7kNvgHlssaF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXeqYTX3oSgR3EvCJ_gLb12IcV3tuPgF2TTpWko7X6Sg&oe=66DD7C76"}, {"file_name": "noavatar-N2-bridge-02 (3).png", "id": "1178705102790902", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_1178705106124235_7607996853217936998_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bcmUNkihFScQ7kNvgElaRa6&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqukvKRjQm2lluQNAes7bDt-DugFYTcB_FBk1HOunbXA&oe=66DD9EFF"}, {"file_name": "avatar-P3-tomb-01 (1) (1).png", "id": "991825028665325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974666_991825031998658_5122658494630612990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3YlcYK34bn8Q7kNvgF0xb53&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8XKbA9O1hOJuve0svVZvrUCREtI_HPMfD5DHvnjFk3w&oe=66DDA037"}, {"file_name": "noavatar-A2-cave-01 (1) (1).png", "id": "223321857097302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_223321860430635_445376749690127518_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AmZ1z3txkvsQ7kNvgEHbbA1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwqV0rBV5cVWH_cAldqR0JkaicGlPGBehM5JFotbZ1lg&oe=66DD92C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape (1).png", "id": "163971826638546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_163971829971879_2698801498208849649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LFV5VwDJBfcQ7kNvgEy4zVX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCq1jhRb1FGOaIX9QaccPFG1LNSSVWESIisx3ObaF6qaA&oe=66DDA0D0"}, "display_name": "Rooms of Realities", "keywords": [], "long_description": "\ud83e\udde9Join unique puzzle adventures in Rooms of Realities! \ud83e\udde9\nRooms of Realities offers unique and well-balanced puzzles to solve alone or with friends! Enter the mysterious levels full of logic, mechanics, precision, memory, cooperation, cipher, and skill-based challenges! And don\u2019t worry if you get stuck - our smart, yet non-invasive hint system will help you get back on track.\n\n\ud83d\udd0d Play solo or with your friends! \ud83d\udd0d\nThe game offers both co-op and single-player modes. Solve all the puzzles by yourself or play with your friends! Work together, help each other and, what\u2019s most important, communicate to finish the adventures.\n\n\ud83d\udd0dPlay 9 different levels in 3 unique environments in Full Game! \ud83d\udd0d\nOn the release, you can expect 9 levels full of puzzles set in 3 different environments! An ancient pyramid, an underwater station, and even an asylum; you will be able to explore all of these wild places! Each environment holds its own story and 3 atmospheric levels to play.\n\n\ud83d\udd0d Post-launch support \ud83d\udd0d\nYou are right, that\u2019s not all! We plan to further develop the game and add even more levels and settings post-launch. So, what are you waiting for? Wishlist the game and stay tuned!\n", "short_description": "Rooms of Realities is a universe of puzzle adventures set in distinctive and atmospheric environments. Join the game in co-op or single-player mode and solve all the secrets inspired by award-winning real-world Escape Rooms!"}]}, "developer_name": "Bluekey", "developer_privacy_policy_url": "https: