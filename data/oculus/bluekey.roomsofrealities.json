ame": "avatar-P3-tomb-01 (1) (1).png", "id": "991825028665325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974666_991825031998658_5122658494630612990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2IopvIZ_wJEQ7kNvgHR4fgs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AD-pqSXwXKaSFVWA55khHnj&oh=00_AYBs7dXBDpPzSEL-Vyzd0yB8nshVpBSlv1qqdJruO5_SfA&oe=66D465B7"}, {"file_name": "noavatar-A2-cave-01 (1) (1).png", "id": "223321857097302", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_223321860430635_445376749690127518_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VBJ9whoVF1wQ7kNvgH7-8yu&_nc_ht=scontent.oculuscdn.com&_nc_gid=AD-pqSXwXKaSFVWA55khHnj&oh=00_AYBCBR9LwApwzIdpiOEh_Eo1mbz4Klc2SnshdGxracnjVw&oe=66D45849"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape (1).png", "id": "163971826638546", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974537_163971829971879_2698801498208849649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8JHU98UyDVoQ7kNvgH4rgDO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AD-pqSXwXKaSFVWA55khHnj&oh=00_AYDb5tPpJU9BqxI8fR20m862V2lg6oEZ_sAuiZY-f3OfrA&oe=66D46650"}, "display_name": "Rooms of Realities", "keywords": [], "long_description": "\ud83e\udde9Join unique puzzle adventures in Rooms of Realities! \ud83e\udde9\nRooms of Realities offers unique and well-balanced puzzles to solve alone or with friends! Enter the mysterious levels full of logic, mechanics, precision, memory, cooperation, cipher, and skill-based challenges! And don\u2019t worry if you get stuck - our smart, yet non-invasive hint system will help you get back on track.\n\n\ud83d\udd0d Play solo or with your friends! \ud83d\udd0d\nThe game offers both co-op and single-player modes. Solve all the puzzles by yourself or play with your friends! Work together, help each other and, what\u2019s most important, communicate to finish the adventures.\n\n\ud83d\udd0dPlay 9 different levels in 3 unique environments in Full Game! \ud83d\udd0d\nOn the release, you can expect 9 levels full of puzzles set in 3 different environments! An ancient pyramid, an underwater station, and even an asylum; you will be able to explore all of these wild places! Each environment holds its own story and 3 atmospheric levels to play.\n\n\ud83d\udd0d Post-launch support \ud83d\udd0d\nYou are right, that\u2019s not all! We plan to further develop the game and add even more levels and settings post-launch. So, what are you waiting for? Wishlist the game and stay tuned!\n", "short_description": "Rooms of Realities is a universe of puzzle adventures set in distinctive and atmospheric environments. Join the game in co-op or single-player mode and solve all the secrets inspired by award-winning real-world Escape Rooms!"}]}, "developer_name": "Bluekey", "developer_privacy_policy_url": "https://gamedust.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gamedust", "support_website_url": null, "website_url": "https://gamedust.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "153115097736660"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1451613089022823"}, {"status": "PUBLISHED", "id": "955066682577016"}]}, "baseline_offer": {"id": "1451613089022823"}, "is_approved": true, "firstOffer"