7E36F"}, {"file_name": "avatar-P3-tomb-01 (1) (1).png", "id": "991825028665325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974666_991825031998658_5122658494630612990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WbrlAE0AK5UQ7kNvgH-5YCk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjcRPtg2sbgTYq2w7I-5FMX5cDeYpIWHu5FieE0DeZaA&oe=66F7FE37"}, {"file_name": "piramida.png", "id": "2001269443572549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974777_2001269446905882_6332380428911043853_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N4L_TYdfB4UQ7kNvgFAk1F_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCD6i8xDYAAUYWzOi_Tr6qjqHM_IvKvQqBXUJuauESIvQ&oe=66F7EFE9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ROR_KV_AppLab_2560x1440.png", "id": "1498201787778657", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75307249_1498201794445323_5568991861944438501_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3rvMUqOiFBsQ7kNvgGx7Eq5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBelw7jvECbTsJl4Q2tDJvIs-a-Q1JTP699AXgQNp8pWA&oe=66F7D184"}, "display_name": "Rooms of Realities", "keywords": [], "long_description": "\ud83d\udd25\ud83d\udd25\ud83d\udd25The game has received its final update which **adds new puzzles and extends playtime for the Forsaken Asylum scenario**, and incorporates **minor fixes for the existing puzzles** in other scenarios.\ud83d\udd25\ud83d\udd25\ud83d\udd25\n\n\ud83e\udde9**Experience puzzle adventures in Rooms of Realities!** \ud83e\udde9\n\nRooms of Realities offers **unique and well-balanced puzzles for solo or cooperative play with friends**! Enter the **mysterious levels** full of logic, mechanics, precision, memory, cooperation, cipher, and skill-based tasks! And don\u2019t worry if you get stuck - our **smart, yet non-invasive hint system** is on hand to guide you back on track.\n\n\n\ud83d\udd0d **Play solo or with your friends!** \ud83d\udd0d\n\nWith both **co-op and single-player modes available** solve all the puzzles by yourself or play with your friends! Work together, help each other and, what\u2019s most important, communicate to finish the adventures.\n\n\ud83d\udd0d **Play 9 different chapters in 3 unique scenarios!** \ud83d\udd0d\n\nThe game now **offers 9 chapters full of puzzles set in 3 different scenarios: an ancient pyramid, an underwater station, and a spooky asylum**. Each environment holds its own story and 3 atmospheric chapters to explore. Now in an improved version after the final update.\n\n\ud83d\udd0d**Get all the collectibles and take a photo in the victory room!** \ud83d\udd0d\n\n**Gather collectibles**, **earn trophies** for completing each scenario, and **commemorate your triumphs with a photo** in our victory rooms. These special sceneries will let you save all the best memories in one click.", "short_description": "Rooms of Realities is a universe of puzzle adventures set in distinctive and atmospheric environments. Play the game in co-op or single-player mode and solve all the secrets inspired by award-winning real-world Escape Rooms!  Now in a new, refined version with enriched content via the final update. Explore the interior of a submarine, a pyramid, and an abandoned asylum, and experience your own adventure!"}]}, "developer_name": "Bluekey", "developer_privacy_policy_url": "https://gamedust.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gamedust", "support_website_url": null, "website_url": "https://gamedust.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_langu