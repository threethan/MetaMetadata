2464_926996435895760_6154143264840409848_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYZiJ9c4DVEQ7kNvgFZK_mt&_nc_ht=scontent.oculuscdn.com&oh=00_AYAGqeVekLgMYD3bU_9MWEN33BZK1uIbWhi-YwzC8gGDDA&oe=66DD771B"}, {"file_name": "AppLab_1080x360.png", "id": "751229200509169", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982480_751229203842502_6907385989361787725_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oAUcUDy6P7wQ7kNvgEwif6J&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhfPt0NJGq2qxDDVEgq9AH3qvvPMuv6huakny2iZAUYQ&oe=66DDA0BC"}, {"file_name": "Icon (1).png", "id": "255021300373062", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031636_255021303706395_8782196129682097274_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fvyFd1SsgccQ7kNvgHPD_Ic&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo4VqP9J6W6fvankEwuxDulIYKuO6KHnL1RXisNY8S3A&oe=66DD7A76"}]}, "id": "403720842466146", "locale": "en_US", "screenshots": [{"file_name": "avatar-P2-gallery-02 (2) (1).png", "id": "580673087227126", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982520_580673093893792_3375852287352260752_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VKdfwmh5uLoQ7kNvgFbq0Du&_nc_ht=scontent.oculuscdn.com&oh=00_AYBDoejBufUzU8HzwPwPN54pU4m4DZlnOUGPQXTxGodNLQ&oe=66DD91CF"}, {"file_name": "Image7 1 (2).png", "id": "1646041522555737", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031332_1646041525889070_9102289246984368427_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EB6dq_sg1f0Q7kNvgG2MhaO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDC_oGDeHTUEWLjEZASnfSH9v1JSrngQvJo43yzY1n8uQ&oe=66DD7312"}, {"file_name": "avatar-N2-bridge-03 (4) 1.png", "id": "856433472685261", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_856433476018594_7242642215078556754_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wAt9E3zOz_0Q7kNvgHZb9g3&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWxcKM4Faz8QIAwCoQAsXFj8yMuMe2agKVqS9_8cxuoQ&oe=66DD856F"}, {"file_name": "avatar-P3-tomb-01 (1) (1).png", "id": "991825028665325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974666_991825031998658_5122658494630612990_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3YlcYK34bn8Q7kNvgF0xb53&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8XKbA9O1hOJuve0svVZvrUCREtI_HPMfD5DHvnjFk3w&oe=66DDA037"}, {"file_name": "piramida.png", "id": "2001269443572549", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974777_2001269446905882_6332380428911043853_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W5Y3GqUZctIQ7kNvgHUO6yZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAidgIpp0wbTAl0PO9DiD2JeveualHxGAwXJjJ7v8DETg&oe=66DD91E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ROR_KV_AppLab_2560x1440.png", "id": "1498201787778657", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75307249_1498201794445323_5568991861944438501_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ecfyoCyxP_oQ7kNvgGhIcpR&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0rWMaX-I0bxse9Rc6ez9rmhpX0V0AejazZpaC0OD1TA&oe=66DD7384"}, "display_name": "Rooms of Realities", "keywords": [], "long_description": "\ud83d\udd25\ud83d\udd25\ud83d\udd25The game has received its final update which **adds new puzzles and extends playtime for the Forsaken Asylum scenario**, and incorporates **minor fixes for the existing puzzles** in other scenarios.\ud83d\udd25\ud83d\udd25\ud83d\udd25\n\n\ud83e\udde9**Experience puzzle adventures in Rooms of Realities!** \ud83e\udde9\n\nRooms of Realities offers **unique and well-balanced puzzles for solo or cooperative play with friends**! Enter the **mysterious levels** full of logic, mechanics, precision, memory, cooperation, cipher, and skill-based tasks! And don\u2019t worry if you get stuck - our **smart, yet non-invasive hint system** is on hand to guide you back on track.\n\n\n\ud83d\udd0d **Play solo or with your friends!** \ud83d\udd0d\n\nWith both **co-op and single-player modes available** solve all the puzzles by yourself or play with your friends! Work together, help each other and, what\u2019s most important, communicate to finish the adventures.\n\n\ud83d\udd0d **Play 9 different chapters in 3 unique scenarios!** \ud83d\udd0d\n\nThe game now **offers 9 chapters full of puzzles set in 3 different scenarios: an ancient pyramid, an underwater station, and a spooky asylum**. Each environment holds its own story and 3 atmospheric chapters to explore. Now in an improved version after the final update.\n\n\ud83d\udd0d**Get all the collectibles and take a photo in the victory room!** \ud83d\udd0d\n\n**Gather collectibles**, **earn trophies** for completing each scenario, and **commemorate your triumphs with a photo** in our victory rooms. These special sceneries will let you save all the best memories in one click.", "short_description": "Rooms of Realities is a universe of puzzle adventures set in distinctive and atmospheric environments. Play the game in co-op or single-player mode and solve all the secrets inspired by award-winning real-world Escape Rooms!  Now in a new, refined version with enriched content via the final update. Explore the interior of a submarine, a pyramid, and an abandoned asylum, and experience your own adventure!"}]}, "developer_name": "Bluekey", "developer_privacy_policy_url": "https://gamedust.co/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Gamedust", "support_website_url": null, "website_url": "https://gamedust.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app