8_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OUNRA6vneD0Q7kNvgFwKO_E&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbtwqm-nUKVQ4N_XxP74QRQhkHw0t54f6S66Kq3QBI_w&oe=6773C49A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "made-in-godot.png", "id": "853716213569126", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031311_853716216902459_2056448508130112580_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4toRlSm0T8kQ7kNvgFt1Eo0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAt4u6Ln9ssnBNfXTHP0TWObkse158Fy4C4-w54vSJ89g&oe=6773EF02"}, "display_name": "Godot Game Engine", "keywords": ["Godot", "Productivity", "GameEngine"], "long_description": "The Godot Engine is a free, all-in-one, cross-platform game engine that makes it easy for you to create 2D, 3D and immersive (XR) apps and games.\n\nGodot provides a huge set of common tools, so you can just focus on making your game without reinventing the wheel.\n\nGodot is completely free and open-source under the very permissive MIT license. No strings attached, no royalties, nothing. Your app / game is yours, down to the last line of engine code.\n\n**NOTE:** Works best with a bluetooth keyboard and mouse.", "short_description": "The Godot Engine enables the creation and development of 2D, 3D and XR apps and games natively on Meta Quest devices."}]}, "developer_name": "Godot Foundation", "developer_privacy_policy_url": "https://godotengine.org/privacy-policy/", "developer_terms_of_service_url": "https://godotengine.org/license/", "publisher_name": "Stichting Godot", "support_website_url": null, "website_url": "https://godotengine.org/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": null, "internet_connection