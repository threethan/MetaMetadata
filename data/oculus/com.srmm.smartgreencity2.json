0924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PcVpzeaYUpIQ7kNvgEffSlN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAxFSzl8Y0qE6Dr6PktOLNmeK_08hw7ruts__oz8vDHqg&oe=67629A72"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FNILdp75EtQQ7kNvgGy2ctH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2t71JM2I6ZuoBqlqo92yH7ovS058KLT327y_u9yqbkQ&oe=6762BFD7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wTzKVGFl760Q7kNvgHyreAj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRPGL3KYvGdQQXPlvmohaFeH67IlDO4kuFJjoSwxJLJQ&oe=6762C515"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dcvB3PQ932oQ7kNvgHCpvL-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCWxwxuoVn1x27pTrWJNhd4SMeUMiuF_8TRMEiF3jSpzA&oe=6762A082"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P6N68bdRnewQ7kNvgF_nIAa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAaCLY3L0vLt5y7gFMGWp7GMNlxhgowxUmmVs6ozqnJnQ&oe=6762BF44"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxnePMEhx54Q7kNvgF3csiX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAeoQc-n59oUZ1ovBbFZG7daX4VnqshrL-cRYShEL78FQ&oe=6762B7A2"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003276_874968084382960_490444167917392231_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MRbuvYsh9hkQ7