797591", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982571_1154233272130924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-NObe_e2MKYQ7kNvgFAukPw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYCDmr1Y8kGd-qNZanqpNlLXcKIC-qy6oPFHPPRnXzCqkg&oe=66F13972"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQ_mS9cOLKQQ7kNvgFfzsMV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYDVqSc3vGl4-09AHPllyvrkpKWA7U-chLRWub9BwayfVA&oe=66F15ED7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wGo7YeAwR0IQ7kNvgGBXmSA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYCmiLOn-kjzqVO10Bisht8FU-XboTuLXNvWOTxXT6u5-w&oe=66F16415"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lUUy4CU4HOQQ7kNvgFAicRZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYCNwbXtq_RUpwXMuwjWbzx3CBxjHL7ElO0nIbf168J6cg&oe=66F13F82"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sWihWEJtrEkQ7kNvgHki60b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYCjZ0_L8hrQx0XYyNZwHENf0UA_UV3nfbZ49qq9iy4k2Q&oe=66F15E44"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DBCUFpOg5R0Q7kNvgGG0Mm-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjK2S6s9qm6MdE4wZhCTCvK&oh=00_AYDBnf7nRpr5pxZAePcbOtbz5KM1hp2FSqyDKyNidJX8Sw&oe=66F156A2"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://sconte