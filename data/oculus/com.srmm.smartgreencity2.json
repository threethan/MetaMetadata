_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j_YEAmYy2TgQ7kNvgEl1PP6&_nc_ht=scontent.oculuscdn.com&oh=00_AYARs5oB-jCse425jblBpWjMG2JBrwzX3Oe5BRNxp1G31w&oe=66F9314C"}, {"file_name": "Square_1440x1440.png", "id": "333633099672923", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75542963_333633103006256_1851106834320739734_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=31t4c3UZVgUQ7kNvgFc93_B&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpJDMxdgeLERySBlcNrIcu2DhEWhWsXokPieMlKhiZLg&oe=66F9237B"}]}, "id": "7126276800753802", "locale": "en_US", "screenshots": [{"file_name": "Screenshot(3)_2560_1440.png", "id": "1785377285291145", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75534973_1785377288624478_4708064803249901820_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m8cBOX7F9nwQ7kNvgF8oWq1&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9obzfO179uaZh8AlxpVRua-l-o0r7O94j2v4YYclFTw&oe=66F9485C"}, {"file_name": "Screenshot(4)_2560_1440.png", "id": "1084137449397288", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_1084137452730621_5104450028338525191_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uuyc6EQ3kP8Q7kNvgEatKO5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDfvLAEx8CuW0u4wdHkArPTdGqOB1Bl5QKoDDHKL4Zq3g&oe=66F9441C"}, {"file_name": "Screenshot(5)_2560_1440.png", "id": "1543167612893241", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1543167616226574_5478733150451952791_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AfZUUYd_3VQQ7kNvgF7R4Z0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBX5SIF7zR_sqGlXpDAkip19R0fFKkxBGnUHiJ5JtyUgQ&oe=66F92A9D"}, {"file_name": "Screenshot(2)_2560_1440.png", "id": "1154233268797591", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982571_1154233272130924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQcPVii-7owQ7kNvgGkYzbI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjFdVb4U3Q2yzMvoDeOpqvUaC65ArakbvzR0ZDxeJWZA&oe=66F92272"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOtDIPPSTCUQ7kNvgF7Acf1&_nc_ht=scontent.oculuscdn.com&oh=00_AYD6wDSn9UdJ0F8RYt7ddZQy0_tgdm6WSgSixddEJrw7LQ&oe=66F947D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S45FNZ-PW2YQ7kNvgEYxPAE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmEbdM_iYTmLL_9yQZA5nUlhZ3BqEasqvEl6s2rfPqcw&oe=66F94D15"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dfqz8mzuCZcQ7kNvgFq7jvO&_nc_ht=scontent.oculuscdn.com&oh=00_AYBTiiDVFOwR8FOnRX_-bXF_stBwNM_NYBhrAOhFRAl0dQ&oe=66F92882"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MB3EmtbfkIkQ7kNvgGL_ztN&_nc_ht=scontent.oculuscdn.com&oh=00_AYCW8Xn_uhhftnEoOyvZobiIy7ebuDrwnJvvXUOFmWeFfA&oe=66F94744"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NvqQwbMZC0Q7kNvgEPigto&_nc_ht=scontent.oculuscdn.com&oh=00_AYCK2wWeIgNXJjdzLQmcqN8cIhlqPSn8Z-yTSkY72CgB7Q&oe=66F93FA2"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003276_874968084382960_490444167917392231_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O_Iqfgrn6icQ7kNvgEvA_Q1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAumjsfiUPc9HRIF0rBkziDPFKo5lT5U01k0CCqpTV2Q&oe=66F947B0"}, {"file_name": "Square_1440x1440.png", "id": "797300635542181", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367597_797300638875514_6595403142216159433_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_aytFJklnGwQ7kNvgF