72130924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sw6EZP93VI0Q7kNvgHqXlAd&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDeQucF5TNx_fZWDm-lpAirFsSG6A6cb3LnfyhT_nr5HA&oe=67289872"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tX_nsim4USAQ7kNvgFadZG7&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBssYWDt9nzZUi6wANMbv4nAB0--UprO7ribtsNAm3rZg&oe=6728BDD7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3iFNbBsutrwQ7kNvgGqjEYR&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYA4lqix8nmxfX6BpcK5WCHFvbhMOs7STqCC9I2GMn2X2w&oe=6728C315"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8WLotWbxJEQ7kNvgFRBjXQ&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYAHM3FNdSqhG58KJ51Eb2hMPLftp-p_DZdNGyYjV290Cw&oe=67289E82"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jA9W75mT2dsQ7kNvgHNjYVh&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDQxDkoxAqEtnoEK0-OOQgtyOb6-9QduNAmp9-p0w3pEQ&oe=6728BD44"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5KzNy1-NhT0Q7kNvgGZiQn8&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYA7xO94A3RwPBAEasizkbbB0LwTTuvHIzBBxbd04dTk2w&oe=6728B5A2"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39003276_874968084382960_490444167917392231_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=46BvinyZG