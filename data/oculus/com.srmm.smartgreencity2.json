0\uc791\n- \uc57d 20\ubd84~30\ubd84 \uc815\ub3c4\uc758 \uccb4\ud5d8 \uc2dc\uac04 \uc608\uc0c1\n\n3. 7\ub2e8\uacc4 \uad6c\uc131\nSTEP 1 \uc870\uc791\ubc29\ubc95 \uc548\ub0b4\nSTEP 2 UN\uccad\uc18c\ub144 \ub300\ud45c\ub2e8\uacfc\uc758 \ub9cc\ub0a8\nSTEP 3 \ub3c4\uc2ec \uc18d\uc758 \uc232\uc5d0\uc11c \ud0c4\uc18c\uc911\ub9bd \uc2e4\ucc9c\nSTEP 4 \ud48d\ub825\ubc1c\uc804\ub2e8\uc9c0\uc5d0\uc11c \ud0c4\uc18c\uc911\ub9bd \uc2e4\ucc9c\nSTEP 5 \ub3d9\ud574\uc548 \ud0c4\uc18c\uc800\uc7a5\uc18c\uc5d0\uc11c \ud0c4\uc18c\uc911\ub9bd \uc2e4\ucc9c\nSTEP 6 \uc0dd\uac01\ud558\uae30\nSTEP 7 \ub9c8\ubb34\ub9ac\n", "short_description": "\uccad\uc18c\ub144\ub4e4\uc5d0\uac8c \ud0c4\uc18c\uc911\ub9bd\uc744 \uc704\ud55c \uacf5\uac04\uc744 \uccb4\ud5d8\ud558\uba70 \ud0c4\uc18c\uc911\ub9bd\uc758 \ud544\uc694\uc131\uacfc \uccad\uc18c\ub144\ub4e4\uc774 \uc2e4\ucc9c\ud560 \uc218 \uc788\ub294 \uac83\ub4e4 \uc54c\uc544\ubcf4\uace0 \ubbf8\ub798\uc758 \uc9c4\ub85c\ub97c \ud0d0\uc0c9\ud574\ubcf4\ub294 VR \ucf58\ud150\uce20\uc785\ub2c8\ub2e4."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.srw.co.kr/privacy_pop", "developer_terms_of_service_url": null, "publisher_name": "SangrokS", "support_website_url": null, "website_url": "http://srmm.kr/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7381473718565323"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"s