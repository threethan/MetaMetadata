0924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RUaigdJRA8UQ7kNvgGS9iQv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMZGasV8YknLVzsH64bVuNXFbhN7cz1sSj5RQjFwzIeQ&oe=674C30F2"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mB-urxOK1SsQ7kNvgHz_4lW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBCPkaaYKZdZ0n4Mbi3O-Lcs3_PwNndprry0BPbuivUmg&oe=674C5657"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Cdf7uUF_jYQ7kNvgEcdghC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAuaoMQJiYlAqaRAm6qFsdJM4nyUQIBZnUf_lzEb4Q05A&oe=674C5B95"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EjeVzU04mR4Q7kNvgGlckB6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADTxH7PmHXMlM_zIBR2bg_BxCccMUvmvgnfTot6ycZpw&oe=674C3702"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wdpu_MWZKIUQ7kNvgH2fgKq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqGfI4GCNR9iRZRUdEGXK_EoynD5T8hZA_tPonS99sWA&oe=674C55C4"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZyWzLDgFSWwQ7kNvgHylogC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqGWo7Gwa2i3rTsQDiXgFAZWez6TNwf1uhIINANzvfwA&oe=674C4E22"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003276_874968084382960_490444167917392231_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=imMDkSMrsucQ7