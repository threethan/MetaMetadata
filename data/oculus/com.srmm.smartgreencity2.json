797591", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982571_1154233272130924_4529887224270705141_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QkJVsg8UVvgQ7kNvgEf_LmH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYDEYhdbsOdpVn3BRRBR_B4RZM7DVhlcg9rxy3qUdkXxsw&oe=66EAA1F2"}, {"file_name": "Screenshot(1)_2560_1440.png", "id": "2100665936973153", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982680_2100665940306486_5664456920141678252_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QRdh73GJz30Q7kNvgG1xNO1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYCKM9QHIyUAbh0eStmMVX1lnVdgjqaBsn-1D6UGmaUhxA&oe=66EAC757"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image.png", "id": "368600119311127", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_368600122644460_5598028405797075028_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d9bbZ0pKfUEQ7kNvgEmZ7q0&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYA4-SerxYWXHYGiyNA0sIIAEcrRU5L4PsOWhQyZ6GUS4A&oe=66EACC95"}, "display_name": "2035 Carbon neutrality of smart green city", "keywords": [], "long_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths.\n\n1. Experience goal\n- Discover specific career topics in promising future industries and occupations against the backdrop of a smart green city in 2035\n- Explore a future path by experiencing a space for carbon neutrality\n- Learn about the need for carbon neutrality and what young people can do\n- Learn about core underlying technologies such as realistic content technology provided as an experience\n\n2. Characteristics of content\n- First-person perspective in which the experiencer becomes the main character\n- 7-step composition according to the actual experience process\n- Developed based on standing only\n- Movement and manipulation using the Oculus Controller\n- Estimated experience time of about 20 to 30 minutes\n\n3. 7-step configuration\nSTEP 1 Instructions on how to operate\nSTEP 2 Meeting with the UN Youth Delegation\nSTEP 3 Practicing carbon neutrality in urban forests\nSTEP 4 Implementation of carbon neutrality in wind power plants\nSTEP 5 Carbon neutrality practice at the East Coast carbon storage site\nSTEP 6 Think\nSTEP 7 Finishing\n", "short_description": "It is a VR content that allows teenagers to experience a space for carbon neutrality, learn about the need for carbon neutrality, what they can do, and explore future career paths."}, {"images": {"nodes": [{"file_name": "HeroCover_3000x900.png", "id": "7527653000591853", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001730_7527653007258519_8435369833685824333_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LmQ6DewUjhEQ7kNvgFw0gJ8&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYCvWVO7VjlY8fwsHnOFx58cbYhQ9PjzIOUyXCydXFxEdg&oe=66EAA802"}, {"file_name": "Landscape_2560x1440.png", "id": "1452940842279363", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031355_1452940845612696_1891464877969558457_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HEaN7Rf6fD4Q7kNvgETuzcb&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYDTeVZQyRx3OYrHIxWkw4OIoo9hq9qRORT5hsf8h9kjNw&oe=66EAC6C4"}, {"file_name": "Portrait_1008x1440.png", "id": "959181839136200", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566686_959181842469533_2388841801262298119_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MjNB99OqAikQ7kNvgHn86RC&_nc_ht=scontent.oculuscdn.com&_nc_gid=A7Ukx9P7VZcvYc5YEICdj4c&oh=00_AYBPYdWDiPGrT1UiQnF1peo8t_46bl2cltL5tCrNSID1Bw&oe=66EABF22"}, {"file_name": "Icon_512x512.png", "id": "874968081049627", "image_type": "APP_IMG_ICON", "uri": "https://sconte