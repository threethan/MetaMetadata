om/v/t64.5771-25/38974479_2038874399585417_8150134708029765562_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CZA1ASsB8noQ7kNvgHWByN-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXpemjHNB6f9NHgXTSfQaX7GtZGOftnyeH6tmOk5K-Fg&oe=66FE906D"}, {"file_name": "scr3.png", "id": "585105812693290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974826_585105816026623_5814357091966599663_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q9C9vVGnv8IQ7kNvgFLq9mt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFI6uu8CAbPi7yZW-rlzh2ITlehYyc-XcDJQzyG1rcew&oe=66FE7E9F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Jetbounce Landscape - 2560x1440.png", "id": "586942085786567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031529_586942089119900_994448641142430003_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5lbxD7FcNhIQ7kNvgF_i_8y&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDAj-E3oX_w1V1_OBWwU3yq9k6LHG3jA7v6zY27fHpuw&oe=66FE80A0"}, "display_name": "Jetbounce", "keywords": [], "long_description": "Jetbounce is a Collect-a-Thon Platformer where you collect gems and explore large open worlds.\n\nAll hand crafted levels and obstacles, designed for multiple paths.\nYou are rewarded for your exploration and boldness.\n\nIntuitive controls: press a button to activate your Jetpack, release it to jump and fly at the direction you're aiming.\n\nSpeed & Momentum is a double-edged sword, the faster you go the longer your jumps, but the more chaos it creates.\n\nIt's a challenging game that does not hold your hand, but you get good at it surprisingly fast.\n\nWill you reach the top?", "short_description": "Jetbounce is a Collect-a-Thon Platformer where you collect gems and explore large open worlds.\n\nAll hand crafted levels and obstacles, designed for multiple paths.\nYou are rewarded for your exploration and boldness.\n\nIntuitive controls: press a button to activate your Jetpack, release it to jump and fly at the direction you're aiming.\n\nWill you reach the top?"}]}, 