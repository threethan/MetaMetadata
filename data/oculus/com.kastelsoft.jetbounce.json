m/v/t64.5771-25/75221321_467423944613505_7705161120832842183_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9jNAlTOs87QQ7kNvgHpaZwI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnOsQYAtn_oqvh-o0l6mpQg&oh=00_AYCcBg1h9DGPgC-Ibv4kFJcE17UkHZauC12bOslUhRZxQQ&oe=66F6899A"}, {"file_name": "scr5.png", "id": "2038874396252084", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974479_2038874399585417_8150134708029765562_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ljuuOIpdsU4Q7kNvgHxiY1d&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnOsQYAtn_oqvh-o0l6mpQg&oh=00_AYAVXXVlW7J3_2D5AoX4g_IDhxVAQhkJtdUEp5-dFErymw&oe=66F6A76D"}, {"file_name": "scr3.png", "id": "585105812693290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974826_585105816026623_5814357091966599663_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tVwAw-5VI9cQ7kNvgEfzgzK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnOsQYAtn_oqvh-o0l6mpQg&oh=00_AYAPZdYUJxCkB8RE18n1Y7kT4jFUfuAW1WBaLlnHmHSxrQ&oe=66F6959F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Jetbounce Landscape - 2560x1440.png", "id": "586942085786567", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031529_586942089119900_994448641142430003_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8qobEaSsJxYQ7kNvgEgYQ0V&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnOsQYAtn_oqvh-o0l6mpQg&oh=00_AYBVEmKXd41yVonQBusJKpWYoYmbx74wLXNq1TFp5Y-aTg&oe=66F697A0"}, "display_name": "Jetbounce", "keywords": [], "long_description": "Jetbounce is a Collect-a-Thon Platformer where you collect gems and explore large open worlds.\n\nAll hand crafted levels and obstacles, designed for multiple paths.\nYou are rewarded for your exploration and boldness.\n\nIntuitive controls: press a button to activate your Jetpack, release it to jump and fly at the direction you're aiming.\n\nSpeed & Momentum is a double-edged sword, the faster you go the longer your jumps, but the more chaos it creates.\n\nIt's a challenging game that does not hold your hand, but you get good at it surprisingly fast.\n\nWill you reach the top?", "short_description": "Jetbounce is a Collect-a-Thon Platformer where you collect gems and explore large open worlds.\n\nAll hand crafted levels and obstacles, designed for multiple paths.\nYou are rewarded for your exploration and boldness.\n\nIntuitive controls: press a button to activate your Jetpack, release it to jump and fly at the direction you're aiming.\n\nWill you reach the top?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1wv8p_ZmThhlgjrFFQX-9JzDVbA1FcMdDUYqefYzExHs", "developer_terms_of_service_url": null, "publisher_name": "Kastel Software", "support_website_url": null, "website_url": "https://discord.gg/eMKhfBmR8E", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "251431297138265"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1627668954739783"}, {"status": "PUBLISHED", "id": "533058315214904"}, {"status": "PUBLISHED", "id": "427180075624529"}, {"status": "PUBLISHED", "id": "1137727443698397"}, {"status": "PUBLISHED", "id": "350469833694202"}]}, "baseline_offer": {"id": "1627668954739783"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722558803, "status": "PUBLISHED", "id": "1627668954739783"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_result