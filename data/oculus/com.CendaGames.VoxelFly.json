com/v/t64.5771-25/38974912_618333235333232_4534300208221126656_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QJ_A-GT9TREQ7kNvgEaw5XR&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDtWKKFQFp8NinzNK2U1yLOZ1Wzb88rgbFYH8D4bPX8yw&oe=67013842"}, {"file_name": "migrated_image.png", "id": "2750941751693197", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974740_321287435228559_4058565170677415936_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6IHHq7N0Z7UQ7kNvgHYM8IS&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDOSbUVMI3tYt9fCpgWH3IpJcDbAipZiQqbAbsiQTJv1g&oe=67012148"}, {"file_name": "migrated_image.png", "id": "2638963979659279", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974490_291274781715627_3037063437625589760_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z8Le58VB0jEQ7kNvgH7dt08&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCwGgPkHcL6yyJjVKeITr7e9F-7dSK_nK7dR2olaJbr-A&oe=67014202"}, {"file_name": "migrated_image.png", "id": "582531832343037", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982457_553270455117852_8839861251510108160_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MrgSamjdVNkQ7kNvgHP2acT&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBRGnYX-KCFyDSvgKkaWjrdfVccszvVMX7-wm0e9U3bYw&oe=67012FC1"}, {"file_name": "migrated_image.png", "id": "218588529517542", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974561_191450348413557_7027399530932862976_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eh_FEqAvBN0Q7kNvgGt9gtk&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCEtLMv_pGEWqZeVd13efcTkMS_iYFNLYtKmUFGbuzo1w&oe=67011D0C"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Voxel Fly", "keywords": ["fly", "fight", "lowpoly", "speed", "enemy"], "long_description": "\"It\u2019s fairly intense which makes it a great experience for VR\" - AndroidAuthority\n\nPlay missions to unlock new machines. Beat the record in this impossible, endless game. Join to the events and become the best in the leaderboards! Avoid of the enemies or simply destroy them. You can choose from many modes:\n\nMODES\nExplorer - Slow speed with many enemies.\nMadness - Mad race with fast speed and less enemies.\nDestroyer - Crash them all! Your enemies has no chance.\nAttacker - Destroy enemies and objects by fire!\nCannoneer - Just fire!\nHorizon - Super speed with left/right turn\nDefender - They shall not pass :)\n\nFEATURES\n- 70 missions (still growing)\n- 30+ machines\n- 2 events\n- You get several games in the one\n- Design your own levels with Customize option\n- Set difficulty for all play modes\n- 72Hz for stable image\n- Set resolution for optimal performance\n\nFollow @CendaGames to get news!\nwww.discord.cenda.cz", "short_description": "Fly, fight and survive with your voxel machine."}]}, "developer_name": "\u010cen\u011bk \u0160trichel", "developer_privacy_policy_url": "http://cenda.cz/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "\u010cen\u011bk \u0160trichel", "support_website_url": "http://cenda.cz/games/", "website_url": "http://cenda.cz/voxelfly/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "zh_CN", "pt", "es", "ru"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5161016940627257"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974562_2229853484007439_5334505473628438528_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc