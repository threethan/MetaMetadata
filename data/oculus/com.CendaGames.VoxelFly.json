17578092", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422381_1130775620911425_9081744549763873311_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G2-1h-DVIVYQ7kNvgFWNU-Q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDH3WBEPIYdzaxtdUpfetFiOZZmw223Yc9lHhd0KuXjCA&oe=67504AE4"}, {"file_name": "Screen_5.png", "id": "1090538558308093", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86805183_1090538561641426_3617847857434066078_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DPwYvESfLkoQ7kNvgGf58Y2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCp6Vv0_tUm9L7HfHgYEfEykQfOoxto_Y5_O2h-8fVe6g&oe=675041EF"}, {"file_name": "Screen_6.png", "id": "827219538588552", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367591_827219545255218_8862787728097512893_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9F-DNS7RYzoQ7kNvgGQ_MWf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZuZNEhSor63ANfJ03zFE0i0daipA7pB1ulVkRzxRdTQ&oe=675035CF"}, {"file_name": "dav01_1.4.1.png", "id": "655606329371405", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210393_655606332704738_8644400852019346204_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6bPNsmvIAhUQ7kNvgGmZtLV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0HV6FQqF6TK0R3zJXrFZutmVx_U6sbE_zDNMfVt-WVw&oe=6750399F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Banner 2560x1440 upraveny text.png", "id": "666483034885126", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340708_666483038218459_7006348042051050796_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qG2olv5cmb8Q7kNvgGYrhOV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAWOkqsfVaB1CYvfgSo2SLRzdehvVOlYC_cJ4f-HFVSWw&oe=67505C81"}, "display_name": "Voxel Fly", "keywords": ["voxel", "plane", "fight", "fly", "speed"], "long_description": "\"It\u2019s fairly intense which makes it a great experience for VR\" - AndroidAuthority\n\nPlay missions to unlock new machines. Beat the record in this impossible, endless game. Join to the events and become the best in the leaderboards! Avoid of the enemies or simply destroy them. You can choose from many modes:\n\nMODES\nExplorer - Slow speed with many enemies.\nMadness - Mad race with fast speed and less enemies.\nDestroyer - Crash them all! Your enemies has no chance.\nAttacker - Destroy enemies and objects by fire!\nCannoneer - Just fire!\nHorizon - Super speed with left/right turn\nDefender - They shall not pass :)\n\nFEATURES\n- 70 missions (still growing)\n- 30+ machines\n- 2 events\n- You get several games in the one\n- Design your own levels with Customize option\n- Set difficulty for all play modes\n- Set resolution for optimal performance\n\nFollow @CendaGames to get news!\nwww.discord.cenda.cz", "short_description": "Fly, fight and survive with your voxel machine."}]}, "developer_name": "\u010cen\u011bk \u0160trichel", "developer_privacy_policy_url": "https://cenda.cz/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "\u010cen\u011bk \u0160trichel", "support_website_url": "http://cenda.cz/", "website_url": "http://cenda.cz/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "FLYING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7944213482364482"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https: