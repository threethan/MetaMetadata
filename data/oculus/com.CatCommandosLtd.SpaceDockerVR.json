569456197643_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQBn-c2ntNwQ7kNvgHkNGLg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCmcGKJZKbXuSeRbvYMSHfVs185kCSpBIC3uQ3kHBZOeA&oe=676FE5FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail_Quest.png", "id": "212483057592508", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75367594_212483060925841_4649205383762646054_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TyDmUDt_IA0Q7kNvgGwBwCm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcm59MtNnxZ9GNrxNUKARKfUsTdoqUJM1yKJMAX-pPkQ&oe=676FE7F6"}, "display_name": "Space Docker VR", "keywords": [], "long_description": "A hardcore space-flight simulator for VR! Get in the cockpit, pilot a spacecraft, and navigate hazardous environments on a journey to become an expert docker!\n\n\"There's no drag in space\" -- Realistic Newtonian physics means that 'docking' becomes a skilful task, as you learn to master your momentum.\n\nFeatures\n- Career Mode: authored missions with unique twists to train and test your docking abilities\n- Random Jobs Content: Weekly missions, as well as 'on-demand' procedural work orders\n- Race Mode: push your flying skills to the max\n- Customizable virtual cockpit controls\n- Compete via Friends/Global leaderboards\n- Unlock flair and upgrades for your cockpit", "short_description": "A hardcore space-flight simulator for VR! Get in the cockpit, pilot a spacecraft, and navigate hazardous environments on a journey to become an expert docker!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.catcommandos.com/sdvr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Cat Commandos Ltd", "support_website_url": null, "website_url": "https://www.catcommandos.com/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"},