836847_551249680984584357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bSgQA6yCcD0Q7kNvgHrli23&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ-TThf8EZUmtTpj5Fhdb7q&oh=00_AYAWp11FeQ_II1QOMG9jNafe5j1aCMzsBjA0l55jyj5j0w&oe=66ED4F14"}, {"file_name": "Chickens.png", "id": "3896124280411693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_3896124283745026_3558838336997043691_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ko_yYsJj-KsQ7kNvgE3I9Qt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ-TThf8EZUmtTpj5Fhdb7q&oh=00_AYC_Ptwr3B1aSsHZiWXsDfc0H6GmQesqq9MJYOW-yIZ8aA&oe=66ED76D3"}, {"file_name": "Pond.png", "id": "193987019092818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_193987022426151_7281453274839913205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h-cEFz7Bh8gQ7kNvgHwfbf8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ-TThf8EZUmtTpj5Fhdb7q&oh=00_AYC4MGMuOetLijy1yeFFsBBecwJRUzGPesIyi7agHK34LQ&oe=66ED4A62"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "321548425962373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_321548429295706_5617240590477412159_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qz1Lnmyvi30Q7kNvgFdCt6g&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ-TThf8EZUmtTpj5Fhdb7q&oh=00_AYBZnTm_9Kvyp41YoF6fWWO4O32g8srMqEIAMSjbdiUw4w&oe=66ED4BF3"}, "display_name": "Crop Craze: Farming Simulator", "keywords": [], "long_description": "In Crop Craze, PicoPlanetDev's new VR farming simulator, you can buy seeds, grow crops, and sell them. Experience a serene view of the countryside and take a break from farming to roast marshmallows by the fire pit. Upgrade your farm to boost profit, buy animals for a bonus, and add a greenhouse. Purchase more land and expand your farm, while managing your money and having fun!\n\nAvailable now on Oculus Quest. Get Crop Craze and enjoy the excitement today!\n\nCrop Craze is developed and supported by PicoPlanet Developing, an indie game developer.", "short_description": "Crop Craze is the first fully immersive Virtual Reality farming simulator. Plant crops, feed animals, complete upgrades, and more in this brand-new game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://picoplanetdev.tk/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "PicoPlanet Developing", "support_website_url": "https://picoplanetdev.tk/contact.html", "website_url": "https://picoplanetdev.tk/farm-game.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["STRATEGY", "SIMULATION", "FOOD"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4906721466051315"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6026891034003340", "version": "1.3.2"}, "id": "274330704036389", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5617270104965437", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6026891034003340"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "274330704036389"}]}, "change_log": null, "created_date": 1619134389, "id": "6026891034003340", "