836847_551249680984584357_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IULZ0WI2ZE8Q7kNvgG-fpLK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYDf509JAvwwtujtuSOPuVd316QVQVfwGU4z264Nt0u40Q&oe=66F29514"}, {"file_name": "Chickens.png", "id": "3896124280411693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_3896124283745026_3558838336997043691_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T43WbcskaYkQ7kNvgEy9LvO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYD56Y3iy-uQ9vuJ86zKSKRUvQF3JPE1vzpHpwN6DBKLGA&oe=66F2BCD3"}, {"file_name": "Pond.png", "id": "193987019092818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_193987022426151_7281453274839913205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzWhfSEmMxQQ7kNvgE6t_g1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYCupihyMemJclCcqpl_8CDVQeupweHC6LDTxGe0dIT_XQ&oe=66F29062"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "321548425962373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974853_321548429295706_5617240590477412159_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=30a3P35Ih_gQ7kNvgGQ0eLR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYANFp-AV8wW-AEYdwGIMW4Bs2VxxV2aeqaDW0S9Kesu6A&oe=66F291F3"}, "display_name": "Crop Craze: Farming Simulator", "keywords": [], "long_description": "In Crop Craze, PicoPlanetDev's new VR farming simulator, you can buy seeds, grow crops, and sell them. Experience a serene view of the countryside and take a break from farming to roast marshmallows by the fire pit. Upgrade your farm to boost profit, buy animals for a bonus, and add a greenhouse. Purchase more land and expand your farm, while managing your money and having fun!\n\nAvailable now on Oculus Quest. Get Crop Craze and enjoy the excitement today!\n\nCrop Craze is developed and supported by PicoPlanet Developing, an indie gam