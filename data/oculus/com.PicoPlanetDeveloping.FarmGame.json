.png", "id": "3896124280411693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974769_3896124283745026_3558838336997043691_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T43WbcskaYkQ7kNvgEy9LvO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYD56Y3iy-uQ9vuJ86zKSKRUvQF3JPE1vzpHpwN6DBKLGA&oe=66F2BCD3"}, {"file_name": "Pond.png", "id": "193987019092818", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974750_193987022426151_7281453274839913205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XzWhfSEmMxQQ7kNvgE6t_g1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYCupihyMemJclCcqpl_8CDVQeupweHC6LDTxGe0dIT_XQ&oe=66F29062"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape-Trademark.png", "id": "1465782734237201", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395588_1465782737570534_1852866444084030374_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_l3SWH3PesQ7kNvgEXoUdf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYD_lzmHHw78zso3VEUNqIXukobTq_H_qdWw4FhB7fPZQA&oe=66F2A856"}, "display_name": "Crop Craze", "keywords": [], "long_description": "In Crop Craze, PicoPlanetDev's new VR farm simulator, you can buy seeds, grow crops, and sell them. Experience a serene view of the countryside and take a break from farming to roast marshmallows by the fire pit. Upgrade your farm to boost profit, buy animals for a bonus, and add a greenhouse. Purchase more land and expand your farm, while managing your money and having fun!\n\nAvailable now on Oculus Quest. Get Crop Craze and enjoy the excitement today!\n\nCrop Craze is developed and supported by PicoPlanet Developing, an indie game developer.", "short_description": "Crop Craze is the first fully immersive Virtual Reality farm simulator. Plant crops, feed animals, complete upgrades, and more in this brand-new game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://picoplanetdev.tk/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "PicoPlanet Developing", "support_website_url": "https://picoplanetdev.tk/contact.html", "website_url": "https://picoplanetdev.tk/farm-game.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FOOD", "SIMULATION", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6247472395290237"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974497_232562859629596_8472566014033538153_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kNU71wPhzpQQ7kNvgGHYTyK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWFDZZFmr2-CbhNka-KFwO9&oh=00_AYBsMUN1RSMaILY40Yckrq5mG_1usbIyshO_Ff7YClhivw&oe=66F2AF15"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Crop Craze", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Education", "id": "879473995923081"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1615342182, "lastRevision": {"nodes": [{"id": "259458555560409", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5617270104965437", "is