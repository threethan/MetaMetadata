Hqa0tkZzq2_8PtYiO8YYavk4WxqHcA&oe=66CDC5E5"}, {"file_name": "AJAX_Screenshot3.png", "id": "330518941665470", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003273_330518948332136_5043370396625167176_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=co9_Ycy6J24Q7kNvgETwmdA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPM8xqCrG_PtzhSN6Fx6MDHg2G61R04rLFVzr6y0Tv0w&oe=66CDA653"}, {"file_name": "AJAX_Screenshot4.png", "id": "688007205201335", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_688007208534668_2257958446064248023_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G4Dl-cQ7jvwQ7kNvgFucx0r&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTnrlCG84rc4clYqsImFWw9IPBENz39Sqjjz3A4ARSnw&oe=66CDCB00"}, {"file_name": "AJAX_Screenshot5.png", "id": "190513696167216", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001687_190513699500549_814425097474291908_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qxptkgWpAcIQ7kNvgGgFizh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDm1lKKK4dZ5_WVSuVUP2-d87dcX6AwLib77sA4HYcrHQ&oe=66CDB893"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_cover.png", "id": "1195823440879067", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_1195823444212400_5305135154571797175_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7dwGhBepX8Q7kNvgGJYv5_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQ8SeC9IhZhF_RxogZxmps3IcmTusbC25aeBO-vVjbSQ&oe=66CDC1E2"}, "display_name": "Ajax All Powerful", "keywords": [], "long_description": "Ajax (Henry Winkler) is a foul-mouthed, double-crossing genie addicted to the human souls he collects in exchange for granting wishes to gullible humans. However, something is different about the seemingly-naive little girl who has rubbed his lamp this time. For one thing, she\u2019s hired a strait-laced lawyer (Chris Parnell) to negotiate her wishes, and they might have a trick or two buried in the new contract\u2019s legalese\u2026.\n\nAJAX ALL POWERFUL is an innovative VR comedy utilizing behind-the-scenes interactive triggers to create a fluid world of changing sizes and perspectives as the story progresses from the lamp to the real world, and beyond. Starring comedy legends Henry Winkler (HAPPY DAYS, ARRESTED DEVELOPMENT, BARRY) and Chris Parnell (RICK AND MORTY, SNL) and written and directed by award-winning VR creator Ethan Shaftel (KAIJU CONFIDENTIAL, EXTRAVAGANZA).\n\n2020 Official Selection at Tribeca Film Festival, Annecy Animation Festival, and the Venice International Film Festival.", "short_description": "Ajax (Henry Winkler) is a foul-mouthed genie addicted to the human souls he collects after tricking gullible masters. But something is different about the little girl who found his lamp this time: she's hired a lawyer to negotiate her wishes. 2020 Official Selection at Tribeca Film Festival, Annecy Animation Festival, and the Venice International Film Festival."}]}, "developer_name": "easyAction", "developer_privacy_policy_url": "https://www.privacypolicies.com/privacy/view/aea7d966b01db45db4b606d3d2575d75", "developer_terms_of_service_url": null, "publisher_name": "VeeR", "support_website_url": "https://veervr.zendesk.com/hc/en-us", "website_url": "http://AjaxAllPowerful.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "323034106433879"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_suppor