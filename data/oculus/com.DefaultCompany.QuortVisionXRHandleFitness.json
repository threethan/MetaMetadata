a0a&_nc_ohc=ojL0pUKfvuIQ7kNvgFt9oZi&_nc_ht=scontent.oculuscdn.com&oh=00_AYBek7WO43W0FqRT5G1di5NcaYSp8PF0Lz0UZH6k51TKhg&oe=66FFE546"}, {"file_name": "QV18.png", "id": "249452961535866", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_249452968202532_5863557633604704976_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=alsoN7iPd7sQ7kNvgFapxI4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAk6gVkU8kdknG1L4sW8lwEgME3fdl7qmJzTwtxZIgmlw&oe=66FFD668"}, {"file_name": "QV21.png", "id": "387772080524134", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974589_387772083857467_7028117611996849228_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQubZ5cUPMQQ7kNvgElPkPh&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVwXQRJe8BEr90iPDma3gnxmQbEowuTR7h_OcZPdWSCg&oe=66FFCE9B"}, {"file_name": "QV23.png", "id": "1723451734815336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75557061_1723451738148669_8104508832040679371_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=987BG7nHUk4Q7kNvgFC1H1W&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEM1-RQWAJAb_3Cm14pvCA9uwjmRgy2gM1pVWKlUDoFw&oe=66FFBBBF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QV20.png", "id": "7123274751082739", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974789_7123274754416072_2642720925600636115_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yr-rGjTWOgkQ7kNvgHjTwy-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjKNqObXjcuvJC86KbHaMm5Xz7FG4xoQFuGnBH8ue_0g&oe=66FFE66C"}, "display_name": "Qourt Vision XR", "keywords": [], "long_description": "Requiring a real basketball to play, Qourt Vision XR is a first-of-its-kind mixed reality training tool specifically engineered for basketball players looking to improve their ability to make spilt-second decisions. Enhance your cognitive skills like never before by mastering offensive principles such as: attacking the top foot, assessing a closeout, splitting-the-screen, rolling off the inside shoulder, knowing when to euro step, and much more. Get the mental and physical reps needed to build true self-confidence while immersing yourself in the future of film study and player-development.\ud83d\udcc8\n\nSEE QUICK and REACT FAST with interactive drills focused on\ud83d\udcaa: \n\no\tChange-Of-Pace\no\tChange-Of-Direction\no\tFootwork\no\tBalance\no\tFluidity\no\tRhythm\no\tHand/ Eye Coordination\no\tAgility\no\tStrength and Conditioning\no\tCreating Space/ Separation\n\nMAKE YOUR MIND SWEAT with signature exercises designed for\ud83e\udde0:\n\no\tDecision-Making\no\tReaction Time\no\tPattern Recognition\no\tAttention Shifting\no\tMulti-Tasking\no\tAnticipation\no\tInhibition\no\tVisual Processing\no\tProblem-Solving\no\tProprioception\n\nSay goodbye to plastic cones, chairs, and trashcans.\ud83d\udeab\n\nREAL WORKOUTS. UNREAL DECISIONS.\ud83c\udfc0\ud83c\udfc6 #QourtVisionXR", "short_description": "Requiring a real ball to play, Qourt Vision XR trains cognitive skills such as decision making, reaction time, anticipation, hand/ eye coordination, pattern recognition, and more through real in-game simulations for the ultimate interactive basketball workout. For more information visit us at: https://www.handlefitness.com"}]}, "developer_name": "Handle Fitness", "developer_privacy_policy_url": "https://www.handlefitness.com/faq", "developer_terms_of_service_url": null, "publisher_name": "RCM Productions, Inc.", "support_website_url": null, "website_url": "https://www.handlefitness.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", 