id=6e7a0a&_nc_ohc=CWfXKJeZiq8Q7kNvgGWn8OS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBz710AvEEsMEZO-54Q2VKrsKYcQK7Orsj5V4jwbHF4IQ&oe=66D706C6"}, {"file_name": "QV18.png", "id": "249452961535866", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974528_249452968202532_5863557633604704976_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F-C6Nw-j-38Q7kNvgEodfCu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLiHXMqknEykwERe98o1pqXFtMiN4SnRZk9YU4uG01PQ&oe=66D6F7E8"}, {"file_name": "QV21.png", "id": "387772080524134", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974589_387772083857467_7028117611996849228_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UZU_GptCquQQ7kNvgFllPo7&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjSNZFnAXt0r8Mg8QWgWcrxT_XShaBzrmKXt13YgNS7Q&oe=66D6F01B"}, {"file_name": "QV23.png", "id": "1723451734815336", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75557061_1723451738148669_8104508832040679371_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jOlsk1QMPSAQ7kNvgHH0UuR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCooKa9EG7qhdRg9C2v9XO_Y1ToQnZy896NCRZ_8suGBg&oe=66D6DD3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QV20.png", "id": "7123274751082739", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974789_7123274754416072_2642720925600636115_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kLJZK5_7YRYQ7kNvgHnMEYa&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhhs0GORIyCg4C9cLq3mLEknsxVRKsxeqnQ2CADh27OQ&oe=66D707EC"}, "display_name": "Qourt Vision XR", "keywords": [], "long_description": "Requiring a real basketball to play, Qourt Vision XR is a first-of-its-kind mixed reality training tool specifically engineered for basketball players looking to improve their ability to make spilt-second decisions. Enhance your cognitive skills like never before by mastering offensive principles such as: attacking the top foot, assessing a closeout, splitting-the-screen, rolling off the inside shoulder, knowing when to euro step, and much more. Get the mental and physical reps needed to build true self-confidence while immersing yourself in the future of film study and player-development.\ud83d\udcc8\n\nSEE QUICK and REACT FAST with interactive drills focused on\ud83d\udcaa: \n\no\tChange-Of-Pace\no\tChange-Of-Direction\no\tFootwork\no\tBalance\no\tFluidity\no\tRhythm\no\tHand/ Eye Coordination\no\tAgility\no\tStrength and Conditioning\no\tCreating Space/ Separation\n\nMAKE YOUR MIND SWEAT with signature exercises designed for\ud83e\udde0:\n\no\tDecision-Making\no\tReaction Time\no\tPattern Recognition\no\tAttention Shifting\no\tMulti-Tasking\no\tAnticipation\no\tInhibition\no\tVisual Processing\no\tProblem-Solving\no\tProprioception\n\nSay goodbye to plastic cones, chairs, and trashcans.\ud83d\udeab\n\nREAL WORKOUTS. UNREAL DECISIONS.\ud83c\udfc0\ud83c\udfc6 #QourtVisionXR", "short_description": "Requiring a real ball to play, Qourt Vision XR trains cognitive skills such as decision making, reaction time, anticipation, hand/ eye coordination, pattern recognition, and more through real in-game simulations for the ultimate interactive basketball workout. For more information visit us at: https://www.handlefitness.com"}]}, "developer_name": "Handle Fitness", "developer_privacy_policy_url": "https://www.handlefitness.com/faq", "developer_terms_of_service_url": null, "publisher_name": "RCM Productions, Inc.", "support_website_url": null, "website_url": "https://www.handlefitness.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25819056944360546"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "4470478159844141"}]}, "baseline_offer": {"id": "4470478159844141"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710175740, "status": "PUBLISHED", "id": "4470478159844141"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27133948059538088", "version": "1.21"}, "id": "24909791128669474", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25622204947379081", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27133948059538088"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "24909791128669474"}]}, "change_log": null, "created_date": 1722714721, "id": "27133948059538088", "version": "1.21", "version_code": 31, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "25622204947379081", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "27133948059538088"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "24909791128669474"}]}, "change_log": null, "created_date": 1722713181, "id": "27133770302889197", "version": "1.2", "version_code": 30, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"no