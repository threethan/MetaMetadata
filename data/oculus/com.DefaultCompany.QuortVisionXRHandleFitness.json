.oculuscdn.com&oh=00_AYCZqrtjjc9mcPmkAU7Ty5_Ezu7VnEbmn7o9a-Gmsk6Cjg&oe=67839C34"}, {"file_name": "QV24.png", "id": "1641316120009217", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031603_1641316123342550_643504991352359473_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GYvoOgLb9UkQ7kNvgHesZKy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrUF5YNRw-Oso_9QBSIzDhevZTnB-cIl9L7vCLVYotyQ&oe=6783BB46"}, {"file_name": "QV18.png", "id": "249452961535866", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974528_249452968202532_5863557633604704976_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iSAsEl77rNYQ7kNvgF07vnj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmAgkqGWE4G4xLR-fOkm-whznpWtSK2khNnC3wug8hCw&oe=6783AC68"}, {"file_name": "QV21.png", "id": "387772080524134", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974589_387772083857467_7028117611996849228_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gdtXS-gT5RQQ7kNvgGYFpz9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkWTUa4YZoxFS_BFdY66QSAxId6R8F8OSAoda-X6_KAQ&oe=6783A49B"}, {"file_name": "QV23.png", "id": "1723451734815336", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75557061_1723451738148669_8104508832040679371_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PqGjiwRr468Q7kNvgE3QqyB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBq1EcSvxCQy-DPMCUcsldCJh23UO2INBUw66eEEDbuOw&oe=678391BF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "QV20.png", "id": "7123274751082739", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974789_7123274754416072_2642720925600636115_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4CdJ-45LAYQ7kNvgEndPUq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCZXFQZclS7L5RDp27T1tZU5i4QTmwU16nl8VwSS4HKw&oe=6783BC6C"}, "display_name": "Qourt Vision XR", "keywords": [], "long_description": "Requiring a real basketball to play, Qourt Vision XR is a first-of-its-kind mixed reality training tool specifically engineered for basketball players looking to improve their ability to make spilt-second decisions. Enhance your cognitive skills like never before by mastering offensive principles such as: attacking the top foot, assessing a closeout, splitting-the-screen, rolling off the inside shoulder, knowing when to euro step, and much more. Get the mental and physical reps needed to build true self-confidence while immersing yourself in the future of film study and player-development.\ud83d\udcc8\n\nSEE QUICK and REACT FAST with interactive drills focused on\ud83d\udcaa: \n\no\tChange-Of-Pace\no\tChange-Of-Direction\no\tFootwork\no\tBalance\no\tFluidity\no\tRhythm\no\tHand/ Eye Coordination\no\tAgility\no\tStrength and Conditioning\no\tCreating Space/ Separation\n\nMAKE YOUR MIND SWEAT with signature exercises designed for\ud83e\udde0:\n\no\tDecision-Making\no\tReaction Time\no\tPattern Recognition\no\tAttention Shifting\no\tMulti-Tasking\no\tAnticipation\no\tInhibition\no\tVisual Processing\no\tProblem-Solving\no\tProprioception\n\nSay goodbye to plastic cones, chairs, and trashcans.\ud83d\udeab\n\nREAL WORKOUTS. UNREAL DECISIONS.\ud83c\udfc0\ud83c\udfc6 #QourtVisionXR", "short_description": "Requiring a real ball to play, Qourt Vision XR trains cognitive skills such as decision making, reaction time, anticipation, hand/ eye coordination, pattern recognition, and more through real in-game simulations for the ultimate interactive basketball workout. For more information visit us at: https://www.handlefitness.com"}]}, "developer_name": "Handle Fitness", "developer_privacy_policy_url": "https://www.handlefitness.com/faq", "developer_terms_of_service_url": null, "publisher_name": "RCM Productions, Inc.", "support_website_url": null, "website_url": "https://www.handlefitness.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topic