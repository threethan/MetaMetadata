31171480358_5026729370863448103_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vTa1Nzai0FMQ7kNvgGTrgzM&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBg_PVS7WyZiFzPOXQFquCsmaBD2X2r8Inv7HhT3xj7Eg&oe=6724B624"}, {"file_name": "Escape!VR - The Basement (9).png", "id": "1074067037200596", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974834_1074067040533929_6623276952308228814_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RIwxRHHJ-G4Q7kNvgGUF29y&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDjbVvk5zte9WKQ2cuzmMAasIAttY1K85-nTKFuUkVC3Q&oe=6724B772"}, {"file_name": "Escape!VR - The Basement (1).png", "id": "954330359393781", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75593948_954330362727114_5990391067909497313_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fkORKd12OecQ7kNvgFtrs6n&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAZ0Rdjm-tClzXqMYcTKBRPUIMGV6o-ks-mY4EQVi33DA&oe=6724B437"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "vlcsnap-2020-07-19-15h38m55s089.png", "id": "736791198517954", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031532_736791201851287_4149678069899420458_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TpB-udCl0ysQ7kNvgFp3A_-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAXvAJfQFMzbOANSZg1-P7e-Bj8TvOF_DC8rWWcJXnyyw&oe=6724A5C6"}, "display_name": "EscapeVR: The Basement", "keywords": ["escape", "escaperoom", "roomescape", "puzzle", "logic"], "long_description": "EscapeVR: The Basement is an 'Escape The Room' genre game which was inspired by real-life escape games and written from the ground up as a room-scale virtual reality experience.\n\nExplore the environment, solve puzzles, discover useful items, investigate clues, and find your way through a total of seven rooms in three areas to -hopefully- escape the basement!\n\n- Solve over a dozen puzzles, which includes smaller ones like finding keys or codes up to large ones which involve complex interactions with daunting machinery.\n\n- Explore three distinct areas with seven rooms, a total of 130 square meters, and more than 200 items to interact with. The game is designed for room scale and features a teleporting system.\n\n- In case you get stuck, a built-in hint system provides you with clues. You\u2019ll also get in-game statistics about your performance, and there are achievements to unlock!\n\nWill you take on the challenge? Will you manage to escape the basement?", "short_description": "You find yourself locked in the cell of an unknown basement with nothing else than a bed and a toilet. Can you escape? Explore the environment, solve puzzles, investigate clues, and find your way through a total of 7 rooms to -hopefully- escape the basement of this VR escape room game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.escapevr.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Five Mind Creations UG (haftungsbeschr\u00e4nkt)", "support_website_url": null, "website_url": "https://www.escapevr.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "ru", "zh_CN", "zh_TW", "zh_HK", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8223548827681853"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031