0070031_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8TlEJ7A_tcQ7kNvgGw4yZ2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABl4GYT55jGAFpuVJkYpA81&oh=00_AYD7kQQ0XoqRimRD3dUAKsrf7nKoHH_G-1QleZiVsF9Xew&oe=66E9786E"}, {"file_name": "wolves_screenshot_2.png", "id": "1055378388254303", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982452_1055378391587636_301160106100217480_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KgsJRTBU7DIQ7kNvgG2zqRB&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABl4GYT55jGAFpuVJkYpA81&oh=00_AYAKZsBtfBNuR7UqgG7Umb3P_cEui_2QRa9rAmFMaxz5TA&oe=66E96E67"}, {"file_name": "wolves_screenshot_1.png", "id": "962449217609498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75241700_962449220942831_2995649587859815741_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YvdmCboKDAYQ7kNvgHQR5MO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABl4GYT55jGAFpuVJkYpA81&oh=00_AYBDb9tryA56GjVKT-tZT8h0XBTVLO0P9Z2pAHv7wZS6_g&oe=66E979F6"}, {"file_name": "wolves_screenshot_3.png", "id": "838008120333322", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036673_838008123666655_8104515146200479989_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zdgjUuXsu54Q7kNvgG0vjiP&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABl4GYT55jGAFpuVJkYpA81&oh=00_AYC50x87d-ASJiT8dp3z3GVkI0wPHtb8nauK8Jhl6YdHhA&oe=66E98497"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Cover_Lucy.png", "id": "779081022930634", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75303839_779081026263967_7131777706299187434_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gsk-7J-rQJsQ7kNvgEKuJ7B&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABl4GYT55jGAFpuVJkYpA81&oh=00_AYC8E88YJYAFP64IAhLgKb0f8vRBzq6XrW0pWmGDsYoyMg&oe=66E981D5"}, "display_name": "Wolves in the Walls", "keywords": ["Lucy", "Gaiman", "Emmy", "VB", "Adaptation"], "long_description": "What makes the noises we can\u2019t explain? Eight-year-old Lucy is convinced it\u2019s wolves. Her family is not so sure.\n\nBut something has been stealing Mom\u2019s jam, glitching Brother\u2019s games, and howling over Dad\u2019s music. Lucy desperately wants to warn them all, and she needs your help. Will you believe her?\n\nBecause when the wolves do, in fact, come out of the walls, it\u2019s all over.\n\nHelp her discover what's hiding inside the walls of her house in this ~40 minute interactive fable based on the book by Neil Gaiman and Dave McKean. Capture proof with photographs, search for clues with a magnifying glass, and defend Lucy\u2019s pig puppet. \n\nWinner of the 2019 Primetime Emmy\u00ae for Outstanding Innovation in Interactive Media.\n\nIf you are especially curious about Lucy and her world you can follow her on Instagram: @lucyandpigpuppet", "short_description": "What makes the noises we can\u2019t explain? Eight-year-old Lucy is convinced it\u2019s wolves. Her family is not so sure.\n\nHelp her discover what's hiding inside the walls of her house in this ~40 minute interactive fable based on the book by Neil Gaiman and Dave McKean.\n\nIf you are especially curious about Lucy and her world you can follow her on Instagram: @lucyandpigpuppet"}]}, "developer_name": "Fable Studio, Inc.", "developer_privacy_policy_url": "https://www.thesimulation.co/privacy", "developer_terms_of_service_url": "https://fable-studio.com/legal/wolves-eula", "publisher_name": "Fable Studio, Inc.", "support_website_url": "https://fable-studio.com/", "website_url": "https://fable-studio.com/wolves-in-the-walls", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1499583320412802"}, {"id": "661880351198839"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processo