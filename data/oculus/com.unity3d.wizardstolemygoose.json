9036_1593967080633330_5809885781233238016_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yOlK_QZ52AYQ7kNvgHFSM9-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoAeBfhwl4byJq1EBvlgXr8KKXOsww9G6hwEpFgH1XQA&oe=66F7DDCF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Wizard Stole My Goose", "keywords": ["puzzle", "bouncing", "wizard", "stole", "goose"], "long_description": "An evil Wizard has stolen your magical goose! \nBut he made a mistake... He dropped his talisman of teleportation! Equipped with the Wizard's Talisman, solve physics-based puzzles above the clouds by bouncing the teleportation orb off of the floating platforms.\nDo you have what it takes to save the goose?", "short_description": "A Puzzle-Platforming adventure game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.tepia.co/", "developer_terms_of_service_url": "https://www.tepia.co/", "publisher_name": "Tepia Co", "support_website_url": null, "website_url": "https://www.tepia.co/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "CASUAL", "NARRATIVE", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "225660843112481"}, "review_messages": ["", "Please update the Logo Transparent artwork asset to meet Oculus Store guidelines. The Oculus Store guidelines can be found here: https://static.oculus.com/documents/oculus-store-art-guidelines.pdf", "", "The current Back Button behavior is incorrect. Currently, both long and short presses of the back button from the Main Menu take the user to the Return to Oculus Home menu. Instead, a short-press should go to that menu, while a long press should bring up the Universal Menu. In addition, when the user is in the game state, a short and long press are both interpreted to bring the user to the Main Menu. Instead, a short press should bring the user to the Main Menu, while he long press should bring up the Universal Menu. Another way to phrase this would be to say the -in all cases- a long press must bring up the Universal Menu, and not perform any other actions.", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482393_814597168678395_2848440585793044480_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yHzsnyxjI9YQ7kNvgEpZzZf&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6CPjkbtDoCQYGMuFursCwuMoHxRHzIjo0gfa8u_gTtA&oe=66F7FC88"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wizard Stole My Goose", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1493190000, "lastRevision": {"nodes": [{"id": "1000433473390568", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1365813440159412", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "781034798717092"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2780152392069391", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449036_1439089549443426_2055912960974389248_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YkLYq-WBznoQ7kNvgFRA_-b&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5e_cpKc2IwA_4g8HhwQSWFdCOORTX6LUJ9WB3rkrMkw&oe=66F7FA9C"}, {"file_name": "migrated_image.png", "id": "825765274601672", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.