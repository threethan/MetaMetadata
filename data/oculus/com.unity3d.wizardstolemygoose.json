112481"}, "review_messages": ["", "Please update the Logo Transparent artwork asset to meet Oculus Store guidelines. The Oculus Store guidelines can be found here: https://static.oculus.com/documents/oculus-store-art-guidelines.pdf", "", "The current Back Button behavior is incorrect. Currently, both long and short presses of the back button from the Main Menu take the user to the Return to Oculus Home menu. Instead, a short-press should go to that menu, while a long press should bring up the Universal Menu. In addition, when the user is in the game state, a short and long press are both interpreted to bring the user to the Main Menu. Instead, a short press should bring the user to the Main Menu, while he long press should bring up the Universal Menu. Another way to phrase this would be to say the -in all cases- a long press must bring up the Universal Menu, and not perform any other actions.", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482393_814597168678395_2848440585793044480_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPm3BFSpa6kQ7kNvgEKT48-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A62KgiG0qvKHecsczX6w_a8&oh=00_AYDU4CgJnYlh60YdaU8x9yvFCP_U5TQViqJF4utHaXpUjQ&oe=66E19308"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wizard Stole My Goose", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1493190000, "lastRevision": {"nodes": [{"id": "1000433473390568", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1365813440159412", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "781034798717092"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2780152392069391", "image_type": "APP_IMG_