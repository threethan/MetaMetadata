 {"file_name": "p15zaE.png", "id": "221336129209398", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569424_221336132542731_1241333500884287488_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n2wK1dhiW64Q7kNvgFFKZNJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjpa26-_fbcgq1k8DooC7ns93sYT16ZnVJ711AwekN6w&oe=67373738"}, {"file_name": "fb8U7J.png", "id": "1072539269798838", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86669354_1072539273132171_2135894898522456064_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUOowz5fOkcQ7kNvgETc1Xh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBO3CNnUNVn39TTMUOnJDxrVwPnBD-XXAYo2OjI_EcKvA&oe=67373B75"}, {"file_name": "jUNAK6.png", "id": "1027487387633182", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75441579_1027487390966515_3967338738165481472_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wU5MHGsTa0MQ7kNvgFzGcns&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFk-GQzPV47cM42Qaspactk58dMkV_hlANg5aF_0I2MQ&oe=67372299"}, {"file_name": "ZYRz7t.png", "id": "155443409097793", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031344_155443412431126_914748555678187520_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T78Ot21B9kwQ7kNvgHo4EtD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8rGyh7MuVQDp9fF6HSrnA-ajWC9oiJ7wEKbXr8mQrYA&oe=67374961"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/eimA5G", "id": "506388483557565", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75302222_506388486890898_6223872675257778176_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fNLeq4IZ0xwQ7kNvgG-8LMX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbmGF4dAk-zHcwoxbdXF33HOL1TvdmUks0YPNkS1Iy8Q&oe=6737194F"}, "display_name": "Pixel Ripped 1995", "keywords": ["pixel", "ripped", "retrogame", "indie", "90s"], "long_description": "Pixel Ripped is back with a brand new nostalgia-fueled virtual reality game-within-a-game, this time in the year 1995! To restore balance to multiple dimensions, our videogame hero Dot recruits the help of the best gamer from 1995, an unassuming 9-year-old boy named David. Join this unlikely duo through challenging throwbacks to all your favorite classics from the late 16-bit and early 32-bit era of games inside a virtual reality world.\n\n\nThe game evokes a genuine nostalgic feeling, such as the adrenaline of playing games without getting caught after your mom told you to go to bed, or the thrill of finding that brand new game at the store. You have to do all that and more through multiple environments - including your living room, bedroom, the local video rental store, the arcade at the pier, and more. With 6 fully original and highly differentiated levels, where each one feels like an entire new game, Pixel Ripped 1995 is an incredible journey for both VR and retro gamers.", "short_description": "Pixel Ripped is back with a brand new nostalgia-fueled virtual reality game-within-a-game, this time in 1995! Help our hero Dot face challenging throwbacks to all your favorite 16-bit and 32-bit classics while surviving the struggles of a typical nine-year-old kid."}, {"images": {"nodes": []}, "id": "222696362359628", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pixel Ripped 1995", "keywords": ["pixel", "ripped", "retrogame", "indie", "90s"], "long_description": "Pixel Ripped est\u00e1 de vuelta cargado de nostalgia para llevarte a un incre\u00edble mundo en Realidad Virtual con un nuevo juego dentro de otro juego, \u00a1esta vez en el a\u00f1o 1995! Con el objetivo de restablecer el equilibrio en m\u00faltiples dimensiones, nuestro h\u00e9roe Dot recluta la ayuda del mejor jugador de 1995, un modesto ni\u00f1o de 9 a\u00f1os llamado David. \u00danete a este d\u00fao en esta desafiante vuelta al pasado en VR, para revivir todos tus cl\u00e1sicos favoritos de finales de la era de 16 bits y principios de los 32 bits.\n\nSentir\u00e1s la adrenalina de cuando jugabas sin que nadie te viese despu\u00e9s de que tus padres te manden a dormir, o la emoci\u00f3n de encontrar el esperado juego en tu tienda de barrio. Prep\u00e1rate a pasar por situaciones a trav\u00e9s de m\u00faltiples escenarios, como la sala de estar, el dormitorio, el videoclub, el sal\u00f3n recreativo y m\u00e1s. Por los 6 niveles originales, cada uno como un nuevo juego, Pixel Ripped 1995 es un viaje que los retrogamers apasionados por la Realidad Virtual no olvidar\u00e1n.", "short_description": "\u00a1Pixel Ripped est\u00e1 de vuelta con un nuevo juego dentro de un juego en Realidad Virtual lleno de nostalgia, esta vez en el a\u00f1o 1995! Ayuda a nuestro h\u00e9roe Dot a enfrentar la vuelta al pasado superando los desaf\u00ecos de jugar dentro de todos tus juegos cl\u00e1sicos favoritos de la era de 16 y 32 bits mientras sobrevives al d\u00eda a d\u00eda de un t\u00edpico ni\u00f1o de nueve a\u00f1os. "}]}, "developer_name": "ARVORE Immersive Experiences", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "ARVORE Immersive Experiences", "support_website_url": "https://discordapp.com/invite/6JNVSn9", "website_url": "http://www.pixelripped.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "ARCADE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "88879