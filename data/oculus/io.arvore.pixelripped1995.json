{"data": {"node": {"__typename": "Application", "id": "3628344387191267", "organization": {"id": "1480825885368636", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7890078401040025"}]}, "id": "1263383651323404"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "415780415213995"}]}, "id": "1707664169518513"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2886115781495034"}]}, "id": "297473121485276"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2925963724165642"}]}, "id": "246900999924157"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2685959161497510"}]}, "id": "2335402783232718"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2683538418374043"}]}, "id": "2518166921773531"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2696893923667027"}]}, "id": "435417563783167"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "3628344387191267"}]}, "id": "1187410921464439"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1973759295992059"}]}, "id": "1895331790518906"}]}}, "firstRevision": {"nodes": [{"application": {"id": "3628344387191267", "release_date": 1587661200, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 19}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6063601956998819"}, "id": "2982837931941539"}]}}, "binary": null, "live_binary": null, "created_date": 1731074174, "id": "28380750651523964", "is_initial_release": false, "name_with_fallback": "v32", "pdp_metadata_with_fallback": {"version": 20, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "28250077974591233"}, "release_status": "RELEASED", "id": "3628344387191267"}, "id": "28250077974591233", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "PENDING", "release_type": "SCHEDULED", "pdp_metadata": null, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974778_864070448821627_3312649972710959663_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9DSiWPRPAcIQ7kNvgFwoo_p&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNMAM56_A-WaosA059E5jpaurUyzDsJ5guihxT_CKz6g&oe=67374497"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pixel Ripped 1995", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1587661200, "lastRevision": {"nodes": [{"id": "2414889095295639", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3628344387191267", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "2222723331357348"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "2940026522752847", "locale": "pt_BR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pixel Ripped 1995", "keywords": ["pixel", "ripped", "retrogame", "indie", "90s"], "long_description": "Pixel Ripped est\u00e1 de volta com um novo jogo dentro de um jogo em realidade virtual cheio de nostalgia, agora em 1995! Para recuperar o equil\u00edbrio de m\u00faltiplas dimens\u00f5es, nossa hero\u00edna Dot pede ajuda ao melhor gamer de 1995, um modesto garoto de nove anos chamado David. Junte-se a essa dupla improv\u00e1vel em desafios que relembram todos os cl\u00e1ssicos favoritos: dos \u00faltimos games 16-bit aos primeiros da era 32-bit, dentro de um mundo em realidade virtual.\nPixel Ripped 95 evoca um genu\u00edno sentimento nost\u00e1lgico, como a adrenalina de jogar games depois que sua m\u00e3e te mandou para a cama, ou a emo\u00e7\u00e3o de encontrar o \u00faltimo lan\u00e7amento da locadora. Voc\u00ea ter\u00e1 que fazer tudo isso por diversos ambientes - incluindo sua sala de estar, quarto, a locadora do bairro, o fliperama no cais e muito mais. Com seis fases totalmente originais, onde cada uma parece um jogo inteiramente novo, Pixel Ripped 1995 \u00e9 uma jornada incr\u00edvel tanto para jogadores de realidade virtual quanto para amantes de games retr\u00f4s.", "short_description": "Pixel Ripped est\u00e1 de volta com um novo jogo dentro de um jogo em realidade virtual lotado de nostalgia, agora em 1995! No corpo de David, um garoto de nove anos com todas as ang\u00fastias t\u00edpicas da sua idade, ajude nossa hero\u00edna Dot a enfrentar os desafios de todos os seus cl\u00e1ssicos em 16-bit e 32-bit. "}, {"images": {"nodes": []}, "id": "1107786146225722", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pixel Ripped 1995", "keywords": ["pixel", "ripped", "retrogame", "indie", "90s"], "long_description": "Pixel Ripped est de retour avec un tout nouveau jeu de r\u00e9alit\u00e9 virtuelle aliment\u00e9 par la nostalgie, cette fois ci en 1995! Pour r\u00e9tablir l'\u00e9quilibre dans plusieurs dimensions, notre h\u00e9ros Dot recrute l'aide du meilleur joueur de 1995, un gar\u00e7on de 9 ans sans pr\u00e9tention nomm\u00e9 David. Rejoignez ce duo improbable \u00e0 travers des retours difficiles \u00e0 tous vos jeux classiques pr\u00e9f\u00e9r\u00e9s de la fin des consoles 16 bits et du d\u00e9but 32 bits dans un monde de r\u00e9alit\u00e9 virtuelle.\n \nLe jeu \u00e9voque un sentiment de nostalgie, comme l'adr\u00e9naline de jouer \u00e0 des jeux apr\u00e8s que votre m\u00e8re vous a dit d'aller au lit, ou le plaisir de trouver ce tout nouveau jeu au magasin. Vous devez faire tout cela et encore plus dans plusieurs environnements - y compris votre salon, votre chambre, le magasin de location de jeux vid\u00e9os local, l'arcade, etc. Avec 6 niveaux enti\u00e8rement originaux, o\u00f9 chacun se sent comme un tout nouveau jeu, Pixel Ripped 1995 est un voyage incroyable pour les joueurs VR et r\u00e9tro.", "short_description": "Pixel Ripped est de retour avec un tout nouveau jeu de r\u00e9alit\u00e9 virtuelle aliment\u00e9 par la nostalgie, cette fois en 1995! Aidez notre h\u00e9ros Dot \u00e0 affronter des retours difficiles \u00e0 tous vos jeux classiques pr\u00e9f\u00e9r\u00e9s de 16 bits et 32 \u200b\u200bbits  tout en survivant aux difficult\u00e9s d'un enfant typique de neuf ans."}, {"images": {"nodes": [{"file_name": "l50Nuk.png", "id": "666711974064191", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982707_666711977397524_3507386747656863744_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kbhAmEC3xDgQ7kNvgHu5Iph&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUcLJitppaJn3a-jrowCg-iCiMSbzMXDpM4nagWeer-Q&oe=67371DC7"}, {"file_name": "rsUymo.png", "id": "911675605918410", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75622019_911675609251743_1742647091605274624_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rqVwMA17WxsQ7kNvgE9jU_Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBy8eKEDRwU7eovXEzKOKdmhmemsqcaXVMSwjbD7Ko9ng&oe=67374126"}, {"file_name": "frnNm2.png", "id": "893153671145258", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75287554_893153674478591_1325067693660831744_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VwM7VaN-YMIQ7kNvgGzwXLl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&o