40143616_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w5EEkVUa5AcQ7kNvgEhGMlB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJv2170dV0KXSsI9safVeGDeRlkTL5g76ptAoKhuJldw&oe=66D82EDF"}, {"file_name": "migrated_image.png", "id": "215648166344885", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974451_2220139041633971_3686866228296548352_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FhUMZk9KluUQ7kNvgGbCRl8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDm6skPRf9bhJ7Vo8-RmLi2QutjkwAEiXNnRYbgvVvosQ&oe=66D83D24"}, {"file_name": "migrated_image.png", "id": "879825635772393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974732_434645204029334_8954674579259785216_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uTeQaGgKs8MQ7kNvgHBQVHo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJKgjLYwOaGtpXLxnfrA0gE2nAfP6dHmGDsVj6M7-YZg&oe=66D83595"}, {"file_name": "migrated_image.png", "id": "248573236181711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974664_2415543541818567_3264394652148563968_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BEswJHmLLDcQ7kNvgFUUYV1&_nc_ht=scontent.oculuscdn.com&oh=00_AYATI_KTMRjLVzrNu26MK7hJu1tr9IqZAEpzwhtekVtzHQ&oe=66D8514A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/igvanf", "id": "2064556733847485", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982689_2064556737180818_7042735879894335488_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e2LbMK1Db0MQ7kNvgGEBRI_&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5606d7O6FlwEBdZUDO5Xi77XO8fiowGDkdDnRJ9A0wg&oe=66D83B5C"}, "display_name": "CrazyTanks Multiplayer", "keywords": ["CrazyTanks", "Multiplayer", "Crazy", "Tanks", "free"], "long_description": "CrazyTanks Multiplayer: The Army of Shadows\nJump, drop mines & telekinesis to kick some tanks in a crazy tank multiplayer.\nWelcome Commander!\nJump into the battlefield and fight your way through this crazy real-time tanks shooter multiplayer!\n\n+ Crazy High Speed Multiplayer +\nUse your tank's crazybilities to kick your enemies - jump behind them, apply your telekinesis force to throw them off the cliff & drop your mines from above.\n\n+ Fight Your Way To Victory +\nGlory, Honor, Eternal Fame - and a lot of other words we've found on the dictionary - you can find them all when you'll become a CrazyTank commander!\n\n+ Features +\n* Jumping tank with telekinesis force\n* Upgrades\n* Cinematics\n* Chat\n\n+ Cross Platform - Play Everywhere +\n* Android\n* Virtual Reality\n* PC\n\nWebsite:\nhttp://www.CrazyTanks.com\nPrivacy Policy:\nhttp://www.CrazyTanks.com/privacy_policy.html", "short_description": "Welcome to Crazy Tanks!\nJump into the battlefield and fight your way through this crazy real-time tanks shooter multiplayer!\n\n+ Crazy High Speed Multiplayer +\nUse your tank's crazybilities to kick your enemies - jump behind them, apply your telekinesis force to throw them off the cliff & drop your mines from above.\n\n+ Fight Your Way To Victory +\nGlory, Honor, Eternal Fame - and a lot of other words we've found on the dictionary - you can find them all when you'll become a CrazyTank commander!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.crazytanks.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Shweng", "support_website_url": null, "website_url": "http://www.CrazyTanks.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "332692152102792"}, "review_messages": ["", "Please 