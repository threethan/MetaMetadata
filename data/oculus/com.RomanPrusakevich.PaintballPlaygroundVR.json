08418673379279_512990948549758932_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FmpP371jv4UQ7kNvgFGMW4t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYDmRbP-vdgxN5UMy527-3JHjUL-vnODXr9YzZIC_Zo_6Q&oe=66E6D33E"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Tff6TeXYVQQ7kNvgEqar0Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYCsx7Sg64KV7ycqSLaIcdJETCic-twnalgFBlY881OC0A&oe=66E6B8B1"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1qPk-74MGYQ7kNvgE68CiB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYBDpnDlzpD33dtr3GPyN1U76zVCxeYipTrOQyd17scOjg&oe=66E6D1B4"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q2xREL_7rbIQ7kNvgH0Dqei&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYAUx7URX9pfXCa9_CgQgPycawJBUQ3NPko6cjEbtkCvDA&oe=66E6D0F3"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NGgOeoIgnbsQ7kNvgEqvaM6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYDmvuamYbxi8hOY8Kx4nixOjndYmUg28eN1JIPygeHLBg&oe=66E6C5B0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GZuzjCmpqTYQ7kNvgH95vP-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmtthcI-OcdEC3D4WhSJYcv&oh=00_AYBCXqg0R3nLb4LxoME8kpea527f4XhvD17T2oKFUraYAg&oe=66E6B522"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": null, "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "G