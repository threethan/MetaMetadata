png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=67VW0K_yMtcQ7kNvgGFoV-f&_nc_ht=scontent.oculuscdn.com&oh=00_AYBeBKtbyZycVuWuKvsLV0WUNw3e-U2CRTePMPMa7fbvPw&oe=66EFF331"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9zfNrP0hsgwQ7kNvgHB347j&_nc_ht=scontent.oculuscdn.com&oh=00_AYBg4Fft8Edg-vJ8b8Ajpm1SPL-5Ni4wy2JeozN3JSa8ZA&oe=66F00C34"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9srLqAVNbdEQ7kNvgFjaWC_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFwZS_xC3O7CXUpKCt5s_4WkfRAZ06j5KdenU61NZgcA&oe=66F00B73"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qeB1ezLXsdUQ7kNvgFJwGHI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMZphtqfcJse0SHIgIWMubWEOzYd3Sn63C9GAje5Wv8g&oe=66F00030"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m4ObfPeta3QQ7kNvgHSyXWB&_nc_ht=scontent.oculuscdn.com&oh=00_AYBliyk5Gv4415WBzGHTO_NCBnWVwQ0cU9zLqa-JPmqhXA&oe=66EFEFA2"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Triangle's Workshop", "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_ap