?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PTpTW7oRkFQQ7kNvgEHXLoF&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKiTyPZW6ZlpitI9OoXxnSGiP0VSr8jQSPBi2slzerWg&oe=66DACBAA"}, {"file_name": "5.png", "id": "913163823907376", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388624_913163827240709_8523473270541195753_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PyP3VCYesC0Q7kNvgFG5ZOS&_nc_ht=scontent.oculuscdn.com&oh=00_AYA951mNHfSUO4Pjh7DGS9y4Twe5x7KlArRcdoxzUORd4g&oe=66DAFCF1"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7K89CJnPqIUQ7kNvgH8W6H7&_nc_ht=scontent.oculuscdn.com&oh=00_AYBs9_nrdm2XGyz0_krjXxS6fmeRh9M7Ws3gEV8r-AQfCA&oe=66DADB31"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QZsdgpO4bMwQ7kNvgHtBIZ8&_nc_ht=scontent.oculuscdn.com&oh=00_AYA2VpinVKR5bP1K2YYs1x-ojIovt8Y_SO5B8Gn4uB8SEQ&oe=66DAF434"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_8.png", "id": "1200666991357930", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974562_1200666994691263_6481262712437112885_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9r9Nk7BspMQ7kNvgE4Y9IL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCo-boLpoNGrcUBqaBwN1k19GuO7Bp2gaTtvfGcpF3Ytw&oe=66DAF9B5"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Perdoon inc.", "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Perdoon inc.", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages":