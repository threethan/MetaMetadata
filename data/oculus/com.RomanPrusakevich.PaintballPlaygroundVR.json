?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PTpTW7oRkFQQ7kNvgH4bVsD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVWZGVyn_oppaL1FXibDaY3eRbYBRyJ5LabOGkaS4hPg&oe=66DC1D2A"}, {"file_name": "5.png", "id": "913163823907376", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388624_913163827240709_8523473270541195753_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kxaHP6-H3UQQ7kNvgE9_BR_&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3uq8I7LgZ7Q3Vz2oPyO8aatBHo_ZyS8v09uy3BV2EGw&oe=66DC4E71"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rQcvAzjmxssQ7kNvgGfyCQm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBtksS4VifW8bxnLNZwWs0fx7sN0rjKSiUyRb29Pu1_kg&oe=66DC2CB1"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dyBSgXOFwc4Q7kNvgFRbqHz&_nc_ht=scontent.oculuscdn.com&oh=00_AYBLJ7zUaYiPzLPDdn4kRVoRlJEQYRKjT--HGN1eTWSQ-w&oe=66DC45B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_8.png", "id": "1200666991357930", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974562_1200666994691263_6481262712437112885_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9r9Nk7BspMQ7kNvgHOTYJR&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5Mdn5YTVWSJCSwSuZx8Se1CS2u8NJ9Ynn9GdPJASRHA&oe=66DC4B35"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Perdoon inc.", "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Perdoon inc.", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages":