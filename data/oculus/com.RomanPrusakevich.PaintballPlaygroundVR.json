1nKEk8Q7kNvgEf70Yl&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAW2ddjbj-S4imHM1Ya8UyjVtfyb2iC4bfbCJlxa8YZOA&oe=6716493E"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A03NrXOD9mMQ7kNvgFSaim8&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYA-UPEb8SFABECXG-Y8hJyY4PHjxI1sxkVXqLMNEP_lig&oe=67162EB1"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gSfRN1lk1cQQ7kNvgFwKUc4&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYB-67_UULLe-rhC6e6F0rv4NYmUr4S-XL6dljnvH4FBfw&oe=671647B4"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMMKxD9dSMYQ7kNvgE7Pn3J&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBVrNdiI-eLSPP7tjqmpUWV3X1VvcX7BTphdqwmGkjSDw&oe=671646F3"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tLyOHZpr3wQQ7kNvgHGeS69&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBeQ405fY_DSHIXClwYmIZJXYacUajfGPo7BnCva2zsLw&oe=67163BB0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=58fQbnc28OgQ7kNvgFlOxVK&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYA0zJCXh0MVCzkFSWHgbRd0Oh2KM4HHfA8F3NkxrRc3gg&oe=67162B22"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, team deathmatch, and 1v1, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Triangle's Workshop", "developer_privacy_policy_url": "https://xsolla.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GA