qxPeHsQ7kNvgG--SG9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCQjn6XUjf9em66oj2C1i9ZRoj-8d9QHx9WascmTCh3VA&oe=67349BBE"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7RFaaZsv1E0Q7kNvgEtRtXj&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCs4LKTj4xusMAg2_y-BTiGcGVjchmmWaHKG2hp-r8PJQ&oe=67348131"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7TIsXoMFmskQ7kNvgF89zwU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAPuDbN9KRQQSpSMoVvOdpUR3srs_Q37ejK_pqTZCbYEA&oe=67349A34"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cgufPbft3yMQ7kNvgEWikOW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBzgEq48CdvM4gg02me9oY0nm1cJKSGf0k3tiQbHKSNWQ&oe=67349973"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvy3muEe_HcQ7kNvgHXHP5N&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBhruINklv_dkf3e9qprEvuwC46uERD6f3xIfskWSLTxg&oe=67348E30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Owm74I9yyS8Q7kNvgE4A_CI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAeP4OMQYORA0HP0PDUSKdqRvdAK1KPpmeI5ijopG67wg&oe=67347DA2"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, team deathmatch, and 1v1, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Triangle's Workshop", "developer_privacy_policy_url": "https://xsolla.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GA