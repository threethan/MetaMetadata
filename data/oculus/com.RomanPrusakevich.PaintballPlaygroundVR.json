18673379279_512990948549758932_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HqAUL9iFQTAQ7kNvgHSpHFh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYDyofGZnh5d0lQFkd_AXeDS5jSkuvSQo1Lzi4kSBscU-w&oe=66F2B0BE"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=67VW0K_yMtcQ7kNvgF5pt6P&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYAVRfS3nVA3aE15LyFtfMPR0Eisr8xZYYLljCgELFnRmw&oe=66F29631"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9zfNrP0hsgwQ7kNvgEXD9s8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYDQtXoOem4d7ZCTmyre2KavmOOh-PZ2WynaULubxKKTsQ&oe=66F2AF34"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kJsJ_kL8qhYQ7kNvgH946Lr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYComX6w6PtcFHuDjTBEI3Fw8aRBAdEnsxbUmss-2LSZJA&oe=66F2AE73"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qeB1ezLXsdUQ7kNvgH09nPb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYDS-5YivyDaE62S3PcYdMir3jBAv_rESQFu6kw3j5YX5g&oe=66F2A330"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m4ObfPeta3QQ7kNvgHHqcSv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AMkZKOSYpHnUc5P9dNj5QC3&oh=00_AYDVSTUr0TGghGs76Qc6eQo0yvrjpUkG-WQYxUpZNv97ZQ&oe=66F292A2"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Triangle's Workshop", "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", 