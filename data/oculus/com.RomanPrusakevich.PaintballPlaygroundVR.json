lNqWEMQ7kNvgEafskz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDUGH5_8KPa9UqJl-tkEOd1OEYFthBszkmwrgsVJmP2lQ&oe=677BCCBE"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rds7-m8eSkEQ7kNvgHH4g9B&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCJczztuL2um_EF8eUptF3NL6Pr7W_xfQsPyX4BiMTCdw&oe=677BB231"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kGtZBO2mFEwQ7kNvgEONXlL&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCHyYBTF6PoPejNkGTohERNl85-rqVQNDk6_UuC16uVrA&oe=677BCB34"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rd4vX5jiFJ4Q7kNvgH8rf-2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCDgw2Ttmve0phDIpN0311u8Kavb6vhM8k9ZJlskp9Tmw&oe=677BCA73"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5EbYLO3PODgQ7kNvgFrkmI5&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAKe2y0tmpOlnseAyx313fOmx5zQmbvKVbAevNxlhTUlA&oe=677BBF30"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eFCn5sjyF0sQ7kNvgErgNv6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDVkuHltbAPDtOo-8dDaOXwYmSMyz09FavxgP1mLKHkiQ&oe=677BAEA2"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, team deathmatch, and 1v1, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": "Triangle's Workshop", "developer_privacy_policy_url": "https://xsolla.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GA