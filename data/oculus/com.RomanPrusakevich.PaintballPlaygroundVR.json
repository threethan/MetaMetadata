08418673379279_512990948549758932_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FmpP371jv4UQ7kNvgEi5Kul&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYDJZL21wak_JYdOV5KGbHv8OYD2yC_D0e_AYj6ElRj0Rw&oe=66E824BE"}, {"file_name": "2.png", "id": "2707140676134104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035379_2707140682800770_2782267164912200003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zoAeTq2-lBsQ7kNvgF1tqER&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYAKRN5miplMRLSy5chiQguivgikgOJtcERHwRcXNb7SoA&oe=66E80A31"}, {"file_name": "1.png", "id": "458106993756711", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982709_458107010423376_7337182134185532194_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6OS2m4qxOWUQ7kNvgGjQtNc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYB1kMhe264QF56xp9-PqNiTW91tJNGpSALDcQuG5cJ11w&oe=66E82334"}, {"file_name": "3.png", "id": "457188553743167", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001680_457188557076500_2840392305648623558_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q2xREL_7rbIQ7kNvgFeYQsL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYCVT0EgBQ6eeHvvTEOaq4-FVYWLNmjt8iQQPVgXSIisPQ&oe=66E82273"}, {"file_name": "shop.png", "id": "1324025155641633", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984475_1324025162308299_7155612355496736927_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0E-zYzi3cugQ7kNvgG0vr70&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYBrTZO3M4l_cBj32PhqhcHT0OU-1ErM8Tf4oWap9r506A&oe=66E81730"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Stinger.png", "id": "544829461377693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982686_544829464711026_7209646544603940757_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3savkruePiYQ7kNvgHYCpBj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkyxEF4T_zstUHO59GPkBRT&oh=00_AYD1CLCbdohG5c8Y_MVuHASa29nB80YdNJX4KMSXpD6rjw&oe=66E806A2"}, "display_name": "Paintball Playground", "keywords": ["Paintball", "VPL", "Esports", "Competitive", "PvP"], "long_description": "Step into the adrenaline-pumping world of Paintball Playground VR, where you can unleash your competitive spirit and tactical skills in a virtual battleground like never before. Get ready to dive into heart-pounding paintball matches that will test your aim, strategy, and teamwork in a dynamic and immersive VR environment.\n\nKey Features\n\n1. Realistic paintball physics - Paintball Playground VR offers realistic paintball physics, including accurate ball trajectory, impact, and splatter effects, enhancing the immersive gameplay experience.\n\n2. Variety of Game Modes - Choose from a variety of game modes, including classic speedball, capture the flag, and king of the hill, each offering unique challenges and opportunities for strategic gameplay.\n\n3. Customizable Gear -  Paintball Playground VR offers extensive customization options for players to personalize their gear and weapons, allowing for unique identity and play style.\n\n4. Multiplayer - The game supports competitive multiplayer modes, where players can team up with friends or compete against others in intense paintball matches, fostering teamwork, communication, and strategic gameplay.\n\n5. Dynamic Environments - The game features a variety of meticulously designed maps with different layouts, terrains, and obstacles to provide dynamic and challenging gameplay for players.\n", "short_description": "A Sports/Shooter game where you compete against other players on SpeedBall, SpeedQB or Woodsball maps."}]}, "developer_name": null, "developer_privacy_policy_url": "https://li-as.github.io/", "developer_terms_of_service_url": null, "publisher_name": "Triangle's Workshop", "support_website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "website_url": "https://paintball-playground-vr.xsollasitebuilder.com/", "category": "G