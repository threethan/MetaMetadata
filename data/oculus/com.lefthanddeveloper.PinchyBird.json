uscdn.com/v/t64.5771-25/75221320_1782371292186867_164990694339198736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=phLBuoxndN0Q7kNvgHfKXa2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCR1LTN1vJfn439i2UDT3mr7kVe4KhO_W9S59Wrks3oWg&oe=67177AAC"}, {"file_name": "screenshot_4_2560x1440.png", "id": "1580553109426913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982623_1580553112760246_6100030736353341626_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SL88bp2jhXQQ7kNvgFEEmUT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDHPEcXZibzXqvXuckyXRdVhD_05MOij1pExlwe9OwVdQ&oe=6717A0F8"}, {"file_name": "screenshot_5_2560x1440.png", "id": "749365180486425", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230052_749365183819758_7996068684862032177_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hpOis4jHhawQ7kNvgH5Ousx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBAjLK4zrZYkc6S6PsQGghtaBcTXuT6Kdw5PcRssW02lw&oe=6717AA4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot_4_2560x1440.png", "id": "1483314488895600", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036631_1483314492228933_3956075025214191325_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N-bXPYx-A9AQ7kNvgFq-_Kp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4UfFKME67LGPq4IEXvDffaMR65rd1ZZNMzOuJB18b5w&oe=671797CE"}, "display_name": "PinchyBird", "keywords": [], "long_description": "Game Features:\n\n- Hand Tracking: control your character with hand tracking\n- Simple yet Addictive Gameplay: Immerse yourself in the simplicity and addictive nature of the game.\n- Passthrough Environment: Play PinchyBird in a passthrough environment, seamlessly blending with the physical reality.\n- Variety of Bird Characters and Pinch Effects: Collect coins and explore the game with new characters and effects\n- Leaderboard Challenges: Achieve high scores through prolonged survival and make your mark on the Top 10 leaderboard.\n- Challenging Level Design: Experience increasingly difficulty levels as you survive longer.", "short_description": "PinchyBird is an addictive casual VR game played through hand tracking, where you control an adorable bird character by pinching with your thumbs and index fingers. Navigate through cube blocks and survive as long as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1vcqJD5rQrc1pL8RViwQTLZ66deA8P9CHQm9sJ217gkA/edit#heading=h.cf1polv3tiux", "developer_terms_of_service_url": null, "publisher_name": "LefthandDeveloper", "support_website_url": null, "website_url": "https://www.youtube.com/@lefthanddeveloper1522", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7094975450584792"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "363603736411163"}]}, "baseline_offer": {"id": "363603736411163"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1707173828, "status": "PUBLISHED", "id": "363603736411163"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7404556732959994", "version": "0.9.41"}, "id": "864458925460872", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Applicat