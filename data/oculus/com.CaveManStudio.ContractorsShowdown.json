: "https://scontent.oculuscdn.com/v/t64.5771-25/38974746_2221097771577520_2182333874334186964_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wqL6nFlw2PgQ7kNvgHf7Dni&_nc_ht=scontent.oculuscdn.com&oh=00_AYD90J_0yuXwDC5QbzZHWfTpzU1U25OBncpQzeD-29pnPw&oe=66FD1E7C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape 2560x1440.png", "id": "1464896037721169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974465_1464896044387835_6481781512083379289_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VDWmvUcfgq8Q7kNvgFuR9T8&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8zUdAEyeoFFZdnKIJl2wb1V9Z3y2fj9rYX8YjH6vRZw&oe=66FD43C7"}, "display_name": "Contractors Showdown", "keywords": ["BR", "FPS", "BattleRoyale", "military", "simulation"], "long_description": "**Contractors Showdown** delivers an immersive military-styled VR First-Person Shooter experience. Engage in heart-pounding combat with **60 players**, navigate a vast and detailed **16km\u00b2(6.17763mi\u00b2)** map. The game centers around a thrilling Battle Royale game mode, where strategic prowess and combat skills are paramount.  Gear up for intense battles, dynamic team play, and a visually stunning VR environment that thrusts players into the forefront of military actions.\n{978837273958553}\n\n# Realistic Combat Experience\nGrip your guns, reload your mags, and pull your triggers in this immersive ground-zero military combat experience. Navigate the battlefield, aim with true precision, and execute real-time warfare strategies to outlast every opponent!\n{956368703161290}\n\n# Adapt and Conquer\nTailor your arsenal to your play style in your own headquarters with our highly customizable loadout system. Coordinate seamlessly with your team using spatial voice chat for a strategic advantage.\n{448213471030033}\n\n# An Expanse to Discover, Master, and Conquer\nGet ready for an epic showdown on a 16km\u00b2 battlefield where you can assemble your ideal squad of one, two, or three Contractors! Utilize the surrounding terrain, such as buildings, landmarks, hills, and other structures, to gain a tactical advantage over other skilled contractors and emerge victorious in a **60-player** royale!\n{1600961607355051}\n", "short_description": "Contractors Showdown delivers an immersive military-styled VR First-Person Shooter experience that centers around a thrilling Battle Royale game mode, where strategic prowess and combat skills are paramount."}]}, "developer_name": "Caveman Game Studio", "developer_privacy_policy_url": "https://www.contractorsvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Caveman Game Studio", "support_website_url": "https://www.contractorsvr.com/contact", "website_url": "https://www.contractorsvr.com/showdown", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "fr", "de", "ko", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6533981030059783"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75568725_1170990267356165_2026764445728421133_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-aVbrhpy4kQQ7kNvgEz_WVW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkPQan7l1UlxDCuNQi8Fw_NyyYe-kHqGzv9sXKSysB9w&oe=66FD2F26"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "