topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6538872382842726"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1126811645631402"}, {"status": "PUBLISHED", "id": "479651701542345"}, {"status": "PUBLISHED", "id": "370993626001205"}, {"status": "PUBLISHED", "id": "786336296469980"}, {"status": "PUBLISHED", "id": "2813926372081429"}, {"status": "PUBLISHED", "id": "432775012561146"}]}, "baseline_offer": {"id": "786336296469980"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "1126811645631402"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7495941733863703", "version": "1.0"}, "id": "247209914665124", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4963431797114722", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7495941733863703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "247209914665124"}]}, "change_log": "v.1.2.2.0\nBullet Duplication: Fixed duplication issues related to ammo boxes.\nDoor Scaling: Resolved abnormal scaling issues with certain doors.\nMXAKM: Fixed a bug where magazine positions were incorrect when returning to the Hideout under specific conditions.\nAiming While Sprinting: Implemented the ability to aim while sprinting, previously unavailable in exfilzone mode.\nWeapon Smoothness: Fixed an issue where the \"weapon smooth\" setting caused weapons to move sluggishly.\nAI Equipment and Distribution: Adjusted Metro AI equipment and slightly reduced the number of Suburban AI enemies.\nSellable Items: Fixed issues preventing RC416, M4A1 \"Agent,\" and UMP45 from being sold.\nTrash Can: Resolved a bug where small items like bullets couldn't be destroyed in trash cans.\nShotgun Ammo: Fixed issues where independent shotgun ammo could not be sold.\nShotgun State Persistence: Fixed issues with the M1897, Sjogren, and M590SG shotguns where chambered and loaded states were not saved between sessions.\nAmmo Loader Interaction: Adjusted interaction angles for ammo loaders in the warehouse and shooting range for easier operation.\nArmor Repair Machine: Fixed an issue where the repair button became unclickable if the hand model was positioned too deeply into the machine.\nSjogren Shotgun: Fixed a bug where a purchased Sjogren shotgun would default to having a round already chambered.\nShooting Range Equipment: Added test armor and helmets (including Christmas event items) to the shooting range loadout menu.\nExtraction Timer: Fixed incorrect display of extraction times.\nOCP-7 Scope: Resolved alignment issues with the OCP-7 sight.\nBattle Royale\nParachuting Weapon Glitch: Fixed an issue where weapons behaved erratically during high-speed movement while parachuting.\nBow and Arrow: Resolved a bug that prevented the use of bows and arrows.\nArmor Insertion: Fixed issues where armor could not be properly equipped", "created_date": 1735302563, "id": "7495941733863703", "version": "1.0", "version_code": 183, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7495903507200859"}, "asset_files": {"count": 5}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4963431797114722", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7495941733863703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "247209914665124"}]}, "change_log": "v.1.2.1.1\nFixed an issue where junk boxes could potentially duplicate items.\nFixed an issue where the Christmas-themed water bottle could not be refilled.\nAttempted to address the fatal error crash issue.", "created_date": 1735126659, "id": "7485868964870980", "version": "1.0", "version_code": 182, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7485827408208469"}, "asset_files": {"count": 5}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4963431797114722", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7495941733863703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "247209914665124"}]}, "change_log": "v.1.2.1.0\nChristmas Event\nCelebrate the holidays with a festive Christmas event!\nChristmas Decorations: Enjoy holiday-themed decorations in your Hideout to get into the festive spirit.\nSpecial Mission: Take on a limited-time Christmas mission with unique rewards.\nSpecial Hunting Squad: A challenging hunting squad has appeared in the Dam area\u2014defeat them for exclusive loot!\nNew Features & Adjustments\nAdded \"Select All\" option for the basement vendor interface.\nThe ammo reloading machine's storage space has been moved to a new table. The original table now cannot store items.\nBlind boxes can now be opened and sold directly in the Hideout.\nBug Fixes\nFixed an issue where storage racks had duplicate IDs.\nResolved an issue where mission items could not be submitted.\nFixed duplication bugs for graphics cards and ammunition.\nAddressed a crash caused by certain shotguns.\nFixed an issue where laser sights would render the inbox unusable.\nResolved task list refresh issues.\nFixed interaction issues between two junk boxes, where only the box with the higher required item count would be recognized during delivery.\nFixed an issue where items could be grabbed through walls.\nAddressed synchronization issues with secret room doors.\nCorrected errors in task location descriptions.\nResolved an issue where bombs would occasionally disappear on their own.\nFixed a bug where empty fuel canisters could allow players to gain speed boosts.\nCorrected hand texture issues in \"Hands Only\" mode when picking up and dropping phones.\nFixed a bug where SECA16 rifles would disappear when placed on the ground.\nResolved an issue preventing the installation of scopes after laser sights were installed.\nFixed a bug where uncapped AKs could equip suppressors in incorrect positions.\nResolved collision issues for weapons like the M3A1 when holstered at the waist.\nFixed an issue where purchasing shotgun ammo would result in receiving two sets instead of one.\nBalance Changes\nImproved the armor protection angle to cover chest areas that previously lacked protection.\nReduced the firing volume of the Sj\u00f6gren shotgun.\nAdjusted the attributes of 5.56x45mm M995 rounds: decreased penetration level and armor damage, increased base damage (to align with the Christmas event's free ammo giveaway).\nFixed an issue where the Rampage OD armor would clip through the ground.\nAdjusted shop prices for ammo pouches, helmets, medical syringes, and fuel canisters.\nResolved a bug preventing bombs from being sold.\nMiscellaneous Updates\nReduced the grab detection range for limb repair kits.\nIncreased the drop rate for high-quality weapons.\nDecreased the drop rate for blind boxes.", "created_date": 1735054557, "id": "7481482705309606", "version": "1.0", "version_code": 181, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7481433438647866"}, "asset_files": {"count": 5}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4963431797114722", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7495941733863703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "247209914665124"}]}, "change_log": "v.1.2.0.2\nFixed a duplicate ID issue with storage racks.\nResolved an issue where mission items could not be submitted.\nFixed the AKM 30-round magazine not being able to fit into pockets.", "created_date": 1734940237, "id": "7474016142722929", "version": "1.0", "version_code": 180, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7473971379394072"}, "asset_files": {"count": 5}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4963431797114722", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7495941733863703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "247209914665124"}]}, "change_log": "Patch 1.2.0.1\nPrevent body leaning while looking down.\nIncreased foot step attenuation radius by a little.\nAdjust armor body location, so it's easier to grab things when looking down.", "created_date": 1734768001, "id": "7462773067180570", "version": "1.0", "version_code": 179, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "7462734350517775"}, "asset_files": {"count": 5}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}