3-2.oculuscdn.com/v/t64.5771-25/57569486_903759010527549_8182948877901131497_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JvrjYlJBK8EQ7kNvgFu-mAG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8GIW6BmoJNqCn2G-h5-gaDCUM_dTXXUf802IjAoY_lg&oe=675029FB"}, {"file_name": "ZephyrusPrelude_2K_05.png", "id": "350498916879232", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974676_350498920212565_1340323091233607755_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9_t1H2OLm8Q7kNvgGUr4o0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCe7QYzOeQey_59l3g7xuzU46nqk7ix1fwN5zCGS3Rq4A&oe=67505B16"}, {"file_name": "ZephyrusPrelude_2K_03.png", "id": "1318325421950726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566696_1318325425284059_512091456979912532_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bDWmVqINBGwQ7kNvgG0iikt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApMZG9yBwBqpkVX-2Bp_IF4FHz08uc02I7_EWulkjoRA&oe=67504CE2"}, {"file_name": "ZephyrusPrelude_2K_02.png", "id": "1558343544530748", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974711_1558343547864081_9152230635257127857_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSqRWaLz_zsQ7kNvgEUoe6b&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiP-O1MohKO8g3B4BvI7Ex8tpjtF9PmQEH1NTXJRxU_g&oe=6750258F"}, {"file_name": "ZephyrusPrelude_2K_04.png", "id": "447055770282127", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/229154367_447055773615460_7679644027065007351_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Q2I1ujQqyIQ7kNvgHm7iV_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYACNG653L1vqTjfI_455IZDlZ47mnvsD1494RHeE2kCcw&oe=675039BE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ZephyrusPrelude_VideoCover_2K.png", "id": "2657342657895072", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031425_2657342661228405_699582976185715733_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j5leSEzfk6EQ7kNvgGhjpLw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPCAwfIpsNYPiQob0p7tz4VVb_mIONifhkAXiVnoEexQ&oe=675043DC"}, "display_name": "Zephyrus Prelude", "keywords": [], "long_description": "Welcome to Zephyrus, a world on the verge of the logical and the magical, full of wizards, witches, mystical and cursed beings. Become a mage, wield your power to escape from the clutches of your enemies. Gather a company to uncover the secrets of the world, solve puzzles, and defeat creatures on the way.\nSearch for the way out of Zephyrus. Collect and use mana to unravel 3-dimensional sliding puzzles. Be aware, at times it takes more than one mage to solve a challenge, acting at the same time can become essential.\nCasting magic in certain places - like touching a floating rune - can lead to an unexpected metamorphosis.\nBe on the lookout for hidden chests, who knows what you may find.\nThe creatures you will meet in the world are magical - curses, spells anything is possible!\n\nMore content coming soon!\nComfort levels will vary for every player, and prolonged use can sometimes cause motion sickness and eye-strain. Please refer to your hardware\u2019s safety guidelines!", "short_description": "Solo and cooperative multiplayer fantasy adventure with a single-player or LAN-multiplayer mode in a family-friendly fantasy universe."}]}, "developer_name": "MageLoop", "developer_privacy_policy_url": "https://mageloop.com/PrivacyPolicy2/", "developer_terms_of_service_url": null, "publisher_name": "MageLoop", "support_website_url": null, "website_url": "https://mageloop.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED",