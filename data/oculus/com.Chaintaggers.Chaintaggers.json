00_AYDsM1GLE68psZiFY4GV0CO92v0oCNA9C6QZlrSub5cG8w&oe=670F97AD"}, {"file_name": "com.Robloxtaggers.Robloxtaggers-20241002-184417 (1).png", "id": "1574471436823076", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57572928_1574471440156409_2404221263152840676_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cJ2ryYjbyD0Q7kNvgHDh3l3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAhSmDY43S4lnOPKaYJ2pDvS4gFxSGQtf1MBhOmTaBXSQ&oe=670F9B2E"}, {"file_name": "com.Robloxtaggers.Robloxtaggers-20241002-184354.png", "id": "935464475083970", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75356794_935464478417303_6973817561119948049_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZUI91vwo9RcQ7kNvgEnWlSq&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD3dKFX51ng3LI7qmbtSh9s6XHBa9N34q3DcEiYPspkBg&oe=670F8D53"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "com.Robloxtaggers.Robloxtaggers-20241002-184354.png", "id": "1908908769592239", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035308_1908908779592238_7373759383729386225_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oQtBbPP6OaIQ7kNvgFGubwv&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBhesaoBOQmYS4U9LlSErTCMVAEuKhi0pjV-FQfeG998g&oe=670FA6E8"}, "display_name": "Chain Taggers", "keywords": [], "long_description": "\"Chain Taggers\" is a fan game inspired by Gorilla Tag, offering a new twist on classic tag mechanics. Players engage in dynamic, fast-paced matches where the primary goal is to tag others while avoiding being tagged themselves. The game introduces a unique \"chain\" system: when a player is tagged, they become linked to the tagger, forming a chain that grows as more players are tagged. This adds a layer of strategy, as taggers must manage the growing chain's impact on their mobility, while untagged players must navigate around these chains to avoid being caught.\n\nMaps in \"Chain Taggers\" are designed with verticality and complexity, featuring hidden paths, trampolines, and zip lines, ensuring each match is unpredictable and challenging. Power-ups like \"Chain Breakers\" allow tagged players to sever the chain, freeing themselves and creating moments of intense gameplay.\n\nThe game offers various modes, including classic tag, team-based competitions, and special event modes. With vibrant visuals, dynamic sound design, and a commitment to regular updates and community feedback, \"Chain Taggers\" provides an engaging and evolving multiplayer experience. Whether you're a fan of Gorilla Tag or new to the genre, \"Chain Taggers\" delivers a fresh and exciting take on the tag game formula.", "short_description": "A game that uses the gorilla locomotion."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/chain-taggers-privacy-policy/home", "developer_terms_of_service_url": "https://sites.google.com/view/chaintaggerstermsofservice/home", "publisher_name": "Wells_VR", "support_website_url": null, "website_url": "https://sites.google.com/view/chain-taggers/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27946629368269674"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2529359330785483"}]}, "baseline_offer": {"id": "2529359330785483"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728352920, "status":