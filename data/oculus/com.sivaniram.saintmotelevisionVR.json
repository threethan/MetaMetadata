 or text.\n\nThe Logo Transparent should be free of any backgrounds and borders. \n\nMore information can be found [here](https://static.oculus.com/documents/oculus-store-art-guidelines.pdf)\n\nPlease let me know if you have any questions.\n", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162718_131999670858758_9066674110725095424_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qdfzfrVEBqMQ7kNvgHdM2y9&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSHRHnHX3xYnBTNGxj6anHHR1OUXk7k0RSOLvvrbl2VA&oe=66CC7099"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Saint Motel VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1509037200, "lastRevision": {"nodes": [{"id": "1599786413374495", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1341118532667756", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1163831723717650"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "3618589811546392", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162684_282301098936169_258599688834383872_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eJ6b6vZexi8Q7kNvgHw7_QU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDx4vfFYEh47oKNghlmFcZ-KnqnTwHILRQ6Cu5tLks-AQ&oe=66CC62E0"}, {"file_name": "migrated_image.png", "id": "2864846966939350", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162690_1929885220666097_6845729204655357952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hdSedCYgdG4Q7kNvgGBPJCT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCsSw9eMfAiq2DZDS1C7YsX1euw9UBnhzPxnMZazQqiEg&oe=66CC6A7E"}, {"file_name": "migrated_image.png", "id": "280805859