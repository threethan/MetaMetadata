2708_476639736035175_3421434865696899072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8-zaZp-0DAYQ7kNvgHR_e4x&_nc_ht=scontent.oculuscdn.com&oh=00_AYCDb50skkNb-OGe2OAfkydcS90CyfNELfOv4C0WHp1x3A&oe=66FBEAF1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Saint Motel VR", "keywords": ["Music", "SaintMotel", "Entertainment"], "long_description": "The first ever virtual reality album! \n\nAs mentioned in Billboard, New York Times, and more, Saint Motel has released their full-length album complete with virtual experiences for each song. Now with the app, you can actually sit inside of the album cover art, legs dangling in the TV pool, while you watch all the VR content and hear the background on the album from the band themselves.", "short_description": "The first ever virtual reality album!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.saintmotel.com/PrivacyPolicy", "developer_terms_of_service_url": "http://www.saintmotel.com/terms-of-use/", "publisher_name": "Saint Motel, LLC", "support_website_url": null, "website_url": "http://www.saintmotel.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "479174916943509"}, "review_messages": ["", "Hello,\n\nI wanted to reach out, as changes to Saint Motel VR's artwork is needed, particular to the Cover Landscape, Cover Square, and Logo Transparent.\n\nThe Cover Landscape and Cover Square should have its bottom 20% of the artwork clear of any logos or text.\n\nThe Logo Transparent should be free of any backgrounds and borders. \n\nMore information can be found [here](https://static.oculus.com/documents/oculus-store-art-guidelines.pdf)\n\nPlease let me know if you have any questions.\n", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162718_131999670858758_9066674110725095424_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elYoV0U6-K8Q7kNvgGG7WX4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBoyjR1AkH9a92ij_vLLCDzwo-emf9vh_LW63DSQfZb7A&oe=66FBE699"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Saint Motel VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1509037200, "lastRevision": {"nodes": [{"id": "1599786413374495", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1341118532667756", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "1163831723717650"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "3618589811546392", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162684_282301098936169_258599688834383872_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AEDVuC_6jtQQ7kNvgGYU_Rz&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZM3bM9D48JC-oOv3KHVQHNCZ4Q8IAx_LVv0hAgf4wZw&oe=66FBD8E0"}, {"file_name": "migrated_image.png", "id": "2864846966939350", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162690_1929885220666097_6845729204655357952_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Su3NS5IQDAcQ7kNvgEgHepD&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6fM40d4ckIUbrVQMV2X-3_3RdnovSxZTetNDMRl9q4w&oe=66FBE07E"}, {"file_name": "migrated_image.png", "id": "280805859260865