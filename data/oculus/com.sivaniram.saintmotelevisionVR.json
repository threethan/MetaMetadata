1916978649_5041920709308186624_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HkJAyvNHijMQ7kNvgGbAk_p&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN8w7aAZ1hA-m01MXbbPJ7i&oh=00_AYABVaRQyp7H23TJfyNsN295tWrBEPIG2S1Ybe4XMQiy3g&oe=66EC0E26"}, {"file_name": "migrated_image.png", "id": "715163335888926", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_476639736035175_3421434865696899072_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77mxnqYPVGEQ7kNvgFTS-84&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN8w7aAZ1hA-m01MXbbPJ7i&oh=00_AYBaValP2oSzUt1by4vfwiYqbsPJ0IESiSXTkyCsXOI9CQ&oe=66EC18F1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Saint Motel VR", "keywords": ["Music", "SaintMotel", "Entertainment"], "long_description": "The first ever virtual reality album! \n\nAs mentioned in Billboard, New York Times, and more, Saint Motel has released their full-length album complete with virtual experiences for each song. Now with the app, you can actually sit inside of the album cover art, legs dangling in the TV pool, while you watch all the VR content and hear the background on the album from the band themselves.", "short_description": "The first ever virtual reality album!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.saintmotel.com/PrivacyPolicy", "developer_terms_of_service_url": "http://www.saintmotel.com/terms-of-use/", "publisher_name": "Saint Motel, LLC", "support_website_url": null, "website_url": "http://www.saintmotel.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["MUSIC", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": [], "supported_player_modes": [], "s