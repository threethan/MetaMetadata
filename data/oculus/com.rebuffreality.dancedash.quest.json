&oh=00_AYAwtJ_9sBVceSv5rbKEmtVVSCsHJnxQJOhdvdW47PRrVw&oe=66CC77A6"}, {"file_name": "Sceenshot_4.png", "id": "2995948090539517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443242_2995948093872850_3031049371269118178_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hsW8RwS9AoQQ7kNvgGhoM43&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUbQgHLJgPZpDsNE93J-9H41qx08zKygGfq0oByULN5Q&oe=66CC8208"}, {"file_name": "Sceenshot_5.png", "id": "292875470306429", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75286676_292875476973095_7784434845127809702_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FHwBX9p6NWMQ7kNvgGLPi44&_nc_ht=scontent.oculuscdn.com&oh=00_AYATMEjwl_-9R4bVngdVsOnn6dM7oGvlq3BInPbvYixHpA&oe=66CC5D02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "996802831614449", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_996802834947782_2069001060840845651_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W9G0DId-bEQQ7kNvgFiHlnZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBffvX3FniPXGAisQEDMrAr6azIw2nlZ-BEhgePijVKcQ&oe=66CC8431"}, "display_name": "Dance Dash", "keywords": [], "long_description": "STOMP THE BEATS, DO THE SHUFFLE\n\nHarness gravity-powered shoes to hover above the dance floor, commanding the beats with a stomp. Slide to rhythm and shuffle, shuffle, shuffle!\n\nDUCK, DODGE, JUMP\n\nFinally JUMP like you mean it in VR! So stay alert and nimble, with some quick reflexes and sick moves, you can easily overcome any obstacle in your path.\n\nUNLEASH THE DANCE DASHER WITHIN", "short_description": "Morph your VR rig into the ultimate dance floor. Finally use your feet to stomp the beats in this pulse-pounding, full body sensory symphony. Pair with Quest controller Trackstraps (see below) to unleash the Dance Dasher within you."}]}, "developer_name": "Rebuff Reality", "developer_privacy_policy_url": "https://rebuffreality.com/pages/privacy-policy", "developer_terms_of_service_url": null, "publisher_name":