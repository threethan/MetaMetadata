c_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJexldj3CW-hBaGsiURz2skMWHNGDjyjIzz01NQmtSxw&oe=6731E078"}, {"file_name": "5.png", "id": "528952326267599", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566697_528952329600932_1590082070944628834_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oqrR1cx0JugQ7kNvgHu1-Xt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9zTxfX_iv5uagR1UO1DC_rlqD6XKCJeLE35QwHcqUEA&oe=6731D8F1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DD-meta-video-cover.png", "id": "1531913677428796", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031377_1531913680762129_8526821131804025808_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bEJl0kUf0_8Q7kNvgEMxVy7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUgmc8tR3lATuiVjDoLd7M2GmgJhoqdkZxCbLs86GpMw&oe=673204A0"}, "display_name": "Dance Dash", "keywords": [], "long_description": "Dance Dash is the definitive FULL BODY TRACKING game, AI powered by BodyLink (beta) camera tracking streaming, with our FREE app for your mobile device. Fully compatible with Quest 2 & 3 standalone.\n# **\ud83d\udd17BodyLink (beta): Your Gateway to Full Body Tracking\ud83d\udd7a**\n{433447386102396}\n\nStomp the beats in this pulse-pounding, full body sensory symphony on your Quest Headset! Craft your own rhythm, groove to community maps, music, and mods. FREE TRIAL.\n\n# **\ud83d\udc83BUST A MOVE**\n{775062488145996}\n\nDance Dash features intuitive mechanics like ducking, dodging, jumping, slapping, and especially shuffling, making it easy to play and highly engaging. Choreograph your most treasured tunes, and let the world know how you rock!\n\n# **\ud83d\udcabDD Editor to Create, Share, and Connect\ud83c\udf0e**\n{807231754337921}\n\nDive into the DD Editor (separate application), to create your own beatmaps for endless gameplay. Learn cool moves from influencers\u2019 videos, or play original music videos in-game\n\nJoin our vibrant community of members from countries all over the world: discord.gg/dancedash!\n\nSupport: dancedash@rebuffreality.com", "short_description": "Free FULL BODY TRACKING on Quest standalone empowered by BodyLink (beta) AI-powered camera tracking streamed from your mobile device. Groove to 100s of community songs and maps IN-GAME plus viral dance videos and MVs. Experience Full Body Gaming Without Limits in the most engaging arcade-style rhythm game ever."}]}, "developer_name": "Rebuff Reality", "developer_privacy_policy_url": "https://rebuffreality.com/pages/privacy-policy", "developer_terms_of_service_url": "https://rebuffreality.com/pages/terms-and-conditions", "publisher_name": "Rebuff Reality", "support_website_url": null, "website_url": "https://www.rebuffreality.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7932919833501685"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974893_1011916050613279_1457410703125469987_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=avRxMLvtRO8Q7kNvgF0bOtc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCESkwwF3WHDKvek4IegznT2yf5aZwh13fgSckRqcP_mw&oe=6731FABA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dance Dash", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326