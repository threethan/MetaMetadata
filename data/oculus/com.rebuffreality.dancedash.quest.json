rIS7LKqxaPBX0c_vmDlzDQCFfa2tv-laZbg&oe=6731D83B"}, {"file_name": "Sceenshot_3.png", "id": "298655613111444", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570306_298655616444777_2869128718776439749_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_ZXxEuJPVcQ7kNvgFWSXyd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQgIyh2W_DgySk2caeZMLovEMPsgn3np4NmHVFZ_Prag&oe=6731FB26"}, {"file_name": "Sceenshot_4.png", "id": "2995948090539517", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443242_2995948093872850_3031049371269118178_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C9YoGDFmO6gQ7kNvgEhdOe_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFLHjnOVaUrHMVkFB9LejawvRNCr2FKzoftzf-WgST_Q&oe=67320588"}, {"file_name": "Sceenshot_5.png", "id": "292875470306429", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75286676_292875476973095_7784434845127809702_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P7nkiUmAslUQ7kNvgEmgJYC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyMkooQyarZ7Jb_xSfu9s_fCzDsYNtRehLcnZaC865Xw&oe=6731E082"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "996802831614449", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367592_996802834947782_2069001060840845651_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kBuKuQizzh0Q7kNvgHYEUW6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4kUAP92szkxUOdJJCeYeZNo7pm_y4Ve8LEAUqeJfNNg&oe=673207B1"}, "display_name": "Dance Dash", "keywords": [], "long_description": "STOMP THE BEATS, DO THE SHUFFLE\n\nHarness gravity-powered shoes to hover above the dance floor, commanding the beats with a stomp. Slide to rhythm and shuffle, shuffle, shuffle!\n\nDUCK, DODGE, JUMP\n\nFinally JUMP like you mean it in VR! So stay alert and nimble, with some quick reflexes and sick moves, you can easily overcome any obstacle in your path.\n\nUNLEASH THE DANCE DASHER WITHIN", "short_description": "Morph your V