.com&oh=00_AYAAInyvDM-JfMLxNVzeUs9FtbVeW39Y0t5x2CFRJ7joVg&oe=66D703A6"}, {"file_name": "Sceenshot_4.png", "id": "2995948090539517", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443242_2995948093872850_3031049371269118178_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=96IMxi3tYbgQ7kNvgEwrC50&_nc_ht=scontent.oculuscdn.com&oh=00_AYDcsIngv5f4vjxJ7SoWX0j6obPDlLxzxiCRZ3iQh89yLg&oe=66D70E08"}, {"file_name": "Sceenshot_5.png", "id": "292875470306429", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75286676_292875476973095_7784434845127809702_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LMx1NQ3oORUQ7kNvgEbYw6X&_nc_ht=scontent.oculuscdn.com&oh=00_AYCThLhHEHUAjYqDENoWI94ed4DljeMbE3dukRGV_WhDFA&oe=66D6E902"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "996802831614449", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367592_996802834947782_2069001060840845651_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qouGRVR0G9MQ7kNvgGY4aRH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBBQ87g2agotEkUh1TVIoHRNIkCIQ5LyQKNwvsX86WkA&oe=66D6D7F1"}, "display_name": "Dance Dash", "keywords": [], "long_description": "STOMP THE BEATS, DO THE SHUFFLE\n\nHarness gravity-powered shoes to hover above the dance floor, commanding the beats with a stomp. Slide to rhythm and shuffle, shuffle, shuffle!\n\nDUCK, DODGE, JUMP\n\nFinally JUMP like you mean it in VR! So stay alert and nimble, with some quick reflexes and sick moves, you can easily overcome any obstacle in your path.\n\nUNLEASH THE DANCE DASHER WITHIN", "short_description": "Morph your VR rig into the ultimate dance floor. Finally use your feet to stomp the beats in this pulse-pounding, full body sensory symphony. Pair with Quest controller Trackstraps (see below) to unleash the Dance Dasher within you."}]}, "developer_name": "Rebuff Reality", "developer_privacy_policy_url": "https://rebuffreality.com/pages/privacy-policy", "developer_terms_of_service_url": null, "publisher_na