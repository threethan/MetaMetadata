exx0NyXB8BSy7iTPnTA&oe=66EFE4D8"}, {"file_name": "ss_ed792c0a4614d9eae6d5990ab4cd64c36b9a7ed6.1920x1080.png", "id": "745617823018968", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974841_745617826352301_1004570169019751923_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ItiCqygud7gQ7kNvgEPSgMv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIA0zXaolBl3aNLpIQzyo8l&oh=00_AYBo360u0bziNiWn9ig-HGVspjZ7E9EpJQbdrC3JO9UXjA&oe=66EFF341"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus Cover Landscape.png", "id": "367495155712652", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75388619_367495159045985_641930893048141514_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1HtXlfCSrYcQ7kNvgFq7gmt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIA0zXaolBl3aNLpIQzyo8l&oh=00_AYAkYji3xQ7fHWEMuo-fePxcvrteOScVFsIH2ch3J_j0TA&oe=66F010B7"}, "display_name": "EducationXR", "keywords": [], "long_description": "EducationXR is an advanced Enterprise 3D training and education authoring platform, addressing creation, deployment, and distribution of immersive experiences available from all phones, tablets, desktops, and VR headsets.\n\nAll content created with EducationXR is immediately available from any device and automatically multiplayer, so users can connect together for interactive learning regardless of device and regardless of location. EducationXR supports SSO for ease of Enterprise access and a robust system for analytics, including 3D VR heatmaps, to help capture the maximum value from immersive learning.\n\nMicrophone permissions required for multiplayer sessions and voice transmission.", "short_description": "EducationXR is an advanced 3D training and education authoring platform addressing creation, deployment, and distribution of immersive experiences for all phones, tablets, desktops, and VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://admin.educationxr.com/public/legal/privacy", "developer_terms_of_service_url": "https: