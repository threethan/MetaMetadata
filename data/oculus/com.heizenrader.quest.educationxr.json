1080.png", "id": "745617823018968", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974841_745617826352301_1004570169019751923_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zjWhGvehi6IQ7kNvgHJiZO_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARgsNyFmgQ2wAJSIEy2zQF2XyHyR08VPQHO2pNhsdv_Q&oe=676A8EC1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus Cover Landscape.png", "id": "367495155712652", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75388619_367495159045985_641930893048141514_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gJ1u3IXEywsQ7kNvgF83Uo7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9msAYYPtNK9j1GOne_Vs_vqQ89z4sVOAAJ4xQRynBFw&oe=676AAC37"}, "display_name": "EducationXR", "keywords": [], "long_description": "EducationXR is an advanced Enterprise 3D training and education authoring platform, addressing creation, deployment, and distribution of immersive experiences available from all phones, tablets, desktops, and VR headsets.\n\nAll content created with EducationXR is immediately available from any device and automatically multiplayer, so users can connect together for interactive learning regardless of device and regardless of location. EducationXR supports SSO for ease of Enterprise access and a robust system for analytics, including 3D VR heatmaps, to help capture the maximum value from immersive learning.\n\nMicrophone permissions required for multiplayer sessions and voice transmission.", "short_description": "EducationXR is an advanced 3D training and education authoring platform addressing creation, deployment, and distribution of immersive experiences for all phones, tablets, desktops, and VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://admin.educationxr.com/public/legal/privacy", "developer_terms_of_service_url": "https://admin.educationxr.com/public/legal/terms", "publisher_name": "Heizenrader LLC", "support_website_url": "https://adm