74841_745617826352301_1004570169019751923_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fi6zgdi6AaUQ7kNvgH09nH8&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYA8s_WX8zekgykkIA1_UO5s8hDE2XP_Nz_DjXhLwo3zlw&oe=671A2341"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus Cover Landscape.png", "id": "367495155712652", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75388619_367495159045985_641930893048141514_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q5ojkw86Uy4Q7kNvgEQ91uM&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDn1d3WQW0DKjyH_nsb2tkzCXjnhjJUg85IDSVYer5j7w&oe=671A40B7"}, "display_name": "EducationXR", "keywords": [], "long_description": "EducationXR is an advanced Enterprise 3D training and education authoring platform, addressing creation, deployment, and distribution of immersive experiences available from all phones, tablets, desktops, and VR headsets.\n\nAll content created with EducationXR is immediately available from any device and automatically multiplayer, so users can connect together for interactive learning regardless of device and regardless of location. EducationXR supports SSO for ease of Enterprise access and a robust system for analytics, including 3D VR heatmaps, to help capture the maximum value from immersive learning.\n\nMicrophone permissions required for multiplayer sessions and voice transmission.", "short_description": "EducationXR is an advanced 3D training and education authoring platform addressing creation, deployment, and distribution of immersive experiences for all phones, tablets, desktops, and VR headsets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://admin.educationxr.com/public/legal/privacy", "developer_terms_of_service_url": "https://admin.educationxr.com/public/legal/terms", "publisher_name": "Heizenrader LLC", "support_website_url": "https://admin.educationxr.com/public/contact-us/request", "website_url": "https://educationxr.com/", "category": "APPS", "comfor