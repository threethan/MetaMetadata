097481388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289720_767418100814721_1225050728314151888_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-_H_McAQ9QQ7kNvgEnMfdo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAaLH7e6Cu4j8AqzVYjznxdhLEwIIrlVQTFEIOhnBmRMQ&oe=67334341"}, {"file_name": "5.png", "id": "772838470285351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572752_772838473618684_7515280295499380483_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=REJDUY6vcl4Q7kNvgGjavyZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgpReSW4GNx0thZk0f_7ZLndOHhl-_C_k3wMHYykNbvw&oe=67333BDE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc11.png", "id": "947269839428464", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443242_947269842761797_6904528688601451475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sMaoBTC1sooQ7kNvgG287dY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAu7hNNcME4ocH2A3ADRbQbtQqL6LAWaZQpPuZw984T-Q&oe=673337F4"}, "display_name": "Golf Pool VR", "keywords": ["Golf", "pool", "sport", "moon", "mini"], "long_description": "Experience a unique game that combines the challenge of Golf with the rules of Pool! Set in various beautiful and physically realistic environments, Golf Pool VR is a competitive and fun game you can play solo or with friends.\n\nKey Features:\n\n- Player vs AI.\n- Two player MP competitive mode. \n- Arcade mode with 10 SP mini levels.\n- Detailed and immersive environments. Experience the solitude of the moon or the adrenaline - rush of a game or two on top of a skyscraper!\n- Accurate physics based gameplay mechanics.\n- 8-Ball Pool (Blackball) rules currently implemented.\n- Additional bonus game modes.\n- Binaural 3d sound system.\n\n*(feel free to join the Community Discord channel to find other players and schedule MP match with them https://discord.gg/ZGAHEuA )", "short_description": "Experience a unique game that combines the challenge of Golf with the rules of 8-ball Pool (Blackball)! Set in various beautiful and physically realistic environments, Golf Pool VR is a competitive and fun game you can play by yourself vs AI or MP with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "https://frozen-dreams.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Frozen Dreams", "support_website_url": "https://frozen-dreams.com/contact/", "website_url": "https://frozen-dreams.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8593776654037073"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001662_7689200034517672_4641083459724106749_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hz8ZEaPplqwQ7kNvgHVqv5_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4n96JfXryx1-vkNeXhToBWj09Oq_SsF7K0NBofl7PQg&oe=6733262E"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Golf Pool VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}, {"