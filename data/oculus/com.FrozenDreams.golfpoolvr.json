01", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75441578_745832259432834_6149206886171614054_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mg61W5EoE6YQ7kNvgHvu-vp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3IwHBB90yxvkci9SXiTYWFi1tIW4owmHooVaNbm4aMA&oe=676E951A"}, {"file_name": "3.png", "id": "767418097481388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75289720_767418100814721_1225050728314151888_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R6t3s0LGjEAQ7kNvgFm4RN8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApzXgpXlC3vCNsRWc-mrV6VzPmwRsMV4GzTQfIJj_1ng&oe=676E96C1"}, {"file_name": "5.png", "id": "772838470285351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75572752_772838473618684_7515280295499380483_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C5lDbsmGbhMQ7kNvgHPM7el&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPz9PobdzV9iJA-nu6GeDsvyOzHsyvcaUv7upueNfTBg&oe=676E8F5E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "sc11.png", "id": "947269839428464", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75443242_947269842761797_6904528688601451475_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f_7posteeb8Q7kNvgE2R1TH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClPugV2fxBTdnEm1sGFygxFxxa07aor96hUDmmYyvLOQ&oe=676E8B74"}, "display_name": "Golf Pool VR", "keywords": [], "long_description": "Experience a unique game that combines the challenge of Golf with the rules of Pool! Set in various beautiful and physically realistic environments, Golf Pool VR is a competitive and fun game you can play solo or with friends.\n\nKey Features:\n\n- Player vs AI.\n- Two player MP competitive mode. \n- Detailed and immersive environments. Experience the solitude of the moon or the adrenaline - rush of a game or two on top of a skyscraper!\n- Accurate physics based gameplay mechanics.\n- 8-Ball Pool (Blackball) rules currently implemented.\n- Additional bonus game modes.\n- Binaural 3d sound system.\n\n*(feel free to join the Community Discord channel to find other players and schedule MP match with them https://discord.gg/ZGAHEuA )", "short_description": "Experience a unique game that combines the challenge of Golf with the rules of 8-ball Pool (Blackball)! Set in various beautiful and physically realistic environments, Golf Pool VR is a competitive and fun game you can play by yourself vs AI or MP with friends."}]}, "developer_name": null, "developer_privacy_policy_url": "http://frozen-dreams.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Frozen Dreams", "support_website_url": "https://steamcommunity.com/app/1008700/discussions/", "website_url": "http://frozen-dreams.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "SPORTS", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "478514513722387"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "9725415894141192"}, {"status": "PUBLISHED", "id": "1039211887763422"}, {"status": "PUBLISHED", "id": "1226530492045656"}, {"status": "PUBLISHED", "id": "238636611110580"}, {"status": "PUBLISHED", "id": "923332128525766"}]}, "baseline_offer": {"id": "1226530492045656"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734292800, "status": "PUBLISHED", "id": "9725415894141192"}]},