-iad3-2.oculuscdn.com/v/t64.5771-25/12727792_1277483228952841_1410584851_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YHloQIkvm4kQ7kNvgHk4Xvg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsf8A0pyW1B6dwznUlOFptVEZ9HBf2GOKzD9_3uNg77Q&oe=6771396A"}, {"file_name": "migrated_image.png", "id": "2811542425596947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12727797_301004060254829_1500414183_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sr2LcTQ5ivAQ7kNvgFRMDS-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0LZWXxl9QEWHVHcc6HdeafTwsgRUEDp7t_jWvkl9GmQ&oe=67713BA7"}, {"file_name": "migrated_image.png", "id": "2738807569571714", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12386448_315258945476102_1813863411_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H_EBUl84josQ7kNvgGfXNVZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyx8NhHyPc8hfg0e6-tRosJHoklyA_cBc5ltC_94zWdQ&oe=67711993"}, {"file_name": "migrated_image.png", "id": "258485008493558", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12522403_605953636231970_1698927185_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_ZDD__ZR1UQ7kNvgGpATIu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbUHBAAZE_77gIdcTwSnauTtKB7JJ1d21CKCXXnVwsxQ&oe=67714CD5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Specular Theory", "keywords": ["Virtual Reality", "360 video", "Movies", "Cinematic", "Behind the scenes"], "long_description": "The world is not flat, our view of it shouldn\u2019t be either. Download our app to get your ongoing dose of the best VR experiences, created by Specular Theory and our featured partners.  This is a one\u00adstop place to\nfind premium experiences and award\u00adwinning VR content including music and entertainment, ST\noriginals and other fun experiments we\u2019ve shot along the way!\n\nWelcome to anti\u00adflat entertainment.\n\nSpecular Theory was founded in 2013 to break new ground in the realm