_512x512.png", "id": "195627282165246", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203613_195627285498579_3340267261792212314_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0NY9JCML4QQ7kNvgErgUIZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYB6vXc6my7QtbK5h0S5iuZoLUBNAIBYzdMf5VLzxRzqkQ&oe=66F2A237"}]}, "id": "864174954909145", "locale": "en_US", "screenshots": [{"file_name": "Oculus_3_2560x1440.png", "id": "1236421240294922", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031419_1236421243628255_5323217315741460823_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SVRywlL2WU0Q7kNvgEBJLqV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYBWhODGyc4-NIU83ZBg4RDUomcCqx0DnXaYWW38zPJD5w&oe=66F2A168"}, {"file_name": "Oculus_5_2560x1440.png", "id": "682994023372250", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974736_682994026705583_4577730632659347148_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4VDddTvKL8sQ7kNvgGXc5GH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYDOuh0EC-g7mYlB91Dz_gFuu0DdrLwM9RnGQUUYcZekTA&oe=66F2B93E"}, {"file_name": "Oculus_1_2560x1440.png", "id": "1318217525618240", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974634_1318217528951573_4762335875613835512_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wy2szjxJB3UQ7kNvgFaRrWy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYCnUrw1HDN4z-2y0LETAa4tQWbogc50TuzRbELAg-1iUQ&oe=66F2BF6E"}, {"file_name": "Oculus_4_2560x1440.png", "id": "1214198305972123", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974736_1214198309305456_6079151099526609138_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzdhFZ_IiAEQ7kNvgHzlKw_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYARxGw4bUaS5eSn3AGkSHg0jdfUYVaASGVnAJTfL1C99Q&oe=66F29F11"}, {"file_name": "Oculus_2_2560x1440.png", "id": "1521755661670181", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982468_1521755665003514_1719816218982804832_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=60FBsAJ3N0sQ7kNvgHN9N6v&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVEBGteKulhebhkCfVl4NOP&oh=00_AYB1F5JN1Vq3iHOzsR2Lz6Nx_e96BCyzamL81wnu68lpTg&oe=66F2A73A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pool Cubed", "keywords": [], "long_description": "FINALLY! Version 1.1 with an experimental online multiplayer mode! Also full American 8-ball rules, expanded Arcade Mode, and an open sandbox practice mode. Support us at http://patreon.com/cavemanlabs or contact us on our website at http://cavemanlabs.com/contact-us to give us your feedback.\n\nIn Pool Cubed, we've exploded the classic pool table into a whole new dimension... and unapologetically twisted it into a first-person-shooter in the process. Now you can literally shoot pool... in VR! This version has two play modes, complete with bar-room ambience. There's a \"classic mode\" for a more familiar experience, and a dual-wielding \"arcade\" mode with a more modern flair. \n\nThis is a sneak-peek at a true one-of-a-kind VR experience that will only get better as we add more features. Join us on this journey and get it while it's free. You can give us feedback on it and check out some of our other experiments at CavemanLabs.com.", "short_description": "If you like to shoot pool, then launch into a whole new dimension where you can actually do just that. It's all in the name... well, except for the guns."}]}, "developer_name": null, "developer_privacy_policy_url": "http://cavemanlabs.com/p3-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Caveman Labs, LLC", "support_website_url": null, "website_url": "http://cavemanlabs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {