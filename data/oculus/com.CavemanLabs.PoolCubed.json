40.png", "id": "485593129259007", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86615257_485593132592340_9219387823348455694_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wFvja9uH0nIQ7kNvgFuq9n8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvdXZuRvoR9GrsXO2MVcRlen3Oz2I7BTSLd31KGRzogw&oe=6718FC36"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pool Cubed", "keywords": [], "long_description": "In Pool Cubed, we've exploded the classic pool table into a whole new dimension... and unapologetically twisted it into a first-person-shooter in the process. Now you can literally shoot pool... in VR! This version has two play modes, complete with bar-room ambience. There's a \"classic mode\" for a more familiar experience, and a dual-wielding \"arcade\" mode with a more modern flair. \n\nThis is a sneak-peek at a true one-of-a-kind VR experience that will only get better from here! Give us some feedback on it and check out some of our other experiments at CavemanLabs.com.", "short_description": "If you like to shoot pool, then launch into a whole new dimension where you can actually do just that. It's all in the name... well, except for the guns."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/b8367e77-edc5-427e-92a5-5ad3d917549e", "developer_terms_of_service_url": null, "publisher_name": "Caveman Labs, LLC", "support_website_url": null, "website_url": "http://cavemanlabs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": 