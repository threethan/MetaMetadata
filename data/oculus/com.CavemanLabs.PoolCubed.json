7&_nc_sid=6e7a0a&_nc_ohc=QkPqQp-t8OcQ7kNvgE6aFhH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDywaChS4P5U88Ui9lX-lZaIYvCQ1EQuipwOdVk0Uy4vg&oe=6718E2BA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Pool Cubed", "keywords": [], "long_description": "FINALLY! Version 1.1 with an experimental online multiplayer mode! Also full American 8-ball rules, expanded Arcade Mode, and an open sandbox practice mode. Support us at http://patreon.com/cavemanlabs or contact us on our website at http://cavemanlabs.com/contact-us to give us your feedback.\n\nIn Pool Cubed, we've exploded the classic pool table into a whole new dimension... and unapologetically twisted it into a first-person-shooter in the process. Now you can literally shoot pool... in VR! This version has two play modes, complete with bar-room ambience. There's a \"classic mode\" for a more familiar experience, and a dual-wielding \"arcade\" mode with a more modern flair. \n\nThis is a sneak-peek at a true one-of-a-kind VR experience that will only get better as we add more features. Join us on this journey and get it while it's free. You can give us feedback on it and check out some of our other experiments at CavemanLabs.com.", "short_description": "If you like to shoot pool, then launch into a whole new dimension where you can actually do just that. It's all in the name... well, except for the guns."}]}, "developer_name": null, "developer_privacy_policy_url": "http://cavemanlabs.com/p3-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Caveman Labs, LLC", "support_website_url": null, "website_url": "http://cavemanlabs.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "554377176733826"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974589_888872458806507_1521202783621254408_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bhAMGbmCbXoQ7kNvgGfBoEK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCkItFGU2b3kOGbxuFVg19tEaUqBWBhLZIQ88kVnSvUg&oe=6718C7CE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pool Cubed", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1622743142, "lastRevision": {"nodes": [{"id": "2905343966402042", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3668769916584785", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "182055157067893"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Oculus_icon_512x512.png", "id": "195627282165246", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75203613_195627285498579_3340267261792212314_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PK2xAy9BgzsQ7kNvgF-4yz3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBAuVsfV3DSjGYJJYIbDweJHc