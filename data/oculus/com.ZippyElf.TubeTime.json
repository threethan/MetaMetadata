.5771-25/39036602_1641584490070843_9150535379462293394_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ijZrRO1QGLcQ7kNvgECENuP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXryAqGDAo80fvvzf-H8H_m48btn2IWPPnDnnmSK0NHQ&oe=676168BF"}, {"file_name": "3rdperson2560x1440.png", "id": "369721786197637", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035347_369721789530970_5122590167641689814_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H69fD8Dx6PAQ7kNvgHKqpss&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6SOh-z35x58ekf-1QucvoAs7e1TD-zH2ygFEMimx9vw&oe=67617534"}, {"file_name": "night2560x1440.png", "id": "1098708348069705", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974625_1098708351403038_1061226773984310534_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sXLTs9XlnyEQ7kNvgGrs8o6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrndZ8x1_Ucf1pBpGUHeQBTBSJ5zHJEZ9Mo-kR3Oy69w&oe=67614A9C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TubeTime2560x1440.png", "id": "2284080728657621", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569430_2284080731990954_1834225393466360514_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MO6x-vwx2KsQ7kNvgFQb4vS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWlSI_zyhsTRIL0Wdin5wC3CMBov2Rfwq_YddhPlHz8g&oe=67615EE7"}, "display_name": "Tube Time", "keywords": ["Tubing", "Relaxation", "Scenery", "adventure", "multiplayer"], "long_description": "Welcome to Tube Time\u2014a relaxing VR river tubing experience! Drift down beautiful rivers, take in the stunning landscapes, and enjoy the gentle flow of nature. Maneuver around rocks and logs at your own pace, discovering hidden spots and enjoying surprises along the way. Whether you\u2019re floating solo or with friends, Tube Time is all about kicking back, enjoying the scenery, and sharing good times. With immersive visuals and intuitive controls, it\u2019s the perfect escape to unwind and create unforgettable moments in a peaceful, vibrant world.", "short_description": "EARLY ACCESS - Hop in and float downriver with friends! Chill out as you drift through beautiful landscapes, soak up the scenery, and enjoy some good vibes together. It\u2019s the perfect escape when you just want to relax and take in the views. \n\nWe\u2019re still hard at work building Tube Time, so we\u2019d love your feedback! Connect with us on Discord or drop us an email. Thank you!\nwww.zippyelf.com"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zippyelf.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Zippy Elf", "support_website_url": "http://www.zippyelf.com/", "website_url": "http://www.zippyelf.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "331529188132278"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "28439274385671859"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75356794_889841719252241_2228185837116783169_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b2ai2ZzKzOcQ7kNvgGIijhz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPyvOdqHbY7A0DBwlM-b8esDh9U465MgVbjFzMQ05RfA&oe=676165B5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Time", "platform": "ANDROID_6DOF", "context_category": {"contex