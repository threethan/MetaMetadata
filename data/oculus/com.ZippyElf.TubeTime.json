uluscdn.com/v/t64.5771-25/38974456_1594835311157632_1300132112682920898_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=roUnbV0ylyUQ7kNvgHxmNp3&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYACsPt40cfjoNKdfl7txIK3DGyzYZ2yY7_zU_oLEnkPNg&oe=6756D2BD"}, {"file_name": "fish2560x1440.png", "id": "838936781499492", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974758_838936784832825_5651749459341392745_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=425mG8VFC8sQ7kNvgF1c_h6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCTuQclVBYgstxCYxZrmWKEJefunFN3eQvFMTX5vhqH2Q&oe=6756DEDB"}, {"file_name": "screenshot_2560x1440_2024-11-13_09-11-40.png", "id": "2269031003455507", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974508_2269031006788840_2032034311802955115_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQnm0s4KQ9cQ7kNvgHffU0y&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCGhJghu56EJ3gjiltCWrTIShOYV3irwDKmnUgDnqWa1A&oe=6756D1E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TubeTime2560x1440.png", "id": "2284080728657621", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569430_2284080731990954_1834225393466360514_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FlBzA5bKmwMQ7kNvgFo6bag&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDUdJUdTYa2qytMBE_7xA2ttthW9rgCiDiWh82FWOzv9g&oe=6756D2E7"}, "display_name": "Tube Time", "keywords": ["Tubing", "Relaxation", "Scenery", "Nature", "Multiplayer"], "long_description": "Welcome to Tube Time\u2014a relaxing VR river tubing experience! Drift down beautiful rivers, take in the stunning landscapes, and enjoy the gentle flow of nature. Maneuver around rocks and logs at your own pace, discovering hidden spots and enjoying surprises along the way. Whether you\u2019re floating solo or with friends, Tube Time is all about kicking back, enjoying the scenery, and sharing good times. With immersive visuals and intuitive controls, it\u2019s the perfect escape to unwind and create unforgettable moments in a peaceful, vibrant world.", "short_description": "EARLY ACCESS - Hop in and float downriver with friends! Chill out as you drift through beautiful landscapes, soak up the scenery, and enjoy some good vibes together. It\u2019s the perfect escape when you just want to relax and take in the views. \n\nWe\u2019re still hard at work building Tube Time, so we\u2019d love your feedback! Connect with us on Discord or drop us an email. Thank you!\nwww.zippyelf.com"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zippyelf.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Zippy Elf", "support_website_url": "http://www.zippyelf.com/", "website_url": "http://www.zippyelf.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "28400037986262166"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75356794_889841719252241_2228185837116783169_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7Akrh7WQrIQ7kNvgHt9KSU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDRNIRlN8WEmIvQMn-ggMUTsVtlOigsTSZLm7-pxcQ-cg&oe=6756D9B5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Time", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES