e7a0a&_nc_ohc=6PdI1c-i31gQ7kNvgGDmskx&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDpKTrvxN6p_fIZ05Z4_x-kLWZl1_fy2QZGOBLW3lvTcQ&oe=675184C7"}, {"file_name": "Screenshots_007.png", "id": "545909776817911", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/86659754_545909780151244_4010903981250884421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QAdpivG6T3MQ7kNvgGTAiEv&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBuryTCXDYLdtEHIZP2uQl6Sqm6dPLrTPahQVCSAlYByg&oe=6751882E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "527712595035285", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974729_527712598368618_6616314205426690112_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5bQmj_nM5FsQ7kNvgGezoXf&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCi3WHSxMqdyfSCYetkOe-IiKKAIdwXQg4QwnG7wsc3Gg&oe=6751ADEB"}, "display_name": "Gamerz Lab", "keywords": [], "long_description": "Gamerz Lab is a multi-activity, sci-fi themed playground designed to give the users a holistic gaming experience like never before.\n\nThere are two separate zones. The Game Zone offers a virtual game booth featuring a wave based shooting game. Over time more and more game booths will be added, each with exciting new games. With every new game Gamerz Lab will become a completely new experience to explore!\n\nWhenever you want to take a break from Game Zone you can move over to the Relax Zone and chill out. With amazing visuals and micro-activity corners like boxing corner and many more to come with every update will make the Gamerz Lab an unforgettable gaming experience for gamers.\nRelax in the lobby or use the boxing corner to release your inner Mike Tyson.\nGame booths offering different experiences (Shooters etc)\nBreathtaking visuals and amazing gameplay.\n", "short_description": "A multi-activity playground designed to immerse you into a sci-fi world of shooting games along with many more to come!"}]},