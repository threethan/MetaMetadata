i": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974608_126126002957948_8632638290137506975_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wJCecZHT8qoQ7kNvgFvxz1G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXHPAgrZDgYnF9nh4vSH1EVY2tqUJeetjRtmRfu2825g&oe=6763F9C7"}, {"file_name": "Screenshots_007.png", "id": "545909776817911", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86659754_545909780151244_4010903981250884421_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pr_HHU33I_QQ7kNvgGC9urZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6-l06JBEJrrPuakMm4xVODDd0JlaT2BGd2LVqJFyv-g&oe=6763FD2E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape.png", "id": "527712595035285", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974729_527712598368618_6616314205426690112_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4ImppDQ-ZrAQ7kNvgEjyclR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtf42VzusRcSwF8ekxT2Cu0Uh5JKzn5xDQrknNUOUkNw&oe=676422EB"}, "display_name": "Gamerz Lab", "keywords": [], "long_description": "Gamerz Lab is a multi-activity, sci-fi themed playground designed to give the users a holistic gaming experience like never before.\n\nThere are two separate zones. The Game Zone offers a virtual game booth featuring a wave based shooting game. Over time more and more game booths will be added, each with exciting new games. With every new game Gamerz Lab will become a completely new experience to explore!\n\nWhenever you want to take a break from Game Zone you can move over to the Relax Zone and chill out. With amazing visuals and micro-activity corners like boxing corner and many more to come with every update will make the Gamerz Lab an unforgettable gaming experience for gamers.\nRelax in the lobby or use the boxing corner to release your inner Mike Tyson.\nGame booths offering different experiences (Shooters etc)\nBreathtaking visuals and amazing gameplay.\n", "short_description": "A multi-activity playground designed to immerse you into a sci-fi world of shooting games along with many more to come!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://dreamerzlab.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Dreamerz Lab Ltd", "support_website_url": null, "website_url": "https://dreamerzlab.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ARCADE", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "641853910228653"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "830354300954875"}]}, "baseline_offer": {"id": "830354300954875"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1634765760, "status": "PUBLISHED", "id": "830354300954875"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6065229856883131", "version": "1.0.1"}, "id": "284927896714354", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5589954674410654", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6065229856883131"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "