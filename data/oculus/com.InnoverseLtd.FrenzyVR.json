PQL5q6SYQ7kNvgHJ6Cau&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYAMJWMpDgUiszP7n6hl-sGrr7HrQOCFWTn7KHPXigHK7Q&oe=66ED6B16"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i4Ys_CuPvSEQ7kNvgHpjBET&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYCmTX1YUkKQ7nEmbUfqz-e9VVXtnvnS2cmfA7sKrBoAKg&oe=66ED4666"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PcNxKXCxyEUQ7kNvgEqelMo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYBZClMcYQq90sYMwY26LVyjQrM9NRqC65BtZmDnNEbCyA&oe=66ED7280"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DwcrJBA0PjEQ7kNvgEred1s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYA14YyxLGjtnWGTTquBaKQ8bTCcsHd9Fzr9NkQ4dhBmdw&oe=66ED6EFC"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r7cZAZpJBtAQ7kNvgH5ajjt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYBQK4SIUBCVZsHa2DtkhMh0vcChyn2EfdP9MM4s3zePwg&oe=66ED6066"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "calandscape.png", "id": "1690346445127882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035319_1690346448461215_7054082562608145111_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzz3MQLQ_y0Q7kNvgFDFloR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjJmkBozyqPHXmfF2tjPEZT&oh=00_AYBEblBOMaiPu8Sf7Rn4bCkwTrcYosZ3kvlx4RRQrEQ4RQ&oe=66ED5A12"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the mayhem into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{1018933603024687}\n\nKey Features:\n\n- **Interactive** environments with **destructible** objects.\n- Combat against **ragdoll enemies** using melee and ranged weapons.\n- Story mode featuring an full **narrative and campaign**.\n- Extensive map selection in **free play mode**, including unique settings such as Labs and Nightclub.\n- **Weapon customization** with attachments and skins.\n- **Boss fights** in custom maps.\n- Additional **mini games** for varied gameplay.\n\n\n\n", "short_description": "Frenzy VR is an action fighter all about destruction and mayhem within interactive physics environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://www.innoverse.co.uk/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb