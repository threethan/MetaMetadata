835746856_211841733235979620_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aUFaUlgK3WoQ7kNvgFg6yWd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDgOmBkSyz4-JOwJP350k8wyZUkiPPHDBpMVlPXj7Hpg&oe=67179110"}, {"file_name": "Screenshot5.png", "id": "880776882536974", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974655_880776885870307_730458897018616067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VJ3IyLgYdMQ7kNvgHsuJ6L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDujZmMApRh89iSlv19NTz80IDEklO-cx17ohW2Wfnj8w&oe=67179D5E"}, {"file_name": "Screenshot4.png", "id": "272936900942329", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974883_272936904275662_2662082753078920897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bxtFXClIdfoQ7kNvgF3p1qy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCaB4-Iv6Jee5o_8Q5uOQF9eEnJNZTmSv5ws2Fqm9D56w&oe=671792F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Banner Landscape.png", "id": "518109149255436", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974584_518109152588769_9082015115285105038_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uiDZYKOFqhgQ7kNvgGBF5AN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZfZ6NeS6VGLT-x1cpuAHqghig-LEIPmK-RiSf3jNN0Q&oe=67177E1B"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "Frenzy VR is a game full of mayhem and destruction. You are placed inside carefully constructed environments where you can go mad and be free to do what you please in a world without consequences. A VR game where all objects can be a weapon, with the added bonus of having satisfying destruction physics. Ever dreamed of hitting your best friend in the face with a toaster? Probably not, but now I mentioned it I bet you want to try it! Frenzy VR is great for stress relief, anger management, and of course just having a bit of fun!\n\n", "short_description": "A destruction and mayhem sandbox playground"}]}, "de