78835746856_211841733235979620_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t8k1x8UrWhUQ7kNvgEYNLGm&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBfe66EOaifOW4cxt6b_1LBKJTxSeJ4HA9FqNpXmX-2DA&oe=671A3410"}, {"file_name": "Screenshot5.png", "id": "880776882536974", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974655_880776885870307_730458897018616067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8VJ3IyLgYdMQ7kNvgE3_KDv&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCl-oU1AEK8lqGcROvzOk_ogZS0x1J9gZa0_PI70S_sEg&oe=671A405E"}, {"file_name": "Screenshot4.png", "id": "272936900942329", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974883_272936904275662_2662082753078920897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bxtFXClIdfoQ7kNvgFqc4kR&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDWlDUqCJIzGy7jJhCbnigmX_jr_SACIlFdVVTvrkkbVQ&oe=671A35F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Banner Landscape.png", "id": "518109149255436", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974584_518109152588769_9082015115285105038_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3JDIvwXn8FAQ7kNvgEqT37Z&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBisOcG3XZMKUZC9OKi_dAKcOBnST15Dt1RNWnlcOdAzQ&oe=671A211B"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "Frenzy VR is a game full of mayhem and destruction. You are placed inside carefully constructed environments where you can go mad and be free to do what you please in a world without consequences. A VR game where all objects can be a weapon, with the added bonus of having satisfying destruction physics. Ever dreamed of hitting your best friend in the face with a toaster? Probably not, but now I mentioned it I bet you want to try it! Frenzy VR is great for stress relief, anger management, and of course just having a bit of fun!\n\n", "short_description": "A destruction and mayhem sandbox playground"}]}, "