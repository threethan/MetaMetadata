_ohc=HBTk2Dw-KJEQ7kNvgH8mmz4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYBq0YdsJMrMOobwuc27140VVeqxCuRXLbXPJWWz08_Xfw&oe=66E6D396"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3kKSLlthN5sQ7kNvgEAOOGO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYD6I5RweRgtXBlKtigCktGNLsZEeZhgliNhQ_CSAPVwSg&oe=66E6AEE6"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZuyVimJd7pcQ7kNvgHH6-nm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYAzNrGzZZbvIVZTme6ZXABgHepVOZ32wypydkFUTeX7xQ&oe=66E6DB00"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B8yDvMtVJOgQ7kNvgGY2NUv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYDFfMGMIYPAWAQQv-PS_W9CpymGZxRMFwutZOO1ovlJjw&oe=66E6D77C"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PG1ddZrzHe8Q7kNvgEZ7zZI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYA4dALZE3ajSKJtIauXBh1KdBjLHctGf3ONsm71yY6uhg&oe=66E6C8E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "calandscape.png", "id": "1690346445127882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035319_1690346448461215_7054082562608145111_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eKvOjrptwlMQ7kNvgGKorwg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqNzcQ2xHZGaXP3oiX7pUPR&oh=00_AYBw06g3pUmbaEMY_Ei5KonTWX64uKh7XyE7LyYDmZEqZA&oe=66E6C292"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the mayhem into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{1018933603024687}\n\nKey Features:\n\n- **Interactive** environments with **destructible** objects.\n- Combat against **ragdoll enemies** using melee and ranged weapons.\n- Story mode featuring an full **narrative and campaign**.\n- Extensive map selection in **free play mode**, including unique settings such as Labs and Nightclub.\n- **Weapon customization** with attachments and skins.\n- **Boss fights** in custom maps.\n- Additional **mini games** for varied gameplay.\n\n\n\n", "short_description": "Frenzy VR is an action fighter all about destruction and mayhem within interactive physics environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://www.innoverse.co.uk/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_m