AYBRuXPO8eghY4gNOxTw9GYC_LMKwCryKG6QErXw5nZLJw&oe=672F5541"}]}, "id": "857997129778343", "locale": "en_US", "screenshots": [{"file_name": "fss1.png", "id": "1581915522362206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003286_1581915525695539_1787690103602106794_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q1heXX5PWi8Q7kNvgEXxSmW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB85b7lD13DAztX0_rur7Ig8TKouS7vTp9BduiSNBJjHQ&oe=672F5616"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rAEhfkTZoXsQ7kNvgF18uG0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA0pk2-PUQx0Za-ijR8yBO4hmJgThp2iwoIUdZLM3nE-g&oe=672F3166"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LGD1kZBm0UQQ7kNvgGO2x9z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMFxWrR2NkdIjXcvafib35o_wM6M4tL61ADsSVltZ4lA&oe=672F5D80"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NYprocUT7WkQ7kNvgFCaljk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYRWHou1-l3Kgz1YmMZII0fJQj4ntWMQOLMSgHuIUD9A&oe=672F59FC"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KTjfP_4rOlUQ7kNvgEWafe8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVkIyDttl72V3j7UP28CKS3CQ8E1lVyFWbbql1d8b-iA&oe=672F4B66"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fvrabtestlandscape.png", "id": "950883880417357", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974778_950883883750690_1310628088402518426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kvbupJHtwaUQ7kNvgErVxUz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClLBdNXvVT0kT9xGUfs1SstPklvs1tHrW1Tp_AIFtVPQ&oe=672F4B01"}, "display_name": "Frenzy VR", "keywords": ["frenzy", "extinction", "physics", "shooter", "cheap"], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the chaos into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{2109188632847206}\n\n# FULLY INTERACTIVE AND DESTRUCTIBLE WORLDS\nAll maps feature fully destructible items, objects, & enemies\n{1205834334006646}\n# RAGDOLL PHYSICS WITH MELEE / RANGED WEAPONS\nNPCs use realistic physics ragdolls for ultimate chaos and mayhem\n{1288794592495760}\n# STORY MODE WITH NARRATIVE AND CAMPAIGN\nComplete the full story with multiple missions and take down the Reborn Company\n{427514700347104}\n# 10+ REALISTIC MAPS AND MISSIONS\nGo ballistic in fully interactable worlds built specifically for you to destroy \n{1040111410694158}\n# FULL WEAPON CUSTOMIZATION AND UPGRADES\nRealistic gun and melee weapon physics that feel just like real life\n{1439551213390894}\n# FIGHT VICIOUS AND CRAZY NPCS\nShow no mercy as you fight back against the corrupt NPCs\n{1556545868591589}\n# EXTRA MINIGAMES AND GAMEMODES\nYou'll never run out of things to do with our infinitely replayable gamemodes\n{887725349457146}", "short_description": "Frenzy VR is an action sandbox all about destruction, shooting, ragdolls, realistic combat, and mayhem within interactive destructible environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative.