ts": [{"file_name": "fss1.png", "id": "1581915522362206", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003286_1581915525695539_1787690103602106794_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OHoRgrcOwRMQ7kNvgGhDYq5&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBaQO-7fhm166mhDazIubNVBbTnWOgqisIppuFI4xy8EA&oe=670A6C16"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bw8HYb6qB74Q7kNvgH8FJ5Z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsO3q4YFrnnFPUZ6wKn3lzqgpE1MoPJwyw4_HCAdLoAw&oe=670A4766"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xYVL4caHO2wQ7kNvgEghAgY&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRDZR9gPumeaBtskvs5PunU5VV2uofr6zxJ-dQRFMxwg&oe=670A7380"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77JPzc2bce8Q7kNvgHLlFGJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAn1FWVLNoTci8JQpO9ZUAoHGulBsOQD0cJGd17UdoUzQ&oe=670A6FFC"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CvzR2JwbwHoQ7kNvgGdbm2g&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDUPWOm9kIKNmn8cMx2KOx56AH7Yc9CAYe7i3eDdD-izQ&oe=670A6166"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FrenzyVRLayers(1)tryingland.png", "id": "458792556508375", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974611_458792559841708_1793807827884714709_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C1n_dLSwnz0Q7kNvgHPRyAX&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtozt4Qsu-jMOkj5ppyxp2RROHcXipgpzs9jqu8DLu1A&oe=670A7418"}, "display_name": "Frenzy VR", "keywords": ["frenzy", "extinction", "physics", "shooter", "cheap"], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the chaos into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{2109188632847206}\n\n# FULLY INTERACTIVE AND DESTRUCTIBLE WORLDS\nAll maps feature fully destructible items, objects, & enemies\n{1205834334006646}\n# RAGDOLL PHYSICS WITH MELEE / RANGED WEAPONS\nNPCs use realistic physics ragdolls for ultimate chaos and mayhem\n{1288794592495760}\n# STORY MODE WITH NARRATIVE AND CAMPAIGN\nComplete the full story with multiple missions and take down the Reborn Company\n{427514700347104}\n# 10+ REALISTIC MAPS AND MISSIONS\nGo ballistic in fully interactable worlds built specifically for you to destroy \n{1040111410694158}\n# FULL WEAPON CUSTOMIZATION AND UPGRADES\nRealistic gun and melee weapon physics that feel just like real life\n{1439551213390894}\n# FIGHT VICIOUS AND CRAZY NPCS\nShow no mercy as you fight back against the corrupt NPCs\n{1556545868591589}\n# EXTRA MINIGAMES AND GAMEMODES\nYou'll never run out of things to do with our infinitely replayable gamemodes\n{887725349457146}", "short_description": "Frenzy VR is an action sandbox all about destruction, shooting, ragdolls, realistic combat, and mayhem within interactive destructible environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://cliq