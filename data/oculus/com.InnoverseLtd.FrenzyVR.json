dn.com/v/t64.5771-25/38974655_880776885870307_730458897018616067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2FqOPTCuFFsQ7kNvgEz-e9x&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBFGeJ4tMnkggUA_SX9ws8RSJ0bRBgEO2u-CtxDpQ8DnQ&oe=6702855E"}, {"file_name": "Screenshot4.png", "id": "272936900942329", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974883_272936904275662_2662082753078920897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tMFaNGTGxd8Q7kNvgETS-mi&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYANhG0OVzBqzrE-7h2h8mDNJew6RLPiTUtLdGaxuOnC-w&oe=67027AF4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Banner Landscape.png", "id": "518109149255436", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974584_518109152588769_9082015115285105038_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPuNHcky02QQ7kNvgHO2Lo-&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDiKB0hR8cjvOp7ac_lG_JCKcE58PhfExbBn0Ra4oIC6w&oe=6702661B"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "Frenzy VR is a game full of mayhem and destruction. You are placed inside carefully constructed environments where you can go mad and be free to do what you please in a world without consequences. A VR game where all objects can be a weapon, with the added bonus of having satisfying destruction physics. Ever dreamed of hitting your best friend in the face with a toaster? Probably not, but now I mentioned it I bet you want to try it! Frenzy VR is great for stress relief, anger management, and of course just having a bit of fun!\n\n", "short_description": "A destruction and mayhem sandbox playground"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.innoverse.co.uk/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Innoverse Ltd", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category":