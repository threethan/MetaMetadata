culuscdn.com&oh=00_AYBKK86pX0eHY9hqaj_nOf1BLhEQgtfTNEv4ssqfSObTzw&oe=6777CDE9"}]}, "id": "3742504672681733", "locale": "en_US", "screenshots": [{"file_name": "fss1.png", "id": "1581915522362206", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003286_1581915525695539_1787690103602106794_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XSuOD4ojcQMQ7kNvgFNu--W&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDYl4ZPaXB9qWWXfZvZCNwptkm1os8IJbYpo5kZcWKnzQ&oe=6777D896"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A_yU4uisyrIQ7kNvgHCg11X&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAlf8MW1MGvNJ5PdMrPEfzWprN7iTQrVIfdOA2IrJkn7g&oe=6777B3E6"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3izSAKwomYYQ7kNvgFKFSjV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC1GHVGZ2uSkCbag-XzYTL4XoULljPYW-GiO_fScFp5pA&oe=6777E000"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U96ICdJy7SoQ7kNvgG5f-oV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB6nj04Glh8c8ItZ99Vzye1ODWn2hTeruK5I72fgCW-Cw&oe=6777DC7C"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vN9QSpZrByMQ7kNvgGWdTTU&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCJrIcc3po-T_XgQNRPMxB0deO8Gv1QFDe_sNNO9ftfGg&oe=6777CDE6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fvrabtestlandmods.png", "id": "838172881603221", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974667_838172884936554_1546969593173240089_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylfGiRAlDOoQ7kNvgFejhgB&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB7AA9vqj84TVnN5BMAjRP7Z9ZXKAZ1kSBekk-WbE_huw&oe=6777B5C6"}, "display_name": "Frenzy VR", "keywords": ["frenzy", "extinction", "physics", "shooter", "cheap"], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the chaos into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{2109188632847206}\n\n# FULLY INTERACTIVE AND DESTRUCTIBLE WORLDS\nAll maps feature fully destructible items, objects, & enemies\n{1205834334006646}\n# RAGDOLL PHYSICS WITH MELEE / RANGED WEAPONS\nNPCs use realistic physics ragdolls for ultimate chaos and mayhem\n{1288794592495760}\n# STORY MODE WITH NARRATIVE AND CAMPAIGN\nComplete the full story with multiple missions and take down the Reborn Company\n{427514700347104}\n# 10+ REALISTIC MAPS AND MISSIONS\nGo ballistic in fully interactable worlds built specifically for you to destroy \n{1040111410694158}\n# FULL WEAPON CUSTOMIZATION AND UPGRADES\nRealistic gun and melee weapon physics that feel just like real life\n{1439551213390894}\n# FIGHT VICIOUS AND CRAZY NPCS\nShow no mercy as you fight back against the corrupt NPCs\n{1556545868591589}\n# MODS, MINIGAMES AND GAMEMODES\nYou'll never run out of things to do with our infinitely replayable gamemodes & Mod Support!\n{887725349457146}", "short_description": "\ud83d\udee0\ufe0fMod Support Update!\n- You can now download mods from in-game\n- Create and upload your own mods via Mod.io\n\nFrenzy VR is an action sandbox all about destruction, shooting, ragdolls, realistic combat, and mayhem within interactive destructible environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": "https://clique.games/terms", "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2710427532541308"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8799097926823159"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974521_875666094770284_6958509115578736936_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lop0uX5-8YoQ7kNvgECuI4E&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAdmJS0grrpONDJadJEHnwpdkHpq38LBd7xKxDNyvsejQ&oe=6777D667"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Frenzy VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Fighting", "id": "2710427532541308"}, {"