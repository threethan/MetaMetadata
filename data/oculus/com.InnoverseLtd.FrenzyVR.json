_AYC137o_3rAt0FzWRrWvurOK2GWTlqnDg6azmew3DkhQAA&oe=67349B41"}]}, "id": "857997129778343", "locale": "en_US", "screenshots": [{"file_name": "fss1.png", "id": "1581915522362206", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003286_1581915525695539_1787690103602106794_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XkXCoQepP_AQ7kNvgFHZYgH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBKZleDkg3Xx0a0EdVWd87P0yCM497ncAJ0Rg4rhe_6Sg&oe=67349C16"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zrSR1xMhDhIQ7kNvgFyLhov&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCl6wJbPsgA6HjtdtATXpKgOhyTS8uOWVW1epZ0sz84Pg&oe=67347766"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gh8Uz6oYATwQ7kNvgEIXrsI&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCRnvqlO2BOSEkMfbKyXs31ni-qahwcGQqlmq8BK47Jtg&oe=6734A380"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hOwX41E2jx0Q7kNvgH2jSGo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCw4jEhlIcoyeuNcNtd9Y59v_diBCJ9rI9OpcdB6b4y4Q&oe=67349FFC"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psDBOAiJrzgQ7kNvgG3tnIf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYADCJys16QYvG5AvkuVfwO8rmmCAX483Z3pNw535VtHqA&oe=67349166"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fvrabtestlandscape.png", "id": "950883880417357", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974778_950883883750690_1310628088402518426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aCgW9mM9twgQ7kNvgGG3BzH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCRBnPVVbAtdpqHQQmByDgXAAiLvvI2EnhxNZhEie2mng&oe=67349101"}, "display_name": "Frenzy VR", "keywords": ["frenzy", "extinction", "physics", "shooter", "cheap"], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the chaos into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{2109188632847206}\n\n# FULLY INTERACTIVE AND DESTRUCTIBLE WORLDS\nAll maps feature fully destructible items, objects, & enemies\n{1205834334006646}\n# RAGDOLL PHYSICS WITH MELEE / RANGED WEAPONS\nNPCs use realistic physics ragdolls for ultimate chaos and mayhem\n{1288794592495760}\n# STORY MODE WITH NARRATIVE AND CAMPAIGN\nComplete the full story with multiple missions and take down the Reborn Company\n{427514700347104}\n# 10+ REALISTIC MAPS AND MISSIONS\nGo ballistic in fully interactable worlds built specifically for you to destroy \n{1040111410694158}\n# FULL WEAPON CUSTOMIZATION AND UPGRADES\nRealistic gun and melee weapon physics that feel just like real life\n{1439551213390894}\n# FIGHT VICIOUS AND CRAZY NPCS\nShow no mercy as you fight back against the corrupt NPCs\n{1556545868591589}\n# EXTRA MINIGAMES AND GAMEMODES\nYou'll never run out of things to do with our infinitely replayable gamemodes\n{887725349457146}", "short_description": "Frenzy VR is an action sandbox all about destruction, shooting, ragdolls, realistic combat, and mayhem within interactive destructible environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://clique.games/privacy", "developer_terms_of_service_url": "https://clique.games/terms", "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8517322938333994"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974527_1023752652822242_8701730835461405390_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C8-QJkrjjU0Q7kNvgE36PZd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDy71Nrse7yneiU9gICVZokzBA5rAVPtsSU7R0-n94yCA&oe=6734A773"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Frenzy VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1635696000, "lastRevision": {"nodes": [{"id": "673330633607538", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_