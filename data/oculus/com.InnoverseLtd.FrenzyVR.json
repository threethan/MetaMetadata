0_AYAv5qejiFrUi7qMVJR7Nz9To3d3X6t_vqZY_pyEOnVcDg&oe=671A3D41"}]}, "id": "857997129778343", "locale": "en_US", "screenshots": [{"file_name": "fss1.png", "id": "1581915522362206", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39003286_1581915525695539_1787690103602106794_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kfPKKX9dZCcQ7kNvgEAJFbG&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCWUPZKSWW8WpekBSZ8aDFM1M1vwEW67xkNywbSK31mAg&oe=671A3E16"}, {"file_name": "fss3.png", "id": "496265416191585", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75422385_496265419524918_8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XwBNCtXikHIQ7kNvgGWD1sW&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCbcU6nTRaA5N92Pt3vMpbogXd6P_G9q7VguuoZDpMPLg&oe=671A1966"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwqZguRUtCsQ7kNvgFc51n3&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYAi5N8lN9GaLiawgd4V2f4ZVzqreVEAGg1daDFPXZYymA&oe=671A4580"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YuvzlUMCOkUQ7kNvgEPw9So&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBAg6SLXtE8oxyr4PGUWzUybocMZqZVLZTLgX6m0OuOmw&oe=671A41FC"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fMLse7RrWKoQ7kNvgFP0aAV&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDC7I2rzaU4CFM-KTFNbVFoCJ-_lpUKHXSLX0taQ9DK6w&oe=671A3366"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fvrabtestlandscape.png", "id": "950883880417357", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974778_950883883750690_1310628088402518426_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_T0KvTU3MkUQ7kNvgFpUJ2P&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCcyOBlqdJ6ZNCGDYLFGpVJXECCm3tVJbcc5ssKIQ77kA&oe=671A3301"}, "display_name": "Frenzy VR", "keywords": ["frenzy", "extinction", "physics", "shooter", "cheap"], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the chaos into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{2109188632847206}\n\n# FULLY INTERACTIVE AND DESTRUCTIBLE WORLDS\nAll maps feature fully destructible items, objects, & enemies\n{1205834334006646}\n# RAGDOLL PHYSICS WITH MELEE / RANGED WEAPONS\nNPCs use realistic physics ragdolls for ultimate chaos and mayhem\n{1288794592495760}\n# STORY MODE WITH NARRATIVE AND CAMPAIGN\nComplete the full story with multiple missions and take down the Reborn Company\n{427514700347104}\n# 10+ REALISTIC MAPS AND MISSIONS\nGo ballistic in fully interactable worlds built specifically for you to destroy \n{1040111410694158}\n# FULL WEAPON CUSTOMIZATION AND UPGRADES\nRealistic gun and melee weapon physics that feel just like real life\n{1439551213390894}\n# FIGHT VICIOUS AND CRAZY NPCS\nShow no mercy as you fight back against the corrupt NPCs\n{1556545868591589}\n# EXTRA MINIGAMES AND GAMEMODES\nYou'll never run out of things to do with our infinitely replayable gamemodes\n{887725349457146}", "short_description": "Frenzy VR is an action sandbox all about destruction, shooting, ragdolls, realistic combat, and mayhem within interactive destructible environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrativ