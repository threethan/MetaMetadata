8304438430453330067_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lLdh2WVavI8Q7kNvgEJHR1F&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnZ8gJr1PnXmEoSa5ndxWX1EVAm2oI563L5hLglfGANg&oe=66D196E6"}, {"file_name": "fss5.png", "id": "1435267927133532", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001727_1435267930466865_1521832622986079609_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SIORUOK1iJ4Q7kNvgEKjP9F&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3CgwjvgAtvthMJoqOwQUHTY4QAww5I9oh1Aemwk49UA&oe=66D1C300"}, {"file_name": "fss2.png", "id": "487757603627320", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371505_487757606960653_694722185615763208_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j2fhpoLOzC8Q7kNvgGT_qul&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWW_EUus44OzSH9ZSt-s4xF7O_8dQ15nCLJkwwdToFdA&oe=66D1BF7C"}, {"file_name": "fss4.png", "id": "1472874233617175", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_1472874236950508_7625030607912362245_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DYj1RdAtqo8Q7kNvgGicW5w&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnNSbhdKpudymww7aB1uirPYEyOMtk7eyj996NLe2tDg&oe=66D1B0E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "calandscape.png", "id": "1690346445127882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035319_1690346448461215_7054082562608145111_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5x8BPA4tyMkQ7kNvgEKmc89&_nc_ht=scontent.oculuscdn.com&oh=00_AYCd2SFrfim2He7smEygcytQCyUG9Q_jjmFwF0DiDrxA0A&oe=66D1AA92"}, "display_name": "Frenzy VR", "keywords": [], "long_description": "# Frenzy VR is an action fighter all about destruction & interactive environments. \n\nYou can use **any object** as a weapon with our advanced destruction physics for realistic mayhem. Frenzy VR includes a **story mode** with deep narrative secrets, levels, and objectives. Take the mayhem into your own hands with **free play modes** allowing unlimited creativity across **various maps** like offices, apartments, prisons, and more.\n\n{1018933603024687}\n\nKey Features:\n\n- **Interactive** environments with **destructible** objects.\n- Combat against **ragdoll enemies** using melee and ranged weapons.\n- Story mode featuring an full **narrative and campaign**.\n- Extensive map selection in **free play mode**, including unique settings such as Labs and Nightclub.\n- **Weapon customization** with attachments and skins.\n- **Boss fights** in custom maps.\n- Additional **mini games** for varied gameplay.\n\n\n\n", "short_description": "Frenzy VR is an action fighter all about destruction and mayhem within interactive physics environments. Play on multiple levels, with tens of weapons, all with a deep and hidden narrative. Explore weapon customization, boss fights, mini-games, and free play modes! "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "https://www.innoverse.co.uk/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7387963461269953"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031456_876439844253627_1064960838702004401_n