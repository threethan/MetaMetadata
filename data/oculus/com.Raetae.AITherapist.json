0994035694688", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86627649_890994039028021_4608335382731456658_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPd1s1W7ttsQ7kNvgERe3uT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-liEa-0E4QGcLjP0b2Yo1vkhd5lGCT4iTWFnFv0qoSQ&oe=67276CC1"}, {"file_name": "cuadrado.png", "id": "403740805822257", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_403740809155590_3665425475595379399_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ycDqGUqqPSIQ7kNvgHv-fzm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKpd2wcG2gfDmWoPT140EY8021ZjqJ3Ka8FDxUcLyUag&oe=672747B9"}]}, "id": "2255892708116700", "locale": "en_US", "screenshots": [{"file_name": "handsfree.png", "id": "1887646108426979", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982488_1887646111760312_4145375204109497571_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k16calkcYRUQ7kNvgGQ2UCZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHFW_ZNw7ccR9EnRwbgzmqO_qj3rcoiNkLKz_84bxOdQ&oe=672768BF"}, {"file_name": "HighresScreenshot00001-2.png", "id": "905216528087646", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75348041_905216531420979_684236653151146309_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=by4kAqPCkNUQ7kNvgHja0lG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBSYFp_5WfIKLN4FHfbb4fmh9TfDodObk5GzyXolczjiQ&oe=67277C01"}, {"file_name": "HighresScreenshot00011.png", "id": "1749545002459091", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974869_1749545005792424_4528764932464907144_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=51yqx22utpwQ7kNvgGang3k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB26J606A0SQ5VI4wH8YI4HNPZmFa0B2wlGbUS9xm-0xg&oe=67275230"}, {"file_name": "HighresScreenshot00006.png", "id": "461075130266017", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982593_461075133599350_8827717328068520762_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KZ52LNrlC0QQ7kNvgERHuiE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFBaCuUJ-YFRSfL6WbCSdXw4DSpUfwlz6no5GEC3Kwpg&oe=672756AF"}, {"file_name": "HighresScreenshot00013.png", "id": "8133057753410314", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982725_8133057763410313_8173433353512199547_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H32fKq9VGtsQ7kNvgE1GjWm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBoaoF74qUER0NNrE-aYqELxd6_7qsYFKx7GaveWp-2Ig&oe=672748C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videocover.png", "id": "1856125128361075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035403_1856125131694408_3239532312285045631_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Owfh84G3B94Q7kNvgFvnVfP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgPKX0nn9FFU7V0TTxqMHxFCigOEPXM_5mIvCCYem06w&oe=67274FB3"}, "display_name": "AI Therapist: Your Emotional Guide", "keywords": ["health", "therapy", "gpt", "anxiety", "stress"], "long_description": "# October 2024 Update\nWe're thrilled to introduce the Hands Free feature! Now you can talk to your therapist using only your voice, without pressing any buttons. This makes your therapy sessions feel more natural and effortless.\n\n# September 2024 Update 3.0\nAfter listening to your feedback, we have incorporated some of the most anticipated features:\n\nNew therapist: Sarah Mitchell\nNew memory function\nNew UI and interaction system\nStay tuned, more updates are on the way!\n\n# Welcome to AI Therapist: Your Emotional Guide\nExperience emotional well-being powered by AI. Engage in natural and meaningful conversations with a generative AI therapist that responds with empathy and relevance. Choose from different clinics, like William Anderson\u2019s structured approach or Sarah Mitchell\u2019s empathetic and fluid method. With memory functions, your AI therapist remembers details between sessions, making each interaction feel more personal and connected.\n\n# Key Features:\n\u2022 Immersive 3D environments for engaging therapy sessions.\n\n\u2022 Realistic AI conversations with emotional support.\n\n\u2022 Unique therapeutic approaches tailored to your needs.\n\n\u2022 New Hands Free feature \u2013 speak naturally without pressing any buttons.\n\n\u2022 Personalized interactions through AI memory.\n\nNote: AI Therapist is an experimental tool and not a replacement for professional therapy. It offers a unique opportunity to explore emotional well-being through technology.", "short_description": "AI Therapist: Your Emotional Guide offers personalized therapy sessions with a generative AI. Visit unique clinics like William Anderson\u2019s or Sarah Mitchell\u2019s, each with their own therapeutic approach. The AI adapts to your journey, remembering key details to guide you through meaningful emotional conversations."}, {"images": {"nodes": []}, "id": "1231697538165305", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# Actualizaci\u00f3n de octubre 2024\n\u00a1Presentamos la nueva funci\u00f3n Hands Free! Habla con tu terapeuta solo con tu voz, sin pulsar ning\u00fan bot\u00f3n. Esto hace que tus sesiones sean m\u00e1s c\u00f3modas y naturales.\n\n# Actualizaci\u00f3n de septiembre 2024 - Versi\u00f3n 3.0\n\n\u2022 Nuevo terapeuta: Sarah Mitchell\n\n\u2022 Funci\u00f3n de memoria mejorada\n\n\u2022 Nueva interfaz y sistema de interacci\u00f3n\n\n\u00a1M\u00e1s actualizaciones est\u00e1n en camino!\n\n# Bienvenido a AI Therapist: Your Emotional Guide\nDisfruta de conversaciones naturales con un terapeuta virtual que se adapta a ti y recuerda los detalles de tus sesiones. Cada encuentro se siente m\u00e1s personal y fluido, ayud\u00e1ndote a mejorar tu bienestar emocional de forma sencilla y cercana.\n\n# Caracter\u00edsticas principales:\n\n\u2022 Entornos 3D inmersivos\n\n\u2022 Conversaciones realistas con IA\n\n\u2022 Nueva funci\u00f3n Hands Free\n\n\u2022 Interacciones personalizadas\n\nNota: AI Therapist: Your Emotional Guide es experimental y no sustituye la terapia profesional.", "short_description": "AI Therapist: Your Emotional Guide te ofrece sesiones de terapia personalizadas con una IA generativa. Visita cl\u00ednicas \u00fanicas como la de William Anderson o Sarah Mitchell, cada una con su propio enfoque terap\u00e9utico. La IA se adapta a tu viaje, recordando detalles clave para guiarte a trav\u00e9s de conversaciones emocionales significativas."}, {"images": {"nodes": []}, "id": "1212404143294495", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# Mise \u00e0 jour d\u2019octobre 2024\nNous sommes ravis de vous pr\u00e9senter la nouvelle fonctionnalit\u00e9 Hands Free ! Parlez \u00e0 votre th\u00e9rapeute simplement avec votre voix, sans appuyer sur aucun bouton. Vos s\u00e9ances deviennent ainsi plus naturelles et fluides.\n\n# Mise \u00e0 jour de septembre 2024 - Version 3.0\nNouveau th\u00e9rapeute : Sarah Mitchell\n\n\u2022Fonction m\u00e9moire am\u00e9lior\u00e9e\n\n\u2022Nouvelle interface et syst\u00e8me d'interaction\n\n\u2022Restez \u00e0 l'\u00e9coute, d\u2019autres mises \u00e0 jour arrivent bient\u00f4t !\n\n# Bienvenue sur AI Therapist: Your Emotional Guide\nExplorez le bien-\u00eatre \u00e9motionnel avec des conversations naturelles et significatives gr\u00e2ce \u00e0 l'IA. Choisissez entre plusieurs approches th\u00e9rapeutiques et b\u00e9n\u00e9ficiez d'interactions personnalis\u00e9es gr\u00e2ce \u00e0 la m\u00e9moire de l'IA.\n\n# Fonctionnalit\u00e9s cl\u00e9s :\n\n\u2022 Environnements 3D immersifs\n\n\u2022 Conversations r\u00e9alistes avec IA\n\n\u2022 Nouvelle fonctionnalit\u00e9 Hands Free\n\n\u2022 Interactions personnalis\u00e9es gr\u00e2ce \u00e0 la m\u00e9moire\n\nRemarque : AI Therapist est un outil exp\u00e9rimental et ne remplace pas une th\u00e9rapie professionnelle. Il offre une opportunit\u00e9 unique d\u2019explorer le bien-\u00eatre \u00e9motionnel par le biais de la technologie.", "short_description": "AI Therapist: Your Emotional Guide offre des s\u00e9ances de th\u00e9rapie personnalis\u00e9es avec une IA g\u00e9n\u00e9rative. Visitez des cliniques uniques comme celle de William Anderson ou de Sarah Mitchell, chacune avec sa propre approche th\u00e9rapeutique. L'IA s'adapte \u00e0 votre parcours, se souvenant des d\u00e9tails cl\u00e9s pour vous guider \u00e0 travers des conversations \u00e9motionnelles significatives."}, {"images": {"nodes": []}, "id": "1089701299375628", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# 2024\u5e7410\u6708\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8\n\u30cf\u30f3\u30ba\u30d5\u30ea\u30fc\u6a5f\u80fd\u306e\u5c0e\u5165\u3092\u559c\u3093\u3067\u304a\u77e5\u3089\u305b\u3057\u307e\u3059\uff01\u4eca\u3067\u306f\u3001\u30dc\u30bf\u30f3\u3092\u62bc\u3059\u3053\u3068\u306a\u304f\u3001\u58f0\u3060\u3051\u3067\u30bb\u30e9\u30d4\u30b9\u30c8\u3068\u4f1a\u8a71\u3059\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u3053\u308c\u306b\u3088\u308a\u3001\u30bb\u30e9\u30d4\u30fc\u30bb\u30c3\u30b7\u30e7\u30f3\u304c\u3088\u308a\u81ea\u7136\u3067 effortless \u306b\u611f\u3058\u3089\u308c\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3057\u305f\u3002\n2024\u5e749\u6708\u30a2\u30c3\u30d7\u30c7\u30fc\u30c8 3.0\n\u7686\u69d8\u306e\u30d5\u30a3\u30fc\u30c9\u30d0\u30c3\u30af\u3092\u304a\u805e\u304d\u3057\u3001\u6700\u3082\u671f\u5f85\u3055\u308c\u3066\u3044\u305f\u6a5f\u80fd\u3092\u3044\u304f\u3064\u304b\u53d6\u308a\u5165\u308c\u307e\u3057\u305f\uff1a\n\u65b0\u3057\u3044\u30bb\u30e9\u30d4\u30b9\u30c8\uff1a\u30b5\u30e9\u30fb\u30df\u30c3\u30c1\u30a7\u30eb\n\n\u65b0\u3057\u3044\u30e1\u30e2\u30ea\u30fc\u6a5f\u80fd\n\n\u65b0\u3057\u3044UI\u3068\u30a4\u30f3\u30bf\u30e9\u30af\u30b7\u30e7\u30f3\u30b7\u30b9\u30c6\u30e0\n\n\u4eca\u5f8c\u3082\u66f4\u65b0\u304c\u4e88\u5b9a\u3055\u308c\u3066\u3044\u307e\u3059\u306e\u3067\u3001\u3054\u671f\u5f85\u304f\u3060\u3055\u3044\uff01\n\n# AI Therapist: Your Emotional Guide\u3078\u3088\u3046\u3053\u305d\nAI\u3092\u6d3b\u7528\u3057\u305f\u611f\u60c5\u7684\u306a\u30a6\u30a7\u30eb\u30d3\u30fc\u30a4\u30f3\u30b0\u3092\u4f53\u9a13\u3057\u3066\u304f\u3060\u3055\u3044\u3002\u5171\u611f\u3068\u9069\u5207\u3055\u3092\u6301\u3063\u3066\u5fdc\u7b54\u3059\u308b\u751f\u6210AI\u30bb\u30e9\u30d4\u30b9\u30c8\u3068\u3001\u81ea\u7136\u3067\u610f\u5473\u306e\u3042\u308b\u4f1a\u8a71\u3092\u4ea4\u308f\u3059\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002\u30a6\u30a3\u30ea\u30a2\u30e0\u30fb\u30a2\u30f3\u30c0\u30fc\u30bd\u30f3\u306e\u69cb\u9020\u5316\u3055\u308c\u305f\u30a2\u30d7\u30ed\u30fc\u30c1\u3084\u3001\u30b5\u30e9\u30fb\u30df\u30c3\u30c1\u30a7\u30eb\u306e\u5171\u611f\u7684\u3067\u6d41\u52d5\u7684\u306a\u65b9\u6cd5\u306a\u3069\u3001\u7570\u306a\u308b\u30af\u30ea\u30cb\u30c3\u30af\u304b\u3089\u9078\u629e\u3067\u304d\u307e\u3059\u3002\u30e1\u30e2\u30ea\u30fc\u6a5f\u80fd\u306b\u3088\u308a\u3001AI\u30bb\u30e9\u30d4\u30b9\u30c8\u306f\u30bb\u30c3\u30b7\u30e7\u30f3\u9593\u306e\u8a73\u7d30\u3092\u8a18\u61b6\u3057\u3001\u5404\u30a4\u30f3\u30bf\u30e9\u30af\u30b7\u30e7\u30f3\u304c\u3088\u308a\u500b\u4eba\u7684\u3067\u3064\u306a\u304c\u308a\u306e\u3042\u308b\u3082\u306e\u306b\u611f\u3058\u3089\u308c\u307e\u3059\u3002\n\n# \u4e3b\u306a\u7279\u5fb4\uff1a\n\n\u9b45\u529b\u7684\u306a\u30bb\u30e9\u30d4\u30fc\u30bb\u30c3\u30b7\u30e7\u30f3\u306e\u305f\u3081\u306e\u6ca1\u5165\u578b3D\u74b0\u5883\u3002\n\n\u611f\u60c5\u7684\u30b5\u30dd\u30fc\u30c8\u3092\u4f34\u3046\u30ea\u30a2\u30eb\u306aAI\u4f1a\u8a71\u3002\n\n\u3042\u306a\u305f\u306e\u30cb\u30fc\u30ba\u306b\u5408\u308f\u305b\u305f\u72ec\u81ea\u306e\u30bb\u30e9\u30d4\u30fc\u30a2\u30d7\u30ed\u30fc\u30c1\u3002\n\n\u65b0\u3057\u3044\u30cf\u30f3\u30ba\u30d5\u30ea\u30fc\u6a5f\u80fd \u2013 \u30dc\u30bf\u30f3\u3092\u62bc\u3055\u305a\u306b\u81ea\u7136\u306b\u8a71\u305b\u307e\u3059\u3002\n\nAI\u30e1\u30e2\u30ea\u30fc\u306b\u3088\u308b\u30d1\u30fc\u30bd\u30ca\u30e9\u30a4\u30ba\u3055\u308c\u305f\u30a4\u30f3\u30bf\u30e9\u30af\u30b7\u30e7\u30f3\u3002\n\n\u6ce8\u610f\uff1aAI Therapist\u306f\u5b9f\u9a13\u7684\u306a\u30c4\u30fc\u30eb\u3067\u3042\u308a\u3001\u5c02\u9580\u7684\u306a\u30bb\u30e9\u30d4\u30fc\u306e\u4ee3\u66ff\u3067\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u30c6\u30af\u30ce\u30ed\u30b8\u30fc\u3092\u901a\u3058\u3066\u611f\u60c5\u7684\u306a\u30a6\u30a7\u30eb\u30d3\u30fc\u30a4\u30f3\u30b0\u3092\u63a2\u6c42\u3059\u308b\u72ec\u7279\u306a\u6a5f\u4f1a\u3092\u63d0\u4f9b\u3057\u307e\u3059\u3002", "short_description": "AI Therapist: Your Emotional Guide\u306f\u3001\u751f\u6210AI\u306b\u3088\u308b\u30d1\u30fc\u30bd\u30ca\u30e9\u30a4\u30ba\u3055\u308c\u305f\u30bb\u30e9\u30d4\u30fc\u30bb\u30c3\u30b7\u30e7\u30f3\u3092\u63d0\u4f9b\u3057\u307e\u3059\u3002\u30a6\u30a3\u30ea\u30a2\u30e0\u30fb\u30a2\u30f3\u30c0\u30fc\u30bd\u30f3\u3084\u30b5\u30e9\u30fb\u30df\u30c3\u30c1\u30a7\u30eb\u306a\u3069\u3001\u305d\u308c\u305e\u308c\u72ec\u81ea\u306e\u30bb\u30e9\u30d4\u30fc\u30a2\u30d7\u30ed\u30fc\u30c1\u3092\u6301\u3064\u30e6\u30cb\u30fc\u30af\u306a\u30af\u30ea\u30cb\u30c3\u30af\u3092\u8a2a\u308c\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3059\u3002AI\u306f\u3042\u306a\u305f\u306e\u65c5\u306b\u9069\u5fdc\u3057\u3001\u91cd\u8981\u306a\u8a73\u7d30\u3092\u8a18\u61b6\u3057\u3066\u3001\u610f\u5473\u306e\u3042\u308b\u611f\u60c5\u7684\u306a\u4f1a\u8a71\u3092\u30ac\u30a4\u30c9\u3057\u307e\u3059\u3002"}, {"images": {"nodes": []}, "id": "894996915882488", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# Oktober 2024 Update\nWir freuen uns, die neue Hands Free-Funktion vorzustellen! Sprich jetzt ganz nat\u00fcrlich mit deinem Therapeuten, ohne einen Knopf zu dr\u00fccken. Deine Therapiesitzungen werden dadurch noch angenehmer und einfacher.\n\n# September 2024 Update 3.0\n\n\u2022 Neuer Therapeut: Sarah Mitchell\n\n\u2022 Verbesserte Speicherfunktion\n\n\u2022 Neues UI und Interaktionssystem\n\nBleibt dran, weitere Updates kommen bald!\n\n# Willkommen bei AI Therapist: Your Emotional Guide\nErlebe nat\u00fcrliche Gespr\u00e4che mit einem einf\u00fchlsamen KI-Therapeuten, der sich an deine Details erinnert und dir eine pers\u00f6nlichere und angenehmere Erfahrung erm\u00f6glicht. Jede Sitzung passt sich mehr an deine Bed\u00fcrfnisse an.\n\n# Hauptfunktionen:\n\n\u2022 Immersive 3D-Umgebungen\n\n\u2022 Realistische Gespr\u00e4che mit der KI\n\n\u2022 Neue Hands Free-Funktion\n\n\u2022 Personalisierte Sitzungen dank KI-Ged\u00e4chtnis\n\nHinweis: AI Therapist ist experimentell und kein Ersatz f\u00fcr professionelle Therapie. Es bietet Unterst\u00fctzung auf dem Weg zur Selbstverbesserung.", "short_description": "AI Therapist: Your Emotional Guide bietet personalisierte Therapiesitzungen mit einer generativen KI. Besuchen Sie einzigartige Kliniken wie die von William Anderson oder Sarah Mitchell, die jeweils ihre eigenen therapeutischen Ans\u00e4tze haben. Die KI passt sich Ihrer Reise an und erinnert sich an wichtige Details, um Sie durch bedeutungsvolle emotionale Gespr\u00e4che zu f\u00fchren."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/ai-therapist-your-emotional-guide-privacy-policy/2d3288f3-8fd3-4db4-9fdb-8ef6efb526a3/privacy", "developer_terms_of_service_url": null, "publisher_name": "Raetae Studios", "support_website_url": null, "website_url": "https://aitherapistapp.rf.gd/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {