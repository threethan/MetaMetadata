{"data": {"node": {"__typename": "Application", "id": "7182773695092320", "organization": {"id": "3809285699117770", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "9022513977764399"}]}, "id": "1254703722380308"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "7182773695092320"}]}, "id": "1076565533678238"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "6291879347595510"}]}, "id": "157881827255789"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "6953290791410082"}]}, "id": "1125147158238878"}]}}, "firstRevision": {"nodes": [{"application": {"id": "7182773695092320", "release_date": 1709756640, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 5}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8284742984895380"}, "id": "1092635708653875"}]}}, "binary": null, "live_binary": null, "created_date": 1726496617, "id": "8226342694068743", "is_initial_release": false, "name_with_fallback": "v7", "pdp_metadata_with_fallback": {"version": 6, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "8226360120733667"}, "release_status": "RELEASED", "id": "7182773695092320"}, "id": "8226360120733667", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7182773695092320", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1111192376735167"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "3417834895175866", "locale": "es_ES", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# Actualizaci\u00f3n de septiembre 2024 3.0\nNovedades:\n\n-Nueva terapeuta: Sarah Mitchell\n\n-Nueva funci\u00f3n de memoria\n\n-Nuevo sistema de interfaz e interacci\u00f3n\n\n\u00a1M\u00e1s actualizaciones en camino!\n\n# Bienvenido a AI Therapist: Your Emotional Guide\nUna innovadora aplicaci\u00f3n de bienestar emocional con IA. Mant\u00e9n conversaciones significativas con un terapeuta de IA que responde con comprensi\u00f3n y relevancia.\nElige entre la cl\u00ednica de William Anderson (enfoque reflexivo) o la de Sarah Mitchell (\u00e9nfasis en empat\u00eda). La IA recuerda detalles entre sesiones para una experiencia personalizada.\n\n# Caracter\u00edsticas principales:\n\n\u2022 Entornos 3D inmersivos\n\n\u2022 Conversaciones de IA realistas\n\n\u2022 M\u00faltiples enfoques terap\u00e9uticos\n\n\u2022 Interacciones personalizadas\n\n\u2022 Plataforma segura para el crecimiento personal\n\n\u2022 Ideal para chequeos diarios\n\nNota: AI Therapist: Your Emotional Guide es experimental y no sustituye la terapia profesional.", "short_description": "AI Therapist: Your Emotional Guide te ofrece sesiones de terapia personalizadas con una IA generativa. Visita cl\u00ednicas \u00fanicas como la de William Anderson o Sarah Mitchell, cada una con su propio enfoque terap\u00e9utico. La IA se adapta a tu viaje, recordando detalles clave para guiarte a trav\u00e9s de conversaciones emocionales significativas."}, {"images": {"nodes": []}, "id": "782723303840886", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "# Mise \u00e0 jour de septembre 2024 3.0\nNouveaut\u00e9s :\n\n-Nouvelle th\u00e9rapeute : Sarah Mitchell\n\n-Nouvelle fonction de m\u00e9moire\n\n-Nouveau syst\u00e8me d'interface et d'interaction\n\nD'autres mises \u00e0 jour \u00e0 venir !\n\n# Bienvenue sur AI Therapist: Your Emotional Guide\nUne application innovante de bien-\u00eatre \u00e9motionnel propuls\u00e9e par l'IA. Engagez des conversations significatives avec un th\u00e9rapeute IA qui r\u00e9pond avec compr\u00e9hension et pertinence.\nChoisissez entre la clinique de William Anderson (approche r\u00e9flexive) ou celle de Sarah Mitchell (accent sur l'empathie). L'IA m\u00e9morise les d\u00e9tails entre les s\u00e9ances pour une exp\u00e9rience personnalis\u00e9e.\n\n# Caract\u00e9ristiques principales :\n\n\u2022 Environnements 3D immersifs\n\n\u2022 Conversations IA r\u00e9alistes\n\n\u2022 Multiples approches th\u00e9rapeutiques\n\n\u2022 Interactions personnalis\u00e9es\n\n\u2022 Plateforme s\u00fbre pour la croissance personnelle\n\n\u2022 Id\u00e9al pour des v\u00e9rifications quotidiennes\n\nNote : AI Therapist: Your Emotional Guide est exp\u00e9rimental et ne remplace pas une th\u00e9rapie professionnelle.", "short_description": "AI Therapist: Your Emotional Guide offre des s\u00e9ances de th\u00e9rapie personnalis\u00e9es avec une IA g\u00e9n\u00e9rative. Visitez des cliniques uniques comme celle de William Anderson ou de Sarah Mitchell, chacune avec sa propre approche th\u00e9rapeutique. L'IA s'adapte \u00e0 votre parcours, se souvenant des d\u00e9tails cl\u00e9s pour vous guider \u00e0 travers des conversations \u00e9motionnelles significatives."}, {"images": {"nodes": [{"file_name": "vertical2.png", "id": "7818059948298010", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641338_7818059951631343_4586385152459728266_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AVLje3RMMxoQ7kNvgGeyIHB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYDyDCc6fc30AVZxUvYjflyp_xP_IzXow7IBFs688WdZtA&oe=66F6A002"}, {"file_name": "logo.png", "id": "1675020873025664", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982630_1675020876358997_7794976227427543697_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TR1Am_CJURYQ7kNvgFthix7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYDr0Vp1_Pjttd-ffS_PSNY3QB5jM5VEbf7hFyNSEGNTqg&oe=66F6B439"}, {"file_name": "mini2.png", "id": "1624139408137944", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75458092_1624139411471277_2547823644810597585_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rCIUe7SKyikQ7kNvgF-Qqwi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYA7M8VVlvNQibP2kKHt-ULRlPWw0Kv1z8XXvkM0_3uy8A&oe=66F6AA30"}, {"file_name": "horizontal2.png", "id": "1187570909142497", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974907_1187570912475830_8030985341655617727_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IAtweliIqXEQ7kNvgF4BIgl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYCBezqKjuKXwm3AmeKRmiO6lVI3fuwBBe2yHsmuWqhTRQ&oe=66F68628"}, {"file_name": "icon2.png", "id": "1036449731366600", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974551_1036449734699933_6566998741812494654_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=55CGRpajsBgQ7kNvgHsIVwy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYCB1y7iTvMXs5a1P0I7udVIbiuBwwmniNtnDq3H-F9Lqw&oe=66F6B132"}, {"file_name": "hero2.png", "id": "973767654517703", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974775_973767657851036_3125741101223280345_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vi9m_ydDUeMQ7kNvgHmCwB7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYDQOq8gVZc33xAm2uoxasRki86pu44UC__W_Jp2eiqMOg&oe=66F691A6"}, {"file_name": "square2.png", "id": "893043396045000", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031560_893043399378333_1826957087164989146_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cS0dWWAov2EQ7kNvgGpJxk7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYCMMyT9VMVUlLQq-W4m9-G4s1pI887RX32kiLpUH7njgQ&oe=66F68921"}]}, "id": "414624481674082", "locale": "en_US", "screenshots": [{"file_name": "HighresScreenshot00001-2.png", "id": "905216528087646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75348041_905216531420979_684236653151146309_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rTH3DIJwOBUQ7kNvgFvVAz5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYAN7vy8thvOWVr-TNJks5K3YkgiJZAzTOece-0hiHUyuQ&oe=66F6B481"}, {"file_name": "HighresScreenshot00007.png", "id": "450200460787368", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036651_450200464120701_5342319903586203976_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k1sS55_gnm8Q7kNvgEAvKJd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYDgug1x_yNwe1VbpyeTcBlRSTGrA6QUoPPN6axjUpOVnQ&oe=66F69369"}, {"file_name": "HighresScreenshot00011.png", "id": "1749545002459091", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974869_1749545005792424_4528764932464907144_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dy6EqQ-0bIgQ7kNvgH5MC6J&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYDEPOvFlnvwzq4hj0yhv7gerXpZ7sJ3KSfBweEdCRKB3g&oe=66F68AB0"}, {"file_name": "HighresScreenshot00006.png", "id": "461075130266017", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982593_461075133599350_8827717328068520762_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GagZhXHZiysQ7kNvgFsMxTf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYBnimv4jDQ0eH5w6057HRbP--LKfGGlXeR36Bkje-FHTA&oe=66F68F2F"}, {"file_name": "HighresScreenshot00013.png", "id": "8133057753410314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982725_8133057763410313_8173433353512199547_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jMtKP5HLTUMQ7kNvgEi8cPk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYCqy8Fdo6SrygjOvIG0A_72wn2Ep_fx-sc_nExzGKFAOA&oe=66F68146"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videocover.png", "id": "1856125128361075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035403_1856125131694408_3239532312285045631_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=coZ-4BXCJ8gQ7kNvgECG43y&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYC0ju7cz5lzLZAxEJSshU6l9jpxImCwsorqlLeRSPkurw&oe=66F68833"}, "display_name": "AI Therapist: Your Emotional Guide", "keywords": ["health", "therapy", "gpt", "anxiety", "stress"], "long_description": "# September 2024 Update 3.0\n\nAfter listening to your feedback we have incorporated some of the most anticipated features:\n\n-New therapist: Sarah Mitchell\n\n-New memory function\n\n-New UI and interaction system\n\nStay tuned, more updates are on the way!\n\n# Welcome to AI Therapist: Your Emotional Guide\n  An innovative journey into emotional well-being powered by artificial intelligence. This app bridges technology and human emotions, enabling users to have natural and meaningful conversations with a generative AI therapist that responds with understanding and relevance.\n\nChoose from different therapy approaches by visiting William Anderson\u2019s clinic, offering a reflective and structured method, or Sarah Mitchell\u2019s clinic, which emphasizes emotional fluidity and empathy. The AI therapist remembers details about you between sessions, making each interaction more personal and connected.\n\n# Key Features: \n\n\u2022 Immersive 3D environments for engaging therapy sessions.\n\n\u2022 Realistic AI conversations for emotional support.\n\n\u2022 Choose different clinics with unique therapeutic approaches.\n\n\u2022 AI remembers details for personalized interactions.\n\n\u2022 A safe platform for self-discovery and growth.\n\n\u2022 Perfect for daily check-ins, with an AI that offers effective assistance.\n\nNote: AI Therapist is experimental and not a substitute for professional therapy. It represents a step towards leveraging AI for emotional well-being, offering companionship on the path to self-improvement.", "short_description": "AI Therapist: Your Emotional Guide offers personalized therapy sessions with a generative AI. Visit unique clinics like William Anderson\u2019s or Sarah Mitchell\u2019s, each with their own therapeutic approach. The AI adapts to your journey, remembering key details to guide you through meaningful emotional conversations."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/ai-therapist-your-emotional-guide-privacy-policy/2d3288f3-8fd3-4db4-9fdb-8ef6efb526a3/privacy", "developer_terms_of_service_url": null, "publisher_name": "Raetae Studios", "support_website_url": null, "website_url": "https://aitherapistapp.rf.gd/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8226360120733667"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031560_893043399378333_1826957087164989146_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cS0dWWAov2EQ7kNvgGpJxk7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUvpi6StLukF-XjZeTAVnY1&oh=00_AYA76