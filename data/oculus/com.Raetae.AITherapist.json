", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982696_919243919714396_6860426524042517358_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wziyfuO4E1MQ7kNvgGftjh8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBEJXj7iES6bjkfRD00heDdFKHEp6_kYxiIrgBhIuRp8w&oe=67275D97"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videocover.png", "id": "1856125128361075", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035403_1856125131694408_3239532312285045631_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Owfh84G3B94Q7kNvgFvnVfP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDgPKX0nn9FFU7V0TTxqMHxFCigOEPXM_5mIvCCYem06w&oe=67274FB3"}, "display_name": "AI Therapist: Your Emotional Guide", "keywords": [], "long_description": "Welcome to AI Therapist: Your Emotional Guide, an innovative journey into emotional well-being powered by artificial intelligence. This app bridges technology and human emotions, enabling users to have natural and meaningful conversations with a generative AI therapist that responds with understanding and relevance.\n\nAI Therapist provides a non-judgmental space for individuals to explore their feelings, thoughts, and emotions. Whether seeking reflection, support, or new ways to connect with your inner self, AI Therapist delivers realistic interactions for a deeper understanding of emotions.\n\nKey Features:\n\n\u2022 Immersive 3D interface for engaging therapy sessions.\n\u2022 Realistic AI conversations for emotional support.\n\u2022 A safe platform for self-discovery and growth.\n\u2022 Perfect for daily check-ins, with an AI that offers effective assistance.\n\nNote: AI Therapist is experimental and not a substitute for professional therapy. It represents a step towards leveraging AI for emotional well-being, offering companionship on the path to self-improvement.", "short_description": "Explore emotions with AI: AI Therapist: Your Emotional Guide offers innovative therapy sessions with generative AI for emotional self-discovery. Experience natural conversations where the AI understands and guides you through your feelings, creating a unique space for emotional exploration."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/ai-therapist-your-emotional-guide-privacy-policy/2d3288f3-8fd3-4db4-9fdb-8ef6efb526a3/privacy", "developer_terms_of_service_url": null, "publisher_name": "Raetae Studios", "support_website_url": null, "website_url": "http://aitherapist.rf.gd/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7225554277480928"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1053705983079502"}, {"status": "CANCELLED", "id": "1971314166674857"}, {"status": "PUBLISHED", "id": "1514659122466778"}, {"status": "PUBLISHED", "id": "244071428771553"}, {"status": "PUBLISHED", "id": "1057196402044808"}]}, "baseline_offer": {"id": "1057196402044808"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727719200, "status": "PUBLISHED", "id": "1053705983079502"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8534583996577943", "version": "4.1"}, "id": "1092635708653875", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinar