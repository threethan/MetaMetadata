id=AHB_VsmIxxn4CkfOTbxUbK1&oh=00_AYCn4PmMjugkpZMSg2TO1-TSWIVFAC-hU274UxhZ6-7eXA&oe=66ED54AF"}, {"file_name": "HighresScreenshot00013.png", "id": "8133057753410314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982725_8133057763410313_8173433353512199547_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H_DKp26wA24Q7kNvgGJFv7_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHB_VsmIxxn4CkfOTbxUbK1&oh=00_AYDuSce6oquM0wNLWAOIExoZDjRSez6AWBk-vcPk4lrAow&oe=66ED46C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videocover.png", "id": "1856125128361075", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035403_1856125131694408_3239532312285045631_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vo3aNgkxlJIQ7kNvgG5ZOug&_nc_ht=scontent.oculuscdn.com&_nc_gid=AHB_VsmIxxn4CkfOTbxUbK1&oh=00_AYBDtj2wg37L-SmVZJHzSl0PpQsAu0AHPYZja4phb_vwrw&oe=66ED4DB3"}, "display_name": "AI Therapist: Your Emotional Guide", "keywords": ["health", "therapy", "gpt", "anxiety", "stress"], "long_description": "# September 2024 Update 3.0\n\nAfter listening to your feedback we have incorporated some of the most anticipated features:\n\n-New therapist: Sarah Mitchell\n\n-New memory function\n\n-New UI and interaction system\n\nStay tuned, more updates are on the way!\n\n# Welcome to AI Therapist: Your Emotional Guide\n  An innovative journey into emotional well-being powered by artificial intelligence. This app bridges technology and human emotions, enabling users to have natural and meaningful conversations with a generative AI therapist that responds with understanding and relevance.\n\nChoose from different therapy approaches by visiting William Anderson\u2019s clinic, offering a reflective and structured method, or Sarah Mitchell\u2019s clinic, which emphasizes emotional fluidity and empathy. The AI therapist remembers details about you between sessions, making each interaction more personal and connected.\n\n# Key Features: \n\n\u2022 Immersive 3D environments for engaging therapy sessions.\n\n\u2022 Realistic AI conversations for emotional support.\n\n\u2022 Choose different clinics with unique therapeutic approaches.\n\n\u2022 AI remembers details for personalized interactions.\n\n\u2022 A safe platform for self-discovery and growth.\n\n\u2022 Perfect for daily check-ins, with an AI that offers effective assistance.\n\nNote: AI Therapist is experimental and not a substitute for professional therapy. It represents a step towards leveraging AI for emotional well-being, offering companionship on the path to self-improvement.", "short_description": "AI Therapist: Your Emotional Guide offers personalized therapy sessions with a generative AI. Visit unique clinics like William Anderson\u2019s or Sarah Mitchell\u2019s, each with their own therapeutic approach. The AI adapts to your journey, remembering key details to guide you through meaningful emotional conversations."}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/ai-therapist-your-emotional-guide-privacy-policy/2d3288f3-8fd3-4db4-9fdb-8ef6efb526a3/privacy", "developer_terms_of_service_url": null, "publisher_name": "Raetae Studios", "support_website_url": null, "website_url": "https://aitherapistapp.rf.gd/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "3362542290449643"}, {"id": "1067126693731825"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8188993451137001