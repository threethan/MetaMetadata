01_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0clSmentUUQQ7kNvgE0fg14&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDggDz_kXnlVA6A9f3asQMgF2N0rE2UNIiuRKHOnq-Y3A&oe=670A5962"}, {"file_name": "SS5.png", "id": "997655260901935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982521_997655264235268_5942355324303180138_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BEjeaMVPVsAQ7kNvgHAXtz-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkSuBzZAHShj5FzCxvxePqIU4xnw5rG5ICSmGHVlJWhg&oe=670A6F21"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_YDemo.png", "id": "598071861169135", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974862_598071864502468_8684961041275352394_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aC1pIYDLPeUQ7kNvgFmbEKl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6TjwNsoOjR8ExvkjeXV2L96RybnmWX8OssVizZoRuUg&oe=670A72E8"}, "display_name": "Simulation X trial", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/pr