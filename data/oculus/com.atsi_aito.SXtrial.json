scdn.com&oh=00_AYAuFKJn_galxqjN7xD6OdmemroGtYV9kTAkIhuG60855Q&oe=67518A62"}, {"file_name": "SS5.png", "id": "997655260901935", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982521_997655264235268_5942355324303180138_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mLHa3CBb6woQ7kNvgFlDdxx&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCggS5dNq_ay4k6f6YF_OHTiwef0iPPrB5myEziLCQWjA&oe=6751A021"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_YDemo.png", "id": "598071861169135", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974862_598071864502468_8684961041275352394_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EBwIKzRJnLoQ7kNvgH1no7O&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAOlrTwfimALKAUP2vOctwoQCzk2dORzaPlYkhRjwWKeg&oe=6751A3E8"}, "display_name": "Simulation X trial", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}, {"images": {"nodes": [{"file_name": "SXDemo_CA_Y.png", "id": "1644986796362767", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t6