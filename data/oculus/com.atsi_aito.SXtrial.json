content-sjc3-1.oculuscdn.com&oh=00_AYByGwPAayDyQTB8d5nwjKA4__aM88NitQ1ug38bUW2avQ&oe=670134A1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_YDemo.png", "id": "598071861169135", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974862_598071864502468_8684961041275352394_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0fjhPjYIMgYQ7kNvgG-0SRe&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCU8BnyWFNEK6Uv9C947thbCQyGFSDt8X85XbKDJKA3Dw&oe=67013868"}, "display_name": "Simulation X trial", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "atsi_aito", "support_website_url": null, "website_url": "https://www.atsiaito.com/product/simulationx", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "S