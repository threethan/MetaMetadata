01_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AfhS2aMC-VsQ7kNvgHg26A6&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBeTFF3b2lkAAGjMeASjruJA9EETlVTBDJBXL4SBue-Ig&oe=67011EE2"}, {"file_name": "SS5.png", "id": "997655260901935", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982521_997655264235268_5942355324303180138_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2RjBgAOxdgcQ7kNvgH3FMts&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYByGwPAayDyQTB8d5nwjKA4__aM88NitQ1ug38bUW2avQ&oe=670134A1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CA_YDemo.png", "id": "598071861169135", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974862_598071864502468_8684961041275352394_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0fjhPjYIMgYQ7kNvgG-0SRe&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCU8BnyWFNEK6Uv9C947thbCQyGFSDt8X85XbKDJKA3Dw&oe=67013868"}, "display_name": "Simulation X trial", "keywords": [], "long_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR.\n\n\u2022 Method of operation\nFor hand tracking only.\nThere is no move operation.\nBasically, the scenario progresses by touching objects.\nOnce the battle simulation starts, it will be a gesture operation.\n1.Attack - Either hand is a Paper\nFrom the palm of your hand, the spell of Shikigami comes out.\nPlease hit enemies and items.\n2.Defense - Either hand is a Rock\nA shield will appear to prevent enemy attacks.\nIf an enemy attack approaches, use a shield to prevent it.\n\n\u2022 How to proceed with the game\n1.Start\nOnce booted, system navigation will begin.\nTouch the Start-device to start.\n2.GamePlay\nIf you select Shikigami, the battle simulation will start after a while.", "short_description": "Pass-through MR shooting game.\nWelcome to Simulation X.\nPlease experience the power of Shikigami with MR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.atsiaito.com/pr