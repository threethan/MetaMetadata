content.oculuscdn.com&_nc_gid=AcDwKFxi8jdft7f2rP_wBFy&oh=00_AYBEzSFDZxBxdGlmsDhuCf4dJaQ6eNdjjo9rZa726qKazA&oe=66F14D39"}, {"file_name": "migrated_image.png", "id": "254919582195734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974489_1420142374787927_6577818241471610880_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=USz03erBm24Q7kNvgG5hYn5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDwKFxi8jdft7f2rP_wBFy&oh=00_AYCzdCyrZ6NB3NcOYhDS6fs6L1cSg1MK0PbRo2E3hdqoKg&oe=66F164C0"}, {"file_name": "migrated_image.png", "id": "206293057136397", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251818_563151154449001_5925446871379083264_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SWfDcMs_dosQ7kNvgENtQQ_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcDwKFxi8jdft7f2rP_wBFy&oh=00_AYBZ5qwHcrLBrPd9PNi6xwwnM7jgtP90enG71UreBJMrZg&oe=66F14FED"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "NBA on TNT VR", "keywords": ["sports", "basketball", "NBA", "livestream", "free"], "long_description": "Watch NBA on TNT games in immersive virtual reality. Be transported to the Inside the NBA studio where you can stream select games and events, including 2020 NBA All-Star and the NBA Playoffs. \nAuthenticate with your cable provider to be fully immersed into the NBA on TNT virtual world and access live games and full-game replays.\nFeatures:\n- Live VR Cast of the top match-ups\n- Choose your camera angle to experience the game from different vantage points\n- Exclusive play-by-play and analysis by NBA on TNT personalities \n- Game highlights available for free\n- Behind the scenes at 2020 NBA All-Star\n- Select games from the 2020 NBA Playoffs\nSupported Devices:\n- Samsung Gear VR Galaxy \n- Samsung S9\n- Samsung S9+\n- Samsung S8\n- Samsung S8+\n- Samsung Note8 \n- S7\n- S7+ \n- S7 edge \n- Oculus Go", "short_description": "Watch NBA on TNT games in virtual reality. Be transported to the Inside the NBA studio where you can stream select games and events, inc