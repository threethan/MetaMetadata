 into the NBA on TNT virtual world and access live games and full-game replays."}]}, "developer_name": "Turner", "developer_privacy_policy_url": "http://www.nba.com/news/privacy_policy.html#/", "developer_terms_of_service_url": "http://www.nba.com/news/termsofuse", "publisher_name": "Turner", "support_website_url": null, "website_url": "http://leaguepasssupport.nba.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["MOVIE", "MUSIC_VIDEO", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1559159477783611"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982656_456089338466461_8737652261204787200_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K4hI9Fg-juMQ7kNvgE43kH3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASRYpmv_Wtq6UsHyfn7I5zt_zn6nMcAEuYWw8-bArI-w&oe=6735ED60"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "NBA on TNT VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1518214607, "lastRevision": {"nodes": [{"id": "865959010232516", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2025498910795441", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "159848851404322"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"imag