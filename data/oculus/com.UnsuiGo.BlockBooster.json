_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i0p6hCxErOkQ7kNvgGFjvi5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBSit_MB-H9aS56_pdMLuS3Xf-qQkVy9YPSelSfgX_xwA&oe=66D5AEC7"}, {"file_name": "4.png", "id": "1637552650348356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_1637552657015022_1262021425768635274_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7BdMbRklsGcQ7kNvgFigcF_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKlU6Hjb_2HLh2xP0IW2pFVo428XKQDOFPDJOu6PhnLw&oe=66D5A604"}, {"file_name": "5.png", "id": "362938819976224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035402_362938823309557_6071927339970691865_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gv9VOViYlHkQ7kNvgEAxDvR&_nc_ht=scontent.oculuscdn.com&oh=00_AYBFleYXhOEOiVc-9p4YYz-BLuCDQW7vQDd1M641uE95rQ&oe=66D5ADE3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BANER_2560_1440.png", "id": "955852295933604", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031370_955852299266937_2273019522432416745_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wIy8G61LPQ8Q7kNvgF1hn1P&_nc_ht=scontent.oculuscdn.com&oh=00_AYAVimCvPmAzfMQONj17_VFZb4A9QkOcKPM4Ku8xU38WsA&oe=66D5A150"}, "display_name": "Block Booster", "keywords": [], "long_description": "Step into a thrilling VR world where every puzzle is an adventure for your brain! Our game isn't just about having fun in virtual reality\u2014it's a cool way to make your brain sharper and faster. Think of it as a gym for your mind, where you twist and turn 3D shapes to fit them together and clear levels.\n\nAs you play, you'll get better at figuring out how to solve these puzzles faster and with fewer moves. It's like training your brain to see things from different angles, and it's a blast! The controls are super easy to get the hang of, so you can start playing and improving your skills right away.\n\nNo matter if you're just looking for a fun game to play after school or you want to give your brain a serious workout, our game has got you covered. It's perfect for when you want to challenge yourself and see how smart you can be in 3D space. Get ready to boost your brain and have tons of fun with our VR puzzle that's all about making you think and move in new ways!", "short_description": "Intellect booster"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1cnNj9q_IG7uStY-L4-XEvup2_WFV10MokfS6n1lgunU/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Oleksii Hinchuk", "support_website_url": null, "website_url": "https://www.facebook.com/profile.php?id=100090303563530", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6959041550882687"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1359471961379472"}, {"status": "PUBLISHED", "id": "422726593703150"}]}, "baseline_offer": {"id": "422726593703150"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1710975600, "status": "PUBLISHED", "id": "1359471961379472"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7703140243139477", "version": "1.3.1V25"}, "id": "385819227458745", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__