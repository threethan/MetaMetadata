7566389081_1678837862000230400_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S_4Ec1WZtUwQ7kNvgHUtcwq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF1f3j0S5rWzu6kDCUQDNCo&oh=00_AYC5XDEyk546sMmJRBmC4TpXaF9NtT0P1DxHS1_f5QpLOg&oe=66F40D8C"}, {"file_name": "migrated_image.png", "id": "231953637929042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138914_2108069686177354_6730451316063076352_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2A3v5oiyAaIQ7kNvgF_5mF4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF1f3j0S5rWzu6kDCUQDNCo&oh=00_AYAMccvoSY_QxklivudNvVwAzaqEIb3rAeMKsTCqcLiJnA&oe=66F401FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/nS4KiW", "id": "211937896154593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448895_211937902821259_3466922117004525568_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QtEW1PXdm-MQ7kNvgFfWJUZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF1f3j0S5rWzu6kDCUQDNCo&oh=00_AYAFjHn0PObfOYZPVcGtLK-0g33TitmEEKbgeQqDjMSFSg&oe=66F3E08D"}, "display_name": "Pi\u00f1ata Party", "keywords": ["exercise", "pi\u00f1ata", "party", "workout", "running"], "long_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR.\n\nCreate a unique room name with friends and hold a multiplayer game with up to four players. Play together or remotely. See who can collect the most candy in three rounds of play.\n\nPractice on your own to build your skills. Pi\u00f1atas will burst with increasing amounts of candy making it more difficult to advance rounds. Pace yourself as you are forced to run faster and longer to win.", "short_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.rollyk.com/privacy", "developer_terms_of_service_url": "http://www.rollyk.com/toc", "publisher_name": "Rollyk", "support_website_url": null, "website_url": "http://www.rollyk.com/pinataparty", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_CA", "en_AU", "en_GB"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "675836513446839"}, "review_messages": ["", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12504788_299693847467886_6384306067588775936_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TWCwwTARaBQQ7kNvgFx08eV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AF1f3j0S5rWzu6kDCUQDNCo&oh=00_AYCDlLSAsyGf5nisT2fAkeox3DqHOG8FPJ4dGgPSDO5OKg&oe=66F3D8C2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pi\u00f1ata Party", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1537981200, "lastRevision": {"nodes": [{"id": "1864721487156474", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1754893891296534", "is_first_party": false, "enables_in