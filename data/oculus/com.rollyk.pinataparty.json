YJQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahks4bgSdNotufmqdx5LZOW&oh=00_AYBHst-HYZwXuu0_1HRnAM16QamUVYV1VubK00hTkq56og&oe=66EAC8F9"}, {"file_name": "migrated_image.png", "id": "237595517414276", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12522249_639977566389081_1678837862000230400_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6B7DGF-_WIMQ7kNvgFklLBl&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahks4bgSdNotufmqdx5LZOW&oh=00_AYDYtPzupweoPMBslTcrzgAeHjqVnV9oKoKjiU7ZPTpHbA&oe=66EAD30C"}, {"file_name": "migrated_image.png", "id": "231953637929042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138914_2108069686177354_6730451316063076352_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yi8mvDFlba0Q7kNvgFa7lUZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahks4bgSdNotufmqdx5LZOW&oh=00_AYCI9gVlgOsj8PZWaaNx1ajPOUqyD7lb49IU8e_i1by8cw&oe=66EAC77B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/nS4KiW", "id": "211937896154593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448895_211937902821259_3466922117004525568_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3IDrEaxMCnMQ7kNvgE56AKz&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ahks4bgSdNotufmqdx5LZOW&oh=00_AYDFfd6t3JJWhNoCI31nZwMz1p5d59A73Ge0DBvR7sSO-w&oe=66EAA60D"}, "display_name": "Pi\u00f1ata Party", "keywords": ["exercise", "pi\u00f1ata", "party", "workout", "running"], "long_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR.\n\nCreate a unique room name with friends and hold a multiplayer game with up to four players. Play together or remotely. See who can collect the most candy in three rounds of play.\n\nPractice on your own to build your skills. Pi\u00f1atas will burst with increasing amounts of candy making it more difficult to advance rounds. Pace yourself as you are forced to run faster and longer to win.", "short_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.rollyk.com/privacy", "developer_terms_of_service_url": "http://www.rollyk.com/toc", "publisher_name": "Rollyk", "support_website_url": null, "website_url": "http://www.rollyk.com/pinataparty", "category": "EARLY_ACCESS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_CA", "en_AU", "en_GB"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "675836513446839"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "174871356747842"}]}, "baseline_offer": {"id": "174871356747842"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1537894800, "status": "PUBLISHED", "id": "174871356747842"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1843975012388421", "version": "2.0"}, "id": "2055451608086836", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "Andro