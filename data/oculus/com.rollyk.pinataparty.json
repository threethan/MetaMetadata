5/12138914_2108069686177354_6730451316063076352_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YTwKnpyVYT0Q7kNvgHkC579&_nc_ht=scontent.oculuscdn.com&oh=00_AYBK0WRK8BiV0WAjySqkZJC7rEwAJiJPgxeJevRKg-APnA&oe=66D45DFB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/nS4KiW", "id": "211937896154593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448895_211937902821259_3466922117004525568_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=udO3U1hO0gEQ7kNvgHM1XZm&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxzQ9weCbJeK1Tm0WnWZk0xgvsKi4Yilicki69y6U_4A&oe=66D43C8D"}, "display_name": "Pi\u00f1ata Party", "keywords": ["exercise", "pi\u00f1ata", "party", "workout", "running"], "long_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR.\n\nCreate a unique room name with friends and hold a multiplayer game with up to four players. Play together or remotely. See who can collect the most candy in three rounds of play.\n\nPractice on your own to build your skills. Pi\u00f1atas will burst with increasing amounts of candy making it more difficult to advance rounds. Pace yourself as you are forced to run faster and longer to win.", "short_description": "Eat virtual candy, burn real calories! Get together with friends and throw a wild party. Smash a pi\u00f1ata and see who can collect the most candy by running in place.  Sensors in the headset and controller track your motion. The faster you move your body, the faster you move in the game. Are you ready to break a sweat? This is active VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.rollyk.com/privacy", "developer_terms_of_service_url": "http://www.rollyk.com/toc", "publisher_name": 