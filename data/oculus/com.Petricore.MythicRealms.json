0_AYC4ZAixHdzrPC-6iYoBMY1SntgN5NSSXtz0h7qc5Z7fLg&oe=6731D7E7"}, {"file_name": "Screenshot5.png", "id": "718449420188985", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031557_718449423522318_1862212767614579329_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u57YP7SUEhUQ7kNvgFPSv_e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAd14jwB-KatUOpMKuujDPcsq_yyKI1rkaySmw6YHaVBQ&oe=6731FC0B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Mythic Realms Trailer-Thumbnail.png", "id": "862597915072784", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974503_862597918406117_5163117168874739528_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lSPM89WzuEQ7kNvgF7Ng4O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCerfN0YqaQyiuxsKRFuFl0INmc2p-TTPa8XzFJb-_fQw&oe=673207D2"}, "display_name": "Mythic Realms Prototype Version", "keywords": [], "long_description": "Note: This demo is now outdated. For the latest updates on Mythic Realms, and for a chance to playtest the newest version, join our Discord! You can find the link in our Linktree linked in the info below. \n\nMythic Realms invites you to transcend the boundaries of your world and enter a realm of endless possibilities. Unearth the mysteries of the MR game world colliding with your own, and uncover the truth behind why they are colliding.\n\nDEMO FEATURES: \n\u2022 Mixed Reality: Seamlessly blend your reality with a mystical realm as you use your device to interact with objects and characters from both worlds. Experience the wonder of worlds colliding and witness monsters crossing over into your surroundings.\n\u2022 Dynamic Gameplay: Whether you're battling fearsome creatures in your living room or building a kingdom in VR mode, there are plenty of interactive activities to keep you occupied.\n\u2022 Build Mode: Build the kingdom of your dreams in MR mode, and then travel into that world, and get immersed in the kingdom you designed by experiencing it in VR mode.\n\u2022 Foes: Sharpen and upgrade your weapons to defeat waves of enemies.\n\u2022 Creativity: Immerse yourself in a visually stunning world that seamlessly blends fantasy with reality. Build a kingdom, forge for materials, and upgrade your weapons through smithing.\n\u2022 Ascend as a Hero: Strengthen your character by leveling up various skills.", "short_description": "Embark on an extraordinary journey of transformation and discovery in Mythic Realms, a captivating mixed reality role-playing game that blends the real world with a realm of mystery, monsters, and magic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://petricoregames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Petricore", "support_website_url": null, "website_url": "https://linktr.ee/petricoregames", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8265414396843909"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_9982469761794443_3062379738544527914_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F1hWOWkAeFYQ7kNvgHodVwW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBPgC1cHmvU0WTfDkdx-8QlFBBnrv_ZmOjSdfBkHNwpfQ&oe=6731E45B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mythic Realms Protot