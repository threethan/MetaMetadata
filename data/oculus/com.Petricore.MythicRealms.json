ps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196223_24626342266965364_4639153513506205510_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qDWUmx0MQHQQ7kNvgEX4_mB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWVSUwlrLuiDPFktK8Z62DyaFbhCWnU-lmkKlvW1oThQ&oe=6731E907"}, {"file_name": "Screenshot5.png", "id": "2810880739080202", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035346_2810880742413535_1026765721309172970_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t_x7KHuKAOEQ7kNvgHZjNqk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxM_dT68FLdXzmr-2RkQuLctgbqSEoSmdcxYUrL59DIQ&oe=6731E742"}, {"file_name": "Screenshot3.png", "id": "970751160661943", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974703_970751163995276_1778428781384122044_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q18jZ00HSLQQ7kNvgG6wAbM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASeXvUBf-9M9bPoQZAcEXJ0tAa0YRoXJ1aMyoID2h23g&oe=6731EDCA"}, {"file_name": "Screenshot4.png", "id": "3560933707454163", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75580060_3560933710787496_5663656956646368754_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=381ycPp3JZsQ7kNvgGLc3bt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4aaiDytBAQCfVV9PY-3Zw3XlEdlyblTXJCiIA4C0Uyg&oe=6731D5DA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mythic Realms", "keywords": [], "long_description": "In Mythic Realms players step into the role of a curious adventurer. A chance encounter with a mysterious object triggers an astonishing transformation, transporting players into a mesmerizing parallel world with their own teeming with secrets to be discovered.\n\n\u2022 Mixed Reality: Seamlessly blend your reality with a mystical realm as you use your device to interact with objects and characters from both worlds. Experience the wonder of worlds colliding and witness monsters crossing over into your surroundings.\n\u2022 Mining: As the chosen hero, you'll need to rebuild a fallen kingdom. Venture through forests.\n\u2022 Dynamic Gameplay: Whether you're battling fearsome creatures in your living room or building a kingdom in VR mode, there are plenty of interactive activities to keep you occupied. \n\u2022 Foes: Sharpen and upgrade your weapons to defeat waves of enemies. \n\u2022 Creativity: Immerse yourself in a visually stunning world that seamlessly blends fantasy with reality. Build a kingdom, forge for materials, and upgrade your weapons through smithing. \n\u2022 Ascend as a Hero: Strengthen your character by unlocking new abilities, enhancing your magical prowess, and mastering combat techniques. \n\nMythic Realms invites you to transcend the boundaries of your world and enter a realm of endless possibilities. Unearth the mysteries of the world colliding with your own, uncover the truth behind why they are colliding, and shape the destiny of a realm in need of a hero. Are you ready?", "short_description": "Embark on an extraordinary journey of transformation and discovery in Mythic Realms, a captivating mixed reality role-playing game that blends the real world with a realm of mystery, monsters, and magic."}]}, "developer_name": null, "developer_privacy_policy_url": "https://petricoregames.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Petricore", "support_website_url": null, "website_url": "https://petricoregames.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_T