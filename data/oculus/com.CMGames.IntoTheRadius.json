07333643926_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ik7ilOak_fwQ7kNvgHV3X5l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlvXSD_jxhKfFom5aYM4LRRSuquAz1TLWinz7RgxWd9A&oe=6741D77E"}, {"file_name": "15_Hub_Weapons_10.png", "id": "2011524495723534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974854_2011524499056867_6974653420321126592_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gGKAeZMcKxEQ7kNvgH7ue22&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmIHZE-0o2_2Qjr8b5CksCipACZMiJ-k_B_aadO9-bHg&oe=6741B207"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ITR_Trailer_Thumbnail_2560x1440.png", "id": "436045485127212", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001671_436045488460545_8320295034043980832_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qXtAg4FUQRUQ7kNvgEcm0Qg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAa3CSHqHLCTK0WQf6N7pi00y_zKDzycEHUhs7JvH-zlQ&oe=6741B1B2"}, "display_name": "Into the Radius", "keywords": ["atmospheric", "shooter", "survival", "horror", "gun"], "long_description": "A VR single-player survival shooter.\n\nYou find yourself in the middle of the blighted zone cut from the outside world. Your guns and your wits are all you have left. Fight the deadly enemies, dodge dangerous anomalies, collect wondrous artifacts on your way to the center of the Radius to find your way out.\n\nExplore the Radius\nBe careful: the Radius is swarming with deadly anomalies dealing damage to anyone foolish or daring enough to get close. Navigate with your realistic map, plan your route, climb over obstacles, scout out shelters, uncover loot caches, and try not to get killed. At least not too often.\n\nCollect and fire realistic guns\nRealistic interaction with a stunning variety of firearms like the AKM Kalashnikov, PM Pistolet Makarova, SKS Carbine, M9 Beretta, PPsh, FN SCAR, and many more.\n\nSurvive by all means\nNavigate the terrain, move slowly, take cover, crouch, sneak, and beware the threats around you!\n", "short_description": "Explore the vast post-apocalyptic area of the Radius in this single-player survival VR shooter. Reach the epicenter of the desolate Anomaly Zone using your wits and a wide arsenal of weapons with realistic handling mechanics.\n"}]}, "developer_name": "CM Games", "developer_privacy_policy_url": "https://cm.games/privacy-policy/", "developer_terms_of_service_url": "https://cm.games/terms-of-use/", "publisher_name": "CM Games", "support_website_url": null, "website_url": "https://cm.games/games/into-the-radius-vr/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "EXPLORATION", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "482515803219800"}}]}, "scheduled_offers": {"count": 46, "nodes": [{"status": "PUBLISHED", "id": "8713039602076257"}, {"status": "PUBLISHED", "id": "1068684124628120"}, {"status": "CANCELLED", "id": "1035190161343109"}, {"status": "CANCELLED", "id": "1006201407840374"}, {"status": "PUBLISHED", "id": "821513643190978"}, {"status": "PUBLISHED", "id": "812602957271557"}, {"status": "PUBLISHED", "id": "511429770851227"}, {"status": "PENDING", "id": "952253885815497"}, {"status": "PUBLISHED", "id": "580722504156472"}, {"status": "PUBLISHED", "id": "271390599006486"}, {"status": "PENDING", "id": "2317651071754193"}, {"status": "PENDING", "id": "799874254948828