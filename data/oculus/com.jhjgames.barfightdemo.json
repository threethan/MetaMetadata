1-3.oculuscdn.com/v/t64.5771-25/38974766_1069670123724893_4837041314092604130_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v9slOLWiXqIQ7kNvgEAJ_NX&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDPSKcJ8tM_uTa-AI-QkyBgDZC4E0c6PVkVYVf7peuPHw&oe=671A1A44"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screen Shot 2022-11-15 at 10.13.29 AM.png", "id": "699294097973489", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974589_699294101306822_8539232374950229543_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bHMHZ15Gx5sQ7kNvgEWPIQ8&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYBgzVVRerEM0LP8kwjhT7hbqiBXH-EWFlgTYOfG7hho3w&oe=671A20BF"}, "display_name": "Galactic Bar Fight", "keywords": [], "long_description": "*** Over 15,000 Downloads, thank you !\n\nGet ready for a Galactic Bar Fight!\n\nGalactic Bar Fight is a fast-paced arena combat game starting in  Pegasus, an intergalactic watering hole in the distant future and then take a tour across the galaxy to various environments all over.\n\nPlayers will be able to complete a variety of our 340+ challenges in both our pegasus hub where they can destroy training droids, practice shooting holograms, observe Hologram stage performers, and more. As well as the in-combat challenges players will be randomly served.\n\nWithin the   bar arenas  players will creatively dispatch enemies using blasters of all types. Featuring 13 unique weapons to Slash , smash , deflect, dissolve, burn ,  and split your enemies. and using Powerups to tip the edge in combat in their own favor.\n\nAll feedback is welcome - come help shape the future of Galactic Bar\nFight as we continue to expand the feature set with suggestions from\nthe community!", "short_description": "Galactic Bar fight is a Galaxy-covering combat tour VR arcade experience, join us as we arrive at Pegasus station and attend  various locales all over the galaxy.! \n\nCurrently  Galactic Bar Fight includes three combat arenas :Club Axilla , Desplate Dunes, and Lych ruins also introducing the weapons and enemies of Galactic Bar Fight . \n\nAchieve our nearly  250 challenges\nView 4 stage entertainment acts\nUse 13 weapons\nUtilize 4 different powerups\nand do it all while listening to energetic music."}]}, "developer_name": "Weird Kid Studios", "developer_privacy_policy_url": "https://www.weirdkidstudios.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Weird Kid Studios", "support_website_url": "https://www.weirdkidstudios.com/support", "website_url": "https://www.weirdkidstudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "838770594270094"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974560_722421441586885_4756691175904922458_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hsfi9fe2xZ0Q7kNvgG2lCir&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCiOCFkAhJfop6ReUI9oN1s4z4CqsVSsxGlci0BzcgOVQ&oe=671A2B05"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Galactic Bar Fight", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1615595312, "lastRevision": {"nodes": [{"id": "2535665073402647", "release_type": "SCHEDULED",