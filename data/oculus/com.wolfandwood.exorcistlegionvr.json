respective owners. All Rights Reserved.", "short_description": "The Exorcist: Legion is an acclaimed horror game set in the Academy Award-winning franchise of The Exorcist.  Now enhanced for Quest 3. Delve deep into the heart of the supernatural as you learn the ancient trade of demonic exorcism and uncover a supernatural conspiracy."}]}, "developer_name": "Wolf & Wood, Ltd.", "developer_privacy_policy_url": "https://www.funtrainvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.funtrainvr.com/exterms", "publisher_name": "Fun Train, Inc.", "support_website_url": "https://www.funtrainvr.com/about", "website_url": "https://www.funtrainvr.com/exorcist", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7533087393445994"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974564_954983586056423_2340967435678367973_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yAVtzB7bCx4Q7kNvgFldY-I&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUhNkWl6qrr30GZit3sH4gn&oh=00_AYB1JnM5fWwxE-Vh9UlyXtIvAXHPUdQB3-ox2E9mLVdOow&oe=66E2BA9F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": 