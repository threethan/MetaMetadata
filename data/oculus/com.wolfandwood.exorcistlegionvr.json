dn.com&_nc_gid=A8kr3yZax8GvzqfGDft5iLD&oh=00_AYClpaVniLahv93Pv8YVI5kFju3Hdny_t0S7IaviUbBTyQ&oe=66EE9200"}, {"file_name": "com.oculus.vrshell-20240515-153356 (0-18-11-19) (1).png", "id": "354549284319646", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269589_354549290986312_349192727238719351_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TXeDBhBkge8Q7kNvgEHl2R1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8kr3yZax8GvzqfGDft5iLD&oh=00_AYDHWzS5tuSIF0pzfF7NSv4Lm8cN8Mnnlhg4MftS8kJ63g&oe=66EEA01F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2.png", "id": "989011322455826", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974850_989011325789159_7554023977374415513_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vKluo858QWEQ7kNvgGzDG90&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8kr3yZax8GvzqfGDft5iLD&oh=00_AYA-vDsrf9wabUoxuhd_ed8nD8UBRDvSe3R_YHBzrPyPKQ&oe=66EE9601"}, "display_name": "The Exorcist: Legion VR", "keywords": ["Exorcist", "Horror", "Movie", "Demon", "Scary"], "long_description": "Experience the game called one of the most terrifying experiences in VR. What an excellent day for an exorcism!  Now enhanced for Quest 3 and optimized for Quest 2 headsets.\n\nDescribed as one of the most disturbing experiences available for virtual reality, The Exorcist: Legion features FIVE connected stories and features a variety of demonic entities, exorcism tools, hidden artifacts and atmospheric locations. \n\n{3847516658858019}\n{534597808967949}\n\nDelve deep into the heart of the supernatural as you learn the trade of demonic exorcism and uncover secrets leading you towards a final confrontation with your darkest, most hidden fears. Are you brave enough?\n\n{1463790964338165}\n\nThe Exorcist: Legion is part action, part mystery, part puzzle-solving... and ALL terror.\n\n{1568767000721557}\n{1072124544621378}\n{3783494471909456}\n--------------------------------------------------\n\nThe Exorcist III and all related characters and elements are trademarks of and \u00a9 Morgan Creek Film Partners I, and LegionVR, LLC, a Fun Train company.  Trademarks belong to their respective owners. All Rights Reserved.", "short_description": "The Exorcist: Legion is an acclaimed horror game set in the Academy Award-winning franchise of The Exorcist.  Now enhanced for Quest 3. Delve deep into the heart of the supernatural as you learn the ancient trade of demonic exorcism and uncover a supernatural conspiracy."}]}, "developer_name": "Wolf & Wood, Ltd.", "developer_privacy_policy_url": "https://www.funtrainvr.com/privacypolicy", "developer_terms_of_service_url": "https://www.funtrainvr.com/exterms", "publisher_name": "Fun Train, Inc.", "support_website_url": "https://www.funtrainvr.com/about", "website_url": "https://www.funtrainvr.com/exorcist", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "HORROR", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8182415548513172"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974564_954983586056423_2340967435678367973_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LVctTr7KaawQ7kNvgEQcpT-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8kr3yZax8GvzqfGDft5iLD&oh=00_AYAfTfntWYcPnsqn5seE35LlKAF