z_iq3DorNdmSOOlFmmSuWIRQgpFhKYCAmCl-t10jTfQ&oe=66EBF61C"}, {"file_name": "migrated_image.png", "id": "146221513358067", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974724_439803246841317_6944505669982617600_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GBYmMEWFkksQ7kNvgHDTgZN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUz3gnyE8T2hN1EjYEj_s6K&oh=00_AYAzeFEJySbeKeCNZLOGZr-45CNZA_qsjCYiy3j9O-2YBg&oe=66EC1E71"}, {"file_name": "migrated_image.png", "id": "275490830108295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974715_2348986035166055_8616935500906758144_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vaPM6RJNwbwQ7kNvgFwsHr9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUz3gnyE8T2hN1EjYEj_s6K&oh=00_AYBGfvybonKXITitBnj8QvBerjo7GWm_ihk3tN_C7xd6rQ&oe=66EC2417"}, {"file_name": "migrated_image.png", "id": "492685264968925", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001662_289325478614142_2042323572780695552_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eotbWaXi7tMQ7kNvgHzuRm4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUz3gnyE8T2hN1EjYEj_s6K&oh=00_AYBdPe3x1BRZ7Wo5r79OCZVrZAZ9EOENZkLcAkFabzpZiQ&oe=66EBF6A6"}, {"file_name": "migrated_image.png", "id": "250684022630962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001698_432265547572690_7022988809973268480_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IRBUCsmigP4Q7kNvgEXKPw0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUz3gnyE8T2hN1EjYEj_s6K&oh=00_AYCMLcawWtKibgToyc2GqwJj3Z7-dTf_9oY2AxVK058_tg&oe=66EC111A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/7NwD7u", "id": "2475056699213854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974599_2475056702547187_922204790702735360_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5kD6wOkuXpwQ7kNvgHJtYXO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUz3gnyE8T2hN1EjYEj_s6K&oh=00_AYAV_ge0Y9ngqnL0iHLSDQONR7NXfPflZVPh11LWm1gm4w&oe=66EC22F4"}, "display_name": "The Exorcist: Legion VR", "keywords": ["Exorcist", "Horror", "Movie", "Demon", "Scary"], "long_description": "The scariest story of all time is now yours to experience if you dare. For a limited time, buyers will also receive the Complete Series on Oculus Rift as a FREE bonus!\n\nThe Exorcist: Legion is a virtual reality adventure set in the Academy Award-winning world created by horror maestro William Peter Blatty. Delve deep into the heart of the supernatural as you learn the trade of demonic exorcism and uncover secrets leading you towards a final confrontation with your darkest, most hidden fears. Are you brave enough?\n\nThe Exorcist: Legion features a variety of locomotion options allowing users to fully customize their adventure.\n\n* Multiple chapters, each featuring a different demonic entity. Replay each chapter for additional secrets and achievements and locate a variety of Easter eggs.\n* Various exorcism tools as well as hidden \u201cartifacts\u201d aid you on your adventure.\n* Return to your evidence room at any time during the game to see items you have collected.", "short_description": "One of VR's highest rated horror adventures is now on Oculus Quest! The Exorcist: Legion VR is an acclaimed virtual reality game set in the Academy Award-winning world created by horror maestro William Peter Blatty.  Delve deep into the heart of the supernatural as you learn the trade of demonic exorcism. For a limited time, buyers will also receive the Complete Series on Oculus Rift as a FREE bonus!"}]}, "developer_name": "Wolf & Wood, Ltd.", "developer_privacy_policy_url": "https://www.exorcistlegion.com/terms", "developer_terms_of_service_url": "https://www.exorcistlegion.com/terms", "publisher_name": "Fun Train, Inc.", "support_website_url": "http://exorcistvr.com/bugs", "website_url": "http://www.exorcistlegion.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "NARRATIVE", "AD