_09.Still002.png", "id": "1642551832819272", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982562_1642551836152605_520028558079364657_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_hLQtjDvLk0Q7kNvgGiadfb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDx6q5WiHVFVDIpf6PgMo4J0dortzxMe0NTmQ5NqTcvfw&oe=672CBAB2"}, {"file_name": "Desktop 2023.09.25 - 20.42.11.10.mp4.00_06_23_38.Still001.png", "id": "643955651273072", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75312297_643955654606405_480568527955268312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9A4iyxf1NUgQ7kNvgEt1zdu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYjPiEiALGNiCDRcVKEZBqYuLJSxF327FZioSaPA8oow&oe=672C9FA6"}, {"file_name": "Master.00_00_34_53.Still005.png", "id": "868776144968854", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57574721_868776148302187_2395318248093284663_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m4zY0NMQ_CYQ7kNvgEQnXum&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCV-uf9uBEYLi7WpdiNDxJoEFio51mVgllULs37a6NzA&oe=672C94F2"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "692760662818107", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982461_692760666151440_1673600769700015261_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kXBXegaZ71MQ7kNvgFRO8kG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjTlmRAZ4NiB4HYzd7DrKWpp9KHj-u8jc1qe5Q3LCJiQ&oe=672C8EBB"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "1014728119759484", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974571_1014728126426150_3738956639406327634_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nr3KnRhGploQ7kNvgGOSBQy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoo5FAsc-fuCpP8x3AD1MWPweI-6Gm5VWLjt8mVHH-PQ&oe=672CA433"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OrypK9FkbQ4Q7kNvgGO42sw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPUiAfK7YYfRIkj7ZEZAWV1ZcqotW2EPm9vYUxWdldag&oe=672CA232"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "CoverSquare.png", "id": "1312052229497294", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982566_1312052239497293_6745570273078436185_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4AHevTBU_58Q7kNvgGPhdYY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCXIGy7vNJWSBmcQZJpP1KkxEYN8Yb7qkG8Nm3j9-04AA&oe=672CC354"}, {"file_name": "CoverPortrait_v2.png", "id": "1024112362161553", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031462_1024112365494886_4766649452308450052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FUPDzWhTm7UQ7kNvgG5RnYk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApjTILqwKJXHTkeTzA9piXlhb3D8iVq4whIfOaAbaLPw&oe=672CB9B5"}, {"file_name": "Logo.png", "id": "973425620588096", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86610716_973425627254762_5218087471640407679_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xex1W9M9FRYQ7kNvgEsYOlv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKHQbLqFgKI38G5xHUjV4Te39ZL5DrPb-BarOzQx9y9A&oe=672CC181"}, {"file_name": "Immersive_Logo_Background.png", "id": "895514205419900", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974456_895514212086566_4652023532074201416_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=imS-ykV2vegQ7kNvgGuq1e2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNmfkJlW2CbQ1Vvnq8xmA499fa4fVwQmXoGGJzkrO0aQ&oe=672CAD5F"}, {"file_name": "Imme