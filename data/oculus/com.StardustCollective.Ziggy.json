39777074167_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0bevJt05HYIQ7kNvgEnDhPc&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARYGIiGh_tDYuThXEG8pMii&oh=00_AYDlBiaF34XGnvSjD3rhtkkN8yuzJuC-0K1GNDhmRyu7qw&oe=66E970F8"}, {"file_name": "HighresScreenshot00146.png", "id": "163970600033098", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566678_163970603366431_5435931785999963108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lji0zEHhPBoQ7kNvgGB6oNQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARYGIiGh_tDYuThXEG8pMii&oh=00_AYALWKPTtFPrmYvW3WKg41yxMJOQvnK2yOdshqTm5deboQ&oe=66E97571"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ejme2BwOgRoQ7kNvgGcI_Jf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARYGIiGh_tDYuThXEG8pMii&oh=00_AYDLHBjvVs7Bx8tw6FMCz3EFXuoUeRqpVlGwEy6oeNf11A&oe=66E965B2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1324311035174797", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_1324311038508130_2610060411856834928_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tc66ra1lOVMQ7kNvgHeV-9_&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARYGIiGh_tDYuThXEG8pMii&oh=00_AYCfcKkMddyLe-1xyJ7NvHpStRrjAjPtyG17CWgYQfo8tQ&oe=66E95E78"}, {"file_name": "CoverImage_Portrait.png", "id": "1021944422558335", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031612_1021944425891668_3460677483354056217_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g5Yc2kTu9PMQ7kNvgGmOU_1&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARYGIiGh_tDYuThXEG8pMii&oh=00_AYCUPX1pgytcvBrIBuhVpQs66Q7LRxCoDYMXEca3HND4MA&oe=66E95E7E"}, {"file_name": "CoverImage_Square.png", "id": "998366967853309", "im