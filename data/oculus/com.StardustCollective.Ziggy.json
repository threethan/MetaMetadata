oh=00_AYAirdwxGjCDeDADYio_-FK7-45xzEldvmnIK44wVAYXGQ&oe=66F68A0F"}, {"file_name": "HighresScreenshot00014.png", "id": "997351624641332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982456_997351627974665_2778603811108028476_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W0Gts2ATu4YQ7kNvgHBX6BP&_nc_ht=scontent.oculuscdn.com&oh=00_AYA9AUFbUFWEU0Etk0Wq5_4PgOK-mV9IBhd2QOTw_0FH9g&oe=66F6B521"}, {"file_name": "HighresScreenshot00040.png", "id": "807733037419699", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_807733040753032_763200239777074167_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wFuAMrm96ucQ7kNvgHQ3v4O&_nc_ht=scontent.oculuscdn.com&oh=00_AYDlWPbhYXfNFMDNfXUPmJDSHW_yHQQGzs65mRcKjEI7Yw&oe=66F69FF8"}, {"file_name": "HighresScreenshot00146.png", "id": "163970600033098", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566678_163970603366431_5435931785999963108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QTfFzSmxJxcQ7kNvgEFWnwL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCiMR8c3CNxF3F3ugJLge7F0DpgEn5mvYeWCAAsF6l4cw&oe=66F6A471"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZklFegGFKHoQ7kNvgHj_0Gb&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFdga4BjTppYYsnznGOTqDImfwOakIhsFsLaeLhMl2rA&oe=66F694B2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1324311035174797", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_1324311038508130_2610060411856834928_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3vyOx6zn5NMQ7kNvgHhbEWq&_nc_ht=scontent.oculuscdn.com&oh=00_AYDzvN-KQfxUvvyeeF89pzTlbUCzF1NX43utH4wQceevnQ&oe=66F68D78"}, {"file_name": "CoverImage_Portrait.png", "id