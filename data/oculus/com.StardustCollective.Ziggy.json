=00_AYBvL2q9V9n5CpsriD73eBqaZ3kOVIQPpBrLZX6MrEQMag&oe=66D46632"}, {"file_name": "Desktop 2023.09.25 - 20.42.11.10.mp4.00_06_23_38.Still001.png", "id": "643955651273072", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75312297_643955654606405_480568527955268312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4n9quwxLshUQ7kNvgG8Qlzu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrRtBGzoQFR-DLA2JCURm5Ne9DNf-I8QDRVP8Vgq6vhw&oe=66D44B26"}, {"file_name": "Master.00_00_34_53.Still005.png", "id": "868776144968854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_868776148302187_2395318248093284663_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L0mAaUivhaMQ7kNvgGr5KaD&_nc_ht=scontent.oculuscdn.com&oh=00_AYBCEFbs46RM1q-9OlefLPxy-wwLadKk2CCE-oIGkNHNDA&oe=66D44072"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "692760662818107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_692760666151440_1673600769700015261_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0mFmIFYRMW0Q7kNvgFIBkfE&_nc_ht=scontent.oculuscdn.com&oh=00_AYCma7ZSfpeWIaExnZtbxCCje6VXuHZXYZHrMVri1Xb7jA&oe=66D43A3B"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "1014728119759484", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974571_1014728126426150_3738956639406327634_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JkfYEhMGCS4Q7kNvgEf4ypR&_nc_ht=scontent.oculuscdn.com&oh=00_AYARc8Z9LDXsYuiRSzecQ8GkwlHSTcsGZZ6dotFlrmMUYQ&oe=66D44FB3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ziRb4tdetUMQ7kNvgFrI33_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaCBHI2mqqkJi_X6mb4_t2xaMTzBewOm1kixph7vAIzA&oe=66D44DB2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"