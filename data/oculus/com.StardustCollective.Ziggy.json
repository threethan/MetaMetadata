62744500445", "locale": "en_US", "screenshots": [{"file_name": "S_music_Trailer_Short_edit.00_00_00_09.Still002.png", "id": "1642551832819272", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1642551836152605_520028558079364657_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GCr2PTPgv_IQ7kNvgH4zOOd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYD65sKywyPKswkjUamqObHTEDKCJlzQCBYjOrKMpF-K-Q&oe=66F40A32"}, {"file_name": "Desktop 2023.09.25 - 20.42.11.10.mp4.00_06_23_38.Still001.png", "id": "643955651273072", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75312297_643955654606405_480568527955268312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tq34MJXymcwQ7kNvgGNM6qb&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYA3V2YSW28QAFxLEVMRGdmhBz3QahrdyiG_KxKx47aueQ&oe=66F3EF26"}, {"file_name": "Master.00_00_34_53.Still005.png", "id": "868776144968854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_868776148302187_2395318248093284663_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vqQXvbHwx6AQ7kNvgHtBwDM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYC6kAkcyNPOOrdC_yx10oJfWXOV46J11QGovDI8OLFCGw&oe=66F3E472"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "692760662818107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_692760666151440_1673600769700015261_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PZjB0_DwCB8Q7kNvgGWakJ6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYDYKW59t4i9o_XCPrQ6aglMJNss7AOTsv5nREDIn7_mBg&oe=66F3DE3B"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "1014728119759484", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974571_1014728126426150_3738956639406327634_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8uFtR9h_wQMQ7kNvgF-ILHQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYCsvN-8UHTqsD3AMqmbNsCdZZWVMvPYgnbtYwZO1ZtHMQ&oe=66F3F3B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gcj0MtMYw-cQ7kNvgFO2nDe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYAPxDOUW1hWhEheOxtcp8KFR5piBmSeU04wbAs8VkxwhQ&oe=66F3F1B2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "CoverSquare.png", "id": "1312052229497294", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982566_1312052239497293_6745570273078436185_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dxt1T_p3fLYQ7kNvgH5_Ot4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYCCuebiuhFAiB4afzNZZCw9zyoX6aC6TNHUshXWqL5W6A&oe=66F3DA94"}, {"file_name": "CoverPortrait_v2.png", "id": "1024112362161553", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031462_1024112365494886_4766649452308450052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QDDINUuxiYgQ7kNvgHTwgLt&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYC5xNHAKPefsegiR0Y9WJKHbwVKE-7JCCGewyZvMPB0vg&oe=66F40935"}, {"file_name": "Logo.png", "id": "973425620588096", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610716_973425627254762_5218087471640407679_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sn5zzwZ0xeoQ7kNvgHmCP5s&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWdZNphSalleck6XvDImiwU&oh=00_AYA0RxY6SEALHfBsjdichlrKI6UvGIDU34FATr7sUvfT6Q&oe=66F3D8C1"}, {"file_name": "Immersive_Logo_Background.png", "id": "895514205419900", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_895514212086566_4652023532074201416_n.png?_nc_cat=102&ccb=1-7&_nc_sid