_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ejme2BwOgRoQ7kNvgGmi0lG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeSxa0Ib3YJfn2xZ--mLA_z&oh=00_AYCIyvOiAyCCktG-O-XHcVk9sDxzL6vS2zP-mD_jX1Za8g&oe=66EAB732"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "CoverSquare.png", "id": "1312052229497294", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982566_1312052239497293_6745570273078436185_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jfAgSoH_xogQ7kNvgGnIKp0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeSxa0Ib3YJfn2xZ--mLA_z&oh=00_AYApN76inkx-UMGEDn3Zr27fRERruovQgoqCYyHP_NjC4g&oe=66EAA014"}, {"file_name": "CoverPortrait_v2.png", "id": "1024112362161553", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031462_1024112365494886_4766649452308450052_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D7jDwNNE2E8Q7kNvgET0R5X&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeSxa0Ib3YJfn2xZ--mLA_z&oh=00_AYDipvEdEYVS1g3WESZIyDITAXTrvnAChP4M9g2OVQWLpw&oe=66EACEB5"}, {"file_name": "Logo.png", "id": "973425620588096", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86610716_973425627254762_5218087471640407679_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P6hMB3JttGIQ7kNvgFIOqwE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AeSxa0Ib3YJfn2xZ--mLA_z&oh=00_AYDi4EazgEH1TbE8JGiFzYXGi8piCWpFJyo5MEOVG-mmxg&oe=66EA9E41"}, {"file_name": "Immersive_Logo_Background.png", "id": "895514205419900", "image_type": "APP_IMG_IMMERSIVE_LAYER_BACKDROP", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_895514212086566_4652023532074201416_n.png?_nc_cat=102&ccb=1-7&_nc_sid