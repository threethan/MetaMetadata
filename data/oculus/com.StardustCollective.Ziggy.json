Desktop 2023.09.25 - 20.42.11.10.mp4.00_06_23_38.Still001.png", "id": "1364267400965138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574723_1364267404298471_3901792330843810654_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Of2WRlLKm-0Q7kNvgH5ehA4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDE2OpEXfNCyxUTErrUrVgqeNqC-FBoXY4M1StWVhVKXg&oe=674DB8FE"}, {"file_name": "Master.00_00_34_53.Still005.png", "id": "1275611523126200", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75340707_1275611526459533_6871146870692278099_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PLrN_tY31RQQ7kNvgFUs3FI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbJP8P7EG5S9TP99kxiIYnDveRmFz6T_LejaRJDFr6Og&oe=674DAC12"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "324528640192467", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974575_324528643525800_8777739433598943558_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DeihJ7bFlz4Q7kNvgGiROOi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAuubEuzSSz-fy0zFb6CS9-aDuxKnSR5yfzq_AoAm8qAQ&oe=674D8A5D"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "6757908704317420", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974691_6757908707650753_3424585239064189609_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x0Pr1jytUmwQ7kNvgGZOSke&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD53RYrEoMmvh32fspTpvyGlG4kH6B3QImDvgLZnjpMpA&oe=674DBAA8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "312845394416247", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035359_312845397749580_7295644085646795585_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whbiWJV2Db8Q7kNvgHpof53&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUX0jJqVjG1dUcd9tZLCeuvxs--KSQzB6OOhUu-V00gw&oe=674D9F79"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.stardustcollective.dev/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Stardust Collective", "support_website_url": "https://www.stardustcollective.dev/support", "website_url": "https://www.stardustcollective.dev/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8801148349965203"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974706_955298052907897_7313547298823469756_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mkfavXRm6xgQ7kNvgGb-n2O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnOx9TtK_aFi9pgDTMJYQmkIGHEMq8RONmHWZ40t85bQ&oe=674DB8B1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Ziggy's Cosmic Adventures", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1699549200, "lastRevision": {"nodes": [{"id": "1570193040004344", "release_type": 