26459533_6871146870692278099_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B5XE0wQcA1kQ7kNvgG7OZFK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKylVtnxL6bj665gketkMbL&oh=00_AYB7nRg7MJy3mslMScOWyZh0srp3aJ79lHd7qL43Zp3x8A&oe=66ED6E92"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "324528640192467", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974575_324528643525800_8777739433598943558_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qu3ud6V6WfsQ7kNvgFXB_Zs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKylVtnxL6bj665gketkMbL&oh=00_AYC7qqHfeHLyOJCC3zs_ARae_3svQRRd7o6inoS0oOzxSQ&oe=66ED4CDD"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "6757908704317420", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974691_6757908707650753_3424585239064189609_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-EPs5q47_AQ7kNvgHGn3bj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKylVtnxL6bj665gketkMbL&oh=00_AYDQWrmBhRlbniBvaNzaPtJC_c8JXwumh0bDNu8GWwG0jw&oe=66ED44E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "312845394416247", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035359_312845397749580_7295644085646795585_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sZbt2Esd7IkQ7kNvgHsNEQK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKylVtnxL6bj665gketkMbL&oh=00_AYDHCZW5M8L-Qx5l78GPG_BGpMcfau60SIJE8x3Iykwj0Q&oe=66ED61F9"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.stardustcollective.dev/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Stardust Collective", "support_website_url": "https://www.stardustcollective.dev/support", "website_url": "https://www.stardustcollective.dev/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "