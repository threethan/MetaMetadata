39777074167_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=msr3owPxW4sQ7kNvgEiRVdF&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af18QokPpYHQuyGL4970yWJ&oh=00_AYDF4V2y4KN4pulwrHRg_vqVMmw2Qjh489J566MX8aWyXQ&oe=66EEB6F8"}, {"file_name": "HighresScreenshot00146.png", "id": "163970600033098", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566678_163970603366431_5435931785999963108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0M_CQ26vX0QQ7kNvgGMpDMG&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af18QokPpYHQuyGL4970yWJ&oh=00_AYCQtvTq0bf7x8JozYpzWmAwjNdY2JnZUxMKzOzFhxGRRg&oe=66EEBB71"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w79r5O5I40EQ7kNvgFvZxr5&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af18QokPpYHQuyGL4970yWJ&oh=00_AYAc4dLdl5raSKPXGB2iYmOyj1cLz6_6B2g8Nmz-HdmqAg&oe=66EEABB2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1324311035174797", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984472_1324311038508130_2610060411856834928_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jvlfvLK3N9wQ7kNvgF-60xy&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af18QokPpYHQuyGL4970yWJ&oh=00_AYDPT-3wY_9GN1wgJN66x2VXHxUrziz8c6wmZJeoyf6l_Q&oe=66EEA478"}, {"file_name": "CoverImage_Portrait.png", "id": "1021944422558335", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031612_1021944425891668_3460677483354056217_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MsJTOiaeDWQQ7kNvgEjzAWV&_nc_ht=scontent.oculuscdn.com&_nc_gid=Af18QokPpYHQuyGL4970yWJ&oh=00_AYCaeczoiVb3eagEr7wwr8NfTIvi7mLrpgCX9bnad_ZerA&oe=66EEA47E"}, {"file_name": "CoverImage_Square.png", "id": "998366967853309", "im