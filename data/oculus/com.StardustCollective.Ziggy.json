=00_AYDNnfX2Xt5-0zSzB8iGrHH7IEwVx5vl1Sg44YGpr0ZfMQ&oe=66D1C332"}, {"file_name": "Desktop 2023.09.25 - 20.42.11.10.mp4.00_06_23_38.Still001.png", "id": "643955651273072", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75312297_643955654606405_480568527955268312_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vErUlf99Qo0Q7kNvgFoqmDJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKFKTcZp5fDavpVJo7abALCgkiBnzHbHFclKDGwr70Aw&oe=66D1A826"}, {"file_name": "Master.00_00_34_53.Still005.png", "id": "868776144968854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574721_868776148302187_2395318248093284663_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vtLR6OcKGiQQ7kNvgFj0CLh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbAaUOUfTSGtv5pdsoMkdkMOAu5wBOEy6QY3pP-Fam4Q&oe=66D19D72"}, {"file_name": "Master.00_00_25_53.Still002.png", "id": "692760662818107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_692760666151440_1673600769700015261_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ujRQvdnjnyMQ7kNvgHkmQlr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDdXxg68afGZCnpF6Tld3bWGgQgJXPZk6ZtR3fz-JWnJA&oe=66D1973B"}, {"file_name": "2023-07-01 19-38-56.mp4.00_05_33_04.Still001.png", "id": "1014728119759484", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974571_1014728126426150_3738956639406327634_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_4T9othts8Q7kNvgE_FsWd&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5aZVX9o8N06Oje2jB62HXjsGkaw4tIkpj_wXWx7UgEg&oe=66D1ACB3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_End_Card-Recovered.png", "id": "273391962004750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974788_273391965338083_1886064065722113930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ziRb4tdetUMQ7kNvgG__vLM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAOu0OplFcL1XeE1zXh2jLCTAQjEcopZ98Y20n0Qd_jg&oe=66D1AAB2"}, "display_name": "Ziggy's Cosmic Adventures", "keywords": ["Cockpit", "Alien", "Green", "Space", "Physics"], "long_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?\n\n\u2022 Become one with the ship: Immerse yourself in a cockpit packed full from ceiling to floor with distinct physics-based interactions (Though make sure to keep your eye on them all if you want to survive!).\n\n\u2022 Rebel against The Empire: Engage in thrilling dogfights as squads of enemies pursue you to re-capture the small green treasure aboard your ship - shoot bullets, launch bombs, and raise your shields. It's going to get bumpy!\n\n\u2022 Navigate the vacuum of space: Control the ship with a radical and easy-to-use virtual flight stick design, dodge your way through hazardous space environments, and don't forget to do a barrel roll!\n\n\u2022 The little guy: Who could forget your cosmic friend, Ziggy?! This mysterious creature is a perfect fuel source. You can also play with them, use them as a resource, feed them, and most importantly pet them!\n\n\u2022 The Journey: Fight your way through 13 unique levels total. Forge a different path each time by beating challenges and unlocking harder worlds en route.", "short_description": "Ziggy's Cosmic Adventures is a VR cockpit game combining ship management with action-arcade combat. You play as a (sometimes effective) bounty hunter with possibly questionable morals, currently in possession of a powerful little alien that you may or may not have stolen/liberated from the evil Empire. As the Empire closes in, you'll need to find a way to balance your ship's management with the onslaught of attacks. Do you have what it takes to survive?"}, {"images": {"