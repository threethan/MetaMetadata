 "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/39035396_508789845285508_7989382406479042993_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c19kmedme9oQ7kNvgHD3sHa&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDswWgrgeRwtiJBA7Jte41bQS9MbZ-A1AgBWWyGdnY2BQ&oe=6728A263"}, {"file_name": "screen2.png", "id": "510325685259902", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974518_510325688593235_6153548243770529811_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=47xWQqfqQNQQ7kNvgEAvQj8&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCxiVhwnW5SaAIQhhlpL7LWy7do2srKqB1VbtbUio2TXw&oe=6728C4AA"}, {"file_name": "screen3.png", "id": "898900988347271", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974518_898900991680604_4064162559334927459_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UhNC0lhdo-cQ7kNvgEfOOR5&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCLsfJtAGFoKt9HvMnWpDZ2JstjVyELbRmM_b9ewSbB8A&oe=6728C7E2"}, {"file_name": "screen4.png", "id": "1550771415533107", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39035420_1550771418866440_5124599204833349204_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mcNwSsVTmzkQ7kNvgG47btb&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYD0lBzPhquUQEv0cnol8HY_-RSGfhoBO373PmqPisO1rg&oe=6728C821"}, {"file_name": "screen5.png", "id": "1246664026750408", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75245823_1246664030083741_697450064622171552_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SDezUmi1-lAQ7kNvgHYEAZt&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYC3cVYOVYcVcEOOy_096PoHDlCH-Yi2VEnzr-k388pWSA&oe=67289FDA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "3720853248168753", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974785_3720853251502086_3604682786672398780_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mf0YhZxRnoQQ7kNvgH5_74I&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYChKgev7k7VfgELYQjcg_76M4vjUc54BH9TovJRBwX5PA&oe=6728A4C7"}, "display_name": "London Walking Like A Tourist - VR Travel", "keywords": ["London", "Travel", "Tourist", "Walk", "Sightseeing"], "long_description": "Experience London through the eyes of a tourist on a nearly 2-hour immersive journey.\n\nA Day in London \u2013 Real Time Experience: Whether you have an hour or a full day, this app lets you explore London for almost 2 hours. No long planning\u2014just dive right in and feel like you're walking the streets of London. Perfect for a quick virtual getaway, it fits seamlessly into your day.\n\nPack Your Virtual Backpack and take a spontaneous day trip! No stress, no planning\u2014start from bustling Victoria Station to the majestic Buckingham Palace, stroll across the Mall to the Horse Guards, and enjoy iconic red buses and the sights of the city. Discover hidden corners and flow with the tourists.\n\nEscape from Home: Break free from routine, launch the app, and jump into the lively streets of London. Hear the city\u2019s sounds, from the rumble of buses to the hum of conversations, and soak in the real atmosphere of this fascinating city.\n\nFeel Like a Tourist: Not a guided tour or information overload\u2014this app gives you the feeling of freely exploring the city, just like a real tourist. Experience the meditative joy of wandering the streets with all the impressions of a real visit.\n\nStart your 2-hour virtual day trip now and immerse yourself in the streets and life of London.", "short_description": "See London through the eyes of a tourist: Stroll through the city as if you were there, walking for almost 2 hours from Victoria Station to Buckingham Palace, across the Mall to the Horse Guards, and continuing to Westminster with Big Ben and the London Eye. Enjoy the city\u2019s sounds, see people, tourists, and red buses\u2014no guided tours, no info overload. Jump right in and take a quick virtual day trip! Relax in a meditative experience that immerses you into the streets and life of London."}]}, "developer_name": null, "developer_privacy_policy_url": "http://vrtravelx.net/home/londonwalk1", "developer_terms_of_service_url": null, "publisher_name": "VRtravelX", "support_website_url": null, "website_url": "http://vrtravelx.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8471867119529633"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2288043414903903"}]}, "baseline_offer": {"id": "2288043414903903"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728943741, "status": "PUBLISHED", "id": "2288043414903903"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8494673280582350", "version": "1.1"}, "id": "1052705616516353", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8471867099529635", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8494673280582350"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1052705616516353"}]}, "change_log": null, "created_date": 1727809120, "id": "8494673280582350", "version": "1.1", "version_code":