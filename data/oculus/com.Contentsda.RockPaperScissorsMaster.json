5771-25/75330719_850088747205423_684042757353052075_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b5MgQv_EdJ4Q7kNvgF5-_aR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBBXeJGqd_o9a5kt13yS7H_Ml-ercnP7vJIQ-eJ5TXePA&oe=672623D3"}, "display_name": "Rock-Paper-Scissors Master", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "It is a cognitive game for cognitive rehabilitation training to help rehabilitate people with cognitive decline and mild cognitive impairment, and is designed to provide two or more cognitive experiences and training in the game. Cognitive Rock-Paper-Scissors Master is a cognitive game designed to allow people with severe disabilities who have difficulty using controllers to play through hand tracking."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_RE