ots": [{"file_name": "08.screenshot3.png", "id": "1135145277676525", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75318184_1135145281009858_7366594915320212636_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N483vn5fQY8Q7kNvgGVb9d8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdVfg-TVEUb1-F-MVC0ePpnjMIFdrgiqaFwUr22mRZZw&oe=670E7054"}, {"file_name": "08.screenshot1.png", "id": "7288563721197860", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974474_7288563724531193_1705445377984521391_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvRc7VtyNtIQ7kNvgHxyvhD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv04p40YnbeKvCqqtim1npDXuftTKB4w04flH8NUYhlg&oe=670E5D33"}, {"file_name": "08.screenshot4.png", "id": "1393579937965717", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75462209_1393579941299050_6951045214326005224_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VPSzpLnDAIUQ7kNvgFdVZ7U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDO7TmwCILLncPqf3wF1Q8tT54huhAWyAIPRxp7T-mrig&oe=670E4020"}, {"file_name": "08.screenshot5.png", "id": "835928298358034", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_835928301691367_7366048854033048333_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zm0NSCypLdwQ7kNvgGereJx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDMGDW5qChWrL1lCKPxdfJQo1g_8wbYakduFKIvZtjLRg&oe=670E4E10"}, {"file_name": "08.screenshot2.png", "id": "1475382446695017", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031319_1475382453361683_7350512207923370097_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-9aL78rHnWYQ7kNvgF4HUiS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByeioJB2h973NwZQz3CMvykXzvo96sgYhysYVVJk1Haw&oe=670E6E79"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "10.coverImage.png", "id": "1855834691532004", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982664_1855834694865337_3191788769292524056_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8-Fh0aiGqsEQ7kNvgF9xdT2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDr2e9gZvjE8IwpIJF81eVcy-mDJrLh53GnJwK27iEIZQ&oe=670E70A4"}, "display_name": "Rock-Paper-Scissors Master", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "It is a cognitive game for cognitive rehabilitation training to help rehabilitate people with cognitive decline and mild cognitive impairment, and is designed to provide two or more cognitive experiences and training in the game. Cognitive Rock-Paper-Scissors Master is a cognitive game designed to allow people with severe disabilities who have difficulty using controllers to play through hand tracking."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "879473995923081"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null