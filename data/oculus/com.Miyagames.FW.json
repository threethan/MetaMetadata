droidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8138859132882217"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": null, "created_date": 1731037421, "id": "8138859132882217", "version": "1.1.1", "version_code": 38, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8138859132882217"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": null, "created_date": 1730942017, "id": "8132976430137154", "version": "1.1.1", "version_code": 37, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8138859132882217"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730886825, "id": "8129487643819366", "version": "1.1.1", "version_code": 36, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8138859132882217"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": "\ud83c\udf1f\ud83d\ude80 Unleash the New Era of Adventure: Floating World's Massive Update \ud83d\ude80\ud83c\udf1f\nDear Players, Get ready to dive into the ocean of excitement as we proudly present the most significant update in the history of Floating World! \ud83c\udf88\ud83c\udf0a\nPrepare for a Whole New Journey:\nThis update is not just a patch; it's a revolution! We've revamped the game with a plethora of new features, items, levels, islands, animals, and a complete storyline that will take your breath away.\n\ud83c\udd98 Important Notice: \ud83c\udd98\nDue to the extensive changes, your old game saves may not work. We strongly encourage starting fresh to fully experience the wonders of Floating World.\nWhat's New:\nNew Island: Evacuation Point - A massive level island filled with puzzles and new resources waiting for you to discover.\nNew Islands: Explore these islands to uncover story clues and new items.\nNew Building Styles: Four new styles of construction to make your floating home more diverse and interesting.\nNew Animal NPCs: Alpacas, Ponies, and more, scattered across islands waiting to be found.\nNew Navigation Tools: Larger sails and new engines for faster and smoother sea travel.\nArcade Game: A built-in arcade game to pass the time at sea, with a mysterious reward for completing it.\nTech Gloves: Earnable after completing specific tasks, these gloves come with \"Flight Chips\" and \"Attack Chips\" for flying and combat abilities.\nTutorial Levels: Learn the basics and tips of Floating World before starting the game.\nNew Background Music: Immerse yourself in the new soundtrack. Plus, new mini-games, items like fireworks, pig costumes, furniture, and more await your discovery in Floating World.\nOptimizations:\nShip Building Limit: Increased ship building limits, with the ability to upgrade further in the upgrader for even larger ships.\nNew Sky and Cloud Effects: Enhanced visual experience.\nItem and Resource Balancing: Adjustments to item and building resource values.\nSynthesizer Tweaks: Prevents accidental drops into the water.\nAnimal Safety: Animals no longer die when they fall into the water.\nBelt Positioning: Improved for more comfortable item placement.\nConstruction Gun: Removes resource return for corresponding resources.\nPlanting Improvements: Smoother planting interactions.\nDisable Fall Damage: No more damage from falling from heights.\nUI Display Effects: Enhanced for better visibility.\nStory Clues: Improved narrative guidance.\nMany known bugs and player feedback have been addressed. This is a polished, complete game version we've been working on for a long time. We hope you enjoy the new experience in Floating World! \ud83c\udf1f\nHappy Floating! \u2601\ufe0f\ud83d\udea2\ud83d\udc2c", "created_date": 1729741270, "id": "8050928198341978", "version": "1.1.0", "version_code": 33, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}