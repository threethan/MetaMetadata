eITYZPhRjHHjKB2me_3HAQMHE8w&oe=67289C21"}, {"file_name": "A004.png", "id": "996103881034355", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974583_996103884367688_4238371506020737238_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NK2HAtBxP8Q7kNvgGOTT0-&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCQDGgp8K1Re33xeQHV-y2f_Yw2arRKWCXmpUzr0TMyUQ&oe=6728A054"}, {"file_name": "A005.png", "id": "741721570567971", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39035357_741721573901304_4839548019498585933_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VLA7rYvX5kwQ7kNvgF1NPZu&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAy2cLGUgZ5BZOdS7Nkld1g_lKqjL7WeTIM2CupJ83eew&oe=6728B4F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape2.png", "id": "1432126240629249", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974629_1432126243962582_5352689955482993965_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ak2-fYzZJdcQ7kNvgHXDuGO&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCyAJGbWw9lnhOkiNkYdSmmdGnCXHOSsqY-TImez2AX2Q&oe=6728C564"}, "display_name": "Floating world  - Alpha", "keywords": [], "long_description": "Floating World is a marine survival, construction game.\nIn addition to perfect systems of survival, food, and planting, a DIY system has been introduced. If you like, you can even create your own Titanic.\n30 years ago a big flood destroyed here. You wake up and only find a raft and a shark around you. Your mission is Evacuation, but before that, you need to stay alive. Are you ready for your adventure?", "short_description": "A big flood hit here. Now your mission is to leave this floating world. But before that, stay alive! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://miyagames.mystrikingly.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MiYa Games", "support_website_url": null, "website_url": "https://miyagames.mystrikingly.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}, {"id": "1990104051447093"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "EXPLORATION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "566097891574823"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "1673744273354220"}, {"status": "PUBLISHED", "id": "801586825290721"}, {"status": "PUBLISHED", "id": "410442764205710"}, {"status": "PUBLISHED", "id": "592530169043964"}]}, "baseline_offer": {"id": "801586825290721"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730421001, "status": "PUBLISHED", "id": "1673744273354220"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5638151719619650", "version": "1.5.03"}, "id": "484910946122783", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": "\ud83c\udf1f\ud83d\ude80 Unleash the New Era of Adventure: Floating World's Massive Update \ud83d\ude80\ud83c\udf1f\nDear Players, Get ready to dive into the ocean of excitement as we proudly present the most significant update in the history of Floating World! \ud83c\udf88\ud83c\udf0a\nPrepare for a Whole New Journey:\nThis update is not just a patch; it's a revolution! We've revamped the game with a plethora of new features, items, levels, islands, animals, and a complete storyline that will take your breath away.\n\ud83c\udd98 Important Notice: \ud83c\udd98\nDue to the extensive changes, your old game saves may not work. We strongly encourage starting fresh to fully experience the wonders of Floating World.\nWhat's New:\nNew Island: Evacuation Point - A massive level island filled with puzzles and new resources waiting for you to discover.\nNew Islands: Explore these islands to uncover story clues and new items.\nNew Building Styles: Four new styles of construction to make your floating home more diverse and interesting.\nNew Animal NPCs: Alpacas, Ponies, and more, scattered across islands waiting to be found.\nNew Navigation Tools: Larger sails and new engines for faster and smoother sea travel.\nArcade Game: A built-in arcade game to pass the time at sea, with a mysterious reward for completing it.\nTech Gloves: Earnable after completing specific tasks, these gloves come with \"Flight Chips\" and \"Attack Chips\" for flying and combat abilities.\nTutorial Levels: Learn the basics and tips of Floating World before starting the game.\nNew Background Music: Immerse yourself in the new soundtrack. Plus, new mini-games, items like fireworks, pig costumes, furniture, and more await your discovery in Floating World.\nOptimizations:\nShip Building Limit: Increased ship building limits, with the ability to upgrade further in the upgrader for even larger ships.\nNew Sky and Cloud Effects: Enhanced visual experience.\nItem and Resource Balancing: Adjustments to item and building resource values.\nSynthesizer Tweaks: Prevents accidental drops into the water.\nAnimal Safety: Animals no longer die when they fall into the water.\nBelt Positioning: Improved for more comfortable item placement.\nConstruction Gun: Removes resource return for corresponding resources.\nPlanting Improvements: Smoother planting interactions.\nDisable Fall Damage: No more damage from falling from heights.\nUI Display Effects: Enhanced for better visibility.\nStory Clues: Improved narrative guidance.\nMany known bugs and player feedback have been addressed. This is a polished, complete game version we've been working on for a long time. We hope you enjoy the new experience in Floating World! \ud83c\udf1f\nHappy Floating! \u2601\ufe0f\ud83d\udea2\ud83d\udc2c", "created_date": 1729741270, "id": "8050928198341978", "version": "1.1.0", "version_code": 33, "release_status": "SCHEDULED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727597449, "id": "7858713014230165", "version": "1.1.0", "version_code": 32, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": "Game update notes:\n\n1.Fixed the issue where using the Building Gun would cause some items to change color and the color effect couldn't be saved.\n2.Fixed the issue where items placed in a full backpack would fall into the sea.\n3.Fixed some issues with the Large Planting Pots, which can now only be used to plant trees.\n4.Fixed the issue where the ship could get stuck and unable to sail when approaching an island.\n5.Fixed the issue where items like the Ship Spear had a chance to be placed on the surface of the sea.\n6.Changed the mechanism for opening the Watch, it now only requires a light touch to open.\n7.The door of the Weather Station will no longer automatically close after being opened.\n8.Added explanations for the game modes.\n9.Added the Flashlight item, which can be crafted in the Synthesizer and is one of our favorite items.", "created_date": 1681173484, "id": "5638151719619650", "version": "1.5.03", "version_code": 29, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": "Fix some small bugs\nTurret battery disappears\nReading files will fall into the water\nLevel Difficulty of Gravity Island", "created_date": 1680147117, "id": "5604497769651712", "version": "1.5.02", "version_code": 28, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "484910946122783"}]}, "change_log": "We've just released a small update, version 15.0.1. This update addresses some issues, including a bug where the water kettle was saved as a cup, the garbage collector not properly collecting trash, and a few bugs with the pigs. We've also optimized the engine speed and building resources to make your journey across the ocean smoother and faster.", "created_date": 1680000368, "id": "5599739810127508", "version": "1.5.01", "version_code": 27, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}