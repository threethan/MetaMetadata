{"data": {"node": {"__typename": "Application", "id": "3649816788453163", "organization": {"id": "492632782066445", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "3649816788453163"}]}, "id": "171484531583309"}]}}, "firstRevision": {"nodes": [{"application": {"id": "3649816788453163", "release_date": 1657800000, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 4}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5638151719619650"}, "id": "484910946122783"}]}}, "binary": {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3649816788453163", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5638151719619650"}, "release_status": "RELEASED"}, "id": "8050928198341978", "version": "1.1.0", "version_code": 33, "release_status": "SCHEDULED", "status": "APPROVED"}, "live_binary": null, "created_date": 1727402845, "id": "7837433636358103", "is_initial_release": false, "name_with_fallback": "v8", "pdp_metadata_with_fallback": {"version": 6, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "7407450462689758"}, "release_status": "RELEASED", "id": "3649816788453163"}, "id": "7407450462689758", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "SCHEDULED", "release_type": "SCHEDULED", "pdp_metadata": null, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974905_2309129605907826_6900634917105921014_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFkSe7BEhWMQ7kNvgFFNom-&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCJfHNeVByN4-btwmeiTzX8vIFHY3YVl4dPP3__LRB_xw&