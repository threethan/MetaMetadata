/v/t64.5771-25/39031338_1265887500732406_1893603739605422374_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Sgrv2fJg2EQ7kNvgHBRjS0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFU77lEnPgB1JTPtigOzfEhbv6lICN9952kASHcIHgxg&oe=66DD98C6"}, {"file_name": "38974871_1206384936434541_9020809264252747724_n.png", "id": "1005499650478161", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974650_1005499653811494_1418916088510280529_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r1NT78AMjkUQ7kNvgFGTq5_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAXtYHtnLEgrBtDg3agA1f32M1GLPTSEtRzTc2kJwA4Zg&oe=66DDA0A1"}, {"file_name": "39001671_535979674537755_1795681502905896771_n.png", "id": "623647446573064", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974753_623647449906397_3671881883898077707_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o10_i0Si20sQ7kNvgHXu9sV&_nc_ht=scontent.oculuscdn.com&oh=00_AYCBgHoYtTvJ_ZiwjlpShEImH3TIb9Ml8x9ArfxoVo9yJw&oe=66DD793A"}, {"file_name": "38982500_1744360005915299_4679405036742276943_n.png", "id": "295492253160542", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210392_295492256493875_6265661070974573467_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J-YwsiAs0vYQ7kNvgENj5Ey&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdcLx0qqMqFyoM2qxeMjF-NmRrXnvtvlySEqHj1LunOg&oe=66DD9C17"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "57569423_1054771248755892_3702692832221211990_n.png", "id": "129256166877255", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_129256170210588_7978277858508373575_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dCAJ60mSCs4Q7kNvgGPfSnE&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0qy20KVowr81PxmRjofeEQOppls4T1ZCtT7gTBlU5rQ&oe=66DD9D91"}, "display_name": "Gardenia VR", "keywords": [], "long_description": "Gardenia is a FPP gardening simulator with elements of platformer, crafting, adventure, exploration and more!\n\nDiscover a beautiful place that is carefree and full of holiday peace. Find treasure and magic mushrooms that will give you access to the most interesting locations. Collect raw materials that you will use on the magic crafting table. Arrange the garden space at your discretion. Make friends with fancy inhabitants and find treasures!\n\nBut remember, your main goal will be to solve the mystery of who is behind the pollution that appears on the island.\n\nKey Features:\nAn atmosphere of relaxation on a distant paradise island\nArrange the space the way you want to create beautiful plant compositions\nA beautiful story to experience and a mystery to unravel\nA unique crafting system based on the Magic Crafting Table\nDexterity elements (magic mushrooms and their properties)", "short_description": "A laid-back combination of a gardening simulator and a fairy tale adventure. Help Wood Grandpa clean the island and restore its beauty so that its former inhabitants can return to their homes. Take photos of your garden compositions, relax and discover the secrets."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrfabric.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VRFabric S.A", "support_website_url": null, "website_url": "https://www.vrfabric.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pl", "es", "it", "ru", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "260993976732242"}}]}, "scheduled_offers": {"coun