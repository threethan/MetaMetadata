JbJqrVLMOhZKWKCVUZFZX-KS5tSYiPdWu-ow&oe=671F7A11"}, "display_name": "Fast Ape Frenzy", "keywords": [], "long_description": "Welcome to Fast Ape Frenzy! Experience the adrenaline-pumping Lava Rising Parkour, where you race against rising lava on shifting terrain, and dominate the Zero Gravity Arenas, mastering movement in anti-gravity zones. Compete with friends or players worldwide in thrilling challenges. And now, brace yourself for the brand-new Horror Mode! A spine-chilling experience filled with heart-pounding excitement, eerie surprises, and terrifying obstacles that will test your courage. Are you ready to face your fears?\n", "short_description": "Welcome to Fast Ape Frenzy! Race against rising lava in Lava Rising Parkour, master anti-gravity in Zero Gravity Arenas, and compete in thrilling global challenges. Now, face the terrifying new Horror Mode packed with eerie surprises and heart-pounding obstacles. Are you ready to conquer your fears?\n"}]}, "developer_name": "EEFX", "developer_privacy_policy_url": "https://sites.google.com/view/eefx/new-privicy-policy", "developer_terms_of_service_url": null, "publisher_name": "EEFX", "support_website_url": null, "website_url": "https://sites.google.com/view/eefx/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8075159032611272"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri"