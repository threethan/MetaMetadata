c_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1YsR3yHJ6-CZqK-wA-5jZ9wGcq4DJLhmdqNkXwndjig&oe=67483DF9"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Virus Hunters", "keywords": ["shooter", "\u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f", "arcade", "monster", "gamekiller"], "long_description": "\u0414\u043e\u0431\u0440\u043e \u043f\u043e\u0436\u0430\u043b\u043e\u0432\u0430\u0442\u044c \u0432 \u043c\u0438\u0440 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438! \u0412 \u0442\u0432\u043e\u0439 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d \u043f\u0440\u043e\u043d\u0438\u043a\u043b\u0438 \u0432\u0438\u0440\u0443\u0441\u044b \u0438 \u043f\u044b\u0442\u0430\u044e\u0442\u0441\u044f \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0438\u0442\u044c \u0432\u0441\u0435 \u0434\u0430\u043d\u043d\u044b\u0435, \u0441\u044a\u0435\u0441\u0442\u044c \u0442\u0432\u043e\u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b, SMS \u0438 \u0434\u0430\u0436\u0435 \u0447\u0430\u0441\u0442\u0438 \u0441\u0430\u043c\u043e\u0433\u043e \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430!\n\u0415\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0432\u044b\u0445\u043e\u0434 \u0441\u043f\u0430\u0441\u0442\u0438 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d \u2013 \u043f\u0440\u043e\u043d\u0438\u043a\u043d\u0443\u0442\u044c \u0432 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u043b\u0430\u0431\u0438\u0440\u0438\u043d\u0442 \u043c\u0438\u043a\u0440\u043e\u0441\u0445\u0435\u043c \u0442\u0432\u043e\u0435\u0433\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430 \u0438 \u0441\u0440\u0430\u0437\u0438\u0442\u044c\u0441\u044f \u0441 \u0432\u0438\u0440\u0443\u0441\u0430\u043c\u0438! \u041e\u0449\u0443\u0442\u0438 \u0441\u0435\u0431\u044f \u0441\u043d\u0430\u0439\u043f\u0435\u0440\u043e\u043c, \u043c\u043e\u043d\u0441\u0442\u0440\u044b \u043c\u043e\u0433\u0443\u0442 \u043f\u0440\u044f\u0442\u0430\u0442\u044c\u0441\u044f \u0432 \u043b\u044e\u0431\u043e\u043c \u0443\u0433\u043e\u043b\u043a\u0435 \u0442\u0432\u043e\u0435\u0433\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430, \u043d\u0430\u0439\u0434\u0438 \u0438\u0445 \u0432\u0441\u0435\u0445 \u0438 \u0441\u043a\u043e\u0440\u0435\u0435 \u0441\u0442\u0440\u0435\u043b\u044f\u0439!\n\u041e\u0445\u043e\u0442\u043d\u0438\u043a\u0438 \u043d\u0430 \u0432\u0438\u0440\u0443\u0441\u044b \u2013 \u044d\u0442\u043e \u0448\u0443\u0442\u0435\u0440 \u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438. \u041f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435 \u0441\u0435\u0431\u044f \u0447\u0430\u0441\u0442\u044c\u044e \u0434\u0440\u0443\u0433\u043e\u0439 \u0432\u0441\u0435\u043b\u0435\u043d\u043d\u043e\u0439!\n1.    \u0427\u0442\u043e\u0431\u044b \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435, \u0432\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u043e \u0432 \u043e\u0447\u043a\u0438 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438\n\n2.    \u041d\u0430\u0432\u0435\u0434\u0438\u0442\u0435 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u043a\u043d\u043e\u043f\u043a\u0443 \u00ab\u0421\u0442\u0430\u0440\u0442\u00bb \u0434\u043b\u044f \u043d\u0430\u0447\u0430\u043b\u0430 \u0438\u0433\u0440\u044b\n\n3.    \u041f\u0440\u0438\u0446\u0435\u043b\u0438\u0432\u0430\u0439\u0442\u0435\u0441\u044c \u0438 \u0441\u0442\u0440\u0435\u043b\u044f\u0442\u0435 \u043f\u043e \u043d\u0438\u043c \u0441 \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043d\u0430\u0436\u0430\u0442\u0438\u044f \u043d\u0430 \u0442\u0430\u0447\u043f\u0430\u043d\u0435\u043b\u044c", "short_description": "\u041f\u043e\u0433\u0440\u0443\u0437\u0438\u0441\u044c \u0432 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u043c\u0438\u0440 \u043f\u0440\u0438\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0439! \u0412 \u0442\u0432\u043e\u0439 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d \u043f\u0440\u043e\u043d\u0438\u043a\u043b\u0438 \u0432\u0438\u0440\u0443\u0441\u044b \u0438 \u043f\u044b\u0442\u0430\u044e\u0442\u0441\u044f \u0443\u043d\u0438\u0447\u0442\u043e\u0436\u0438\u0442\u044c \u0432\u0441\u0435 \u0434\u0430\u043d\u043d\u044b\u0435, \u0441\u044a\u0435\u0441\u0442\u044c \u0442\u0432\u043e\u0438 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b, SMS \u0438 \u0434\u0430\u0436\u0435 \u0447\u0430\u0441\u0442\u0438 \u0441\u0430\u043c\u043e\u0433\u043e \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430.\n\u0415\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0432\u044b\u0445\u043e\u0434 \u0441\u043f\u0430\u0441\u0442\u0438 \u0441\u043c\u0430\u0440\u0442\u0444\u043e\u043d \u2013 \u043f\u0440\u043e\u043d\u0438\u043a\u043d\u0443\u0442\u044c \u0432 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u043b\u0430\u0431\u0438\u0440\u0438\u043d\u0442 \u043c\u0438\u043a\u0440\u043e\u0441\u0445\u0435\u043c \u0442\u0432\u043e\u0435\u0433\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430 \u0438 \u0441\u0440\u0430\u0437\u0438\u0442\u044c\u0441\u044f \u0441 \u0432\u0438\u0440\u0443\u0441\u0430\u043c\u0438! \u041e\u0449\u0443\u0442\u0438 \u0441\u0435\u0431\u044f \u0441\u043d\u0430\u0439\u043f\u0435\u0440\u043e\u043c, \u043c\u043e\u043d\u0441\u0442\u0440\u044b \u043c\u043e\u0433\u0443\u0442 \u043f\u0440\u044f\u0442\u0430\u0442\u044c\u0441\u044f \u0432 \u043b\u044e\u0431\u043e\u043c \u0443\u0433\u043e\u043b\u043a\u0435 \u0442\u0432\u043e\u0435\u0433\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430, \u043d\u0430\u0439\u0434\u0438 \u0438\u0445 \u0432\u0441\u0435\u0445 \u0438 \u0441\u043a\u043e\u0440\u0435\u0435 \u0441\u0442\u0440\u0435\u043b\u044f\u0439!\n\u041e\u0445\u043e\u0442\u043d\u0438\u043a\u0438 \u043d\u0430 \u0432\u0438\u0440\u0443\u0441\u044b \u2013 \u044d\u0442\u043e \u0448\u0443\u0442\u0435\u0440 \u0432 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u0438."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.kaspersky.ru/privacy", "developer_terms_of_service_url": "https://box.kaspersky.com/f/45e0559a0c/?dl=1", "publisher_name": "Kaspersky Lab", "support_website_url": null, "website_url": "http://www.kaspersky.ru/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ru"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4811534235607340"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162727_159337071300258_7057857626519896064_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OX1c9s8cS1kQ7kNvgF_ScUu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB65n-fKBmdUCLNumIVYL89gYoBqEbOt8TBln305RV-Mg&oe=67484C94"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Virus Hunters", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1502295872, "lastRevision": {"nodes": [{"id": "253939371681205", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1311094275670998", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platfo