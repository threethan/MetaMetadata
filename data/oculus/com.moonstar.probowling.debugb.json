8046856323557_936814310806023400_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fpUAQ5qq3eAQ7kNvgEKMPpx&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAo3Z76XpjgfaVtJ7dP1U7mFB2Tqlv_jqiL2t6XAqQspg&oe=67163956"}, {"file_name": "PBS_screen_05.png", "id": "849228486441144", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982466_849228489774477_1664850757641330586_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KItRv-swrNkQ7kNvgHfs8_E&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCFbzcCYty3evhKFcOeFSV-cI3NCTX53ABKmhA8xaoKww&oe=6716489F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer.png", "id": "2764813460329851", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39001656_2764813463663184_5629484777239942721_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lptI0AQbOQwQ7kNvgGbCIIQ&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCjK8xkuT471xChBBoSyFaAYsbgSsz6F79eZT0ee429NA&oe=6716550E"}, "display_name": "Pro Bowling Social", "keywords": [], "long_description": "Bowling is a fun sports game but you need to go to a club since it requires a large space to play. With Pro Bowling Social, you can play bowling in the comfort of your home. \nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": null, "developer_privacy_policy_url": "https: