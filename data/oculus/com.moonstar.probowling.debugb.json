n bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": null, "developer_privacy_policy_url": "https://probowlingsocial.com/privacy.html", "developer_terms_of_service_url": "https://probowlingsocial.com/terms.html", "publisher_name": "Moonstar Games", "support_website_url": "http://www.moonstargames.com/", "website_url": "https://www.probowlingsocial.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "477185303971835"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "762834101465588"}, {"status": "PUBLISHED", "id": "500187308661396"}]}, "baseline_offer": {"id": "500187308661396"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1663021680, "status": "PUBLISHED", "id": "762834101465588"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4864261987006820", "version": "1.0.0.6.12"}, "id": "603234731410122", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4838616066238079", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4864261987