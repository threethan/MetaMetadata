=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAjr85SwIg8a5FVnraVtMXZwMpC6aR8W0z9vko4Q1GQcw&oe=672DF456"}, {"file_name": "PBS_screen_05.png", "id": "849228486441144", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_849228489774477_1664850757641330586_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VvSTh6Nb00gQ7kNvgHPZLFN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhtutsh6363bDZ3C2qvIQzSiXfI-wmnPupg8soSX1A7Q&oe=672E039F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape2.png", "id": "5611790352244147", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031393_5611790368910812_4809372919932531516_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UmxvmNJlbaQQ7kNvgFRzF6o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYJWy9H5Uwe6S8u8047uzXyMn7RdEO0wHekq0MEdpfHg&oe=672DFB13"}, "display_name": "Pro Bowling Social", "keywords": [], "long_description": "Bowling is a fun sports game but you need to go to a club since it requires a large space to play. With Pro Bowling Social, you can play bowling in the comfort of your home. \nPro Bowling Social is also available for Meta GO.\nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them. Pro Bowling Social is also available for Meta GO."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.moo