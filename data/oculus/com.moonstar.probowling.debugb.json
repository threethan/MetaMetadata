sOVyhw&oe=67714846"}, {"file_name": "PBS_screen_04.png", "id": "1508046849656891", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001667_1508046856323557_936814310806023400_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=elpIAdz6iIYQ7kNvgEmqGvX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqeVrg6-ACxOp4bdccJQvl5j8hL25i3LJiIck5fav5SA&oe=677130D6"}, {"file_name": "PBS_screen_05.png", "id": "849228486441144", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_849228489774477_1664850757641330586_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9jJHE7FZ1kIQ7kNvgGzoJqO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYln_NaWodbxRB_DS7zEPAyzmuhgGIMGq02w0qX-bM8w&oe=6771401F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer.png", "id": "2764813460329851", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001656_2764813463663184_5629484777239942721_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OxlpSVCCtyYQ7kNvgFd7HjA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSqVEAXDHZyH9G6ckaEIzwp7l8sahTbrxq9aqsTZ34RQ&oe=67714C8E"}, "display_name": "Pro Bowling Social", "keywords": [], "long_description": "Bowling is a fun sports game but you need to go to a club since it requires a large space to play. With Pro Bowling Social, you can play bowling in the comfort of your home. \nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them."}]}, "developer_name": null, "developer_privacy_policy_url": "https://probowlingsocial.com/privacy.html", "developer_terms_of_service_url": "https://probowlingsocial.com/terms.html", "publisher_name": "Moonstar Games", "support_website_url": "http://www.moonstargames.com/", "website_url": "https://www.probowlingsocial.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "477185303971835"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "762834101465588"}, {"status": "PUBLISHED", "id": "500187308661396"}]}, "baseline_offer": {"id": "500187308661396"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1663021680, "status": "PUBLISHED", "id": "762834101465588"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4864261987006820", "version": "1.0.0.6.12"}, "id": "603234731410122", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4838616066238079", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "486426198700