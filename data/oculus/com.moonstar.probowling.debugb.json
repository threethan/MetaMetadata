806023400_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VnbTrMqdgS8Q7kNvgHOMeDN&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9OYklHnaVi3wJxlz43Zd1O&oh=00_AYASDZ1wGI_Nyf0EPiZv5sb4YBaE5Cye3L3G88FFDrJ3kw&oe=66E42056"}, {"file_name": "PBS_screen_05.png", "id": "849228486441144", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982466_849228489774477_1664850757641330586_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-lsi0OlH7TkQ7kNvgG_vcQ1&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9OYklHnaVi3wJxlz43Zd1O&oh=00_AYBHkVb_zcobkjBKvGessCRpMCSp_000C1FVSs5U691eBg&oe=66E42F9F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape2.png", "id": "5611790352244147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031393_5611790368910812_4809372919932531516_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=36FASP467B0Q7kNvgFR1m7l&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9OYklHnaVi3wJxlz43Zd1O&oh=00_AYAA7SMiFWQChn5YCb_hvECPEBhg1U6re8mob26kH3BVrg&oe=66E42713"}, "display_name": "Pro Bowling Social", "keywords": [], "long_description": "Bowling is a fun sports game but you need to go to a club since it requires a large space to play. With Pro Bowling Social, you can play bowling in the comfort of your home. \nPro Bowling Social is also available for Meta GO.\nThe goal of ten-pin bowling is is to knock over all ten pins at the end of a lane, with two balls per frame allowed to knock down all pins. A strike is achieved when all the pins are knocked down on the first roll, and a spare is achieved if all the pins are knocked over on a second roll.\nStrike is 30 points regardless of ensuing rolls' results. Spare is 10 points, plus pinfall on first roll of the current frame. Game lasts for 10 frames and maximum score a player can get is 300 with 10 strikes. This scoring system is called World Bowling Scoring.", "short_description": "Pro Bowling Social is a multiplayer, ten-pin bowling game. You can compete with players around the world and voice chat with them. Pro Bowling Social is also available for Meta GO."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.moonstargames.com/bowling_privacy.html", "developer_terms_of_service_url": "http://www.moonstargames.com/bowling_terms.html", "publisher_name": "Moonstar Games", "support_website_url": "http://www.moonstargames.com/", "website_url": "https://www.moonstargames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "6830816583684674"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57570295_669633954798127_7171720418909545425_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NV8LpkHhNrgQ7kNvgEfgmeO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9OYklHnaVi3wJxlz43Zd1O&oh=00_AYBGczxqPWgglcbar2Nnd1qsE1OgysLuZE9RDqkPBeyPpw&oe=66E43353"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pro Bowling Social", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1663021680, "lastRevision": {"nodes": [{"id": "4838616152904737", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4838616066238079", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform":