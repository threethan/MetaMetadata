69428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a5TXL0JFcTQQ7kNvgGwceP7&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAXyAcTudLjTYMOQWUZiNhI-lBU5Bb7vsF0cHwZ7WEtwg&oe=675EB650"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lnoCa-s7yWMQ7kNvgEqUg5Q&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDvHlEGvL386j9LO7tlYojUB3D7TjpxD-fNnl1QaQ5BIw&oe=675EB184"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYKJYMUenYcQ7kNvgH8U3d8&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCnwEvoYHk1PvT6vAhsKgtrMeifX1uavLdxp9qAl17oYA&oe=675EA662"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z08xGJVkPBYQ7kNvgGf_1QW&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYB6YpSyTkzuTXae-0h9BddotAN7KtfDBj7B5Xa-cu2Sig&oe=675EC235"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the priva