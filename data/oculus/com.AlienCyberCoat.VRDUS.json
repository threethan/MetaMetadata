57569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YAMGjiOAwPQQ7kNvgEj_cBP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJkmuD3155jiPXnFIOfdRn8&oh=00_AYC2BO7oBeztLEKYRkxVeuKv9bAQvMvcgKhlG6PTwly6dg&oe=66ED5550"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jdFBeLiL824Q7kNvgEmMlod&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJkmuD3155jiPXnFIOfdRn8&oh=00_AYA956oBMS-XBAF1bRSlXh9lAeMMIrlWLZGLqzaXFDEesQ&oe=66ED5084"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fk_SzNCvbAIQ7kNvgGUH9ZE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJkmuD3155jiPXnFIOfdRn8&oh=00_AYATWZ79BZ7Q8cjRXmghg2drhzPzZ4QK8NaIpWCrJprukg&oe=66ED4562"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rauknBoSEk0Q7kNvgGwrR_b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJkmuD3155jiPXnFIOfdRn8&oh=00_AYAopb_Au39W_YPQ-FPkivx41L8QdB0dxIIVnuDrzzSU_w&oe=66ED6135"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum k