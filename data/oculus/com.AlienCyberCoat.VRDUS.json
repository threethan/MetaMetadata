sid=6e7a0a&_nc_ohc=fCtxMuCLqfMQ7kNvgGJsvi7&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlIMuu6T3SrhvJfaEb4pKqchTjg8UmrdQsSB1f1ZBkkg&oe=670CF484"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DY9UPnrt7mUQ7kNvgHJKwoO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCg-nIO2Ncc3tGx8f14KoaZZ0eC4lPt9-ey2pbpHXd74Q&oe=670CE962"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jSvyEcKwsL0Q7kNvgFrj-7k&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAs6pPnm29byheWYduSXiaRxb7HZKgkEDzXlGqi8oq7Vw&oe=670D0535"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the privacy of VR, play and mod your own realistic looking drum set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "27433260359255