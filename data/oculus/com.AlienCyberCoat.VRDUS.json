1_UCnT7wwDhd0UGA&oe=671633D0"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Z-K3ZuG6lUQ7kNvgFcZq7k&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCJbayzcfh37FoIPK5p54N-qNvNGhuVH9BtzuZaqcW6_w&oe=67162F04"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c2KKfpjiK5oQ7kNvgHQoJz5&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYB9urAH1g4sWRqH-8WlypZgoOCSyq8FSfpy4QH23Zm5QQ&oe=671623E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aVFi9cXKop0Q7kNvgFNvgOQ&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBnNjIXtXXz7fINLBpN5suMPsKmDA7b0xSxeCsjZ71RLg&oe=67163FB5"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the privacy of VR, play and mod your own realistic looking drum set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url":