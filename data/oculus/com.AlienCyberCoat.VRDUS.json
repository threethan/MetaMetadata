569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZQ1SkQHyYxMQ7kNvgH28lpN&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCJE3y5lV_0sFHlTrTGJ5wLiOcG6DFDR8lfChWBMg0uyQ&oe=67518750"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7kGNpZcK5CIQ7kNvgHIKDSl&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCSO9bjf83chAMvIMRG_RPxXrwAFdNqf8jaxf6gFdEy9g&oe=67518284"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qMvhUdwMC7kQ7kNvgFjHsdM&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAmTNNdEc7nL6Qzv59hYNvW0p1zLKpOvlYHbm8Ubd9GpA&oe=6751AFA2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yuAeAz60si0Q7kNvgHInAur&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAaFL-4G95CqUWAky2LvVbKkgqMWG6T0fOJEk9urT6jlA&oe=67519335"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the priv