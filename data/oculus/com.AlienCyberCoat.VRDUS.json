71-25/57569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E1t4gJA4dTgQ7kNvgEw5_3t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYCEYnCsZalNeWTRIwRuLVxpngIqTXzJLakLbZgcVPKpkg&oe=66E02650"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5h0Iu4-JWisQ7kNvgGZEOMc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYC973GnS0XJyCcN6LI_uFEQ7B0Mz9V-XQzbvD8xlEXOfQ&oe=66E02184"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l2jRJ2pupNkQ7kNvgEQjLkn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYAoec6sEWLqDMJF5VHuGFPr4Ulob1LZCRyjDTZRbOkAJw&oe=66E01662"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FR5yxt0N0wQQ7kNvgGKZcV7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYDoEqHoju6XZIfuA5oYOfP-aTMY3E3L41Tw-V0UTFMCPA&oe=66E03235"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR 