39003257_495038763045987_4867298960515823153_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pSbnTy0icEYQ7kNvgHLOEJl&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDAttA6LSmfmXMI3yt4gdSilx9quoSCigWqJ-6lWPXlww&oe=674054F6"}]}, "id": "1490050118567894", "locale": "en_US", "screenshots": [{"file_name": "questscreen1.png", "id": "2083704262043517", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974460_2083704265376850_5284516510319531605_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8P7NbfgyPT8Q7kNvgE3JQnr&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDInUAy5OAj78aS2kaLo32q_PI6lOLPni_D3pZHXw6F5A&oe=6740604E"}, {"file_name": "s2.png", "id": "407378231670034", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982441_407378235003367_5843710557005180397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8NZbJQ02rdUQ7kNvgFsKbkw&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAkHIpKMLbzBdtK_mw8lDiSWokwijQKGRfo_na-2P_IAA&oe=674074AB"}, {"file_name": "questscreen4.png", "id": "1223405765599341", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031383_1223405768932674_572751514927265543_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZzxSflIHAUQ7kNvgHL-ciH&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBtflsnyyjOk6p5EKyoOPYQNJmziXqUZKkOlrOAj5ukhw&oe=67406C26"}, {"file_name": "questscreen2.png", "id": "540028365590749", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/86669354_540028372257415_1274998599367666162_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D1A7nrRwNVYQ7kNvgEXjmTF&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDZv9_OFuafVwRwYtaMYvQ4ffAnOTvZ4kNPK298lHG8-g&oe=674063D3"}, {"file_name": "meta222.png", "id": "746671854102950", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57568677_746671857436283_359019516506841873_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YLWZNE_NOLgQ7kNvgHY6A6I&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCpq0LM9gWbU86TxtNYwL272GqGlDJTONxPwKHhzp0wKQ&oe=67408B37"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "meta2.png", "id": "1191734111867428", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036695_1191734115200761_5872942496386580375_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oB-mu9r2Y34Q7kNvgFQRg54&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBVKuqov_EutzFPALSFAyW_QWQC6LOLxusLmFQXSmcGzw&oe=67405566"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "Realistic like freestyle VR drumkit simulator and mini rhythm game. No space for a real drumkit? Own one in VR. Play the drums anytime anywhere. Practice or play your audio files (.Mp3 .Wav .Ogg) and load them up in-game.\n\nPosition your drums, cymbals, pads wherever you like. Modify each drum sound by using the different drum heads, cymbals, and hi-hats.\n\nThe Note highway accepts (.chart) files such as Clone Hero drum charts. These files must added by you and are not included. \n\nTenor drum harness and tenor drums included. (Marching band drums)\n\nFeatures:\n- Save and load your kit\n- Pressure sensitive strikes\n- Bass and hi-hat foot pedals (VR buttons)\n- Bass and hi-hat foot pedals (USB/Bluetooth Pedal/Gamepads)\n- Multiple locations\n- Change the sounds and look\n\nVR Drum Hardware Included:\n9+ snare drums, 5+ bass drums, also an amped bass drum, 5+ crash cymbals, 1 ride cymbal, 3 splash cymbals, tom drums 6\", 8\", 10\", 12\", 14\". A roto tom rack 6\", 8\", 10\" roto toms, 5 different hi-hats (rock, 50's, metal trash etc), china cymbals, dry ride/crash, custom china stack, mounted tambourine, cow bells, steelpan drum, xylophone and more.\n\nInclude Test:\n- Liv.tv", "short_description": "A realistic like freestyle VR drumkit simulator and mini rhythm game.\n\nPosition your drum kit hardware. Modify each drum sound by using different drum heads, cymbals, hi-hats etc. Add your own custom songs or beat maps to play on the Note Highway.\n\nUse the in-game file browser and music player (.Mp3 .Wav .Ogg) to cover songs."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26123450683967919"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031517_972409864428624_375254253918777929_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RGId68XWBy4Q7kNvgG1ZK7_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAxm-CsPBVcVY-0w_EBcNch7_UWdmNXezdIS0T_3ta66w&oe=674060F4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Drums Ultimate Streamer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1706725464, "lastRevision": {"nodes": [{"id": "24141290328850641", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "24141290282183979", "is_first_party": false, "enables_in_app_ads": false, "is_concept": fa