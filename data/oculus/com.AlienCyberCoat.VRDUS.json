zk4g2U3xDNXRvBfA&oe=671A2850"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iaF_GS2K6WMQ7kNvgGb2AgX&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYC02DTfWmYxUxLOwzuyjoEXxiZePslL-QrKn9KptddOSg&oe=671A2384"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a9VajNj9c_gQ7kNvgFgz4IK&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCnp3FXvP2j5HHXWJbg4iSFWF3aH6Kr7pW1xljHJGi7AA&oe=671A1862"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P9junJjR65kQ7kNvgGRnBuy&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDzHReMUosDRXHfJEgUUpUp7h_BDZv-ApeARFyFPK8_3g&oe=671A3435"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the privacy of VR, play and mod your own realistic looking drum set."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url":