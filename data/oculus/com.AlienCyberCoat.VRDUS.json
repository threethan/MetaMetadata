57569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e7C58lpivR8Q7kNvgHqtm5c&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aza1RLN8SOnRYraUp8KjVis&oh=00_AYA4KJXidO9dpimnX7-0GCma4tMjKSYCNKYzfmibTUL7Ow&oe=66F3ECD0"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kP1IfiWQCEYQ7kNvgFEj2FD&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aza1RLN8SOnRYraUp8KjVis&oh=00_AYA6pa_AQGnTGeL4Ay45sB73xeEgXSR3HDKPXhof5u1sWA&oe=66F3E804"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IHwUWGFpZf8Q7kNvgGSbrHd&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aza1RLN8SOnRYraUp8KjVis&oh=00_AYCSGl_8GarYKXS-olRsTgA6gbYWdlJQXezAk83ZIqildg&oe=66F3DCE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YmbH-fKxiDAQ7kNvgFQBj5e&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aza1RLN8SOnRYraUp8KjVis&oh=00_AYBQ-1qpWIWrAcySLTSN-lpAWy629tuVNCJgP1PxQmtX_g&oe=66F3F8B5"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum k