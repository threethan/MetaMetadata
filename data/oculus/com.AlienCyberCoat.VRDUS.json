"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003257_495038763045987_4867298960515823153_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=phziS3Mq-NoQ7kNvgGgS639&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYDHAfU27g0QtgeZwWRrngzRWimaqv8LJJOPSoCya2QeqQ&oe=66E01776"}]}, "id": "1674708130026425", "locale": "en_US", "screenshots": [{"file_name": "meta222.png", "id": "746671854102950", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568677_746671857436283_359019516506841873_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3r0qEHVinD0Q7kNvgGNKgQq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYCdolAPBUI3pQbZLlPVp4bjkoHkNR1OkfdbezmasrwFSQ&oe=66E01577"}, {"file_name": "s2.png", "id": "407378231670034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_407378235003367_5843710557005180397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aoT4Bq5j8jMQ7kNvgHY5YHf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYAfDkeliEeYPQDmohoxEXYHtB635fKEODPX4Lln058vcQ&oe=66E0372B"}, {"file_name": "meta666.png", "id": "2689205241246204", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974895_2689205244579537_4557241657444279032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ou1BvYos7mgQ7kNvgFRW4lQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYCKbpe57cZnEuvJCnQDxd0y-D3gMpduPoB3zCjoyEECmg&oe=66E03B4D"}, {"file_name": "quest5.png", "id": "258372300602516", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_258372307269182_2994196070795906295_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wVO-ZLjICpAQ7kNvgFbdBJX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYAZTs--RFqwrV18TmRltltl5CjINC4XZwTYWB9flGEnEQ&oe=66E02A53"}, {"file_name": "meta444.png", "id": "1174210640368452", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031416_1174210647035118_2127096637090478004_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5c4BySafNjMQ7kNvgE00pJg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYAOhttNmfP6twDSAgBDJPWCJ04gAyrxWEO7yrWPE8WbzA&oe=66E0285C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "meta2.png", "id": "1191734111867428", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036695_1191734115200761_5872942496386580375_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q8l67XYNYCcQ7kNvgHiGTyl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYCQuxO_-OJ3qzxYdWuD09O9-LWefWmdzLG5UJeTPhXumw&oe=66E017E6"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "Customizable freestyle VR drum simulator. Note highway rhythm games 2D/3D included. Must add your own custom songs or beat maps for the highways. Freestyle practice or play your MP3's in-game and make a drum cover like a real kit.\n\nIn-game Quest file browser .MP3/.OGG/.WAV audio player.\n\nPosition your drums, cymbals, and electronic drum pads where you like. Modify each drum sound by using different drum heads, cymbals, hi-hats.\n\nTenor drum harness and tenor drums included. (Marching band drums)\n\nQuick Features:\n- Save and load your kit\n- Pressure sensitive strikes\n- Bass and hi-hat foot pedals (VR buttons)\n- Bass and hi-hat foot pedals (USB/Bluetooth Pedal/Gamepad)\n- Multiple locations\n- Change sounds and look of kit\n- Tenor drums\n- Xylophone\n\nVR Drum Hardware Included:\n8 snare drums, 5 bass drums, also an amped bass drum, 5 crash cymbals, 2 ride cymbals, 3 splash cymbals, tom drums 6\", 8\", 10\", 12\", 14\". A roto tom rack 6\", 8\", 10\" roto toms, 4 different hi-hats (rock, 50's, metal trash etc), china cymbals, dry ride/crash, custom china stack, mounted tambourine, cow bells, steelpan drum, xylophone and more.\n\nTest Include:\n- Liv.tv\n\nDetail: \nThe note highway supports .chart drum charts with music. Custom music and drum charts (.chart files and song folders) that must be added yourself.", "short_description": "Customizable freestyle VR drum simulator and rhythm games.\n\nMust add your own custom songs or beat maps to play on the note highways. Position your drum kit hardware. Modify each drum sound by using different drum heads, cymbals, hi-hats etc.\n\nIn-game Quest file browser and music player .MP3/.OGG/.WAV\n\nTest Included:\n- Liv.tv"}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26006641622315493"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_972409864428624_375254253918777929_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=glV6scyvMQEQ7kNvgG74PUh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AjjdaBrStwzTkXHxhP7f9rd&oh=00_AYAoInbUJlRnV-68OMFkqdI_ibnwb0rXh9m8NlQdrdY_Qw&oe=66E02374"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Drums Ultimate Streamer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}], "release_date": 1706725464, "lastRevision": {"nodes": 