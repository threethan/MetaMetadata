57569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8KdHBShyh40Q7kNvgH6ZST4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AESauEBAl-TejVOGX3tPJ2g&oh=00_AYDDeYm0dkw5cM1byqqdnTF-mIeVi4HuliGyKnFV7NbTdg&oe=66EAB250"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I54UtXvJHeUQ7kNvgFCWdFz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AESauEBAl-TejVOGX3tPJ2g&oh=00_AYAkxl0ykhsDvrMljmK9Z0Zshl-m4zP8WPh5cXfqQcHHBw&oe=66EAAD84"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fk_SzNCvbAIQ7kNvgHZfpNl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AESauEBAl-TejVOGX3tPJ2g&oh=00_AYCsJhsdfPW4LeDxx-yBtdp4KhLZYRKIOEeQLuXNn8Y4Vw&oe=66EAA262"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9L7mvdYHsn8Q7kNvgFg_p_k&_nc_ht=scontent.oculuscdn.com&_nc_gid=AESauEBAl-TejVOGX3tPJ2g&oh=00_AYBEDFQY4JLZk4J_MFbgadskf2naQF1rwV6yMNv-Yb1ANA&oe=66EABE35"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum k