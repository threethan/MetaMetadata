57569428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e7C58lpivR8Q7kNvgFuvSiJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_xov6TUlRr3r7CrBh6XoI&oh=00_AYCA2x8PSDK6saexNJUJvALHs9I1I9PLg4BYdSS0NV4d6w&oe=66F68FD0"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EtlKdgFeKikQ7kNvgG6RBt0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_xov6TUlRr3r7CrBh6XoI&oh=00_AYDsxsAEe8A8l9_kvCcI05BFuUysW9Vr_BAS8VOqFgVAZA&oe=66F68B04"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kUVG7iU8r4YQ7kNvgGaZTeh&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_xov6TUlRr3r7CrBh6XoI&oh=00_AYBoPuN8ofVIsllh6P7djbL5zMdSD982BdnmJqXcIP_VNw&oe=66F67FE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YmbH-fKxiDAQ7kNvgFz47W0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ah_xov6TUlRr3r7CrBh6XoI&oh=00_AYBqaj0Z-IyLUrnxTwgXTQ5km_xIvTYBLmiTZZNRiU-r9A&oe=66F69BB5"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum k