39003257_495038763045987_4867298960515823153_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9bkRVlQxEYkQ7kNvgE8WH0R&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvdtjlw9F3XLBLJxp4SERoNWAjByx0kHomNUrYjtl2kw&oe=67371A76"}]}, "id": "1490050118567894", "locale": "en_US", "screenshots": [{"file_name": "questscreen1.png", "id": "2083704262043517", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974460_2083704265376850_5284516510319531605_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RM7GvKeXpHEQ7kNvgGfso46&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyrGO0pF5vwg86SHDWvYmrWKTqWQm-JD8FeRSzaU2o7w&oe=673725CE"}, {"file_name": "s2.png", "id": "407378231670034", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982441_407378235003367_5843710557005180397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YNL9QepCHOkQ7kNvgHlnjB6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAo7_1-Eo8DXHbnSMv09-JALuHA89_FfQRIOdtqAnYkjg&oe=67373A2B"}, {"file_name": "questscreen4.png", "id": "1223405765599341", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031383_1223405768932674_572751514927265543_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JdNfDsUX9ywQ7kNvgFR1_7H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWXdFz2XzkUaPvic77rNpkEdRvUnTK-NIBC9Uh8HdYoA&oe=673731A6"}, {"file_name": "questscreen2.png", "id": "540028365590749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86669354_540028372257415_1274998599367666162_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aCsI83NVnq0Q7kNvgHqNRuI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdR-WTGlA3tBrIKvMex1f3YolgjRZ2gZyLskMKTyCC2w&oe=67372953"}, {"file_name": "meta222.png", "id": "746671854102950", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568677_746671857436283_359019516506841873_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-iG0ONMKuTgQ7kNvgHA8c1Z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSUXr8IhvqjV2SIpzmRcKkHH1_vf4H5JJHR-YVPTJZLw&oe=67371877"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "meta2.png", "id": "1191734111867428", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036695_1191734115200761_5872942496386580375_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eeKdrXGasyAQ7kNvgEkuYqm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYASDaUJ5mNsfnqbWlAJXOI4wpWK4Ki-9Kqx07gDjThiDg&oe=67371AE6"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "Realistic like freestyle VR drumkit simulator and mini rhythm game. No space for a real drumkit? Own one in VR. Play the drums anytime anywhere. Practice or play your audio files (.Mp3 .Wav .Ogg) and load them up in-game.\n\nPosition your drums, cymbals, pads wherever you like. Modify each drum sound by using the different drum heads, cymbals, and hi-hats.\n\nThe Note highway accepts (.chart) files such as Clone Hero drum charts. These files must added by you and are not included. \n\nTenor drum harness and tenor drums included. (Marching band drums)\n\nFeatures:\n- Save and load your kit\n- Pressure sensitive strikes\n- Bass and hi-hat foot pedals (VR buttons)\n- Bass and hi-hat foot pedals (USB/Bluetooth Pedal/Gamepads)\n- Multiple locations\n- Change the sounds and look\n\nVR Drum Hardware Included:\n9+ snare drums, 5+ bass drums, also an amped bass drum, 5+ crash cymbals, 1 ride cymbal, 3 splash cymbals, tom drums 6\", 8\", 10\", 12\", 14\". A roto tom rack 6\", 8\", 10\" roto toms, 5 different hi-hats (rock, 50's, metal trash etc), china cymbals, dry ride/crash, custom china stack, mounted tambourine, cow bells, steelpan drum, xylophone and more.\n\nInclude Test:\n- Liv.tv", "short_description": "A realistic like freestyle VR drumkit simulator and mini rhythm game.\n\nPosition your drum kit hardware. Modify each drum sound by using different drum heads, cymbals, hi-hats etc. Add your own custom songs or beat maps to play on the Note Highway.\n\nUse the in-game file browser and music player (.Mp3 .Wav .Ogg) to cover songs."}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26123450683967919"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031517_972409864428624_375254253918777929_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JvdeW8A3UKsQ7kNvgHk_Lpg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfEwnU3JzPVUtSSXB7_4Y7SFau9ZN1nNtqU1p0E-09-A&oe=67372674"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Drums Ultimate Streamer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1706725464, "lastRevision": {"nodes": [{"id": "24141290328850641", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "24141290282183979", "is_first_party": false, "enables_in_app_ads": false, "is_concept": fa