/39003257_495038763045987_4867298960515823153_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uqHwnNTMDtoQ7kNvgGGHebS&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDYRBV1i4pJwKmDYIJA8nkuC4VJBHeamR5hkWP-pP7Ztg&oe=672899F6"}]}, "id": "1674708130026425", "locale": "en_US", "screenshots": [{"file_name": "meta222.png", "id": "746671854102950", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/57568677_746671857436283_359019516506841873_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4_1bhi-A-sQ7kNvgEZdbEC&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAgPX19rEmX1Kvb9nFFAp_eWmvs-B1pK0vlvAQwMSmmnQ&oe=672897F7"}, {"file_name": "s2.png", "id": "407378231670034", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982441_407378235003367_5843710557005180397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rOmo5MtcE-gQ7kNvgHbotVM&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDHTe7wb7nnB9a6A2_I7Np63aG-DIjPFZeB8iXTbn52GA&oe=6728B9AB"}, {"file_name": "meta666.png", "id": "2689205241246204", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974895_2689205244579537_4557241657444279032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=teXN3u4wW3AQ7kNvgFYIyq9&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYA8Ov3A5e4kYntktMjYNpVI_NryPqFHtNjWV6MqoAiZvg&oe=6728BDCD"}, {"file_name": "quest5.png", "id": "258372300602516", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982721_258372307269182_2994196070795906295_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYDVe0eFf0oQ7kNvgGif6JO&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBXxSWf8y1Acq9F-jg9RFo8jfll67VBQ-JiYep90YhBbA&oe=6728ACD3"}, {"file_name": "meta444.png", "id": "1174210640368452", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031416_1174210647035118_2127096637090478004_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=om04N0ZBnsgQ7kNvgHy1a6n&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYDa2LymVDB7ODpMmbyiYUs0i54LsAwkbU6VGwt1JhBITQ&oe=6728AADC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "meta2.png", "id": "1191734111867428", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39036695_1191734115200761_5872942496386580375_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpcbZn6VofYQ7kNvgGpQsUt&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAKF8e-pKNrFWOBrlfhr6b7X3rOClmFmBvzVCiHOO1ySA&oe=67289A66"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "Customizable freestyle VR drum simulator. Note highway rhythm games 2D/3D included. Must add your own custom songs or beat maps for the highways. Freestyle practice or play your MP3's in-game and make a drum cover like a real kit.\n\nIn-game Quest file browser .MP3/.OGG/.WAV audio player.\n\nPosition your drums, cymbals, and electronic drum pads where you like. Modify each drum sound by using different drum heads, cymbals, hi-hats.\n\nTenor drum harness and tenor drums included. (Marching band drums)\n\nQuick Features:\n- Save and load your kit\n- Pressure sensitive strikes\n- Bass and hi-hat foot pedals (VR buttons)\n- Bass and hi-hat foot pedals (USB/Bluetooth Pedal/Gamepad)\n- Multiple locations\n- Change sounds and look of kit\n- Tenor drums\n- Xylophone\n\nVR Drum Hardware Included:\n8 snare drums, 5 bass drums, also an amped bass drum, 5 crash cymbals, 2 ride cymbals, 3 splash cymbals, tom drums 6\", 8\", 10\", 12\", 14\". A roto tom rack 6\", 8\", 10\" roto toms, 4 different hi-hats (rock, 50's, metal trash etc), china cymbals, dry ride/crash, custom china stack, mounted tambourine, cow bells, steelpan drum, xylophone and more.\n\nTest Include:\n- Liv.tv\n\nDetail: \nThe note highway supports .chart drum charts with music. Custom music and drum charts (.chart files and song folders) that must be added yourself.", "short_description": "Customizable freestyle VR drum simulator and rhythm games.\n\nMust add your own custom songs or beat maps to play on the note highways. Position your drum kit hardware. Modify each drum sound by using different drum heads, cymbals, hi-hats etc.\n\nIn-game Quest file browser and music player .MP3/.OGG/.WAV\n\nTest Included:\n- Liv.tv"}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26006641622315493"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031517_972409864428624_375254253918777929_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B-8PkYzplA4Q7kNvgGuX9OI&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCLU7v2CN60rUclKzKAFd_44JZOLi8aCrJeudzQOgjNMA&oe=6728A5F4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Drums Ultimate Streamer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1706725464, "lastRevision": {"nodes": [{"id": "24141290328850641", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {