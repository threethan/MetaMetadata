_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YsuWPT-ZquUQ7kNvgH1dpmo&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD2iaubrwAdxK0pFT5v4wPFxgtKQ1Ft6-Kdy51WRJUX3g&oe=670B98F6"}]}, "id": "1674708130026425", "locale": "en_US", "screenshots": [{"file_name": "meta222.png", "id": "746671854102950", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/57568677_746671857436283_359019516506841873_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1hJJGY_rn_sQ7kNvgHYhEjH&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC9gUBtCX-XxJ1e0Ik8RgeCFCgqEsn-1yY1GHrRl60IuA&oe=670B96F7"}, {"file_name": "s2.png", "id": "407378231670034", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982441_407378235003367_5843710557005180397_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3pCH9KA-DYkQ7kNvgHJE53r&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB8q6aKWG8Fs5pqBSDZhpPuYmHy-EaUSviBWQyKm56R1g&oe=670BB8AB"}, {"file_name": "meta666.png", "id": "2689205241246204", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974895_2689205244579537_4557241657444279032_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2tuwRyw__bsQ7kNvgGpzGGG&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBhRRlZhle9JV4rhqgiRLcnBiG8wEH-FQgCr7Lg1ZjQgQ&oe=670BBCCD"}, {"file_name": "quest5.png", "id": "258372300602516", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982721_258372307269182_2994196070795906295_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8C8JepVO33IQ7kNvgGsZ4-m&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYApUPG5Orr371czDYETAce8JBcWzXaHlmmjJnr3P4vH-g&oe=670BABD3"}, {"file_name": "meta444.png", "id": "1174210640368452", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031416_1174210647035118_2127096637090478004_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j0LTI2P2J-QQ7kNvgHtHzZj&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYD3SSNuHilFUZZLqLvvKDprH3LIDrIw7kAuxRuz5ob2Og&oe=670BA9DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "meta2.png", "id": "1191734111867428", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39036695_1191734115200761_5872942496386580375_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zvD0qBqZT_MQ7kNvgE1akMk&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDLJdWHFpisYnbx-V9weaYrbsdz1uqivnxbdTyMssMlNA&oe=670B9966"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "Customizable freestyle VR drum simulator. Note highway rhythm games 2D/3D included. Must add your own custom songs or beat maps for the highways. Freestyle practice or play your MP3's in-game and make a drum cover like a real kit.\n\nIn-game Quest file browser .MP3/.OGG/.WAV audio player.\n\nPosition your drums, cymbals, and electronic drum pads where you like. Modify each drum sound by using different drum heads, cymbals, hi-hats.\n\nTenor drum harness and tenor drums included. (Marching band drums)\n\nQuick Features:\n- Save and load your kit\n- Pressure sensitive strikes\n- Bass and hi-hat foot pedals (VR buttons)\n- Bass and hi-hat foot pedals (USB/Bluetooth Pedal/Gamepad)\n- Multiple locations\n- Change sounds and look of kit\n- Tenor drums\n- Xylophone\n\nVR Drum Hardware Included:\n8 snare drums, 5 bass drums, also an amped bass drum, 5 crash cymbals, 2 ride cymbals, 3 splash cymbals, tom drums 6\", 8\", 10\", 12\", 14\". A roto tom rack 6\", 8\", 10\" roto toms, 4 different hi-hats (rock, 50's, metal trash etc), china cymbals, dry ride/crash, custom china stack, mounted tambourine, cow bells, steelpan drum, xylophone and more.\n\nTest Include:\n- Liv.tv\n\nDetail: \nThe note highway supports .chart drum charts with music. Custom music and drum charts (.chart files and song folders) that must be added yourself.", "short_description": "Customizable freestyle VR drum simulator and rhythm games.\n\nMust add your own custom songs or beat maps to play on the note highways. Position your drum kit hardware. Modify each drum sound by using different drum heads, cymbals, hi-hats etc.\n\nIn-game Quest file browser and music player .MP3/.OGG/.WAV\n\nTest Included:\n- Liv.tv"}]}, "developer_name": null, "developer_privacy_policy_url": "https://aliencybercoat.wixsite.com/home", "developer_terms_of_service_url": null, "publisher_name": "Alien Cyber Coat", "support_website_url": null, "website_url": "https://aliencybercoat.wixsite.com/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26006641622315493"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031517_972409864428624_375254253918777929_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AuX2cehy8t4Q7kNvgFPys9S&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBXhOTYbn3t9aa4_JnEfwY0piATjt7eqTatdImtGDZAMg&oe=670BA4F4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Drums Ultimate Streamer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}], "release_date": 1706725464, "lastRevision": {"nodes": [{"id": "24141290328850641", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "24141290282183979", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "