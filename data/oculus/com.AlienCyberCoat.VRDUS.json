69428_354054837263179_8887903356272987137_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4DJwg-EB9HkQ7kNvgGPPuTV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBJ6ToxuHvp3CqQ79MHMMwdMA6ZhvQ_sO_YbkN677uZPg&oe=675D64D0"}, {"file_name": "s4.png", "id": "748534227309832", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974899_748534230643165_2347223058285118564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lnoCa-s7yWMQ7kNvgE6PA30&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAR4G-_NLKU42dy0EWjXUTK83Vn29R0ryVxtTGG_KT7gw&oe=675D6004"}, {"file_name": "s5.png", "id": "357518203678417", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75302218_357518207011750_4579930035608897030_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYKJYMUenYcQ7kNvgEXFATB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC_cQMY8nvuBYbEHDdt2OjH5irzcpnNp5ewUWM60u8vIg&oe=675D8D22"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerThumb.png", "id": "6866505960070899", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031557_6866505966737565_4554394408291032221_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xdXsSL43hggQ7kNvgGd-yWD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDLN1pkyySu0BBRslgsLCdAGEc3L3RwGtIG8WE1IYHAwA&oe=675D70B5"}, "display_name": "VR Drums Ultimate Streamer", "keywords": [], "long_description": "A VR musical instrument simulator of a full drum kit. Practice in the privacy of VR, play and mod your drum set however you like. \n\nPlay the VR drum kit to your favorite music. (You must provide the music source)\n\nThis project was started when we were not able to own a real physical drum set anymore. It has been tuned the past 2 years and has brought us the feeling we were striving for. I hope it can bring others the same joy. We believe we have become better drummers from what we were, practicing in this game.", "short_description": "A VR drum kit instrument simulator. Practice in the priva