e7a0a&_nc_ohc=nCcd7aLGiwUQ7kNvgGG2PtM&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYCgoXo7TGld4yXqDN-PqsYbbXewmJ7rcXQS3mhS4q7CTA&oe=675EC3C0"}, {"file_name": "MoveScreenshot3.png", "id": "849737352507824", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39003240_849737355841157_4505946110024152142_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xPgs0OpZz3sQ7kNvgFnCS2D&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYA1C4mOehBIM7eThQQvd2rT0HbopWZPdTKKhQCEIyuQYg&oe=675ED9DD"}, {"file_name": "MoveScreenshot4.png", "id": "378762913276491", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031396_378762916609824_8818112194797267718_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZrGq2bqXSp8Q7kNvgE7hDjk&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBXRsxjKIuWaGl8ULo8Z-HHsdy-XlHg2ykR4nC0AoJyRA&oe=675EB896"}, {"file_name": "MoveScreenshot5.png", "id": "363050304798113", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031311_363050308131446_815762859288176452_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EIyywLcT1BoQ7kNvgFA1-jL&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDaroF3TqQqmYFSXUgP7ccSlNcAQn01JQ28UeAygDrdAg&oe=675ED784"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Oculus Move", "keywords": ["fitness", "workout", "calories", "exercise"], "long_description": "Oculus Move is a platform feature that helps you keep tabs on your fitness in VR so you can have more fun while exercising. Track the calories you burn and how long you\u2019ve been physically active across any game or app in VR. Set goals for yourself and track your progress over time. \n\n- SET GOALS for daily calories and move minutes \n- VISUALIZE your trends by day, by month or filter by app\n- TRACK activity across all VR apps and games from the Oculus Store\n- COUNT calorie estimates for you* \n- REAL-TIME STATS via in-game overlay (not yet available for all users) \n\n*Age, weight, height and sex are variables that impact the rate at which you burn calories. If you provide this information, your calorie estimate will be better. If you choose to skip, an average will be used.", "short_description": "Oculus Move is a platform feature that helps you keep tabs on your fitness in VR so you can have more fun while exercising. Track the calories you burn and how long you\u2019ve been physically active across any game or app in VR. Set goals for yourself and track your progress over time. "}]}, "developer_name": "Oculus", "developer_privacy_policy_url": "https://www.oculus.com/legal/privacy-policy/", "developer_terms_of_service_url": "https://www.oculus.com/legal/terms-of-service/", "publisher_name": "Oculus", "support_website_url": null, "website_url": "https://www.oculus.com/", "category": "SYSTEM", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "470867594697236"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8367306856701449", "version": "106.0.0.8.436"}, "id": "1149426002116372", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_appl