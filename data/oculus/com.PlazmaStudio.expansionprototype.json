1047364073377576_1204616426285170562_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3CPloblsqRAQ7kNvgEqkDqL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBKT6zdt0auKP5TrBHwOYP2PgyYGgi2JDWdiFg7DjHeGA&oe=66CDC8DB"}, "display_name": "Expansion", "keywords": [], "long_description": "Get into the shoes of a tactical warlord genius. Strategize, explore, and conquer as you build your own intergalactic empire. Engage in ultimate warfare and venture beyond the observable universe. Mastermind crucial decision-making and employ indirect control of units, relying on your strategic brilliance to outwit opponents.\n\nExpansion is an immersive VR adventure with unique gameplay that blends strategy, action, exploration, and tactics, testing the limits of your intelligence and ability to devise intricate maneuvers. Assemble your battle squads, strategize their tactics, and engage in intense multiplayer battles to dominate resources and establish your intergalactic dominion.\n\nThe universe awaits! Will you rise to the challenge? Dive straight into the battle! Embark on a VR journey like no other in Expansion.\n\nImmersive VR Sci-Fi Experience\nTactical Multiplayer Battles\nStrategic Indirect Unit Control\nBoundless World Exploration\n", "short_description": "https://plazmastudio.com/\nExpansion Alpha Test"}]}, "developer_name": null, "developer_privacy_policy_url": "https://plazmastudio.com/en/privacy-policy-vr/", "developer_terms_of_service_url": null, "publisher_name": "Plazma Studio", "support_website_url": null, "website_url": "https://plazmastudio.com/en/expansion/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "889588098232891"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["STRATEGY", "ADVENTURE", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_gr