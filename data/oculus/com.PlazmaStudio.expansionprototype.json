_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9_5eLTXJc5wQ7kNvgEj4e3S&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkMzJyk3NNW4ZDPidll6uvY&oh=00_AYA7pdWHSQI_uF7S-NzRkBokSM4Amh_KWdmjkaMYn3yluA&oe=66E6C21C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-Cover-Image.png", "id": "1047364070044243", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982439_1047364073377576_1204616426285170562_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gCoLwkPV-gQQ7kNvgGOIpVo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkMzJyk3NNW4ZDPidll6uvY&oh=00_AYCdjQo-pfy1LSijv0WFomV-WBQlzah9upoMmfEer9smgw&oe=66E6D55B"}, "display_name": "Expansion", "keywords": [], "long_description": "Get into the shoes of a tactical warlord genius. Strategize, explore, and conquer as you build your own intergalactic empire. Engage in ultimate warfare and venture beyond the observable universe. Mastermind crucial decision-making and employ indirect control of units, relying on your strategic brilliance to outwit opponents.\n\nExpansion is an immersive VR adventure with unique gameplay that blends strategy, action, exploration, and tactics, testing the limits of your intelligence and ability to devise intricate maneuvers. Assemble your battle squads, strategize their tactics, and engage in intense multiplayer battles to dominate resources and establish your intergalactic dominion.\n\nThe universe awaits! Will you rise to the challenge? Dive straight into the battle! Embark on a VR journey like no other in Expansion.\n\nImmersive VR Sci-Fi Experience\nTactical Multiplayer Battles\nStrategic Indirect Unit Control\nBoundless World Exploration\n", "short_description": "https://plazmastudio.com/\nExpansion Alpha Test"}]}, "developer_name": null, "developer_privacy_policy_url": "https://plazmastudio.com/en/privacy-policy-vr/", "developer_terms_of_service_url": null, "publisher_name": "Plazma Studio", "support_website_url": null, "website_url": "https://plazmastudio.com/en/expansion/", "categor