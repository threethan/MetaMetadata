g&oe=66E18BB1"}, {"file_name": "\u622a\u56fe\u65b0-2.png", "id": "1070736023862515", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75314846_1070736027195848_7560656726562944090_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A9owDQMvz64Q7kNvgF4g7lp&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq4d0zVhb_9RaVoefPukNLi&oh=00_AYDHMxMwRIt-n3wmcNAUmStLddPYr1EUyfgkq29LY0rpjg&oe=66E18307"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt-Landscape.png", "id": "476329454223428", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982439_476329457556761_3593194100586946197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m3nm64uHoDYQ7kNvgGxlxFo&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aq4d0zVhb_9RaVoefPukNLi&oh=00_AYDgL4odgyvsBDgNgbITZJoqRywVOFIEevajAyTTBB7FHw&oe=66E166FE"}, "display_name": "Carrier Aircraft", "keywords": [], "long_description": "As a discount\uff0c you can buy the game for only $0.99 this week!\nThis is an exciting VR aerial combat game. It combines elements of naval warfare. \nYour mission is flying an aircraft from the carrier, finding and clearing all enemy warships.\nBesides flying and shooting, you can also experience taking off and landing from an aircraft carrier.\nIn addition, there are many intense missions about aerial combat or naval warfare, such as air raid, protecting the oil rig platform, breaking through the valley, escaping from the cave and so on. ", "short_description": "Fly your aircraft from the carrier, find and clear all of the enemy fleet!"}]}, "developer_name": "Fengu Studio", "developer_privacy_policy_url": "http://aircraft.manyatang.com/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Fengu Studio", "support_website_url": null, "website_url": "http://aircraft.manyatang.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SHOOTER", "S