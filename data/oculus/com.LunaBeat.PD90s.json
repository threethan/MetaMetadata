dn.com/v/t64.5771-25/39035336_687864668975080_3799469745248446085_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STCuIEkFaGMQ7kNvgHsm-ra&_nc_ht=scontent.oculuscdn.com&oh=00_AYC2k9WLEM_t5iqwYeMUIyKCBdXMvPsBNenddtkikju8fA&oe=66E42D34"}, {"file_name": "3_claw.png", "id": "735311164471340", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982491_735311167804673_4071518481012166557_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o1z8r7QJA3MQ7kNvgHwGjDn&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgvpYSulTau-x2jAULsgBmVNYro20MHkCKTLf3MkXO8Q&oe=66E43B4B"}, {"file_name": "4_closet.png", "id": "1216840659086593", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223477_1216840662419926_363780128826617756_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8mtKjO-AgMQ7kNvgHRDFYR&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-2byDggHtM_tD7-PqcKuxi-JacSqOLtBwWN33TyT3ZQ&oe=66E439DF"}, {"file_name": "5_cipher.png", "id": "1098650507665430", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982484_1098650510998763_8560998532462045152_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JTLgGNhjyxkQ7kNvgHdzh9X&_nc_ht=scontent.oculuscdn.com&oh=00_AYD019PdckOQA4wKRa1Qj44z4TExJ573GtmEcMhwpHczVg&oe=66E420C8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-banner-2560x1440.png", "id": "747708629605598", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982542_747708632938931_4037373318369181551_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SgXkGk2l3yEQ7kNvgFBWhl-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAkHP8tyLizZlzFR2wKKuOkWPdJprvrok63SS3x7DEIIw&oe=66E42C36"}, "display_name": "Paranormal Detective: Escape from the 90's", "keywords": [], "long_description": "You play as a detective who is super in to the supernatural, and you've been tasked with tracking down a girl who went missing back in 1998 at the old abandoned mall- possibly the arcade where her big sister worked.\n\nInvestigate the old haunted arcade in an abandoned dead mall to try and find the missing girl!\n\nThe old machines still work- play arcade classics like skee ball, air hockey, basketball, pinball and more while you're looking for clues!\n\nExplore the arcade, unlock hidden secrets, solve puzzles and play awesome retro 90\u2019s arcade games in this VR escape room adventure!\n\n**NOTE: There are NO jump scares in this game! Just a spooky atmosphere.**", "short_description": "90's teen Delia has disappeared in an abandoned arcade and it\u2019s up to you to find her in this thrilling VR escape room adventure! Solve challenging puzzles and discover mysterious clues, all while playing awesome retro 90's arcade games!"}]}, "developer_name": "LunaBeat", "developer_privacy_policy_url": "https://lunabeat.com/page.php?id=privacy_policy_90s", "developer_terms_of_service_url": null, "publisher_name": "LunaBeat", "support_website_url": "https://lunabeat.com/page.php?id=contact", "website_url": "http://lunabeat.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "712355256528252"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "2019355035147218"}, {"status": "PENDING", "id": "977863857457317"}, {"status": "PUBLISHED", "id": "3269669106612435"}, {"status": "PUBLISHED", "id": "825502778627779"}, {"status": "PUBLISHED", "id": "1008780276455982"}, {"status": "PENDING", "id": "608195511122421"}]}, "baseline_offer": {"id": "3269669106612435"}, "is_approved": true, "firstOffer": {"nodes": [{"st