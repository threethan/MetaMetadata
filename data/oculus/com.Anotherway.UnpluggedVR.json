"661134541018539"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1892468820862074"}, {"id": "2675955252474460"}]}, "id": "819134361755092"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1812602608857115"}]}, "id": "420938118313188"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "922402147808085"}]}, "id": "201237933592909"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "1039652702743731"}]}, "id": "1190771160933233"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "872183756232656"}]}, "id": "1166959413328166"}]}}, "firstRevision": {"nodes": [{"application": {"id": "4714094898617280", "release_date": 1634824689, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 32}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6493910463969039"}, "id": "479146376498367"}]}}, "binary": null, "live_binary": null, "created_date": 1725978312, "id": "9070106026349457", "is_initial_release": false, "name_with_fallback": "v21", "pdp_metadata_with_fallback": {"version": 20, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "562788288540471"}, "release_status": "RELEASED", "id": "4714094898617280"}, "id": "562788288540471", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "PENDING", "release_type": "SCHEDULED", "pdp_metadata": null, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_840632253641023_136013485393239468_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G0s3XkHAaAYQ7kNvgGZcabI&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYBHIjgCJZOoLNuLW9dfu7DT6WHGj1e5yhTdoOMrnrvM6A&oe=66E6DC18"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Unplugged: Air Guitar ", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 1634824689, "lastRevision": {"nodes": [{"id": "301074915056295", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4714094898617280", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "315345976750481"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "4242745475772486", "locale": "it_IT", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unplugged", "keywords": [], "long_description": "Sali sul palco con Unplugged e suona alcune delle migliori canzoni rock di band famose in tutto il mondo, tra cui The Offspring, Weezer e Ozzy Osbourne. Indossa il visore VR e, grazie alla tecnologia che traccia il movimento delle dita, suona la chitarra dal vivo davanti a un pubblico sempre pi\u00f9 numeroso. Scegli una delle tante chitarre e amplificatori per fare un incredibile viaggio nel rock. Segui gli accordi, tocca le corde al momento giusto e diventa una leggenda del rock!\nDiventa una leggenda del rock: suona le tue canzoni rock preferite su un palco dal vivo\nDomina il palco: intrattieni la folla con le esibizioni rock di una vita\nCrea la tua carriera: sblocca nuove canzoni, luoghi, chitarre e molto altro\nVerso la fama: competi per diventare una superstar\nTre modalit\u00e0 di gioco: comincia con la modalit\u00e0 facile, suona nella modalit\u00e0 normale, e fai decollare il rock con la modalit\u00e0 difficile\nUn viaggio nel rock: vivi cinque decadi di canzoni rock, chitarre, amplificatori e molto altro", "short_description": "Fa' finta di suonare la chitarra e scrivi la storia del rock in VR! Con Unplugged potrai suonare alcune tra le migliori canzoni del rock usando solo le mani. Niente controller e niente periferiche. Hai la stoffa per diventare una leggenda del rock?"}, {"images": {"nodes": []}, "id": "3156017897963318", "locale": "pt_BR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unplugged", "keywords": [], "long_description": "Suba ao palco do Unplugged e toque alguns dos hinos mais insanos de grandes bandas de rock, como The Offspring, Weezer e Ozzy Osbourne. Coloque seus \u00f3culos de RV e use as m\u00e3os para tocar air guitar ao vivo no palco, em frente a plateias cada vez maiores. Fa\u00e7a sua escolha entre guitarras e amplificadores virtuais para detonar em sua incr\u00edvel jornada no rock. Acompanhe os acordes com os dedos, toque as cordas no tempo certo e vire uma lenda do rock. Pelo amor ao rock!\n\nVire uma lenda do rock: apresente suas m\u00fasicas favoritas ao vivo no palco \nDomine o palco: inspire os f\u00e3s com uma apresenta\u00e7\u00e3o roqueira hist\u00f3rica\nConstrua sua carreira: desbloqueie novas can\u00e7\u00f5es e palcos, conquiste guitarras e muito mais\nConquiste a fama: participe da competi\u00e7\u00e3o e seja a maior estrela do ranking\nTr\u00eas modos de jogo: comece no f\u00e1cil, ensaie no normal e quebre tudo no dif\u00edcil\nDivirta-se em uma jornada roqueira: sinta as emo\u00e7\u00f5es de cinco d\u00e9cadas de cl\u00e1ssicos do rock, guitarras, amplificadores e muito mais", "short_description": "Toque air guitar e entre para a hist\u00f3ria do rock em RV! Em Unplugged, voc\u00ea toca alguns dos maiores hinos do rock com as pr\u00f3prias m\u00e3os... e mais nada! N\u00e3o precisa de controles nem de perif\u00e9ricos. Prepare-se para ser uma lenda do rock!"}, {"images": {"nodes": []}, "id": "1871695696333409", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unplugged", "keywords": [], "long_description": "\u041f\u0440\u044b\u0433\u0430\u0439\u0442\u0435 \u043d\u0430 \u0441\u0446\u0435\u043d\u0443 \u0432 Unplugged \u0438 \u043e\u0442\u0436\u0438\u0433\u0430\u0439\u0442\u0435 \u043f\u043e\u0434 \u0441\u0430\u043c\u044b\u0435 \u0431\u043e\u043b\u044c\u0448\u0438\u0435 \u043d\u0435\u0432\u043e\u043e\u0431\u0440\u0430\u0437\u0438\u043c\u043e \u043a\u0440\u0443\u0442\u044b\u0435 \u043f\u0435\u0441\u043d\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0445 \u0440\u043e\u043a-\u0433\u0440\u0443\u043f\u043f, \u0432\u043a\u043b\u044e\u0447\u0430\u044f The Offspring, Weezer \u0438 Ozzy Osbourne. \u041d\u0430\u0434\u0435\u0432\u0430\u0439\u0442\u0435 VR-\u0448\u043b\u0435\u043c \u0438 \u0437\u0430 \u0441\u0447\u0435\u0442 \u043e\u0442\u0441\u043b\u0435\u0436\u0438\u0432\u0430\u043d\u0438\u044f \u0440\u0443\u043a \u0438\u0433\u0440\u0430\u0439\u0442\u0435 \u043d\u0430 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u0438\u0442\u0430\u0440\u0435 \u043d\u0430 \u043a\u043e\u043d\u0446\u0435\u0440\u0442\u0435 \u043f\u0435\u0440\u0435\u0434 \u0440\u0430\u0441\u0442\u0443\u0449\u0435\u0439 \u0442\u043e\u043b\u043f\u043e\u0439. \u0412\u044b\u0431\u0438\u0440\u0430\u0439\u0442\u0435 \u0433\u0438\u0442\u0430\u0440\u0443 \u0438 \u0443\u0441\u0438\u043b\u043e\u043a \u0438\u0437 \u043a\u043e\u043b\u043b\u0435\u043a\u0446\u0438\u0438, \u0447\u0442\u043e\u0431\u044b \u043c\u043e\u0449\u043d\u043e \u043f\u0440\u043e\u0439\u0442\u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u0440\u043e\u043a-\u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435. \u0411\u0435\u0440\u0438\u0442\u0435 \u0430\u043a\u043a\u043e\u0440\u0434\u044b, \u0443\u0434\u0430\u0440\u044f\u0439\u0442\u0435 \u043f\u043e \u0441\u0442\u0440\u0443\u043d\u0430\u043c \u0432 \u043d\u0443\u0436\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0438 \u0441\u0442\u0430\u043d\u044c\u0442\u0435 \u0440\u043e\u043a-\u043b\u0435\u0433\u0435\u043d\u0434\u043e\u0439. \u0417\u0430 \u0440\u043e\u043a!\n\n\u0421\u0442\u0430\u043d\u044c\u0442\u0435 \u0440\u043e\u043a-\u043b\u0435\u0433\u0435\u043d\u0434\u043e\u0439: \u0438\u0433\u0440\u0430\u0439\u0442\u0435 \u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u0440\u043e\u043a-\u043f\u0435\u0441\u043d\u0438 \u043d\u0430 \u0436\u0438\u0432\u044b\u0445 \u043a\u043e\u043d\u0446\u0435\u0440\u0442\u0430\u0445. \n\u0411\u043b\u0438\u0441\u0442\u0430\u0439\u0442\u0435 \u043d\u0430 \u0441\u0446\u0435\u043d\u0435: \u0437\u0430\u0432\u0435\u0434\u0438\u0442\u0435 \u0442\u043e\u043b\u043f\u0443 \u0440\u043e\u043a-\u043a\u043e\u043d\u0446\u0435\u0440\u0442\u043e\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043e\u043d\u0438 \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0437\u0430\u0431\u0443\u0434\u0443\u0442.\n\u041f\u043e\u0441\u0442\u0440\u043e\u0439\u0442\u0435 \u043a\u0430\u0440\u044c\u0435\u0440\u0443: \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0439\u0442\u0435 \u043d\u043e\u0432\u044b\u0435 \u043f\u0435\u0441\u043d\u0438 \u0438 \u0441\u0446\u0435\u043d\u044b, \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0439\u0442\u0435 \u0433\u0438\u0442\u0430\u0440\u044b \u0438 \u043c\u043d\u043e\u0433\u043e\u0435 \u0434\u0440\u0443\u0433\u043e\u0435.\n\u0417\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0439\u0442\u0435 \u0441\u043b\u0430\u0432\u0443: \u0441\u043e\u0440\u0435\u0432\u043d\u0443\u0439\u0442\u0435\u0441\u044c \u0441 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0438\u0433\u0440\u043e\u043a\u0430\u043c\u0438, \u0447\u0442\u043e\u0431\u044b \u0441\u0442\u0430\u0442\u044c \u0441\u0443\u043f\u0435\u0440\u0437\u0432\u0435\u0437\u0434\u043e\u0439 \u0441\u043f\u0438\u0441\u043a\u0430 \u043b\u0438\u0434\u0435\u0440\u043e\u0432.\n\u0422\u0440\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u0430 \u0438\u0433\u0440\u0430\u0442\u044c: \u043d\u0430\u0447\u043d\u0438\u0442\u0435 \u0432 \u043f\u0440\u043e\u0441\u0442\u043e\u043c \u0440\u0435\u0436\u0438\u043c\u0435, \u0438\u043c\u043f\u0440\u043e\u0432\u0438\u0437\u0438\u0440\u0443\u0439\u0442\u0435 \u0432 \u043e\u0431\u044b\u0447\u043d\u043e\u043c \u0438 \u043e\u0442\u0436\u0438\u0433\u0430\u0439\u0442\u0435 \u043d\u0430 \u0432\u044b\u0441\u043e\u043a\u043e\u0439 \u0441\u043b\u043e\u0436\u043d\u043e\u0441\u0442\u0438.\n\u041e\u0442\u043f\u0440\u0430\u0432\u044c\u0442\u0435\u0441\u044c \u0432 \u0440\u043e\u043a-\u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435: \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435 \u043d\u0430 \u0441\u0435\u0431\u0435 5 \u0434\u0435\u0441\u044f\u0442\u0438\u043b\u0435\u0442\u0438\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043d\u044b\u0445 \u0440\u043e\u043a-\u043f\u0435\u0441\u0435\u043d, \u0433\u0438\u0442\u0430\u0440, \u0443\u0441\u0438\u043b\u0438\u0442\u0435\u043b\u0435\u0439 \u0438 \u043c\u043d\u043e\u0433\u043e\u0433\u043e \u0434\u0440\u0443\u0433\u043e\u0433\u043e.", "short_description": "\u0418\u0433\u0440\u0430\u0439\u0442\u0435 \u043d\u0430 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u043e\u0439 \u0433\u0438\u0442\u0430\u0440\u0435 \u0438 \u043f\u0438\u0448\u0438\u0442\u0435 \u0438\u0441\u0442\u043e\u0440\u0438\u044e \u0440\u043e\u043a\u0430 \u0432 VR! \u0412 Unplugged \u0432\u044b \u0441\u043c\u043e\u0436\u0435\u0442\u0435 \u0436\u0435\u0441\u0442\u043a\u043e \u043e\u0442\u0436\u0438\u0433\u0430\u0442\u044c \u043f\u043e\u0434 \u0432\u0435\u043b\u0438\u0447\u0430\u0439\u0448\u0438\u0435 \u0440\u043e\u043a-\u0445\u0438\u0442\u044b \u0433\u043e\u043b\u044b\u043c\u0438 \u0440\u0443\u043a\u0430\u043c\u0438. \u0413\u0435\u0439\u043c\u043f\u0430\u0434\u044b \u0438 \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430 \u043d\u0435 \u043d\u0443\u0436\u043d\u044b. \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b \u0441\u0442\u0430\u0442\u044c \u0440\u043e\u043a-\u043b\u0435\u0433\u0435\u043d\u0434\u043e\u0439?!"}, {"images": {"nodes": []}, "id": "1019225398853212", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Unplugged", "keywords": [], "long_description": "Sal a escena en Unplugged y rockea las canciones m\u00e1s conocidas de bandas de rock famosas del mundo entero, como The Offspring, Weezer y Ozzy Osbourne. Ponte el visor de RV, usa el seguimiento de manos y toca la guitarra de aire frente a p\u00fablicos cada vez m\u00e1s numerosos. Elige una tu guitarra virtual y amplificador e inicia tu viaje de rock. Coloca los dedos en funci\u00f3n de los acordes, rasguea las cuerdas en el momento justo y s\u00e9 una leyenda del rock. \u00a1Por amor al rock!\n\nConvi\u00e9rtete en una leyenda del rock: toca tus canciones favoritas en el escenario. \nAdu\u00e9\u00f1ate del escenario: estremece a la multitud con una actuaci\u00f3n \u00fanica.\nDesarrolla tu carrera: desbloquea canciones y escenarios, gana guitarras y m\u00e1s.\nAsciende a la fama: compite contra otros para reinar en el marcador.\nTres maneras de rockear: inicia en el modo f\u00e1cil, toca en modo normal y rockea al m\u00e1ximo en el modo dif\u00edcil.\nInicia tu viaje de rock: vive 5 d\u00e9cadas de canciones famosas, guitarras, amplificadores y m\u00e1s.", "short_description": "Toca la guitarra de aire y escribe la historia del rock en realidad virtual. En Unplugged, podr\u00e1s rockear bien fuerte con algunas de las canciones m\u00e1s famosas, solo usando las manos. No se requieren controles ni perif\u00e9ricos. \u00bfQuieres ser una estrella de rock?"}, {"images": {"nodes": [{"file_name": "UNP_Icon.png", "id": "4373059229428261", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_4373059236094927_793221422589488887_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iwsu-Zl42Q0Q7kNvgED52AL&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYDthyZ88FWxwoeoO6Nm5F4LFiluWrE8ipKdd77dqGuQdQ&oe=66E6BE12"}, {"file_name": "UNP_Portrait.png", "id": "3047315962259373", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974873_3047315965592706_7051312403964362224_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULk-5aLR3iYQ7kNvgGa2Sdg&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYCddg_X0pnMTNL3ejCUvfR-dxoRlTXXtWO_lDuvYL-tLA&oe=66E6C34E"}, {"file_name": "UNP_Landscape.png", "id": "1036900587147482", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65228806_1036900590480815_6177819282104065821_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_EtYV_qlh8Q7kNvgHxgChM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYDA4oIyG7iIglZMxwkLxpvWaV0TfWIMWC2nZqrIBJPEwA&oe=66E6DC04"}, {"file_name": "UNP_Hero.png", "id": "585228386172725", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_585228389506058_6872088899624327679_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cIYBSWUWl8MQ7kNvgExOcXX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYC-4VA1KXz1Y-zilRQ2s-xg7of8PGCfU5Z1Kod0EHEhuQ&oe=66E6D49D"}, {"file_name": "UNP_Square.png", "id": "544276040018204", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227814954_544276043351537_3872504155759577488_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=abHYgLLp_q8Q7kNvgGKp_6R&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zTyxsjiXcFDYx0yX_vPAp&oh=00_AYBRRSL0KHOG5EIod7AToXFGwDgm2sWiSwvW27GuQMNpEQ&oe=66E6C8E3"}, {"file_name": "Unplugged_Logo_Air_Guitar_light.png", "id": "216761810515195", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001679_216761817181861_4649642962545599675_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FaBkalYZRjwQ7kNvgHFaI3V&_nc_ht=scontent.oculuscdn.com&_nc_gid=A0zT