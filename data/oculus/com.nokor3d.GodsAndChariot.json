2.oculuscdn.com/v/t64.5771-25/39001726_1219689678602704_2437162313273701657_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AU7DjPoTKYkQ7kNvgGaA-1K&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpb1kXM6Q1I1i-iaO6iA8Owmb_WWl8xFkUHg7DsKbRNA&oe=6749BC9E"}, {"file_name": "output-onlinepngtools (82).png", "id": "396093395786929", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_396093399120262_1987173989107118684_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ttOAH58e90Q7kNvgG3wvJu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBK2xP-l_J55QDAlGQtRtDdAFG12RT-25rgEMN4YWC2Ww&oe=67499A5F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Gods and Chariot (13)_mh1654881457720.png", "id": "3186201544969495", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_3186201548302828_5950261700357957901_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cnIFUBeIpTsQ7kNvgF3i5tT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARZNbSskOdDOosfnlKexiZ_hmE5YdHlDtKt6N3MNCE8w&oe=674998D8"}, "display_name": "Gods and Chariot", "keywords": [], "long_description": "\nIn this game you will go back to mighty Egyptian Empire. Ride the chariot, crush your enemy and see them driven, or travel across the oasis. Shoot a bow, use a spear, or go to battles, fight alongside with Egyptian gods and save the land from darkness and invaders.\n\nIn bronze age Chariots were the most fearful instrument of war. Unorganized light Infantries are going to be easily destroyed by chariots. Elite troops, heavy infantries/pikemen are effective causing damage to chariot.\n\nIn the battles you will need to defeat the enemy marshal and make sure yours doesn't fall. You will also receive reinforcements, however it is going to be outnumbered by enemy.\n\nThis is a single player game. You can sit or stand when playing the game. You can always recalibrate your position/height after change posture or placements.\n\nThis game is in active development. 