You can always recalibrate your position/height after change posture or placements.\n\nThis game is in active development. ", "short_description": "Historical Chariot Warfare experience in Bronze Age Egypt. Crush your enemy and more!\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3dnokor.com/", "developer_terms_of_service_url": null, "publisher_name": "3DNOKOR", "support_website_url": null, "website_url": "https://www.3dnokor.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "408636891342520"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974459_2892928767674344_6584608137871806760_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2maXPBU-Nq8Q7kNvgGAi6ie&_nc_ht=scontent.oculuscdn.com&_nc_gid=ApE6-PiGxyxNvPNH7r0Hxyo&oh=00_AYA8JFFHabFcMUxmBcvTzuW3jRYDEq6ksNAtFj2OJBFDkA&oe=66E18AEF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gods and Chariot", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1654556400, "lastRevision": {"nodes": [{"id": "5187290021389857", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5187289964723196", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cer