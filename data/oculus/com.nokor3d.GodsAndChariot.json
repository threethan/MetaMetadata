2.oculuscdn.com/v/t64.5771-25/39001726_1219689678602704_2437162313273701657_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ezcLHXG1hf8Q7kNvgFfdyuk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADbSA1SPT5MazbBGNf6UCkZD9tnoblSDDH5rbiCI2-pA&oe=674B0E1E"}, {"file_name": "output-onlinepngtools (82).png", "id": "396093395786929", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_396093399120262_1987173989107118684_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ttOAH58e90Q7kNvgG3jbym&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBi8mvqEw7uLnYig5bhzpEISQikC7VzK3SJJQ5bWzCvHA&oe=674AEBDF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Gods and Chariot (13)_mh1654881457720.png", "id": "3186201544969495", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_3186201548302828_5950261700357957901_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iLj8NJnzvcIQ7kNvgGjd675&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5-HErnO0B3jAlWNtZskg8hYOhdatLfiQIOb-pezSHAw&oe=674AEA58"}, "display_name": "Gods and Chariot", "keywords": [], "long_description": "\nIn this game you will go back to mighty Egyptian Empire. Ride the chariot, crush your enemy and see them driven, or travel across the oasis. Shoot a bow, use a spear, or go to battles, fight alongside with Egyptian gods and save the land from darkness and invaders.\n\nIn bronze age Chariots were the most fearful instrument of war. Unorganized light Infantries are going to be easily destroyed by chariots. Elite troops, heavy infantries/pikemen are effective causing damage to chariot.\n\nIn the battles you will need to defeat the enemy marshal and make sure yours doesn't fall. You will also receive reinforcements, however it is going to be outnumbered by enemy.\n\nThis is a single player game. You can sit or stand when playing the game. You can always recalibrate your position/height after change posture or placements.\n\nThis game is in active development. ", "short_description": "Historical Chariot Warfare experience in Bronze Age Egypt. Crush your enemy and more!\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3dnokor.com/", "developer_terms_of_service_url": null, "publisher_name": "3DNOKOR", "support_website_url": null, "website_url": "https://www.3dnokor.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "FIGHTING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "408636891342520"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974459_2892928767674344_6584608137871806760_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yU5_qvoOl_QQ7kNvgEt9510&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAC2tHjW_YH-Aovtu5R3kUvsnyUz_eo61pDw9TAsl6Lkg&oe=674B02EF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Gods and Chariot", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1654556400, "lastRevision": {"nodes": [{"id": "5187290021389857", "release_type": "SCHEDULED", "administration_status": "A