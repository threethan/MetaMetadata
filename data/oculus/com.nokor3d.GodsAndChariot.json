2.oculuscdn.com/v/t64.5771-25/39001726_1219689678602704_2437162313273701657_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BtBsI9gZS3IQ7kNvgEcADNa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDJO2cWRqZsJ7vSEK82_E-C7xodazbYHuBHnqmjXCM8Q&oe=6727759E"}, {"file_name": "output-onlinepngtools (82).png", "id": "396093395786929", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974905_396093399120262_1987173989107118684_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uRDvYh9uPRYQ7kNvgG_16yP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAJNHjEPdfpuLeD_MN9t1_vS8bVtDsroJQM4r2nKzRZQ&oe=6727535F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Gods and Chariot (13)_mh1654881457720.png", "id": "3186201544969495", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003281_3186201548302828_5950261700357957901_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=artm0M9gPicQ7kNvgGO4LAD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBq09-tWrivQMYXfAcXVCD--MwTi3ZhpbTvWlETg8iSqg&oe=672751D8"}, "display_name": "Gods and Chariot", "keywords": [], "long_description": "\nIn this game you will go back to mighty Egyptian Empire. Ride the chariot, crush your enemy and see them driven, or travel across the oasis. Shoot a bow, use a spear, or go to battles, fight alongside with Egyptian gods and save the land from darkness and invaders.\n\nIn bronze age Chariots were the most fearful instrument of war. Unorganized light Infantries are going to be easily destroyed by chariots. Elite troops, heavy infantries/pikemen are effective causing damage to chariot.\n\nIn the battles you will need to defeat the enemy marshal and make sure yours doesn't fall. You will also receive reinforcements, however it is going to be outnumbered by enemy.\n\nThis is a single player game. You can sit or stand when playing the game. You can always recalibrate your position/height after change posture or placements.\n\nThis game is in active development. 