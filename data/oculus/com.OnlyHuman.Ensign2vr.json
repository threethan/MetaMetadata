n.com&_nc_gid=AJOiyMW5sohpCbdFEwgJQqM&oh=00_AYBY7QyZX-8NTdHHfHlRfFMB8rmLNUt2_DTAGfJrwl2Z8g&oe=66E2D33F"}, {"file_name": "Screenshot2.png", "id": "120463376691687", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974844_120463380025020_3766637278220880444_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P3ZHIWZ9PIkQ7kNvgGLoCTy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJOiyMW5sohpCbdFEwgJQqM&oh=00_AYCJ5UlxPqpim0x-d4NkxegI1rCUMkbZ9-aT2hllcOaLjQ&oe=66E2E06C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerScreenshot.png", "id": "3465163723593541", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974887_3465163730260207_1427127429038847667_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d-IVRwouZiwQ7kNvgF84pF3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJOiyMW5sohpCbdFEwgJQqM&oh=00_AYD4HFE9Gvui-sfLmWd4Ah1XaVgXQ1MF1ZkU5e3NIsXWKA&oe=66E2D5B9"}, "display_name": "Symphony of Stars", "keywords": [], "long_description": "Play Symphony of Stars how you like! Fly around gazing at the stars and planets, or engage in combat, take over planets and build your faction's empire! If you choose the later, you'll need to use a bit of strategy as there are other factions vying for control of the system in the game. Build up resources, and properly leave planets defended before moving on the attack.\n\nFeatures:\n-3 Different playable factions, each with their own style of ship\n-Randomly generated maps, each game is different!\n-AI Difficulty levels, and team settings. Up the AI difficulty and try to take them down with a friend if you'd like!\n-Online multiplayer, play with up to 9 other humans or hone your skills against the AI!", "short_description": "Either enjoy the sights of a randomly generated system or conquer territory and build defenses, your call."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.onlyhumanstudios.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Only Human Studios", "support