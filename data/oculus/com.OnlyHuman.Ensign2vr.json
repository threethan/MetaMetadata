n.com/v/t64.5771-25/38974844_120463380025020_3766637278220880444_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=syevQL3ur20Q7kNvgHcIMvZ&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDJPg1cOXHiQlB7Jlz_lz2Jq1BbEmf7peNusEih72Rfww&oe=671A3F6C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerScreenshot.png", "id": "3465163723593541", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38974887_3465163730260207_1427127429038847667_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jm1FrCm09MwQ7kNvgHN0WFz&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBnrGmuykLQZV4qGwyFsDqpIgWGQM68WpJqN-pIbK00DA&oe=671A34B9"}, "display_name": "Symphony of Stars", "keywords": [], "long_description": "Play Symphony of Stars how you like! Fly around gazing at the stars and planets, or engage in combat, take over planets and build your faction's empire! If you choose the later, you'll need to use a bit of strategy as there are other factions vying for control of the system in the game. Build up resources, and properly leave planets defended before moving on the attack.\n\nFeatures:\n-3 Different playable factions, each with their own style of ship\n-Randomly generated maps, each game is different!\n-AI Difficulty levels, and team settings. Up the AI difficulty and try to take them down with a friend if you'd like!\n-Online multiplayer, play with up to 9 other humans or hone your skills against the AI!", "short_description": "Either enjoy the sights of a randomly generated system or conquer territory and build defenses, your call."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.onlyhumanstudios.net/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Only Human Studios", "support_website_url": null, "website_url": "https://www.onlyhumanstudios.net/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": 