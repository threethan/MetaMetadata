{"data": {"node": {"__typename": "Application", "id": "2436897736439055", "organization": {"id": "2263495133904157", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "6177535518960366"}]}, "id": "2166934093507764"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4963431797114722"}]}, "id": "1568887280268643"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2436897736439055"}]}, "id": "2563734466999212"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "2250162051701470"}]}, "id": "2137239849689656"}]}}, "firstRevision": {"nodes": [{"application": {"id": "2436897736439055", "release_date": 1607018400, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 50}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6328319427296847"}, "id": "2498639197047980"}]}}, "binary": null, "live_binary": null, "created_date": 1689929162, "id": "6275099989285458", "is_initial_release": false, "name_with_fallback": "v16", "pdp_metadata_with_fallback": {"version": 16, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "1236105270431613"}, "release_status": "RELEASED", "id": "2436897736439055"}, "id": "1236105270431613", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": null, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "MANAGED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2436897736439055", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "304496867117951"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "685174603666498", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\ucee8\ud2b8\ub799\ud130\uc2a4", "keywords": ["\uc288\ud305", "\uc11c\ub4e0\uc5b4\ud0dd", "\uc2dc\ubbac\ub808\uc774\uc158", "\uc561\uc158", "\uba40\ud2f0\ud50c\ub808\uc774"], "long_description": "<\ucee8\ud2b8\ub799\ud130\uc2a4 VR>\uc740 \uba40\ud2f0\ud50c\ub808\uc774 \ubc00\ub9ac\ud130\ub9ac \uc288\ud305 VR \uac8c\uc784\uc73c\ub85c, \uaca9\ub82c\ud55c \ucd1d\uaca9\uc804\uacfc \ud300\ud50c\ub808\uc774 \ubbf8\uc158, \uce58\uba85\uc801\uc778 \ubb34\uae30, \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5 \uac00\ub2a5\ud55c \ub85c\ub4dc\uc544\uc6c3 \ub4f1 \ucc28\uc138\ub300 VR \uc804\ud22c \uacbd\ud5d8\uc744 \uc120\uc0ac\ud569\ub2c8\ub2e4.\n\uc8fc\uc694 \ud2b9\uc9d5: \n1. \uce90\uc8fc\uc5bc \ubc0f \uacbd\uc7c1 \uac8c\uc784 \ubaa8\ub4dc \n2. \uac15\ub3c4 \ub192\uc740 \uc624\ud504\ub77c\uc778 \ubc0f \uc628\ub77c\uc778 \ud300\ud50c\ub808\uc774 \ubbf8\uc158 \n3. \ucd5c\ub300 4\uba85\uc758 \ud50c\ub808\uc774\uc5b4\uac00 \ud568\uaed8\ud558\ub294 \uce58\uc5f4\ud55c \uc11c\ubc14\uc774\ubc8c \ubaa8\ub4dc\n4. 30\uac00\uc9c0 \uc774\uc0c1\uc758 \ubb34\uae30 \uc911 \uc120\ud0dd \uac00\ub2a5 \n5. \ucee4\uc2a4\ud130\ub9c8\uc774\uc9d5 \uac00\ub2a5\ud55c \ub85c\ub4dc\uc544\uc6c3 \uc2dc\uc2a4\ud15c \n6. 'Quest' \ubc0f 'Rift' \ud50c\ub7ab\ud3fc \uad50\ucc28 \ud50c\ub808\uc774 \uc9c0\uc6d0\n7. \uc0ac\uaca9 \uc5f0\uc2b5 \ud5c8\ube0c \uc9c0\uc5ed", "short_description": "<\ucee8\ud2b8\ub799\ud130\uc2a4>\ub294 \ube60\ub978 \uc18d\ub3c4\ub85c \uc9c4\ud589\ub418\ub294 \ubc00\ub9ac\ud130\ub9ac \uc288\ud305 \uac8c\uc784\uc73c\ub85c, \uc628\ub77c\uc778 \ub300\uc804 \ubaa8\ub4dc\uc640 \ud300\ud50c\ub808\uc774 \ubbf8\uc158\uc744 \uc990\uae38 \uc218 \uc788\uc2b5\ub2c8\ub2e4."}, {"images": {"nodes": []}, "id": "667890048611512", "locale": "es_LA", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Contractors", "keywords": ["Disparos", "Militar", "Simulador", "Acci\u00f3n", "Multijugador"], "long_description": "\u201cContractors VR\u201d es un juego competitivo de disparos con tem\u00e1tica militar y multijugador. Entra a un campo de batalla de otro nivel en VR con tiroteos intensos, misiones cooperativas, armas letales y equipamiento personalizable.\nLas caracter\u00edsticas incluyen: \n1. Modos de juego casuales y competitivos. \n2. Misiones cooperativas intensas sin conexi\u00f3n y en l\u00ednea. \n3. Un desafiante modo de supervivencia para un m\u00e1ximo de 4 jugadores.\n4. M\u00e1s de 30 armas diferentes. \n5. Sistema de equipamiento personalizable. \n6. Sistema de juego cruzado entre las plataformas Quest y Rift.\n7. Zona de campo de pruebas.", "short_description": "\u201cContractors\u201d es un juego de disparos y de tem\u00e1tica militar con modos de juego competitivos y misiones cooperativas en l\u00ednea."}, {"images": {"nodes": [{"file_name": "2436897736439055.png", "id": "1607594363385477", "image_type": "APP_IMG_CUBEMAP_SOURCE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_1607594366718810_687937224033050485_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=buom9A4s4SwQ7kNvgEA4kht&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYCcE1TFDMr9lGcVQp8hX2z7-7-OdttND6ZQC_RA4Q60Yw&oe=66F53614"}, {"file_name": "CoverSquare.png", "id": "1383112605575707", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001698_1383112608909040_2834905582571453296_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2riu9RA3MPMQ7kNvgErhFV4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYBe9WXwPIg4iI-VxwR5cucyBWUSN8PjiaZXm-e7eg1nPA&oe=66F55544"}, {"file_name": "MiniLandscape.png", "id": "1304877230236790", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031525_1304877233570123_7951197877138417575_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jFsvA1AcbEAQ7kNvgEGSL6K&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYBqhd-oQbf