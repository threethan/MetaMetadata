F-gbR3w7&oh=00_AYDiiVAaiRusE1_ZAyEH4e_3UeazwwL_bqTEEVrWj7Fnwg&oe=66F548E2"}]}, "id": "667389074909218", "locale": "en_US", "screenshots": [{"file_name": "Screen Shot 2021-11-05 at 7.19.41 PM.png", "id": "3001255886805429", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984454_3001255890138762_1639676261828133687_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=01q1ETMKmCgQ7kNvgEMvLpc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYAniVtPndMRK5ej9yaD-6LrTpSpI6lLapuv27qMiWYFOA&oe=66F534F2"}, {"file_name": "Screen Shot 2021-11-05 at 8.01.22 PM.png", "id": "923278391924057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984454_923278395257390_1611555704418945577_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QUFSJ0CTUTwQ7kNvgErzGHC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYA50NhUCdZL0WbVjguykenITOzSG04B8uEYZT5H4mbZRw&oe=66F54702"}, {"file_name": "Screen Shot 2021-11-05 at 8.01.53 PM.png", "id": "1952253051631865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036661_1952253054965198_6514419083199581159_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tyweWmAbwK4Q7kNvgHvE8F_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYDhgDpTL6YrZ2BRTG8lrYwnv-THv2VtJBjWVAIByQ9I-A&oe=66F5572C"}, {"file_name": "Screen Shot 2021-11-05 at 7.22.47 PM.png", "id": "1096174924460438", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031548_1096174927793771_621082233837009528_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jq94KPqg-UUQ7kNvgFUu92N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYCcrTq77XF3r3KEdQJ5eKgMRe1DIowmhxEDaBR7PJ2h_Q&oe=66F54905"}, {"file_name": "Screen Shot 2021-11-05 at 7.18.19 PM.png", "id": "602087107579823", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036680_602087110913156_4974182995452516198_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0KLaYIHkxKcQ7kNvgF3ra8W&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYCNRjvLQrAzrVVUoT-T3X5Zz0Iq3u4yWTa134OCCM3tiQ&oe=66F53B1A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverLandscape 2560x1440.png", "id": "839437637789524", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982478_839437644456190_7091366435697552788_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k6paOeNNYEQQ7kNvgEaGaiW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJHqBmapGSqu8OIF-gbR3w7&oh=00_AYDZKqdWXat4g022LnvOCyCrOYuILC9vc0GiOvarSoHS1g&oe=66F54A04"}, "display_name": "Contractors", "keywords": ["Shooter", "Military", "Action", "Multiplayer", "Simulation"], "long_description": "*Custom loadout and game mode are finally available!\n\nContractors VR is a fast-paced military competitive multiplayer VR shooter game, gear up and experience the next-level VR battlefield with lethal weapons and intense firefights.\n\nFeatures include: \n1. Custom contents created by the community\n2. Casual and competitive game modes\n3. 16 players GroundWar\n4. Intense offline and online co-op missions. \n5. Challenging zombie survival mode with up to 4 players\n6. Over 30 different weapons to choose from\n7. World War 2 and Ninja loadout\n8. Customizable loadout system\n9. Cross-play across Quest and Rift platforms\n10. Cross Platform social system\n11. Target practice hub area.", "short_description": "Contractors is a fast-paced military shooter game, with online competitive game modes and coop missions."}, {"images": {"nodes": []}, "id": "226029389926965", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Contractors", "keywords": ["Tir", "Guerre", "Simulation", "Action", "Multijoueur"], "long_description": "\u00ab Contractors VR \u00bb est un FPS de guerre en r\u00e9alit\u00e9 virtuelle multijoueur et comp\u00e9titif. D\u00e9couvrez un champ de bataille en r\u00e9alit\u00e9 virtuelle perfectionn\u00e9, avec des combats intenses, des missions en coop, des armes l\u00e9tales et un \u00e9quipement personnalisable.\r\nPrincipales caract\u00e9ristiques :\r\n1. Des modes de jeu d\u00e9tente et comp\u00e9titifs.\r\n2. Des missions intenses hors ligne et en coop en ligne.\r\n3. Un mode survie plein de d\u00e9fis pouvant accueillir jusqu'\u00e0 4 joueurs.\r\n4. Plus de 30 armes \u00e0 tester.\r\n5. Un syst\u00e8me d'\u00e9quipement personnalisable.\r\n6. Un cross-play entre les plateformes Quest et Rift.\r\n7. Une zone de hub pour s'entra\u00eener au tir.", "short_description": "\u00ab Contractors \u00bb est un FPS de guerre bourr\u00e9 d'action proposant des modes comp\u00e9titifs et des missions coop en ligne."}, {"images": {"nodes": []}, "id": "215256241508880", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Contractors", "keywords": ["shooter", "Milit\u00e4r", "Simulation", "Action", "Mehrspieler"], "long_description": "\u201eContractors VR\u201c ist ein kompetitiver Mehrspieler-Milit\u00e4rshooter in VR. Erlebe ein v\u00f6llig neues VR-Schlachtfeld mit intensiven Schusswechseln, Koop-Missionen, t\u00f6dlichen Waffen und anpassbaren Ausr\u00fcstungen.\nFeatures: \n1. Modi f\u00fcr kompetitive Spieler und Gelegenheitsspieler\n2. Intensive Offline- und Online-Koop-Missionen\n3. Herausfordernder \u00dcberlebensmodus f\u00fcr bis zu 4 Spieler\n4. Auswahl aus mehr als 30 unterschiedlichen Waffen\n5. Anpassbares Ausr\u00fcstungssystem\n6. Crossplay auf den Quest- und Rift-Plattformen\n7. Zentraler Hub mit Ziel\u00fcbungen", "short_description": "\u201eContractors\u201c ist ein schneller Milit\u00e4rshooter mit kompetitiven Online-Spielmodi und Koop-Missionen."}, {"images": {"nodes": []}, "id": "198034279919181", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u30b3\u30f3\u30c8\u30e9\u30af\u30bf\u30fc\u30ba", "keywords": ["\u30b7\u30e5\u30fc\u30c6\u30a3\u30f3\u30b0", "\u30df\u30ea\u30bf\u30ea\u30fc", "\u30b7\u30df\u30e5\u30ec\u30fc\u30b7\u30e7\u30f3", "\u30a2\u30af\u30b7\u30e7\u30f3", "\u30de\u30eb\u30c1\u30d7\u30ec\u30a4"], "long_description": "\u300c\u30b3\u30f3\u30c8\u30e9\u30af\u30bf\u30fc\u30baVR\u300d\u306f\u30b3\u30f3\u30da\u30c6\u30a3\u30c6\u30a3\u30d6\u30de\u30eb\u30c1\u30d7\u30ec\u30a4\u578b\u306eVR\u30df\u30ea\u30bf\u30ea\u30fc\u30b7\u30e5\u30fc\u30c6\u30a3\u30f3\u30b0\u30b2\u30fc\u30e0\u3067\u3059\u3002\u6b21\u4e16\u4ee3VR\u304c\u63cf\u304d\u51fa\u3059\u6226\u5834\u3067\u3001\u6fc0\u3057\u3044\u9283\u6483\u6226\u3084CO-OP\u30df\u30c3\u30b7\u30e7\u30f3\u3092\u4f53\u9a13\u3057\u307e\u3057\u3087\u3046\u3002\u5f37\u529b\u306a\u6b66\u5668\u3068\u30ab\u30b9\u30bf\u30de\u30a4\u30ba\u53ef\u80fd\u306a\u88c5\u5099\u3067\u6226\u3044\u629c\u304f\u306e\u3067\u3059\u3002\n\u4e3b\u306a\u7279\u5fb4: \n1. \u30ab\u30b8\u30e5\u30a2\u30eb\u3068\u30b3\u30f3\u30da\u30c6\u30a3\u30c6\u30a3\u30d6\u306e\u96e3\u6613\u5ea6\u3092\u9078\u3079\u308b\u30b2\u30fc\u30e0\u30e2\u30fc\u30c9\u3002\n2. \u30aa\u30f3\u30e9\u30a4\u30f3\u3068\u30aa\u30d5\u30e9\u30a4\u30f3\u306e\u4e21\u65b9\u3067\u697d\u3057\u3081\u308b\u523a\u6fc0\u7684\u306aCO-OP\u30df\u30c3\u30b7\u30e7\u30f3\u3002\n3. \u6700\u59274\u4eba\u306e\u30d7\u30ec\u30a4\u30e4\u30fc\u306b\u3088\u308b\u96e3\u6613\u5ea6\u306e\u9ad8\u3044\u30b5\u30d0\u30a4\u30d0\u30eb\u30e2\u30fc\u30c9\u3002\n4. \u9078\u3079\u308b\u6b66\u5668\u306f30\u7a2e\u985e\u4ee5\u4e0a\u3002 \n5. \u30ab\u30b9\u30bf\u30de\u30a4\u30ba\u53ef\u80fd\u306a\u88c5\u5099\u3002\n6. Quest\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u3068Rift\u30d7\u30e9\u30c3\u30c8\u30d5\u30a9\u30fc\u30e0\u306e\u30af\u30ed\u30b9\u30d7\u30ec\u30a4\u306b\u5bfe\u5fdc\u3002\n7. \u5c04\u6483\u7df4\u7fd2\u3092\u884c\u3048\u308b\u30cf\u30d6\u30a8\u30ea\u30a2\u3002", "short_description": "\u300c\u30b3\u30f3\u30c8\u30e9\u30af\u30bf\u30fc\u30ba\u300d\u306f\u30b9\u30d4\u30fc\u30c9\u611f\u3042\u3075\u308c\u308b\u30df\u30ea\u30bf\u30ea\u30fc\u30b7\u30e5\u30fc\u30c6\u30a3\u30f3\u30b0\u30b2\u30fc\u30e0\u3067\u3059\u3002\u30aa\u30f3\u30e9\u30a4\