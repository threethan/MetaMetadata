ile_name": "4.png", "id": "975198817093493", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57566693_975198820426826_7097624739394196541_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TNXH5Q54SlwQ7kNvgGp7MZU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD9sxfI1s96vxdiJ7GOSjghDWo3j9f5EqJAgl4_qxTj3g&oe=6730828C"}, {"file_name": "1.png", "id": "415893571368646", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001715_415893574701979_3461447245540982035_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5GOVuf9MWPsQ7kNvgH8IN-I&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCeXmfztEJloaujqWpQ4ZbP0odhxVqceSu1FpcK4CQk8w&oe=67309DD6"}, {"file_name": "8.png", "id": "1225052075535021", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/65396729_1225052078868354_6945820870147360559_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jyzl2p1Ga68Q7kNvgE_1EP7&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCmyAyt_i-dWvoK8U5GTLjAMJfVpGL_T0y76ND96rCx8Q&oe=673080DE"}, {"file_name": "2.png", "id": "457815206622098", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75210399_457815209955431_6948775186918221287_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=spFUjZPb0kEQ7kNvgGhx99m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCRg9S1VmiNQIyHU8qrKemtwjw3ciQAmC87U3DLSN9ycw&oe=6730AE6A"}, {"file_name": "3.png", "id": "662596896051796", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974523_662596899385129_8527079563659693432_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C3-4VzoKzQoQ7kNvgGxdPcY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA-s7pey4GG2UbC1GTCB8ABJH-cBrXm-1tuiuahjOhzXA&oe=67309C54"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gameplayVR3.png", "id": "492345567046352", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974804_492345570379685_6511341930176300148_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fa5iT-Yl2SoQ7kNvgEXv_kd&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC__s65XjT7ezDi0D_uiZnocNpZvfUKUoTP7Fg90ItNDQ&oe=6730A7AD"}, "display_name": "Escape Simulator", "keywords": ["escape", "room", "coop", "simulator", "puzzle"], "long_description": "Escape Simulator is a first-person puzzler you can **play solo or in an cross platform online co-op** (best with 2-3 players, but playable with up to 8!). Explore a growing set of **highly interactive escape rooms**. Pick up and examine everything, break objects, solve locks, and decipher puzzles to escape! After finishing the main game, watch for free content updates and explore rooms **built by our awesome community**.\n\n# \u2b50**REVIEWS** \n\"What I've seen has left me considerably impressed.\" - UploadVR\n\n# \u2692\ufe0f**COMMUNITY-MADE ROOMS**\nAfter finishing the main game **explore numerous rooms** built by our amazing Steam community. New rooms every Friday!\n\n# \ud83e\udd1d**CROSS-PLATFORM CO-OP**\nAll rooms are playable in a cross platform online co-op. Play with up to 8 players (best played with 2-3) on PC, Quest 2 and 3. Customize your character and join friends to solve puzzles together. More heads are better than one! \n\n# \ud83e\udde9**INTERACTIVE PUZZLES**\nExplore 21+ official rooms filled with puzzles designed by real-life escape room operators. If it\u2019s not nailed down, you can pick it up.\n\n# \ud83d\udd0d**EXEMINE EVERYTHING**\nRead books, examine ancient artifacts, and find clues to riddles. Need to cross-reference a clue? No problem - just pin it!\n\n# \ud83c\udfc6**MORE COMING VERY SOON!** \nThe game is getting even more content in a form of free rooms & addons: \n- **Steampunk**: Solve four new rooms on the beautiful steampunk airship \"Valor.\"\n- **Wild West**: Become an outlaw in the Wild West.\n- **Magic**: Embrace your magic potential, and follow in the footsteps of great witches and wizards. \n\n", "short_description": "First-person puzzler you can play solo or in an online co-op. Explore a set of highly interactive escape rooms. Move furniture, pick up and examine everything, smash pots and break locks! Supports community rooms through the level editor."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pinestudio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Pine Studio", "support_website_url": "https://pinestudio.com/contact/", "website_url": "https://pinestudio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_HK", "zh_TW", "fr", "de", "it", "ja", "ko", "pt_BR", "pt", "es_MX", "es", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8391957634193202"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035437_262112640261132_151828284577000246_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8RSrBrCDOIQQ7kNvgGeyB3j&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBN7-lgdBBr-xIEbDUZ5x74GrRkuycDj9KsK09C_keslg&oe=67308217"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Escape Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Puzzle", "id": "377978390272490"}], 