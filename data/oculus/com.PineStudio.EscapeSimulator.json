"2560 x 1440px_2.png", "id": "320238073833003", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38984445_320238077166336_4108859041842358382_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MPml0pNwuSwQ7kNvgHx941q&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCex_cyK2MUZJGLN2EsepPlUcbvkV2oErp-FmCBBZqwzg&oe=67125659"}, {"file_name": "1400x1400Art.png", "id": "262112626927800", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39035437_262112640261132_151828284577000246_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRg3rqo958AQ7kNvgHAdIKZ&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDykpsiEjhgLNE3rU0s0iQ9RU2PSWRXqlmKPA0SJfWU2w&oe=67122F97"}]}, "id": "1040214757378097", "locale": "en_US", "screenshots": [{"file_name": "2.png", "id": "457815206622098", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75210399_457815209955431_6948775186918221287_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wceDpQ9FP04Q7kNvgF1WtHC&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYA6VUcg5TU2iC3VcyW2aCxnPfmY_G-LULQpTJ8e93-6Xg&oe=67125BEA"}, {"file_name": "8.png", "id": "1225052075535021", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/65396729_1225052078868354_6945820870147360559_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZuXrBuKfHIQ7kNvgHLURB7&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAqWevwSZK9xnCrkJtWFbrwY5u0Fov6j4i0MI6x45T26A&oe=67122E5E"}, {"file_name": "4.png", "id": "975198817093493", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/57566693_975198820426826_7097624739394196541_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wC4-SIqK0G0Q7kNvgELOvuQ&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDBJmKUZ1SOwg0jVTkTDe-MRhkq1ZsmNiqGVbJsIqjN1Q&oe=6712300C"}, {"file_name": "1.png", "id": "415893571368646", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39001715_415893574701979_3461447245540982035_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UpXAlPxf7wcQ7kNvgGC_nKW&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYC-fAh2LOpC7pwB8ubL03UJynb861SBZVr76esGiNTD0A&oe=67124B56"}, {"file_name": "3.png", "id": "662596896051796", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974523_662596899385129_8527079563659693432_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TBIRNbY_Ff8Q7kNvgEAbvkb&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAyL5N7xcTXSkpVLs5U5TQsxA595uQdmxu3smx5eUXCmQ&oe=671249D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gameplayVR3.png", "id": "492345567046352", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974804_492345570379685_6511341930176300148_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B3ssl9GNPGQQ7kNvgFHA7V4&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAunsIMR0nFjTqIo90X-zwWoL0NIyIJQL42RCVbGJQagw&oe=6712552D"}, "display_name": "Escape Simulator", "keywords": ["escape", "room", "coop", "multiplayer", "simulator"], "long_description": "Escape Simulator is a first-person puzzler you can **play solo or in an online co-op** (best with 2-3 players, but playable with up to 8!). Explore a growing set of **highly interactive escape rooms**. Pick up and examine everything, break objects, solve locks, and decipher puzzles to escape! After finishing the main game, watch for free content updates and explore rooms **built by our awesome community**.\n\n# \u2b50**REVIEWS** \n\"What I've seen has left me considerably impressed.\" - UploadVR\n\n# \u2692\ufe0f**COMMUNITY-MADE ROOMS**\nAfter finishing the main game **explore numerous rooms** built by our amazing community.\n\n# \ud83e\udd1d**ONLINE CO-OP**\nAll rooms are playable in an online co-op. Play with up to 8 players (best played with 2-3). Customize your character and join friends to solve puzzles together. More heads are better than one!\n\n# \ud83e\udde9**INTERACTIVE PUZZLES**\nExplore 28+ official rooms filled with puzzles designed by real-life escape room operators. If it\u2019s not nailed down, you can pick it up.\n\n# \ud83d\udd0d**EXEMINE EVERYTHING**\nRead books, examine ancient artifacts, and find clues to riddles. Need to cross-reference a clue? No problem - just pin it!\n\n# \ud83c\udfc6**WANT MORE?**\nThe game features additional content in the form of Addons with 4 large rooms each: \n- **Steampunk**: Solve four new rooms on the beautiful steampunk airship \"Valor.\"\n- **Wild West**: Become an outlaw in the Wild West.\n- **Magic**: Embrace your magic potential, and follow in the footsteps of great witches and wizards. \n\n", "short_description": "First-person puzzler you can play solo or in an online co-op. Explore a set of highly interactive escape rooms. Move furniture, pick up and examine everything, smash pots and break locks! Supports community rooms through the level editor."}]}, "developer_name": null, "developer_privacy_policy_url": "https://pinestudio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Pine Studio", "support_website_url": "https://pinestudio.com/contact/", "website_url": "https://pinestudio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_HK", "zh_TW", "fr", "de", "it", "ja", "ko", "pt_BR", "pt", "es_MX", "es", "tr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8102822136440088"