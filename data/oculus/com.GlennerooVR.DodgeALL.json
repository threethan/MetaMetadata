own levels.", "short_description": "DODGE ALL THE THINGS! Use your body to move around your play space to dodge obstacles coming at you from everywhere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://dodgeall.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "GlennerooVR LLC", "support_website_url": "https://www.dodgeall.com/contact/", "website_url": "https://www.dodgeall.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2776542286000603"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8148433558591486"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974439_946695660655669_4162065645042705343_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Osr0R4f0Ea0Q7kNvgFTy4zy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBVyChTgjWzoizqBbr2o-UdUzUqof5_Cx1ifbbRa1lauQ&oe=6763F13F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DodgeALL", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Survival", "id": "644354873106712"}], "release_date": 1728582540, "lastRevision": {"nodes": [{"id": "5477835492317986", "release_typ