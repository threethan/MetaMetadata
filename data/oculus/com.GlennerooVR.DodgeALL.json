uluscdn.com&oh=00_AYCw6OorSx9rLvxqOCuWdzVtLzqn2ENI6wZAxjduL9y5FA&oe=6739C2F0"}, {"file_name": "vlcsnap-2024-07-26-18h06m56s734.png", "id": "1015866550329656", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031656_1015866556996322_7240666593516287157_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZDyflQXGn3cQ7kNvgF5Cikf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIHNEjTVwm7Bv0Bhr6v0KNZsan___IgwwK--3LY5Eo_w&oe=6739B95D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Master comp (cover_art_landscape_2560x1440)_BEHIND_vB-02.png", "id": "1011953627287113", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031608_1011953630620446_8286352629206095362_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hn6j8hgYZdwQ7kNvgE3cC0g&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBofK_0PQncY9lV23O3Q58sr-XDNLmAM7GCxeOYAEhOwQ&oe=6739CF60"}, "display_name": "DodgeALL", "keywords": ["Sport", "Action", "Dodge", "Physical", "Fitness"], "long_description": "*DodgeALL* is a high-intensity VR game that puts your agility and reflexes to the test. Engage in a world where the only rule is to dodge everything that comes your way! With immersive 3D environments and physics-based gameplay, each level presents a new challenge, offering endless replayability. Dodge, weave, and strategize in this adrenaline-fueled game, where your skill determines your survival. \n\nAre you ready to DodgeALL?\n\n# Features include:\n- Room-scale & 360 degrees: Where you can move IRL is where you can move in-game.\n- 3D Spatial Audio: Gives audible cues where obstacles are coming from.\n- Abilities: 5 different unlockable abilities to help when you're lazy.\n- Endless Mode: Play any unlocked level until you drop. Each iteration gets progressively faster.\n- Leaderboards: Compare your dodging skills to other players.\n- Interactive Twitch mode: Let your viewers throw things at you!\n- Custom levels: Design your own levels.", "short_description": "DODGE ALL THE THINGS! Use your body to move around your play space to dodge obstacles coming at you from everywhere."}]}, "developer_name": null, "developer_privacy_policy_url": "https://dodgeall.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "GlennerooVR LLC", "support_website_url": null, "website_url": "https://www.dodgeall.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7966366353464875"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974788_812747210287449_4775042150579634429_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JM-b93lpEVAQ7kNvgG--iD9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBSBK7qrOi2dxdrUKGy-KHX_DlK1DdA5o1ieqlaIZLTHA&oe=6739DA09"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DodgeALL", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1728582540, "lastRevision": {"nodes": [{"id": "5477835492317986", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5477835475651321", "is_first_par