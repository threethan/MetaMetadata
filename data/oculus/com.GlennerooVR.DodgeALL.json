ienPlanet > Virus03 now launches in an arc instead of straight line.\nCHANGE: Pirates > CannonBall now bounces on platform.", "created_date": 1725412909, "id": "7475591059209076", "version": "0.40.2.0", "version_code": 598, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}