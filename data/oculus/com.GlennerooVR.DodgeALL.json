.com/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "GlennerooVR LLC", "support_website_url": null, "website_url": "https://www.dodgeall.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7267329153368602"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1231507447541804"}]}, "baseline_offer": {"id": "1231507447541804"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728582540, "status": "PUBLISHED", "id": "1231507447541804"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7475591059209076", "version": "0.40.2.0"}, "id": "2493148167513843", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5477835475651321", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7475591059209076"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2493148167513843"}]}, "change_log": "FEATURE: Pirates boss level can now be completed by hitting other ships with bouncing CannonBalls.\nBUGFIX: Arena no longer casts shadows on bridges.\nBUGFIX: Bridges are no longer created whe