160273775_6419788065856305808_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Js_LzSfXEm8Q7kNvgHkqmcQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCK8WnOlWaq96my8UAx3fVLh7kqwicqr5bX6651wB35vQ&oe=6762C13C"}, {"file_name": "TESTING_Custom..._27.09.2024_15-28-40.png", "id": "1050416876643524", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982699_1050416879976857_2541298537873682018_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KeagALpYO_gQ7kNvgE7e_pS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA45h9SOhjm22rjWh58JM7U3oxRDv-lZLh1Inf0cFXuNQ&oe=6762CAD7"}, {"file_name": "TESTING_Custom..._27.09.2024_15-29-07.png", "id": "1051814829912246", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001719_1051814833245579_2292447559769007296_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6CNznkXapVQQ7kNvgHUjJda&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0vwxcRnULZ8xEXVRJJC5iaJ-ueY7hCqH-BHVwZTwouA&oe=6762B51B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PVP_Custom..._03.09.2024_18-19-46.png", "id": "878374677686772", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297581_878374681020105_5346817692899346482_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RLX6pueqRtUQ7kNvgEnmIlV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrjOWYrFF4M0huTHfrNOQCBbm4pom-7yVTYhBFm9m58Q&oe=6762B0CC"}, "display_name": "Chimp Chambers PvP", "keywords": [], "long_description": "Chimp Chambers PvP is an exciting and unique virtual reality multiplayer game that takes you on an adventure with your friends as you play as a Chimp's. Jump, run, and explore with your friends through four different maps: Forest, Shop, and Horror. With more maps to come soon, you'll never run out of new places to explore! Challenge your friends to races, obstacle courses, and other fun challenges. With realistic graphics, you'll feel like you're really in the game. So grab your friends and join the adventure in Chimp Chamb