48616_8902619268996763540_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OHTJcJimeiAQ7kNvgEaaGub&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCi2srqnA4z0Avlo3XYsFNNuVVQuDCjfja6Xy8EVxYQ1w&oe=6702605B"}, {"file_name": "2.png", "id": "422654703964695", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982659_422654707298028_5742817564110713231_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aWCHGwM710oQ7kNvgHFwrbA&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBz6dmzcyVkUY0y0HeTaEXX5TwdqXrRWQBjkrrzYuUVrA&oe=670281F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Olympic Ring Toss Cover Art - Video Cover (4).png", "id": "369271119076220", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75203625_369271122409553_4178350087346444669_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PkHEFVcacL4Q7kNvgG6TMcc&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCqQ3Z7582cwXp6spZIYeQ54c5piBcXjEuHcwTn60Dnqg&oe=67026A0F"}, "display_name": "Olympic Ring Toss", "keywords": [], "long_description": "Celebrate the excitement of the Paris 2024 Olympics with Olympic Ring Toss, an immersive mixed reality game exclusively on Meta Quest! Step into the vibrant world of the Olympics and test your skills as you aim to toss rings around a miniature Eiffel Tower.\n\n**Gameplay Features:**\n\n- **Intuitive Controls:** Use your hands to grab and toss rings in a realistic mixed reality environment.\n- **Practice Mode:** Perfect your aim and strategy without the pressure of time.\n- **Timed Mode:** Challenge yourself to score as high as possible within 60 seconds.\n- **Wind Force:** Increase difficulty by activating side-to-side wind force.\n- **Parisian Charm:** Enjoy the beautiful backdrop of a miniature Eiffel Tower, bringing the spirit of Paris 2024 right into your living room.\n\nWhether you're a casual gamer looking for some fun or a competitive player aiming for the top score, Olympic Ring Toss offers a unique and thrilling experience that brings the magic of the Olympics to life. Grab your Meta Quest and join the celebration!", "short_description": "Celebrate the excitement of the Paris 2024 Olympics with Olympic Ring Toss, an immersive mixed reality game exclusively on Meta Quest! Step into the vibrant world of the Olympics and test your skills as you aim to toss rings around a miniature Eiffel Tower!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisanreality.com/privacy-policy-for-olympic-ring-toss", "developer_terms_of_service_url": null, "publisher_name": "Artisan Effects", "support_website_url": null, "website_url": "https://artisanreality.com/olympic-ring-toss", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26161096950203840"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/86624163_1412423196819945_139219939353204253_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8kA1Nth3gp8Q7kNvgEY7sTO&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAVc7w_uTuTqgC376_QiJsfnPTGBWmzCA6-S-TqrSEIvw&oe=6702690F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Olympic Ring Toss", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "27765