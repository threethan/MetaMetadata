3-3.oculuscdn.com&oh=00_AYBx4huHVw2nRRwgzygID5d1RJFPO-dmpRVNlkg9Vz6BzA&oe=676024BC"}, {"file_name": "3.png", "id": "2259244384415283", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/54770912_2259244387748616_8902619268996763540_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=72pE4VZf1X0Q7kNvgGeRBaC&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBNUXKd0hwkzqiFZyHR1Bpb00S6re93ey1sI898Sg7USQ&oe=675FFADB"}, {"file_name": "2.png", "id": "422654703964695", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982659_422654707298028_5742817564110713231_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oby5NPdKJW4Q7kNvgFl_S7i&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAhxAX04Pszgi1M33KmWKuzgKM7PicKACVoXV6-8U8fvQ&oe=67601C72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Olympic Ring Toss Cover Art - Video Cover (4).png", "id": "369271119076220", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75203625_369271122409553_4178350087346444669_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BQrRzMZgIIYQ7kNvgEjltQC&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBrIN5RqtqgekojiFwCFQAUrvDjf8P3fxFh2jmDd0gbIA&oe=6760048F"}, "display_name": "Olympic Ring Toss", "keywords": [], "long_description": "Celebrate the excitement of the Paris 2024 Olympics with Olympic Ring Toss, an immersive mixed reality game exclusively on Meta Quest! Step into the vibrant world of the Olympics and test your skills as you aim to toss rings around a miniature Eiffel Tower.\n\n**Gameplay Features:**\n\n- **Intuitive Controls:** Use your hands to grab and toss rings in a realistic mixed reality environment.\n- **Practice Mode:** Perfect your aim and strategy without the pressure of time.\n- **Timed Mode:** Challenge yourself to score as high as possible within 60 seconds.\n- **Wind Force:** Increase difficulty by activating side-to-side wind force.\n- **Parisian Charm:** Enjoy the beautiful backdrop of a miniature Eiffel Tower, bringing the spirit of Paris 2024 right into your living room.\n\nWhether you're a casual gamer looking for some fun or a competitive player aiming for the top score, Olympic Ring Toss offers a unique and thrilling experience that brings the magic of the Olympics to life. Grab your Meta Quest and join the celebration!", "short_description": "Celebrate the excitement of the Paris 2024 Olympics with Olympic Ring Toss, an immersive mixed reality game exclusively on Meta Quest! Step into the vibrant world of the Olympics and test your skills as you aim to toss rings around a miniature Eiffel Tower!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://artisanreality.com/privacy-policy-for-olympic-ring-toss", "developer_terms_of_service_url": null, "publisher_name": "Artisan Effects", "support_website_url": null, "website_url": "https://artisanreality.com/olympic-ring-toss", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26161096950203840"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/86624163_1412423196819945_139219939353204253_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t3iN6xsbzpoQ7kNvgHHIKrB&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBtDVww3HXQx3_zhtx_jw2b1OnQFk1xGjNoohl3DWdzyQ&oe=6760038F"}, "is_concept": fals