t64.5771-25/38974626_229341219688879_8855335381352838646_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=52e_3237uFgQ7kNvgGbDVBo&_nc_ht=scontent.oculuscdn.com&oh=00_AYAKqx__E5Dps-ys9UF_q6OYE-nAT6GgKAD0iIlVjmL42A&oe=66F15CF0"}, {"file_name": "2.png", "id": "623996265823309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031542_623996269156642_306575761543613007_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzEOxAbfGFsQ7kNvgHw-tHS&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPzoSTp4cPquitmY-8Tn5DLukBS2cq_Gee6FEaFXRgDw&oe=66F16C22"}, {"file_name": "5.png", "id": "202071012569172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_202071015902505_6130434384487279671_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E-wCNoTRWjMQ7kNvgENC6Lg&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZRXpmhdwsYND0-hCZkM6AUcBg7jL5bb2z8fe3h9zB4A&oe=66F1446C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "4.png", "id": "957698088745851", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_957698092079184_7037937944838343346_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cfOqArNfKEQQ7kNvgGawRR5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaLGOkRNtREL9zipv70-frfbkCv0H4kwug4GUnAGcrBg&oe=66F168EF"}, "display_name": "highrescue", "keywords": [], "long_description": "\"highrescue\" is a virtual reality game in which you can prove your skills as an astronaut rescuer in 4 different levels. \n\nTo achieve the best results, we recommend starting with the training level.  \n\nEach mission always starts with different initial conditions. The position of the astronauts in space varies. The supply of oxygen can also be different. Therefore, keep calm and get an overview of the situation first.  First supply the astronauts who need it most with oxygen. Save the astronauts with the highest priority who have the least oxygen left. \n\nAlso pay attention to your health and the energy level of your jet stream. Good luck on your adventures. ", "short_description": "\"highrescue\" is a virtual reality game in which you can prove your skills as an astronaut rescuer in 4 different levels. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://highlewelt.com/privacy_highrescue.html", "developer_terms_of_service_url": null, "publisher_name": "highlewelt GmbH", "support_website_url": null, "website_url": "https://highlewelt.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "183622331264052"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "872750657414193"}, {"status": "PUBLISHED", "id": "1565276393994116"}]}, "baseline_offer": {"id": "872750657414193"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1699383817, "status": "PUBLISHED", "id": "872750657414193"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6847214758638662", "version": "2.0"}, "id": "179075118375766", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6833381176688687", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6847214758638662"}, "release_status": "RELEASED"}, "binary_r