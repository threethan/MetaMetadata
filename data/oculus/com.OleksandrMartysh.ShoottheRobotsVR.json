try escape your gun-point in any way: running, jumping, crawling, riding cars. Take your favourite pistol into your hand, and enjoy sophisticated animations of how robots fall from your well-aimed shots\n\nKey game features:\n- Super enjoyable robots death aniamtions\n- Futuristic city environment\n- A lot of 'Mods' to customize your game experience in radical way", "short_description": "Do you love shooting? What about robots? And what about shooting the robots? In this fast-paced game you have to use a well-aimed shots to neutralize robots which will run away from you in every possible way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/shoot-the-robots-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Martysh", "support_website_url": null, "website_url": "https://sites.google.com/view/shoot-the-robots-vr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6563093763799979"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "246660481762639"}, {"status": "PUBLISHED", "id": "3668323656716531"}]}, "baseline_offer": {"id": "3668323656716531"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709272800, "status": "PUBLISHED", "id": "246660481762639"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "bina