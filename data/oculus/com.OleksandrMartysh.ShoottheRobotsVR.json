shot (1).png", "id": "3638913266395979", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_3638913269729312_5856549257956450824_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OQjGDPAVxR4Q7kNvgHzXENL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDaeWLeghO9klocJovCcCUHyZxkcwX8-dLtjdouK-Jjww&oe=66E6D8A3"}, {"file_name": "Oculus Screenshot (4).png", "id": "2733572393460707", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036608_2733572396794040_313492660194021754_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYoqxq6-o38Q7kNvgGAaSDp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhlmUngK0VHnq0tBIqGnCTxyL0e8RkLeTuMQ6UGRCMCw&oe=66E6AD0E"}, {"file_name": "Oculus Screenshot (2).png", "id": "6882517855134571", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_6882517861801237_7491338628550035453_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0uqDKYLTuuQQ7kNvgGQHcjr&_nc_ht=scontent.oculuscdn.com&oh=00_AYD9WGSxeTTjlEDryLHf3poY80ynWe6un2ca8mZQR2IexQ&oe=66E6C9E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus Screenshot (5).png", "id": "1502415067247993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001670_1502415070581326_41715781668599962_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2EAe7Y0nvdoQ7kNvgGgxQdv&_nc_ht=scontent.oculuscdn.com&oh=00_AYCfGY4s_Be1gW8UUMS_pB8EWNyxWUO6GX3qH-4MjX120A&oe=66E6C257"}, "display_name": "Shoot the Robots", "keywords": [], "long_description": "Good old 'shoot-em-all' returns, now in VR! Now in futuristic environment filled by robots, drones and flying cars!\n\nIn this fast-paced game you have to shoot the running robots, who try escape your gun-point in any way: running, jumping, crawling, riding cars. Take your favourite pistol into your hand, and enjoy sophisticated animations of how robots fall from your well-aimed shots\n\nKey game features:\n- Super enjoyable robots death aniamtions\n- Futuristic city environment\n- A lot of 'Mods' to customize your game experience in radical way", "short_description": "Do you love shooting? What about robots? And what about shooting the robots? In this fast-paced game you have to use a well-aimed shots to neutralize robots which will run away from you in every possible way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/shoot-the-robots-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Martysh", "support_website_url": null, "website_url": "https://sites.google.com/view/shoot-the-robots-vr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6563093763799979"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "246660481762639"}, {"status": "PUBLISHED", "id": "3668323656716531"}]}, "baseline_offer": {"id": "3668323656716531"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1709272800, "status": "PUBLISHED", "id": "246660481762639"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6985751704867514", "version": "1"}, "id": "1407487926848345", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6563093747133314", "is_concept": false, "latest_released_binary": {"__type