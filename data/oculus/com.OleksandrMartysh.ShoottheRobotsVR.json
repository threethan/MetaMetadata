1).png", "id": "3638913266395979", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_3638913269729312_5856549257956450824_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QFWZfSykSj4Q7kNvgE03OEg&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgBB56J66VsT-7mt_a_Ohcl8EGIKFWar1nTNOcwNcLFA&oe=66FBF0A3"}, {"file_name": "Oculus Screenshot (4).png", "id": "2733572393460707", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036608_2733572396794040_313492660194021754_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_DTlcDGBadYQ7kNvgHrw-io&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRfFNA8DcEgtw5Dy69i7M6igRg-Vt86LY9yqs2VzaEVQ&oe=66FBC50E"}, {"file_name": "Oculus Screenshot (2).png", "id": "6882517855134571", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031344_6882517861801237_7491338628550035453_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fgtVpP2OYVsQ7kNvgEn9Nvy&_nc_ht=scontent.oculuscdn.com&oh=00_AYCU-0_5r3UNWQIJM3EKSvavMan7T6000jk-H3cDoqkaSw&oe=66FBE1E4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus Screenshot (5).png", "id": "1502415067247993", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001670_1502415070581326_41715781668599962_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MTZO5ZwRqC8Q7kNvgHNJb9V&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrgai7B957Awn24yHDK_WU_pg2_YBMJGgjEHoqCPg-7w&oe=66FBDA57"}, "display_name": "Shoot the Robots", "keywords": [], "long_description": "Good old 'shoot-em-all' returns, now in VR! Now in futuristic environment filled by robots, drones and flying cars!\n\nIn this fast-paced game you have to shoot the running robots, who try escape your gun-point in any way: running, jumping, crawling, riding cars. Take your favourite pistol into your hand, and enjoy sophisticated animations of how robots fall from your well-aimed shots\n\nKey game features:\n- Super enjoyable robots death aniamtions\n- Futuristic city environment\n- A lot of 'Mods' to customize your game experience in radical way", "sh