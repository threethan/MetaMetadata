191083694208", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39036604_454191087027541_1520264469949419060_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpORXAbl0BgQ7kNvgFtaBUi&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDrXXIjckAEY6eWf0v8ABxbUGSHe_Y19jEfi_O3FEFQmA&oe=6729FDF9"}, {"file_name": "megafireball-screenshot2.png", "id": "808615271128686", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39031550_808615274462019_725203892941569946_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t0QbBwBfU-AQ7kNvgGt7vnv&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAl48x-9AqG-eIM_nzwlgWHg5ZYwbJkvZWR60XdVWsARA&oe=672A1B4A"}, {"file_name": "megafireball-screenshot3.png", "id": "1573013316829533", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39001672_1573013320162866_4797529111027989710_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uwxJIE9Jd1kQ7kNvgG-aZJG&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAxqIsAmg60tNBB8XqcaXipQvtcAoetFxmrjZwagOINVQ&oe=6729ED5F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mega-fireball-meta-thumbnail.png", "id": "297548626627266", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75203625_297548629960599_7897722605495133285_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VJqqxIZNeA0Q7kNvgEbOWza&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDk5ABwfXnQ1UKhKPA6eZs7thNgMU5UksRO6jbvYErPOw&oe=6729FDCD"}, "display_name": "Mega Fireball (Beta)", "keywords": ["passthrough", "mixed", "fireball", "soccer"], "long_description": "**Free for a limited time during Open Beta!**\n\nMega Fireball is the only mixed-reality game that turns your entire place into a playable space!\n\n**Mixed Reality Local Multiplayer**\n\nGrab a friend with a Quest device and play together in the same room or go solo against the AI in single-player mode. Slap, shoot, and smash the ball into the goal before your opponent to win! \n\n**Single Player**\n\nTake on our AI with several challenging tiers, practice up rookie, they know how to get around any room in your house!\n\n**One Goal, Many Shots**\n\nThere\u2019s only one net, but plenty of referees, fireguys, power-ups that\u2019ll get in your way! Fireguys will spread fire anywhere they touch including the ball! That\u2019s cool, you know why? Because fireballs score double points my friend! \n\n**ADVANCED MODE**\n\nQuit the button mashing and use your controllers (or head) to punch balls into the goal. Or use your left trigger to shoot water balloons at your opponent. Whatever it takes to win!", "short_description": "**Free for a limited time during Open Beta!**\n\nSlap, shoot, and smash your way to victory"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.luckyjuicebox.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Lucky Juicebox", "support_website_url": null, "website_url": "https://www.luckyjuicebox.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8274096762672762"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1647485852457155"}]}, "baseline_offer": {"id": "1647485852457155"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725903540, "status": "PUBLISHED", "id": "1647485852457155"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "bina