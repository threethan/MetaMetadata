29_347564237900126_6876275775432191798_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P9FUYjHz1GkQ7kNvgHqP9u9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuTeeqzZbk-WvkBtxNsPLnSAKz64-lt0z9wEBvCosxPQ&oe=66E95014"}, {"file_name": "mega-fireball-logo.png", "id": "325426557311550", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031450_325426560644883_7793862978609649211_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4CkiTbondKYQ7kNvgHxvpo6&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5TfJCyg9CWLVi5OIH0fYOjaS9is3WP76W_Fv4CXOQrw&oe=66E97DC8"}]}, "id": "7899010476877535", "locale": "en_US", "screenshots": [{"file_name": "megafireball-screenshot1.png", "id": "1359473408780309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035470_1359473412113642_1183086942426174673_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TgoN6JMJb0oQ7kNvgGgkdtH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNysZv_DbNZb3xLKRiKgwhqCYriDr024bkgqpk1WhdlQ&oe=66E970C9"}, {"file_name": "megafireball-screenshot4.png", "id": "244063662127058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035398_244063665460391_1875690423852693327_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rdfvx4QprRoQ7kNvgHqFsM4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBaQcNnPuT5zXkvR1r5sQ2hHMSjHNV2tVtn8hbgn9CoBw&oe=66E95F07"}, {"file_name": "megafireball-screenshot5.png", "id": "454191083694208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036604_454191087027541_1520264469949419060_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x--sSwW4bMMQ7kNvgEo8_mH&_nc_ht=scontent.oculuscdn.com&oh=00_AYC1Q-MhpRDoM8UAPsFHr8HbDQXmKTzpWwmqiK-47R8lBA&oe=66E96479"}, {"file_name": "megafireball-screenshot2.png", "id": "808615271128686", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031550_808615274462019_725203892941569946_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fnHxS1PM3wUQ7kNvgH4g3Q2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBwCYsjlZ3xgnPjM15M1_PZd8qXnEUrqhy6ZPUziirf1Q&oe=66E981CA"}, {"file_name": "megafireball-screenshot3.png", "id": "1573013316829533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_1573013320162866_4797529111027989710_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5HXMJK4CgW4Q7kNvgFpQ6Hl&_nc_ht=scontent.oculuscdn.com&oh=00_AYBb0qYPSDdijsCo1e06Trbep-81ZgKQo8PcuOIqOWnAQw&oe=66E953DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mega-fireball-meta-thumbnail.png", "id": "297548626627266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203625_297548629960599_7897722605495133285_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-E2hMl3sdqwQ7kNvgGmk-x5&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJ9qa6vom2ntmzEihGKkVVMGYPaZIeSQD320sCrMt6EA&oe=66E9644D"}, "display_name": "Mega Fireball (Beta)", "keywords": ["passthrough", "mixed", "fireball", "soccer"], "long_description": "**Free for a limited time during Open Beta!**\n\nMega Fireball is the only mixed-reality game that turns your entire place into a playable space!\n\n**Mixed Reality Local Multiplayer**\n\nGrab a friend with a Quest device and play together in the same room or go solo against the AI in single-player mode. Slap, shoot, and smash the ball into the goal before your opponent to win! \n\n**Single Player**\n\nTake on our AI with several challenging tiers, practice up rookie, they know how to get around any room in your house!\n\n**One Goal, Many Shots**\n\nThere\u2019s only one net, but plenty of referees, fireguys, power-ups that\u2019ll get in your way! Fireguys will spread fire anywhere they touch including the ball! That\u2019s cool, you know why? Because fireballs score double points my friend! \n\n**ADVANCED MODE**\n\nQuit the button mashing and use your controllers (or head) to punch balls into the goal. Or use your left trigger to shoot water balloons at your opponent. Whatever it takes to win!", "short_description": "**Free for a limited time during Open Beta!**\n\nSlap, shoot, and smash your way to victory"}]}, 