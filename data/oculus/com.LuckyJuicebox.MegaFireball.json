me": "megafireball-screenshot2.png", "id": "808615271128686", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031550_808615274462019_725203892941569946_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CN40jlgk0QwQ7kNvgFf4unP&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABacRnvLZAow34aYZzjtHvx&oh=00_AYA_U5XFJGpoygXAXPuTyN2lrMYrn2NuI-r1q7ZLWCSTXg&oe=66F0194A"}, {"file_name": "megafireball-screenshot3.png", "id": "1573013316829533", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001672_1573013320162866_4797529111027989710_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_4ldUfFGCgQ7kNvgFkyVO9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABacRnvLZAow34aYZzjtHvx&oh=00_AYASZEOyZtcUQ-K9-Azxu0RyxSyO9ayggRARAmAkHj1PzA&oe=66EFEB5F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "mega-fireball-meta-thumbnail.png", "id": "297548626627266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203625_297548629960599_7897722605495133285_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PbmP1UvP0ZYQ7kNvgFqLZxK&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABacRnvLZAow34aYZzjtHvx&oh=00_AYBQRixviyaawxgwn5VXyQYe5QvewIv6vSiKS8R65s2cwA&oe=66EFFBCD"}, "display_name": "Mega Fireball (Beta)", "keywords": ["passthrough", "mixed", "fireball", "soccer"], "long_description": "**Free for a limited time during Open Beta!**\n\nMega Fireball is the only mixed-reality game that turns your entire place into a playable space!\n\n**Mixed Reality Local Multiplayer**\n\nGrab a friend with a Quest device and play together in the same room or go solo against the AI in single-player mode. Slap, shoot, and smash the ball into the goal before your opponent to win! \n\n**Single Player**\n\nTake on our AI with several challenging tiers, practice up rookie, they know how to get around any room in your house!\n\n**One Goal, Many Shots**\n\nThere\u2019s only one net, but plenty of referees, fireguys, power-ups that\u2019ll get in your way! Fireguys will spread fire anywhere they touch including the ball! That\u2019s cool, you know why? Because fireballs score double points my friend! \n\n**ADVANCED MODE**\n\nQuit the button mashing and use your controllers (or head) to punch balls into the goal. Or use your left trigger to shoot water balloons at your opponent. Whatever it takes to win!", "short_description": "**Free for a limited time during Open Beta!**\n\nSlap, shoot, and smash your way to victory"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.luckyjuicebox.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Lucky Juicebox", "support_website_url": null, "website_url": "https://www.luckyjuicebox.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8274096762672762"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982440_1168634550813394_1328695584411408316_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=am7erq3rh58Q7kNvgHAoDr4&_nc_ht=scontent.oculuscdn.com&_nc_gid=ABacRnvLZAow34aYZzjtHvx&oh=00_AYCkj8FGnXk0GioFEbfhkznCqf5i0UNVI8hkKF3IU_qMpQ&oe=66EFF834"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mega Fireball (Beta)", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_nam