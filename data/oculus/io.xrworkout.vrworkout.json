.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NTaZg3H5CqUQ7kNvgFbRZrQ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxxoT4MJZuqNCNWonZ7hXvjml6HMY6rxG5_HD1hUPS4A&oe=670D0AB5"}, {"file_name": "screen3_auto_x2_colored_toned_light_ai.jpg.png", "id": "3422410544695300", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003227_3422410548028633_2782161710992601325_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxNrIgdNv0UQ7kNvgEK5jY4&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvUYd-slRZVY1B3MLgaEF4CBdEpMpCibzyJgAFdGg4CA&oe=670CF59C"}, {"file_name": "screen2_auto_x2_colored_toned_light_ai.jpg.png", "id": "887004912504237", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984455_887004915837570_4522940590059961806_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-FjFpHYf0ucQ7kNvgFFbox9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNBIMf8QVTQfoA0P9AZYw-V3a9DioSKq5HFnJLrbmKow&oe=670CEBA5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "reallyfit_thumb.png", "id": "3407462022845421", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974653_3407462026178754_8981674626759072485_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=09Ep6w6QPkUQ7kNvgFaq-lt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCoo6qS6oXQvYk8dMmg1bZNHl2f1ntHkmK5EAxb7H5iNg&oe=670CF6D9"}, "display_name": "VR Workout", "keywords": ["fitness", "workout", "gym", "health", "exercise"], "long_description": "Sprint. Squat. Jump. Crunch.\n\nVR Workout is the FULL-BODY FITNESS app of the future.\n\n\ud83d\udd90\ufe0fCONTROLLERLESS\n\ud83d\udcaaHIGH INTENSITY\n\ud83d\udc53MIXED REALITY\n\ud83e\uddd1\u200d\ud83e\udd1d\u200d\ud83e\uddd1MULTIPLAYER\n\ud83d\udce3LIVE CLASSES\n\n\u25b6\ufe0fExperience complete freedom of movement with a totally controllerless, hands-free experience, bringing you the most comprehensive and effective workout in virtual reality.\n\n\u25b6\ufe0fMove at your own pace, with intelligent exercise design that meets you where you\u2019re at, and safely pushes you to the limit.\n\n\u25b6\ufe0fChoose from eight immersive environments, from the heights of a glowing city skyline to the depths of a luminous cave.\n\n\u25b6\ufe0fOr use our state of the art mixed reality mode, with the full clarity of your immediate surroundings to support you.\n\n\u25b6\ufe0fMeet up with friends across the globe with our multiplayer experience, where you can challenge each other in competitive motion through a custom workout of your own design.\n\n\u25b6\ufe0fLevel up with our live classes, where you can push yourself in a group setting with one of our experienced instructors.\n\nHappy. Healthy. Social. Global. We do this together. \ud83d\udc4a\n\nWe Are Movement.", "short_description": "The ultimate full body fitness game that follows YOUR rules. Pushing the boundaries of movement in VR with hand tracking and rhythm based bodyweight exercises.\nJoin or build circles that workout together around the globe with multiplayer group workouts. \nWith a unique mixed reality passthrough workout for smaller spaces and a true gym in a bag if you take it on your next trip."}]}, "developer_name": null, "developer_privacy_policy_url": "https://xrworkout.io/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XRWorkout Inc", "support_website_url": "https://chat.vrworkout.at/", "website_url": "https://xrworkout.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ACTION", "MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["