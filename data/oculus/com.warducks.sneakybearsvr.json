 action adventure game is all you need to get involved in one of the most exciting adventures of all time. Finish the game to play against your friends in the leaderboard measured \u201cSurvival mode\u201d. This game just keeps giving...\n#dontletthemcatchya"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/377885", "developer_terms_of_service_url": "http://globalagents.warducks.com/about/terms.html", "publisher_name": "WarDucks LTD", "support_website_url": null, "website_url": "http://www.sneakybearsvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "328749599178416"}, "review_messages": ["", "Please remove the cardboard VR box from the end of your video. Also remove all the text overlays from your screenshots, we do not allow these in screenshots."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162737_1948439828761445_3792758135878320128_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RTtXyV7zwNAQ7kNvgHqIHmU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxQDSPQ80Una9xeR6lOYCDboKMkIPlcfpIgYAhf6BNXA&oe=66DAD883"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Sneaky Bears VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1480525353, "lastRevision": {"nodes": [{"id": "1578584052434140", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"a