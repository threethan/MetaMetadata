=quH9wlC70uoQ7kNvgE65J74&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlKrsMHFQVZXIYzwzQlt1icfuE_FS5u-F5e73nBEkzoA&oe=6731D86B"}, {"file_name": "migrated_image.png", "id": "519543012325134", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12410200_380138495730072_6437105380458758144_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DJHy5jBhS7IQ7kNvgEdilHb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqXU3PNQpf486aHjBKmkVK18xMus5j5PwUWRmpdE-sZQ&oe=673207BB"}, {"file_name": "migrated_image.png", "id": "226611475377680", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12534042_154466091904783_1012288985252233216_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hyR5VomQHoEQ7kNvgHwHFum&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYsU1UJqKjBCfGA6r8EFANSnY9Weyd6mZkMgD1KPLpTQ&oe=6731FC1D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videothumbnail.png", "id": "1954501114863988", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12504730_1954501118197321_8750639735501750272_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gPSeh3hTM2QQ7kNvgGgD25K&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAM_pTFZHHvQTtJoHzDmeKgUEgB_U23quj6DcWF8pzgAw&oe=6731DC03"}, "display_name": "Cat 'S' Trophy", "keywords": ["cat", "racing", "catstrophy", "catastrophe", "kart"], "long_description": "In Cat \u2018S\u2019 Trophy cats have races in honour of the ruler of the internet - the Cat God. Conveniently, all five cats in the game can turn into vehicles when the race begins. The gameplay of Cat \u2018S\u2019 Trophy consists of two parts; Part One is track drawing. The player draws the track where the cats will race. Part Two is the actual racing. In order to win the race, players need to gather \u201cstar crystals\u201d around the track and the lucky cat to gather the most star crystals from the track wins.\n\nWith references to popular culture and to memes, Cat \u2019S\u2019 Trophy has been designed to be approachable and engaging to a wide audience. The artwork, graphics and characterization are immersive and appealing, while gameplay has been designed to counter and minimize causes for motion sickness. There are no engines revving but cats purring before the start of the race too. Players both young and old are bound to enjoy Cat \u2019S\u2019 Trophy.", "short_description": "Welcome to the world of Cat 'S' Trophy; a cat kart racing game where cats turn into half cat, half vehicle and FULL AWESOME! Roll the cosmic ball of yarn to create tracks and race to collect STAR CRYSTALS to please the ALMIGHTY CAT GOD. Find the lost GOLDEN BURGERS and use weaponised cheeseburgers to win the Cat 'S' Trophy!"}]}, "developer_name": "Visible Realms", "developer_privacy_policy_url": "http://www.visiblerealms.com/", "developer_terms_of_service_url": "http://www.visiblerealms.com/", "publisher_name": "Visible Realms", "support_website_url": null, "website_url": "http://www.visiblerealms.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "RACING", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1907669476287371"}}]}, "scheduled_offers": {"count": 52, "nodes": [{"status": "PUBLISHED", "id": "604325853732973"}, {"status": "PUBLISHED", "id": "176825280426270"}, {"status": "PUBLISHED", "id": "2562125644068024"}, {"status": "PUBLISHED", "id": "2202520656737774"}, {"status": "PUBLISHED", "id": "371144324075633"}, {"status": "PUBLISHED", "id": "871735999990863"}, {"status": "PENDING", "id": "21364