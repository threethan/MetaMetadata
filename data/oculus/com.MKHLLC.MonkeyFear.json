d outrun other players in a battle of nerves and skill.", "short_description": "Monkey Fear is an adrenaline-pumping VR game where you take on the role of a monkey in a high-stakes game of tag. Explore a variety of unique levels, from eerie caves to towering skyscrapers and haunted forests. Each environment presents new challenges as you outmaneuver and escape from other players. Use your speed, agility, and quick thinking to survive. Will you conquer your fear, or will you be caught?"}]}, "developer_name": "Banana Blitz Studios", "developer_privacy_policy_url": "https://goldencarminelol.wixsite.com/banana-blitz-studios/contact", "developer_terms_of_service_url": null, "publisher_name": "Banana Blitz Studios", "support_website_url": null, "website_url": "https://goldencarminelol.wixsite.com/banana-blitz-studios", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7979517682102371"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8179747578746046", "version": "0.0.23"}, "id": "1193636765303133", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__type