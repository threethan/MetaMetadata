nt-iad3-1.oculuscdn.com&oh=00_AYDpXAqzguDzwBGnnf85CVaVk2XMKvY6w-U9FLNW19cCrA&oe=673B18E7"}, {"file_name": "Screenshot4.png", "id": "708869224255352", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974779_708869227588685_2869106126093839933_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j8rOJ3M_LWAQ7kNvgH0cun5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3AGm8KZqjUju4IQLmDZxqglmnPdLgnvU1gdDPVrWpEg&oe=673B3E2D"}, {"file_name": "TrailerCover.png", "id": "534773861901717", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031350_534773868568383_1567764472152410917_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GD6uWnCz-UYQ7kNvgGj-9V0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQYTA3rSYW9M7JYnSAa75CeyjMz9wG7OToTJm7YLuGdA&oe=673B0DF5"}, {"file_name": "Screenshot1.png", "id": "3057879474512333", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_3057879477845666_3909506663525550675_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YB_OLYczW6oQ7kNvgE8wD6t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAS782HF2Y8ipNDIO3KokDKqmpIdvVxiy7Lo5jfDLOMOA&oe=673B0B9A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Simli Lite", "keywords": [], "long_description": "Simli Lite is a limited version of the full Simli experience. Here you\u2019ll get a taste of what the full Simli experience has to offer. Explore one of our simulated social situations and customize your experience using our speech-to-text prompts. In the full Simli app, we have more than 10 social situations you can experience.\n\nWith Simli Lite, you\u2019ll get to experience a simulated job interview. Before you start, you\u2019ll get to choose what job you\u2019ve applied for and then get relevant questions from the interviewer. The interview will take place in an office with you and one character. Who knows, maybe you\u2019ll get hired?\n\nThere\u2019s no limit to how much you can test, so go ahead and test as much as you want. That way, we also get valuable feedback on what works and what doesn\u2019t. And hey, if you know someone who needs to practice their job interviewing skills, then share it with them too!\n\nTeam Simli\n", "short_description": "With Simli Lite you get to experience a Lite version of the full Simli experience. Here you can try one of our simulated social situations and experiment with speech-to-text to customize your training session. So what are you waiting for? See for yourself how real-seeming the conversations with our characters are."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.simli.com/privacy-policy-simli-vr", "developer_terms_of_service_url": null, "publisher_name": "Simli", "support_website_url": null, "website_url": "https://www.simli.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "nb"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "172026665622583"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "972520273738811"}]}, "baseline_offer": {"id": "972520273738811"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1682030649, "status": "PUBLISHED", "id": "972520273738811"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9737148116302746", "version": "23"}, "id": "2495536120594534", "channel_name": "LIVE"}]}, "is_for_oculus_keys_