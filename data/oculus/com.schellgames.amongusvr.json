aceship together but keep an eye out as one or more random players among the crew are Impostors bent on killing everyone. Experience all of the same deception and deceit as the original game, but now in your own virtual Skeld!", "short_description": "Teamwork and betrayal in space! Crewmates work together to complete tasks before one or more Impostors kill everyone aboard. Experience all of the same deception and deceit as the original game, but now in your own virtual Skeld."}]}, "developer_name": "Schell Games, Innersloth LLC, and Robot Teddy", "developer_privacy_policy_url": "https://www.innersloth.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Innersloth LLC", "support_website_url": null, "website_url": "http://amongusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5117759654955623"}}]}, "scheduled_offers": {"count": 20, "nodes": [{"status": "PUBLISHED", "id": "787105573627866"}, {"status": "PUBLISHED", "id": "258182170717311"}, {"status": "PUBLISHED", "id": "3011634795796580"}, {"status": "PENDING", "id": "665594805658722"}, {"status": "CANCELLED", "id": "730306009111686"}, {"status": "PUBLISHED", "id": "249691424642529"}, {"status": "PENDING", "id": "1244809802828037"}, {"status": "CANCELLED", "id": "390208247274111"}, {"status": "PUBLISHED", "id": "733165988586055"}, {"status": "PENDING", "id": "672411608192569"}, {"status": "CANCELLED", "id": "213755624825464"}, {"statu