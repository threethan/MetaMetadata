 Us VR", "keywords": ["social", "multiplayer", "party", "casual", "deduction"], "long_description": "Prepare for departure but beware the Impostor! Among Us VR is an online party game of teamwork and betrayal. Grab your crew and headset to plunge into the VR version of this hit multiplayer game for 4 - 10 players. Attempt to hold your spaceship together but keep an eye out as one or more random players among the crew are Impostors bent on killing everyone. Experience all of the same deception and deceit as the original game, but now in your own virtual Skeld!", "short_description": "Teamwork and betrayal in space! Crewmates work together to complete tasks before one or more Impostors kill everyone aboard. Experience all of the same deception and deceit as the original game, but now in your own virtual Skeld."}]}, "developer_name": "Schell Games, Innersloth LLC, and Robot Teddy", "developer_privacy_policy_url": "https://www.innersloth.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Innersloth LLC", "support_website_url": null, "website_url": "http://amongusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}, {"id": "1023770785722696"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "5117759654955623"}}]}, "scheduled_offers": {"count": 21, "nodes": [{"status": "PUBLISHED", "id": "945426797623260"}, {"status": "PUBLISHED", "id": "7