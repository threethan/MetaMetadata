_description": "Enjoy viewing your favorite mobile video application in your private theater at a scenic lakeside campground. Sit back, relax, and enjoy.\n\n'Go to Labs', whenever you feel like doing more than viewing. We bring (most of) your mobile applications into your private garden so you can check your email, message your friend, play game or do anything else you were doing on your phone."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.samsung.com/", "developer_terms_of_service_url": "http://www.samsung.com/", "publisher_name": "Samsung Electronics Co., Ltd", "support_website_url": null, "website_url": "https://www.facebook.com/phonecastvr.samsung.5", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["MOVIE", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "498795581680233"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162763_110802936248128_3835108759684775936_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SkAicoKdKDAQ7kNvgH0N5S9&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArHW5lJRpJMakOIyEFdV4_r&oh=00_AYAHl8CPikZkZmaDf3bM1t_VFUkN3-UhsKmEuNnAXc_uZQ&oe=66E6B938"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Samsung PhoneCast VR Beta", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1493750098, "lastRevision": {"nodes": [{"id": "990442407723679", "release