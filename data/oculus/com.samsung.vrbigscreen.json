 phone."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.samsung.com/", "developer_terms_of_service_url": "http://www.samsung.com/", "publisher_name": "Samsung Electronics Co., Ltd", "support_website_url": null, "website_url": "https://www.facebook.com/phonecastvr.samsung.5", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["MOVIE", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "498795581680233"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162763_110802936248128_3835108759684775936_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rNqJthNk1OMQ7kNvgHhE_sL&_nc_ht=scontent.oculuscdn.com&oh=00_AYDR5afEm_EJ8mhctICu4aJ-1-K5LS8xOgnHeUGUvRSCVw&oe=66F7DCB8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Samsung PhoneCast VR Beta", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1493750098, "lastRevision": {"nodes": [{"id": "990442407723679", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1239896026125279", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "756402511203143"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "2740270946251