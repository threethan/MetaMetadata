e.png", "id": "2602400070083948", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974674_693268591106821_9100309189326012416_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UUzVoU5VMSwQ7kNvgH59e83&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRzA18NyDUtYHuhvkUUcdAqJC9y_l4YrOiVFhe2g1x6w&oe=67430393"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "1261893117932221", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984446_1261893121265554_2620193258863035889_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4l9VFvoYnkIQ7kNvgELdsq0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlNSk-_TlfQaqyLfa-9J8XB_VmNeMWYmzGtuRHTC-hrQ&oe=674303E1"}, "display_name": "Virtual Desktop", "keywords": ["computer", "streaming", "movie", "video", "pcvr"], "long_description": "Connect wirelessly to your computer(s) to watch movies, browse the web, play games on a giant virtual screen or stream PCVR games. Virtual Desktop is a highly optimized, native application developed for low latency, high quality streaming.\n\n\u2022 Computer must be wired with Gigabit Ethernet cable to a 5 GHz router\n\u2022 Supports most PCs and laptops running Windows 10 or 11, macOS Mojave or later\n\u2022 PCVR game streaming requires a VR Ready PC running Windows 10 or 11\n\u2022 Videos tab allows you to download or stream regular/180/360 videos directly from your computer\n\u2022 Supports Bluetooth mice, keyboards and gamepads\n\u2022 Supports 3D Side-by-Side / Over-Under content on screen\n\u2022 Supports multi-monitors (physical and/or virtual)\n\u2022 Includes a Microphone passthrough option\n\u2022 Supports remote connections over the internet (enable UPnP on your router)", "short_description": "Connect wirelessly to your computer(s) to watch movies, browse the web, play 2D games or stream PCVR games. Virtual Desktop is a highly optimized, native application developed for low latency, high quality streaming.\n\n\u2022 Connect up to 4 computers (Windows 10 or 11, macOS Mojave or later)\n\u2022 PCVR game streaming requires a VR Ready PC running Windows 10 or 11\n\u2022 Supports Bluetooth mice, keyboards and gamepads\n\u2022 Supports remote connections over the internet\n\u2022 Computer must be wired to a 5 GHz router"}]}, "developer_name": "Virtual Desktop, Inc.", "developer_privacy_policy_url": "https://www.vrdesktop.net/privacy-policy", "developer_terms_of_service_url": "https://www.vrdesktop.net/terms-of-service", "publisher_name": "Virtual Desktop, Inc.", "support_website_url": "http://discord.vrdesktop.net/", "website_url": "https://www.vrdesktop.net/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1055187466124150"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MOVIE", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7975921419117607"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974517_2404935902972942_2526505135848152155_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MtD_uK1JTnUQ7kNvgEI382n&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD1hScXeuYBkRKcPSgCWx1spH_q1DMCTwyjC6xDriqaAA&oe=67431A5C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Virtual Desktop", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_to