ttico per interagire con gli abitanti del mare: granchietti, pesci pagliaccio, orche, delfini, balene, sottomarini, meduse e pesci farfalla appariranno uno alla volta e si animeranno davanti ai tuoi occhi.", "short_description": "Un'esperienza di realt\u00e0 virtuale interattiva per trasportare i pi\u00f9 piccoli alla scoperta di un coloratissimo mondo marino."}]}, "developer_name": "Digital Mosaik", "developer_privacy_policy_url": "https://lab.digitalmosaik.com/en/underwater-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Digital Mosaik", "support_website_url": "https://www.digitalmosaik.com/", "website_url": "https://www.digitalmosaik.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_HK", "zh_CN", "en_US", "it"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "486541939712742"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031591_590413265139061_6550789582781153280_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ioSs19fLxdoQ7kNvgEq-W90&_nc_ht=scontent.oculuscdn.com&_nc_gid=AmRVWlgOlwKl7g8I9Rl3PNz&oh=00_AYDgixw0gSUEICvZhfgPnEFeJ4cvNmN2IaRzTrqb243Suw&oe=66F14635"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Underwater", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1590685141, "lastRevision": {"nodes": [{"id": "863870110693544", "release_type": "SCHEDULED", "administratio