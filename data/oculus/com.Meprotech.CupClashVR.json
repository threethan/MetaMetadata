6&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Iiqq2hbb6AQ7kNvgEKmpTs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBxd94CyH3M6hlkszpbhZHhP3eIA7Kp_EaChzyGQhJgg&oe=67237665"}, {"file_name": "top logo.png", "id": "447204795038572", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982608_447204798371905_2469105837415396930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MLuM26ZGb1AQ7kNvgF7Dzjd&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYADky0k7j5MevnCq9hvKiIYneyLYF52q9NQoeSDkAOD7w&oe=67236404"}]}, "id": "1086382906454988", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1073847807596986", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984444_1073847810930319_679931874618762655_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_fLksFvyu4Q7kNvgFCJeZc&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDIHLRiQwC3AJbmt-83jCdlkyqv8hNCLq6BWoIxAxsBzg&oe=672383B4"}, {"file_name": "2.png", "id": "1888612228285227", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568682_1888612231618560_8868891280293497096_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hb9ofohWfrEQ7kNvgGZ_3oQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcNa7TPQ6P_3TiKg0xc-UiK0hP6qgZE-oWNUEBsAMjsg&oe=6723553E"}, {"file_name": "3.png", "id": "1552518795373654", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314845_1552518798706987_6105746557122647736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n102DlVl7VYQ7kNvgG7-6qa&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhQhB3-5B2X3X_Le6DALSo75tn2kKQ2zpDsKwHdTSlCA&oe=67236774"}, {"file_name": "4.png", "id": "524410273676671", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031482_524410277010004_6965172599976371479_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L_UW2ZSQmT8Q7kNvgHvmTGr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvukTwm1U4im2PHpHvmjF19-kgvtIr_86xvFDo57tN9Q&oe=67238405"}, {"file_name": "5.png", "id": "1200934834517895", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036657_1200934837851228_7457471836996257057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2sxcBK5XJ0gQ7kNvgHG3fhg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCvA8eWo8faQeTbO0CoFJgaYLeIDkxbtzSM8UNx4cSofw&oe=672352FA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["party", "cup", "ball", "casualgame", "minigame"], "long_description": "# Cup Clash VR: Smash or Stack\n\nThis virtual reality game combines precision, creativity, and strategy in a simple but engaging way.\n\n### Cup Breaker\nIn Cup Breaker, you use tennis balls to knock down cups from a distance. Aim carefully and throw to break as many cup patterns as possible. Every hit feels rewarding as you see the cups fall.\n\n### Cup Builder\nCup Builder tests your stacking skills. Follow a displayed pattern to build a tall tower of cups without letting it collapse. Think through each move and try to stack as high as you can.\n\n### Game Features\n- **Two Modes**: Cup Breaker for smashing cups, and Cup Builder for stacking.\n- **Simple Gameplay**: Focus on aiming and stacking without unnecessary distractions.\n- **Strategic Fun**: Take your time in building or enjoy quick, fast-paced cup smashing.\n\nCup Clash VR is a straightforward experience, letting you focus on the challenge of smashing or stacking cups.\n\n{1583804702345811}", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "developer_terms_of_service_url": null, "publisher_name": "MEPROTECH", "support_website_url": null, "website_url": "https://meprotech.in/", "category": null, "comfort_rati