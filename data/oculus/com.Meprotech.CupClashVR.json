nt-ams2-1.oculuscdn.com/v/t64.5771-25/39031533_542191508278648_4381187768276350707_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pBdtbgDPpcUQ7kNvgHoPY-H&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAqLghYRYjJIxUQwIEhcDzvFusWR4kykAR2M-xWUMXdkA&oe=6756E0E5"}, {"file_name": "top logo.png", "id": "447204795038572", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982608_447204798371905_2469105837415396930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y2rXVHEhsuUQ7kNvgE8FW41&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBVUj1NXkahgYgryrRgZFxyQCzXk_D4GAH2gCZNxbgvNw&oe=6756CE84"}]}, "id": "1086382906454988", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1073847807596986", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38984444_1073847810930319_679931874618762655_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bw672nbMxiMQ7kNvgHEeN4e&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD2DEO6UvFYeYp-E4WwcUVsYl7GaKfm_9XX65j9_navVw&oe=6756EE34"}, {"file_name": "2.png", "id": "1888612228285227", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57568682_1888612231618560_8868891280293497096_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ztfC8nrgrGkQ7kNvgHi6xza&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB1xIF-4EjC4hxfpXFrUcufziOYyq8xzgN0xMd8DzDGJw&oe=6756BFBE"}, {"file_name": "3.png", "id": "1552518795373654", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75314845_1552518798706987_6105746557122647736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gnOE3_8LqFMQ7kNvgFmQJGB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCb_dizsR3jM7zpLJXA9QE-sEavWWdI6I1oUV0t-AUosA&oe=6756D1F4"}, {"file_name": "4.png", "id": "524410273676671", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031482_524410277010004_6965172599976371479_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LXT5eYOHjtwQ7kNvgGNJkXe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC4DtadXPhjOrplDShR8-7TsS9BYcdzde6lmvHnJ3lVLw&oe=6756EE85"}, {"file_name": "5.png", "id": "1200934834517895", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036657_1200934837851228_7457471836996257057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZWu1Fqe3xfQQ7kNvgEctZ-c&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCRS9NgXSCQLz_higaybRvrO2mI9SKgKv23ENBLJZIlAA&oe=6756F5BA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["party", "cup", "ball", "casualgame", "minigame"], "long_description": "# Cup Clash VR: Smash or Stack\n\nThis virtual reality game combines precision, creativity, and strategy in a simple but engaging way.\n\n### Cup Breaker\nIn Cup Breaker, you use tennis balls to knock down cups from a distance. Aim carefully and throw to break as many cup patterns as possible. Every hit feels rewarding as you see the cups fall.\n\n### Cup Builder\nCup Builder tests your stacking skills. Follow a displayed pattern to build a tall tower of cups without letting it collapse. Think through each move and try to stack as high as you can.\n\n### Game Features\n- **Two Modes**: Cup Breaker for smashing cups, and Cup Builder for stacking.\n- **Simple Gameplay**: Focus on aiming and stacking without unnecessary distractions.\n- **Strategic Fun**: Take your time in building or enjoy quick, fast-paced cup smashing.\n\nCup Clash VR is a straightforward experience, letting you focus on the challenge of smashing or stacking cups.\n\n{1583804702345811}", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "develope