nt-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_542191508278648_4381187768276350707_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q2bigcS1TWkQ7kNvgFlrjFU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDo9Eocn1MVMTb7fneNgFDTzX_xl8Pw_g6FeO2xEVNFwQ&oe=6762BE65"}, {"file_name": "top logo.png", "id": "447204795038572", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982608_447204798371905_2469105837415396930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wkDcIQZV0F8Q7kNvgF7Ppuo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBLuxkgKJDs6tn_6IzlIeSkJWqnWg92zeXN1AvYuxvKw&oe=6762AC04"}]}, "id": "1086382906454988", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1073847807596986", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984444_1073847810930319_679931874618762655_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vTfwMtNi7e8Q7kNvgEph_Fm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJs_lherbEerAeztspcwjuLfQHAHJ86VZnSmAAXE2qKg&oe=6762CBB4"}, {"file_name": "2.png", "id": "1888612228285227", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568682_1888612231618560_8868891280293497096_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BBDc0-0VmDUQ7kNvgGi5vhM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAOXNssXD5vYMX1-1aVqn-Ph0KXK_gXxBA-m9lzKJA8Xg&oe=67629D3E"}, {"file_name": "3.png", "id": "1552518795373654", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314845_1552518798706987_6105746557122647736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oZ6dpobRsIgQ7kNvgFnyZeU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDyMWG3fzklPAcCDITBvfOyuwVumcg1jliwDHDSfTe8NQ&oe=6762AF74"}, {"file_name": "4.png", "id": "524410273676671", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031482_524410277010004_6965172599976371479_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5N4gyBDBlO4Q7kNvgFyCaUN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcZkh3flBf934dP2aiQo24nvv0HIZqPL747tY2zTA1xw&oe=6762CC05"}, {"file_name": "5.png", "id": "1200934834517895", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036657_1200934837851228_7457471836996257057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3xgHYtl6N8sQ7kNvgF27Ke5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrwkUcc3zRMxKMFfUwv6wiADnxQsIrk9CRisAYPvKpvQ&oe=6762D33A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["party", "cup", "ball", "casualgame", "minigame"], "long_description": "# Cup Clash VR: Smash or Stack\n\nThis virtual reality game combines precision, creativity, and strategy in a simple but engaging way.\n\n### Cup Breaker\nIn Cup Breaker, you use tennis balls to knock down cups from a distance. Aim carefully and throw to break as many cup patterns as possible. Every hit feels rewarding as you see the cups fall.\n\n### Cup Builder\nCup Builder tests your stacking skills. Follow a displayed pattern to build a tall tower of cups without letting it collapse. Think through each move and try to stack as high as you can.\n\n### Game Features\n- **Two Modes**: Cup Breaker for smashing cups, and Cup Builder for stacking.\n- **Simple Gameplay**: Focus on aiming and stacking without unnecessary distractions.\n- **Strategic Fun**: Take your time in building or enjoy quick, fast-paced cup smashing.\n\nCup Clash VR is a straightforward experience, letting you focus on the challenge of smashing or stacking cups.\n\n{1583804702345811}", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "develope