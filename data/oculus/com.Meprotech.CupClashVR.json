nt-iad3-2.oculuscdn.com/v/t64.5771-25/39031533_542191508278648_4381187768276350707_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t1X7kp_WChgQ7kNvgG2qpGe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBldulCJ0iDhxCrkkKuFxPf_H9Pf-L9TjtkzwmK4zOcUg&oe=675C26E5"}, {"file_name": "top logo.png", "id": "447204795038572", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982608_447204798371905_2469105837415396930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v0bpzAfP8LYQ7kNvgFNfGNL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCB82gTxXn-MStXSMUVB5H47WKBGLrYPo_y_kvtZpdgWQ&oe=675C1484"}]}, "id": "1086382906454988", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1073847807596986", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984444_1073847810930319_679931874618762655_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-ye5B9KXSE8Q7kNvgEANAYD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAO2PydHBGYVDQIXPfP9-gEEdgx3-64jvvo4VW9IiawSw&oe=675C3434"}, {"file_name": "2.png", "id": "1888612228285227", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568682_1888612231618560_8868891280293497096_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VB7G-Sx055YQ7kNvgGZFxlz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsJHWbAegjNPucJxh4JSFzkefBt3sd8Q5fUP1n-Z96Ig&oe=675C05BE"}, {"file_name": "3.png", "id": "1552518795373654", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75314845_1552518798706987_6105746557122647736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ClVExwgF6U0Q7kNvgGXasQn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA3V7o-IdN3XoF1KhCvp8JdrL-MMQDO4bWav-x7GIlsfA&oe=675C17F4"}, {"file_name": "4.png", "id": "524410273676671", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031482_524410277010004_6965172599976371479_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vRhMYtomdDUQ7kNvgFUvwoN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJbp8eQacikY_uLpHZSMan8i2XdKP-zM1qdxJou6_JGw&oe=675C3485"}, {"file_name": "5.png", "id": "1200934834517895", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036657_1200934837851228_7457471836996257057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L4_GvHZJiVwQ7kNvgFnIPgm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCD89DfGsrct6IhGAaz2LIetXXZXE9Bu-h49YC1YuOBQQ&oe=675C037A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["party", "cup", "ball", "casualgame", "minigame"], "long_description": "# Cup Clash VR: Smash or Stack\n\nThis virtual reality game combines precision, creativity, and strategy in a simple but engaging way.\n\n### Cup Breaker\nIn Cup Breaker, you use tennis balls to knock down cups from a distance. Aim carefully and throw to break as many cup patterns as possible. Every hit feels rewarding as you see the cups fall.\n\n### Cup Builder\nCup Builder tests your stacking skills. Follow a displayed pattern to build a tall tower of cups without letting it collapse. Think through each move and try to stack as high as you can.\n\n### Game Features\n- **Two Modes**: Cup Breaker for smashing cups, and Cup Builder for stacking.\n- **Simple Gameplay**: Focus on aiming and stacking without unnecessary distractions.\n- **Strategic Fun**: Take your time in building or enjoy quick, fast-paced cup smashing.\n\nCup Clash VR is a straightforward experience, letting you focus on the challenge of smashing or stacking cups.\n\n{1583804702345811}", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "develope