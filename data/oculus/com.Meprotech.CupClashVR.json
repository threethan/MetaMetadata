=1-7&_nc_sid=6e7a0a&_nc_ohc=MIlbIPMvWY0Q7kNvgEnO_PB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5YoN1NNRWMzXrwFL7AfkJv2t4TqHoNXhLSKWPm5pPhw&oe=676AA038"}, {"file_name": "5.png", "id": "544533391449905", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974723_544533394783238_2618581233150498749_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pPNne5J-TU0Q7kNvgHGXJOq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVbJwnBaO1Dw5vdyZxB8c1D6ScHD_n6ucSWqi23OfbpQ&oe=676AB42A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["CupGame", "CupBreaking", "CupBuilderGame", "Ballthrowgame", "Cup"], "long_description": "Welcome to Cup Clash VR!\nPrepare for an action-packed adventure in this thrilling virtual reality experience where precision, creativity, and strategy collide! \nCup Breaker challenges you to grab your tennis balls and shatter as many cup patterns as possible from a distance. Aim, throw, and feel the excitement as you knock down cups in a satisfying display of destruction! \nIn Cup Builder, test your skills by stacking and aligning cups to construct the tallest tower without it tumbling over. Follow the displayed pattern, strategize your moves, and rise to the challenge at your own pace. How high can you build your masterpiece? \nWith immersive gameplay, Cup Clash VR offers a unique blend of fast-paced action and thoughtful construction. Whether you\u2019re smashing or stacking, the fun never ends! ", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "developer_terms_of_service_url": null, "publisher_name": "MEPROTECH", "s