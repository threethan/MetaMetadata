nt-lhr8-2.oculuscdn.com/v/t64.5771-25/39031533_542191508278648_4381187768276350707_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=82isDtwyr40Q7kNvgEOJyQJ&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCC3qi47TsToetyBNS4NbqKtRbq2iS4PNdFlT6XLij_kw&oe=672A0DE5"}, {"file_name": "top logo.png", "id": "447204795038572", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982608_447204798371905_2469105837415396930_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DHCzD1ToLF4Q7kNvgEKqpyw&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDp_mar8CY-hUNMc8KswRnF7El7-6O3gIx8d_Vfmhaqyg&oe=6729FB84"}]}, "id": "1086382906454988", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "1073847807596986", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38984444_1073847810930319_679931874618762655_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWKPpY2-5t8Q7kNvgG44Cnw&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDO24STa3FnYwPgt5hfNHHcB6y1rF_uZ1nCkkCGJA7FFA&oe=672A1B34"}, {"file_name": "2.png", "id": "1888612228285227", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/57568682_1888612231618560_8868891280293497096_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_wJ5U2zRtvQQ7kNvgFBWl6r&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCPKUfPzt6DmV61JPVbhF96t9jogt4zIP5l9x0WPmn5VA&oe=6729ECBE"}, {"file_name": "3.png", "id": "1552518795373654", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75314845_1552518798706987_6105746557122647736_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8RMRjfb30IMQ7kNvgGSf8H7&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBure187HHgILw10YnVLTgxSE7zBatwiGZClNberoI2fw&oe=6729FEF4"}, {"file_name": "4.png", "id": "524410273676671", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031482_524410277010004_6965172599976371479_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lfrpa70TwNEQ7kNvgGKl8li&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYC6lRlNEGTLezsOal1LkRp1PgyP7LIsJgggU7uCGQDv8Q&oe=672A1B85"}, {"file_name": "5.png", "id": "1200934834517895", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39036657_1200934837851228_7457471836996257057_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y_jUE3JAVo4Q7kNvgFaLPlV&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDVoELjqs_aInDd_z20RbQvrexoZm34Qg2lpjO63yXaWQ&oe=6729EA7A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Cup Clash VR", "keywords": ["party", "cup", "ball", "casualgame", "minigame"], "long_description": "# Cup Clash VR: Smash or Stack\n\nThis virtual reality game combines precision, creativity, and strategy in a simple but engaging way.\n\n### Cup Breaker\nIn Cup Breaker, you use tennis balls to knock down cups from a distance. Aim carefully and throw to break as many cup patterns as possible. Every hit feels rewarding as you see the cups fall.\n\n### Cup Builder\nCup Builder tests your stacking skills. Follow a displayed pattern to build a tall tower of cups without letting it collapse. Think through each move and try to stack as high as you can.\n\n### Game Features\n- **Two Modes**: Cup Breaker for smashing cups, and Cup Builder for stacking.\n- **Simple Gameplay**: Focus on aiming and stacking without unnecessary distractions.\n- **Strategic Fun**: Take your time in building or enjoy quick, fast-paced cup smashing.\n\nCup Clash VR is a straightforward experience, letting you focus on the challenge of smashing or stacking cups.\n\n{1583804702345811}", "short_description": "\"Cup Clash VR\" is an action-packed virtual reality game where players engage in thrilling cup battles. Use strategy, quick reflexes, and precision to stack, toss, and clash cups in various dynamic environments.  challenge yourself in this fast-paced, immersive experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/meprotech.in/cupclashvr/home", "develope