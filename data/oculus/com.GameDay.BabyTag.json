n.com&oh=00_AYBtsB6O-QB0zr6BlEVgYxok1CH1GGlb28QCOC0RlTgmeg&oe=6728AD82"}, {"file_name": "5.png", "id": "584259886891700", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974873_584259890225033_988868963508915964_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-xcu3cjD0OsQ7kNvgHdV0br&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYDvz21SScMwq3GUNGWEzIwLGRpegqXyZeNbRtbGrMi3VA&oe=6728C6C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "20220214-TrailerCover.png", "id": "460610222433526", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974913_460610225766859_5128284085787517535_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=72bZ9w2hWLYQ7kNvgGGj6sa&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYA0ANLSEU4u0T2ii7EShEXXaMCF66lj9KW21nPELr_zzQ&oe=6728BFDD"}, "display_name": "Baby Tag", "keywords": [], "long_description": "Be a baby! \nBaby Tag is a tag game where you can act like a baby! All the other babies will come after you and try to tag you. You need to run away for as long as possible! Sliding across the floor! Crawling up to the ceiling, or hiding under the desk! Throw objects at the other babies! Use any method you can imagine!\nGoooooooooooooooo!\n- Climb on the walls, the ceiling, or any place you want!\n- Have fun on \"mini city\" or \"room\" maps!\n- Escape from several different baby types!\n- Throw a prop at babies and watch what happens!\n- Compete with other players on the Survival Time Leader Board!\n- Enjoy Multiplayer Mode with strangers! (There is no voice chat, so you can enjoy your game quietly and peacefully)", "short_description": "Be a baby! Don't let the bad babies get you or you will get tagged! Crawl away, climb on the walls or ceiling! \nThrow props at the bad babies and watch what happens!\nCompete with other players on the Survival Time Leader Board!\nYou\u2019re welcome to contact us in the following ways: \nEmail - feedback@gameday.tech"}]}, "developer_name": null, "developer_pr