84259886891700", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974873_584259890225033_988868963508915964_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z9aBaT6pCj0Q7kNvgFVfUE-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1wEa6FUVmPifwOhj-T6YtA7EimwMim1W3_aL2sr3f0w&oe=6703DCC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "20220214-TrailerCover.png", "id": "460610222433526", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974913_460610225766859_5128284085787517535_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=toju55EtL2MQ7kNvgGbGagl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArSxnd3JD_2j_UrV2E-r6oVczB1ZxNlJW-_Z5ZTUMHUQ&oe=6703D5DD"}, "display_name": "Baby Tag", "keywords": [], "long_description": "Be a baby! \nBaby Tag is a tag game where you can act like a baby! All the other babies will come after you and try to tag you. You need to run away for as long as possible! Sliding across the floor! Crawling up to the ceiling, or hiding under the desk! Throw objects at the other babies! Use any method you can imagine!\nGoooooooooooooooo!\n- Climb on the walls, the ceiling, or any place you want!\n- Have fun on \"mini city\" or \"room\" maps!\n- Escape from several different baby types!\n- Throw a prop at babies and watch what happens!\n- Compete with other players on the Survival Time Leader Board!\n- Enjoy Multiplayer Mode with strangers! (There is no voice chat, so you can enjoy your game quietly and peacefully)", "short_description": "Be a baby! Don't let the bad babies get you or you will get tagged! Crawl away, climb on the walls or ceiling! \nThrow props at the bad babies and watch what happens!\nCompete with other players on the Survival Time Leader Board!\nYou\u2019re welcome to contact us in the following ways: \nEmail - feedback@gameday.tech"}]}, "developer_name": null, "developer_privacy_policy_url": "http://babytag.gameday.ren/PrivacyPolicy.html", "developer_terms_of_service_url": "http://babytag.gameday.ren/TermsofService.html", "publisher_name": "Roar Wild Studio", "support_website_url": null, "website_url": "https://www.roarwildstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "943864580244878"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250460_632054477903046_8423502976386064439_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qH1dTOkl94cQ7kNvgE_ksEr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrCvBC4Hr260qBRCW48TqcW6EMsaj_CiGSqmQbWkTjaQ&oe=6703C16B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Baby Tag", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1649279121, "lastRevision": {"nodes": [{"id": "311349194388734", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5205141932837634", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "11107792530