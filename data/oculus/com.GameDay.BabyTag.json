cdn.com&oh=00_AYAPrb9u9_JGBI9rN_ihICehLOW9L9GV93Tg628wFKto4g&oe=677FA46E"}, {"file_name": "20220215-ScreenShot-4.png", "id": "470340424637893", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036686_470340427971226_5527383313252539010_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rAMzGtxlkEAQ7kNvgE5f9vg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsuLNN-vHxRtmvAMomv9SPb1Pi-KX_Z69WBZPqWkq6Bw&oe=677FA6FD"}, {"file_name": "20220215-ScreenShot-5.png", "id": "482186193416937", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974537_482186196750270_4100614178132899433_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3an8sTLZjqsQ7kNvgHaSsg9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAeHfKUAbX2iPcelWTVhhrxrKS4DuZ-gs0r60-D5sUX3w&oe=677FB2BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "20220214-TrailerCover.png", "id": "460610222433526", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974913_460610225766859_5128284085787517535_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PZxiYWEWNfMQ7kNvgEsvXgx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA5mJs4C9DH-xfUcZ0ScKWG6m8rup_eaKL41m78r-4mww&oe=677FC2DD"}, "display_name": "Baby Tag", "keywords": [], "long_description": "Be a baby! \nBaby Tag is a tag game where you can act like a baby! All the other babies will come after you and try to tag you. You need to run away for as long as possible! Sliding across the floor! Crawling up to the ceiling, or hiding under the desk! Throw objects to the other babies! Use any method you can imagine!\nGoooooooooooooooo!\n\n- Climb on the walls, the ceiling, or any place you want!\n- Escape from several different baby types!\n- Throw a prop to babies and watch what happens!\n- Compete with other players on the Survival Time Leader Board!\n- Use props to slow down other babies!\n- Coming Soon: Multiplayer Mode and New maps.\n\nThis is still a demo version. Welcome to contact us in the following ways:\n