zA6a1iI6-Lb20OEaHgUTcoiQYu9w&oe=67050284"}, {"file_name": "3.png", "id": "312134025073755", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036620_312134028407088_6262983324001973987_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ON9IAeleELcQ7kNvgFETNLu&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB82EtoC2YP-_9gQPS6dKkIUOpvw_sn1kCkv-EQw006VQ&oe=67051375"}, {"file_name": "4.png", "id": "855287939427923", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001654_855287942761256_262016941582295271_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zqGWnpHIjQUQ7kNvgEk8PTW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAn8J2BN89XfbPHkk_81ze4HUJBvNO8BF537QhVX4rF7g&oe=67052868"}, {"file_name": "5.png", "id": "320300157529436", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982453_320300160862769_8131700945978593410_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O8NF8RgAba0Q7kNvgFsf9Em&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvEaZ4Czi_2flBlFWYcclflUJgl7i7hX25rom6kHuGug&oe=670515D3"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Action Resort XR", "keywords": [], "long_description": "Dive into the ultimate XR experience with Action Resort XR! Unleash your fists in our boxing simulations, refine your reflexes in high-velocity games, or channel your inner chef in a chaotic virtual kitchen. It's not just about gaming; it's a total body-and-mind adventure.\n\nConsider this collection a must-have for any XR enthusiast. We've carefully curated a blend of games that enhance both your mental acuity and physical well-being, all while delivering a fun-packed experience with top-tier visuals.\n\nLaunch Modes to Look Forward To:\n\u2022 Pro Boxing Training: Get in the ring with your highly customizable coach (m/f) and rise through the ranks, from amateur to pro \u2013 and beyond!\n\n\u2022 Smoothie Bar: Don your chef hat in our virtual kitchen; chop veggies, peel fruits, and blend up some wellness!\n\n\u2022 Ball Smasher Reflex Training: Hone your reflexes by taking on rapid-fire pitching machines. It's a workout for mind and muscle!\n\n\u2022 Food Fight: Take all your rage out on Bots such as the Banana or the Pizza Slice; Brace yourself for the sweatiest, most exhilarating session you'll ever have in XR!\n\nEmbrace a healthier, more active you with Action Resort XR. Our activities offer more than just fun\u2014they deliver a holistic wellness journey that seamlessly integrates into your daily life. Enjoy health benefits from cardiovascular wellness to mental sharpness!", "short_description": "Action-packed fitness in XR! Swing, punch, and play your way to health and happiness."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fitnesscloud.eu/privacyPolicy.htm", "developer_terms_of_service_url": "https://fitnesscloud.eu/eula.htm", "publisher_name": "Verseus Games", "support_website_url": null, "website_url": "https://www.verseus-games.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6737088016413144"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "873040847652882"}, {"status": "PUBLISHED", "id": "1227616802022734"}, {"status": "PUBLISHED", "id": "727333112789362"}]}, "baseline_offer": {"id": "873040847652882"}, "is_approved": true, "firstOffer": {"nodes": [{"start_t