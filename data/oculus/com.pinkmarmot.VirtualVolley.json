-1.oculuscdn.com&oh=00_AYBah-bKpxJzWVzajK92CZhNViJASZ5vttcdvvQr2fC62Q&oe=67839647"}, {"file_name": "com.oculus.vrshell-20240918-104919-16-9.png", "id": "432221772740034", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003244_432221776073367_2817356410933122245_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oMW6ksyRU6UQ7kNvgEk_-Zx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTriCMd9lc1R6os87iMKZZRrj3Ow7uZo7-052-l7oZCg&oe=6783A583"}, {"file_name": "com.oculus.vrshell-20240918-172151-16-9.png", "id": "525943766800804", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001686_525943770134137_7010552549987315403_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xQEIuDI2vBgQ7kNvgGxZYNn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDEblaqPMUQNvmEUF4E6aZaXUIufS5dKStgkXTuoyaHLQ&oe=6783A7CE"}, {"file_name": "com.oculus.vrshell-20240918-103648-16-9.png", "id": "1038004147626815", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036653_1038004150960148_6975583511713956111_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ba_2SDqgPR0Q7kNvgHiH_-U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAUJlHXoCoK-8oHxVLmCIdwjMfLhYA40NNYLMwXfLdUzg&oe=678396E4"}, {"file_name": "com.oculus.vrshell-20240918-103507-16-9.png", "id": "569453585752182", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974667_569453589085515_5940168554369537433_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qPNRC3xNAcMQ7kNvgGnZ-GV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDexQDOimJx5ir2wvp1sU8L0qdC8d_EIL3vaa8JCm4vrA&oe=678390CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PostOculusStore_Volleggball.png", "id": "3722721384723693", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974611_3722721391390359_3140296778754052086_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0KbKdsRCTjwQ7kNvgHv5gjo&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFoUPJk4GD3JnseNcEO5ty_ynkLenH3guvZMYm1AEdZQ&oe=6783930D"}, "display_name": "Volleggball", "keywords": ["volleyball", "sport", "competitive", "multiplayer", "volley"], "long_description": "# \ud83d\udd25\ud83c\udfd0\ud83e\udd5a Spike before you get cooked ! \ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\nGet ready to crack up with Volleggball, the egg-citing volleyball game that'll have you jump for victory! \n\nThis yolk-tastic multiplayer experience is no chicken feed \u2013 it's a shell-shocking adventure that'll keep you coming back for more!\n\n{1045102036463669}\n\n## \ud83d\udc23 Scramble with your friends\ud83d\udc23 \n\nJump into open lobbies and get cracking with players from around the globe!\n\n## \ud83d\udc50 Sunny-side up gameplay \ud83d\udc50\n\nChoose between 1vs1 or 2vs2 matches for the perfect serving of competition\n\n## \ud83e\udd5aHilarious AI Opponents\ud83e\udd5a\n\nFace off against funny, clumsy egg bots that'll keep you laughing as you play\n\n## \ud83d\ude0e Egg-spressive customization \ud83d\ude0e \n\nStand out from the carton with dozens of ways to personalize your egg-vatar\n\n## \ud83c\udfdd\ufe0f Eggs-quisite environments \ud83c\udfdd\ufe0f\n\nSpike your way through 4 egg-mazing maps: \n- Tropical Island Paradise\n- Autumn Lake Splendor\n- Winter Mountain Wonderland\n- Volcanic Inferno (careful not to get poached!)\n\n\ud83d\udd25\ud83c\udfd0\ud83e\udd5a\n\nWhether you're a seasoned pro or just out of your shell, Volleggball offers an egg-citing VR experience that's no yolk! So don't chicken out \u2013 grab your friends and get ready to scramble the competition in this egg-ceptional volleyball adventure!\n\n\ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\n---\n\ud83c\udf99\ufe0fChat with us on our discord ! https://discord.gg/NvRjfSnmma\n", "short_description": "Best volleyball game in the egg world!\n"}, {"images": {"nodes": [{"file_name": "PostOculusStore_FreeToPlay.png", "id": "844627027575279", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75297582_844627030908612_100519495280906896_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lk-n8StKXlkQ7kNvgEW4Q66&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHmFgyNEeKuDOgjQqyqSOgMvK5ssl_MIRr6CJ37eUh3g&oe=6783B66D"}]}, "id": "505018882335185", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Volleggball", "keywords": [], "long_description": "# \ud83d\udd25\ud83c\udfd0\ud83e\udd5a Smashez avant d'\u00eatre cuit ! \ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\nPr\u00e9parez-vous \u00e0 vous fendre la coquille avec Volleggball, le jeu de volleyball qui vous fera sauter d'oeuf-orie ! \n\nCette eggsp\u00e9rience multijoueur n'est pas pour les poules mouill\u00e9es - c'est une aventure digne des meilleurs omelettes qui vous donnera envie d'y revenir encore et encore !\n\n{844627027575279}\n\n## \ud83d\udc23 Mettez tous vos amis dans le m\u00eame panier \ud83d\udc23 \n\nRejoignez des parties ouvertes et amusez-vous avec des joueurs du monde oeuf-tier, sans vous brouiller (ou pas) !\n\n## \ud83d\udc50 Un gameplay \u00e0 la coque \ud83d\udc50\n\nChoisissez entre des matchs simple ou doubles pour une dose parfaite de comp-oeuf-tition.\n\n## \ud83e\udd5aDes adversaires IA coquasse\ud83e\udd5a\n\nAffrontez des rob\u0153ufs dr\u00f4les et maladroits qui vous feront rire \u00e0 vous en secouer le jaune.\n\n## \ud83d\ude0e Personnalisations \u0153ufs-riginales\ud83d\ude0e \n\nD\u00e9marquez-vous avec des dizaines de fa\u00e7ons de personnaliser votre avacoque.\n\n## \ud83c\udfdd\ufe0f Environnements coquetiers\ud83c\udfdd\ufe0f \n\nFaites des smashes \u00e0 travers 4 cartes incroyables :\n- Paradis tropical\n- Splendeur automnale au bord du lac\n- Merveille hivernale en montagne\n- Enfer volcanique (attention \u00e0 ne pas vous faire cuire !)\n\n\ud83d\udd25\ud83c\udfd0\ud83e\udd5a\n\nQue vous soyez un pro aguerri ou un d\u00e9butant, Volleggball offre une exp\u00e9rience de volleyball egg-citante qui va vous endurcir le blanc ! Alors ne marchez pas sur des oeufs - attrapez vos amis et pr\u00e9parez-vous \u00e0 battre la concurrence dans cette aventure de volleyball egg-ceptionnelle !\n\n\ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\n---\n\ud83c\udf99\ufe0fDiscutez avec nous sur notre Discord !\nhttps://discord.gg/NvRjfSnmma\n\n", "short_description": "Le meilleur joeuf de volleyball dans ce monde \u00e0 la coque"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pinkmarmotstudios.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Pink Marmot Studios", "support_website_url": null, "website_url": "https://www.pinkmarmotstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "CASUAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8106559496133107"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210390_1421672541637223_4430522060750231209_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xhotUrKMTggQ7kNvgHbYo8_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1kJ-LBT07zII4RxA1uNan54Bm5okjCYJhahy0CuG_8Q&oe=678399E9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Volleggball", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "274332