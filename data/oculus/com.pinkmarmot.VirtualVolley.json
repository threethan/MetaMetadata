{"data": {"node": {"__typename": "Application", "id": "3910010955788003", "organization": {"id": "514462403203330", "viewer_permissions": [], "application_groupings": {"nodes": [{"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "4486563551434692"}]}, "id": "295311585777083"}, {"viewer_has_update_access": false, "full_applications": {"nodes": [{"id": "3910010955788003"}]}, "id": "886090098646518"}]}}, "firstRevision": {"nodes": [{"application": {"id": "3910010955788003", "release_date": 1627928575, "is_concept": false, "platform": "ANDROID_6DOF", "scheduled_offers": {"count": 1}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7954465584675833"}, "id": "1457488524585046"}]}}, "binary": null, "live_binary": null, "created_date": 1723128833, "id": "7785838711538522", "is_initial_release": false, "name_with_fallback": "v10", "pdp_metadata_with_fallback": {"version": 10, "application": {"is_concept": false, "latest_released_pdp_metadata": {"id": "7785842044871522"}, "release_status": "RELEASED", "id": "3910010955788003"}, "id": "7785842044871522", "release_status": "RELEASED", "status": "APPROVED"}, "release_date": 1723446654, "administration_status": "APPROVED", "is_first": false, "release_status": "RELEASED", "release_type": "SCHEDULED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3910010955788003", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1259746821094145"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "PostOculusStore_FreeToPlay.png", "id": "844627027575279", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75297582_844627030908612_100519495280906896_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nRirGGhVIY8Q7kNvgFqT2jl&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYCyT6CtxTbr2d5mXs5wWrQshNhF-cKJ6U8WMSK0MXtViA&oe=66E18DED"}]}, "id": "3703478143313678", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Volleggball", "keywords": [], "long_description": "# \ud83d\udd25\ud83c\udfd0\ud83e\udd5a Smashez avant d'\u00eatre cuit ! \ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\nPr\u00e9parez-vous \u00e0 vous fendre la coquille avec Volleggball, le jeu de volleyball qui vous fera sauter d'oeuf-orie ! \n\nCette eggsp\u00e9rience multijoueur n'est pas pour les poules mouill\u00e9es - c'est une aventure digne des meilleurs omelettes qui vous donnera envie d'y revenir encore et encore !\n\n{844627027575279}\n\n## \ud83d\udc23 Mettez tous vos amis dans le m\u00eame panier \ud83d\udc23 \n\nRejoignez des parties ouvertes et amusez-vous avec des joueurs du monde oeuf-tier, sans vous brouiller (ou pas) !\n\n## \ud83d\udc50 Un gameplay \u00e0 la coque \ud83d\udc50\n\nChoisissez entre des matchs simple ou doubles pour une dose parfaite de comp-oeuf-tition.\n\n## \ud83e\udd5aDes adversaires IA coquasse\ud83e\udd5a\n\nAffrontez des rob\u0153ufs dr\u00f4les et maladroits qui vous feront rire \u00e0 vous en secouer le jaune.\n\n## \ud83d\ude0e Personnalisations \u0153ufs-riginales\ud83d\ude0e \n\nD\u00e9marquez-vous avec des dizaines de fa\u00e7ons de personnaliser votre avacoque.\n\n## \ud83c\udfdd\ufe0f Environnements coquetiers\ud83c\udfdd\ufe0f \n\nFaites des smashes \u00e0 travers 4 cartes incroyables :\n- Paradis tropical\n- Splendeur automnale au bord du lac\n- Merveille hivernale en montagne\n- Enfer volcanique (attention \u00e0 ne pas vous faire cuire !)\n\n\ud83d\udd25\ud83c\udfd0\ud83e\udd5a\n\nQue vous soyez un pro aguerri ou un d\u00e9butant, Volleggball offre une exp\u00e9rience de volleyball egg-citante qui va vous endurcir le blanc ! Alors ne marchez pas sur des oeufs - attrapez vos amis et pr\u00e9parez-vous \u00e0 battre la concurrence dans cette aventure de volleyball egg-ceptionnelle !\n\n\ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\n---\n\ud83c\udf99\ufe0fDiscutez avec nous sur notre Discord !\nhttps://discord.gg/NvRjfSnmma\n\n", "short_description": "Le meilleur joeuf de volleyball dans ce monde \u00e0 la coque"}, {"images": {"nodes": [{"file_name": "PostOculusStore_FreeToPlay.png", "id": "1045102036463669", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75361353_1045102039797002_7060094311243211613_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LoPJAWzLsFAQ7kNvgFcmRrm&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYD3s2CB1o3-KyKtHp6x2dh7pNb_cXvZcu4FIxw1Y63MrA&oe=66E16A2A"}, {"file_name": "Customization.png", "id": "796479432600979", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982566_796479435934312_1716921857363409735_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_G4DsteesEYQ7kNvgGrY6pH&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYC2hpjGahHoIji0GUmGzPEQ2e2A_WpP2bPvWlJKWHTwQg&oe=66E182C6"}, {"file_name": "NEWVolcanoMap.png", "id": "385364441226303", "image_type": "APP_IMG_MARKDOWN_INLINE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031362_385364444559636_8957833416117844976_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ArbOf-NZJF0Q7kNvgHmdXNN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYDYXazrRzUWBm6y3n1Ucy6wq4KhFiPN1oKnOXDVuwvJJQ&oe=66E17B0C"}, {"file_name": "PostOculusStore_Volleggball.png", "id": "1682716595888004", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035315_1682716599221337_7075827842099927230_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bFO-dYYWPsMQ7kNvgFBIuUG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYCk1Mki4mSGzex_Pf6t0wOrDKQznOa0m-XRr-gVG6bYew&oe=66E16DFA"}, {"file_name": "Cover_Square.png", "id": "1421672538303890", "image_type": "