2135", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001726_348869887225468_2871228655726821519_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=26fmBa5GRUcQ7kNvgHuSrOo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYBLTWkFJDqbXLrp5ec30qJmKWxjuaUFMbo_oPtqC_GqXQ&oe=66E198D7"}]}, "id": "2245259855853432", "locale": "en_US", "screenshots": [{"file_name": "PostOculusStore_FreeToPlay.png", "id": "1552696538557236", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974515_1552696541890569_5347462861699962584_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDopvEKN2ygQ7kNvgFPaHQp&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYBlx0qcgB7RvkiHROnRm5SRorVVmntr-bsxBcRCj5xE_A&oe=66E17F81"}, {"file_name": "PostOculusStore_NewContent.png", "id": "921346419069217", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035326_921346422402550_6850587611098269896_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WgjbTT-kIFkQ7kNvgFHCifq&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYCePqHCDkPufihkMGGp3eTSY8_CiURHYnzIZlGMtvVr7g&oe=66E19034"}, {"file_name": "PostOculusStore_FreeYolkies.png", "id": "933413718102958", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003247_933413721436291_435652226654268995_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X9jwhzHoMuQQ7kNvgFLdqJv&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYCHZYicn16Mcl-09_AZmpi_5pLZF02NJg19AZC4f8N4CA&oe=66E1894B"}, {"file_name": "com.pinkmarmot.VirtualVolley-20211203-145600_Moment3 (1).png", "id": "255208209930803", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974613_255208216597469_559092475689458136_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wPVircu1QhYQ7kNvgGV6wC_&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYA_byl6wNIAzKgstpCiaSMe2m0nhgIclGNAXo0L1qRyNw&oe=66E17D94"}, {"file_name": "com.pinkmarmot.VirtualVolley-20211203-150103_Moment2 (1).png", "id": "320468449691304", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031379_320468456357970_3230564276216986875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VnRHXf7o4twQ7kNvgEy9M83&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYBOmifIuFxPkjQ1PiPOuH7TKjJlaOlfsHM3tKzgcrLo1w&oe=66E17952"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PostOculusStore_Volleggball.png", "id": "3722721384723693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974611_3722721391390359_3140296778754052086_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fJ0wlBB2ZFcQ7kNvgF8G-8T&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYBR-Y2HK-TR8U6cc2K2S_E6reT2g6M5HNIUccuqFyByhw&oe=66E16A8D"}, "display_name": "Volleggball", "keywords": ["volleyball", "sport", "coop", "competitive", "multiplayer"], "long_description": "# \ud83d\udd25\ud83c\udfd0\ud83e\udd5a Spike before you get cooked ! \ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\nGet ready to crack up with Volleggball, the egg-citing volleyball game that'll have you jump for victory! \n\nThis yolk-tastic multiplayer experience is no chicken feed \u2013 it's a shell-shocking adventure that'll keep you coming back for more!\n\n{1045102036463669}\n\n## \ud83d\udc23 Scramble with your friends\ud83d\udc23 \n\nJump into open lobbies and get cracking with players from around the globe!\n\n## \ud83d\udc50 Sunny-side up gameplay \ud83d\udc50\n\nChoose between 1vs1 or 2vs2 matches for the perfect serving of competition\n\n## \ud83e\udd5aHilarious AI Opponents\ud83e\udd5a\n\nFace off against funny, clumsy egg bots that'll keep you laughing as you play\n\n## \ud83d\ude0e Egg-spressive customization \ud83d\ude0e \n\nStand out from the carton with dozens of ways to personalize your egg-vatar\n\n## \ud83c\udfdd\ufe0f Eggs-quisite environments \ud83c\udfdd\ufe0f\n\nSpike your way through 4 egg-mazing maps: \n- Tropical Island Paradise\n- Autumn Lake Splendor\n- Winter Mountain Wonderland\n- Volcanic Inferno (careful not to get poached!)\n\n\ud83d\udd25\ud83c\udfd0\ud83e\udd5a\n\nWhether you're a seasoned pro or just out of your shell, Volleggball offers an egg-citing VR experience that's no yolk! So don't chicken out \u2013 grab your friends and get ready to scramble the competition in this egg-ceptional volleyball adventure!\n\n\ud83e\udd5a\ud83c\udfd0\ud83d\udd25\n\n---\n\ud83c\udf99\ufe0fChat with us on our discord ! https://discord.gg/NvRjfSnmma\n", "short_description": "Best volleyball game in the egg world!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.pinkmarmotstudios.com/policy", "developer_terms_of_service_url": null, "publisher_name": "Pink Marmot Studios", "support_website_url": null, "website_url": "https://www.pinkmarmotstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SIMULATION", "CASUAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7785842044871522"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210390_1421672541637223_4430522060750231209_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5fcaFhwbaMcQ7kNvgHgouCP&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALJ45A32DhxlE_44bQffE-G&oh=00_AYDIqP2dAupiIsfdduiv89WGJVVeb7Aqm9iIPOUTZDfPGw&oe=66E17169"}, "is_conce