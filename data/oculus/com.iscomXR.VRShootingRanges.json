8_815726647310948_3362039653801996321_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BFhg-t4lhOcQ7kNvgFGEJ9q&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDRd9cwBF1zE9UGC5E5uiliSQKpWTA2Xqc7PAkcMKZi8g&oe=670131A4"}, {"file_name": "Screen03.png", "id": "458792463814758", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982634_458792467148091_4598735201883525848_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yc-el3rFSnQQ7kNvgEq96WJ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBw1OfoAvKpbb-KhMyjSa4fecD9p0ii6pS7G8UPv2ekWA&oe=67013C10"}, {"file_name": "Screen04.png", "id": "882170897297199", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982608_882170900630532_4473124677356716627_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EFK4d7qlZE8Q7kNvgEWm5Qh&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC2lQ-PVIEPc5lJx003DxxL0_ZLg7bKMF1Fuok0bZ9sbA&oe=67011069"}, {"file_name": "Screen05.png", "id": "482368991227096", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974723_482368994560429_7585562947056232922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7YDztkmcSooQ7kNvgFfFfi-&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDO9haHsH2G9vBgv7d7oSFH7MM8GD3B6aHcgfN7zADJQw&oe=67012CA8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "490910340337703", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982706_490910343671036_2809014443838437620_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zul7x1QaT6gQ7kNvgGxi7fa&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBOjD8LPwYxFZdp1wo5sSrEurNNtmVjy7RQCKtSgJh2fw&oe=6701250D"}, "display_name": "VRShootingRanges", "keywords": [], "long_description": "Enhances Reaction Speed and Focus: Due to the time-limited nature of the game, players need to quickly aim and shoot targets within the given timeframe, significantly improving reaction speed and focus.\n\nImproves Hand-Eye Coordination: The game requires players to maintain precise aim on moving targets, which greatly aids in enhancing hand-eye coordination.\n\nProvides a Safe Shooting Experience: Practicing shooting in a virtual environment allows players to experience the thrill and challenges of shooting while avoiding the potential risks associated with real-world shooting.\n\nGradual Skill Improvement: With the three different difficulty levels, players can gradually improve their shooting skills, allowing them to tackle more challenging scenarios.\n\nRelaxation and Stress Relief: The shooting game offers a way for players to relax, providing a temporary escape from the stresses of daily life by focusing on shooting targets.", "short_description": "This virtual shooting range game allows players to enhance their shooting skills in a safe environment. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://ecom.iscom.sg/index.php?route=information%2Finformation&language=en-gb&information_id=3", "developer_terms_of_service_url": null, "publisher_name": "IS COM XR Apps Developer", "support_website_url": null, "website_url": "https://ecom.iscom.sg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8125401627556361"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1216498142717299"}]}, "baseline_offer": {"id": "1216498142717299"}, "is_approved": true, "firstOffer": {"nodes": [{"