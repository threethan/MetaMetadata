6_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YjfInBlQkWwQ7kNvgEjqC3M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpPJ7SG-5rfze8yX1ZAUqpVz93MrPAfDAN18qncS3hzA&oe=67851772"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-image-oculus.png", "id": "111068434439188", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984460_111068437772521_8603171618917798057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OosDGGxshREQ7kNvgEeiseu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkokfmPEi7GiKT4dOJ_zHG5cPtcUfYgH4IT9MAA6t_pA&oe=6784FCAC"}, "display_name": "YUKI", "keywords": ["new", "best", "cool", "games", "2021"], "long_description": "PRE-ORDER TODAY WITH 10% OFF! \n\nYUKI is an upbeat mix of the bullet-hell and roguelike game genres in VR, set in an incredible anime universe.  Step into the wild imagination of a child and fly through multidimensional worlds holding her favorite action character, Yuki. Use your hands to fly Yuki and dodge loads of bullets and obstacles that cross your path! Groove to the sound of mesmerizing music as you maneuver through each of the new spellbinding game levels while blasting the evil Yokaliens.\n\nAs you embark on this enthralling spatial VR-designed gameplay, you\u2019ll find yourself getting into a smooth choreography with enemies, bullets, and obstacles. Collect cool power-ups to become stronger as you face new levels that surprise you every time. The more you play, the more powerful you become, and better are the chances you'll make it through. After all, a child's imagination can cease evil, and the only way to save the universe is to play like a kid!", "short_description": "PRE-ORDER TODAY WITH 10% OFF! YUKI is a new upbeat mix of bullet-hell and roguelike game in VR! Enter a kid\u2019s wild imagination and fly through an anime universe controlling Yuki\u2019s action figure. Dodge bullets and cool obstacles, while fighting evil forces. Enjoy this new experience and one of the best games released in 2021!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://arvore.io/privacy-policy/yuki/", "developer_terms_of_service_url": null, "publisher_name": "ARVORE Immersive Experiences", "support_website_url": "https://discordapp.com/invite/WYbwX8GF8u", "website_url": "http://www.yukivrgame.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "327628065955338"}}]}, "scheduled_offers": {"count": 11, "nodes": [{"status": "PUBLISHED", "id": "642481704773757"}, {"status": "PUBLISHED", "id": "1607663506792767"}, {"status": "PUBLISHED", "id": "2041845019579145"}, {"status": "PUBLISHED", "id": "1179907763462187"}, {"status": "PUBLISHED", "id": "1474668723151268"}, {"status": "PUBLISHED", "id": "334111481948206"}, {"status": "PUBLISHED", "id": "500205107874907"}, {"status": "PUBLISHED", "id": "552083279255370"}, {"status": "PUBLISHED", "id": "545119760177983"}, {"status": "PUBLISHED", "id": "271137096014190"}, {"status": "PUBLISHED", "id": "1729013160622019"}]}, "baseline_offer": {"id": "642481704773757"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1736367060, "status": "PUBLISHED", "id": "642481704773757"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "i