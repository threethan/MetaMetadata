}, {"file_name": "Arcade-Legend-ScreenShot-Multiplayer.png", "id": "522675833125749", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974817_522675836459082_401004978519256163_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hCf61Z5cu48Q7kNvgHcM-AW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyeWC5YV8NZgUVmq0J0VLEsNpE0lNBXzY2fZYQmOSXOw&oe=6742FBF9"}, {"file_name": "Arcade-Legend-ScreenShot-7.png", "id": "678364266986275", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031562_678364270319608_5229569528347897268_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hHcFkz2eAF0Q7kNvgGpUsgH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCEydkx5alhtrUpay6809yciwZAO6h8hdWOpWTPN1NDw&oe=67432838"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Arcade-Legend-Video-Thumbnail-v2.png", "id": "697083368210796", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223477_697083371544129_9128614203797304007_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IKAloBunhN0Q7kNvgEXcdfQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0whMJExt4aDDheab1XV_CjmDmE9Ks7BNRjCDo8QDxMg&oe=67430C3C"}, "display_name": "Arcade Legend", "keywords": ["arcade", "legend", "social", "party", "bowling"], "long_description": "Congratulations! You\u2019re the unexpected owner of an abandoned arcade, and it\u2019s up to you to convert this dilapidated building into a thriving business.\n\nWith incredible tools at your disposal and a wide variety of materials, furniture and decorations, you will restore, customize and expand your venue, revealing the forgotten secrets of this mysterious old building.\n\nFill your arcade with officially licensed games, which are yours to play for free, forever! Win tickets and claim prizes from an expansive range of consumable and collectible items in your very own prize store.\n\nInvite friends to your arcade for head-to-head competition, explore other arcades, and compete on leaderboards against the best players around the globe.\n\nArcade Legend is the authentic arcade experience for the virtual world!", "short_description": "You\u2019re the unexpected owner of an abandoned arcade! The incredible tools at your disposal allow you to fully customize your venue as you work to discover its hidden secrets.\n\nPlay officially licensed arcade games to win tickets and claim prizes from your very own prize store.\n\nInvite friends to your arcade for head-to-head competition and compete on leaderboards against the best players around the globe.\n\nArcade Legend is the authentic arcade experience for the virtual world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://arcadelegendvr.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "LAI Games", "support_website_url": "https://arcadelegendvr.com/support/", "website_url": "https://arcadelegendvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "324472783062664"}}]}, "scheduled_offers": {"count": 24, "nodes": [{"status": "PUBLISHED", "id": "582456944252537"}, {"status": "PUBLISHED", "id": "378653248628777"}, {"status": "PUBLISHED", "id": "786192440170722"}, {"status": "PUBLISHED", "id": "460596209676690"}, {"status": "PUBLISHED", "id": "810406310681221"}, {"status": "PUBLISHED", "id": "1554622941682709"