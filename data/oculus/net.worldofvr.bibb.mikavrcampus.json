iad3-1.oculuscdn.com&oh=00_AYBfSeXjQWxlbGPJLvX9RAVjXXdlEEP1UyNAuEU8pNqqIw&oe=67177E50"}, {"file_name": "Outro.png", "id": "833532391864456", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982727_833532395197789_2455978168416510090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YpWduR1fgMkQ7kNvgEKp-4k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPceAxaZ64u8MScALpaP2Yi1cbsAfE0YJ78KuQUtSN2A&oe=67178CA9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1350689075540903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031363_1350689078874236_3671146087760275177_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i32ielIuMOgQ7kNvgEk53Z-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC906ad9iR9H04yowSnPu7WJdiSHZctnpKhq1RnLwBFA&oe=67179315"}, "display_name": "MIKA VR Campus", "keywords": [], "long_description": "Willkommen bei MIKA VR!\nMIKA, die Abk\u00fcrzung f\u00fcr \"Medien- und IT-Kompetenz in der Ausbildung\", pr\u00e4sentiert MIKA VR \u2013 eine Virtual Reality-Anwendung, die speziell entwickelt wurde, um Ausbildungspersonal mit immersiven Medien vertraut zu machen. Ihr Ziel ist es, eine Br\u00fccke zwischen traditionellen Lehrmethoden und den M\u00f6glichkeiten immersiver Medien in der Berufsbildung zu schlagen.\n\nWarum MIKA VR?\nMIKA VR bietet eine Einf\u00fchrung in verschiedene Darstellungsformen immersiver Medien, darunter:\n360\u00b0-Video: Tauchen Sie in fotorealistische Rundumansichten ein.\n3D-Umgebung: Erleben Sie interaktive dreidimensionale Welten.\nAugmented Reality: Verschmelzen Sie digitale Elemente mit der realen Umgebung.\n3D-Scan: Erforschen Sie hochaufl\u00f6sende, dreidimensionale Modelle.\nMIKA Space: Werden Sie selbst aktiv! Im MIKA Space k\u00f6nnen sie Modelle selber bauen, praktische Anwendungsbeispiele aus der Berufsbildung entdecken und kollaboratives Arbeiten \u00fcben. \n\nAnwendungsbeispiele aus der Berufsbildung\nMIKA VR zeigt nicht nur die Darstellungsformen von immersiven Medien, sondern veranschaulicht auch ihre Anwendungsm\u00f6glichkeiten f\u00fcr die Ausbildung an praxisnahen Beispielen. Wir zeigen Ihnen, wie immersive Medien in verschiedenen Branchen und Berufsfeldern eingesetzt werden k\u00f6nnen, um die Lern- und Lehrerfahrung zu bereichern.\n\n\n\n", "short_description": "MIKA, die Abk\u00fcrzung f\u00fcr \"Medien- und IT-Kompetenz in der Ausbildung\", pr\u00e4sentiert MIKA VR \u2013 eine Virtual Reality-Anwendung, die speziell entwickelt wurde, um Ausbildungspersonal mit immersiven Medien "}]}, "developer_name": null, "developer_privacy_policy_url": "https://worldofvr.de/datenschutz-mika-vr-campus/", "developer_terms_of_service_url": null, "publisher_name": "World of VR GmbH", "support_website_url": null, "website_url": "https://www.worldofvr.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7151924998257900"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "729983292369336"}]}, "baseline_offer": {"id": "729983292369336"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1708110600, "status": "PUBLISHED", "id": "729983292369336"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7150595958390804", "version": "1.1.2"}, "id": "3434396910145951", "channel_name": "LIVE"}]}, "is