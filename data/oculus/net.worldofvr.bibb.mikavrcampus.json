80_911512466948279_759698115856434292_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9hO-NS9NB-EQ7kNvgHBrs3a&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgAA16yG_4wJd0glQsnjSCdMnXdcEjKL2RxFEY629XIA&oe=671780CA"}, {"file_name": "cover_land.png", "id": "868005494919879", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982686_868005498253212_1847485979690881328_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KlOMbTvP9roQ7kNvgFW7zum&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJG6eTvtfdI8X_My0mPnQ3FfAeyrW0px2gXfFrp46cqg&oe=671793EC"}]}, "id": "1504263713553213", "locale": "en_US", "screenshots": [{"file_name": "360.png", "id": "1447382299523604", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570301_1447382302856937_1803661992115352449_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_1qf9y6_eQ8Q7kNvgFX6xAt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2hDLg-4lN-lD3zb0Ym-EdtrQN6H59Uxskf7JM__mzmg&oe=6717A3D1"}, {"file_name": "CAD.png", "id": "896391335608882", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_896391338942215_8604677652732219281_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kVDBafsxnyMQ7kNvgFR8twd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC8dZmHyycoHjoYVbJ4wWwMKMlpeIaFArESwaRc7icaEw&oe=6717A4BC"}, {"file_name": "Scan.png", "id": "308872574992257", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223475_308872578325590_6636054780775919658_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FEbeOhimaAEQ7kNvgHVCQWL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAoQ5BiXcTaGeI53KX2Mvv1ud9yIPoWbe4_tsbWKYB1ZA&oe=671796CE"}, {"file_name": "AR.png", "id": "1120942435738297", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75422394_1120942439071630_4444957082847083691_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wyxT_BA7sOEQ7kNvgE7-UTd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfSeXjQWxlbGPJLvX9RAVjXXdlEEP1UyNAuEU8pNqqIw&oe=67177E50"}, {"file_name": "Outro.png", "id": "833532391864456", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982727_833532395197789_2455978168416510090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YpWduR1fgMkQ7kNvgEKp-4k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPceAxaZ64u8MScALpaP2Yi1cbsAfE0YJ78KuQUtSN2A&oe=67178CA9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1350689075540903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031363_1350689078874236_3671146087760275177_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i32ielIuMOgQ7kNvgEk53Z-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC906ad9iR9H04yowSnPu7WJdiSHZctnpKhq1RnLwBFA&oe=67179315"}, "display_name": "MIKA VR Campus", "keywords": [], "long_description": "**MIKA VR - Eine Einf\u00fchrung in immersive Medien in der Ausbildung**\n\nDie berufsbegleitende und bundesweit angebotene Weiterbildung MIKA steht f\u00fcr Medien- und IT-Kompetenz f\u00fcr Ausbildungspersonal und wird vom Bundesministerium f\u00fcr Bildung und Forschung gef\u00f6rdert. Tauchen Sie mit MIKA-VR ein in 360\u00b0-Videos, interaktive 3D-Umgebungen, Augmented Reality und 3D-Scans. \n\nMIKA-VR bietet eine interaktive und effektive M\u00f6glichkeit, Ausbildungspersonal in die Welt immersiver Medien einzuf\u00fchren.\n\nErleben Sie praxisnahe Anwendungsbeispiele aus verschiedenen Branchen oder Berufsfeldern und entdecken Sie neue virtuelle M\u00f6glichkeiten f\u00fcr Ihre Ausbildung!\n\nWeitere Informationen unter:\n- **Bundesinstitut f\u00fcr Berufsbildung (BIBB):** https://www.bibb.de/ \n- **Leando:** https://leando.de/\n- **MIKACAMPUS\u00ae:** https://training.leando.de/goto_mika_cat_23116.html\n\nKontakt: MIKA@bibb.de\n\n", "short_description": "MIKA VR - Eine Einf\u00fchrung in immersive Medien in der Ausbildung "}]}, "developer_name": null, "developer_privacy_policy_url": "https://worldofvr.de/datenschutz-mika-vr-campus/", "developer_terms_of_service_url": null, "publisher_name": "World of VR GmbH", "support_website_url": null, "website_url": "https://www.worldofvr.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "421923165850360"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7592534554196940"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031370_1435194640371500_4843368527435125828_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oXdRgfj_XiMQ7kNvgEPuX65&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAcVYW4Q7wpmdWSCg-qgfLNxjrEezAQgEAXvRO9pTTddg&oe=6717A977"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MIKA VR Campus", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Business", "id": "421923165850360"}], "release_date": 1708110600, "lastRevision": {"nodes": [{"id": "6809075229209547", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6809075195876217", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "189876500839727"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "logo.png", "id": "147011384