nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9N2K4ZxQJMgQ7kNvgGo6t54&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDJG7XLDvq1NfGB7BJBrCxoAYHO4pERE2979RjOjNyzHw&oe=6701174A"}, {"file_name": "cover_land.png", "id": "868005494919879", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982686_868005498253212_1847485979690881328_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4gm0I2Ps2tsQ7kNvgHXik_y&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBxRz4roiCRJ0dDL7lI_kEMWkujqaTTrvSPXtuSKdMOYg&oe=67012A6C"}]}, "id": "1504263713553213", "locale": "en_US", "screenshots": [{"file_name": "360.png", "id": "1447382299523604", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57570301_1447382302856937_1803661992115352449_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pL-BUch3VvYQ7kNvgElNYgQ&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCWydtBN1BtQpR2eLRGC0vsQaXnsyOXdYW6CuXTH5OwKw&oe=67013A51"}, {"file_name": "CAD.png", "id": "896391335608882", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982548_896391338942215_8604677652732219281_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g7Mo1rvRJnMQ7kNvgH3tB45&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBr6zFQMMV6lhWFt6g3ZgvyaPariYOxUPdG-0chDd0JNg&oe=67013B3C"}, {"file_name": "Scan.png", "id": "308872574992257", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75223475_308872578325590_6636054780775919658_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xF8tlf0xFl8Q7kNvgF2tCPg&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAPEp2v2Tn9O6PMPgxY19Odj_4AjXdQ5ChU1Dj5HzU68g&oe=67012D4E"}, {"file_name": "AR.png", "id": "1120942435738297", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75422394_1120942439071630_4444957082847083691_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v8_QeuLch1EQ7kNvgFlovei&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCJoexAZ_8w42A7WOJeziwr8qjFM2dGAY1CjyO_LcDy7w&oe=670114D0"}, {"file_name": "Outro.png", "id": "833532391864456", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982727_833532395197789_2455978168416510090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EDTllsLcIn0Q7kNvgEC2CxP&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYArraxFC_lhgTMMkvqFVsbB2-Aaj-RmprWQXbKwxqO64w&oe=67012329"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1350689075540903", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031363_1350689078874236_3671146087760275177_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CRrQaoH0gkYQ7kNvgE5SK6r&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAbXjMXHO_387N8CYlNSp3Jm2_7FKdQIWBAWTudetux0w&oe=67012995"}, "display_name": "MIKA VR Campus", "keywords": [], "long_description": "**MIKA VR - Eine Einf\u00fchrung in immersive Medien in der Ausbildung**\n\nDie berufsbegleitende und bundesweit angebotene Weiterbildung MIKA steht f\u00fcr Medien- und IT-Kompetenz f\u00fcr Ausbildungspersonal und wird vom Bundesministerium f\u00fcr Bildung und Forschung gef\u00f6rdert. Tauchen Sie mit MIKA-VR ein in 360\u00b0-Videos, interaktive 3D-Umgebungen, Augmented Reality und 3D-Scans. \n\nMIKA-VR bietet eine interaktive und effektive M\u00f6glichkeit, Ausbildungspersonal in die Welt immersiver Medien einzuf\u00fchren.\n\nErleben Sie praxisnahe Anwendungsbeispiele aus verschiedenen Branchen oder Berufsfeldern und entdecken Sie neue virtuelle M\u00f6glichkeiten f\u00fcr Ihre Ausbildung!\n\nWeitere Informationen unter:\n- **Bundesinstitut f\u00fcr Berufsbildung (BIBB):** https://www.bibb.de/ \n- **Leando:** https://leando.de/\n- **MIKACAMPUS\u00ae:** https://training.leando.de/goto_mika_cat_23116.html\n\nKontakt: MIKA@bibb.de\n\n", "short_description": "MIKA VR - Eine Einf\u00fchrung in immersive Medien in der Ausbildung "}]}, "developer_name": null, "developer_privacy_policy_url": "https://worldofvr.de/datenschutz-mika-vr-campus/", "developer_terms_of_service_url": null, "publisher_name": "World of VR GmbH", "support_website_ur