-fra5-2.oculuscdn.com/v/t64.5771-25/38982480_911512466948279_759698115856434292_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iKTDGSRPXrMQ7kNvgGj4WCW&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCYnCSQC70X5zIOtGAZLzMmnsCCOGEWTTHmzU0YJ1u33g&oe=675182CA"}, {"file_name": "cover_land.png", "id": "868005494919879", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982686_868005498253212_1847485979690881328_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FJ0yPDXo2u0Q7kNvgFjn9MI&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCrH2fWYB7pH-BLZVSX0SbFciegKjQB-3Wc9Xu3PspBdw&oe=675195EC"}]}, "id": "862906222250622", "locale": "en_US", "screenshots": [{"file_name": "360.png", "id": "1447382299523604", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57570301_1447382302856937_1803661992115352449_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3S4OEVLhKw8Q7kNvgH4qFlW&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYABi4r7ETJEMpvarpxV5_znuCcEF2a9twpfxUb__y0CLg&oe=6751A5D1"}, {"file_name": "CAD.png", "id": "896391335608882", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38982548_896391338942215_8604677652732219281_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rA75zOIB95gQ7kNvgE5eO0u&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYB8mxllI9ZbHkzO-d5yE6p2vU8-lKoRNl0kvHgr1uTbtQ&oe=6751A6BC"}, {"file_name": "Scan.png", "id": "308872574992257", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75223475_308872578325590_6636054780775919658_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZinDB3HOgzEQ7kNvgFNSV0-&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYClGafuNvna4XR8Jg_c_ZdgOYmj2Vm0t7PkSkvOPLVUtQ&oe=675198CE"}, {"file_name": "AR.png", "id": "1120942435738297", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75422394_1120942439071630_4444957082847083691_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZPzVDefAQ8kQ7kNvgE6FoII&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA8QPfXzksjAzFgSbFC9J5n-Wrl6lf0Jw5E6FVwhZ99Aw&oe=67518050"}, {"file_name": "Outro.png", "id": "833532391864456", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982727_833532395197789_2455978168416510090_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=64KeenGaj6AQ7kNvgGXkbYo&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDqPUtyPOCOHTU2V2T0TZpZzpNkeWt_gdmG9vFwZ9TvKg&oe=67518EA9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1350689075540903", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031363_1350689078874236_3671146087760275177_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k1cT7eiP27QQ7kNvgG3_gc_&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAlMDxyUBCWXum4BGSRUnzx-VZUHwW9yvB-z31kJmZMxQ&oe=67519515"}, "display_name": "MIKA VR Campus", "keywords": [], "long_description": "Willkommen bei MIKA VR!\nMIKA, die Abk\u00fcrzung f\u00fcr \"Medien- und IT-Kompetenz in der Ausbildung\", pr\u00e4sentiert MIKA VR \u2013 eine Virtual Reality-Anwendung, die speziell entwickelt wurde, um Ausbildungspersonal mit immersiven Medien vertraut zu machen. Ihr Ziel ist es, eine Br\u00fccke zwischen traditionellen Lehrmethoden und den M\u00f6glichkeiten immersiver Medien in der Berufsbildung zu schlagen.\n\nWarum MIKA VR?\nMIKA VR bietet eine Einf\u00fchrung in verschiedene Darstellungsformen immersiver Medien, darunter:\n360\u00b0-Video: Tauchen Sie in fotorealistische Rundumansichten ein.\n3D-Umgebung: Erleben Sie interaktive dreidimensionale Welten.\nAugmented Reality: Verschmelzen Sie digitale Elemente mit der realen Umgebung.\n3D-Scan: Erforschen Sie hochaufl\u00f6sende, dreidimensionale Modelle.\nMIKA Space: Werden Sie selbst aktiv! Im MIKA Space k\u00f6nnen sie Modelle selber bauen, praktische Anwendungsbeispiele aus der Berufsbildung entdecken und kollaboratives Arbeiten \u00fcben. \n\nAnwendungsbeispiele aus der Berufsbildung\nMIKA VR zeigt nicht nur die Darstellungsformen von immersiven Medien, sondern veranschaulicht auch ihre Anwendungsm\u00f6glichkeiten f\u00fcr die Ausbildung an praxisnahen Beispielen. Wir zeigen Ihnen, wie immersive Medien in verschiedenen Branchen und Berufsfeldern eingesetzt werden k\u00f6nnen, um die Lern- und Lehrerfahrung zu bereichern.\n\n\n\n", "short_description": "MIKA, die Abk\u00fcrzung f\u00fcr \"Medien- und IT-Kompetenz in der Ausbildung\", pr\u00e4sentiert MIKA VR \u2013 eine Virtual Reality-Anwendung, die speziell entwickelt wurde, um Ausbildungspersonal mit immersiven Medien "}]}, "developer_name": null, "developer_privacy_policy_url": "https://worldofvr.de/datenschutz-mika-vr-campus/", "developer_terms_of_service_url": null, "publisher_name": "World of VR GmbH", "support_website_url": null, "website_url": "https://www.worldofvr.net/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7151924998257900"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "729983292369336"}]}, "baseline_offer": {"id": "729983292369336"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1708110600, "status": "PUBLISHED", "id": "729983292369336"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7150595958390804", "version": "1.1.2"}, "id": "3434396910145951", "channel_name": "LIVE"}]}, 