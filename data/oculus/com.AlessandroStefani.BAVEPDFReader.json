4.5771-25/39031456_578777177835924_5647234019236652575_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eKZU8RpqGwUQ7kNvgFxzOyM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAmjAtoOeR0SnzEE4l-uT19_pmiJCx0ja6-QjYKKhMlQ&oe=677D2833"}, {"file_name": "Screen-5.png", "id": "1744410642996406", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031339_1744410649663072_9038105118067916280_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GSCjVkL0NRsQ7kNvgEDkeOs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBj9JYkAMb0UUcfKmNpkJMPtGswElVn_mSQp9pFDuW4hQ&oe=677D16D1"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PDF Reader", "keywords": ["PDF", "reader", "document", "office", "bave"], "long_description": "This free PDF viewer can display PDF files in real scale in passthrough.\nIt's mainly intended to display documents in real size (A4,A3,A2,A1,A0).\nUseful for readers, creatives, architects and engineers that wants to visualize the documents before printing them (save the trees!) in a fast and easy way.\nSimply drag and drop your PDF files from the PC to your quest via the USB cable, download them with the internet browser., or connect a USB storage (USB OTG Supported).\nAt the first app opening, remember to grant the permission to read your files when asked. All your files local, without remote processing, cloud sharing or requirement for accounts.\nIt does not support advanced PDF functions like password protection, fileOpen etc.\nThe app is still in developing phase, all feedback is appreciated!", "short_description": "Free, simple and fast PDF viewer (preview)"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.bave.info/privacynotice", "developer_terms_of_service_url": null, "publisher_name": "Alessandro Stefani", "support_website_url": null, "website_url": "http://www.bave.info/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692