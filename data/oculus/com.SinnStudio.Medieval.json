uluscdn.com&oh=00_AYCCKpLmppguaFKsKBsmfgeU-tC6LIerNoJmO5a8Apak2Q&oe=6785140B"}, {"file_name": "SM1_Quest_Screenshot_02_2560x1440.png", "id": "830937845065239", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572957_830937848398572_4732046014359676178_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tVGW1xmVs1UQ7kNvgH77YQm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJfGabVc8txTpUN17gSnxXYi8vmB83uvU9eYAYIrTyAA&oe=6784EB69"}, {"file_name": "SM1_Quest_Screenshot_10_2560x1440.png", "id": "9750576061679198", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75234364_9750576071679197_3624091386835304979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JfeFZIFUntcQ7kNvgHCWMEG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBv7CitomK16WF8P1peHLINN4Fp4ok9Fp1iU2e7rjXOeA&oe=67850276"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SM1_Claus_Quest_TrailerCover_Landscape_2560x1440 (1).png", "id": "1799382404144436", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75451781_1799382407477769_661240311382443040_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LoOwWiSs5J4Q7kNvgEakI2Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYArLI-EGcBwRpj7JwHlS6FI8ggcaKMxqCBmFxjLF4aznA&oe=67851CC7"}, "display_name": "Swordsman", "keywords": ["combat", "swords", "fighting", "blade", "realistic"], "long_description": "You\u2019ll have to defeat a skilled Claus while looking over your shoulder for his flying beholders while making sure you don\u2019t fall into the freezing waters of the North Pole. Not many will succeed, but the ones that do will be rewarded. \u2694\ufe0f\u2744\ufe0f  \n\nMore on Swordsman: \n\nSwordsman is a physics-based medieval combat game designed for virtual reality. \n\nThe game features Knights, Vikings, Mongols, Samurai, Pirates, realistic armor physics, epic boss fights and powerful boss weapons, a Kraken, RPG player progression and customization, a Blacksmith, Armorer and Skill Master to help you build a character suited to your playstyle and lots of items to buy and unlock, all in effort to stop the J\u00f6tunn from taking over the world. \n\nThe J\u00f6tunn has recruited captains from all over the world, giving them godly weapons with which to command powerful armies. He wields seemingly infinite power: Hellfire.\n\nSwordsman also features gameplay modifiers. These will let you change how the core game works in fun and interesting ways. Hardcore enemies, invisible enemies (floating swords), Doomfist (super strength), the ability to slow time down whenever you want and many more.", "short_description": "The Claus Battle is here and it's brutal! \u2694\ufe0f\u2744\ufe0f  \n\nSwordsman is a physics-based medieval combat game designed for virtual reality. The game features advanced weapon handling, dismemberment, realistic armor physics, factions and boss fights, RPG elements and player progression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sinnstudio.com/privacy-policy/", "developer_terms_of_service_url": "https://sinnstudio.com/terms-of-service/", "publisher_name": "Sinn Studio Inc.", "support_website_url": "https://sinnstudio.com/contact/", "website_url": "https://sinnstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_VE", "de", "es_AR", "ko", "es_PE", "en", "fr", "es", "es_PR", "ja", "es_CL", "es_MX", "zh_CN", "es_CO", "zh_HK"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", 