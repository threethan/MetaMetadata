&oe=66F685A0"}, {"file_name": "38982608_708167126449080_452779246691541386_n.png", "id": "4128661433911977", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974874_4128661437245310_4058106861531004112_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wdJTr5aoQkQQ7kNvgE9K2IV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlotS4JgZaRRKKXooYP8DKw&oh=00_AYB9WgBmrR8n2lXrNFoq8F0TY84bRxN-3ZmlP21iFBnw7w&oe=66F6A1AC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39001692_334264194667765_5196668722407465283_n.png", "id": "209260867897882", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_209260871231215_1421022200260640740_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pAAZ-HUPQo0Q7kNvgGvyRMT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AlotS4JgZaRRKKXooYP8DKw&oh=00_AYDr5pm3DRXh36Htx7eK5W-Pw6bQ70L7z_-7O8t0MmW7xA&oe=66F6A93C"}, "display_name": "Swordsman", "keywords": [], "long_description": "Swordsman is a physics-based medieval combat game designed for virtual reality. \n\nThe game features Knights, Vikings, Mongols, Samurai, Pirates, realistic armor physics, epic boss fights and powerful boss weapons, a Kraken, RPG player progression and customization, a Blacksmith, Armorer and Skill Master to help you build a character suited to your playstyle and lots of items to buy and unlock, all in effort to stop the J\u00f6tunn from taking over the world. \n\nThe J\u00f6tunn has recruited captains from all over the world, giving them godly weapons with which to command powerful armies. He wields seemingly infinite power: Hellfire.\n\nSwordsman also features gameplay modifiers. These will let you change how the core game works in fun and interesting ways. Hardcore enemies, invisible enemies (floating swords), Doomfist (super strength), the ability to slow time down whenever you want and many more.", "short_description": "Swordsman is a physics-based medieval combat game designed for virtual reality. The game features advanced weapon handling, dismemberment, realistic armor physics, factions and boss fights, RPG elements and player progression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sinnstudio.com/privacy-policy/", "developer_terms_of_service_url": "https://sinnstudio.com/terms-of-service/", "publisher_name": "Sinn Studio Inc.", "support_website_url": "https://sinnstudio.com/contact/", "website_url": "https://sinnstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "935740177094186"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PUBLISHED", "id": "940218567790357"}, {"status": "PENDING", "id": "6433017616808470"}, {"status": "PUBLISHED", "id": "596187948287437"}, {"status": "PENDING", "id": "1687783515057032"}, {"status": "PUBLISHED", "id": "1306781823449388"}, {"status": "PENDING", "id": "1216001692689149"}, {"status": "PUBLISHED", "id": "1510733259672414"}, {"status": "PENDING", "id": "716071860077247"}, {"status": "PUBLISHED", "id": "1407022796850758"}, {"status": "PUBLISHED", "id": "310446238472388"}, {"status": "PENDING", "id": "646571727663934"}, {"status": "PENDING", "id": "847861429627798"}, {"status": "CANCELLED", "id": "558706512755204"}]}, "baseline_offer": {"id": "1510733259672414"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721667600, "status": "PUBLISHED", "id": "940218567790357"}]}, "liveChannel": {"node