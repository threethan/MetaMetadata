_8E-7AFpn9KzQmuOdXmhwe7kqr9kGZMShgrVYQRwg&oe=66FE7269"}, {"file_name": "SM1_Quest_Screenshot_10_2560x1440.png", "id": "9750576061679198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234364_9750576071679197_3624091386835304979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zr1YZIXE6EcQ7kNvgFlbiKY&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMunH6Kw_8qNY2qFycf6-d5MEGVvZkOhHK6w93YR_8nw&oe=66FE8976"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SM1_Quest_TrailerCover_2560x1440.png", "id": "1339488779978594", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974626_1339488783311927_7293579740847162876_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w0tEk9F7ItUQ7kNvgGAyZxV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHB2fIhKQHlngz8AoQb3vrO47xmJgssvnv_9PAgXonGw&oe=66FE6938"}, "display_name": "Swordsman", "keywords": ["combat", "swords", "fighting", "blade", "realistic"], "long_description": "Our NEW Training Grounds & Leaderboards updates bring the competitiveness you've been waiting for in Swordsman. Compete cross-platform on many different challenges, such as hand-to-hand combat, tatami mat, and archery. Will you try to crack the top 100 leaderboard? \n\nMore on Swordsman: \n\nSwordsman is a physics-based medieval combat game designed for virtual reality. \n\nThe game features Knights, Vikings, Mongols, Samurai, Pirates, realistic armor physics, epic boss fights and powerful boss weapons, a Kraken, RPG player progression and customization, a Blacksmith, Armorer and Skill Master to help you build a character suited to your playstyle and lots of items to buy and unlock, all in effort to stop the J\u00f6tunn from taking over the world. \n\nThe J\u00f6tunn has recruited captains from all over the world, giving them godly weapons with which to command powerful armies. He wields seemingly infinite power: Hellfire.\n\nSwordsman also features gameplay modifiers. These will let you change how the core game works in fun and interesting ways. Hardcore enemies, invisible enemies (floating swords), Doomfist (super strength), the ability to slow time down whenever you want and many more.", "short_description": "Swordsman is a physics-based medieval combat game designed for virtual reality. The game features advanced weapon handling, dismemberment, realistic armor physics, factions and boss fights, RPG elements and player progression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sinnstudio.com/privacy-policy/", "developer_terms_of_service_url": "https://sinnstudio.com/terms-of-service/", "publisher_name": "Sinn Studio Inc.", "support_website_url": "https://sinnstudio.com/contact/", "website_url": "https://sinnstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_VE", "de", "es_AR", "ko", "es_PE", "en", "fr", "es", "es_PR", "ja", "es_CL", "es_MX", "zh_CN", "es_CO", "zh_HK"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8655872164441794"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974482_298354309591224_6385317809527689438_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HzOSI7iIDSgQ7kNvgFcti2I&_nc_ht=scontent.oculuscdn.com&oh=00_AYDOc_8VawbQ_aF414OWHrP0lZ02cPu_kGPdD26zQQ15kg&oe=66FE847B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": fals