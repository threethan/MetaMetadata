c=ClEmR2L-XOkQ7kNvgFt-Hzw&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa6lNhRzMH5Rf_5NlI8ZSlw&oh=00_AYDXvGRmgd6x2y6rKpirGh3nhv97PJdomp-5fZev4Yo8jQ&oe=66EE90CB"}, {"file_name": "SM1_Quest_Screenshot_02_2560x1440.png", "id": "830937845065239", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572957_830937848398572_4732046014359676178_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lzUQF8jXOiAQ7kNvgFE3h3J&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa6lNhRzMH5Rf_5NlI8ZSlw&oh=00_AYD1BTc2_Z8v7NArbJN4cGiyjTUQtl8RE47xKLnTQ91aXA&oe=66EEA069"}, {"file_name": "SM1_Quest_Screenshot_10_2560x1440.png", "id": "9750576061679198", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234364_9750576071679197_3624091386835304979_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Q9wmMcDb8wQ7kNvgEVfHIF&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa6lNhRzMH5Rf_5NlI8ZSlw&oh=00_AYB-ttn0VD1VW9ddNv91NCcMld5dBY1hudjIOzdeVEqttw&oe=66EEB776"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SM1_Quest_TrailerCover_2560x1440.png", "id": "1339488779978594", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974626_1339488783311927_7293579740847162876_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Q0FRfYWBN4Q7kNvgEfXvE5&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa6lNhRzMH5Rf_5NlI8ZSlw&oh=00_AYCN5NKpnBdv6IyDcCHEPt5OzSMcRd_nnDgeiU8K40vlYw&oe=66EE9738"}, "display_name": "Swordsman", "keywords": ["combat", "swords", "fighting", "blade", "realistic"], "long_description": "Our NEW Training Grounds & Leaderboards updates bring the competitiveness you've been waiting for in Swordsman. Compete cross-platform on many different challenges, such as hand-to-hand combat, tatami mat, and archery. Will you try to crack the top 100 leaderboard? \n\nMore on Swordsman: \n\nSwordsman is a physics-based medieval combat game designed for virtual reality. \n\nThe game features Knights, Vikings, Mongols, Samurai, Pirates, realistic armor physics, epic boss fights and powerful boss weapons, a Kraken, RPG player progression and customization, a Blacksmith, Armorer and Skill Master to help you build a character suited to your playstyle and lots of items to buy and unlock, all in effort to stop the J\u00f6tunn from taking over the world. \n\nThe J\u00f6tunn has recruited captains from all over the world, giving them godly weapons with which to command powerful armies. He wields seemingly infinite power: Hellfire.\n\nSwordsman also features gameplay modifiers. These will let you change how the core game works in fun and interesting ways. Hardcore enemies, invisible enemies (floating swords), Doomfist (super strength), the ability to slow time down whenever you want and many more.", "short_description": "Swordsman is a physics-based medieval combat game designed for virtual reality. The game features advanced weapon handling, dismemberment, realistic armor physics, factions and boss fights, RPG elements and player progression."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sinnstudio.com/privacy-policy/", "developer_terms_of_service_url": "https://sinnstudio.com/terms-of-service/", "publisher_name": "Sinn Studio Inc.", "support_website_url": "https://sinnstudio.com/contact/", "website_url": "https://sinnstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FIGHTING", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["es_VE", "de", "es_AR", "ko", "es_PE", "en", "fr", "es", "es_PR", "ja", "es_CL", "es_MX", "zh_CN", "es_CO", "zh_HK"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SIT