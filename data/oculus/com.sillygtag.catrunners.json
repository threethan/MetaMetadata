ulus.vrshell-20240913-154503.png", "id": "1295997011362785", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39031551_1295997018029451_4874148165582609917_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0BDgXw3Q-gQ7kNvgGrmWzu&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYB9m1BPePBSPZ7IrH73rarY4HWST3DbokWjhHhDBtW9cg&oe=677E6F6B"}, {"file_name": "com.oculus.vrshell-20240913-154217 - Copy.png", "id": "1045901736691410", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39031339_1045901743358076_6500831139519781618_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sx9L8zMX4oUQ7kNvgG4NW-z&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBFT2AIfkWqnXs7Rce-IVlu62k-ZDdsmlVoUGStuN-o5A&oe=677E50A6"}, {"file_name": "com.oculus.vrshell-20240913-154217 - Copy - Copy.png", "id": "510128938654044", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39031612_510128941987377_3947027613919397214_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f5xNBYjz5hsQ7kNvgH4xBXV&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYA4HJMr29aW_ZJeBpzytMpqZqUFd5FzeamsMz9wsGnUYg&oe=677E6954"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "com.oculus.vrshell-20240913-154217 - Copy - Copy.png", "id": "479178548447971", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/43997716_479178551781304_7296852763250394190_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8GxJdQN0LAQ7kNvgETi7_V&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYDmGEtxJfKC741B7ga-qGvvDX5_dPxaH_eouLM92-TvfQ&oe=677E5ED6"}, "display_name": "CatRunners", "keywords": [], "long_description": "Cat Runners is an exhilarating fan-made game that takes the fast-paced action of Gorilla Tag and infuses it with a feline twist. Set in a lush, immersive world teeming with vibrant, jungle-themed environments, players transform into agile, anthropomorphic cats, each boasting unique abilities and characteristics.\n\nIn Cat Runners, the goal is simple: outpace and outmaneuver your opponents in high-energy chases. With intuitive, parkour-style movement mechanics, you\u2019ll experience the thrill of scaling walls, leaping between platforms, and darting through dense foliage with feline grace. The game\u2019s dynamic controls allow for a fluid, natural movement experience that captures the essence of a cat's agility and speed.\n\nThe game features a variety of playful and challenging arenas, each designed to test your skills and strategy. From dense, maze-like forests to sprawling urban rooftops, every environment offers unique obstacles and opportunities for creative navigation. You\u2019ll need to use your wits and reflexes to dodge, weave, and pounce on your rivals, all while avoiding capture.\n\nCat Runners encourages both solo and multiplayer gameplay, with modes designed to cater to different styles and preferences. Whether you\u2019re honing your skills in single-player challenges or engaging in competitive matches with friends, the game offers endless replayability and excitement.", "short_description": "Cat Runners is a thrilling fan game inspired by Gorilla Tag, where players slip into the paws of agile, anthropomorphic cats. Dash, leap, and climb through vibrant, jungle-themed environments, using your feline agility to outmaneuver opponents in high-speed chases. With dynamic movement mechanics and a playful atmosphere, Cat Runners promises endless fun and competitive excitement for cat enthusiasts and parkour fans alike. Can you become the ultimate top cat?"}]}, "developer_name": "Solar", "developer_privacy_policy_url": "https://sites.google.com/view/gorillal/home", "developer_terms_of_service_url": null, "publisher_name": "Hrqmable", "support_website_url": null, "website_url": "https://sites.google.com/view/gorillal/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}