0_AYDLJrSOgyYfvwCdlSFDww-zbIA0GP-tzFAJcOtMcB2rQQ&oe=67792CB0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Japanese Pinball VR", "keywords": ["fun", "games", "action", "arcade", "sports"], "long_description": "It's a pinball game that anyone can enjoy with easy operation!\n\nRule is easy!\nLet's hit the ball with the cue and aim for the score hole!\n\nThere are various kinds of units! Aim for a high score!\n\nThere are also boards with bonus holes!\nIf you put in a bonus hole the top of the high score hole will open and chances!\n\nI can play from children to adults \"Japanese Pinball\"!\ndownload now!", "short_description": "\"Japanese Pinball\" appeared in VR!\nIt is different from normal pinball.\nIt is Japan's own pinball."}]}, "developer_name": "BAIBAI, Inc.", "developer_privacy_policy_url": "http://baibai.co.jp/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "BAIBAI, Inc.", "support_website_url": null, "website_url": "http://baibai.co.jp/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "527101265157238"}, "review_messages": ["Hello,\n \nCongratulations! Your submission is ready to publish in the Oculus Store.\n \nYour app will be released on 1/22/2019 @ 10AM PT for $3.99 under the Games section of the mobile store.  Let us know if you would like a different date otherwise we will proceed with launch  Please review all binaries in the STORE channel to make sure the proper supported devices are listed.  Please do not update your online services (such as your back-end servers) during your launch week.\n \nOnce your submission is published, you can access analytics here: (https://developer.oculus.com/apps/).\n \nThanks,\n \nThe Oculus Store Team\n\n", "Hello,\n\nThank you for your submission to our store. However, we feel that the price point of $5.99 is too aggressive. A recommended price of $3.99 or lower will encourage higher adoption rates and reach out to more users.\n\nWe have seen trends in our data showing titles that begin with prices too aggressive cause a permanent negative trajectory to their adoption rates even after a later price drop. Please let us know if a lower price point would be acceptable for you.\n\nBest,\n\nThe Oculus Store Team", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984462_910593039137101_1865398051493904384_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ImwwLoa3GRcQ7kNvgHwnc3T&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrC2SbmM9GghwjQwQn04Ll0zrcQzmG1_sr1rS3nWW_mA&oe=67792988"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Japanese Pinball VR", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1548180000, "lastRevision": {"nodes": [{"id": "127558818253905", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1890484677736105", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "307554400102238"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "1326492960869696", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\u30b9\u30de\u30fc\u30c8\u30dc\u30fc\u30ebVR", "keywords": ["zen", "funny", "k