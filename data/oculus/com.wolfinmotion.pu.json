l brewery in Plze\u0148, Czech Republic. Be transported to our underground maturation cellars where we parallel brew our beer, watch our Saaz hop harvest, scoop Moravian barley in our Malthouse, soar to the top of the water tower, discover triple decoction in our Brewhouse, meet our expert Beermaster and see our coopers repitching huge lagering barrels in the cooperage. It\u2019s just like you\u2019re actually on a tour in Plze\u0148!"}]}, "developer_name": "Wolf in Motion Ltd", "developer_privacy_policy_url": "http://pilsnerurquell.com/pdfs/PU-Privacy-Policy.pdf", "developer_terms_of_service_url": "http://pilsnerurquell.com/pdfs/PU-Privacy-Policy.pdf", "publisher_name": "Pilsner Urquell", "support_website_url": null, "website_url": "http://pilsnerurquell.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "DOCUMENTARY_HISTORY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "cs", "sk", "zh_CN", "ja", "ro", "ko"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1327973284375723"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974836_239869153363247_5323963222997336064_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvLLwoxdG6UQ7kNvgHRiuon&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCuIXUZmEugxFalJ8yB-f-_5bu0hokvhZFEwQdoQno7vQ&oe=67405CD3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pilsner Urquell Virtual Brewery Tour SG", "platform": "ANDROID", "context_category": null, "conte