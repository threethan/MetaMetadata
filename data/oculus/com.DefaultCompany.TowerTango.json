n.com&oh=00_AYBc7yGj8vPRQiAXHjZY4it0GHazgPyPw139oArV6OZtQA&oe=670120C6"}, {"file_name": "screenshot1.png", "id": "733187238941323", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974554_733187242274656_9060180601804483531_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vMgrR8-xrlgQ7kNvgFMcGvC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAuka9fPN2ef-rjxEw5Kfe3T6aRSJ-1gVflske02RDFzg&oe=6701365E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Tower Tango", "keywords": ["building", "chaotic", "multiplayer", "free", "climbing"], "long_description": "Tower Tango is a chaotic 3v3/2v2/1v1 game about building a tower higher than everyone else's. This, however, is not as easy as it sounds! You and your team will need to work together and stack different building blocks on top of each other, while being careful not to unbalance the tower! \n\nTo spice things up, players also get to fight for the powerups that spawn in the middle of the map, while simultaneously defending their tower from AI monsters. \n\nThe character customization in Tower Tango is also not limiting! You can buy and equip a series of abilities that give you small, stacking buffs over your chosen main class. \n\nSo what are you waiting for? Join the fun in Tower Tango! \n\nMake sure to also join the discord server: https://discord.gg/zmK7rqDs8R", "short_description": "Tower Tango is a chaotic and fun multiplayer tower-building game where players compete to build the tallest tower."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/towertango/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "MasterOX", "support_website_url": null, "website_url": "https://sites.google.com/view/towertango/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": 