0_900140974414743_8121947409357394209_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e2JvNe8cVQcQ7kNvgGyZXaS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBpLFsi11MA1ZaOMm57-Re3zfHcTKyDFEXuimg9hQaUFg&oe=66F7D0E1"}, {"file_name": "HS_Quest_Hellhound1.png", "id": "802604334410469", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429290_802604337743802_5202483369891568299_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vi-eiTfUZRMQ7kNvgFibyGi&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRyNOSpDT8nsrPgCj-Fak_OGu8uugMkDHqqgLdOYtPjg&oe=66F7E5C2"}, {"file_name": "HS_Quest_FireFrost1.png", "id": "221010510781337", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422382_221010514114670_5417626890402215327_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EMcnlrqgoAAQ7kNvgFe2G8o&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgsaZVuzaRzR_3B-liEtd0RsLTZqD1UqS7wNQacysjmA&oe=66F7D5C0"}, {"file_name": "HS_Quest_Lightning2.png", "id": "569932288384987", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974500_569932291718320_112790462111659770_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Yvi8gNzOfUQ7kNvgH13gq8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtNDT77YAPuUplNZkoDZrOEzPWF4RYmDRiwtUv0ZeRnQ&oe=66F7F17B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus_CoverLandscape_2560x1440.png", "id": "3497414057171266", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001660_3497414060504599_1767120571552452621_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=18f7BPC-ov8Q7kNvgEfRsY8&_nc_ht=scontent.oculuscdn.com&oh=00_AYDudjX4vr_ku_peBztjw6OFdzgoEWJHa9lB3ZLGQVcJPA&oe=66F7F099"}, "display_name": "Hellsweeper VR", "keywords": ["Hell", "Souls", "Roguelike", "Magic", "RPG"], "long_description": "From the makers of Sairento VR comes a first person action-combat game that descends you into hell. In Hellsweeper VR you traverse the demonic dimensions, wield weapons with deadly precision, command the forces of telekinesis and muster mystical powers to wipe out your twisted enemies. Reap your rewards, upgrade your skills, and choose your fate as you experiment with unique combat variations and start to discover what being a Hellsweeper means to you.\n\n\u2022 Intense limitless movement: A daring, no-holes-barred locomotion system that pushes the limits of even the bravest of VR players.\n\u2022 Master your combat style: Summon, wield & master various weapons and magic combinations. \n\u2022 Survive in various game modes: Various singleplayer and co-op modes. Survive together, Die together. \n\u2022 Content-rich experience with high replayability: Conquer 18 maps, over 10 enemy types with elemental variants and multiple mission types, offering a unique gameplay experience with every run.", "short_description": "Hellsweeper VR is an intense action-combat first person experience. Traverse the underworld, gain mastery of your weapons and elemental magic, or fall to the unrelenting onslaught of hell's twisted souls. Dare to descend into hell."}]}, "developer_name": "Mixed Realms", "developer_privacy_policy_url": "https://www.mixedrealms.com/privacy-policy/", "developer_terms_of_service_url": "https://vertigo-games.com/eula/", "publisher_name": "Vertigo Games", "support_website_url": "https://vertigogames.atlassian.net/servicedesk/customer/portal/2", "website_url": "https://hellsweepervr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_TW", "fr", "it", "ja", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_mod