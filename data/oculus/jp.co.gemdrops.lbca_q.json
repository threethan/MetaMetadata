aEbCDSbszYusdnjwkoIGN1_kNyEQ&oe=6741B219"}, {"file_name": "Oculus_ScreenShot_03.png", "id": "467744061027767", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75469623_467744064361100_7880822556392606006_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Im4Fs0dOWnQQ7kNvgGXoLdt&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAoMrosBsRNnQnJr0DJx5CREOjjd3hk9G3o8ZUqPggR8g&oe=6741B4C7"}, {"file_name": "Oculus_ScreenShot_04.png", "id": "505969614131293", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348043_505969617464626_3812815100748589999_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=knEvcT4JeIwQ7kNvgHUj1tM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6kXkej39vTCJUGcQxcz5wiRYbM45V1wAY8VfD7gPRfg&oe=6741D406"}, {"file_name": "Oculus_ScreenShot_05.png", "id": "244218393954762", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75272208_244218397288095_2010481662243637500_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ddupL36bfi4Q7kNvgHwAqgg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCjvln3sWQgwcDX_B4kCwEW-dQxJSC8m4Et_ZEsTQ4EA&oe=6741DBFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus_thumbnail.png", "id": "248675496713807", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210897_248675500047140_1438478199089127099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WvUZ9tS6Hi0Q7kNvgGTUM3M&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBeqkod-yxsA45ENDXL1u3uojkfAonn8gpZBY-dsgcg9A&oe=6741BA61"}, "display_name": "Laid-Back Camp - Virtual - Lake Motosu", "keywords": [], "long_description": "Experience Laid-Back Camp in 3D!\n\nTogether, Nadeshiko (you!) and Rin embark on a new camping adventure at Lake Motosu, taking pictures and trying lots of delicious food.\n\nAbout the Game\nSet near scenic Mt. Fuji, Nadeshiko, Rin & co. encounter a variety of unique situations. Join them in VR via your smartphone for a short adventure game (each version is about the length of an anime episode), where the fully voiced characters and vibrant scenery will make you feel like you\u2019re really there!\n\nCast\nNadeshiko Kagamihara (Yumiri Hanamori)\nRin Shima (Nao Toyama)\nChiaki Ogaki (Sayuri Hara)\nAoi Inuyama (Aki Toyosaki)\nEna Saito (Rie Takahashi)\nNarration by Akio Otsuka", "short_description": "Laid-Back Camp has gone virtual. Get a taste of the great outdoors from the comfort of your own home!"}, {"images": {"nodes": [{"file_name": "Oculus_Logo_ko.png", "id": "4038226506211115", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236138_4038226509544448_1816862056650537296_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xn_WZtFJ7K0Q7kNvgE2ca7J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBI6MWq15kTmTBZtmPyGBOzRZPhSbBpKh-W0p58EAXS9g&oe=6741CE77"}, {"file_name": "Oculus_Landscape_ko.png", "id": "919856972177142", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75221327_919856975510475_5924956419647214320_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uCThpl5VznYQ7kNvgEIw1nL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4nGnmqOZeJCVwS_auxVl7HkFGdFffxDgu9155pb0Tqg&oe=6741B6BB"}, {"file_name": "Oculus_Portrait_ko.png", "id": "776084849960300", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982456_776084853293633_558844344158556497_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffRZ1h4pLB8Q7kNvgG20X-9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBm8xfuoYS31P706MuS3DC07MrQrG7j2gIdTgQ9SZNHlQ&oe=6741CF75"}, {"file_name": "Oculus_VRLandscape_kr.png", "id": "422127778877320", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982653_422127782210653_3712641520069869897_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tP6bsnPO5agQ7kNvgFO8A8O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTefDucbmmBZVaAoQbQHEp4HI08qoqcVu7iFXX2f4Yhg&oe=6741CF18"}, {"file_name": "Oculus_Square_ko.png", "id": "242692000810925", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75429286_242692007477591_8188376607856499931_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dp7V1mH9VCEQ7kNvgHMTqia&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWOBTOmgyrUyRLj2zLWglNR12DayW97tMBVKYYVON4sA&oe=6741C121"}, {"file_name": "Oculus_Icon_mobile.png", "id": "144826694130167", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65397209_144826697463500_6554260038838101604_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=slCc7F336-4Q7kNvgFYTGtm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBq9itEcI9MFJEjWw5YgeYprLK3qh6agw5nw9unMsl2aA&oe=6741B544"}, {"file_name": "Oculus_Hero_ko.png", "id": "127376645864520", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982668_127376649197853_6751287802320528359_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GrkMRdKUmRgQ7kNvgGcN0eI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC6gI55B4I2QRMRhWW27tUubgDekA0GvIwu3fnqaX-tuQ&oe=6741D6D9"}]}, "id": "703142277018711", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus_thumbnail.png", "id": "736245260416070", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568679_736245263749403_9142336049420305343_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PXFCqMK5HcoQ7kNvgFz8YrC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5Bzl4cfxxUcwC0dEmadygGBI1y_BJKTnxL9_QC_nG6Q&oe=6741CA38"}, "display_name": "\uc720\ub8e8\ucea0\u25b3 VIRTUAL CAMP ~\ubaa8\ud1a0\uc2a4\ud638 \ud3b8~", "keywords": [], "long_description": "\uc720\ub8e8\ucea0\uc758 \ucea0\ud551\uc744 \ud480 3D\ub85c \uc990\uae30\uc138\uc694.\n\n\ubaa8\ud1a0\uc2a4\ud638 \ud3b8\uc5d0\uc11c\ub294 \u300c\ub098\ub370\uc2dc\ucf54\u300d\uac00 \ub418\uc5b4 \u300c\ub9b0\u300d\uacfc \ud568\uaed8 \ub458\ub9cc\uc758 \ub290\uae0b\ud55c \ucea0\ud551\uc744 \uac00\uac8c \ub429\ub2c8\ub2e4.\n\uc0ac\uc9c4\uc744 \ucc0d\uace0, \uc2dd\uc0ac\ub97c \ud558\uace0,\n\uc5ec\uc720\ub85c\uc6b4 \uc2dc\uac04\uc744 \uc990\uae30\uc138\uc694.\n\n\u25a0\uac8c\uc784\n\uc774 \uc791\ud488\uc740 \ub098\ub370\uc2dc\ucf54\uc640 \ub9b0, \uadf8\ub9ac\uace0 \ubcc0\ud568\uc5c6\ub294 \uba64\ubc84\ub4e4\uc774 \ub9cc\ub098\ub294 \ub2e4\uc591\ud55c \uc0c1\ud669\uacfc \ud5e4\ud504\ub2dd\uc744 \ud480\ubcf4\uc774\uc2a4\ub85c \uc990\uae38 \uc218 \uc788\ub294 3D \uc5b4\ub4dc\ubca4\ucc98 \uac8c\uc784\uc785\ub2c8\ub2e4. \n\uc560\ub2c8\uba54\uc774\uc158 \ud55c \ud654 \uc815\ub3c4\uc758 \ubd84\ub7c9\uc744 \uc990\uae38 \uc218 \uc788\uc73c\uba70\n\ud604\uc9c0\uc5d0\uc11c \uc9c1\uc811 \uccb4\ud5d8\ud558\ub294 \ub4ef\ud55c \ud50c\ub808\uc774\uac00 \uac00\ub2a5\ud569\ub2c8\ub2e4.\n\n\u25a0CAST\n\uce74\uac00\ubbf8\ud558\ub77c \ub098\ub370\uc2dc\ucf54(\ud558\ub098\ubaa8\ub9ac \uc720\ubbf8\ub9ac)\n\uc2dc\ub9c8 \ub9b0(\ud1a0\uc57c\ub9c8 \ub098\uc624)\n\uc624\uc624\uac00\ud0a4 \uce58\uc544\ud0a4(\ud558\ub77c \uc0ac\uc720\ub9ac)\n\uc774\ub204\uc57c\ub9c8 \uc544\uc624\uc774(\ud1a0\uc694\uc0ac\ud0a4 \uc544\ud0a4)\n\uc0ac\uc774\ud1a0 \uc5d0\ub098(\ud0c0\uce74\ud558\uc2dc \ub9ac\uc5d0)\n\ub098\ub808\uc774\uc158(\uc624\uc624\uce20\uce74 \uc544\ud0a4\uc624)", "short_description": "\ub4dc\ub514\uc5b4 \u300e\uc720\ub8e8\ucea0\u25b3\u300f\uc774 \uac00\uc0c1 \uc138\uacc4\uc5d0 \ub4f1\uc7a5! \ud6c4\uc9c0\uc0b0\uc5d0\uc11c \ucea0\ud551\ud558\ub294 \uae30\ubd84\uc744 \uc9d1\uc5d0\uc11c \ub290\uaef4\ubcf4\uc138\uc694."}, {"images": {"nodes": [{"file_name": "Oculus_Square_sc.png", "id": "3715674095179173", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031642_3715674098512506_1408991749097769152_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ID0u-HvpqkcQ7kNvgHDrEwf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQ7CSIgd0mdsbw