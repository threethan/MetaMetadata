d": "547814163935384", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75269593_547814167268717_5127817127143993804_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EiUKrHrUB4MQ7kNvgEBtytn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCs8aIyejwgqyrditTouCJQmtgEKlXqJ4dpRT9vn9QN-w&oe=6745CF4E"}, {"file_name": "hills1.png", "id": "2645738312253585", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974832_2645738315586918_6450838348964482069_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LZSR8XXH5e4Q7kNvgGmCm4E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHQOGym6fUcWiPP0fvlXrW_BP8D-qSghFDwBoENsciQA&oe=6745BCAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "titlex2560.png", "id": "333021865958301", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974694_333021869291634_9003243686799909372_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ha6dMis1SsQ7kNvgExIyrq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAujR_JOredI1l0wm0vx8L69B9Qa0jRbb_eWgmgaacsFA&oe=6745A6EB"}, "display_name": "LIT", "keywords": [], "long_description": "Bayre City at night is known for it\u00b4s roaring street-racing scene and network of fast open roads. If you are willing to risk your good night\u00b4s sleep, you are in for a ride. Starting from the bottom with your classic whip, you build reputation, wealth and speed as you go. Just remember you are not alone with your dream of more than 30 highly detailed, customizable vehicles and apparel. Get ready to light up the city together.\n\nLIT is a multiplayer game that also has a storymode that you can complete. BayreCity is the biggest open map with 5+ areas: NorthBay/Downtown area, OldTown area, Hillside area, EagleMountain area and BayreCity Racetrack area. You can also find the BayreCity Dragway here. Other map called SanMimas takes a freeway through the mountains to the desert. Third map is called HorizonHills and can be accessed through quickplay with \"FURY:Rampage\" car or load the map with any car or roomname throught the old track editor tool found on the garage table near the sofas.\n\nLIT has different activities with different rewards: Races you start on BayreCity intersections, Stunt jumps, DeliveryMissions(Rivals-mode enabled), 1 lap race at the BayreRacetrack, timeattack run up and down the Eagle-mountain(starts from the parkinglot edge), full 66 lap race at HorizonHillsSpeedway(min 2 player online, requires FURY-car), NoHesi-type action at the SanMimas freeway, Lowrider-cars with hydraulics, Driftcars and the most important feature to be able to freely roam around the city.\n\n", "short_description": "Take the driver\u00b4s seat and zoom into the night. Lit provides an impressive immersive racing experience from the garage drawing board to high-speed rivalry on the streets of Bayre City. When you see cars gathering around and ready to go, it could be your next time to shine."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.refinereality.com/lit_privacypolicy.html", "developer_terms_of_service_url": "https://www.refinereality.com/RefineRealityEULA.pdf", "publisher_name": "Refine Reality Ltd.", "support_website_url": null, "website_url": "http://www.refinereality.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27391797617130266"}, "review_me