uluscdn.com&_nc_gid=AgyUz6gPEWOZtz9Umhqa9Jm&oh=00_AYBep-JnsiKDclaMPOjBD0IbjUTV8qr-Z1P0PiI-9tl4yA&oe=66E2D307"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VID COVER.png", "id": "537194471909024", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75251819_537194475242357_4309468404986525274_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRFFtMJZjhwQ7kNvgHiGnC-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgyUz6gPEWOZtz9Umhqa9Jm&oh=00_AYAk9NYQc3o4h3ABt9N_qQd9loCFKms7GL2P6oZQbBpTHQ&oe=66E2D6BC"}, "display_name": "BallisticVR", "keywords": [], "long_description": "It's a puzzle game where you start by taking a tutorial to teach you how to use the input system to control the missiles before launch them to hit the targets.\n\nThe directions that the player inputs is relative to the missile's axis all the time and the player can hit the targets with so many variations of inputs.\n\nYou need to go throw a magnetic field to hit some of the targets which increases the level of difficulty as you progress in the game.\n\nWhen you finish the level in a the fastest time you can put your name on the board.", "short_description": "BallisticVR is a Meta Quest VR game. it's about hitting targets by trying and refining inputs. With so many worlds and so many changeable targets the fun never end to beat the fastest time.\n"}]}, "developer_name": "EYEFORK STUDIOS", "developer_privacy_policy_url": "https://sites.google.com/view/eyefork/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "EYEFORK STUDIOS", "support_website_url": null, "website_url": "https://sites.google.com/view/eyefork/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "