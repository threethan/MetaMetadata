6e7a0a&_nc_ohc=HeoV4SmnlSoQ7kNvgG-IYaB&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5z85zb4n__WrdNqOrV7DuUtUDGR-WkmyhG-W1FDL9Mw&oe=66F561FB"}, {"file_name": "av3.png", "id": "1626739571413656", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031511_1626739574746989_3799010006881472438_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uKprXHTjNdMQ7kNvgFJOq-2&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPGucbxIw6uvLTo-Opys1XZGQUZvofRvooYkYdDkBOrw&oe=66F55E4E"}, {"file_name": "av4.png", "id": "2766628573493043", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_2766628576826376_6086476090495238385_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_cTFXNkT8h4Q7kNvgEDjPss&_nc_ht=scontent.oculuscdn.com&oh=00_AYD5y7Z7BREQekaElLehY5xo7F_-xbML3UYA5ic_lrA16g&oe=66F534C0"}, {"file_name": "av5.png", "id": "965561804698294", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_965561808031627_3479686342881604064_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gijkqbnr7L0Q7kNvgHuXi9u&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo5dvID55WhqbhgGNRfyzVVuc7dONSz8TG-oBvnIzBSg&oe=66F5652D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "AV3", "keywords": [], "long_description": "Step into the immersive world of AV3, the ultimate VR horror experience! Get ready to embark on a thrilling journey where you'll swing through levels like a gorilla, relying on your arms to propel you forward. But beware, for within the darkness lie horrifying monsters, poised to ambush you and your online comrades at any moment. Survival hinges on your ability to outwit and outmaneuver these relentless adversaries as you navigate the treacherous landscapes. Will you muster the courage and cunning needed to escape the clutches of AV3? There's only one way to find out.", "short_description": "Prepare yourself for AV3, the best VR horror experience! You'll be swinging through levels like a gorilla, using your arms to move. But watch out, because lurking in the shadows are terrifying monsters, just waiting to jump on you and your online companions. It's all about strategy as you run to survive the entity terror of AV3. Do you think you have what it takes to escape?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1DyXFeidGDPDH0_U09fb-t9vWDsvUPeGiq3uq5sdXpgo/edit", "developer_terms_of_service_url": null, "publisher_name": "FarmerGT", "support_website_url": null, "website_url": "https://sites.google.com/view/av3vr/home", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7444030819009171"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "929282162533163"}]}, "baseline_offer": {"id": "929282162533163"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1713216900, "status": "PUBLISHED", "id": "929282162533163"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7642668305812087", "version": "0.2.2"}, "id": "351766114535096", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7444030802342506", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7642668305812