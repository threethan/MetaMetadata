: "Christmas Tag", "keywords": [], "long_description": "\"Christmas Tag\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity.\nThe objective of Musical Taggers is simple yet delightful: players use virtual reality tools to create beautiful, glowing art installations throughout the game world.\nThese installations can take the form of intricate patterns, flowing designs, or even abstract masterpieces\u2014all designed to evoke a sense of peace and serenity.", "short_description": "\"Christmas Tag\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity."}]}, "developer_name": "VIPER", "developer_privacy_policy_url": "https://sites.google.com/view/christmas-tag-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "VIPER", "support_website_url": null, "website_url": "https://sites.google.com/view/christmas-tag-home/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8815729148449271"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "ba