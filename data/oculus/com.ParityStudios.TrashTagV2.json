3583330988545007_1063429096330025058_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=77BQLx4JBCsQ7kNvgHU2NwJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoGJitNpry03MMZ-h7tkRn_3RcCeCxFNu4pMasapTiIw&oe=6739CB7B"}, {"file_name": "screenshot2.png", "id": "240240288908224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035312_240240292241557_3101874849347185748_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ZOTEQcoQOEQ7kNvgET0vrs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB_5GFwzLBffYXXvuC_auiAVAm2xpBh-e9od_6o_agPYQ&oe=6739E005"}, {"file_name": "screenshot3.png", "id": "3709258015971624", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031644_3709258019304957_2106116046951259043_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UcnK6sHbnGEQ7kNvgHzTGZa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAH_y5ml86kxC23qzcnQ9-gmVmq238KRM8G7PH6KFdKBQ&oe=6739E3DA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Trash Tag", "keywords": [], "long_description": "Are you tired of gorilla tag fan games only about species of monkeys or gorillas? Have you ever wanted something different? Well look no further to Trash Tag! Trash Tag is hand locomotive based VR game where you can have fun socializing and exploring different maps well playing different great game modes!\n\nALL GAMEMODES:\n\n1. Tag (BETA) - In this mode, their is one person who has the Cheese Touch and they have to tag another player who doesn't have the Cheese Touch. Once they've been tagged, the player tagged will now have the Cheese Touch and the original player will not have the Cheese Touch anymore. You can tell when a player has the Cheese Touch when the player has a cheese texture.\n\n2. Casual - In this mode, their is no tag, or running from something. In this mode you can just chill with your friends, yourself, or other people.\n\n\n", "short_description": "Trash Tag is a hand locomotive based VR game made to socialize and have fun!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/trashtagvr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Parity Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/trashtagvr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "676136927748528"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "266494526060636"}, {"status": "PENDING", "id": "905988440581419"}]}, "baseline_offer": {"id": "266494526060636"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1692072008, "status": "PUBLISHED", "id": "266494526060636"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7537893349579963", "version": "1.3.48"}, "id": "898882368125919", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5764859953549987", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7537893349579963"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1730589265, "id": "