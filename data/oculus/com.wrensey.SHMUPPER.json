7a0a&_nc_ohc=UjZSw645Z5MQ7kNvgFIiUwa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQPfFwtcFmEZ_Lm-dAj1mYek6LRK5OmRFqHhaeZiOaAQ&oe=677A5747"}, {"file_name": "storeShot_1.png", "id": "1101855813658769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_1101855816992102_8806418871866348803_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=svkuhkC89lkQ7kNvgEHEGaG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAjAT7xppGBOe_V4CND6o1P0Zat3mK7I54GSrNMlDWwAQ&oe=677A5B9E"}, {"file_name": "storeShot_3.png", "id": "1917893115028734", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974684_1917893118362067_5388885521248075099_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RZqcvh3wP84Q7kNvgEFLnBm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfRMeie9pXYa1nvlLJD37FcLvis9hxp_6hQGZ9zmnwYg&oe=677A6C52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Key_Art_01.png", "id": "630217451080550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031424_630217454413883_6000066187856028787_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b-JlcDLZ694Q7kNvgEY41Hy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBazSqDkVDcqKDaxCrzYfaVs0rMrMAM5aJ1uDaQaR9QVA&oe=677A5E28"}, "display_name": "SHMUPPER (Demo)", "keywords": [], "long_description": "Have you ever wanted to play a retro-style space shooter from a more immersive and engaging perspective? SHMUPPER is a dog-based arcade-style 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. \n\nWhile inspired by the iconic titles mentioned previously, this game comes with a twist. While in VR, the movement of your ship is done primarily through the movement of your body! In order to steer, the player must lean or step forwards, backward, left, 