tyle 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/16lFrus7R7ppi39mqaBgltVsrpCqohCfF/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Wrensey", "support_website_url": null, "website_url": "https://shmupper.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "ARCADE", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5143349832356092"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2764344137210572"}]}, "baseline_offer": {"id": "2764344137210572"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1617292920, "status": "PUBLISHED", "id": "2764344137210572"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4055785134543315", "version": "0.903"}, "id": "746371082985028", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3444316302356871", "is_concept": false, "latest_released_binary