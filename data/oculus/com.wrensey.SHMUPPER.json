c=DEzFGNmTU8EQ7kNvgEOjukj&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAYFWPupxK454AbRHr1MhZ5Fo4BYy0Svi7WnZxOP4ERrQ&oe=670F921E"}, {"file_name": "storeShot_3.png", "id": "1917893115028734", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974684_1917893118362067_5388885521248075099_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vR2pAuRzuRgQ7kNvgENmYUL&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCU0EByLwMWqKKf6HEQAg0QyLT56OlG1VkQiKBvvn6pGg&oe=670FA2D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Key_Art_01.png", "id": "630217451080550", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031424_630217454413883_6000066187856028787_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=osSNogOTeQ4Q7kNvgF2lAeW&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBgarCBACQcEPJ2MW8dDnd-l-1kq6HthxuLyyKap-RdFA&oe=670F94A8"}, "display_name": "SHMUPPER (Alpha Demo)", "keywords": [], "long_description": "Known Issues:\n- Random crashes on Quest 2 (If you experience this, just close the app and try opening it again)\n\nConsider taking time to fill out the Demo Feedback Form! https://forms.gle/VfNTeAHANpcKfwFi9\n\nHave you ever wanted to play a retro-style space shooter from a more immersive and engaging perspective? SHMUPPER is a dog-based arcade-style 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. \n\nWhile inspired by the iconic titles mentioned previously, this game comes with a twist. While in VR, the movement of your ship is done primarily through the movement of your body! In order to steer, the player must lean or step forwards, backward, left, or right in order to maneuver through space. ", "short_description": "SHMUPPER is a dog-based 3D SHMUP or \u201cShoot-em-up\u201d with a retro-inspired space shooter aesthetic in a VR 3rd person perspective with innovative ship steering mechanics!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/16lFrus7R7ppi39mqaBgltVsrpCqohCfF/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Wrensey", "support_website_url": null, "website_url": "https://shmupper.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "684621449580952"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031449_3506033679523448_5130487383571396026_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wOV_uUJmkMoQ7kNvgGsUB0o&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDpVhtlt_P71ksw8ycnAhiH0K5brJ14NvSgaVDsZxkmVA&oe=670F88D7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SHMUPPER (Alpha Demo)", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1617292903, "lastRevision": {"nodes": [{"id": "3608764989201697", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3444316302356871", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "124853912859