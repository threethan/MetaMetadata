31381185", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031540_237319134714518_137872481270082489_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x_lLHIftgC8Q7kNvgHfyMLF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYCxB3qLolUjtU9XtW9WBtTKEyNybqzJIecKIrOdCHfhSw&oe=66E2C9B2"}, {"file_name": "logo_2D - Copy.png", "id": "113465573968850", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974787_113465580635516_6182280747561874547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CeZX6ovnGlwQ7kNvgFX1lMw&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYCpCz4BIky8l3uR70OEVJZJwoWDDI6ooVtQJcmWDu2Jsw&oe=66E2C0F8"}]}, "id": "3900026250087011", "locale": "en_US", "screenshots": [{"file_name": "storeShot_2.png", "id": "270018604631376", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_270018607964709_4626393478543646047_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g3tGXmH56kYQ7kNvgE16tDW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYD602ztiEJHDghU85yYeekepTGWObYdQ5r7d94WWdRggA&oe=66E2EF00"}, {"file_name": "storeShot_5.png", "id": "297912958337775", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_297912961671108_2214511544760724894_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQ26xScf6KEQ7kNvgE1XcSd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYDWkEDgPVK72Po4qp6WeENfs0fDgZh-2wFwBmSLh9f5UQ&oe=66E2BE3F"}, {"file_name": "storeShot_4.png", "id": "461706031546379", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_461706034879712_219498851670986028_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mho7NbcHNiEQ7kNvgHdlCyr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYCCYvyUTH3l_iASainlfHPy0-P8DGNiEz70ZYKy0Rr5Vg&oe=66E2BAC7"}, {"file_name": "storeShot_1.png", "id": "1101855813658769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_1101855816992102_8806418871866348803_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tnTzCzBYlwcQ7kNvgHdp9GN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYDEnblMTwHo9FrOWy9Ec0915XscWrIJ_8RjSxoPRyXw6g&oe=66E2BF1E"}, {"file_name": "storeShot_3.png", "id": "1917893115028734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974684_1917893118362067_5388885521248075099_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uxU5TOWK5UYQ7kNvgGLY5k-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYD7p_mp3Tu_btNJg9VHE1LlsiIUPMYRxJLSy7iOu248RA&oe=66E2CFD2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Key_Art_01.png", "id": "630217451080550", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031424_630217454413883_6000066187856028787_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lGaOacUeTwAQ7kNvgHi_2mA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYA2obdGU1V37rantAWG-JGdd-7GOaY01e4mQkmmnWCQNg&oe=66E2C1A8"}, "display_name": "SHMUPPER (Alpha Demo)", "keywords": [], "long_description": "Known Issues:\n- Random crashes on Quest 2 (If you experience this, just close the app and try opening it again)\n\nConsider taking time to fill out the Demo Feedback Form! https://forms.gle/VfNTeAHANpcKfwFi9\n\nHave you ever wanted to play a retro-style space shooter from a more immersive and engaging perspective? SHMUPPER is a dog-based arcade-style 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. \n\nWhile inspired by the iconic titles mentioned previously, this game comes with a twist. While in VR, the movement of your ship is done primarily through the movement of your body! In order to steer, the player must lean or step forwards, backward, left, or right in order to maneuver through space. ", "short_description": "SHMUPPER is a dog-based 3D SHMUP or \u201cShoot-em-up\u201d with a retro-inspired space shooter aesthetic in a VR 3rd person perspective with innovative ship steering mechanics!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/16lFrus7R7ppi39mqaBgltVsrpCqohCfF/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Wrensey", "support_website_url": null, "website_url": "https://shmupper.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FLYING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "684621449580952"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031449_3506033679523448_5130487383571396026_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2fU63FeJJtcQ7kNvgHtprJI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZuBfESBk12ShvdxhBNKn03&oh=00_AYCMBwDzzCCwH7vnz_8iudmpY5i_xhJ3VqIHJATMLiASzA&oe=66E2EE17"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SHMUPPER (Alpha Demo)", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1617292903, "lastRevision": {"nodes": [{"id": "3608764989201697", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3444316302356871", "is_first_party": false, "enables_in_app_ads": false, "i