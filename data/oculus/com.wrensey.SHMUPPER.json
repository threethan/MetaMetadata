7a0a&_nc_ohc=NJqwk8y1fPsQ7kNvgGVlPUd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3OU2FGIGysZ6dYDhdg5lUZqBWQeujH86kpwtVcIXhKQ&oe=676A8547"}, {"file_name": "storeShot_1.png", "id": "1101855813658769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_1101855816992102_8806418871866348803_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DRb9CmYdUggQ7kNvgHOZRuD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9swpvvuykBQQa5UAH71SIVDncTk-ZyN-3iX1Jqj7b4Q&oe=676A899E"}, {"file_name": "storeShot_3.png", "id": "1917893115028734", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974684_1917893118362067_5388885521248075099_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kRFTcEpCxtgQ7kNvgFD2v_2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJXHM8duUvDWkMwf3TDXdMRYnOyVX-3Q68qQjBO-_H_g&oe=676A9A52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Key_Art_01.png", "id": "630217451080550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031424_630217454413883_6000066187856028787_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TB6IUq58oscQ7kNvgGlnggp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtZmMlFJ-RnzgikLNyj08gHzHyKor1XBPFhXv1ZEFDhg&oe=676A8C28"}, "display_name": "SHMUPPER (Demo)", "keywords": [], "long_description": "Have you ever wanted to play a retro-style space shooter from a more immersive and engaging perspective? SHMUPPER is a dog-based arcade-style 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. \n\nWhile inspired by the iconic titles mentioned previously, this game comes with a twist. While in VR, the movement of your ship is done primarily through the movement of your body! In order to steer, the player must lean or step forwards, backward, left, 