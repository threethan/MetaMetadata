c=DRb9CmYdUggQ7kNvgHOZRuD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB9swpvvuykBQQa5UAH71SIVDncTk-ZyN-3iX1Jqj7b4Q&oe=676A899E"}, {"file_name": "storeShot_3.png", "id": "1917893115028734", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974684_1917893118362067_5388885521248075099_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kRFTcEpCxtgQ7kNvgFD2v_2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJXHM8duUvDWkMwf3TDXdMRYnOyVX-3Q68qQjBO-_H_g&oe=676A9A52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Key_Art_01.png", "id": "630217451080550", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031424_630217454413883_6000066187856028787_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TB6IUq58oscQ7kNvgGlnggp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtZmMlFJ-RnzgikLNyj08gHzHyKor1XBPFhXv1ZEFDhg&oe=676A8C28"}, "display_name": "SHMUPPER (Alpha Demo)", "keywords": [], "long_description": "Known Issues:\n- Random crashes on Quest 2 (If you experience this, just close the app and try opening it again)\n\nConsider taking time to fill out the Demo Feedback Form! https://forms.gle/VfNTeAHANpcKfwFi9\n\nHave you ever wanted to play a retro-style space shooter from a more immersive and engaging perspective? SHMUPPER is a dog-based arcade-style 3D SHMUP or \u201cShoot-em-up\u201d that does just that! It tasks the player with the objective of battling waves of enemies through unique levels across the galaxy. It draws inspiration from classics in the genre such as Star Fox, Metal Slug, and Macross with a VR twist. \n\nWhile inspired by the iconic titles mentioned previously, this game comes with a twist. While in VR, the movement of your ship is done primarily through the movement of your body! In order to steer, the player must lean or step forwards, backward, left, or right in order to maneuver through space. ", "short_description": "SHMUPPER is a dog-based 3D SHMUP or \u201cShoot-em-up\u201d with a retro-inspired space shooter aesthetic in a VR 3rd person perspective with innovative ship steering mechanics!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/16lFrus7R7ppi39mqaBgltVsrpCqohCfF/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Wrensey", "support_website_url": null, "website_url": "https://shmupper.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FLYING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "684621449580952"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031449_3506033679523448_5130487383571396026_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdIAF9RGuZQQ7kNvgEutCma&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDeGG7H9JZNvEvktEv-Uvs2lQgTUVoiwS-urGat6SHm5g&oe=676AB897"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SHMUPPER (Alpha Demo)", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1617292903, "lastRevision": {"nodes": [{"id": "3608764989201697", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": 