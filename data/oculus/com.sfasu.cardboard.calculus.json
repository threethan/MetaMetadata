77032_6326525325192354927_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dQMDrJ46P1AQ7kNvgGPAg7Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARVfShWgm8YI3vRsMinXRyR&oh=00_AYDf5eUE6Q9yb38Y_tsdfo-6zsf_uh2T-4_EmUupg95WQA&oe=66E7FC31"}, {"file_name": "OPic5.png", "id": "759888274975318", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035424_759888278308651_3917968689767614253_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jTb2LgCj6-QQ7kNvgHTA3Ff&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARVfShWgm8YI3vRsMinXRyR&oh=00_AYBViTslwpIomEYbd3IArXwqS-csilIyzI7Cwch-oFB8NA&oe=66E8004C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DemoScreenshot.png", "id": "716412476040559", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_716412479373892_1832124735032102603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=objcsZ6-__oQ7kNvgEdmp7C&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARVfShWgm8YI3vRsMinXRyR&oh=00_AYC_GbyBSIEqhVdd5TGkVcAyX_09l4O5UrNG6VpRLqa6Ww&oe=66E82D6B"}, "display_name": "Calculus in Virtual Reality", "keywords": [], "long_description": "This app includes over 50 lessons and playgrounds covering :\n- 3D coordinates\n- Graphs is 3D\n- Curves and Surfaces\n- Vector Valued Functions of 1 Variable\n- Multivariable Functions\n- Vector Fields\n- Line Integrals\n\nYou can find descriptions for lessons and playgrounds, as well as supplemental materials for the CalcVR app at https://calcvr.org.", "short_description": "We have added literal depth to calculus! \nThe CalcVR app enables the users to visualize concepts in multi-variable calculus within a virtual reality setting. The user can specify their own objects for visualization as well go through lessons on the geometry and calculus of multi-variable functions and the corresponding surfaces. These elements are rendered in VR so the user can see the depth of these mathematical objects and the multiple facets at play in the study of these mathematical topics.\n"}]}, "developer_name": null, "developer