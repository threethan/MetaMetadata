77032_6326525325192354927_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DGy6YWWpFAAQ7kNvgEUNmxT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqlA-DYEvlUrpImsTS5teXp&oh=00_AYDEwhCausr9_0TK_xYn22F43S5_XACVV-2TSblRG3mffQ&oe=66DD7031"}, {"file_name": "OPic5.png", "id": "759888274975318", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035424_759888278308651_3917968689767614253_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wm1JF2ezsOAQ7kNvgFZgyIC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqlA-DYEvlUrpImsTS5teXp&oh=00_AYAtPZqmeENA047m6H2HjucOx2ZA0PXCvT4U_PmSC5fJMw&oe=66DD744C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DemoScreenshot.png", "id": "716412476040559", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982666_716412479373892_1832124735032102603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vBG8RDgSaosQ7kNvgGLlHgy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AqlA-DYEvlUrpImsTS5teXp&oh=00_AYC16N2gMvaW7U9Qx1WsRbIcdognh4vs0MhamPoyTNifkw&oe=66DDA16B"}, "display_name": "Calculus in Virtual Reality", "keywords": [], "long_description": "This app includes over 50 lessons and playgrounds covering :\n- 3D coordinates\n- Graphs is 3D\n- Curves and Surfaces\n- Vector Valued Functions of 1 Variable\n- Multivariable Functions\n- Vector Fields\n- Line Integrals\n\nYou can find descriptions for lessons and playgrounds, as well as supplemental materials for the CalcVR app at https://calcvr.org.", "short_description": "We have added literal depth to calculus! \nThe CalcVR app enables the users to visualize concepts in multi-variable calculus within a virtual reality setting. The user can specify their own objects for visualization as well go through lessons on the geometry and calculus of multi-variable functions and the corresponding surfaces. These elements are rendered in VR so the user can see the depth of these mathematical objects and the multiple facets at play in the study of these mathematical topics.\n"}]}, "developer_name": null, "developer