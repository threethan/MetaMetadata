gQ7kNvgGk1HwC&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCaRLmPmAjykLKnOnirMupeuM7PCqjrvoPSDm9bsBvPgw&oe=677E7F71"}, {"file_name": "OPic5.png", "id": "759888274975318", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39035424_759888278308651_3917968689767614253_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7NiTmMztdl4Q7kNvgGKXn1A&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBuGE_3T6FfmSD4cTaYiTUGvOw_I9gFEirVGGn4651i8g&oe=677E4B4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "DemoScreenshot.png", "id": "716412476040559", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38982666_716412479373892_1832124735032102603_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-hYws9RCQI4Q7kNvgEH1LDg&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYBDgeT3jngx2DhWbPCqqSxEpVI49ns6aK6O852IF3ihSA&oe=677E786B"}, "display_name": "Calculus in Virtual Reality", "keywords": [], "long_description": "This app includes over 50 lessons and playgrounds covering :\n- 3D coordinates\n- Graphs is 3D\n- Curves and Surfaces\n- Vector Valued Functions of 1 Variable\n- Multivariable Functions\n- Vector Fields\n- Line Integrals\n\nYou can find descriptions for lessons and playgrounds, as well as supplemental materials for the CalcVR app at https://calcvr.org.", "short_description": "We have added literal depth to calculus! \nThe CalcVR app enables the users to visualize concepts in multi-variable calculus within a virtual reality setting. The user can specify their own objects for visualization as well go through lessons on the geometry and calculus of multi-variable functions and the corresponding surfaces. These elements are rendered in VR so the user can see the depth of these mathematical objects and the multiple facets at play in the study of these mathematical topics.\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://calcvr.org/support-and-technical-details/privacy-policy/", "developer_terms_of_service_u