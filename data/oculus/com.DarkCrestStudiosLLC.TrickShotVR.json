=VZJQe1MiCs8Q7kNvgHZ2764&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBhgLT9vsnMZEPbHKX1fesrD0NBBOXbLTFWEn6cvA2fhA&oe=67013498"}, {"file_name": "Screenshot5.png", "id": "833704595209069", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974821_833704598542402_1020522212248896912_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z4hZL4FwqgYQ7kNvgH0s5RC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAQsMMw1ZfyhF0uDdNgGQ_8sevhreec-9svRhztLNlURw&oe=67010E13"}, {"file_name": "Screenshot.png", "id": "283171127378906", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031314_283171130712239_38048015563775330_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vUiyeWwnX4QQ7kNvgEzVBbz&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDdgJxqBZl62FJp_QULYMszRkqivc7_mmkPLq-wnq5L6w&oe=670121A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TSVR2560.png", "id": "557783223170073", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031579_557783226503406_7792884008937608733_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nec-oCR7TokQ7kNvgH03Djq&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAj-Usm8fvklw2ylVd4tkqVNSnRTqxBd-4RiBMLdQVJ4w&oe=67012BDE"}, "display_name": "Trick Shot VR", "keywords": [], "long_description": "Have you ever wanted to try doing the craziest trick shots around town? Now you can with Trick Shot VR! Switch between using a ping pong ball, a basketball, or a frisbee to land the best shots. \n\nEach trick shot item has 3 unique levels with their goal item set around the neighborhood. Once all 3 levels are completed in a section, that trick shot item can be used around the neighborhood in Freeplay! \n\nFeatures include :\n- Spawning on Grip - With the spawn on grip feature, you can continue to spawn throwables as many times as you like! \n\n- Interactable Openings - Doors and windows can be opened to add another layer of challenge to shots.\n\n- Moveable Pans - The pots and pans in the kitchen are pickupable. use them to bounce  throws off of!\n\n- Clear Spawned - Too many thrown items? Open the quick hand menu and clear them.\n\n- Dynamic Scoring - Scoring is based off of how far thrown an object is, and how many times it bounced. Each object also has a specific bounce multiplier!\n\nThe real question is, how many bounces can you get, and how far of a throw can you land?  ", "short_description": "Switch between using a ping pong ball, a basketball, or a frisbee to land the craziest trick shots around the neighborhood! How many bounces can you get, and how far can you throw?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/trickshotvrprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "DarkCrest Studios", "support_website_url": null, "website_url": "https://www.darkcreststudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6673538636074650"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1389054368700850"}]}, "baseline_offer": {"id": "1389054368700850"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1698862580, "status": "PUBLISHED", "id": "1389054368700850"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6663617663733414", 