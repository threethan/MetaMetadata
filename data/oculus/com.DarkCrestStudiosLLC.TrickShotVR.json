hc=SSL27PuDV7gQ7kNvgHha4_V&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD_kXalC4fcZEISHay3jrnBA-IKXUykKWmZETKkDg0fFQ&oe=6742F913"}, {"file_name": "Screenshot.png", "id": "283171127378906", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031314_283171130712239_38048015563775330_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lx21pAzWpPAQ7kNvgGDATON&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaccRra-pgoZCpSWeNxwSX4i-sWFeMjZ3W88mA3Ua3ng&oe=67430CA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TSVR2560.png", "id": "557783223170073", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031579_557783226503406_7792884008937608733_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PV8fECP8474Q7kNvgFlPdLA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDxG6Q3sBgUU_hb-E-RvkPKf7Hk761kDVPRwtbAtiR5bw&oe=674316DE"}, "display_name": "Trick Shot VR", "keywords": [], "long_description": "Have you ever wanted to try doing the craziest trick shots around town? Now you can with Trick Shot VR! Switch between using a ping pong ball, a basketball, or a frisbee to land the best shots. \n\nEach trick shot item has 3 unique levels with their goal item set around the neighborhood. Once all 3 levels are completed in a section, that trick shot item can be used around the neighborhood in Freeplay! \n\nFeatures include :\n- Spawning on Grip - With the spawn on grip feature, you can continue to spawn throwables as many times as you like! \n\n- Interactable Openings - Doors and windows can be opened to add another layer of challenge to shots.\n\n- Moveable Pans - The pots and pans in the kitchen are pickupable. use them to bounce  throws off of!\n\n- Clear Spawned - Too many thrown items? Open the quick hand menu and clear them.\n\n- Dynamic Scoring - Scoring is based off of how far thrown an object is, and how many times it bounced. Each object also has a specific bounce multiplier!\n\nThe real question is, how many bounces can you get, and how far of a throw can you land?  ", "short_description": "Switch between using a ping pong ball, a basketball, or a frisbee to land the craziest trick shots around the neighborhood! How many bounces can you get, and how far can you throw?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/trickshotvrprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "DarkCrest Studios", "support_website_url": null, "website_url": "https://www.darkcreststudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6673538636074650"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031330_3722106418009092_8666488020782910488_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DrYKwUcd-uAQ7kNvgGLIlDP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLjxyUE0wUsLm0wudChgJ_AbQYyJE9j02UNmaq1vGUBQ&oe=6742F90A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Trick Shot VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1698862580, "lastRevision": {"nodes"