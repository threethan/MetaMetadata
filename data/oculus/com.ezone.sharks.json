": "Screen04.png", "id": "1343419042888294", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57566697_1343419046221627_7953970189567143758_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K1QzZViC5SgQ7kNvgE145bK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDg3Z1pyHrOWxIMr5Yypq9UrCbjSLVfyk7_gtO1K1DLgA&oe=6777CF56"}, {"file_name": "Screen03.png", "id": "905660597203865", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57566697_905660600537198_34404823879072796_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pBTWQyy_am4Q7kNvgGfitKK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCtvg8s3OCgdpGnai35ytxYufS5INPnyC9Gg4MOGiw7LA&oe=6777C253"}, {"file_name": "Screen02.png", "id": "107434759034425", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974844_107434762367758_2961221435767143771_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IM1qcXnFNf0Q7kNvgGXh2VL&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAISy6kSvkmVKfNlVdtwl89NZpofYFJmysP9TWmEmheHQ&oe=6777E33D"}, {"file_name": "Screen05_2560x1440.png", "id": "1547673899049640", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974535_1547673902382973_7505119238297113617_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VOiNWuAoC2UQ7kNvgG89AGM&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD0xGm1mPVxVKICVq0rHA71vWGBMt7Rp317zr7ah7ni8g&oe=6777C1B3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumb_2560x1440.png", "id": "698638202067330", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982719_698638205400663_289794054610158311_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vk7LtUk2VfMQ7kNvgGoX-y1&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD4_6T0YJ7QpvcU0XqotxVSWZLTdHcvj-RaKdlOA1IFoQ&oe=6777C9DD"}, "display_name": "SHARKS", "keywords": [], "long_description": "Eat your friends in 'SHARKS' a cross-platform (PC and VR) multiplayer hunting game. Hunt with groups of up to 10 people online. Eat whatever you can to survive and avoid the zombie sharks: last player standing wins. It's like Gorilla Tag with sharks.\n\nThe VR controls are super responsive (it feels like a human-shark mind meld): simply look where you want the shark to swim. Pull the trigger to move forward, press the grip button to chomp/eat things.", "short_description": "Eat your friends in 'SHARKS' a cross-platform (PC and VR) multiplayer hunting game. Hunt with groups of up to 10 people online. Eat whatever you can to survive and avoid the zombie sharks: last player standing wins. It's like Gorilla Tag with sharks."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ezone.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Ezone PTY LTD", "support_website_url": null, "website_url": "https://ezone.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "219944073774624"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "245104471462418"}, {"status": "PUBLISHED", "id": "1006562187377203"}]}, "baseline_offer": {"id": "245104471462418"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720481722, "status": "PUBLISHED", "id": "245104471462418"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28856168227303566", "version": "0.1"}, "id": "601272338109301", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9571468216200189", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28856168227303566"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "601272338109301"}]}, "change_log": "Release Notes - v0.1.17 - \"TOXIC CLEANUP\"\n\nFind all the toxic barrels and move them to the containment area for a big reward!\n\nNew:\n- Toxic barrel containment area\n\nFixes:\n- Christmas themed items packed away for next year\n\nIf you love playing SHARKS then buy some skins to show your support. All proceeds from skins go right back into the game: new game modes, customizable items, maps, interactable creatures and objects and multiplayer servers.\n\nThanks so much for playing and please tell your friends: word of mouth is the best way to get more players in the game!\n\nIf you have any feedback or comments, please come chat in the Discord (https://ezone.com/discord). Cheers!\n\n- Simon and Jamie", "created_date": 1735455844, "id": "28856168227303566", "version": "0.1", "version_code": 17, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9571468216200189", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28856168227303566"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "601272338109301"}]}, "change_log": "Release Notes - v0.1.16 - \"HOLIDAY TIDY UP\"\n\nThis update is a minor tidy up of some loose ends. See what happens when you find all the presents and get them under the Christmas Tree!\n\nNew:\n- A new rare prize code added to the Discord!\n\nFixes:\n- Easier to bite multiplayer objects\n- Collision tolerances improved\n- Occlusion culling tweaks\n- Steam demo update compatible with Meta Quest\n- Ghost barrel fixed\n\nDon't forget to collect your free gift from us - a special limited edition Elf Hat (while supplies last). If you love playing SHARKS then buy some skins to show your support. All proceeds from skins go right back into the game: new game modes, customizable items, maps, interactable creatures and objects and multiplayer servers.\n\nThanks so much for playing and please tell your friends: word of mouth is the best way to get more players in the game!\n\nIf you have any feedback or comments, please come chat in the Discord (https://ezone.com/discord). Cheers!\n\n- Simon and Jamie", "created_date": 1734146503, "id": "28698372036416520", "version": "0.1", "version_code": 16, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9571468216200189", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28856168227303566"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "601272338109301"}]}, "change_log": "Release Notes - v0.1.15 - \"HAPPY HOLIDAYS!\"\n\nSee what happens when you find all the presents and get them under the Christmas Tree!\n\nNew:\n- Christmas Tree to decorate\n- Presents to collect\n- Festive toxic red barrels\n- More rewards for winning\n\nFixes:\n- Bigger goldfish\n- Improved physics for heavy items\n- Shark head collider more accurate\n- Cooldown for snap turn\n\nDon't forget to collect your free gift from us - a special limited edition Elf Hat (while supplies last). If you love playing SHARKS then buy some skins to show your support. All proceeds from skins go right back into the game: new game modes, customizable items, maps, interactable creatures and objects and multiplayer servers.\n\nThanks so much for playing and please tell your friends: word of mouth is the best way to get more players in the game!\n\nIf you have any feedback or comments, please come chat in the Discord (https://ezone.com/discord). Cheers!\n\n- Simon and Jamie", "created_date": 1733693206, "id": "28645334258386965", "version": "0.1", "version_code": 15, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9571468216200189", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28856168227303566"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "601272338109301"}]}, "change_log": "Release Notes - v0.1.13 - \"PLAY WITH FRIENDS\"\n\nNow you can invite friends to play with you in SHARKS right from your Quest headset. Just open the main Meta/Oculus menu from within the game, select a friend from the people menu and 'Invite to your location' so you can play and chat in SHARKS together.\n\nFixes:\n- Play with friends fix\n\nDon't forget to collect your free gift from us - a special limited edition Elf Hat (while supplies last). If you love playing SHARKS then buy some skins to show your support. All proceeds from skins go right back into the game: new game modes, customizable items, maps, interactable creatures and objects and multiplayer servers.\n\nThanks so much for playing and please tell your friends: word of mouth is the best way to get more players in the game!\n\nIf you have any feedback or comments, please come chat in the Discord (https://ezone.com/discord). Cheers!\n\n- Simon and Jamie", "created_date": 1733280426, "id": "28597293059857752", "version": "0.1", "version_code": 14, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9571468216200189", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28856168227303566"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "601272338109301"}]}, "change_log": "Release Notes - v0.1.13 - \"GIFT GIVING SEASON\"\n\nJust in time for the gift giving season we've added PRIZE CODES to SHARKS. Now you can get prize codes from our Discord (and #sharks on your socials) to unlock packs of goldfish plus rare skins and items.\n\nNew:\n\n- Prize codes: check our Discord and #sharks on your socials for free prizes (try GOLD50)\n- Limited edition skin: SANTA SUIT\n- More Leaderboards: Shark Kills, plus Goldfish, Crabs and Dead Fish Eaten \n\nFixes:\n- Fixed shark colliders with biteable objects\n- Speed limit on thrown objects\n- Meta Destinations fix\n\nDon't forget to collect your free gift from us - a special limited edition Elf Hat (while supplies last). If you love playing SHARKS then buy some skins to show your support. All proceeds from skins go right back into the game: new game modes, customizable items, maps, interactable creatures and objects and multiplayer servers.\n\nThanks so much for playing and please tell your friends: word of mouth is the best way to get more players in the game!\n\nIf you have any feedback or comments, please come chat in the Discord (https://ezone.com/discord). Cheers!\n\n- Simon and Jamie", "created_date": 1733211861, "id": "28589259190661139", "version": "0.1", "version_code": 13, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}