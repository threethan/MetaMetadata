cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-tyWbuCFFw8Q7kNvgFFvFGx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAEK6oyee9-7SwYnFCBd8-YNhwrZthOcO8xC0VPuDe99w&oe=6756EA03"}, {"file_name": "SHARKS_05.png", "id": "2269242109942347", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75630191_2269242113275680_4646654512371818505_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-i_s8UU9A8wQ7kNvgFA8kdq&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA_Y0k7aNE_KGGefX-tUXM8JyIbQI9Dw2slmItg5jIkYw&oe=6756DC98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SHARKS_VideoThumb_2560x1440.png", "id": "3360721347574845", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/54823267_3360721350908178_5498804926593167363_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LjVVIKTXUdMQ7kNvgE2zI9c&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB2iv5m_IlP46VKa4brKQxzFFxe9aJnsqQQ2vPLZYxcvQ&oe=6756D2B5"}, "display_name": "SHARKS", "keywords": [], "long_description": "Eat your friends in 'SHARKS' a cross-platform (PC and VR) multiplayer hunting game. Hunt with groups of up to 10 people online. Eat whatever you can to survive and avoid the zombie sharks: last player standing wins.\n\nThe VR controls are super responsive (it feels like a human-shark mind meld): simply look where you want the shark to swim. Pull the trigger to move forward, press the grip button to chomp/eat things. \n\nYou can also play with your non-VR friends on the flat-screen version. Each game is a quick snack-sized round so it's perfect to just drop-in or -out whenever you've got a spare minute.\n\nCollect goldfish to customise your shark with tons of unlockable hats, eyes, teeth and extras. Who would have thought sharks could be so cute?\n\nThere's no pay-to-win so everyone is on equal terms....and if you get tired of eating each other, there are plenty of other things to chomp on (more game modes coming soon)\n\nWhat are you waiting for? Get your friends to download SHARKS and start eating each other today!\n\nNote: This is a demo version with one game mode (zombie tag) and one arena. If you like what you see so far please leave a review and include any suggestions so we can make sure your ideas make it into to the final full game. Thanks!", "short_description": "Eat your friends in 'SHARKS' a cross-platform (PC and VR) multiplayer hunting game. Hunt with groups of up to 10 people online. Eat whatever you can to survive and avoid the zombie sharks: last player standing wins."}]}, "developer_name": null, "developer_privacy_policy_url": "https://apps.ezone.com/privacy-statement/", "developer_terms_of_service_url": null, "publisher_name": "Ezone PTY LTD", "support_website_url": null, "website_url": "https://ezone.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2710427532541308"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "28366253992961661"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974629_1009348120445865_2311351690113652741_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yp4-O1Tj1DwQ7kNvgFlHl7u&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDTxOh7oMsHAl9yhM_1i-9bEsdfxD-ljBLRUe2a8XEEXQ&oe=6756E229"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SHARKS", "pla