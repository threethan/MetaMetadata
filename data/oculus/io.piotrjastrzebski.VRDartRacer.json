vlcsnap-2024-04-25-18h25m43s877.png", "id": "1093766311892065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443244_1093766315225398_5656452165633868604_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lV9zRyxJHV0Q7kNvgGng2Us&_nc_ht=scontent.oculuscdn.com&_nc_gid=An5TlttEiqGB8AV1I_hotfe&oh=00_AYDb7FZ6VCkxtBiWO4c9RzIhlZwnwtpEjoFqippQIAYemw&oe=66F160E6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-update-header.png", "id": "804058618254459", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75223485_804058621587792_7836461228791862435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5TwfPSGwhfQQ7kNvgErVEUv&_nc_ht=scontent.oculuscdn.com&_nc_gid=An5TlttEiqGB8AV1I_hotfe&oh=00_AYCFWGGvM2vxVMZdPflPoXP-Lh4JBOFAUKMqDepdhrAFqw&oe=66F16D5B"}, "display_name": "Dart Racer Demo", "keywords": [], "long_description": "Dart Racer Demo is immersive arcade racing game set in a futuristic galaxy obsessed with speed. Master the intuitive controls, fine-tune your dart, and compete in thrilling races across a variety of captivating environments. Demo content is a subset of Early Access version, new content will be added as it becomes available!\n\nRace in Quick Races!\nMaster tracks and test upgrades in Quick Race! These thrilling interstellar competitions test your skills and push you to outperform rivals, offering a competitive environment for aspiring racers.\n\nTune Up Your Dart!\nUpgrade your dart with top-performing parts to meet the challenges ahead. Enhance its speed, acceleration, health, and handling by installing the best components available. Continuously optimizing your dart's performance is essential to stay competitive.\n\nCustomize Your Dart!\nExpress your style by customizing the visuals of your dart. Choose from a variety of designs, colors, and cosmetic elements to make it stand out on the racetrack. Personalize your dart to reflect your racing identity and showcase your creativity.\n\nMaster the Controls!\nBecome proficient in the unique controls of the dart. Master the intricacies of managing thrust, boosting, and executing advanced maneuvers. By honing your control skills, you can navigate challenging tracks, overtake opponents, and maintain optimal speed throughout the races.\n", "short_description": "Dart Racer is an immersive arcade racing game set in a futuristic galaxy obsessed with speed. Master the intuitive controls, fine-tune your dart, and compete in thrilling races across a variety of captivating environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.piotrjastrzebski.io/privacy/", "developer_terms_of_service_url": null, "publisher_name": "LubSoft Games", "support_website_url": null, "website_url": "https://www.piotrjastrzebski.io/project/dart-racer/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pl"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8068463513209174"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001669_2499944647017252_8053253345469521020_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IJwCePkgbtAQ7kNvgEplr7F&_nc_ht=scontent.oculuscdn.com&_nc_gid=An5TlttEiqGB8AV1I_hotfe&oh=00_AYAzlCjgM3qs8VuQT3nOUtMq8Oj0cjLsaVCV3Q6b2-2kGA&oe=66F136ED"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Dart Racer Demo