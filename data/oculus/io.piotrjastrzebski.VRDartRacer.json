2wF9FRpqYaug3VjtUjpw&oe=677D04C4"}, {"file_name": "vlcsnap-2024-04-04-11h26m04s404.png", "id": "3250167811956742", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035458_3250167815290075_1866600750269766196_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bz59lB1MVz8Q7kNvgH90175&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA--OJ8fxVkDUXQS4mjHj_qw06zhhXD-acy-sElEXMT1w&oe=677CF9C1"}, {"file_name": "vlcsnap-2024-04-25-18h25m43s877.png", "id": "1093766311892065", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75443244_1093766315225398_5656452165633868604_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqjqPAAaXUUQ7kNvgGBnTwn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwNt-Vfxg__JGVAEAst67pYsDU5knFcGtSieQZRKSO4w&oe=677D1FE6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "oculus-update-header.png", "id": "804058618254459", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75223485_804058621587792_7836461228791862435_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BRzbGNfeeDUQ7kNvgEfZC16&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB013lxnX-TwoNUveu3PWsHRdnLgH860ATAp5rqQEk2QQ&oe=677D2C5B"}, "display_name": "Dart Racer Demo", "keywords": [], "long_description": "Dart Racer Demo is immersive arcade racing game set in a futuristic galaxy obsessed with speed. Master the intuitive controls, fine-tune your dart, and compete in thrilling races across a variety of captivating environments. Demo content is a subset of Early Access version, new content will be added as it becomes available!\n\nRace in Quick Races!\nMaster tracks and test upgrades in Quick Race! These thrilling interstellar competitions test your skills and push you to outperform rivals, offering a competitive environment for aspiring racers.\n\nTune Up Your Dart!\nUpgrade your dart with top-performing parts to meet the challenges ahead. Enhance its speed, acceleration, health, and handling by installing the best components available. Continuously optimizing your dart's performance is essential to stay competitive.\n\nCustomize Your Dart!\nExpress your style by customizing the visuals of your dart. Choose from a variety of designs, colors, and cosmetic elements to make it stand out on the racetrack. Personalize your dart to reflect your racing identity and showcase your creativity.\n\nMaster the Controls!\nBecome proficient in the unique controls of the dart. Master the intricacies of managing thrust, boosting, and executing advanced maneuvers. By honing your control skills, you can navigate challenging tracks, overtake opponents, and maintain optimal speed throughout the races.\n", "short_description": "Dart Racer is an immersive arcade racing game set in a futuristic galaxy obsessed with speed. Master the intuitive controls, fine-tune your dart, and compete in thrilling races across a variety of captivating environments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.piotrjastrzebski.io/privacy/", "developer_terms_of_service_url": null, "publisher_name": "LubSoft Games", "support_website_url": null, "website_url": "https://www.piotrjastrzebski.io/project/dart-racer/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "RACING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "pl"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8549219708466883"}, "review_messages": [""]}]}, "cover_square_image": {"ur