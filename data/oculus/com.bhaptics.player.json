g", "id": "740529083775221", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_740529087108554_5314167487145197875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zQlGKrfUjGgQ7kNvgH5LDrE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIEjakOQILAfqXXDRfrDF83&oh=00_AYDETwunwUhMS2UQB30jsX5t2C6ET95xG8EI0IbHz4EHcg&oe=66DEEBD5"}, {"file_name": "05.Screenshot05-2560x1440px.png", "id": "249132200736666", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031512_249132204069999_7347648445570689376_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wK_irwc_uyQQ7kNvgHWQqOi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIEjakOQILAfqXXDRfrDF83&oh=00_AYAn-PEb2LWVOtF1kM-o72gKS-JqTEEZSdDJo_UQp1CWFg&oe=66DEDD52"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i_pGiwp-upQQ7kNvgFUmLXX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIEjakOQILAfqXXDRfrDF83&oh=00_AYCxuknStSWUKB_1h-DVYzNW-yBxP6zkHV9VgavT_I1f5g&oe=66DEE60A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/bhaptics/tact-android/wiki/bHaptics-Player-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "bHaptics Inc.", "support_website_url": null, "website_url": "https://bhaptics.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1810624985774554"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974560_141146578030678_1341183236655433780_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eZ7CZFDmtPgQ7kNvgH5_krX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AIEjakOQILAfqXXDRfrDF83&oh=00_AYBU-4WCq9LMQ3x_FNcQVgbOsa-WSRrgGjjtsPuZ0MNwEw&oe=66DED3D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "bHaptics Player", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1628877679, "lastRevision": {"nodes": [{"id": "1015842962285415", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3454125161357542", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert"