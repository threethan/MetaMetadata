F7D999"}, {"file_name": "\ucea1\ucc98_2024_09_09_11_17_06_267.png", "id": "2544381102425523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982452_2544381105758856_7258058883905750247_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mz75q2lvSWoQ7kNvgFstiGe&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJBsMOwE8Gr0N3pioxEEMBPHk3WCdJgoVEs-Tkj3t_hA&oe=66F7F740"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MLYJxMUQ3ucQ7kNvgEduGby&_nc_ht=scontent.oculuscdn.com&oh=00_AYCB2CMXbG54ku88-XR04WdgAancbk5jDOZ2_MT592vkEw&oe=66F7F28A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/bhaptics/tact-android/wiki/bHaptics-Player-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_