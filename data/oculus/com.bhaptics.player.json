t-sin6-3.oculuscdn.com/v/t64.5771-25/75443251_368894909610602_7836673737145307018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDSMvjGJU_UQ7kNvgGrK24w&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAQtdWZJD7CEMZxL0GHkslrKZWVi_X6TKdjeOYPVfM4Ng&oe=6728A119"}, {"file_name": "\ucea1\ucc98_2024_09_09_11_17_06_267.png", "id": "2544381102425523", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38982452_2544381105758856_7258058883905750247_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3ZEnT27TV4Q7kNvgGFT0xC&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYBFJQnCxJBp-MJC5u4Wt1Ni8Pvrkk_Ly22Y6vLgiP9jUA&oe=6728BEC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F-xZnw5hfGwQ7kNvgFE0olf&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYC0ei6WJeZpru7zUcjg3b0_f5yGAYoWnQXFJb02dAq2Sg&oe=6728BA0A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/bhaptics/tact-android/wiki/bHaptics-Player-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "bHaptics Inc.", "support_website_url": null, "website_url": "https://bhaptics.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7514285182008166"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38974560_141146578030678_1341183236655433780_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ETYAzJ1FnggQ7kNvgFbGCOH&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYDKa47oIQtFlHeMbiSHPv4WSh1S_CwSUs-zqYhcxihSDw&oe=6728A7D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "bHaptics Player", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}], "release_date": 1628877679, "lastRevision": {"nodes": [{"id": "1015842962285415", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3