g", "id": "740529083775221", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_740529087108554_5314167487145197875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z_Bhs4jSMpoQ7kNvgHcnc9N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AllvFkaCggMoFdg2NatTJba&oh=00_AYCvee1-fSSUbdOf_ApVGy9rJv4hoqqpz5SOObrnLkcUbg&oe=66E58355"}, {"file_name": "05.Screenshot05-2560x1440px.png", "id": "249132200736666", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031512_249132204069999_7347648445570689376_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zEH3QBOFt1AQ7kNvgGo8OLN&_nc_ht=scontent.oculuscdn.com&_nc_gid=AllvFkaCggMoFdg2NatTJba&oh=00_AYB9qEVfHaO_-hdPtyLcfA801JIsZAWk4YYNSvp731m1iQ&oe=66E574D2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jC8GyacWMb0Q7kNvgEOZRD3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AllvFkaCggMoFdg2NatTJba&oh=00_AYCfWYyb8EqEyy6G9ImF3cTJex3aABfoRIGMrKTp3GXOSw&oe=66E57D8A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/bhaptics/tact-android/wiki/bHaptics-Player-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "bHaptics Inc.", "support_website_url": null, "website_url": "https://bhaptics.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1810624985774554"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974560_141146578030678_1341183236655433780_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8FHyXI_QSFYQ7kNvgE44M48&_nc_ht=scontent.oculuscdn.com&_nc_gid=AllvFkaCggMoFdg2NatTJba&oh=00_AYD1Wr590oJeGcAdz0jGffhKGwCaLn6x1XVr_T6b-Kn5fw&oe=66E56B50"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "bHaptics Player", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1628877679, "lastRevision": {"nodes": [{"id": "1015842962285415", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3454125161357542", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert"