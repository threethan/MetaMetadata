110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Do9mQSZwmxQQ7kNvgF38p2B&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD8go2QiAR3PUjUUlWW5RNuPtTqaVNfmQ48XeHptTZ1pA&oe=670F9499"}, {"file_name": "\ucea1\ucc98_2024_09_09_11_17_06_267.png", "id": "2544381102425523", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982452_2544381105758856_7258058883905750247_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9q2QsOLc4UoQ7kNvgFR8NUm&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC9okviSl8qltwsb7zuCS4thl-h4S6Xjf6M30PQ-xN54A&oe=670FB240"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8nDx8_uIpw8Q7kNvgHuwozc&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA-eJGHRPA5jDcpN8uBxnDULvwxcCPCv3FNmTb1dzC6NQ&oe=670FAD8A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "deve