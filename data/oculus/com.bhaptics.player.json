99_5600897206481665559_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z-bKRgUCCGAQ7kNvgHrMQ1l&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBanmQFWUEV6l1P26i2drKJGW0Ca-qoF6Bf8MKf0PLaUA&oe=6745C4A8"}, {"file_name": "05.Screenshot04-2560x1440px.png", "id": "314013226965418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031476_314013230298751_7849957315873123109_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ejVmvWUYzckQ7kNvgHSxkWH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCngY_C9hP-vj6kNuzpTMaq_t4pBidI2jVEv5ID5uc69g&oe=6745C83E"}, {"file_name": "05.Screenshot05-2560x1440px.png", "id": "275807634258881", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984465_275807637592214_6306817039150739602_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XBP8SaBTWckQ7kNvgGn_43P&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAsv64yzpS4j5M5RogcwNtXzgW00B018Hm7f7s5tAav2w&oe=6745BF2D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WK_DQFQ3vcIQ7kNvgFYMQnE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDh61CbmCb8DIAHjWq-R_7wpN4beKuqn6CZ026aYboLBw&oe=6745BB0A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "developer_name": "bHaptics Inc", "developer_privacy_policy_url": "https://github.com/bhaptics/tact-android/wiki/bHaptics-Player-Privacy-Policy", "developer_terms_of_service_url": null, "publisher_name": "bHaptics Inc", "support_website_url": null, "website_url": "https://bhaptics.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "513919543391118"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2188085558000604"}]}, "baseline_offer": {"id": "2188085558000604"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628877660, "status": "PUBLISHED", "id": "2188085558000604"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8012822468821099", "version": "1.6.0"}, "id": "299385658340431", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBin