110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=38U6yWVGUzUQ7kNvgG1ztAr&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBHL3tmvXQ23l1ArG12SEieNlDkowl5nNUubTC4wtxqMw&oe=670E4319"}, {"file_name": "\ucea1\ucc98_2024_09_09_11_17_06_267.png", "id": "2544381102425523", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982452_2544381105758856_7258058883905750247_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9q2QsOLc4UoQ7kNvgH7nOGR&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1ksWwhI1qwDi8OhMOuqaXw5P_ovDPr4mp_UdarNTI5w&oe=670E60C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8nDx8_uIpw8Q7kNvgFQ2XY6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAACMXeKG1XrDGMRo4to0H02zzTa77d5T5cbtODyeqN1Q&oe=670E5C0A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. "}]}, "deve