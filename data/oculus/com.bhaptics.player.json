-1.oculuscdn.com/v/t64.5771-25/75443251_368894909610602_7836673737145307018_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JHLEQbdRis4Q7kNvgFH6N8K&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC65RUHOFzXdpKQgcBGA16ADuHgJxJ7EigSeMBh0eZetA&oe=672B4419"}, {"file_name": "\ucea1\ucc98_2024_09_09_11_17_06_267.png", "id": "2544381102425523", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982452_2544381105758856_7258058883905750247_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h3ZEnT27TV4Q7kNvgE5Q346&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCgAXq-8NJZ_vlokx-9ETHc46gS-C59eDoqX6R9gi59Kw&oe=672B61C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "07.TrailerThumbnail-2560x1440px.png", "id": "5334467729957483", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57566677_5334467736624149_6454293066537641987_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cAHwvFFCOuUQ7kNvgECgeEY&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAnpERcDdyOq0aJFTarqlHRMQvHIfSgrMkd_5VlSxGR7A&oe=672B5D0A"}, "display_name": "bHaptics Player", "keywords": [], "long_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device in the Player will register it on the device, allowing any games to automatically connect to the devices. Main functions of this application are as follows;\n\n1. Pair / Unpair: Users can Pair and unpair bHaptics' haptic devices. Once the haptic devices are paired with the app, it does not require any other pairing processes for Quest game which used the bHaptics SDK to provide haptic feedback.\n\n2. Real-time Streaming: Users can see the haptic mappings on bHaptics Player (PC version) realtime using this application. \n\n", "short_description": "bHaptics Player App is a device manager which allows users to connect bhaptics devices with Oculus Quest to play natively supported games. Pairing a device 