n": "BG Experience provides a window into today's vehicle systems including the engine, brake, drive line, and cooling system.  Learn about how each system functions, the challenges they face and BG preventive maintenance solutions to these challenges.\n\nBG\u2019s purpose is to ensure every vehicle owner understands the importance of automotive maintenance.  We want every vehicle on the road to run better and last longer.  To support this mission, we offer the highest quality maintenance products.  We study the latest technologies so we can supply the appropriate chemistry using the most effective delivery method.  We provide products, equipment and training to nearly 50,000 service centers worldwide.  \n", "short_description": "\nBG Experience provides a window into today's vehicle systems including the engine, brake, drive line, and cooling system.  Learn about how each system functions, the challenges they face and BG preventive maintenance solutions to these challenges."}]}, "developer_name": null, "developer_privacy_policy_url": "https://github.com/ReedBG/BG-Experience-Meta-App-Lab-Privacy-Policy/blob/main/README.md", "developer_terms_of_service_url": null, "publisher_name": "BG Products, inc.", "support_website_url": null, "website_url": "https://www.bgprod.com/training/bg-experience-for-automotive-professionals/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}, {"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_