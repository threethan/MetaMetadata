64.5771-25/75195905_332563895341423_8206461054165449111_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5AOslIP61QoQ7kNvgGQtyL9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBMy7NHSds62Tk3eZDk_-ueKzWgA6ZtYGEkl1XSf8nvzg&oe=6752D2B7"}, {"file_name": "6.png", "id": "319220812964042", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974854_319220816297375_2785443597618188154_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NTp16rMOhxoQ7kNvgH1Sj43&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDK4XFNiQ5KQXi6DKFPL6Aq5YiTYEEQHtHXY8FdIV3Mcw&oe=6752CB97"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Banner 2560x1440.png", "id": "906123403348165", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974676_906123406681498_7278768579614188263_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4OZVoQc51twQ7kNvgHqLqNk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC0mqtXJZXN01qa7h004jwyEKFNWvNVEsSHd2krkkkl1g&oe=6752EACB"}, "display_name": "Rai Cinema Channel", "keywords": [], "long_description": "Rai \u00e8 la prima media company a lanciare un\u2019APP VR tutta italiana, per offrire ai propri utenti una vasta gamma di contenuti originali in realt\u00e0 virtuale.\u200b Con l\u2019APP potrai fruire contenuti esclusivi lineari e VR 360\u00b0, per vivere un\u2019esperienza immersiva nel \u201ccinema virtuale\" di Rai Cinema al fianco delle star sui red carpet dei festival cinematografici, guardare interviste e immergerti in corti e documentari VR.\u200b Una volta scaricata la APP ed indossato il visore, potrai scegliere se muoverti con il controller o camminare fisicamente nello spazio circostante.\u200b Nel Foyer avrai a disposizione dei punti interattivi come un proiettore storico del Museo Nazionale del Cinema di Torino ricostruito in 3D, l'angolo dei premi Rai Cinema e gli ingressi per le sale dei video lineari e VR 360\u00b0. Selezionando le locandine, verrai proiettato direttamente nella sala per visionare il contenuto scelto.\u200b Troverai i video lineari all'interno della Sala Cinema, mentre i video 360\u00b0 sulla sfera della Sala VR.", "short_description": "Rai Cinema Channel, la App VR targata Rai"}, {"images": {"nodes": []}, "id": "219022517007495", "locale": "it_IT", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Rai Cinema Channel", "keywords": [], "long_description": "Rai \u00e8 la prima media company a lanciare un\u2019APP VR tutta italiana, per offrire ai propri utenti una vasta gamma di contenuti originali in realt\u00e0 virtuale.\u200b Con l\u2019APP potrai fruire contenuti esclusivi lineari e VR 360\u00b0, per vivere un\u2019esperienza immersiva nel \u201ccinema virtuale\" di Rai Cinema al fianco delle star sui red carpet dei festival cinematografici, guardare interviste e immergerti in corti e documentari VR.\u200b Una volta scaricata la APP ed indossato il visore, potrai scegliere se muoverti con il controller o camminare fisicamente nello spazio circostante.\u200b Nel Foyer avrai a disposizione dei punti interattivi come un proiettore storico del Museo Nazionale del Cinema di Torino ricostruito in 3D, l'angolo dei premi Rai Cinema e gli ingressi per le sale dei video lineari e VR 360\u00b0. Selezionando le locandine, verrai proiettato direttamente nella sala per visionare il contenuto scelto.\u200b Troverai i video lineari all'interno della Sala Cinema, mentre i video 360\u00b0 sulla sfera della Sala VR.", "short_description": "Rai Cinema Channel, la App VR targata Rai"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.rai.it/privacy/PrivacyPolicy.html", "developer_terms_of_service_url": "https://www.rai.it/privacy/PrivacyPolicy.html", "publisher_name": "RAI Radiotelevisione Italiana S.p.A.", "support_website_url": "https://www.rai.it/raicinema/", "website_url": "https://www.rai.it/raicinema/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_categor