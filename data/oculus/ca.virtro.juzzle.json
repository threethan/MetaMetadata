me": "Juzzle", "keywords": ["puzzle", "jelly", "sokoban", "casual", "cute"], "long_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration!\n\nIn each level there are a number of blue jelly friends. Your goal as the green jelly is to push your friends to the blue targets. The order does not matter, but sometimes it takes a little creativity to figure out the solution.  Get your Juzzle on!\n", "short_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration! \nGet your Juzzle on!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.virtrogames.com/privacy", "developer_terms_of_service_url": "https://www.virtro.ca/terms-of-service.html", "publisher_name": "Virtro Entertainment Inc.", "support_website_url": null, "website_url": "https://www.virtrogames.com/juzzle", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "463630398759527"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculus