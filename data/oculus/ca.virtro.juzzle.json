: "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001674_3420482484735883_5760285503493327692_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T99-n5sUY-4Q7kNvgEDC_8N&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCsEulIf_WiYtvOGoW-Uwrr794I5n9dd472X4N1UPz_cw&oe=676BE1D9"}, "display_name": "Juzzle", "keywords": ["puzzle", "jelly", "sokoban", "casual", "cute"], "long_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration!\n\nIn each level there are a number of blue jelly friends. Your goal as the green jelly is to push your friends to the blue targets. The order does not matter, but sometimes it takes a little creativity to figure out the solution.  Get your Juzzle on!\n", "short_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration! \nGet your Juzzle on!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.virtrogames.com/privacy", "developer_terms_of_service_url": "https://www.virtro.ca/terms-of-service.html", "publisher_name": "Virtro Entertainment Inc.", "support_website_url": null, "website_url": "https://www.virtrogames.com/juzzle", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "sup