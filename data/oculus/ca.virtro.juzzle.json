ailer": null, "video_trailer_thumbnail": {"file_name": "juzzle_trailer_cover.png", "id": "3420482481402550", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001674_3420482484735883_5760285503493327692_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wrYA990X5e8Q7kNvgHF4Lzq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ae4VGm4KPCdLSN2uH2rRfaw&oh=00_AYAZgNc8AtEZC9wFqJmqW3ooEehIDF2lygsGJKsbQOIJ8Q&oe=66DED159"}, "display_name": "Juzzle", "keywords": ["puzzle", "jelly", "sokoban", "casual", "cute"], "long_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration!\n\nIn each level there are a number of blue jelly friends. Your goal as the green jelly is to push your friends to the blue targets. The order does not matter, but sometimes it takes a little creativity to figure out the solution.  Get your Juzzle on!\n", "short_description": "Juzzle is a modern take on the classic Japanese 2D puzzle Sokoban.  Juzzle may look easy at first glance, but only a select few will be able to finish the game. These friendly faced jellies will have you scratching your head in no time! Work your brain out with 20 levels of adorable frustration! \nGet your Juzzle on!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.virtrogames.com/privacy", "developer_terms_of_service_url": "https://www.virtro.ca/terms-of-service.html", "publisher_name": "Virtro Entertainment Inc.", "support_website_url": null, "website_url": "https://www.virtrogames.com/juzzle", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_RE