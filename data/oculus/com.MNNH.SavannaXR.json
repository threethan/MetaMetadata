b8e8\uc5b8\uc11c\ub4e4\uc758 \uba54\ud0c0\ubc84\uc2a4 \uc1fc!\n\n\ud310\ud0c0\uc2a4\ud2f1\ud55c \uba54\ud0c0\ubc84\uc2a4 \uc1fc\ub97c \uac10\uc0c1\ud558\uace0 \uc140\ub7fd\uc5d0\uac8c \uc790\uc720\ub86d\uac8c \ub2e4\uac00\uac00\uac70\ub098 \ub458\ub7ec\ubcf4\uc138\uc694.\n\uc0ac\uc9c4\uacfc \ud654\uba74\uc73c\ub85c\ub9cc \ubcf4\ub358 \uc778\ud50c\ub8e8\uc5b8\uc11c\ub97c 3\ucc28\uc6d0\uc73c\ub85c \uc880 \ub354 \uac00\uae4c\uc774 \ub9cc\ub098\ubcf4\uc138\uc694.\n\uc140\ub7fd\uc758 3D \ub514\uc9c0\ud138 \uad7f\uc988\ub97c \uc18c\uc720\ud558\uace0, \ud5c8\ub2c8\ubb38 \ubc14\ub2f7\uac00\uc5d0\uc11c \ub458\ub9cc\uc758 \uacf5\uac04\uacfc \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc138\uc694.\n\nPC, \ubaa8\ubc14\uc77c, VR \ud5e4\ub4dc\uc14b\uacfc AR \uae00\ub798\uc2a4\ub85c \uc5b8\uc81c \uc5b4\ub514\uc5d0\uc11c\ub098 \uc774\uc5b4\uc9c0\ub294 \uc778\ud50c\ub8e8\uc5b8\uc11c\ub4e4\uc758 \ucd08\uc2e4\uac10 \uba54\ud0c0\ubc84\uc2a4\uc1fc! \uc9c0\uae08 \ub9cc\ub098\ubcf4\uc138\uc694.", "short_description": "\uc9c4\uc9dc \uc778\ud50c\ub8e8\uc5b8\uc11c\uac00 \uc654\ub2e4. \uba54\ud0c0\ubc84\uc2a4 \uc1fc!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.mn-nh.com/savannaxr-privacy-policy-for-meta", "developer_terms_of_service_url": null, "publisher_name": "Mn_nH, Inc.", "support_website_url": null, "website_url": "http://www.savanna-xr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supp