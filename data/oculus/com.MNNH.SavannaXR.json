8836_5102217309390676390_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lJYFGZZLPSYQ7kNvgFW-5te&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8BJBpX-U0AS2_wZWT1WUj9waoApuJcyYj5ZTeLDnvtw&oe=672B6F91"}, "display_name": "SavannaXR", "keywords": [], "long_description": "Meet K-celebrity in metaverse.\n\nFamous K-celeb's performance shows open in several stages.\nComplete 6-DoF 3D real celeb will meet with you.\nYou can look around or close to influencer freely.\nIn cosmic space, seaside, alien planet, fairy-tale forest and fractal club,\ninfluencer's fantastic performance fascinate you.\n\nThis is not fake human, awkward virtual influencer is gone.\nReal influencer shows real performance in metaverse!\nVolumetric capture based real influencer make a sense of realism.\n", "short_description": "Real influencer's real performance in metaverse"}, {"images": {"nodes": []}, "id": "138146279064831", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\uc0ac\ubc14\ub098XR", "keywords": [], "long_description": "Fake \uc5bc\uad74, \uc5b4\uc0c9\ud55c \ubc84\uce04\uc5bc \uc778\ud50c\ub8e8\uc5b8\uc11c\ub294 \uac00\ub77c.\n\uba54\ud0c0\ubc84\uc2a4\uc5d0\uc11c \ud3bc\uccd0\uc9c0\ub294 \uc9c4\uc9dc \uc778\ud50c\ub8e8\uc5b8\uc11c\uc758 \uc9c4\uc9dc \ud37c\ud3ec\uba3c\uc2a4!\n\n\ub54c\ub85c\ub294 \uc6b0\uc8fc \uacf5\uac04\uc5d0\uc11c, \ub3d9\ud654\uc18d \uc232\uc18d\uc5d0\uc11c, \ud558\ub298\uc704\uc5d0\uc11c, \ub54c\ub85c\ub294 \ubc84\uce04\uc5bc \ud074\ub7fd \uc2a4\ud14c\uc774\uc9c0\uc5d0\uc11c\uc758  \ud654\ub824\ud55c \ubb34\ub300 \uc704 \uc720\uba85 \uc778\ud50c\ub8e8\uc5b8\uc11c\ub4e4\uc758 \uba54\ud0c0\ubc84\uc2a4 \uc1fc!\n\n\ud310\ud0c0\uc2a4\ud2f1\ud55c \uba54\ud0c0\ubc84\uc2a4 \uc1fc\ub97c \uac10\uc0c1\ud558\uace0 \uc140\ub7fd\uc5d0\uac8c \uc790\uc720\ub86d\uac8c \ub2e4\uac00\uac00\uac70\ub098 \ub458\ub7ec\ubcf4\uc138\uc694.\n\uc0ac\uc9c4\uacfc \ud654\uba74\uc73c\ub85c\ub9cc \ubcf4\ub358 \uc778\ud50c\ub8e8\uc5b8\uc11c\ub97c 3\ucc28\uc6d0\uc73c\ub85c \uc880 \ub354 \uac00\uae4c\uc774 \ub9cc\ub098\ubcf4\uc138\uc694.\n\uc140\ub7fd\uc758 3D \ub514\uc9c0\ud138 \uad7f\uc988\ub97c \uc18c\uc720\ud558\uace0, \ud5c8\ub2c8\ubb38 \ubc14\ub2f7\uac00\uc5d0\uc11c \ub458\ub9cc\uc758 \uacf5\uac04\uacfc \uc2dc\uac04\uc744 \ubcf4\ub0b4\uc138\uc694.\n\nPC, \ubaa8\ubc14\uc77c, VR \ud5e4\ub4dc\uc14b\uacfc AR \uae00\ub798\uc2a4\ub85c \uc5b8\uc81c \uc5b4\ub514\uc5d0\uc11c\ub098 \uc774\uc5b4\uc9c0\ub294 \uc778\ud50c\ub8e8\uc5b8\uc11c\ub4e4\uc758 \ucd08\uc2e4\uac10 \uba54\ud0c0\ubc84\uc2a4\uc1fc! \uc9c0\uae08 \ub9cc\ub098\ubcf4\uc138\uc694.", "short_description": "\uc9c4\uc9dc \uc778\ud50c\ub8e8\uc5b8\uc11c\uac00 \uc654\ub2e4. \uba54\ud0c0\ubc84\uc2a4 \uc1fc!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.mn-nh.com/savannaxr-privacy-policy-for-meta/", "developer_terms_of_service_url": null, "publisher_name": "Mn_nH, Inc.", "support_website_url": null, "website_url": "http://www.savanna-xr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "434961926215971"}], "external_subscription_type": "REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME", "MUSIC_VIDEO"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1318356068712709"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1896958074008722"}]}, "baseline_offer": {"id": "1896958074008722"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1683314580, "status": "PUBLISHED", "id": "189695807400872