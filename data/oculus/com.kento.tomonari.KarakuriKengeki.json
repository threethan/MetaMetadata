uluscdn.com&oh=00_AYCfIYC8Sp4BhdGqkwIFbDfZzCjN9HXe8S9skoIKl_rDIA&oe=670FADC0"}, {"file_name": "KarakuriKengeki_Logo_screenshot_3.png", "id": "689417049312624", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031531_689417052645957_2531460316095286781_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5NBPrui3TTAQ7kNvgHLSWAd&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBP3jxNX7OsqGhUqZBvDJmfeCLqPZxmijaPXb0Ybnm2HA&oe=670FAE34"}, {"file_name": "KarakuriKengeki_Logo_screenshot_4.png", "id": "1365992614230914", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39035424_1365992617564247_196057820963030135_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Qzl2yRlHCIQ7kNvgH9C7tA&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAqeqUR1BFPIfd1YL8FEpGxli2xjkkBYhku7zbmKZyqbw&oe=670FA14F"}, {"file_name": "KarakuriKengeki_Logo_screenshot_5.png", "id": "1309156996589649", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974817_1309156999922982_1445576129522989721_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ad10WJxdDQAQ7kNvgGOKkX4&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBQqS_JJIWViyBvRZZAV3FV0aZs7iLMGHvV9-dxWyypTA&oe=670FA0C9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "KarakuriKengeki_Logo_25601440_2.png", "id": "3356133711309124", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974699_3356133714642457_2341147062143720854_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0VidXA6vcKUQ7kNvgGGyuym&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDhQAI7v9xg0U0TchJckAxScqp3pkzaEFEh9Wro-Y6xOw&oe=670FAF75"}, "display_name": "KARAKURI KENGEKI", "keywords": [], "long_description": "KARAKURI KENGEKI is a VR sword-fighting game in which the player fights as a samurai robot using a Japanese katana, moving through various stages redolent of old Japan.\n\nAs a samurai robot, you take up your katana bravely against the enemies ranked against you in each stage, battling with swords amid vividly Japanese settings as the tension ratchets up.\n\nBecause the enemies are waiting for you in formation, you cannot win simply by waving your sword around like a maniac.\n\nInstead, you work your way carefully through each stage, discovering the bespelled sword with its mysterious power, luring the enemy cleverly into single combat to make quick work of them.", "short_description": "KARAKURI KENGEKI is a VR sword-fighting game in which the player fights as a samurai robot using a Japanese katana, moving through various stages redolent of old Japan."}]}, "developer_name": null, "developer_privacy_policy_url": "https://karakuri-kengeki.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Kento Tomonari", "support_website_url": null, "website_url": "https://karakuri-kengeki.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1218569015412235"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "503440432480530"}, {"status": "PUBLISHED", "id": "1952973088458420"}, {"status": "PUBLISHED", "id": "715962460709465"}, {"status": "PUBLISHED", "id": "729185712547457"}, {"status": "PUBLISHED", "id": "583920156845230"}]}, "baseline_offer": {"id": "503440432480530"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727793240, "status": "PUBLISHED", "id": "503440432480530"}]}, "liveChannel": {"nodes": [{"latest_supported_bina