12218730772", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031436_768312222064105_2483983745682146754_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ljhps_TIYMAQ7kNvgGFf8Ut&_nc_ht=scontent.oculuscdn.com&oh=00_AYBiJ9PvZ0dltpyCr0ocanxlegrFZGY0CwmnGZXSIAGeug&oe=66F8031E"}, {"file_name": "com.ypro.project_y-20240210-1504414_2.png", "id": "1144388200046417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003227_1144388210046416_8982093088097178928_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vP0UVDmoNNAQ7kNvgF4Wj1c&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtiGKLbdoWU3OTPk0w81maUohvZHzEPtA8r1aj38XIuQ&oe=66F7DC11"}, {"file_name": "com.ypro.project_y-20240210-115437.png", "id": "1405118490144295", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230048_1405118493477628_4689660376237645316_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gIf3ItsQZIsQ7kNvgESEOQo&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxeXEDxX2BBaZHa194OLgmQGFD-Afjx_Qv_Jo8jyszOg&oe=66F7EC1B"}, {"file_name": "com.ypro.project_y-20240209-2137122.png", "id": "7621650634553270", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556799_7621650644553269_1655627145384024300_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ARFlVb_LocoQ7kNvgG5upvt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHdHLK43UffffA34TbUyRsfG0PmAjCXow8WDSubpeSbw&oe=66F7E21D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Project_Y: Working Title", "keywords": [], "long_description": "This game is the Japanese version.\nIt supports Japanese only.\n\n\"A true ghost story told by a person named Y.\nIt was about an investigation to find out the true meaning of a common self-inflicted urban legend that says, ``If you hear it, you'll be cursed.''\nand...\nThere is a ``sinister existence'' that appears and disappears there.\nThis project reconstructed those interview records as 360\u00b0 videos and produced and developed them as interactive content using live-action VR.\n\n\n- It comes with \"\"noise\"\" -\n\nOnce you have watched the video, you must find all the ``sinister beings'' recorded in the video.\nThat's the only way to escape.\n\nAnd when I found out everything,\n\u201cSomething\u201d happens\u2026\"", "short_description": "This game is the Japanese version.\nIt supports Japanese only.\n\n\"A true ghost story told by a person named Y.\nIt was about an investigation to find out the true meaning of a common self-inflicted urban legend that says, ``If you hear it, you'll be cursed.''\nand...\nThere is a ``sinister existence'' that appears and disappears there.\nThis project reconstructed those interview records as 360\u00b0 videos and produced and developed them as interactive content using live-action VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/project-y-2023/#h.16e2qbqtwnwb", "developer_terms_of_service_url": null, "publisher_name": "Y_Project", "support_website_url": null, "website_url": "https://sites.google.com/view/project-y-2023/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7016709591766084"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031605_413074461347670_8775974682184546969_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rfUDvHqMJCAQ7kNvgHVNpAQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDigj1Jko7VgPjN4GBgkCDp0seKebX8lIemiJibHh