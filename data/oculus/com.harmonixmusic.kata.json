ontent-iad3-2.oculuscdn.com&oh=00_AYD4jRsA5XEe9zetrie16n36yQQmWtczTu8z5yG-WaQhpw&oe=6707C882"}, {"file_name": "migrated_image.png", "id": "2542446246016105", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974734_2154819051486552_5200243674969014272_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QLjd6LcwG6MQ7kNvgEslUiG&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCPRGRlSL6Nd2ZIEf2mDWd4V7SmKUctBGxse2k-JCU1Pw&oe=6707D889"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/8woxvc", "id": "2408637455871163", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982506_2408637459204496_8733115104997933056_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WsgLOf-J0JYQ7kNvgF2Ycev&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDa5rOLDo4OfqOuR3gzlnt6Be8wtQrXt1yOgQ9io1hQWQ&oe=6707B491"}, "display_name": "Audica", "keywords": ["music", "audica", "rhythm", "shooter", "electronic"], "long_description": "Audica\u2122 is a VR Rhythm Shooter from Harmonix, the makers of Rock Band\u2122 and Dance Central\u2122. Armed with a pair of rhythm blasters, you shoot and smash targets to the beat of a soundtrack featuring songs from some of the world\u2019s most popular electronic artists. The better your timing and accuracy, the better your score. The better your score, the higher your place on the Audica Leaderboards.\n \nAudica is incredibly intuitive and immersive from the first time you play - use your blue and orange blasters to shoot color-coded targets to the beat while in a breathtaking cosmic arena. On expert difficulty, Audica gameplay is intense and exacting. If you want to claim a spot at the top of the leaderboards, you\u2019ll need to practice until you and your blasters become one, performing a tightly choreographed ballet of beat-blasting brilliance.", "short_description": "Audica\u2122 is a VR \u201crhythm shooter\u201d that combines Harmonix\u2019s award-winning music gameplay with precision shooting mechanics and a killer soundtrack, all set in a mesmerizing cosmic arena."}]}, "developer_name": "Harmonix Music Systems, Inc", "developer_privacy_policy_url": "http://www.harmonixmusic.com/privacy", "developer_terms_of_service_url": "http://www.harmonixmusic.com/terms", "publisher_name": "Harmonix Music Systems, Inc", "support_website_url": null, "website_url": "http://www.audicagame.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "it", "de", "es", "ko", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "473154484473948"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5801809953220929", "version": "1.0.3.4"}, "id": "418267622142259", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2333124776756148", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5801809953220929"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "418267622142259"}]}, "change_log": "Built @ Changelist: 1318086", "created_date": 1677262596, "id": "5801809953220929", "version"