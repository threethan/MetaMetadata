ate diverse environments for a dynamic experience.", "short_description": "\"Mountain Bike Downhill \" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zigagamestudio.com/wp-content/uploads/2024/08/privacy.jpg", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8106763722734848"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974573_1402004540487763_1602457485752839331_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rruFaypL7VwQ7kNvgFuOK08&_nc_ht=scontent.oculuscdn.com&oh=00_AYDznZS5hcM0TbSBXsgIpKWi74CdReqqjOvXC4xlxqz2fg&oe=66CB1BC4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mountain Bike Downhill", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Racing", "id": "673385183287495"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1712849400, "lastRevision": {"nodes": [{"id": "7332579526819942", "release_type":