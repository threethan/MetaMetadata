png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=71cxqYo0utAQ7kNvgE38gCt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDs9Yz7VT_mWxHm0cOOLx6XoxEthcaMyMMzNRip6xQmHQ&oe=6718DF0A"}, {"file_name": "4.png", "id": "737633705153185", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982492_737633708486518_5940799322534748557_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z61sjtjveegQ7kNvgFr4-Ms&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_fUbjLhVqUqfID_BnUoCSoW8yKzMsBahrlzkoaJbunQ&oe=6718FBBA"}, {"file_name": "5.png", "id": "930424335389008", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86629761_930424338722341_3549609640625277831_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gNatzzSP-WwQ7kNvgHBqiLr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5VCBoc3LaX6Ld1IMcp08UEJvnk9GNT7KKj6-Hl0NQ0g&oe=6718E702"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "4596146003944923", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036697_4596146007278256_3277507150616169599_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lrW7Q9-eu0sQ7kNvgHzguMe&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCa_3noTnXZMHbQjvu5b9-sO3y2n4BNWxVGHj2Z6nEHmA&oe=6718EA34"}, "display_name": "Mountain Bike Downhill", "keywords": ["bike", "motorbike", "race", "offroad", "bicycle"], "long_description": "Dive into an exhilarating adventure through the world of off-road mountain bike racing and speed with \"Mountain Bike Downhill\". Explore breathtaking natural landscapes, thrilling races, and endless exploration opportunities.\n\n\ud83c\udfc6Career Mode:\nTake on a series of exhilarating challenges.\nUnlock new levels and bikes as you progress.\nMaster each stunt for the ultimate gaming glory.\n\n\ud83d\udeb4Stunt Mode:\nPerform jaw-dropping stunts \nConquer challenges with stunt bikes\n\n\ud83d\udd52Time Trials:\nCarry objects against the clock in a thrilling Time Trial.\nTest your speed and precision in solo gameplay.\nCompete for the best times and unlock new levels\n\n\ud83d\udeb2Bikes:\nUnlock and choose from a fleet of high-speed, \nEach bike has unique attributes for varied gameplay experiences.\nUpgrade your favorite vehicle for enhanced performance.\n\n\ud83d\uddfa\ufe0f Navigate diverse environments for a dynamic experience.", "short_description": "\"Mountain Bike Downhill \" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ketchygames.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8443762805701603"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974573_1402004540487763_1602457485752839331_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jtnKcuP5i8IQ7kNvgG9DTPV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9cvQj3XpXzdBrodzxq6xZN66igw5ha8v7cdoQeqwPTQ&oe=6718E444"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mountain Bike Downhill", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "27433260359