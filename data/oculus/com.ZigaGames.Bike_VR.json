s \n-Conquer challenges with stunt bikes\n\n=> Time Trial:\nCarry objects against the clock in a thrilling Time Trial.\nTest your speed and precision in solo gameplay.\nCompete for the best times and unlock new levels\n\nDifferent bikes:\n\nUnlock and choose from a fleet of high-speed, \nEach bike has unique attributes for varied gameplay experiences.\nUpgrade your favorite vehicle for enhanced performance.\n\nNavigate diverse environments for a dynamic experience.", "short_description": "\"MTB Downhill\" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.zigagamestudio.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "673385183287495"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7332579510153277"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1662404114545082"}, {"status": "PUBLISHED", "id": "395645306885073"}, {"status": "PUBLISHED", "id": "1137402660655108"}, {"status": "PUBLISHED", "id": "324746850657027"}, {"status": "PUBLISHED", "id": "1330448884298064"}]}, "baseline_offer": {"id": "1137402660655108"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "i