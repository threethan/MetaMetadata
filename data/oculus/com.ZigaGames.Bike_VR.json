5398803782458602424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6lNWO_uzH8Q7kNvgGvRuSH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn_QNWV98ZUWUEVhcYJthr3poYLA9KePnmNz3CIbiIHg&oe=67066A0A"}, {"file_name": "4.png", "id": "737633705153185", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982492_737633708486518_5940799322534748557_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RVkf4iHiQRcQ7kNvgGWae-p&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDBGrXs8CLDMSigZfQRehLUR3Qy6R5xA0q_4IHrqCKvg&oe=670686BA"}, {"file_name": "5.png", "id": "930424335389008", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86629761_930424338722341_3549609640625277831_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z6O-u7NCDKoQ7kNvgEmONgF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBB8sEWyDsXsx4HCqML7CDttr7OSwZquZR6bIt12ecrQ&oe=67067202"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "7576637879026119", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86615892_7576637889026118_3213961923196708108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MmilgOWLUtoQ7kNvgFQxZXS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3LCZp6v6h2VQIFr8mAiKYlFBS_5JYDPl-gI8uI3XOoA&oe=6706695B"}, "display_name": "MTB Downhill", "keywords": [], "long_description": "Dive into an exhilarating adventure through the world of off-road mountain bike racing and speed with \"MTB Downhill\". Explore breathtaking natural landscapes, thrilling races, and endless exploration opportunities.\n\nModes: \n=> Career Mode:\n-Take on a series of exhilarating challenges.\n-Unlock new levels and bikes as you progress.\n-Master each stunt for the ultimate gaming glory.\n\n=> Stunt Mode:\n-Perform jaw-dropping stunts \n-Conquer challenges with stunt bikes\n\n=> Time Trial:\nCarry objects against the clock in a thrilling Time Trial.\nTest your speed and precision in solo gameplay.\nCompete for the best times and unlock new levels\n\nDifferent bikes:\n\nUnlock and choose from a fleet of high-speed, \nEach bike has unique attributes for varied gameplay experiences.\nUpgrade your favorite vehicle for enhanced performance.\n\nNavigate diverse environments for a dynamic experience.", "short_description": "\"MTB Downhill\" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.zigagamestudio.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7332579510153277"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1662404114545082"}, {"status": "PUBLISHED", "id": "395645306885073"}, {"status": "PUBLISHED", "id": "1137402660655108"}, {"status": "PUBLISHED", "id": "324746850657027"}, {"status": "PUBLISHED", "id": "1330448884298064"}]}, "baseline_offer": {"id": "1137402660655108"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1662404114545082"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8084111845000036", "version": "8"}, "id": "1691683161239709", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries