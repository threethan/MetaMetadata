6708108_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q1CwTH1JhWsQ7kNvgE2mjO0&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBoJFxr2c89TQ6THTgTdKtjBm8clXL8Ql2-8ZwtJl6MwQ&oe=67879C5B"}, "display_name": "MTB Downhill", "keywords": [], "long_description": "Dive into an exhilarating adventure through the world of off-road mountain bike racing and speed with \"MTB Downhill\". Explore breathtaking natural landscapes, thrilling races, and endless exploration opportunities.\n\nModes: \n=> Career Mode:\n-Take on a series of exhilarating challenges.\n-Unlock new levels and bikes as you progress.\n-Master each stunt for the ultimate gaming glory.\n\n=> Stunt Mode:\n-Perform jaw-dropping stunts \n-Conquer challenges with stunt bikes\n\n=> Time Trial:\nCarry objects against the clock in a thrilling Time Trial.\nTest your speed and precision in solo gameplay.\nCompete for the best times and unlock new levels\n\nDifferent bikes:\n\nUnlock and choose from a fleet of high-speed, \nEach bike has unique attributes for varied gameplay experiences.\nUpgrade your favorite vehicle for enhanced performance.\n\nNavigate diverse environments for a dynamic experience.", "short_description": "\"MTB Downhill\" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.zigagamestudio.com/index.php/privacy-policy-2/", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "673385183287495"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "