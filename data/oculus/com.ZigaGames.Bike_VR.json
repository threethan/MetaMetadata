culuscdn.com/v/t64.5771-25/38982570_1099384551335548_5398803782458602424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JaoiNkbg-oMQ7kNvgEkMMS8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADAVVHQVKcLrYX4XODAZNv-&oh=00_AYC58rXGlnUoLHnZSMZQJ-je9syJ5k_H-L-OpeOWGLL6AQ&oe=66F1520A"}, {"file_name": "4.png", "id": "737633705153185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982492_737633708486518_5940799322534748557_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gxyZuwvm4DAQ7kNvgG6KG24&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADAVVHQVKcLrYX4XODAZNv-&oh=00_AYA6IJu-7sdzvFKX6ZA1Zq_9xkfTeu20Y1u1UGBHsxOnmw&oe=66F1367A"}, {"file_name": "5.png", "id": "930424335389008", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86629761_930424338722341_3549609640625277831_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lVxM7tAUGZYQ7kNvgFruMf8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADAVVHQVKcLrYX4XODAZNv-&oh=00_AYB_jzhInWoFSO4_rCabWbGlCkrYmtBbqYuo71njwLJumA&oe=66F15A02"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440.png", "id": "4596146003944923", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036697_4596146007278256_3277507150616169599_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S0n1IEzwQfcQ7kNvgEryiiV&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADAVVHQVKcLrYX4XODAZNv-&oh=00_AYB9hC5VR_nRvMa703vcwAKAAJw_We1oyPbwT2fuZLfOnA&oe=66F15D34"}, "display_name": "Mountain Bike Downhill", "keywords": ["bike", "motorbike", "race", "offroad", "bicycle"], "long_description": "Dive into an exhilarating adventure through the world of off-road mountain bike racing and speed with \"Mountain Bike Downhill\". Explore breathtaking natural landscapes, thrilling races, and endless exploration opportunities.\n\n\ud83c\udfc6Career Mode:\nTake on a series of exhilarating challenges.\nUnlock new levels and bikes as you progress.\nMaster each stunt for the ultimate gaming glory.\n\n\ud83d\udeb4Stunt Mode:\nPerform jaw-dropping stunts \nConquer challenges with stunt bikes\n\n\ud83d\udd52Time Trials:\nCarry objects against the clock in a thrilling Time Trial.\nTest your speed and precision in solo gameplay.\nCompete for the best times and unlock new levels\n\n\ud83d\udeb2Bikes:\nUnlock and choose from a fleet of high-speed, \nEach bike has unique attributes for varied gameplay experiences.\nUpgrade your favorite vehicle for enhanced performance.\n\n\ud83d\uddfa\ufe0f Navigate diverse environments for a dynamic experience.", "short_description": "\"Mountain Bike Downhill \" is all about off-roading, speed, and challenges in VR."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zigagamestudio.com/wp-content/uploads/2024/08/privacy.jpg", "developer_terms_of_service_url": null, "publisher_name": "Ziga Games", "support_website_url": null, "website_url": "https://www.zigagamestudio.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "673385183287495"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8106763722734848"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974573_1402004540487763_1602457485752839331_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MHv_3BDbXCkQ7kNvgGg9Vx6&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADAVVHQVKcLrYX4XODAZNv-&oh=00_AYAfL_RFNFwqtdhk4S2uDtdDx6OMpeesG6oThr8j1yfI2A&oe=66F15744"}, "is_concept": false, "is_test": false, "is_trial_o