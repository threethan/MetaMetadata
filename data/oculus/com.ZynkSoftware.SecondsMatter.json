06264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031432_960154091839597_238106282151978913_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uIPIKBAdcpUQ7kNvgFbD5YB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBXcVRqiYqEpH41egzrZMBQGtQ7xIKEB6L9RSUd45fciA&oe=6773DB25"}, {"file_name": "screenshot3.png", "id": "1023239755339442", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031353_1023239758672775_4906347536319771816_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QbAbfAgIEO4Q7kNvgE7-HLx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBpbIPFzJSDdLeC_b2CDj-bRXDfAUp92k7KLs9CEn3Lmw&oe=6773C65C"}, {"file_name": "screenshot2.png", "id": "810202130828903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035354_810202140828902_3720512733690472135_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_ynl1J7nuQAQ7kNvgEJtZD5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMIXPbBGsd9MbHEDloknRzYayh7sHrUv9c_UapaybR-Q&oe=6773E214"}, {"file_name": "screenshot1 (1).png", "id": "1207746699899191", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974497_1207746703232524_2400542087860910924_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zRUkn58rdq8Q7kNvgEfIGn8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYOd-DthZhWO3kBjizqEe_VUThRMvdUOI6jQ_4cCUlWg&oe=6773C5FC"}, {"file_name": "screenshot4.png", "id": "819981346420526", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031473_819981349753859_5878379290111350232_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tHF05-9n4W0Q7kNvgHPT7hF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEu5F9xo6gKyM60iYHAAkSrUmEXlIMvZQkXinDDuY-Sw&oe=6773CDD6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverImage.png", "id": "317054290746045", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001717_317054297412711_2707351604601941949_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4kUfP_YRgRIQ7kNvgFLfK-1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRM3cxH5I4Dq_CS9NuVyhZb3SLEEc6yj32LrgARowYjw&oe=6773C556"}, "display_name": "10 Seconds", "keywords": [], "long_description": "Have you ever heard of the phrase \"simple things are harder than they seem\"? \n\nWell, 10 Seconds challenges you to try and find out whether the phrase is right or wrong by giving you a set of tasks that you have to carry out. And guess what? For each task you have a limited time of... just... 10 seconds! You better be fast!\n\nHave you heard enough already? Gather your friends and play this party, funny, fast paced game in order to see who is better at throwing stuff, eating, drinking or other common activities when the time is your worst enemy!\n\nFriendly advice: The difficulty of each task will increase during the game session, so don't get too cocky!\n\nFeatures\n- Local leaderboard in order to compare your skills with the ones of your friends.\n- Global leaderboard in order to compare your skills with the ones of other players across the world.", "short_description": "Gather your friends and play this party, funny, fast paced game in order to see who is better at throwing stuff, eating, drinking or other common activities when the time is your worst enemy! To complete each task you have a maximum of... yeah... you guessed it... 10 seconds!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.zynksoftware.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Zynk Software Srl", "support_website_url": null, "website_url": "https://www.zynksoftware.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1700921480735423"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT",