e": "New Project (31).png", "id": "2668087653371576", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/86604448_2668087656704909_6337941301460523144_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2rAey6XPqYQ7kNvgE9mxGV&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDUha1Q71WuA56gZI3XdhelQf6iCRI-hX00cyPxnj2edQ&oe=670142CF"}, {"file_name": "New Project (23).png", "id": "437182372452061", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001664_437182375785394_3294082664135552880_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uizX9l6yWroQ7kNvgG3ding&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYASUxozmNFfAZrGWBfuOr2HCIGqZ4RVR4sPT6fl0GERJA&oe=67012239"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "New Project (25).png", "id": "478700128022045", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982457_478700131355378_6798201122442898696_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4X3__Xrk5oEQ7kNvgHQvhAO&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCbi77ORhrv-rlUC9w0bCcK8SucsP567-Yggh3tZRlyCA&oe=67011B51"}, "display_name": "Monke Tag", "keywords": [], "long_description": "Welcome to Monke Tag, a Gorilla Tag fan game with Tag! There are three game modes, Infection, Tag, and Casual. There are nine maps to explore, Forest, Monkeist Labs, Beach, Canyons, Caves, MonkeVillie, Laser Tag Arena, Mountains, and Jungle. There are a bunch of cosmetics in the Monke Mall for you to dress your Monke up! If you wanna see how the cosmetics look on you, go ahead and try them on!  All your purchased cosmetics will be stored in the Wardrobe on the top floor of stump. Monke Tag is all about fun, every month you should expect an update that adds limited time cosmetics and exciting map changes! Have you ever felt like making content for the game? Well we feature a Content Creator system that if joined, grants you a unique badge to show of to fellow Monkes. If this game seems like something you wanna play, go ahead and download on the Meta Applab Store!", "short_description": "Welcome to Monke Tag, a Gorilla Tag fan game with Tag! There are 3 Game modes, Infection, Tag, and Casual. There are many maps to play in and explore. This game uses the Gorilla Locomotion System."}]}, "developer_name": "Monke Laboratory Studios", "developer_privacy_policy_url": "https://monkeylabstudios.wixsite.com/studio", "developer_terms_of_service_url": null, "publisher_name": "Monke Laboratory Studios", "support_website_url": null, "website_url": "https://monkeylabstudios.wixsite.com/studio", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25850274364586808"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035344_1956832518100406_1382433572107163388_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p6KKTbA36iYQ7kNvgEG7urP&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYClMT83pTHdVCJ2sBgQZvbJ-SmDr1Rup-XmtDOMyjswhQ&oe=67013BFD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Monke Tag", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Casual", "id": "394813081514456"}], "relea