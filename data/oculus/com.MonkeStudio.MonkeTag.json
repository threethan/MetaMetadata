_sid=6e7a0a&_nc_ohc=5km2dIwM7c4Q7kNvgE61KA5&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5fjryRvFlCEzN1OjJeKGLA&oh=00_AYA-Ti4_sJIOAY1ziv8eA9m6moCIvRwMVXMz1wWyq7Ug9g&oe=66E04731"}, {"file_name": "New Project (31).png", "id": "2668087653371576", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86604448_2668087656704909_6337941301460523144_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCX8GvOrrJEQ7kNvgGOQZpf&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5fjryRvFlCEzN1OjJeKGLA&oh=00_AYCxbo8Nap9rvSUgW8pkDZ-epEwCJZyesxBy57F-vphwkA&oe=66E0150F"}, {"file_name": "New Project (23).png", "id": "437182372452061", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001664_437182375785394_3294082664135552880_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Jo1RGhxpnUQ7kNvgHtTx5d&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5fjryRvFlCEzN1OjJeKGLA&oh=00_AYDGhqOtZovFEh_1fxxGhhH7vNaxIcZFBzNqXk1JaG6Nrw&oe=66E02CB9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "New Project (25).png", "id": "478700128022045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982457_478700131355378_6798201122442898696_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=64eufQVfKJAQ7kNvgE-ClQZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5fjryRvFlCEzN1OjJeKGLA&oh=00_AYAAVUyG5XOVOv8-9hIB5scMFUaay6WiycmgkdJUvUpVsQ&oe=66E025D1"}, "display_name": "Monke Tag", "keywords": [], "long_description": "Welcome to Monke Tag, a Gorilla Tag fan game with Tag! There are three game modes, Infection, Tag, and Casual. There are nine maps to explore, Forest, Monkeist Labs, Beach, Canyons, Caves, MonkeVillie, Laser Tag Arena, Mountains, and Jungle. There are a bunch of cosmetics in the Monke Mall for you to dress your Monke up! If you wanna see how the cosmetics look on you, go ahead and try them on!  All your purchased cosmetics will be stored in the Wardrobe on the top floor of stump. Monke Tag is all about fun, every month you should expect an update that adds limited time cosmetics and exciting map changes! Have you ever felt like making content for the game? Well we feature a Content Creator system that if joined, grants you a unique badge to show of to fellow Monkes. If this game seems like something you wanna play, go ahead and download on the Meta Applab Store!", "short_description": "Welcome to Monke Tag, a Gorilla Tag fan game with Tag! There are 3 Game modes, Infection, Tag, and Casual. There are many maps to play in and explore. This game uses the Gorilla Locomotion System."}]}, "developer_name": "Monke Laboratory Studios", "developer_privacy_policy_url": "https://monkeylabstudios.wixsite.com/studio", "developer_terms_of_service_url": null, "publisher_name": "Monke Laboratory Studios", "support_website_url": null, "website_url": "https://monkeylabstudios.wixsite.com/studio", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "25850274364586808"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035344_1956832518100406_1382433572107163388_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dsj7XQSrnucQ7kNvgHnKCag&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5fjryRvFlCEzN1OjJeKGLA&oh=00_AYCSFULNPfNKl_UMk-sRyNqNqGF4LYBXcz5ZcWUY_57i3w&oe=66E0467D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Monke Tag", "platform": "ANDROID_6DOF", "