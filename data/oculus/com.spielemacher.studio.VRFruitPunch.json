ects\n", "short_description": "Monster Mu throws one fruit after the other to your head and wants to hit you. Monster Mu throws faster and  faster and will sometimes  throw several fruits at once. Punch the fruit at the right time and finish your fruit cocktail otherwise the fruit will explode in your face. Attention: Don't let the toaster hit you. \n\nstay tuned for more updates coming soon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.frupumakesmehigh.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "spielemacher.studio", "support_website_url": null, "website_url": "http://www.frupu.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2480812052071620"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "5867664996674060"}]}, "baseline_offer": {"id": "5867664996674060"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1675117020, "status": "PUBLISHED", "id": "5867664996674060"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7595248883911517", "version": "0.1.9"}, "id": "828962331603092", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Applicatio