omisation and innovative creative tools like the flower brush.", "short_description": "Create and explore floral beauty in mixed reality."}]}, "developer_name": "EVRESNCE", "developer_privacy_policy_url": "https://www.evresnce.com/myflowerreality-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "EVRESNCE", "support_website_url": null, "website_url": "https://www.evresnce.com/myflowerreality", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7074660312660247"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "551061694442250"}, {"status": "CANCELLED", "id": "1127704722270923"}, {"status": "PUBLISHED", "id": "1171575260734216"}, {"status": "PUBLISHED", "id": "835208681888223"}, {"status": "PUBLISHED", "id": "985342312903905"}, {"status": "PUBLISHED", "id": "2115386038847920"}, {"status": "PUBLISHED", "id": "724104343228594"}]}, "baseline_offer": {"id": "551061694442250"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734111540, "status": "PUBLISHED", "id": "551061694442250"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8563257000467230", "version": "2.0.3"}, "id": "349597770970826", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBina