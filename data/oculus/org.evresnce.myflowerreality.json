CE", "developer_privacy_policy_url": "https://www.evresnce.com/myflowerreality-privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "EVRESNCE", "support_website_url": null, "website_url": "https://www.evresnce.com/myflowerreality", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1990104051447093"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko", "fr", "de", "ja", "es"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8520180608108203"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982484_3933527333603344_4312811210700702227_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3ggHZEfdfqEQ7kNvgEDl0JS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAv_FNKUT0WtYZu7yF5LZNJBocMQ7hJtaRHxc8mh1lCRA&oe=6762D0C9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "My Flower Reality", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "Sandbox", "id": "1990104051447093"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1713203040, "lastRevision": {"nodes": [{"id": "7074660349326910", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en