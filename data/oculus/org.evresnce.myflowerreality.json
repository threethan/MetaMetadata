uc18d\uc73c\ub85c \ube60\uc838\ub4e4\uac8c \ud558\ub294 \uc2f1\uae00 \ud50c\ub808\uc774\uc5b4 VR \ubc0f \ud63c\ud569 \ud604\uc2e4 \uac8c\uc784\uc785\ub2c8\ub2e4. \uaf43\uc73c\ub85c \uac00\ub4dd\ud55c \uacf5\uac04\uc744 \uafb8\ubbf8\uba70 \ud3b8\uc548\ud568\uc744 \ub290\uaef4\ubcf4\uc138\uc694.\n\n\uc190 \ucd94\uc801 \uae30\ub2a5\uc774\ub098 \ud130\uce58 \ucee8\ud2b8\ub864\ub7ec\ub97c \uc0ac\uc6a9\ud574 \ub2e4\uc591\ud55c \uc544\uc774\ud15c\uc73c\ub85c \uba4b\uc9c4 \uaf43\uaf42\uc774\ub97c \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694.", "short_description": "VR\uc5d0\uc11c \ud50c\ub85c\ub9ac\uc2a4\ud2b8\uac00 \ub418\uc5b4 \ub2f9\uc2e0\uc758 \ucc3d\uc758\ub825\uc744 \uaf43\ud53c\uc6b0\uc138\uc694."}, {"images": {"nodes": []}, "id": "726452256288622", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "My Flower Reality", "keywords": [], "long_description": "\u30de\u30a4\u30fb\u30d5\u30e9\u30ef\u30fc\u30fb\u30ea\u30a2\u30ea\u30c6\u30a3(My Flower Reality)\u306f\u3001\u82b1\u306e\u7f8e\u3057\u3055\u306e\u4e16\u754c\u306b\u6ca1\u5165\u3067\u304d\u308b\u30b7\u30f3\u30b0\u30eb\u30d7\u30ec\u30a4\u30e4\u30fc\u306eVR\u304a\u3088\u3073\u30df\u30c3\u30af\u30b9\u30c9\u30ea\u30a2\u30ea\u30c6\u30a3\u30b2\u30fc\u30e0\u3067\u3059\u3002\u82b1\u3067\u7a7a\u9593\u3092\u98fe\u308a\u3001\u30ea\u30e9\u30c3\u30af\u30b9\u3057\u307e\u3057\u3087\u3046\u3002\n\n\u30cf\u30f3\u30c9\u30c8\u30e9\u30c3\u30ad\u30f3\u30b0\u3084\u30bf\u30c3\u30c1\u30b3\u30f3\u30c8\u30ed\u30fc\u30e9\u30fc\u3092\u4f7f\u3063\u3066\u3001\u3055\u307e\u3056\u307e\u306a\u30a2\u30a4\u30c6\u30e0\u3067\u7d20\u6575\u306a\u30a2\u30ec\u30f3\u30b8\u30e1\u30f3\u30c8\u3092\u4f5c\u308a\u307e\u3057\u3087\u3046\u3002", "short_description": "VR\u3067\u30d5\u30ed\u30fc\u30ea\u30b9\u30c8\u306b\u306a\u308a\u3001\u3042\u306a\u305f\u306e\u5275\u9020\u529b\u3092\u958b\u82b1\u3055\u305b\u307e\u3057\u3087\u3046\u3002"}]}, "developer_name": "EVRESNCE", "developer_privacy_policy_url": "https://www