uscdn.com&oh=00_AYDe0LkXOvZux0JBf_hrZUgB1Pimb0i8kUbw1PjzXdyQtA&oe=67503250"}, {"file_name": "5Mpz9L.png", "id": "221495209305416", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035317_221495212638749_374869865195896832_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AJFi0RLOVuEQ7kNvgEDwh2f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBNzc6AbQG9G31--9zKBfQv-Z7DOk_-x9zmeMjhu6Wp3g&oe=67504503"}, {"file_name": "uOlsk0.png", "id": "244667959986378", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036641_244667963319711_4654484053272035328_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fvMHB5ITtV0Q7kNvgF0V6n9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZ2NrdTMWXfbFJsdCqX5m-lvI0BtqrTdGjO64Kk-OcUQ&oe=67505CE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FNAFHW_TrailerCover_2560x1440.png", "id": "676657016245591", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75395600_676657019578924_7001247118161678736_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VAm0_WsBOV4Q7kNvgHjuaoR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCAB6PcnXPw6VflcjqBsC5IFHGUQWDqiQzwfjqo4l5Oyg&oe=67504102"}, "display_name": "Five Nights at Freddy's: Help Wanted", "keywords": ["freddy", "robot", "survival", "horror", "jumpscare"], "long_description": "Five Nights at Freddy\u2019s: Help Wanted is a virtual reality experience for the Oculus Quest. FNaF: HW is a collection of classic and original mini-games set in the Five Nights universe. Survive terrifying encounters with your favorite killer animatronics in a collection of new and classic FIVE NIGHTS AT FREDDY\u2019S\u2122 experiences. \u201cWhere fantasy and fun come to life!\u201d\n\n\nYOU\u2019RE HIRED - Repair claustrophobic ventilation systems, troubleshoot broken animatronics that could activate at any moment, or spend your evenings cowering in the nighttime security guard office. \nCELEBRATE - Confront your favorite killer animatronics including; Freddy, Bonnie, Chica, Foxy, Springtrap, The Mangle, Funtime Foxy, and Circus Baby. \nPIZZA PARTY - Scenes from classic titles have been updated for an immersive VR experience including;  Five Nights at Freddy\u2019s, Five Nights at Freddy\u2019s 2, Five Nights at Freddy\u2019s 3, Five Nights at Freddy\u2019s 4,  and Five Nights at Freddy\u2019s: Sister Location.", "short_description": "Five Nights at Freddy\u2019s: Help Wanted is a virtual reality experience for the Oculus Quest. FNaF: HW is a collection of classic and original mini-games set in the Five Nights universe. Survive terrifying encounters with your favorite killer animatronics in a collection of new and classic FIVE NIGHTS AT FREDDY\u2019S\u2122 experiences. \u201cWhere fantasy and fun come to life!\u201d"}]}, "developer_name": "Steel Wool Studios", "developer_privacy_policy_url": "https://www.steelwoolstudios.com/legal/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "ScottGames", "support_website_url": "https://www.steelwoolstudios.com/contact", "website_url": "https://www.steelwoolstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "240760414888413"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/43931329_349919905972447_6988520783076009363_n.png?stp=dst-png_s360x360&_nc_cat=1