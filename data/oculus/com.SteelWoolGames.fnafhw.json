_sid=6e7a0a&_nc_ohc=rLIm38mXNsYQ7kNvgHfaIz6&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aug9jcejiE2_i6BDBJ3XbSc&oh=00_AYAv1iyQMzasNrK1fCuHUPkX9GOBftlOXBedj5QG3Fr1Mg&oe=66E022D0"}, {"file_name": "5Mpz9L.png", "id": "221495209305416", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035317_221495212638749_374869865195896832_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZFHGMxRV_7YQ7kNvgHxWY29&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aug9jcejiE2_i6BDBJ3XbSc&oh=00_AYC-B5SalGcybh0GgJ4zC5o-1kk3NH6A5DFBtCaBoUYB0A&oe=66E03583"}, {"file_name": "uOlsk0.png", "id": "244667959986378", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_244667963319711_4654484053272035328_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jE-Lw-2UZ3YQ7kNvgErXy8Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aug9jcejiE2_i6BDBJ3XbSc&oh=00_AYDTV4llN6zvDvePY5pTeu7hf486NJXnGAKrdAXFfbJa-w&oe=66E01520"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FNAFHW_TrailerCover_2560x1440.png", "id": "676657016245591", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395600_676657019578924_7001247118161678736_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4_4THJvfL-cQ7kNvgH85B2m&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aug9jcejiE2_i6BDBJ3XbSc&oh=00_AYBb4CYz-D1hl4jwlY8aVOy9lWg3XbJA0Bgf5KX6M48eqg&oe=66E03182"}, "display_name": "Five Nights at Freddy's: Help Wanted", "keywords": ["freddy", "robot", "survival", "horror", "jumpscare"], "long_description": "Five Nights at Freddy\u2019s: Help Wanted is a virtual reality experience for the Oculus Quest. FNaF: HW is a collection of classic and original mini-games set in the Five Nights universe. Survive terrifying encounters with your favorite killer animatronics in a collection of new and classic FIVE NIGHTS AT FREDDY\u2019S\u2122 experiences. \u201cWhere fantasy and fun come to life!\u201d\n\n\nYOU\u2019RE HIRED - Repair claustrophobic ventilation systems, troubleshoot broken animatronics that could activate at any moment, or spend your evenings cowering in the nighttime security guard office. \nCELEBRATE - Confront your favorite killer animatronics including; Freddy, Bonnie, Chica, Foxy, Springtrap, The Mangle, Funtime Foxy, and Circus Baby. \nPIZZA PARTY - Scenes from classic titles have been updated for an immersive VR experience including;  Five Nights at Freddy\u2019s, Five Nights at Freddy\u2019s 2, Five Nights at Freddy\u2019s 3, Five Nights at Freddy\u2019s 4,  and Five Nights at Freddy\u2019s: Sister Location.", "short_description": "Five Nights at Freddy\u2019s: Help Wanted is a virtual reality experience for the Oculus Quest. FNaF: HW is a collection of classic and original mini-games set in the Five Nights universe. Survive terrifying encounters with your favorite killer animatronics in a collection of new and classic FIVE NIGHTS AT FREDDY\u2019S\u2122 experiences. \u201cWhere fantasy and fun come to life!\u201d"}]}, "developer_name": "Steel Wool Studios", "developer_privacy_policy_url": "https://www.steelwoolstudios.com/legal/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "ScottGames", "support_website_url": "https://www.steelwoolstudios.com/contact", "website_url": "https://www.steelwoolstudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "240760414888413"}, "review_messages": ["", ""]}]}, "cover_square_