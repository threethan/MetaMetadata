855C6"}, {"file_name": "08.screenshot1.png", "id": "796034401991611", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57575348_796034405324944_8908986719027688797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mr0Taqhdw2YQ7kNvgEnSP-i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCooc7q6i_2jG-4EyWDHfV-ks5BJWUJkHpZJfz7wHvz9Q&oe=67484D0F"}, {"file_name": "08.screenshot5.png", "id": "295911690214865", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974673_295911693548198_2567195772866003076_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKxFDceR5rcQ7kNvgErtWw4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJzmYTv0LDt4t10f4da6KmxR3XuLvAGl3knNmjdjQJag&oe=67486DA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "10.coverImage.png", "id": "960323861972159", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974763_960323865305492_1348944185261368978_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLd1bL3xNwEQ7kNvgHdA-bW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATzGFopbSCf9dsK_7f4YAl5biHCE0q3GEQ9WboOhZ-Eg&oe=6748661B"}, "display_name": "Spatial Perception Training (Cube)", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "It is a cognitive game for cognitive rehabilitation training to help rehabilitate people with cognitive decline and mild cognitive impairment, and is designed to provide two or more cognitive experiences and training in the game. Cognitive Cube Game is designed to allow people with disabilities who have difficulty using controllers to play games through hand tracking."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7225481560912519"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "3676336805964599"}, {"status": "PUBLISHED", "id": "1879294155924348"}]}, "baseline_offer": {"id": "3676336805964599"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727851321, "status": "PUBLISHED", "id": "3676336805964599"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7225556140905061", "version": "0.1"}, "id": "360772393016725", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7225481550912520", "is_concept": false, "latest_rele