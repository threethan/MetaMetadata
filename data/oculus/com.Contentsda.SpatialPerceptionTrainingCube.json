32_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-olYAcA5Lt4Q7kNvgFIOPDB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApVwkclTtGZ-Bfk2NOYHKUT8sHM7JPn4FA52vJGCeinA&oe=671E26C7"}, {"file_name": "ApplicationFrameHost_4yHb3kIMNl.png", "id": "898098425583003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974866_898098428916336_2931089108733324906_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNMuwaqAwD0Q7kNvgEh35QE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyBpqfMSKPcO4wWxzb3bdC-jS64nq0ukRxO6ec6TITow&oe=671E31D0"}, {"file_name": "ApplicationFrameHost_MVPsgttq8J.png", "id": "1279758249849202", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572929_1279758253182535_1861169253656048050_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PoPMEeJUL2oQ7kNvgFeJKa2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkLt62q8c49TcCrQDfnkS26uEWOMrXmNexT0wpA1ediQ&oe=671E2657"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1_2560x1440-Trailor_\ubcf5\uc0ac\ubcf8-001.png", "id": "557343843348584", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001663_557343850015250_3946109195033621862_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qV7x9orZov4Q7kNvgEJz4_d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkfwLPCRmnEAu5EX6NQiKIBi-mHe-bH9Cx4v6wYBaBGw&oe=671E36D0"}, "display_name": "Spatial Perception Training (Cube)", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting