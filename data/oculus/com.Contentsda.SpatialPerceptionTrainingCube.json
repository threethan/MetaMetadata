ad3-1.oculuscdn.com&oh=00_AYALxB0yGfVIDwWIaPTw1ADTeTYc2vcyJQb9Rff3Sax95g&oe=67826FA7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "10.coverImage.png", "id": "960323861972159", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974763_960323865305492_1348944185261368978_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LnXWUiB0XQcQ7kNvgHSfqji&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJey5AZ9HKkmhZUoQYilU1QzDSsXlM5kcQOO7-9T2GoA&oe=6782681B"}, "display_name": "Spatial Perception Training (Cube)", "keywords": [], "long_description": "\"Dive into the realm of realistic experiments through Virtual Reality (VR). Experience the excitement of conducting actual reactions in a risk-free digital laboratory. Mix substances, observe genuine changes, and engage with lifelike molecular structures\u2014all in an immersive 3D environment. Enhance your learning by interacting with accurate representations of laboratory equipment and substances, all while honing your scientific skills. Explore the world of chemistry in an unprecedented way, where hands-on experimentation meets cutting-edge technology for an educational adventure like no other.", "short_description": "It is a cognitive game for cognitive rehabilitation training to help rehabilitate people with cognitive decline and mild cognitive impairment, and is designed to provide two or more cognitive experiences and training in the game. Cognitive Cube Game is designed to allow people with disabilities who have difficulty using controllers to play games through hand tracking."}]}, "developer_name": null, "developer_privacy_policy_url": "https://training.contentsda.kr/privacy-policy-en/", "developer_terms_of_service_url": "https://training.contentsda.kr/terms-and-conditions-en/", "publisher_name": "ContentsDa Inc", "support_website_url": null, "website_url": "https://training.contentsda.kr/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "27433