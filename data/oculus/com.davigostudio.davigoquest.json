tent-iad3-2.oculuscdn.com/v/t64.5771-25/75520119_245796898145225_2210460177510141286_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rrCY_GdRatwQ7kNvgEgGbpK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAp3MV4ih65D1-1CWIRZbszprcrSAZd42ZkjrpXXaYp1Q&oe=676AAF6C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Davigo_Quest_Landscape2.png", "id": "649494150680615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974703_649494154013948_5417440697342019613_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rg2m1e6XZOUQ7kNvgE6SqDq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCBD2c8-z4o-Gq4xAgAvOHYGPtj5tRVMhTsVpMj8d91g&oe=676A9FB9"}, "display_name": "DAVIGO", "keywords": [], "long_description": "DAVIGO is a VR vs. PC physics-based battle game. Become the GIANT and battle tiny KNIGHTS online in a variety of maps and game modes.\n\nDAVIGO requires an internet connection and must be played with at least one other person who joins your game on PC. Your opponents can fight you as a KNIGHT on PC by downloading the free DAVIGO KNIGHT'S PASS at davigogame.com/knightspass.\n\nYou are the boss. Unleash devastating power on the puny KNIGHTS with physics-driven, full-body gameplay. Pound the ground, rip trees and stones from the earth, and throw everything you can to leave no KNIGHT standing.\n\nBattle in 7 official maps that will take you from the hellish sacrificial pit of ALTAR to the desolate, snowy peak of SUMMIT. Download custom maps created by other players to continue the fight.\n\nFace off in one of four game modes. BRAWL is DAVIGO's flagship fight to the death, while TOWER and CAPTURE spice up the battle with secondary objectives. CLASSIC recreates the DAVIGO Alpha experience and will challenge you with a limited arsenal.\n\nFeatures\n- Cross-reality combat with 1 VR player and 1-4 PC players\n- Physics-driven full-body gameplay\n- 7 maps and 4 game modes to compete in\n- mod.io support to download custom maps created with the DAVIGO Map Editor\n- Free KNIGHT'S PASS for PC players to battle you online", "short_description": "DAVIGO is a VR vs. PC physics-based battle game. Become the GIANT and face off against tiny KNIGHTS in online matches. Connect with up to four PC players and show them who's boss! KNIGHTS play for free with DAVIGO KNIGHT'S PASS on PC."}]}, "developer_name": "Davigo Studio", "developer_privacy_policy_url": "https://docs.google.com/document/d/1lz5gOT9B9w4PQX0CZczJ4YTJlEOKXVPhlRV80ElKT3Y/edit?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "Davigo Studio", "support_website_url": null, "website_url": "https://www.davigogame.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7837719749675799"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031574_1366392287620467_3730322496501733613_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U6QN4v5omEoQ7kNvgFX-gsf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrcdYMXZkZv4Yrhgcf1-6pP-i9VorHie4f403o-FmNOg&oe=676A9D8A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DAVIGO", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1701280800, "lastRevision": 