771-25/57566698_628875282549563_4913645439909033743_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y5d8o2kTOHUQ7kNvgF5M-Sl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6m3lt2O5GlrTgcSlHtjI2yxyq0jPWeORJ8tdljmpCKw&oe=6703D5DB"}, {"file_name": "3.png", "id": "3187958854840290", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974513_3187958858173623_2630061441027911886_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jUASSLlh6sQQ7kNvgEcTBJm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCi8lm7svYrigZZGsXW0NPAm1LjXFjd56tpM5G8YfdqVg&oe=6703B4CF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (4).png", "id": "941214970482404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031643_941214973815737_2432176783600565336_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HSV2Uakrp3YQ7kNvgHRUx7S&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBgee3dvJ6jTYF5oAncHEcgSdHJyqCHr4smaQKaHNtwPw&oe=6703B3B2"}, "display_name": "Wingit", "keywords": [], "long_description": "Unleash Your Inner Bird in Aerial Dogfights and Races.\n\nEver dreamed of soaring through the skies as a majestic bird, engaging in thrilling air-to-air challenges, or participating in high-speed tag races?\n\nWe\u2019ve been developing a unique bird flapping and gliding mechanic that brings this experience to life in our upcoming multiplayer game, currently dubbed \u201cWingit\u201d.\n\nWe\u2019ve created a basic block-out map and implemented an infection game mode for testing purposes. However, we\u2019re eager to explore more game modes and perfect the overall experience.\n\nDepending on how you choose to fly, this game can be quite a lot of exercise :)\n\nWatch the attached video for a glimpse into the heart-pounding action and join our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN", "short_description": "Flap, glide, swoop, dip and flap to soar like a bird. Hang out with your friends or play a game of Tag, Hunt or make it up as you go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/terms-of-use", "publisher_name": "Remio", "support_website_url": null, "website_url": "https://remiovr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "26492902133657108"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982565_1471268383645088_2435847090510333944_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ay7ODgDvxtcQ7kNvgHbdr51&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvfBxduQ3Kd9qwA_yuzBiC6M2OJ2iNz8KoSfE6Yl4WyQ&oe=6703C1B3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wingit", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Flying", "id": "388572352490011"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1684527560, "lastRevision": {"nodes": [{"id": "9470601172980470", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "9470601146313806", "is_first_party": false, "enables_in_app_ads"