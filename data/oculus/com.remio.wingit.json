(447).png", "id": "628875279216230", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566698_628875282549563_4913645439909033743_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dzyf2M0zsxUQ7kNvgFiWddX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCoPJau_RJ7SL8BM5ZNxgSjL80bN-8hBjXeUIj25NA-qA&oe=671F855B"}, {"file_name": "3.png", "id": "3187958854840290", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974513_3187958858173623_2630061441027911886_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2-NOvbDGhxkQ7kNvgHGZFaX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDO0V2Twqvg313ywU8Eiq3nLvsSUctdZYfs6e9lS6Sbkw&oe=671F644F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (4).png", "id": "941214970482404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031643_941214973815737_2432176783600565336_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MHKcqjMeJogQ7kNvgFMAneE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkn1vBeDKnW0ONrK3wEQbb6fZYYq0VHHm7-I2f6RAS5g&oe=671F6332"}, "display_name": "Wingit", "keywords": [], "long_description": "Unleash Your Inner Bird in Aerial Dogfights and Races.\n\nEver dreamed of soaring through the skies as a majestic bird, engaging in thrilling air-to-air challenges, or participating in high-speed tag races?\n\nWe\u2019ve been developing a unique bird flapping and gliding mechanic that brings this experience to life in our upcoming multiplayer game, currently dubbed \u201cWingit\u201d.\n\nWe\u2019ve created a basic block-out map and implemented an infection game mode for testing purposes. However, we\u2019re eager to explore more game modes and perfect the overall experience.\n\nDepending on how you choose to fly, this game can be quite a lot of exercise :)\n\nWatch the attached video for a glimpse into the heart-pounding action and join our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN", "short_description": "Flap, glide, swoop, dip and flap to soar like a bird. Hang out with your friends or play a game of Tag, Hunt or make it up as you go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/terms-of-use", "publisher_name": "Remio", "support_website_url": null, "website_url": "https://remiovr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "26492902133657108"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982565_1471268383645088_2435847090510333944_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=msaxxXdEotkQ7kNvgEJwSop&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBcI73LfU8FaElsTz1FJi_vKphJ7vmKQAEKCJTWfJJ-bg&oe=671F7133"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wingit", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}, {"topic_name": "Hangout", "id": "1023770785722696"}], "release_date": 1684527560, "lastRevision": {"nodes": [{"id": "9470601172980470", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "9470601146313