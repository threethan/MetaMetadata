SHCM9vDgT0nm9PK5M-cOicBhJnYw&oe=6760165B"}, {"file_name": "3.png", "id": "1178829089457402", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39035408_1178829092790735_4177157206921738101_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y5j9swqwbaoQ7kNvgGLZOuD&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCBRIdLbIl_6NiTSvyYs-ZqtRN88IG4tclNmO7U_z6BXg&oe=67602B9F"}, {"file_name": "5.png", "id": "191014460539420", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75221326_191014463872753_8085014165971567389_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xoMt3sw2q5UQ7kNvgG-t9AG&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDup3seUqh5UuDGdFqEO9wPhRewrHsFrrZiON7GWDGMWQ&oe=67600285"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "YT cover.png", "id": "795036341841578", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/75221326_795036345174911_8871026441229388364_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UUtHXN5nra8Q7kNvgH603kr&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYAXkH8OoUdDiGW0vnHe_v1hgv9xNXLW_wZsN4y_WO2zTg&oe=676016C4"}, "display_name": "Wingit", "keywords": [], "long_description": "Unleash Your Inner Bird in Aerial Dogfights and Races.\n\nEver dreamed of soaring through the skies as a majestic bird, engaging in thrilling air-to-air challenges, or participating in high-speed tag races?\n\nWe\u2019ve been developing a unique bird flapping and gliding mechanic that brings this experience to life in our upcoming multiplayer game, currently dubbed \u201cWingit\u201d.\n\nWe\u2019ve created a basic block-out map and implemented an infection game mode for testing purposes. However, we\u2019re eager to explore more game modes and perfect the overall experience.\n\nDepending on how you choose to fly, this game can be quite a lot of exercise :)\n\nWatch the attached video for a glimpse into the heart-pounding action and join our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN", "short_description": "Flap, glide, swoop, dip and flap to soar like a bird. Hang out with your friends or play a game of Tag, Hunt or make it up as you go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/terms-of-use", "publisher_name": "Remio", "support_website_url": null, "website_url": "https://remiovr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "604415144974293"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1629304740912580"}]}, "baseline_offer": {"id": "1629304740912580"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1684527560, "status": "PUBLISHED", "id": "1629304740912580"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28002285962718710", "version": "2.134"}, "id": "1169779027757091", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "9470601146313806", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "28002285962718710"}, "release_status": "RELEASED"}, "binary_release_channels": {"nod