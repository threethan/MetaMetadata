ftDYyAqvA_gdFur-U9rBbt2iDInTA&oe=6756DBDB"}, {"file_name": "3.png", "id": "1178829089457402", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035408_1178829092790735_4177157206921738101_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CsPM-brib1YQ7kNvgFHsrkz&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDRAU3X-OMQFgwt61iNIBlmS_x-njyudbUQn8uImai-0g&oe=6756F11F"}, {"file_name": "5.png", "id": "191014460539420", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75221326_191014463872753_8085014165971567389_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AWiUiEka_8gQ7kNvgEg0CYl&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBitDp8kpdpp1vN9gFNEitksgDhRrFGoW_q6HFN7D_jjw&oe=6756C805"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "YT cover.png", "id": "795036341841578", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75221326_795036345174911_8871026441229388364_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RQK1iva0D4QQ7kNvgE6Pp-7&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDCMyUZx6cwjt_RsONNCWtsWY5gpOddswRR-gu27Flb9Q&oe=6756DC44"}, "display_name": "Wingit", "keywords": [], "long_description": "Unleash Your Inner Bird in Aerial Dogfights and Races.\n\nEver dreamed of soaring through the skies as a majestic bird, engaging in thrilling air-to-air challenges, or participating in high-speed tag races?\n\nWe\u2019ve been developing a unique bird flapping and gliding mechanic that brings this experience to life in our upcoming multiplayer game, currently dubbed \u201cWingit\u201d.\n\nWe\u2019ve created a basic block-out map and implemented an infection game mode for testing purposes. However, we\u2019re eager to explore more game modes and perfect the overall experience.\n\nDepending on how you choose to fly, this game can be quite a lot of exercise :)\n\nWatch the attached video for a glimpse into the heart-pounding action and join our Discord to see where we take it next -- https://discord.com/i