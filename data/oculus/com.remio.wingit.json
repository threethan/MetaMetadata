ion and join our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN", "short_description": "Flap, glide, swoop, dip and flap to soar like a bird. Hang out with your friends or play a game of Tag, Hunt or make it up as you go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/terms-of-use", "publisher_name": "Remio", "support_website_url": null, "website_url": "https://remiovr.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "388572352490011"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "26492902133657108"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982565_1471268383645088_2435847090510333944_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DXYx_PPhUWUQ7kNvgFD0I82&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5CCAsVhK_0oIUmqDn0jUGT&oh=00_AYBCs8l_Smd1e1jy1MFy_F_8zqPrlj475mKFpMD2PnmqMA&oe=66DED7B3"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Wingit", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Flying", "id": "388572352490011"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 16845