cdn.com&oh=00_AYD5ZOBWlHLFtbiAOgGqz1ywD9v4BU_K5-5Uo-sybSEO8A&oe=66FD3E5B"}, {"file_name": "3.png", "id": "3187958854840290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974513_3187958858173623_2630061441027911886_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LggS_kmb5UoQ7kNvgF3h7l_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDBqMJStekL6EZ0R5vwyetss0o0p4W2tCBEcYvATrLyFw&oe=66FD1D4F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Untitled design (4).png", "id": "941214970482404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031643_941214973815737_2432176783600565336_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x6Hnc3wUhnQQ7kNvgGiL2e_&_nc_ht=scontent.oculuscdn.com&oh=00_AYB6rjMJueJFjEzkyWdTVr6GccD4z1u6E6TpR-ycuvxsxQ&oe=66FD1C32"}, "display_name": "Wingit", "keywords": [], "long_description": "Unleash Your Inner Bird in Aerial Dogfights and Races.\n\nEver dreamed of soaring through the skies as a majestic bird, engaging in thrilling air-to-air challenges, or participating in high-speed tag races?\n\nWe\u2019ve been developing a unique bird flapping and gliding mechanic that brings this experience to life in our upcoming multiplayer game, currently dubbed \u201cWingit\u201d.\n\nWe\u2019ve created a basic block-out map and implemented an infection game mode for testing purposes. However, we\u2019re eager to explore more game modes and perfect the overall experience.\n\nDepending on how you choose to fly, this game can be quite a lot of exercise :)\n\nWatch the attached video for a glimpse into the heart-pounding action and join our Discord to see where we take it next -- https://discord.com/invite/YrZwpCANQN", "short_description": "Flap, glide, swoop, dip and flap to soar like a bird. Hang out with your friends or play a game of Tag, Hunt or make it up as you go."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.remiovr.com/privacy-policy", "developer_terms_of_service_url": "https://www.remiovr.com/terms-o