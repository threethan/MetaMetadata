uVZyLZ039cnJiv6HQ&oe=6713AA19"}, {"file_name": "PGVR_PDP Art_Hero Art_3000x900_V3.png", "id": "401435552647803", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974579_401435555981136_8586953570072082474_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tBxsqmSvD0YQ7kNvgGTUBnr&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5ewHU39Qbx9A722GSIVy6HgSh1VEHZ5XV_E4k68FBFw&oe=671385CF"}, {"file_name": "PGVR_Cover Art_Landscape_2560x1440_V2.png", "id": "371582902215938", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982441_371582905549271_8695301135169567714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=knqNAteKWFIQ7kNvgFwgOSy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC3uQQIqW2HWe_dSi7LB27wDMzHbpQpwX9REFDfDZ7KeQ&oe=6713A4AE"}]}, "id": "756088459572302", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "380805198180213", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982616_380805201513546_3929713453765025453_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gy67G7fTXyoQ7kNvgF1ykwj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMcdAZLT5eHC8IqyLkQqlawOnuZp5fwge8StZX33SOcw&oe=671382FA"}, {"file_name": "2.png", "id": "285246717932861", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86627654_285246721266194_2575969446918668996_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nSK18aIQj5IQ7kNvgFiV_3h&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjbmbHBozW-XzFTEH6pnw9PD5y-tJcbq7sGj8WsD87CA&oe=67138B8C"}, {"file_name": "3.png", "id": "436292478867404", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982603_436292482200737_3040556094683052284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MnouyE2tvxcQ7kNvgF9POnk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBaHHpUBVnPCCgl0Xk5pntvbcIgHmB8bZG5sRR1rRAusw&oe=67139167"}, {"file_name": "4.png", "id": "1527536304642649", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031429_1527536307975982_8067806095485934547_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OioJo76mk9sQ7kNvgF_pcMU&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDj3RNvVqdovbetv89XTGu4mS8ZPnekCz7dAeyAh67ckw&oe=671384C4"}, {"file_name": "5.png", "id": "368211236050734", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230049_368211239384067_4433699725196166729_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=odBPY4d9reEQ7kNvgEKM71R&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA8b5IdDUiF-nOvILX7y0ZG8uc_ykRJ3v9HlvvJEVOKuQ&oe=67139A15"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PGVR_Trailer Cover Image_2560x1440.png", "id": "889830889410023", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974794_889830892743356_5440725574582926712_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3VHpBCGfPBkQ7kNvgFBJreC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYChYALnqMSnqlXqoPYLJRGasBJ74OkG-Lodn9HbesPwgQ&oe=67139246"}, "display_name": "Programmer VR", "keywords": ["ProgrammingInVR", "VirtualRealityProgramming", "VRProgramming", "LearnProgrammingInVR", "SolvePuzzlesInVR"], "long_description": "Want to learn programming and develop problem-solving skills in a fun way?\n\nSet off on an exciting journey with \"Programmer VR,\" a first-of-a-kind VR game on the Meta Store.\n\nYour mission? Help Bob navigate a virtual world, overcome obstacles and improve intelligence level.\n\nWith each challenge you conquer, you\u2019ll learn programming concepts like Instructions execution order, conditional statements, loops, arrays and much more. Boost your problem-solving skills and logical thinking - all while you play a fun game.\n\nBrought to you by the creators of iB Cricket, one of the highest-rated VR games.\n\nNo prior programming knowledge is required.\n\nKey Features:\n\nCampaign Mode: 75 puzzles across 3 difficulty levels. Challenge yourself!\n\nMultiplayer Mode:  Race against an opponent in PvP battles or collaborate with a friend to master challenges.\nEnhanced with voice chat and personalized Meta avatars, you can truly connect with players.\n\nDaily Challenges: Complete a new challenge everyday and top the global leaderboard.\n\nAchievements: Celebrate your learning accomplishments, track your leaderboard standings.\n\nLevel up your experience\u2026\n\nMR Mode: With the power of Mixed Reality, Set your puzzle anywhere in your room and move freely in the real world to get an excellent view.\n\nHand Tracking: Interact seamlessly with the virtual world using your hands, making your experience even more lifelike.\n\nProgrammer VR is your ticket to programming fun. Get started now and unlock your potential!", "short_description": "A first-of-a-kind fun game on the Meta Store to help you learn programming & develop problem-solving skills. \n\nYour mission? Help Bob navigate a virtual world, overcome obstacles & improve intelligence level. \n\nWith each puzzle, learn programming concepts like Instructions execution order, conditional statements, loops -- all while you play a fun game. \n\nWith exciting features like Multiplayer Mode, Daily Challenges, enhanced with MR Mode and Hand Tracking, learning is now a thrilling adventure!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": "https://proyuga.tech/programmer-vr-eula/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/ProgrammerVR_Support", "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVE