at=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zBXk9fP-0SYQ7kNvgGQe5xd&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCyItpQxu1xPHolJ6-I-t4LsSrfaJIE8rFoheuWsAoOgQ&oe=67122E61"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PVR_Cover Landscape - 2560x1440.png", "id": "429997232540328", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75361360_429997235873661_5804819608709080672_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qu5c50up22gQ7kNvgGXVjrJ&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDfUs95C0sA63IuURhGoFX8hEb7obYD3r1mDvO2dRbzSQ&oe=671239C8"}, "display_name": "Programmer VR", "keywords": [], "long_description": "Want to learn programming in a fun way? \n\nLook no further than Programmer VR\n\nHelp Bob collect rewards by overcoming obstacles in 3 breathtaking virtual worlds.  Learn programming concepts, sharpen your logical thinking and develop problem-solving skills in an easy, fun, immersive, and enjoyable way. This game is brought to you by the developers of iB Cricket, one of the highest-rated VR games.\n\nKey features:\n- 50 levels of programming fun\n- 3 enchanting virtual worlds -  Pond, Futuristic Neon City, and Neon Pyramid\n- No previous programming knowledge is required\n- Sharpen your logical thinking skills and improve your critical thinking skills\n- Learn programming concepts like Instruction execution order,  Conditional Statements, and Loops.\n- Co-op Mode\n", "short_description": "Help Bob collect rewards by overcoming obstacles in 3 breathtaking virtual worlds. As you help Bob progress through 50 levels, you\u2019ll learn programming concepts, sharpen your logical thinking and develop problem-solving skills in an easy, fun, immersive, and enjoyable way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": null, "website_url": "https://proy