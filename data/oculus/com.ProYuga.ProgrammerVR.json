&oh=00_AYDregdHjUSlDniUDOGpoqoQ7uSmkaQnlpxmFGj14aglHQ&oe=66EC0467"}, {"file_name": "4.png", "id": "1527536304642649", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031429_1527536307975982_8067806095485934547_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QSPYcYmqm5kQ7kNvgE8SF3c&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMscCQsIYTUDtKgH35avvO&oh=00_AYDM_xAX2-xYjua4eI3eU7hGfRGauKBcEFXOSy6FqKXRew&oe=66EBF7C4"}, {"file_name": "5.png", "id": "368211236050734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230049_368211239384067_4433699725196166729_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XcDfsGBaGGYQ7kNvgEEtr3i&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMscCQsIYTUDtKgH35avvO&oh=00_AYAcuyAmU66EkHC6ny-JoN1mEBLYu2CYeBS1g7FWbm1Cog&oe=66EC0D15"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PGVR_Trailer Cover Image_2560x1440.png", "id": "889830889410023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_889830892743356_5440725574582926712_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fg0SrAXWsckQ7kNvgHxPv1g&_nc_ht=scontent.oculuscdn.com&_nc_gid=ADMscCQsIYTUDtKgH35avvO&oh=00_AYCxzidA6ak8YsKDGZWReBJS9p9V4JLbjBOtDyT432uNNQ&oe=66EC0546"}, "display_name": "Programmer VR", "keywords": ["ProgrammingInVR", "VirtualRealityProgramming", "VRProgramming", "LearnProgrammingInVR", "SolvePuzzlesInVR"], "long_description": "Want to learn programming and develop problem-solving skills in a fun way?\n\nSet off on an exciting journey with \"Programmer VR,\" a first-of-a-kind VR game on the Meta Store.\n\nYour mission? Help Bob navigate a virtual world, overcome obstacles and improve intelligence level.\n\nWith each challenge you conquer, you\u2019ll learn programming concepts like Instructions execution order, conditional statements, loops, arrays and much more. Boost your problem-solving skills and logical thinking - all while you play a fun game.\n\nBrought to you by the creators of iB Cricket, one of the highest-rated VR games.\n\nNo prior programming knowledge is required.\n\nKey Features:\n\nCampaign Mode: 75 puzzles across 3 difficulty levels. Challenge yourself!\n\nMultiplayer Mode:  Race against an opponent in PvP battles or collaborate with a friend to master challenges.\nEnhanced with voice chat and personalized Meta avatars, you can truly connect with players.\n\nDaily Challenges: Complete a new challenge everyday and top the global leaderboard.\n\nAchievements: Celebrate your learning accomplishments, track your leaderboard standings.\n\nLevel up your experience\u2026\n\nMR Mode: With the power of Mixed Reality, Set your puzzle anywhere in your room and move freely in the real world to get an excellent view.\n\nHand Tracking: Interact seamlessly with the virtual world using your hands, making your experience even more lifelike.\n\nProgrammer VR is your ticket to programming fun. Get started now and unlock your potential!", "short_description": "A first-of-a-kind fun game on the Meta Store to help you learn programming & develop problem-solving skills. \n\nYour mission? Help Bob navigate a virtual world, overcome obstacles & improve intelligence level. \n\nWith each puzzle, learn programming concepts like Instructions execution order, conditional statements, loops -- all while you play a fun game. \n\nWith exciting features like Multiplayer Mode, Daily Challenges, enhanced with MR Mode and Hand Tracking, learning is now a thrilling adventure!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": "https://proyuga.tech/programmer-vr-eula/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/ProgrammerVR_Support", "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "8794739959230