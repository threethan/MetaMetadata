ng virtual worlds. As you help Bob progress through 50 levels, you\u2019ll learn programming concepts, sharpen your logical thinking and develop problem-solving skills in an easy, fun, immersive, and enjoyable way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": null, "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "CO_OP"], "id": "1275623976377558"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1035682837997293"}, {"status": "CANCELLED", "id": "1695388824546938"}, {"status": "PUBLISHED", "id": "1198288288102376"}, {"status": "CANCELLED", "id": "970963277602459"}, {"status": "PUBLISHED", "id": "349666894158081"}]}, "baseline_offer": {"id": "349666894158081"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "1035682837997293"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7419240601509462", "version": "2.10.0"}, "id": "514331816794309", "channel_name": "LIVE"}]}, "is_for_o