o Art_3000x900_V3.png", "id": "401435552647803", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974579_401435555981136_8586953570072082474_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v_61KZ3HqZoQ7kNvgElyrp0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDEfLU0qD_n3cUC2kG6XIXFR_jTuntJWs1wOKVKr54HYw&oe=66D58F4F"}, {"file_name": "PGVR_Cover Art_Landscape_2560x1440_V2.png", "id": "371582902215938", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_371582905549271_8695301135169567714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7rwvA1ECtMkQ7kNvgGp2HA5&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvZcCZQy2z0xnhHJ6o0g4lPTsqHebzlv7QHUAPtWQfeg&oe=66D5AE2E"}]}, "id": "756088459572302", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "380805198180213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982616_380805201513546_3929713453765025453_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NZamT9bAUTwQ7kNvgEUFG0q&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlQU4iVF7cul3pgQyIsm61GeQoQ48oO4mMGLsEnjUO6Q&oe=66D58C7A"}, {"file_name": "2.png", "id": "285246717932861", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627654_285246721266194_2575969446918668996_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rtzlTpe8Y7MQ7kNvgEoyz-a&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3TaZGDmN6htn-eSyY9BOfhHfgj1rttHcajBx7vLMKSA&oe=66D5950C"}, {"file_name": "3.png", "id": "436292478867404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982603_436292482200737_3040556094683052284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rZkHq6a9HlYQ7kNvgEu9nev&_nc_ht=scontent.oculuscdn.com&oh=00_AYAdyR-BfWTc_77V-FR4bhX53yqQRIB3-9NrWyjE6OLzRQ&oe=66D59AE7"}, {"file_name": "4.png", "id": "1527536304642649", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031429_1527536307975982_8067806095485934547_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yP9RV_ecFHcQ7kNvgFh4lHY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCe1vJQKmlEYwaUDfWLA45GTZ9X9r0NPIKBnDUZ0FXsyQ&oe=66D58E44"}, {"file_name": "5.png", "id": "368211236050734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230049_368211239384067_4433699725196166729_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1lzbjjYMCqsQ7kNvgEcCjXK&_nc_ht=scontent.oculuscdn.com&oh=00_AYDIX4qM0A38Dj2Vl_KJSPbfY7WOhBSKyV-CRs_dcLWZfA&oe=66D5A395"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PGVR_Trailer Cover Image_2560x1440.png", "id": "889830889410023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_889830892743356_5440725574582926712_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1QK6rvw_UQoQ7kNvgFwTNPE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZhnmleEEbLKmORfK89uqS-s38AER11DHwh7w-aUywoQ&oe=66D59BC6"}, "display_name": "Programmer VR", "keywords": ["ProgrammingInVR", "VirtualRealityProgramming", "VRProgramming", "LearnProgrammingInVR", "SolvePuzzlesInVR"], "long_description": "Want to learn programming and develop problem-solving skills in a fun way?\n\nSet off on an exciting journey with \"Programmer VR,\" a first-of-a-kind VR game on the Meta Store.\n\nYour mission? Help Bob navigate a virtual world, overcome obstacles and improve intelligence level.\n\nWith each challenge you conquer, you\u2019ll learn programming concepts like Instructions execution order, conditional statements, loops, arrays and much more. Boost your problem-solving skills and logical thinking - all while you play a fun game.\n\nBrought to you by the creators of iB Cricket, one of the highest-rated VR games.\n\nNo prior programming knowledge is required.\n\nKey Features:\n\nCampaign Mode: 75 puzzles across 3 difficulty levels. Challenge yourself!\n\nMultiplayer Mode:  Race against an opponent in PvP battles or collaborate with a friend to master challenges.\nEnhanced with voice chat and personalized Meta avatars, you can truly connect with players.\n\nDaily Challenges: Complete a new challenge everyday and top the global leaderboard.\n\nAchievements: Celebrate your learning accomplishments, track your leaderboard standings.\n\nLevel up your experience\u2026\n\nMR Mode: With the power of Mixed Reality, Set your puzzle anywhere in your room and move freely in the real world to get an excellent view.\n\nHand Tracking: Interact seamlessly with the virtual world using your hands, making your experience even more lifelike.\n\nProgrammer VR is your ticket to programming fun. Get started now and unlock your potential!", "short_description": "A first-of-a-kind fun game on the Meta Store to help you learn programming & develop problem-solving skills. \n\nYour mission? Help Bob navigate a virtual world, overcome obstacles & improve intelligence level. \n\nWith each puzzle, learn programming concepts like Instructions execution order, conditional statements, loops -- all while you play a fun game. \n\nWith exciting features like Multiplayer Mode, Daily Challenges, enhanced with MR Mode and Hand Tracking, learning is now a thrilling adventure!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": "https://proyuga.tech/programmer-vr-eula/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/ProgrammerVR_Support", "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOU