o Art_3000x900_V3.png", "id": "401435552647803", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974579_401435555981136_8586953570072082474_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ioh01By5lKIQ7kNvgGxUT6S&_nc_ht=scontent.oculuscdn.com&oh=00_AYAO5OFr3jp1E3Fp3s0WlPFjYV145sLwLN8N-0J48ASnxw&oe=66D983CF"}, {"file_name": "PGVR_Cover Art_Landscape_2560x1440_V2.png", "id": "371582902215938", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982441_371582905549271_8695301135169567714_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=swMmjBZuGUoQ7kNvgGUuw1R&_nc_ht=scontent.oculuscdn.com&oh=00_AYDo5r3Iar1NceLJLAYrLumTa1z6QSNzrIu_rjpAIZDydg&oe=66D9A2AE"}]}, "id": "756088459572302", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "380805198180213", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982616_380805201513546_3929713453765025453_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=40aBwh0RKTIQ7kNvgFkKU2A&_nc_ht=scontent.oculuscdn.com&oh=00_AYBEk8vHEeZ8Gj_oeTlQMdV01sx8JoAvhW2iX34W2SYszg&oe=66D980FA"}, {"file_name": "2.png", "id": "285246717932861", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627654_285246721266194_2575969446918668996_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w254ev4auZQQ7kNvgHiNmIX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDtmyx-_2ew4mk6gUNrdlCM2Vy_2MAOPs3m4W-9olchoA&oe=66D9898C"}, {"file_name": "3.png", "id": "436292478867404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982603_436292482200737_3040556094683052284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YNNoEOao0PwQ7kNvgHmP-V3&_nc_ht=scontent.oculuscdn.com&oh=00_AYB6AzymerOvtpm1w6634PGUcRXp6VqM4vQmOLfKvNNsEg&oe=66D98F67"}, {"file_name": "4.png", "id": "1527536304642649", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031429_1527536307975982_8067806095485934547_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O5MO4qKxv3MQ7kNvgHjoHyd&_nc_ht=scontent.oculuscdn.com&oh=00_AYAH1Ye7wNA2SSL74fhSQj4IF4g0Bt_szAN4sMYRBXu7yw&oe=66D982C4"}, {"file_name": "5.png", "id": "368211236050734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230049_368211239384067_4433699725196166729_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nB0ruxcPBecQ7kNvgFWRE5b&_nc_ht=scontent.oculuscdn.com&oh=00_AYAJtfA9m773EdcazDanpxlDtB59_lrEgRAGTFr79j4CrQ&oe=66D99815"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "PGVR_Trailer Cover Image_2560x1440.png", "id": "889830889410023", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_889830892743356_5440725574582926712_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8CAhzj3VplwQ7kNvgGQV02A&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvmUy4VXgCkkTFWVdDWnVKJgzYnmHHclT0RXq2eUnTig&oe=66D99046"}, "display_name": "Programmer VR", "keywords": ["ProgrammingInVR", "VirtualRealityProgramming", "VRProgramming", "LearnProgrammingInVR", "SolvePuzzlesInVR"], "long_description": "Want to learn programming and develop problem-solving skills in a fun way?\n\nSet off on an exciting journey with \"Programmer VR,\" a first-of-a-kind VR game on the Meta Store.\n\nYour mission? Help Bob navigate a virtual world, overcome obstacles and improve intelligence level.\n\nWith each challenge you conquer, you\u2019ll learn programming concepts like Instructions execution order, conditional statements, loops, arrays and much more. Boost your problem-solving skills and logical thinking - all while you play a fun game.\n\nBrought to you by the creators of iB Cricket, one of the highest-rated VR games.\n\nNo prior programming knowledge is required.\n\nKey Features:\n\nCampaign Mode: 75 puzzles across 3 difficulty levels. Challenge yourself!\n\nMultiplayer Mode:  Race against an opponent in PvP battles or collaborate with a friend to master challenges.\nEnhanced with voice chat and personalized Meta avatars, you can truly connect with players.\n\nDaily Challenges: Complete a new challenge everyday and top the global leaderboard.\n\nAchievements: Celebrate your learning accomplishments, track your leaderboard standings.\n\nLevel up your experience\u2026\n\nMR Mode: With the power of Mixed Reality, Set your puzzle anywhere in your room and move freely in the real world to get an excellent view.\n\nHand Tracking: Interact seamlessly with the virtual world using your hands, making your experience even more lifelike.\n\nProgrammer VR is your ticket to programming fun. Get started now and unlock your potential!", "short_description": "A first-of-a-kind fun game on the Meta Store to help you learn programming & develop problem-solving skills. \n\nYour mission? Help Bob navigate a virtual world, overcome obstacles & improve intelligence level. \n\nWith each puzzle, learn programming concepts like Instructions execution order, conditional statements, loops -- all while you play a fun game. \n\nWith exciting features like Multiplayer Mode, Daily Challenges, enhanced with MR Mode and Hand Tracking, learning is now a thrilling adventure!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": "https://proyuga.tech/programmer-vr-eula/", "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": "https://bit.ly/ProgrammerVR_Support", "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOU