235873661_5804819608709080672_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aBdDXRtvcMUQ7kNvgEk3sEN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTXy33L6U26ywoBbcgSV4WyUZdc-MQubGP41rjxcc0Yw&oe=66F68A48"}, "display_name": "Programmer VR", "keywords": [], "long_description": "Want to learn programming in a fun way? \n\nLook no further than Programmer VR\n\nHelp Bob collect rewards by overcoming obstacles in 3 breathtaking virtual worlds.  Learn programming concepts, sharpen your logical thinking and develop problem-solving skills in an easy, fun, immersive, and enjoyable way. This game is brought to you by the developers of iB Cricket, one of the highest-rated VR games.\n\nKey features:\n- 50 levels of programming fun\n- 3 enchanting virtual worlds -  Pond, Futuristic Neon City, and Neon Pyramid\n- No previous programming knowledge is required\n- Sharpen your logical thinking skills and improve your critical thinking skills\n- Learn programming concepts like Instruction execution order,  Conditional Statements, and Loops.\n- Co-op Mode\n", "short_description": "Help Bob collect rewards by overcoming obstacles in 3 breathtaking virtual worlds. As you help Bob progress through 50 levels, you\u2019ll learn programming concepts, sharpen your logical thinking and develop problem-solving skills in an easy, fun, immersive, and enjoyable way."}]}, "developer_name": null, "developer_privacy_policy_url": "https://proyuga.tech/programmer-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ProYuga Advanced Technologies Limited", "support_website_url": null, "website_url": "https://proyuga.tech/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "879473995923081"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PUZZLE", "STRATEGY"], "has_in_app_ads": fal