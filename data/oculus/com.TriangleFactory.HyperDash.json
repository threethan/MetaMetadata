uR1IPnUjXi-X9ksA&oe=67472133"}, {"file_name": "Screenshot01.png", "id": "212968357216442", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974593_212968360549775_8534305649088085796_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylr8Dc9TspQQ7kNvgEailfg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBY1Vui7wlY3H1tmTafeFgsVfREzOndS1jDCIM9ONxzJw&oe=6747046D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BannerOculus_2560x1440_Halloween.png", "id": "1071551511196730", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035438_1071551514530063_403088320425317847_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6PZnxuyiQPMQ7kNvgFDADbN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDaF758JXUbUmHnFBu62JtL7CBD0vYIlZ8zMNtTZo5YBg&oe=67471486"}, "display_name": "Hyper Dash", "keywords": ["fps", "shooter", "hyperdash", "robots", "multiplayer"], "long_description": "Hyper Dash is a free-to-play VR multiplayer team-based shooter that lets you dive into fast-paced action across a variety of maps and game modes! \n\n## GAME MODES GALORE\nA multitude of game modes await your victory! Choose between Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination, and Ball. You can remix all these modes with Mutators too. \n\n## MOVEMENT IS KEY\nDash, sprint, and rail grind your way across the arenas to engage the enemy in fast-paced combat and secure the objective for your team to bring the win home.\n\n## ADDITIONAL FEATURES\nTake advantage of features like offline mode/bots, dedicated servers, private servers, rebindable controls, left-hand support, voice chat, and more!", "short_description": "Hyper Dash is a free VR multiplayer team based shooter. Make smart use of Dashing, Sprinting, Walking and Rail Grinding to get around the arenas and win in a variety of gamemodes like; Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination & Ball. Remix them with Mutators too! "}]}