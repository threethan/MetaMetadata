/t64.5771-25/38974593_212968360549775_8534305649088085796_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0FUW8IPb5E0Q7kNvgF5bHEm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2XKUwbe3V4t0IN9RzX-PaO_qgvWbcSWXKg8I5W6ePfA&oe=6705196D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover_2560x1440.png", "id": "162026732390478", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974518_162026735723811_4416925458547619227_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5QLMFTvKqSEQ7kNvgFWTa5n&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZjpjiB5oJKkVLT_wuk6tqt-HFqaFkb5n0XvWbvJDkLg&oe=67050504"}, "display_name": "Hyper Dash", "keywords": ["fps", "shooter", "hyperdash", "robots", "multiplayer"], "long_description": "Hyper Dash is a free-to-play VR multiplayer team-based shooter that lets you dive into fast-paced action across a variety of maps and game modes! \n\n## GAME MODES GALORE\nA multitude of game modes await your victory! Choose between Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination, and Ball. You can remix all these modes with Mutators too. \n\n## MOVEMENT IS KEY\nDash, sprint, and rail grind your way across the arenas to engage the enemy in fast-paced combat and secure the objective for your team to bring the win home.\n\n## ADDITIONAL FEATURES\nTake advantage of features like offline mode/bots, dedicated servers, private servers, rebindable controls, left-hand support, voice chat, and more!", "short_description": "Hyper Dash is a free VR multiplayer team based shooter. Make smart use of Dashing, Sprinting, Walking and Rail Grinding to get around the arenas and win in a variety of gamemodes like; Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination & Ball. Remix them with Mutators too! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://privacy.hyperdashvr.com/", "developer_terms_of_service_url": "https://www.hyperdashvr.com/terms-of-u