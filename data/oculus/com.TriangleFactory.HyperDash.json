_nc_gid=AJ444x0smtOLGnAJfMpYQBn&oh=00_AYDnrQ1eA78plvh8w9mZVID8zefUAA0PB0jAoGTQub0rYw&oe=66E16573"}, {"file_name": "Screenshot01.png", "id": "212968357216442", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974593_212968360549775_8534305649088085796_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l7iuFb7kPwoQ7kNvgHn_5dE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ444x0smtOLGnAJfMpYQBn&oh=00_AYDDOke6X6Ex3Q30-HmgIs4U1KikE7GXVksjYHF142Ij5g&oe=66E180ED"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover_2560x1440.png", "id": "162026732390478", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974518_162026735723811_4416925458547619227_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qRPBMY4Z6KQQ7kNvgHo6G7P&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ444x0smtOLGnAJfMpYQBn&oh=00_AYCh3gS4nGamwXEMIftrlwXCYTPLK-qglA4aLvvuXxqdYg&oe=66E16C84"}, "display_name": "Hyper Dash", "keywords": ["fps", "shooter", "hyperdash", "robots", "multiplayer"], "long_description": "Hyper Dash is a free-to-play VR multiplayer team-based shooter that lets you dive into fast-paced action across a variety of maps and game modes! \n\n## GAME MODES GALORE\nA multitude of game modes await your victory! Choose between Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination, and Ball. You can remix all these modes with Mutators too. \n\n## MOVEMENT IS KEY\nDash, sprint, and rail grind your way across the arenas to engage the enemy in fast-paced combat and secure the objective for your team to bring the win home.\n\n## ADDITIONAL FEATURES\nTake advantage of features like offline mode/bots, dedicated servers, private servers, rebindable controls, left-hand support, voice chat, and more!", "short_description": "Hyper Dash is a free VR multiplayer team based shooter. Make smart use of Dashing, Sprinting, Walking and Rail Grinding to get around the arenas and win in a variety of gamemodes like; Payload, Domination, Control Point, (Team) Deathmatch, Capture The Flag, Elimination & Ball. Remix them with Mutators too! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://privacy.hyperdashvr.com/", "developer_terms_of_service_url": "https://www.hyperdashvr.com/terms-of-use/", "publisher_name": "Triangle Factory", "support_website_url": null, "website_url": "https://hyperdashvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "es_AR", "ru", "ko", "pt", "es_PE", "en", "pt_BR", "it", "fr", "es", "es_PR", "zh_HK", "ja", "es_CL", "es_MX", "zh_CN", "es_CO", "nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8318489871504498"}, "review_messages": ["Approving this update for release. You are welcome to release this when you want. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404372_853960951816892_1815142792384671410_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0KZOk9zJ-DYQ7kNvgEA6Rlv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ444x0smtOLGnAJfMpYQBn&oh=00_AYAZ46YE2sH6d2C9HgynAwXKSG1p3K-QdjvaSq3lk_-PxA&oe=66E1911D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hyper Dash", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": 