_sid=6e7a0a&_nc_ohc=9mLw0qOa4mEQ7kNvgEFO1KL&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYDZMb025Wkpq60ZUBrTFRgJhDTPuMLFp2isNlcL15QO8Q&oe=671A1BA3"}, {"file_name": "certificatemachine.png", "id": "419222644501284", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031359_419222647834617_1044340319385662871_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tsdu00HOtIYQ7kNvgGiaqvv&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYBv8zOVTp_WA_h837w9ooaMKv7L94f05C2idJNG5qHe7w&oe=671A26C7"}, {"file_name": "gustav.png", "id": "1041151010314056", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38982712_1041151013647389_9208282846641755977_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jPb9Z71Dos4Q7kNvgFHjAF6&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCJ74FGFEYFxP9mayvo26OJF80XLKa54aPHFq79TriM3g&oe=671A2C31"}, {"file_name": "lawyers head-resize.png", "id": "409356922173502", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38984472_409356925506835_675175198628609171_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QlMTkXGx1U8Q7kNvgFYTYwH&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAFvKRcasK50N5yBto2RmQvjpoix8UPhxOeKv_jYccqxA&oe=671A3A6F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1568747630685050", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39031482_1568747634018383_5207621578584535018_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XuU4lLLNjxkQ7kNvgEwFdPG&_nc_zt=3&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCRsozfcUmlD5e3OB-AWIL9p1X9M_g8r5F-w0eBcGct8g&oe=671A1909"}, "display_name": "Metamorphosis", "keywords": ["bug", "meta", "puzzle", "escape", "mystery"], "long_description": "# **An Extraordinary Journey Through a Surreal World**\n\n---\n\nIf navigating daily life in 1900s Vienna isn\u2019t complicated enough for Gregor, things take a truly Kafkaesque turn one morning when he awakens to discover he\u2019s been transformed into... a **cockroach**.\n\n### Armed with only your **wit** and **strange new appendages**, embark on a mind-bending journey to unravel the mystery behind your *metamorphosis*.\n\n### \n\n### **Welcome to a World Unlike Any Other**\n\nIn this surreal world, everyday objects loom like towering giants, while dizzying heights challenge your step, and each turn begins a new adventure.\n\n\n#### What to expect:\n- **Dance** all night in a bug's nightclub  \n- **Delve** into arthropod-organized crime  \n- **Dodge** the hands of mammoth humans  \n- **Escape** the bureaucratic traps of buggy officials\n\n---\n\n**But beware**, your friend\u2019s life is hanging by a thread, and your only hope to regain human form lies deep within the heart of a mysterious **Tower**\u2014a place with its own plans for you.\n\n---\n\n### Metamorphosis is a first-person **adventure-platformer** set in a surreal, beautifully twisted world, where your newfound abilities as an insect are your only hope for redemption.\n### \nWill you **avoid the Tower** and **save your friend**? Or will you be **lost forever** in this strange, curious land?\n\n---\n\n# *Embrace the challenge. Escape the Tower. Your metamorphosis awaits.*\n", "short_description": "If navigating daily life in 1900s Vienna isn\u2019t complicated enough for Gregor, things take a Kafkaesque turn one morning when he awakens to discover he\u2019s transformed into a cockroach. Armed with only your wits and some strange new appendages, set off on an extraordinary journey to unravel the mystery of your metamorphosis. \n\nMetamorphosis is a first-person adventure set in a surreal world filled with strange and curious denizens where your newfound abilities are your only hope for redemption."}]}, "developer_name": null, "developer_privacy_policy_url": "https://blacksunproductions.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Black Sun Productions Inc.", "support_website_url": null, "website_url": "https://www.blacksunproductions.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7251689064878355"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "946320024193285"}, {"status": "PUBLISHED", "id": "512458781587156"}]}, "baseline_offer": {"id": "946320024193285"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729200301, "status": "PUBLISHED", "id": "946320024193285"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8569516319762283", "version": "1.0"}, "id": "393013043376555", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7251689061545022", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8569516319762283"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1729384194, "id": "8625866610793920", "version": "1.0", "version_code": 87, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": {"id": "8625865637460684"}, "asset_files": {"count": 1}, "debug_symbols": {"count": 0}, "__isAppBinary