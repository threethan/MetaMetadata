nCBRuhiIZuRE8qckg&oe=6735CA75"}, {"file_name": "tower guard (2560x1440).png", "id": "8485937158126419", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75348041_8485937174793084_2516280312178372418_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sy9XYx465K0Q7kNvgEdDqZl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAbisUfbucqWxhwY1KnZpOua94KzM8dkNjAlSFS2Q3zoA&oe=6735D68C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer thumbnail (2560x1440).png", "id": "1559416704673842", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982594_1559416711340508_3090645405972205296_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K-DA_KsomV4Q7kNvgH0uX01&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC5wJuviEQoO7-UoaQIdVnG3-XwBV401Vlik9jzoyFLRw&oe=6735F5C7"}, "display_name": "Metamorphosis", "keywords": ["bug", "puzzle", "escape", "mystery", "campaign"], "long_description": "# **An Extraordinary Journey Through a Surreal World**\n\n---\nEver wonder what it's like to be a bug? Become Gregor, who transforms into a tiny cockroach in a gigantic world! \n\n### Armed with only your **wit** and **strange new appendages**, embark on a mind-bending journey to unravel the mystery behind your *metamorphosis*.\n\n### \n\n### **Welcome to a World Unlike Any Other**\n\nIn this surreal first person adventure-platformer, everyday objects loom like towering giants, while dizzying heights challenge your step, and each turn begins a new adventure.\n\n\n#### What to expect:\n- **Dance** all night in a bug's nightclub  \n- **Delve** into arthropod-organized crime  \n- **Discover** hidden pathways through surreal environments\n- **Dodge** the hands of mammoth humans  \n\n---\n\n**But beware**, your friend\u2019s life is hanging by a thread, and your only hope to regain human form lies deep within the heart of a mysterious **Tower**.\n\n---\n\n### \nWill you **avoid the Tower** and **save your friend**? Or will you be **lost forever** in this strange, curious land?\n\n---\n\n# *Embrace the challenge. Escape the Tower. Your metamorphosis awaits.*\n", "short_description": "Ever wonder what it's like to be a bug? Become Gregor, who transforms into a tiny cockroach in a gigantic world! Explore massive rooms where everyday objects tower above you. Run up walls, crawl through cracks, and leap across huge gaps. Make friends with talking insects, uncover secrets, and help save your human friend in trouble. It's a thrilling adventure full of surprises and challenges\u2014all in the immersive world of virtual reality! Are you ready to bug out?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://blacksunproductions.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Black Sun Productions Inc.", "support_website_url": null, "website_url": "https://www.blacksunproductions.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8682026641844583"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031606_3956296141318175_939904925939257333_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YTYXCeHzi8IQ7kNvgFzB9b2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCR4n91fj4vMvph9ndOmZWeJaid3m77bez5lFpAKkqvBg&oe=6735E856"}, "is_concept": false, "is_test": false, "is_trial_offer_valid"