25/75250454_212305930722586_6903001219283382907_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=drMX83EHOBwQ7kNvgFbuTOh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD9zy-dectPkBBvblUFBC3eJvpolEQZ0MOP267ujyldlw&oe=676400F2"}, "display_name": "2DLike Adventure", "keywords": ["retro", "Timetrial", "RTA", "\u30bf\u30a4\u30e0\u30a2\u30bf\u30c3\u30af", "\u30ec\u30c8\u30ed"], "long_description": "This game is\nUse dash and jump to reach the goal.\nto reach the goal of the stage.\njumping action game.\n\n\nOperation Description\nLStick(Left/Right)     \n-Move\u3000\u3000\n\nLStick(Left/Right) +Hold B\n-Dash\u3000\n\nA Button\n-Jump\n\n------------------------\n\nStory\nThe orb that brings peace to the world has been stolen by an evil dragon!\n\nThe heroes are now\nTo reclaim the orb!", "short_description": "Use your jumping and dashing skills to reach the goal of the stage!\n\nAn old-fashioned\n2D style jumping action game!\n\nThe game features a variety of unique stages, \nincluding beach, Japanese style, and ice world.\n\nThe game is simple, yet deep.\nchallenging stages await you!\n\nLet's go on a journey into the 2D world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/08/2dlike-adventure.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/08/about-2dlike-adventure.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en",