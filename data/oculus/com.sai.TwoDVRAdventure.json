_2970735375846012854_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4EH2rS55cooQ7kNvgELnGdo&_nc_ht=scontent.oculuscdn.com&oh=00_AYBk7h9mMW9z1hK5vc-c6qf29k5GMfv4f7S4Jv9pwUJE1g&oe=66F7DE03"}, {"file_name": "sc4.png", "id": "2621756744793074", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974904_2621756751459740_1034031394191481928_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hjie_r6eTTUQ7kNvgG1aRFP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDY59LrEuF5co-Old5OEthZZUV2qYKn5KH7mr5eDRGS7g&oe=66F7F02C"}, {"file_name": "sc5.png", "id": "234311285220729", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982679_234311288554062_4110438399576794859_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=isOaPbfIwiYQ7kNvgHcHNVm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWz8A6CUyYaaqoAJkngWj7vxQnEUZXeQ2JYPQi6Jgd6Q&oe=66F805DF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "samne.png", "id": "212305927389253", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75250454_212305930722586_6903001219283382907_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mrqinhih08sQ7kNvgHzN4Il&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5C-i3VqH4yslPebHY1iDEjBOWfaZc74GcWRLh3rkVLA&oe=66F7E5F2"}, "display_name": "2DLike Adventure", "keywords": [], "long_description": "This game is\nUse dash and jump to reach the goal.\nto reach the goal of the stage.\njumping action game.\n\n\nOperation Description\nLStick(Left/Right)     \n-Move\u3000\u3000\n\nLStick(Left/Right) +Hold B\n-Dash\u3000\n\nA Button\n-Jump\n\n------------------------\n\nStory\nThe orb that brings peace to the world has been stolen by an evil dragon!\n\nThe heroes are now\nTo reclaim the orb!", "short_description": "Use your jumping and dashing skills to reach the goal of the stage!\n\nAn old-fashioned\n2D style jumping action game!\n\nThe game features a variety of unique stages, \nincluding beach, Japanese style, and ice world.\n\nThe game is simple, yet deep.\nchallenging stages await you!\n\nLet's go on a journey into the 2D world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2021/08/2dlike-adventure.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2021/08/about-2dlike-adventure.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3025086504472794"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "692812979705673"}, {"status": "PUBLISHED", "id": "1213004072535961"}]}, "baseline_offer": {"id": "1213004072535961"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "692812979705673"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8018722404882890", "version": "1.6"}, "id": "376931833772244", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4171680576253778", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8018722404882890"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "376931833772244"}]}, "change_log": "ver