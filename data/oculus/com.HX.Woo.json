&_nc_sid=6e7a0a&_nc_ohc=JS6ihU6b0CgQ7kNvgFgzW9G&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMZnZ4MgBzpeStNyUAT9ajL_qLVNdawPF88VPni-K3mQ&oe=66FD1AF6"}, "display_name": "Party Crashers: Balloons", "keywords": [], "long_description": "If you are a social expert, you can interact with other users in real-time voice chat, send emoji bubbles, and make unexpected actions in the game lobby. But if you are a social novice, there is no need to worry at all, there are many unique ice-breaking mini-games in the game lobby. You can also experience different modes of the game with other players in the game room. It's a stress-free world where you can have fun with your friends!\n\nGame Mode:\n-Scruffle Mode: Pick up any item on the ground at will, smash mercilessly at your opponent, and win!\n-Handball Mode: Team up with your teammates to pass, shoot, and score! Smash your opponents and hinder their attacks!\n-Graffiti Mode: Use props with different functions, let your imagination run wild, and turn the surrounding walls into works of art that only belong to you!\n\n", "short_description": "Party Crashers: Balloons is a casual, party-type VR game. Become \"Balloons\" in a world full of fantasy, and enjoy the joy of socializing with players from all over the world. "}]}, "developer_name": "HXDF", "developer_privacy_policy_url": "http://vrpro.sitaitongxue.com/web2/outsource/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "HXDF", "support_website_url": null, "website_url": "https://discord.gg/U27U59QNxZ", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": 