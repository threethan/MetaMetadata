5124723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nJ2JqR_D9Y4Q7kNvgEHIpsq&_nc_ht=scontent.oculuscdn.com&_nc_gid=A114Mz3Aq6tikb3FYwSwVMY&oh=00_AYAYdoievcaNlNVrISH_bH3tKwA3uSfIYJhLPJqs0aeplw&oe=66D43D76"}, {"file_name": "\u622a\u56fe5.png", "id": "1108811133252997", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982439_1108811136586330_644352280341395127_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xyNhOvS3JRoQ7kNvgFqxNKy&_nc_ht=scontent.oculuscdn.com&_nc_gid=A114Mz3Aq6tikb3FYwSwVMY&oh=00_AYBkpQaOmTLNK-oiXQgi-7fjdyVglP8PUNYV0tqTItvSvw&oe=66D434FA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u9884\u544a\u7247\u5c01\u9762\u56fe\u7247.png", "id": "1378159819287337", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035322_1378159822620670_4442149295807103551_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K30U4ulR6k4Q7kNvgGJoClS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A114Mz3Aq6tikb3FYwSwVMY&oh=00_AYB04MtgbYIjnZK5incn_XHFgI5sAENkFx5EYibdVC7cJg&oe=66D43C76"}, "display_name": "Party Crashers: Balloons", "keywords": [], "long_description": "If you are a social expert, you can interact with other users in real-time voice chat, send emoji bubbles, and make unexpected actions in the game lobby. But if you are a social novice, there is no need to worry at all, there are many unique ice-breaking mini-games in the game lobby. You can also experience different modes of the game with other players in the game room. It's a stress-free world where you can have fun with your friends!\n\nGame Mode:\n-Scruffle Mode: Pick up any item on the ground at will, smash mercilessly at your opponent, and win!\n-Handball Mode: Team up with your teammates to pass, shoot, and score! Smash your opponents and hinder their attacks!\n-Graffiti Mode: Use props with different functions, let your imagination run wild, and turn the surrounding walls into works of art that only belong to you!\n\n", "short_description": "Party Crashers: Balloons is a casual, party-type VR game. Become \"Balloons\" in a world full of fantasy, and enjoy the joy of socializing with players from all over the world. "}]}, "developer_name": "HXDF", "developer_privacy_policy_url": "http://vrpro.sitaitongxue.com/web2/outsource/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "HXDF", "support_website_url": null, "website_url": "https://discord.gg/U27U59QNxZ", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ACTION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "5144463448949289"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PENDING", "id": "2404261699875326"}, {"status": "PUBLISHED", "id": "496445349158531"}, {"status": "PENDING", "id": "1651785838550098"}, {"status": "PENDING", "id": "789545458913955"}, {"status": "PUBLISHED", "id": "406395798129521"}, {"status": "PUBLISHED", "id": "411325417094831"}]}, "baseline_offer": {"id": "496445349158531"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1662656400, "status": "PENDING", "id": "2404261699875326"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6168790806470895", "version": "2.0"}, "id": "241636984818519", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "547584