file_name": "\u9884\u544a\u7247\u5c01\u9762\u56fe\u7247.png", "id": "1378159819287337", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035322_1378159822620670_4442149295807103551_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wvyMcrFCb84Q7kNvgHiv6LJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCV3tJl1IggSyPCa9sLiBovoaLIjkigCmU-HHJNptiLzw&oe=6720B376"}, "display_name": "Party Crashers: Balloons", "keywords": [], "long_description": "If you are a social expert, you can interact with other users in real-time voice chat, send emoji bubbles, and make unexpected actions in the game lobby. But if you are a social novice, there is no need to worry at all, there are many unique ice-breaking mini-games in the game lobby. You can also experience different modes of the game with other players in the game room. It's a stress-free world where you can have fun with your friends!\n\nGame Mode:\n-Scruffle Mode: Pick up any item on the ground at will, smash mercilessly at your opponent, and win!\n-Handball Mode: Team up with your teammates to pass, shoot, and score! Smash your opponents and hinder their attacks!\n-Graffiti Mode: Use props with different functions, let your imagination run wild, and turn the surrounding walls into works of art that only belong to you!\n\n", "short_description": "Party Crashers: Balloons is a casual, party-type VR game. Become \"Balloons\" in a world full of fantasy, and enjoy the joy of socializing with players from all over the world. "}]}, "developer_name": "HXDF", "developer_privacy_policy_url": "http://vrpro.sitaitongxue.com/web2/outsource/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "HXDF", "support_website_url": null, "website_url": "https://discord.gg/U27U59QNxZ", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED