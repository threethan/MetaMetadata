409_4002421495152795441_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QdhJRzE2VMIQ7kNvgGakq3I&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuPbpJOY4_Ke-eQI7dWLkT-&oh=00_AYBWPQHqLsiRWjUHiZEpvjVAv62dvoGnRzlvQtHQ_0BtjQ&oe=66E6CBF1"}, {"file_name": "sshot1.png", "id": "3001572386745655", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974601_3001572390078988_6193970039339129983_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t2YL_6xivXsQ7kNvgHwqE2-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuPbpJOY4_Ke-eQI7dWLkT-&oh=00_AYBZ5-QJpaiorvxxm-P4tehKYDEtpgWwZK52HYIq2jr15A&oe=66E6B802"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u89c6\u9891\u5c01\u9762.png", "id": "144995564288837", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974446_144995567622170_1328094978115473705_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r5zIHkMuSHAQ7kNvgH-07EQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuPbpJOY4_Ke-eQI7dWLkT-&oh=00_AYAvFISu3gOgFin4sq_DWLu6l50uRr5mhKVDNSUX9VzpsQ&oe=66E6C22C"}, "display_name": "Mortal and Monster", "keywords": [], "long_description": "Mortal & Monster is a challenging rogue-like action RPG developed for Quest. We are aiming to combine tower-defense battle system and rogue-like dungeon map together to make an epic single player VR dungeon adventure.\n\nDynamic Character Build: Discover hundreds of unique weapons, skills, food, potions, wands  and other items to make your own build. \n\nFull 6DOF Battle System: Each weapon has its own unique battle style, including sword&shield, claymore, bow, throwing axe. You can use 6DOF controller to input actions like block, slash, stab, two-hand cleave and so on. \n\nRandom Map and Events: the dungeon map is generated randomly. Each room contains different events like combat encounters, trap, merchant, bonfire, alter, mini card game and so on. Every time you begin your journey in the dark dungeon, the layout differs which is displayed in map. ", "short_description": "Mortal & Monster is a challenging rogue-like action RPG developed for Quest. We are aiming to combine tower-defense battle system and rogue-like dungeon map together to make an epic single player VR dungeon adventure."}]}, "developer_name": "Chemera Games", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/ed3e0079-f83d-4472-bb14-96c5ebd5d6fd", "developer_terms_of_service_url": null, "publisher_name": "Bitsrealm Technology", "support_website_url": null, "website_url": "http://www.mortal-monster.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3118113795067825"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4144298965638266", "version": "1.5"}, "id": "464965814712640", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4004581999609964", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4144298965638266"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "464965814712640"}]}, "change_log": null, "created_date": 1623241837, "id": "4144298965638266", "version": "1.5", "version_code": 7, "release