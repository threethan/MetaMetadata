mEZjaikFpavgy-Mrg&oe=674314F1"}, {"file_name": "sshot1.png", "id": "3001572386745655", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974601_3001572390078988_6193970039339129983_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hj1qkCs-ZzsQ7kNvgGWZAwl&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwtEaX-CYHWchfqq1UF7Z9YcoFfiY2js_b8d-b9R8uhg&oe=67430102"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u89c6\u9891\u5c01\u9762.png", "id": "144995564288837", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974446_144995567622170_1328094978115473705_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZU_ns_t78bgQ7kNvgEBnEXV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcdzcds-unrVsjRmILRJrKloXabQPLlEavr0qm28w4lA&oe=67430B2C"}, "display_name": "Mortal and Monster", "keywords": [], "long_description": "Mortal & Monster is a challenging rogue-like action RPG developed for Quest. We are aiming to combine tower-defense battle system and rogue-like dungeon map together to make an epic single player VR dungeon adventure.\n\nDynamic Character Build: Discover hundreds of unique weapons, skills, food, potions, wands  and other items to make your own build. \n\nFull 6DOF Battle System: Each weapon has its own unique battle style, including sword&shield, claymore, bow, throwing axe. You can use 6DOF controller to input actions like block, slash, stab, two-hand cleave and so on. \n\nRandom Map and Events: the dungeon map is generated randomly. Each room contains different events like combat encounters, trap, merchant, bonfire, alter, mini card game and so on. Every time you begin your journey in the dark dungeon, the layout differs which is displayed in map. ", "short_description": "Mortal & Monster is a challenging rogue-like action RPG developed for Quest. We are aiming to combine tower-defense battle system and rogue-like dungeon map together to make an epic single player VR dungeon adventure."}]}, "developer_name": "Chemera Games", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/ed3e0079-f83d-4472-bb14-96c5ebd5d6fd", "developer_terms_of_service_url": null, "publisher_name": "Bitsrealm Technology", "support_website_url": null, "website_url": "http://www.mortal-monster.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "821934236779161"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3118113795067825"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974910_183919413635947_1005106245949355557_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rs6ElYt_kzQQ7kNvgF0pJvP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3EFo-vzBnBee54YZQxGB3gIRQZv2VQ41KcY4sfnVe3Q&oe=674300AE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mortal and Monster", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Role Playing", "id": "821934236779161"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1625775631, "lastRevision": {"nodes": [{"id": "110233891202788", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "40045819996