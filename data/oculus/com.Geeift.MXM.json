g rogue-like action RPG developed for Quest. We are aiming to combine tower-defense battle system and rogue-like dungeon map together to make an epic single player VR dungeon adventure."}]}, "developer_name": "Chemera Games", "developer_privacy_policy_url": "https://www.privacypolicies.com/live/ed3e0079-f83d-4472-bb14-96c5ebd5d6fd", "developer_terms_of_service_url": null, "publisher_name": "Bitsrealm Technology", "support_website_url": null, "website_url": "http://www.mortal-monster.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3118113795067825"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4144298965638266", "version": "1.5"}, "id": "464965814712640", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4004581999609964", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4144298965638266"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "464965814712640"}]}, "change_log": null, "created_date": 1623241837, "id": "4144298965638266", "version": "1.5", "version_code": 7, "release