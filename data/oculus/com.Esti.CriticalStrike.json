&oe=677D1AA4"}, {"file_name": "ss3.png", "id": "1546656862640155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982619_1546656865973488_7064097390353144668_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tYlm2oVvPekQ7kNvgFR9gVc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgcJSymbX5lKwTp1Q4G8wv15-2GEXuFWTfae1u38NzEw&oe=677D2B99"}, {"file_name": "2.png", "id": "831640062426071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974548_831640065759404_7177660222910413548_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ECKD4vgaBPkQ7kNvgE0C7id&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAZ1YEwhIpC7xcULcRcZUgW3-xOwAT9ho-fapbbxEfthA&oe=677D2993"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "527000839915236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031526_527000846581902_1697330175906579671_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TN-TA5683V8Q7kNvgF6O7gZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvnzM4a13ezoT4_j81vaAPQYbFZ7XfmHJEMyyKx8maDQ&oe=677D2424"}, "display_name": "Critical Hit", "keywords": ["shotter", "casual", "fun", "hypercasual", "ArcadeChallenge"], "long_description": "Critical Hit\" is an exhilarating action game designed to test your precision and reflexes. Set in a vibrant, dynamic world, the objective is simple yet endlessly entertaining: shoot and eliminate balloon-like characters that float and bounce unpredictably across the screen.\n\nEach level presents a unique challenge, with increasing difficulty as you progress. The targets, resembling colorful and quirky balloon figures, move in patterns that require sharp focus and quick decision-making. Your task is to aim, shoot, and pop as many of these balloon characters as possible before time runs out or before they escape your range.\n\nThe game\u2019s intuitive controls make it accessible to players of all skill levels, while its escalating challenges keep even the most seasoned gamers on their toes. The physics-based mechanics ensure that every shot feels satisfying, whether you\u2019re pulling off a perfect long-range hit or executing rapid-fire shots at close range.\n\n\"Critical Hit\" offers a variety of weaponry, each with its own unique attributes, allowing you to customize your gameplay experience. \n\n", "short_description": "Experience the thrill of precision shooting in 'Critical Hit,' where your aim determines your success! Challenge yourself to take down quirky balloon-like characters with your sharp shooting skills. Perfect your accuracy and timing to hit the mark in this addictive, fast-paced game. Unlock levels, earn rewards, and become the ultimate marksman. Whether you're a casual gamer or a shooting enthusiast, 'Critical Hit' offers endless fun and excitement!"}]}, "developer_name": "ESTI Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ESTI Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/critical-strike", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8434403773291691"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com