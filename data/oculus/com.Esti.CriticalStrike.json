pBi9OM0rWOYf2EA&oe=6785163D"}, {"file_name": "ss4.png", "id": "3771632216407378", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031518_3771632219740711_7195365230456519162_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5crM4CdSvL4Q7kNvgHEBmcH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnIh6Mq1EJaI06uoMpgSe23OXDpa5-k4D5sPDOBMpvTw&oe=678508B1"}, {"file_name": "ss1.png", "id": "1226270102149303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_1226270105482636_6891749792742744979_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s0fcFGxqBYkQ7kNvgEG9Kx9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYl1uD-n-cWFu-gJS_jM3iql7j61arKdjvvQxqllb5aw&oe=678503A4"}, {"file_name": "ss3.png", "id": "1546656862640155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982619_1546656865973488_7064097390353144668_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ionXLP2hVTAQ7kNvgFf4hWj&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKq_zbb6AQ1RYOmz5BSt01Vg37_YSnXTx86mj85recww&oe=67851499"}, {"file_name": "2.png", "id": "831640062426071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974548_831640065759404_7177660222910413548_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XeDpvggyKVMQ7kNvgE91Cjy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2V9VjQ8bBN58s6FOQt3AMEEdo-sH9EgczQC-w_TsxOw&oe=67851293"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "527000839915236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031526_527000846581902_1697330175906579671_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMDuSGc8sDcQ7kNvgG3zkcD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcGmut6kYS088GxWtZkacdGUHNvLE4BCYBVG1i5Vn4qA&oe=67850D24"}, "display_name": "Critical Hit", "keywords": ["shotter", "casual", "fun", "hypercasual", "ArcadeChallenge"], "long_description": "Critical Hit\" is an exhilarating action game designed to test your precision and reflexes. Set in a vibrant, dynamic world, the objective is simple yet endlessly entertaining: shoot and eliminate balloon-like characters that float and bounce unpredictably across the screen.\n\nEach level presents a unique challenge, with increasing difficulty as you progress. The targets, resembling colorful and quirky balloon figures, move in patterns that require sharp focus and quick decision-making. Your task is to aim, shoot, and pop as many of these balloon characters as possible before time runs out or before they escape your range.\n\nThe game\u2019s intuitive controls make it accessible to players of all skill levels, while its escalating challenges keep even the most seasoned gamers on their toes. The physics-based mechanics ensure that every shot feels satisfying, whether you\u2019re pulling off a perfect long-range hit or executing rapid-fire shots at close range.\n\n\"Critical Hit\" offers a variety of weaponry, each with its own unique attributes, allowing you to customize your gameplay experience. Whether you prefer the precision of a sniper rifle, the power of a shotgun, or the rapid fire of a machine gun, there\u2019s a weapon to suit your style.\n\n", "short_description": "Experience the thrill of precision shooting in 'Critical Hit,' where your aim determines your success! Challenge yourself to take down quirky balloon-like characters with your sharp shooting skills. Perfect your accuracy and timing to hit the mark in this addictive, fast-paced game. Unlock levels, earn rewards, and become the ultimate marksman. Whether you're a casual gamer or a shooting enthusiast, 'Critical Hit' offers endless fun and excitement!"}]}, "developer_name": "ESTI Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ESTI Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/critical-strike", "cat