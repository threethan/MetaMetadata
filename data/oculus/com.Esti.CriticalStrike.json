&oe=673B14E4"}]}, "id": "8216565548435599", "locale": "en_US", "screenshots": [{"file_name": "ss2.png", "id": "417368344702101", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75361350_417368348035434_2450629024912348088_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KnB9fTlvi1oQ7kNvgE6EuK7&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBg-TlX2wB1473tgoXn30nss6FTUZhnYp99WAZVyy_jYQ&oe=673B423D"}, {"file_name": "ss4.png", "id": "3771632216407378", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031518_3771632219740711_7195365230456519162_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PjmcasCE22QQ7kNvgHMNKD9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQiWqvNE1-FPyzmSNZpH2PtE81zh0dBmuaqLJt1JwZPA&oe=673B34B1"}, {"file_name": "ss1.png", "id": "1226270102149303", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_1226270105482636_6891749792742744979_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=i_GGdQfLZekQ7kNvgEJQiFQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtd34HNiOy1Nk-LaEhksYhrQ38qtOdC2jhtqJNbpM0xQ&oe=673B2FA4"}, {"file_name": "ss3.png", "id": "1546656862640155", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982619_1546656865973488_7064097390353144668_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zz-nqlwL_ZcQ7kNvgFfj0tq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrWZi171LsRPfxs_rThznV-NsAL6jNCL7BT4O6W3jzcQ&oe=673B4099"}, {"file_name": "2.png", "id": "831640062426071", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974548_831640065759404_7177660222910413548_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GwzX27cW7XAQ7kNvgECUVeu&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmo5N_sDOFgYAFjc5zhkXHEo5UxGw7PmM2z6hbZmeeLQ&oe=673B3E93"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "1.png", "id": "527000839915236", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031526_527000846581902_1697330175906579671_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cybi5-m4SoIQ7kNvgHBU3T6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbpBmGjKD5IFcg1nmSHgMRerdidhFSb7b4LkO2ZxO9nA&oe=673B3924"}, "display_name": "Critical Hit", "keywords": ["shotter", "casual", "fun", "hypercasual", "ArcadeChallenge"], "long_description": "Critical Hit\" is an exhilarating action game designed to test your precision and reflexes. Set in a vibrant, dynamic world, the objective is simple yet endlessly entertaining: shoot and eliminate balloon-like characters that float and bounce unpredictably across the screen.\n\nEach level presents a unique challenge, with increasing difficulty as you progress. The targets, resembling colorful and quirky balloon figures, move in patterns that require sharp focus and quick decision-making. Your task is to aim, shoot, and pop as many of these balloon characters as possible before time runs out or before they escape your range.\n\nThe game\u2019s intuitive controls make it accessible to players of all skill levels, while its escalating challenges keep even the most seasoned gamers on their toes. The physics-based mechanics ensure that every shot feels satisfying, whether you\u2019re pulling off a perfect long-range hit or executing rapid-fire shots at close range.\n\n\"Critical Hit\" offers a variety of weaponry, each with its own unique attributes, allowing you to customize your gameplay experience. Whether you prefer the precision of a sniper rifle, the power of a shotgun, or the rapid fire of a machine gun, there\u2019s a weapon to suit your style.\n\n", "short_description": "Experience the thrill of precision shooting in 'Critical Hit,' where your aim determines your success! Challenge yourself to take down quirky balloon-like characters with your sharp shooting skills. Perfect your accuracy and timing to hit the mark in this addictive, fast-paced game. Unlock levels, earn rewards, and become the ultimate marksman. Whether you're a casual gamer or a shooting enthusiast, 'Critical Hit' offers endless fun and excitement!"}]}, "developer_name": "ESTI Soft", "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view?usp=sharing", "developer_terms_of_service_url": null, "publisher_name": "ESTI Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/critical-strike", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8394027643995971"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1597660114468704"}, {"status": "PUBLISHED", "id": "1182926622995690"}]}, "baseline_offer": {"id": "1182926622995690"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726084261, "status": "PUBLISHED", "id": "1597660114468704"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8395105760554826", "version": "0.5"}, "id": "1169961984276037", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8311321648933238", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "83951057605