yond Chronos", "keywords": ["CHRONOS", "TOKYO", "Adventure", "Mecha", "SF"], "long_description": "\"\u2014This isn\u2019t a dream.\"\nDive into the future in Altdeus: Beyond Chronos, a sci-fi adventure full of robot battles, pop music, and emotion. Featuring one of the largest branching storylines ever in a VR game, Altdeus will place you in the shoes of Chloe, a pilot in humanity's forces fighting massive hostile organisms known as the Meteora.\n\nConverse with other characters and seek clues in the Adventure Section. The Mecha Battle Section is where things get rough, as you enter the cockpit of Makhia, the towering humanoid anti-Meteora combat weapon.\n\nWhen Chloe arrives at her final decision\u2014what will you choose?\n\nGenre: VR Adventure / Visual Novel", "short_description": "\"\u2014This isn\u2019t a dream.\"\nDive into the future in Altdeus: Beyond Chronos, a sci-fi adventure full of robot battles, pop music, and emotion. Featuring one of the largest branching storylines ever in a VR game, Altdeus will place you in the shoes of Chloe, a pilot in humanity's forces fighting massive hostile organisms known as the Meteora.\n\nGenre: VR Adventure / Visual Novel"}]}, "developer_name": "MyDearest Inc.", "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "MyDearest Inc.", "support_website_url": "https://altdeus.com/en/", "website_url": "https://altdeus.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en_US", "fr", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "su