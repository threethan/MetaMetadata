, {"file_name": "4.png", "id": "397170391541946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195906_397170394875279_9128241455594099915_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-nhzopqE7MQ7kNvgH-QZqx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AtwTa8TzapPxpwBAXjURe1h&oh=00_AYBU0F7FFJb0Lk0X6FlvqPcsLQnqO9atkQrXlu9xvCiiow&oe=66F540F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Oculus.png", "id": "293952722081199", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036685_293952725414532_5233729569157977764_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZEVgGRzQkRsQ7kNvgFSNWKU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AtwTa8TzapPxpwBAXjURe1h&oh=00_AYAp-TPiKvdHz8XK8vLPXbUyOnIO705THnAFn7nWeKQf8w&oe=66F5392F"}, "display_name": "ALTDEUS: Beyond Chronos", "keywords": ["Battle", "Exploration", "Story", "Adventure", "Narrative"], "long_description": "\u201cThe story to draw and the big scale production that makes full use of robot battle are excellent.\u201d 9/10 \u2013 IGN Japan\n\"I found myself completely immersed in ALTDEUS' story\u2026\" GREAT\u2605\u2605\u2605\u2605 \u2013 UploadVR\nALTDEUS features 15-20 hours of gameplay with one of the largest branching storylines ever in a VR game.\n\nThis game contains multiple unlockable paths - don't stop playing at the first credits roll!\n\n2280. You become a mecha pilot of a military organization, to defend the underground city against giant enemies. Even in the future 200 years from now, the proposition of which one you choose doesn't change at all. Your choices and actions branch the story leading to multiple endings.\n\nMyDearest is an independent VR publisher/developer based in Akihabara, Japan. We released TOKYO CHRONOS in 2019, and the game has not only won several awards but also gained people who support us. We'd like you to enjoy ALTDEUS which has impressive directions as well as unprecedented stories.", "short_description": "\u201cThe story to draw and the big scale production that makes full use of robot battle are excellent.\u201d 9/10 \u2013 IGN Japan\nALTDEUS features 15-20 hours of gameplay with one of the largest branching storylines ever in a VR game. Your choices and actions branch the story leading to multiple endings.\n\nThis game contains multiple unlockable paths - don't stop playing at the first credits roll!\n\nThis game is highly recommended for people who don\u2019t have a high tolerance against motion sickness."}, {"images": {"nodes": [{"file_name": "ALTDEUS_\u30b9\u30c8\u30a2\u30d2\u30fc\u30ed\u30fc\u30ab\u30d0\u30fc.png", "id": "4223279501109476", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_4223279504442809_3739855637233883216_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uxNmKzVSFRsQ7kNvgExMjdh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AtwTa8TzapPxpwBAXjURe1h&oh=00_AYAXh02gbZfiFXHfmDpy9fvFP1H8PPtLX1hDfAsjWqSmXg&oe=66F538AC"}, {"file_name": "75195903_820598405369726_3225761644119553739_n.png", "id": "2919710161687177", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031622_2919710165020510_2929328724112360960_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0oqzO1oWWN0Q7kNvgHbTzY4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AtwTa8TzapPxpwBAXjURe1h&oh=00_AYALW0FzCMNWiicBHPzV0fQhSzG9Qo4fgPMVNLEVkg4uHQ&oe=66F55F71"}, {"file_name": "75292488_2711827285699173_9164718924552926630_n.png", "id": "1698153337036670", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54770913_1698153340370003_3797474642646423738_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oKvvxwbgPdsQ7kNvgEMtB8W&_nc_ht=scontent.oculuscdn.com&_nc_gid=AtwTa8TzapPxpwBAXjURe1h&oh=00_AYCs2JNS5QC-iRgMfnd-ottzzzfXTvgNx_h6XdwebaIp_w&oe=66F56274"}, {"file_name": "ALTDEUS_\u30b9\u30c8\u30a2\u30ab\u30d0\u30fc\u6a2a_2560x1440.png", "id": "1308187112973193", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t6