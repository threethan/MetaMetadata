c_ht=scontent.oculuscdn.com&oh=00_AYDumm4KBgzNPASORFhtdKViGavP2aVitXhiWt8kKBUGpg&oe=66F7DBBE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "chillaxtagging (1).png", "id": "1693469214752403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931338_1693469221419069_6009792193737061338_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l3-L4ZUEQcUQ7kNvgF0HvbC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtxdKtb8-3O-8bngTtWewRgM7j99zKziJp4mMBzhoxLg&oe=66F7FA6B"}, "display_name": "Chillax Tagging", "keywords": [], "long_description": "Chillax Tagging is an immersive VR game that draws inspiration from the beloved Gorilla Tag, offering players a unique and exhilarating experience in a vibrant, open-world environment. In Chillax Tagging, you embody agile creatures, using your arms to swing, climb, and tag your friends in a thrilling game of tag. The game\u2019s innovative hand-based locomotion system provides an incredibly immersive experience, allowing you to navigate the world with fluid, natural movements.\n\nGame Modes and Environments\nChillax Tagging features a variety of game modes to suit different play styles and moods:\n\nCasual Mode: Perfect for social hangouts, this mode allows you to explore serene environments, chat with friends, and enjoy a relaxed pace. Whether you\u2019re lounging in a tranquil forest or exploring a peaceful village, Casual Mode is all about chilling and connecting with others.\nCompetitive Mode: For those seeking a challenge, Competitive Mode offers intense tag battles in dynamic environments. Navigate through bustling cityscapes, ancient ruins, or futuristic arenas as you outmaneuver your opponents and strive to be the last one standing.\nAdventure Mode: Embark on exciting quests and challenges in Adventure Mode. Solve puzzles, discover hidden secrets, and complete missions that test your agility and wit. This mode adds a layer of depth and narrative to the game, making each session a new adventure.", "short_description": "Chillax Tagging is an exhilarating VR game inspired by the popular Gorilla Tag. Dive into a vibrant, open-world environment where you embody agile creatures, using your arms to swing, climb, and tag your friends in a thrilling game of tag. The unique hand-based locomotion system offers an immersive experience, allowing you to navigate the world with fluid, natural movements.\n\nIn Chillax Tagging, you can explore various game modes, from casual social hangouts to intense competitive matches."}]}, "developer_name": "UnityGame", "developer_privacy_policy_url": "https://sites.google.com/view/chillaxtagging/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Hrqmable", "support_website_url": null, "website_url": "https://sites.google.com/view/chillaxtagging/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7940438519357560"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1045553240539614"}]}, "baseline_offer": {"id": "1045553240539614"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726631640, "status": "PUBLISHED", "id": "1045553240539614"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8030362620365149", "version": "2.8"}, "id": "10531