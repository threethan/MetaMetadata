7&_nc_sid=6e7a0a&_nc_ohc=ndJvp_ojAOoQ7kNvgEFXfbS&_nc_ht=scontent.oculuscdn.com&oh=00_AYANdekXAiN0MWz1vTZD2-Uy_wQFLjP5Rtb7KGawcLnJfQ&oe=66F7EFFD"}, {"file_name": "fangame2.png", "id": "892985789374863", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556279_892985792708196_9165036967193102334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XB5fzL_8U8kQ7kNvgHqz4Vu&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjzxp37Tc2wTV7SnsQXdR7wiXB835t920nYJUC7MIV4w&oe=66F7F164"}, {"file_name": "fangame3.png", "id": "1210115256699065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031517_1210115260032398_1586727260078025309_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4clj37_1Qg8Q7kNvgFQ_uJZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqLJpani0-gdcFu1Bv_wSAT_c_ZjpdnrkzTb8Ph52kGQ&oe=66F7DCF7"}, {"file_name": "fangame2.png", "id": "1223014018711819", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031444_1223014025378485_3881326784603181523_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3hVm43gjzLsQ7kNvgFG9Mw6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDumm4KBgzNPASORFhtdKViGavP2aVitXhiWt8kKBUGpg&oe=66F7DBBE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "chillaxtagging (1).png", "id": "1693469214752403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931338_1693469221419069_6009792193737061338_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l3-L4ZUEQcUQ7kNvgF0HvbC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCtxdKtb8-3O-8bngTtWewRgM7j99zKziJp4mMBzhoxLg&oe=66F7FA6B"}, "display_name": "Chillax Tagging", "keywords": [], "long_description": "Chillax Tagging is an immersive VR game that draws inspiration from the beloved Gorilla Tag, offering players a unique and exhilarating experience in a vibrant, open-world environment. In Chillax Tagging, you embody agile creatures, using your arms to swing, climb, and tag your friends in a thrilling game of tag. The game\u2019s innovative hand-based locomotion system provides an incredibly immersive experience, allowing you to navigate the world with fluid, natural movements.\n\nGame Modes and Environments\nChillax Tagging features a variety of game modes to suit different play styles and moods:\n\nCasual Mode: Perfect for social hangouts, this mode allows you to explore serene environments, chat with friends, and enjoy a relaxed pace. Whether you\u2019re lounging in a tranquil forest or exploring a peaceful village, Casual Mode is all about chilling and connecting with others.\nCompetitive Mode: For those seeking a challenge, Competitive Mode offers intense tag battles in dynamic environments. Navigate through bustling cityscapes, ancient ruins, or futuristic arenas as you outmaneuver your opponents and strive to be the last one standing.\nAdventure Mode: Embark on exciting quests and challenges in Adventure Mode. Solve puzzles, discover hidden secrets, and complete missions that test your agility and wit. This mode adds a layer of depth and narrative to the game, making each session a new adventure.", "short_description": "Chillax Tagging is an exhilarating VR game inspired by the popular Gorilla Tag. Dive into a vibrant, open-world environment where you embody agile creatures, using your arms to swing, climb, and tag your friends in a thrilling game of tag. The unique hand-based locomotion system offers an immersive experience, allowing you to navigate the world with fluid, natural movements.\n\nIn Chillax Tagging, you can explore various game modes, from casual social hangouts to intense competitive matches."}]}, "developer_name": "UnityGame", "developer_privacy_policy_url": "https://sites.google.com/view/chillaxtagging/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Hrqmable", "support_website_url": null, "website_url": "https://sites.google.com/view/chillaxtagging/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics"