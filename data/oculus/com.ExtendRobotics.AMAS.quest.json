37283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aCWSpY9xJtMQ7kNvgHrIi8H&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATSnsKu2LdWoQagULWEgPKmzf6YuSuHSrWSMTc4X7umQ&oe=674EFB1C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U2ak8EkJTiwQ7kNvgEoUQDz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDItG7zwnnFftdGUsFYDX0bERT0BVBkFkqjHMpLeYgCkg&oe=674EEC68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p_Q4nazBqpIQ7kNvgGb_tKM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCocP-WnCkenYPDYNPSdIeTJ62xTI6ZC4TCr0sA6rMRNg&oe=674ED972"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor hardware integration contact Extend Robotics.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_priva