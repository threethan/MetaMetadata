lbtKLhbo0Od5GdiTw&oe=66ED5D68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LtdWGKrSOK4Q7kNvgG46uvB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQoJQKNqBzEPlwYVBMcKOnZcK-5BoDFqNKFoqx4wxgKw&oe=66ED4A72"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor hardware integration contact Extend Robotics.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.extendrobotics.com/user-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Extend Robotics", "support_website_url": null, "website_url": "http://www.extendrobotics.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommende