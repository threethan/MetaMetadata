oftTeams-image.png", "id": "223946769812825", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001726_223946773146158_7772036560979420344_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ydc0N6UaVkMQ7kNvgFQT6Rr&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD4YQDrGTvZv-U21TIhNN1ep9T_qE4IPgRVSSoqcwU90A&oe=6756CE03"}]}, "id": "455427327408675", "locale": "en_US", "screenshots": [{"file_name": "Screenshot (109).png", "id": "505098797308375", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75439600_505098800641708_5486984715524090908_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9to0XTeWQBsQ7kNvgF70lbt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA0i4xMdF94qNkV4227F5rpuGI5ACqIboPqlRI59LuwAw&oe=6756E8CD"}, {"file_name": "Screenshot (121).png", "id": "232213002328208", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035466_232213005661541_969947023180179234_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R19eAMrat9oQ7kNvgFV-Z8l&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAjI9Rpc2urZdGRfLjYQQ0YPc-pp9Bx301LpMBtGsbaDg&oe=6756DBCF"}, {"file_name": "Screenshot (122).png", "id": "744625859827156", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974683_744625863160489_3999024988748835723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WW0Kp7yO2wwQ7kNvgG7RoLe&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDCPFutwZGcDnEfiOLwTChhWl9wcnoOK0Fks06dR2VMAA&oe=6756DC84"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_PMxvZLvHdgQ7kNvgHMaHSR&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBvLCPNsXW82CyNCBdHBti4STNNOu5F8kvSTJIjJ8muiw&oe=6756E41C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KicJP9f6WpwQ7kNvgHikeEJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCZh1PSwLMYt9qMfBX4YwSZeGGousPdBxmrpF614gbtVA&oe=6756D568"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q3fdcltEUnkQ7kNvgG_8HYo&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD69TAxVwbUi4OGy5Pb1jhwdsNqI63M3H7MdxX08S7ImA&oe=6756C272"}, "display_name": "AMAS AppLab", "keywords": [], "long_description": "Imagine if you could use your own hands to control a robotic arm on the other side of the world. Imagine with the right robotic arm if you could lift up an object larger than a car, or smaller than the tiniest grain of sand, without being physically present.\n\nWelcome to AMAS, the Advanced Mechanics Assistance System. AMAS lets you physically control robotics arms remotely over the internet, using intuitive gestures in an immersive 3D environment.\n\nThe application begins with a tutorial where you learn to control a simulated robotic arm; and record and replay your movements of the robot. When you\u2019ve mastered the simulation, you can then graduate to controlling real robots anywhere in the world.\n\nIf you have a robotic arm that you\u2019d like to connect with, please get in touch with Extend Robotics at (http://www.extendrobotics.com/). (please note that you will need to buy some extra hardware and software to enable tele-control). Extend Robotics are always on hand to offer expert advice.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "ht