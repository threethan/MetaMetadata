oftTeams-image.png", "id": "223946769812825", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001726_223946773146158_7772036560979420344_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wwFl2rDZ-mgQ7kNvgGpaY5p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2IURx11RUQWycEEDTi24hfprY8Q4eIycgdxE2kaf1qA&oe=6739CD03"}]}, "id": "455427327408675", "locale": "en_US", "screenshots": [{"file_name": "Screenshot (109).png", "id": "505098797308375", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75439600_505098800641708_5486984715524090908_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=edDlLw-qh6YQ7kNvgH_7YJH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDw2O2-0xQ_UVjW3lg9_Z4y5FkJL5u1Vye7Y_wvfRwHEw&oe=6739E7CD"}, {"file_name": "Screenshot (121).png", "id": "232213002328208", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035466_232213005661541_969947023180179234_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=93nvT4l1kYgQ7kNvgFGQpFA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB90xe9btEx9HVdy9CsLkYdeZRalHQmzS2w5kVT3JqbRw&oe=6739DACF"}, {"file_name": "Screenshot (122).png", "id": "744625859827156", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974683_744625863160489_3999024988748835723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nGi4VhFidLsQ7kNvgFQ5MlQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDGI6lDCPSgjVPPnE6qnKtEixVaFhyI33I3PsSjA2W3mw&oe=6739DB84"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r63eGhjMFWoQ7kNvgE2GRYF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBGlyxSsDJrV9S5wqAt8t-I3_oAwD4FFe2AbxdlmrdIsA&oe=6739E31C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RI3NcCQCXVkQ7kNvgGaz5Ha&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbH37B-m9Nmah9eXYxZUtLIGyvVPtdWLJAuVAGzEcuQg&oe=6739D468"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f2-FuTP271MQ7kNvgGbpybo&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCx-5ns2E4sLwwtSeVTtaDfpmEecaicIAXzk65JeiTA-Q&oe=6739C172"}, "display_name": "AMAS AppLab", "keywords": [], "long_description": "Imagine if you could use your own hands to control a robotic arm on the other side of the world. Imagine with the right robotic arm if you could lift up an object larger than a car, or smaller than the tiniest grain of sand, without being physically present.\n\nWelcome to AMAS, the Advanced Mechanics Assistance System. AMAS lets you physically control robotics arms remotely over the internet, using intuitive gestures in an immersive 3D environment.\n\nThe application begins with a tutorial where you learn to control a simulated robotic arm; and record and replay your movements of the robot. When you\u2019ve mastered the simulation, you can then graduate to controlling real robots anywhere in the world.\n\nIf you have a robotic arm that you\u2019d like to connect with, please get in touch with Extend Robotics at (http://www.extendrobotics.com/). (please note that you will need to buy some extra hardware and software to enable tele-control). Extend Robotics are always on hand to offer expert advice.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "ht