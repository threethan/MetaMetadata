AMy8i_uwlimTCH9H7WYnLgA&oe=66E6C2F3"}, {"file_name": "MicrosoftTeams-image.png", "id": "223946769812825", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001726_223946773146158_7772036560979420344_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8vRyiT4sYYUQ7kNvgGNl_II&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYABAp5jPJTAzCLBjahv-m5KidbDjAGsy135SnZEg0XvDg&oe=66E6BE83"}]}, "id": "455427327408675", "locale": "en_US", "screenshots": [{"file_name": "Screenshot (109).png", "id": "505098797308375", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75439600_505098800641708_5486984715524090908_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gwk_AfgH2VoQ7kNvgHa0NcO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYBbjiuSDZ4PB6-84njp3l0rLa7VHBN9XMuz46L0G7E5Iw&oe=66E6D94D"}, {"file_name": "Screenshot (121).png", "id": "232213002328208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_232213005661541_969947023180179234_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m7YjI41TuY8Q7kNvgECMF8B&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYCJit5svFZ9FU92oawFsZUAV69qPQU6FuKz5kP85cLBbA&oe=66E6CC4F"}, {"file_name": "Screenshot (122).png", "id": "744625859827156", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974683_744625863160489_3999024988748835723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Me3BbSCI_NQQ7kNvgGWUPqG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYByzSBFRFT6kDV4X6m8yKI-s9YwFGmxB7mqusiiJqsErg&oe=66E6CD04"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=syyKp7Bu97IQ7kNvgGVrEwg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYC6q4qOS6jgvROKt-TaJGh3Z00iyxqkeIJ0FTzv-ef3rQ&oe=66E6D49C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cmGfB-31laEQ7kNvgEee0AB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYBy45GM1SSgmvqXFo-KFKNvSsEtXMEeHg21jTNGXMZVSQ&oe=66E6C5E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQz38h9Nfn0Q7kNvgG6BSQR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYBgCFoofLxY-SgpRiGXKIG4CCKQVEY_fL77tgUcX7EaPQ&oe=66E6B2F2"}, "display_name": "AMAS AppLab", "keywords": [], "long_description": "Imagine if you could use your own hands to control a robotic arm on the other side of the world. Imagine with the right robotic arm if you could lift up an object larger than a car, or smaller than the tiniest grain of sand, without being physically present.\n\nWelcome to AMAS, the Advanced Mechanics Assistance System. AMAS lets you physically control robotics arms remotely over the internet, using intuitive gestures in an immersive 3D environment.\n\nThe application begins with a tutorial where you learn to control a simulated robotic arm; and record and replay your movements of the robot. When you\u2019ve mastered the simulation, you can then graduate to controlling real robots anywhere in the world.\n\nIf you have a robotic arm that you\u2019d like to connect with, please get in touch with Extend Robotics at (http://www.extendrobotics.com/). (please note that you will need to buy some extra hardware and software to enable tele-control). Extend Robotics are always on hand to offer expert advice.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.extendrobotics.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Extend Robotics", "support_website_url": null, "website_url": "http://www.extendrobotics.com/", "category": "APPS", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "393222478507326"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7355842087854683"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974538_288801626491501_2411136954370111549_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e2kgupP2qyEQ7kNvgHtZ4X-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AChKjzgu5w2QdJc8-yoOgoc&oh=00_AYCd0S_hqOa_qUwcwmFUSXe0zRbdg9T9jWQh25eOttJTAQ&oe=66E6BC64"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "AMAS AppLab", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Productivity", "id": "1063584910766706"}, {"topic_name": "Utilities", "id": "393222478507326"}], "release_date": 1646784000, "lastRevision": {"nodes": [{"id": "384065986750790", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4049436078495317", "is_first_par