25/39001726_223946773146158_7772036560979420344_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bsRagR1lbYIQ7kNvgFe-b0_&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2xyQrOUQE8AVqAYYjbgxSuy4W_iXAQyqinDtGg5XyVA&oe=66ED5603"}]}, "id": "455427327408675", "locale": "en_US", "screenshots": [{"file_name": "Screenshot (109).png", "id": "505098797308375", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75439600_505098800641708_5486984715524090908_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sozleZPOtOUQ7kNvgF845Dg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiOBLFZf0rmvXsDemMn2DR1Aco-mwElLr6_WjWWmtodA&oe=66ED70CD"}, {"file_name": "Screenshot (121).png", "id": "232213002328208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035466_232213005661541_969947023180179234_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jOCLF6KkErEQ7kNvgH1aTee&_nc_ht=scontent.oculuscdn.com&oh=00_AYAexKQLmNMf0eOIsQfLlP0Cas9lMwkd_fqM4qsqEcH_Sg&oe=66ED63CF"}, {"file_name": "Screenshot (122).png", "id": "744625859827156", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974683_744625863160489_3999024988748835723_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_XKmpumsZL0Q7kNvgEefL__&_nc_ht=scontent.oculuscdn.com&oh=00_AYDc26oHz18ChzwSkY0NB_OCC7vPZiPCfGRwe_j450J3FQ&oe=66ED6484"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4day2PeTOYoQ7kNvgFZMwC7&_nc_ht=scontent.oculuscdn.com&oh=00_AYA90oXYGhY1DL00ucMWjO_svSmBhEAJV0l1J7G5Bj_pUQ&oe=66ED6C1C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pSZdPEd6cFUQ7kNvgHimmzq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBexoP_rKMPSgIEQVebIUtEKHRaMlbtKLhbo0Od5GdiTw&oe=66ED5D68"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LtdWGKrSOK4Q7kNvgG46uvB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQoJQKNqBzEPlwYVBMcKOnZcK-5BoDFqNKFoqx4wxgKw&oe=66ED4A72"}, "display_name": "AMAS AppLab", "keywords": [], "long_description": "Imagine if you could use your own hands to control a robotic arm on the other side of the world. Imagine with the right robotic arm if you could lift up an object larger than a car, or smaller than the tiniest grain of sand, without being physically present.\n\nWelcome to AMAS, the Advanced Mechanics Assistance System. AMAS lets you physically control robotics arms remotely over the internet, using intuitive gestures in an immersive 3D environment.\n\nThe application begins with a tutorial where you learn to control a simulated robotic arm; and record and replay your movements of the robot. When you\u2019ve mastered the simulation, you can then graduate to controlling real robots anywhere in the world.\n\nIf you have a robotic arm that you\u2019d like to connect with, please get in touch with Extend Robotics at (http://www.extendrobotics.com/). (please note that you will need to buy some extra hardware and software to enable tele-control). Extend Robotics are always on hand to offer expert advice.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.extendrobotics.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Extend Robotics", "support_website_url": null, "website_url": "http://www.extendrobotics.com/", "category": "APPS", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692