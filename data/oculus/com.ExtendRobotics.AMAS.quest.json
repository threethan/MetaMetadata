37283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_PMxvZLvHdgQ7kNvgEp26tA&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDGR_aaFZMkFusGdjHmln-iZFXZxh7xk2Y1xSmWpbBuKQ&oe=6758359C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KicJP9f6WpwQ7kNvgGDJUmn&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBB_w65Ov2tiTR7jxoB3q15t4doytDW9P6BtJo_ljTSsQ&oe=675826E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3N6wT71I3XIQ7kNvgGGHHT8&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAoXb9PC1SOS2ubfSpbvQwkNZhfGnZBkeEPLbllHTNoPg&oe=675813F2"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor hardware integration contact Extend Robotics.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_priva