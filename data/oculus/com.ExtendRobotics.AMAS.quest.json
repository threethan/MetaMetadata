7283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oXH0BT7eLK8Q7kNvgEYGeKZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABN_KZNFHTXtFmOkOqj3WnWR8j1bqZwY42I03r4V31iw&oe=677FC29C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tWZ_4xu7T5gQ7kNvgGziMoJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAVcs5fPQupZZejwcAspoJPYgrNyLSMGzLdKkYqczN03Q&oe=677FB3E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N8gYlcroFScQ7kNvgF7fWuF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYCq3jN8tB1IXUuzk4elOKki0bv7BucV2SnU1klgz4Xw&oe=677FA0F2"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor hardware integration contact Extend Robotics.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privac