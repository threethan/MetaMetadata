kNvgGfslZs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAEcDEJ5ETBW4FliKaRn1w&oh=00_AYAxs7tBGCUQfQPp_CsC0MGbvCDX0cuiSosZN3w_gfDqEA&oe=66E42A04"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=syyKp7Bu97IQ7kNvgHnGoLG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAEcDEJ5ETBW4FliKaRn1w&oh=00_AYBmS7dJHPja2VFWyuh4yYSO3ejC7ZnZGZ6YYo89eAvwsQ&oe=66E4319C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cmGfB-31laEQ7kNvgEwkPpp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAEcDEJ5ETBW4FliKaRn1w&oh=00_AYAAw9GOTA4jMxBt2r9kvlInF23EYdnXU-P4murg5vQXBg&oe=66E422E8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cobkm1BndA4Q7kNvgHsD8Qv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AZAEcDEJ5ETBW4FliKaRn1w&oh=00_AYAtozLK1uqts7KbWBt8jkstxz6VIXTuf_vtwHilufShaA&oe=66E40FF2"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor 