xbcG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1y-hh4VxmEh7TscgWQuFc&oh=00_AYB6k0aEyoXs4XMmICXJUBD0qih1QhcObAp2xS8k-0zDkQ&oe=66F2AA84"}, {"file_name": "Screenshot (123).png", "id": "441798080794085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031313_441798084127418_6466023488837283457_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjbBS-f02vgQ7kNvgFQURWY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1y-hh4VxmEh7TscgWQuFc&oh=00_AYB5cju7MKzlhHpOjSrJhgB62KnXnSP_XBF2g5U-SIK9Jg&oe=66F2B21C"}, {"file_name": "Screenshot (125).png", "id": "1077642882808314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_1077642886141647_3996924414895117640_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zwzvFsklFe0Q7kNvgFNzLCg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1y-hh4VxmEh7TscgWQuFc&oh=00_AYAg400NQP1W60lnGfE__tbXsivvlbc8kFyq_bsuxrWNZA&oe=66F2A368"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1789612074582758", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_1789612077916091_4846501484232258193_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UM7ytuZlhzEQ7kNvgFMTVFd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AN1y-hh4VxmEh7TscgWQuFc&oh=00_AYBCwAUXAUoNFAEuDfIV_ZDcu-I-JdyDK6BIegxl7UWFrw&oe=66F29072"}, "display_name": "AMAS", "keywords": [], "long_description": "AMAS - Advanced Mechanics Assistance System.\n\nPhysical robot control with intuitive gesture input and immersive 3D perception.\n \nThe application starts in tutorial where you may:\n- experience robotic arm control in simulation\n- record and replay the motion of the digital arm and the interactions\n- connect to physical robots (hardware required)\n- connect to 3D sensors (hardware required)\n \nThe tutorial demoes the principles behind VR control of robotic arm:\n- grasp the end effector of simulated arm\n- move your hand around to move the simulated arm\n- control robotic gripper with Oculus controller\n- interact with simulated objects\n \nFor hardware integration contact Extend Robotics.", "short_description": "This is not a game.\n \nApplication for physical robot control using VR with 3D camera input.\n \nExperience above in simulation without hardware components.\n \nFor hardware integration contact Extend Robotics."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.extendrobotics.com/user-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Extend Robotics", "support_website_url": null, "website_url": "http://www.extendrobotics.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "PRODUCTIVITY", "UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "505132867703208"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "552013372912374"}, {"status": "PUBLISHED", "id": "1049209179271843"}, {"status": "PUBLISHED", "id": "946564399913560"}]}, "baseline_offer": {"id": "552013372912374"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1649800800, "status": "PUBLISHED", "id": "552013372912374"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6552693544836212", "version": "7.3"}, "id": "1173770749698179", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "