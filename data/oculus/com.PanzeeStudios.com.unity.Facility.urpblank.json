25/39031340_1647708676089916_8461424291594965379_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XeTYYa6wdSIQ7kNvgE-fn0j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHerPp2Vi6Zd__UwfIzAS2KKXeprDWVsLoD_c9dxDwBw&oe=674AFF95"}, {"file_name": "Picture 3.png", "id": "453494903768795", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974751_453494907102128_9056554922113121411_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KKPcInvYu0sQ7kNvgHnMznr&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBuEeyusFcXD_50_GiSZGiKsVmYWyOt0XjFnNx7_Mof8Q&oe=674B08CB"}, {"file_name": "Picture 4.png", "id": "1042167284226546", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974792_1042167287559879_6781408860502880089_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N4_LLMz3ftcQ7kNvgE_5kbf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtkeBDtgXUu8-xqZE-fFR-xxl8uiTmAAkhaJSWSG3FxA&oe=674AF83D"}, {"file_name": "Picture 5.png", "id": "1513990049996907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035471_1513990053330240_3673974849952779443_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uvucqgtwB2AQ7kNvgF4qmfy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAyiy1MNpGKHiAkbzk0KOBgb9UMfZOIiQh5dAu6QZg5Og&oe=674B100B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Extinction Facility", "keywords": ["fangame", "gorilla", "monkey", "horror"], "long_description": "Extinction Facility is an immersive VR horror fan game that brings a fresh and terrifying twist to the Gorilla Tag-inspired genre. Set in a dark, sprawling facility, the game draws heavily from chilling inspirations like \"Big Scary\" and \"Scary Baboon,\" creating an atmosphere filled with tension, suspense, and unexpected frights.\n\nThe players navigate through the eerie environment while trying to survive against horrifying creatures. The unsettling design of the monsters, combined with the ominous atmosphere, ensures that every step you take is filled with dread. While the gameplay is rooted in fear, it maintains a sense of fun and excitement, making it as exhilarating as it is terrifying.", "short_description": "Extinction Facility is a VR horror fan game inspired by the eerie and intense vibes of \"Big Scary\" and \"Scary Baboon.\" While it draws from these chilling influences, it offers a unique, heart-racing experience as players navigate through a dark, terrifying facility. The game balances fear and fun, backed by an amazing community that makes the suspenseful adventure worth diving into."}]}, "developer_name": null, "developer_privacy_policy_url": "https://ezra-1-shop.fourthwall.com/pages/privacy-policy-19372f45-86af-40b1-ae25-e3deababc97a", "developer_terms_of_service_url": null, "publisher_name": "PanzeeStudios", "support_website_url": null, "website_url": "https://ezra-1-shop.fourthwall.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "27129942736652609"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1037680018094200"}]}, "baseline_offer": {"id": "1037680018094200"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729712220, "status": "PUBLISHED", "id": "1037680018094200"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27113413788305504", "version": "0.8.0"}, "i