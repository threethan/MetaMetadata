ECmssp&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuKyP7UQftCB35VtYfpF9BV&oh=00_AYB9gQa1xCO7pO5Gu6EcmO1V6uy7Op0DuHlgEE9_MB5Gzw&oe=66E57D1C"}, {"file_name": "migrated_image.png", "id": "523846394990749", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031393_1915025241936151_4470904914679169024_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yM_bpnFwerYQ7kNvgFduIE1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuKyP7UQftCB35VtYfpF9BV&oh=00_AYC6aQz8z7d8fdzV2TTSFUDWwVfMFClAn4oqPQ9cifuLDg&oe=66E586CE"}, {"file_name": "migrated_image.png", "id": "2793770237375662", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974719_557104284812169_3235244043390681088_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nYhm_U_sDYMQ7kNvgFfjS0y&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuKyP7UQftCB35VtYfpF9BV&oh=00_AYDhBO9yK7MxdIOuDTgtrnR6cWf89aTGPZt24vvk5rTroA&oe=66E55ED5"}, {"file_name": "migrated_image.png", "id": "548510542449076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974861_2038196229809514_6481838989559988224_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ewDBnPPFfXoQ7kNvgERLm6q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuKyP7UQftCB35VtYfpF9BV&oh=00_AYBrF009MwXE2IrtEXg9AFpuXoKvT3pdyFslxTZWlfWEtw&oe=66E58856"}, {"file_name": "migrated_image.png", "id": "523695041681100", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982515_1202827069876585_3787854185169420288_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_1wbecdlWpMQ7kNvgHbKysz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuKyP7UQftCB35VtYfpF9BV&oh=00_AYBjlkTvbiqPW-gbVWTZljkCveF-5mhTx47dsHjJ071YgA&oe=66E55D0A"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creed: Rise to Glory - Demo", "keywords": ["free", "games", "best", "demo", "fun"], "long_description": "Experience the pulse-pounding excitement of boxing with the cinematic thrill of a blockbuster movie as you become Adonis Creed, fighting to establish your legacy in the ring and beyond. \n\n\u2022 Live Your Legacy: Challenge both your body and mind as you experience the ascent of Adonis Creed from undiscovered underdog to world-class fighter, all within an immersive universe inspired by the Creed\u2122 films.\n\u2022 Multiple Game Modes: Choose your path to glory in multiple game modes: story-driven Career, customizable Freeplay, or minigame-based Training.\n\u2022 Online PvP: The fight just a lot more personal. Set up custom fights with friends or find your contenders in crossplay Quick Match.\n\u2022 Feel the Impact: Phantom Melee Technology mimics the real-life effects of throwing and taking punches in the ring, such as the out-of-body sensation of getting knocked out or the strain of fatigue during a long, frantic bout.", "short_description": "Do you have what it takes to become a champion? Follow the ascent of boxer Adonis Creed as you go toe-to-toe with the world\u2019s top opponents in this intense, cinematic boxing experience. Featuring new Phantom Melee Technology for impactful VR melee combat, you\u2019ll train, fight, and win like Creed."}]}, "developer_name": "Survios", "developer_privacy_policy_url": "https://survios.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Survios", "support_website_url": null, "website_url": "https://survios.com/creed/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4554096