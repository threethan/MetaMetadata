 nuclear bomb. The series is both informational and inspirational.", "short_description": "A series of immersive documentaries about Kyushu, Japan's third largest island and a vibrant blend of natural wonder and cultural heritage. The experiences include a combination of live 360 video and more fantastical AI built worlds to recreate historical scenes and acknowledge Japan's rich anime culture."}]}, "developer_name": null, "developer_privacy_policy_url": "https://catchreality.co.uk/index.php/kyushu-vr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Catch Reality", "support_website_url": "https://catchreality.co.uk/index.php/kyushu-vr/", "website_url": "https://catchreality.co.uk/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "1283811691952063"}, {"id": "879473995923081"}, {"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7850261341769733"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "453868397385944"}]}, "baseline_offer": {"id": "453868397385944"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728304560, "status": "PUBLISHED", "id": "453868397385944"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7935993406529859", "version": "1.0.0"}, "id": "2551913838314352", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false,