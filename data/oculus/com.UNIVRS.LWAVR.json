acer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P9yzw9xiZhEQ7kNvgEAm51i&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-4CiZWUSIwzx9iO8Vbt5xvQd-vZTxNToEH65WloZzIg&oe=66D70B8E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FhTF13SAxjEQ7kNvgH1BuI1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDP6Q1MNSlIum0uziPyQ51maOHk4XK2ZfmcwYVoMij4Wg&oe=66D6F666"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yqGiBydJUagQ7kNvgHzG7Ca&_nc_ht=scontent.oculuscdn.com&oh=00_AYAuZjAaK0oD8cHkFbajj3tfi5A38XM699aGv9_fQLFZEw&oe=66D6E8B3"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lLf-gvOFt4AQ7kNvgGTSri5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZqT2TmFCOn1WEFkVp73YzLdFXKYU8oL9UiCuJUls8MQ&oe=66D6F8CF"}, {"file_name": "HERO_JP_202012.png", "id": "136977781532024", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_136977784865357_8309174075716611938_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HdmyI2Rw7k8Q7kNvgGMP55F&_nc_ht=scontent.oculuscdn.com&oh=00_AYADUa23-g5pc-tE9ZnRu96OmRKj3OPSayJZh2NHkpCD_A&oe=66D70E92"}, {"file_name": "Icon_512x512.png", "id": "359642228386793", "imag