-3.oculuscdn.com&oh=00_AYDYHYz4x28U63V1stGNRVfkG0HK5WHxVgm413ndvYSi-g&oe=67583231"}, {"file_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8MODAtPuDX0Q7kNvgHt8zZb&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCbhPYfXaKukSLzyliVkGfGLg6GKU5yd5Y9L2eBw-R1Rg&oe=6758312B"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oTFFJWgALJwQ7kNvgGuPv-F&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD3fAdjNsJQEmKRXOrq32JhXfP_Nzu2baAm8iybp9UpUA&oe=67583C6F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0MbZJPZ9DPUQ7kNvgGSllGU&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBRLUvMWgTBqaKgLS5IMAty4i0Dox8fvpp7HxjIUdPHow&oe=675840AF"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XnvXhVEQxnAQ7kNvgHaKP7K&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYC--lnazEtIPxqSkRdeCmeQxE0gqR8OwVy5LjEqbGnACw&oe=67583E8E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=28G1LfTJwCoQ7kNvgHPkR5T&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAbCumHKFHwWE7DFrKiMiQtqMO8bDRATcwrEKrsh6ThDA&oe=67582966"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WRRkEmhq91MQ7kNvgELMQLx&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD2uSvywLXrZ-P_cJox9BX98r6EUJU5nMDwsWnh5UKVZg&oe=67581BB3"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MVBudQexE18Q7kNvgH1K4JD&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAekgn4ZXFEaMTZ0ixXJpXibHoFaOZDLoOkOMhD6TWfxg&oe=67582BCF"}, {"file_name": "HERO_JP_202012.png", "id