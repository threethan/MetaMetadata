tiplayer and take in the sights of the world of Little Witch Academia will be added with the November Update.\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Take to the skies on a magical broom in the VR racing game based on the Little Witch Academia anime! Enjoy an original Little Witch Academia story with Akko and her friends. "}]}, "developer_name": "UNIVRS, Inc.", "developer_privacy_policy_url": "https://lwa-vr.com/privacy-policy/", "developer_terms_of_service_url": "https://lwa-vr.com/terms-of-use/", "publisher_name": "UNIVRS, Inc.", "support_website_url": "https://lwa-vr.com/", "website_url": "https://lwa-vr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "673385183287495"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "FLYING", "RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2129959183821549"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "4614031451981039"}, {"status": "PUBLISHED", "id": "760684374779863"}]}, "baseline_offer": {"id": "760684374779863"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1635181200, "status": "PUBLISHED", "id": "4614031451981039"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3997751140329505", "version": "1.3.0"}, "id": "293680851597364", "channel_name": 