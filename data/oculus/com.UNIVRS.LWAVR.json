-2.oculuscdn.com&oh=00_AYDhMQBGTi6UyUzFMVaXnmslz484w68OfEJTBP0sTo3qzg&oe=672F53B1"}, {"file_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R3jhQEO5FyEQ7kNvgF6-pk4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAG7HhEv0jl9vJ_LKWnAgBbFR9VkmnUaMrYdHoZ-oYfSg&oe=672F52AB"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gc-5YVXbtSgQ7kNvgG5g-z3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBH638hCvJEnjXmwKiiYcNJ9wNkR9MengtBSI1L936-bA&oe=672F5DEF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P9caMf0HI80Q7kNvgFmfp7x&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEbNAcRen2lDol29_Fii6aIQhGPAw_0zH4kMphdfrGxA&oe=672F622F"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UCv7BCytTCIQ7kNvgHpGDIe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCo5dB_QJUzRjBNACVW9Ckb_YvGez8H4SyUY2aH4Qgy9Q&oe=672F600E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N6aw38_L5WAQ7kNvgEdLxF9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjypIXEWNbrTiVpEO44KdCH0fHUXe0P1nFDM6vbEmjWg&oe=672F4AE6"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AfLJy1bObUQ7kNvgGU0Fo8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfNliVIq7TbKJG7bS-WMtWc5K8aR4XM2mTFSVNKvpILw&oe=672F3D33"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=75Aw4ao5pW0Q7kNvgFegHwC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKI3QGTxuhYczxdiKRGuRm3s4pVv7Rv3g1KowghY-Tcg&oe=672F4D4F"}, {"file_name": "HERO_JP_202012.png", "id