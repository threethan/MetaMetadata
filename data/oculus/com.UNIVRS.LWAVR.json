e_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9bOOb8q5TpwQ7kNvgEO2Km1&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBWyurV0OJtYhe9VDM4ibwiASw7r7t8xw_7bBFLtWK0kw&oe=670FAEAB"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j_bGLtlAXZ8Q7kNvgEcvi8H&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAAxx2AFcDawPTaY-Qi_LZMuXBk598-BQKnLhfeEaagDg&oe=670FB9EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8uro6p6ukYYQ7kNvgH4ACCG&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBYsARxShgcMPtvnMO4oWtS5yHUHWYKMgxRU4MWOl43aw&oe=670FBE2F"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZiVhXSIaey4Q7kNvgFi_b4o&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBophxB-Soyk8xJn-Mj0tPmjcVT5JhI9rBfvKPCiIfbcA&oe=670FBC0E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xaSJa4HK0mwQ7kNvgHMXUWK&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBqlVRd_j_1PuWSkSEol3oiZIQKXhsGWkedU-P0r1-IAg&oe=670FA6E6"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rVgFTeJ_lB0Q7kNvgESt0gv&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAu99LtvEA7iFF6X2i26VhDtpB6I_u73nXyWseOt6ujEQ&oe=670F9933"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_3yqSuDmO5cQ7kNvgGUog4H&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCMK9I_wy8MlGaH_1oA9bytx4HSyFJX_-2vZKxktN3HIQ&oe=670FA94F"}, {"file_name": "HERO_JP_202012.png", "id": "136977781532024", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974450_136977784865357_8309174075716611