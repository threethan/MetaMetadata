-1.oculuscdn.com&oh=00_AYC1J7ASIJJ8jOXfUmsMMXiZ7bNxP-iYZC4InxIhdLR4Iw&oe=673499B1"}, {"file_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mKxpndKGS7EQ7kNvgEWrJ2e&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB66D-uS3kDCn2vUqOeRut86lBovFmnDug7uhpxCA4Cbg&oe=673498AB"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oZCxv6WhNqwQ7kNvgHToKBT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDM__-MIOUmVdujYR2euQT98Hbh5EvMKFmFas5dQUbLZA&oe=6734A3EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Fve4m7Lhh0Q7kNvgHx60D1&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCsZOi84RKkUoPixsFAiuMj0mOmHkc1sRFzAohJbFVs0w&oe=6734A82F"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=04CX6EPDfA0Q7kNvgGBd2Mr&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCc0WDL2mf6mkCKIXr7zLolOf8AtfoVCl1jyvVZOTSqoQ&oe=6734A60E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IZv2Mric22MQ7kNvgHeOR73&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAkIUYUU58NHfq0-B-djt32Z9RHQ8mMJwV1yCXjl-M2Zw&oe=673490E6"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AXchoDPY2JQQ7kNvgETkSTB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAKS2Wa8hZ-a3NYksULbsjSsjQvNKuJG5ZBelNck_rRsw&oe=67348333"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y3MM12sAogoQ7kNvgFJPQGW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDXFykagKKXq_-W9jK9WkvlqRbSN3MSrMJgEdA1qrbd2Q&oe=6734934F"}, {"file_name": "HERO_JP_202012.png", "id