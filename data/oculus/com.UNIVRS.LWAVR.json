-2.oculuscdn.com&oh=00_AYAU-6GaEwQiGoRAghsHU5fej3uHrnLmCZmjSnPdGhJvyQ&oe=6718EA31"}, {"file_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFp5rdbP1FsQ7kNvgHwUryA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrCsMLuHD_SEl82xvr86-CtRTd7rBpZQwA4dD2YJPHqg&oe=6718E92B"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yqP3k5KjIjUQ7kNvgEP9PH5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnMFHRXCciOJ45C8ALh_UB_2MKHlcfdb6DoXn3W4zAZg&oe=6718F46F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Grod4Ox2F2AQ7kNvgEmSiil&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDm_-ifO4uHxyWqmJgOT7Cu6NrvvddVP21kTWRWeyXXmg&oe=6718F8AF"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uybfpRaK-L0Q7kNvgFp28mA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUv1uUKtUNWkrPKMm7e99nLAY2p6W2_KQmH1IoWURLOQ&oe=6718F68E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u7ziSHXXQFkQ7kNvgEGC8-5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCfufUNApsZ1THN8qR89FgjuvTLWEGoyc8U46zWffXqsQ&oe=6718E166"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uJWUYywU9sgQ7kNvgFZ3p9G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBpQQiT2BJeBwtd1PqgGu5761ikbJ9JLymLRcR5uceQsA&oe=6718D3B3"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_1GgWUuPnHsQ7kNvgEOu-hf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHYbo4t2vYAKjvquXgNSXWodctHcRFkfY2oPrlrNPVbA&oe=6718E3CF"}, {"file_name": "HERO_JP_202012.png", "id