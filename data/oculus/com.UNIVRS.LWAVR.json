-2.oculuscdn.com&oh=00_AYBsX4UXCffVQ68oqsqMbeXbJEq9EqwQRE_JTS-l0BUVpA&oe=6731F6B1"}, {"file_name": "LWAVR_SS_v2_Broom-Selection_EN.png", "id": "481612919484138", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572918_481612926150804_4447341486731504408_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ABnorefo9AQ7kNvgGALXxp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrewjArHRuVczDYBG8CfJ7KYCfNM06w3ypRC2HXuMiiA&oe=6731F5AB"}, {"file_name": "LWAVR_SS_v2_RaceResult_EN.png", "id": "3719234578120529", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569425_3719234581453862_2231910023601147922_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oZCxv6WhNqwQ7kNvgFqU3YO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwVOaPFq_j4DtTXI6CWHpGBrEYebRw1XgqgUaaaiXPmA&oe=673200EF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape_EN_202012.png", "id": "5020676941307271", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974864_5020676947973937_8734171976397690593_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Fve4m7Lhh0Q7kNvgFuet6v&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCv4-NdMHze8_FJYVGbVG6Iv62Nv-U6fqUcJeMon-o4Fg&oe=6732052F"}, "display_name": "Little Witch Academia: VR Broom Racing", "keywords": ["racing", "magic", "flying", "witch", "anime"], "long_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\nEnroll at the prestigious Luna Nova Witchcraft Academy and compete with your fellow student witches to win the prestigious Stella Cup.\n\nExperience the thrill of flight across more than a dozen tracks! Cast magic to speed up and slow other teams down as you race to finish first! Purify the school\u2019s restless spirits in special ghost hunting missions.\n\nUse rewards from winning races and completing missions to buy new brooms, enhance your magic powers, and find the best combination to become the top student!\n\nPlay with the other users in online multiplayer and take in the sight of the world of Little Witch Academia together! \n\n\n\u00a9 2017 TRIGGER / Yoh Yoshinari / \"Little Witch Academia\" Committee \u00a9 UNIVRS, Inc.", "short_description": "Soar through the skies, hunt for ghosts, and become the best witch racer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UCv7BCytTCIQ7kNvgFDgNHB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYNCpdF46NiMpV6NY63qdBIowYamVmJ35e4fCrwz5KuQ&oe=6732030E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N6aw38_L5WAQ7kNvgHH-Js0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBKc6Dazl1ZicHp-nxFygvSxxRHqP7TKAxnrR5sNqb58A&oe=6731EDE6"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AfLJy1bObUQ7kNvgFfJNca&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAm2m1pUnzLS17iki4HnU0nqMNXXtx0RZQhwsdSBa2ejw&oe=6731E033"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDphqfJGTf0Q7kNvgFfjfDx&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCHf2JrefecY2e6s4g6fTKoS6wpEam154e0g1GtFcyR_Q&oe=6731F04F"}, {"file_name": "HERO_JP_202012.png", "id