acer in the world!\n\n\u00a9 2017 T/YY/LWAC   \u00a9 UNIV"}, {"images": {"nodes": [{"file_name": "Squere_JP_202012.png", "id": "1327244154279833", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982648_1327244157613166_2961322866020914640_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8rwik9dse64Q7kNvgEZpnFJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRDxfYIUS8Uam1LkHXBvzwWyWA9qaq-WfGJKdnnp_A6g&oe=66CB2E0E"}, {"file_name": "mini_JP_202012.png", "id": "767739813819324", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974453_767739817152657_5763260574459999295_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bnSrB5XmdncQ7kNvgHu5aT8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPLQj87Ap8m0iPXOELl18f35EYsV5v0tTbq8-7q9Xn6Q&oe=66CB18E6"}, {"file_name": "Portrait_JP_202012.png", "id": "687368831924916", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974557_687368835258249_3301610840483328822_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7dT63IqHUTgQ7kNvgGh8_WF&_nc_ht=scontent.oculuscdn.com&oh=00_AYBor384dUE6w1PgGZ_53Cp6xwNv_WVUhFyXLmm99wiSwA&oe=66CB0B33"}, {"file_name": "Landscape_JP_202012.png", "id": "210773470635130", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001687_210773473968463_5238021041892551677_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6QL_ZkzgATEQ7kNvgGFDDEQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCzX6zUauqt1zzMbqm5JtUUYAnPoW3qMui7IihU34CZWQ&oe=66CB1B4F"}, {"file_name": "HERO_JP_202012.png", "id": "136977781532024", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974450_136977784865357_8309174075716611938_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O_NNx_ItcxAQ7kNvgEKh0L9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDC_C13KLJi4ksfyAk73uUHUXccrcRYJ5Ll0IDciL0ANw&oe=66CAF8D2"}, {"file_name": "Icon_512x512.png", "id": "359642228386793", "imag