le_name": "migrated_image.png", "id": "1077023719325156", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/11162741_213309465866648_4741737525071052800_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o4CtenP2RfYQ7kNvgEjX8wi&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBi5M2p45WPJ3atk6OJvULdDSVxo9x3lrct7PlHv2ji-w&oe=673091C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Store-cover-art-Landscape.png", "id": "2041597679394765", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/11162695_2041597682728098_4684482690437611520_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_kS_lGm3hUQ7kNvgHJhUcU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDUPr8umxdxNXFeujuCX4nDKy_KOZMvdNx840j8BOvX1g&oe=67308AE6"}, "display_name": "Space World", "keywords": ["SpaceWorldvr", "SpaceWorld", "solarsystem", "Universe"], "long_description": "Depart to unlimited Universe.\nUpon wearing VR gear, you can depart to Universe.\n\nObserve and move to Universe and planets in the solar systems including Earth wearing a space suit.\nYou can see Sun, Mercury, Venus. Earth, Moon, Mars, Jupitor, Satune, Uranos, Neptune and other asteroids and meteorites.\n\nGame operation\nThis game uses touch pad and eye tracking of VR gear.\nThis game uses the eye tracking for direction choice.", "short_description": "Wearing a VR gear and watch solar system as an astronaut.\nLook roud planets using a space suit.\nExperience and study Universe."}, {"images": {"nodes": []}, "id": "203404110927922", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "\uc6b0\uc8fc\uc138\uc0c1", "keywords": ["\uc6b0\uc8fc\uc138\uc0c1vr", "\uc6b0\uc8fc", "\ud0dc\uc591\uacc4"], "long_description": "\ubb34\ud55c\ud55c \uc6b0\uc8fc\ub85c \ub5a0\ub098\uc2ed\uc2dc\uc624.\n\ub2f9\uc2e0\uc740 VR\uc744 \uc4f0\ub294 \uc21c\uac04 \uc6b0\uc8fc\ub85c \ub5a0\ub098\uac8c \ub429\ub2c8\ub2e4.\n\n\uc9c0\uad6c\uac00 \uc788\ub294 \ud0dc\uc591\uacc4\ub97c \uc6b0\uc8fc\ubcf5\uc744 \uc785\uace0 \uc774\ub3d9\ud558\uba70 \uc6b0\uc8fc\uc640 \ud589\uc131\uc744 \uad00\ucc30\ud574 \ubcf4\uc138\uc694.\n\ud0dc\uc591, \uc218\uc131, \uae08\uc131, \uc9c0\uad6c, \ub2ec, \ud654\uc131, \ubaa9\uc131, \ud1a0\uc131, \ucc9c\uc655\uc131, \ud61c\uc655\uc131\uacfc\n\uadf8 \uc678 \uc18c\ud589\uc131, \uc6b4\uc11d\ub4e4\uc744 \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc6b0\uc8fc\ubcf5\uc758 \uae30\ub2a5\uc744 \ud65c\uc6a9\ud558\uba74 \ud589\uc131\uc758 \uad00\ucc30\ud558\uc138\uc694.\n\ud589\uc131\uc5d0 \ub300\ud55c \uac04\ub2e8\ud55c \uc124\uba85\ub3c4 \ubcfc \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n* \uac8c\uc784\uc5d0 \ub4f1\uc7a5\ud558\ub294 \uc8fc\uc694 \ud589\uc131\n\ud0dc\uc591, \uc218\uc131, \uae08\uc131, \uc9c0\uad6c, \ub2ec, \ud654\uc131, \ubaa9\uc131, \ud1a0\uc131, \ucc9c\uc655\uc131, \ud61c\uc655\uc131, \uba85\uc655\uc131, \uadf8\uc678 \uc18c\ud589\uc131\uacfc \uc6b4\uc11d\n\n* \uac8c\uc784\uc870\uc791\n\ubcf8 \uac8c\uc784\uc740 GearVR\uc758 \ud130\uce58\ud328\ub4dc\uc640 \uc2dc\uc120\ud2b8\ub808\ud0b9\uc744 \uc0ac\uc6a9\ud569\ub2c8\ub2e4.\n\ubcf8 \uac8c\uc784\uc740 \uc2dc\uc120\uc744 \uc774\uc6a9\ud558\uc5ec \uc120\ud0dd\ud558\ub294 \ubc29\ubc95\uc744 \uc0ac\uc6a9\ud569\ub2c8\ub2e4.", "short_description": "VR\uc744 \ucc29\uc6a9\ud558\uace0 \uc6b0\uc8fc\uc778\uc774 \ub418\uc5b4 \ud0dc\uc591\uacc4\ub97c \uad6c\uacbd\ud558\uc138\uc694.\n\uc6b0\uc8fc\ubcf5\uc758 \uae30\ub2a5\uc744 \uc774\uc6a9\ud558\uc5ec \ud589\uc131\uc744 \ub3cc\uc544\ubcf4\uc138\uc694.\n\uc6b0\uc8fc\ub97c \uccb4\ud5d8\ud558\uace0 \uacf5\ubd80\ud558\uc138\uc694."}]}, "developer_name": null, "developer_privacy_policy_url": "http://einpictures.co.kr/cms/bbs/content.php?co_id=provision", "developer_terms_of_service_url": "http://einpictures.co.kr/cms/bbs/content.php?co_id=provision", "publisher_name": "eiNpictures", "support_website_url": null, "website_url": "http://www.einpictures.co.kr/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comf