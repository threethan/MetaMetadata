3654061", "locale": "en_US", "screenshots": [{"file_name": "Screenshot_Denture_care_SS_01.png", "id": "1129420498781233", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39031647_1129420502114566_7797351096586524855_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d6l50W93iz4Q7kNvgEtDA7K&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYB9nkGtWg5H7VOpHxXIwRa1_r-3R7dppU_pyggsNSVSsw&oe=6787ACDC"}, {"file_name": "Screenshot_Denture_care_SS_02.png", "id": "600228952535565", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974582_600228955868898_6732249895982997807_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ifI6nFG4ZdgQ7kNvgF3cgNa&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDLd1wABv0x4Qgczsg0jgp-WRWBr1LDz6R9TkkofgGQCA&oe=67879297"}, {"file_name": "Screenshot_Denture_care_SS_03.png", "id": "875518378124719", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/86659795_875518381458052_7759255826766159598_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1dfGi-Ic-30Q7kNvgHyDH2j&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBh3mHyQlNAy1hIpHtdpbcEY7OkLrnLhnq4Rw-trGpR8A&oe=67879840"}, {"file_name": "Screenshot_Denture_care_SS_04.png", "id": "27724867150494724", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39001663_27724867157161390_4548887320702482461_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ki2q6W-550QQ7kNvgFaJhr8&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBfeAWgiZmi2EHgW-O9YFmhnpes9ESj_MZ7a3WVRJN3Sg&oe=6787A202"}, {"file_name": "Screenshot_Denture_care_SS_05.png", "id": "1131592008595757", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035447_1131592011929090_1231757135431009187_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eg3piwyurIAQ7kNvgEEAeMK&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDugHeImJ3C9E-rrkbeZZ_PGbdU2RBsXqF1lAe6U5OIzw&oe=6787AA92"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot_Denture_care_SS_04.png", "id": "947685033485616", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974842_947685036818949_1456140317117615991_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KAJrEenUUaYQ7kNvgFbMjzV&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDxhuReyffsDuS1HSZwAhIGCWW0DJPbY6jXDth-z2OUyg&oe=6787B300"}, "display_name": "Denture Care Simulator", "keywords": ["denture", "vr", "simulator", "CNA", "dentist"], "long_description": "This VR simulation teaches the essential skill of cleaning upper or lower dentures, focusing on hygiene and patient comfort. The tutorial includes preparation, communication, denture removal, cleaning, and reinsertion.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n By the end of this tutorial, participants will be able to: \n- Remember the steps and safety protocols for cleaning dentures. \n- Understand the importance of maintaining proper oral hygiene for patients with dentures. \n- Apply the correct techniques for removing, cleaning, and reinserting dentures. \n- Analyze the condition of the dentures and the oral cavity to provide appropriate care. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a hygienic and comfortable experience for patients during denture cleaning. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the proper technique for cleaning upper or lower dentures to ensure patient oral hygiene and comfort with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9545925298768315"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/86661277_1127026168983939_808792631297541421_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aW2UDumYopIQ7kNvgEb2Em9&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAp8aIZ0XtdGMByjPVAOCq5y7KOzA7LIWn_kddETdKBAw&oe=6787A626"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Denture Care Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1725345000, "lastRevision": {"nod