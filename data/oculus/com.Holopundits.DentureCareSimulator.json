0565077318_3715358503935570332_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pEYAo-Y0DLQQ7kNvgHYRhfL&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBPkwZAORnwnV5qVb-FJpbkORDFhMZaPAdDclCQ1ururA&oe=671247A9"}, {"file_name": "Screenshot_Denture_care_SS_03.png", "id": "1049190563227605", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75556281_1049190566560938_413158407590428633_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ITekt4-yIoYQ7kNvgFmGlC_&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBodM4DHQMhaQ5t90-PW0hx6mtZ3cHC29tQ33s0QWCI_Q&oe=671237E7"}, {"file_name": "Screenshot_Denture_care_SS_04.png", "id": "390341390760079", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38984474_390341394093412_8123740890310372371_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DQZgEYKQ3YkQ7kNvgFPrT0I&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCyccLcBCi1wPE7erDoiea-wAGOfk0QiKlOO1eCsOipUw&oe=671260BD"}, {"file_name": "Screenshot_Denture_care_SS_05.png", "id": "532050912599107", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39003266_532050915932440_7858627279682767410_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WqfwuArPrYQ7kNvgET8hjv&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCJ0Wt_W0lkgcg55kdg2EKRux0oSfk8CjOj6AIcIuyFXQ&oe=6712613C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "897456102209936", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982716_897456105543269_5076105286420963898_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0lcF5bVerhYQ7kNvgGyhj40&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBJnedzZaGSEwhN40cuM5mePYXNENkH3VEp-Wg9SdrESg&oe=671239A5"}, "display_name": "Denture Care Simulator", "keywords": ["denture", "vr", "simulator", "CNA", "dentist"], "long_description": "This VR simulation teaches the essential skill of cleaning upper or lower dentures, focusing on hygiene and patient comfort. The tutorial includes preparation, communication, denture removal, cleaning, and reinsertion. By the end of this tutorial, participants will be able to: \n- Remember the steps and safety protocols for cleaning dentures. \n- Understand the importance of maintaining proper oral hygiene for patients with dentures. \n- Apply the correct techniques for removing, cleaning, and reinserting dentures. \n- Analyze the condition of the dentures and the oral cavity to provide appropriate care. \n- Evaluate their technique to ensure it adheres to best practices and safety standards. \n- Create a hygienic and comfortable experience for patients during denture cleaning. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with proper care efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn the proper technique for cleaning upper or lower dentures to ensure patient oral hygiene and comfort."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8778953515465501"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982549_1040144037601256_5