/t64.5771-25/38974677_1792974031091569_2627110454405493041_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WYIAaAhR1QQ7kNvgFx-iyI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAT9XNxJEcoj52yuRrKzBOdq7jeO7HhsL1CmcXHNGxQcw&oe=66CB20CE"}, {"file_name": "12533893_1868211036810456_1413905441456390144_n.png", "id": "283953866563712", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031316_283953869897045_3790473181351733818_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qzkRIw8Ld9oQ7kNvgHJg1vQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkSUVE0pkdd_Rtz0x2ZA-1wljPqsCInrXeBJjm-aEpsQ&oe=66CB1BE9"}, {"file_name": "12410280_2092372077716159_929760415565479936_n.png", "id": "4363577010425172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_4363577017091838_5914970981483448679_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cZG82GxkzfcQ7kNvgEclF6J&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrjOOukX6LhtyzF3AdD5TC79GXGd05WD1v_oERzZ_irQ&oe=66CB0200"}, {"file_name": "12331069_160468287993322_5972463010785001472_n.png", "id": "438337284255288", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001713_438337290921954_707755681439087945_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=azD6c9USJsAQ7kNvgElBLxw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDztz_3jonY2tuA-QiErlGkEQYyHWFiJfLjpxt6jzG1Rg&oe=66CAFE4C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "12410440_161187991252513_7573761693591797760_n.png", "id": "443504130284780", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982708_443504133618113_6202141701920609476_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iw-FOuyi0n4Q7kNvgF9zNl6&_nc_ht=scontent.oculuscdn.com&oh=00_AYCz-FuKTqun7yOpUTgrp2D2DnYcz89V8paBtUbpI2QNgA&oe=66CB1B1B"}, "display_name": "TrainerVR", "keywords": [], "long_description": "TrainerVR is a unique physics-based VR train construction game.\nIn TrainerVR you can create from simple tracks to an elaborate rail network, just like the wooden piece game, but to the infinity and beyond, and drive the trains inside your creations!\n\nHave you ever feel the despair of running out of tracks just when the fun was sparkling?\nHave you ever dreamed about a huge train network connecting towns, going  up and down, intersecting and looping?\nIf you liked building with your own bare hands, you\u2019ll feel the same in our limitless VR world and see your dreams come true.\n\nBut this is not only about the destination; it's also about the journey. Enjoy building your structures, growing more complex, while fighting against Newton\u2019s laws.\n\nOnce the job is done you can place as many trains as you want and ensure everyone\u2019s safety avoiding crashes acting like a profesional train traffic controller.\n\nOnce you go track you can't go back. Come aboard!", "short_description": "TrainerVR is a unique physics-based VR train construction game.\nIn TrainerVR you can create from simple tracks to an elaborate rail network, just like the wooden piece game, but to the infinity and beyond, and drive trains inside your creations!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sumalab.com/trainervr/eula.html", "developer_terms_of_service_url": "https://sumalab.com/trainervr/eula.html", "publisher_name": "Sumalab", "support_website_url": null, "website_url": "http://sumalab.com/#work_trainervr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "es", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1207629852978572"}, "revie