.oculuscdn.com&oh=00_AYAxyVPDfePm_OrlvCCtBvWFxke9i6H-pu9rmn3OVC3dhA&oe=6729FD30"}, {"file_name": "fess2.png", "id": "1573146119940717", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75530717_1573146123274050_4310339754583532284_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dmk4NTuAP64Q7kNvgGq9Epu&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCdlo5kEJ8O9uxnXxrOgxq3zSZ7sydxhHbqWAHStINpFA&oe=672A03EA"}, {"file_name": "ss5.png", "id": "477555264958134", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75375751_477555268291467_2374736760519112248_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_YhufoxKHEQ7kNvgG3nG2q&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYClgUVR6xKfdo2JHw0CQv1E_tTHD7u-qvc_S8xwhxOK_w&oe=6729FD22"}, {"file_name": "fess3.png", "id": "832451812223411", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982491_832451815556744_6666122954197467457_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQqAPJAe1KgQ7kNvgFUyFY5&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCgzbzCeDD65RQVxKzfrdy6-rp6i_ucF5Eof-9dMrblNQ&oe=672A2302"}, {"file_name": "fess4.png", "id": "937590288172907", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75608442_937590291506240_1781024231375164692_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hqGxVjrgXR4Q7kNvgGrQKpn&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDlKELjuxA75wAIAQ6gCJbzrmqIM1ctrgO492Ck7SdzTw&oe=672A1250"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "offfeland.png", "id": "1474104146612822", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974903_1474104149946155_2671951907265698351_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A3Y99PvQy1cQ7kNvgFuR4_I&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDXvHqy2tHbbxud0VKdlZaIHvQCqcH-JQBD51ca9tymPw&oe=672A2152"}, "display_name": "Frenzy Extinction", "keywords": ["Frenzy", "Zombies", "Shooter", "Extinction", "Multiplayer"], "long_description": "The Frenzy Virus has mutated, unleashing a new wave of chaos. You and your team must now confront hordes of \"The Ridden\" in Frenzy Extinction. Immerse yourself in a fast-paced, action-packed VR experience where survival hinges on your ability to adapt, upgrade, and overpower relentless enemies.\n{884670816818563}\n# Key Features:\n**Intense Horde Survival Gameplay**\n\nEngage in thrilling, physics-based combat against waves of mutated monsters. Each enemy is designed with unique abilities and behaviors, keeping you on your toes as you fight for survival.\n{874210834178242}\n**Upgrade and Customize**\n\nCollect Necronium from defeated enemies to upgrade your gear, unlock new areas, and enhance your abilities with powerful perks. \n{1360911605312518}\n**Diverse and Immersive Maps**\n\nExplore 10 maps, each with its own atmosphere and challenges. Survive in desolate cities, eerie forests, and more! \n{1223888265699744}\n**Epic Boss Battles**\n\nFace off against formidable bosses throughout each map. These fights will test your skills and teamwork as you survive their special abilities. \n{1040387070873437}\n**Multiplayer Mayhem**\n\nTeam up with up to 3 friends in seamless co-op multiplayer. Strategize and cooperate to defeat the hordes, share loot, and defeat the boss to extract. \n{1432121080833086}\n**Progression and Customization**\n\nGather scrap, a permanent currency, to unlock new weapons and upgrades at your home base. Persistently enhance your character across play sessions, becoming stronger and more versatile with each run.\n\n\n\n", "short_description": "The Frenzy Virus has mutated. Now, you and your team must defeat hordes of \"The Ridden\" in Frenzy Extinction! Survive waves of mutated monsters as your team upgrades their gear, powers up with custom abilities, and races to extract after defeating the elite bosses. Using physics-based combat and dismemberment, take on tons of maps with 50+ unique weapons. "}]}, "developer_name": "Innoverse Ltd", "developer_pri