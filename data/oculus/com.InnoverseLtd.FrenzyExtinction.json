t=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCdlo5kEJ8O9uxnXxrOgxq3zSZ7sydxhHbqWAHStINpFA&oe=672A03EA"}, {"file_name": "ss1.png", "id": "474136575300959", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38982676_474136578634292_2367709692022450363_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQnwuvtKuD4Q7kNvgFylx0a&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAxyVPDfePm_OrlvCCtBvWFxke9i6H-pu9rmn3OVC3dhA&oe=6729FD30"}, {"file_name": "fess3.png", "id": "832451812223411", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982491_832451815556744_6666122954197467457_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VQqAPJAe1KgQ7kNvgFUyFY5&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCgzbzCeDD65RQVxKzfrdy6-rp6i_ucF5Eof-9dMrblNQ&oe=672A2302"}, {"file_name": "fess4.png", "id": "937590288172907", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75608442_937590291506240_1781024231375164692_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hqGxVjrgXR4Q7kNvgGrQKpn&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDlKELjuxA75wAIAQ6gCJbzrmqIM1ctrgO492Ck7SdzTw&oe=672A1250"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Frenzy Extinction", "keywords": ["Frenzy", "Zombies", "Shooter", "Extinction"], "long_description": "The Frenzy Virus has mutated, unleashing a new wave of chaos. You and your team must now confront hordes of \"The Ridden\" in Frenzy Extinction. Immerse yourself in a fast-paced, action-packed VR experience where survival hinges on your ability to adapt, upgrade, and overpower relentless enemies.\n{884670816818563}\n# Key Features:\n**Intense Horde Survival Gameplay**\n\nEngage in thrilling, physics-based combat against waves of mutated monsters. Each enemy is designed with unique abilities and behaviors, keeping you on your toes as you fight for survival.\n\n**Upgrade and Customize**\n\nCollect Necronium from defeated enemies to upgrade your gear, unlock new areas, and enhance your abilities with powerful perks. \n\n**Diverse and Immersive Maps**\n\nExplore 10 maps, each with its own atmosphere and challenges. Survive in desolate cities, eerie forests, and more! \n\n**Epic Boss Battles**\n\nFace off against formidable bosses throughout each map. These fights will test your skills and teamwork as you survive their special abilities. \n\n**Multiplayer Mayhem**\n\nTeam up with up to 3 friends in seamless co-op multiplayer. Strategize and cooperate to defeat the hordes, share loot, and defeat the boss to extract. \n\n**Progression and Customization**\n\nGather scrap, a permanent currency, to unlock new weapons and upgrades at your home base. Persistently enhance your character across play sessions, becoming stronger and more versatile with each run.\n\n", "short_description": "The Frenzy Virus has mutated. Now, you and your team must defeat hordes of \"The Ridden\" in Frenzy Extinction! Survive waves of mutated monsters as your team upgrades their gear, powers up with custom abilities, and races to extract after defeating the elite bosses. Using physics-based combat and dismemberment, take on 10 maps with 50+ unique weapons. "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "http://clique.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages