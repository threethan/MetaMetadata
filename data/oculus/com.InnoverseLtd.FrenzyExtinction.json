DMQborzqYPytgtlV0Hj-fjQhg5dcZqyPDqLuhCy7XTxA&oe=67694530"}, {"file_name": "fess3.png", "id": "832451812223411", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982491_832451815556744_6666122954197467457_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMbSfghg-G8Q7kNvgG5qP0Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaifz_zyp28lFYSARASUG8UY19ZD8_YgAts5-MhbMmjA&oe=676932C2"}, {"file_name": "fess4.png", "id": "937590288172907", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75608442_937590291506240_1781024231375164692_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DLHLu9bF1o4Q7kNvgHGBIjN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDc3NeWchPn11JTzZNqjPusgfwYXNhjdTkfZ2LWpypA1A&oe=67695A50"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Frenzy Extinction", "keywords": ["Frenzy", "Zombies", "Shooter", "Extinction"], "long_description": "The Frenzy Virus has mutated, unleashing a new wave of chaos. You and your team must now confront hordes of \"The Ridden\" in Frenzy Extinction. Immerse yourself in a fast-paced, action-packed VR experience where survival hinges on your ability to adapt, upgrade, and overpower relentless enemies.\n{884670816818563}\n# Key Features:\n**Intense Horde Survival Gameplay**\n\nEngage in thrilling, physics-based combat against waves of mutated monsters. Each enemy is designed with unique abilities and behaviors, keeping you on your toes as you fight for survival.\n\n**Upgrade and Customize**\n\nCollect Necronium from defeated enemies to upgrade your gear, unlock new areas, and enhance your abilities with powerful perks. \n\n**Diverse and Immersive Maps**\n\nExplore 10 maps, each with its own atmosphere and challenges. Survive in desolate cities, eerie forests, and more! \n\n**Epic Boss Battles**\n\nFace off against formidable bosses throughout each map. These fights will test your skills and teamwork as you survive their special abilities. \n\n**Multiplayer Mayhem**\n\nTeam up with up to 3 friends in seamless co-op multiplayer. Strategize and cooperate to defeat the hordes, share loot, and defeat the boss to extract. \n\n**Progression and Customization**\n\nGather scrap, a permanent currency, to unlock new weapons and upgrades at your home base. Persistently enhance your character across play sessions, becoming stronger and more versatile with each run.\n\n", "short_description": "The Frenzy Virus has mutated. Now, you and your team must defeat hordes of \"The Ridden\" in Frenzy Extinction! Survive waves of mutated monsters as your team upgrades their gear, powers up with custom abilities, and races to extract after defeating the elite bosses. Using physics-based combat and dismemberment, take on 10 maps with 50+ unique weapons. "}]}, "developer_name": "Innoverse Ltd", "developer_privacy_policy_url": "http://clique.games/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": null, "website_url": "https://www.innoverse.co.uk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "644354873106712"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "ACTION", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "25176949395285406"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1290047835663564"}, {"status": "PUBLISHED", "id": "1268987520902727"