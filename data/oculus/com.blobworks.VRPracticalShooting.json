Mxygw86yMQ7kNvgGvHx4K&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASsQRPINdCbLFIDBzzuf6zu&oh=00_AYAzntojWW6BLl1B1hiLb0VGWZV2u2e0uBekmswcuaPasg&oe=66E95DF8"}, {"file_name": "Practical05.png", "id": "1308348672870572", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003233_1308348676203905_6268088337758980308_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l2oG4oDsBgIQ7kNvgEeWIBt&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASsQRPINdCbLFIDBzzuf6zu&oh=00_AYAan5TBLRKLkbzSCAsxNmN_lthANwwiTAAUuVGjnNDH8Q&oe=66E958F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "4236058733127537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001694_4236058739794203_843853504506656205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5VT8JIQ45uEQ7kNvgEnCC0g&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASsQRPINdCbLFIDBzzuf6zu&oh=00_AYDJXK0e9ENtUMZUgmxRLNpQv6ykhm7Oi5BrQPkg7a812A&oe=66E9593B"}, "display_name": "VR Practical Shooting", "keywords": [], "long_description": "This app emphasize on using only one controller to mimic more intuitive grips for practical sports shooting in the case of handguns. User will be able to freely shoot different handguns in a free range, or go through competition style stages where scores and time will be shown at the end, with various penalties and range commands to follow. Features so far includes realistic ballistic, accurate paper scoring system (so even if a line break will count as a score, based on size of bullet hole that matches calibre of choice), haptic based trigger reset, physics steel targets and more. ", "short_description": "A VR trainer for the competitive shooting sport. "}]}, "developer_name": "blobworks", "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/80c15757-0ebb-47fb-9432-c62c43503030", "developer_terms_of_service_url": null, "publisher_name": "blobworks", "support_website_url": null, "website_url": "https://tinyurl.com/blobworks", "category": "GAMES", "comfort_rating": "NOT