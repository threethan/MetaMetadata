n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EM8fcy06FNAQ7kNvgG1l0tT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYBH7sd3qVRLhHxBCGHVqJeEj4W1C8TxjvWueiqXXukbiA&oe=66F146F8"}, {"file_name": "Practical05.png", "id": "1308348672870572", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003233_1308348676203905_6268088337758980308_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMtwN0FgqUkQ7kNvgFBywW2&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYAE_1_eo-AvY3mSB5XAcsN7EX2VJslbwD8ZxCPM9ZlfhA&oe=66F141F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "4236058733127537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001694_4236058739794203_843853504506656205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tNNP-MrUhusQ7kNvgHt8Cbk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYB5oSjHZztq9KfsruD-6vRwPYTkf0p10jyOLnfWnLLSew&oe=66F1423B"}, "display_name": "VR Practical Shooting", "keywords": [], "long_description": "This app emphasize on using only one controller to mimic more intuitive grips for practical sports shooting in the case of handguns. User will be able to freely shoot different handguns in a free range, or go through competition style stages where scores and time will be shown at the end, with various penalties and range commands to follow. Features so far includes realistic ballistic, accurate paper scoring system (so even if a line break will count as a score, based on size of bullet hole that matches calibre of choice), haptic based trigger reset, physics steel targets and more. ", "short_description": "A VR trainer for the competitive shooting sport. "}]}, "developer_name": "blobworks", "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/80c15757-0ebb-47fb-9432-c62c43503030", "developer_terms_of_service_url": null, "publisher_name": "blobworks", "support_website_url": null, "website_url": "https://tinyurl.com/blobworks", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1880523522336520"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "160326949517164"}]}, "baseline_offer": {"id": "160326949517164"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1628563200, "status": "PUBLISHED", "id": "160326949517164"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6350391388357687", "version": "0.1.230514"}, "id": "131373588865765", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3875542155842635", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6350391388357687"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "131373588865765"}]}, "change_log": "- Additional setting button to disable trigger detection on draw ", "created_date": 1684082012, "id": "6350391388357687", "version": "0.1.230514", "version_code": 162, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "Androi