file_name": "Practical04.png", "id": "506013484133607", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003242_506013490800273_1160939464028821919_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=efdRbnGYciIQ7kNvgG-Iq7m&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBFQJfnyjfeP3dzFQ4GU3EsCyAluDV4vRaDYXzP6zfEwQ&oe=67824BF8"}, {"file_name": "Practical05.png", "id": "1308348672870572", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003233_1308348676203905_6268088337758980308_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0J5jvDFlHH4Q7kNvgGHD01i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAE6UYDffmgRr5mQv7TMT0NPIYkcBJHk32C6zmg7n7JEg&oe=678246F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "4236058733127537", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001694_4236058739794203_843853504506656205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JXAWbu6fWTkQ7kNvgEbpElS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNYM9RGlmIMxklPxsi3CzjLlHFxvXrf4Qs4dWKtegtqA&oe=6782473B"}, "display_name": "VR Practical Shooting", "keywords": [], "long_description": "Release date 20 November 2021\n\nVR Practical Shooting is a sandbox experience built for those who are interested in competition shooting and sandbox shooters. There are various free ranges, competition mode with detailed scoring, all using realistically modelled firearms and innovative controls to closely mimic the real thing in ways that feels natural. \n\nJoin the discord server for feedback and suggestions: https://discord.me/blobworks\nJoin the YouTube channel for frequent devlogs: https://www.youtube.com/c/blobworks\n", "short_description": "A VR trainer for the competitive shooting sport and those who enjoy plinking with firearms. "}]}, "developer_name": "blobworks", "developer_privacy_policy_url": "https://docs.google.com/document/d/14pHKxrzFG41PSdfGDhO_RdH_xrsvYfEL6LY-Jnhiikw/edit?usp=sharing", "develope