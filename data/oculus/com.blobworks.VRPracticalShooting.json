ontent-sjc3-1.oculuscdn.com&oh=00_AYDEixzz5P56ijkBgm17-1HvJPzKs3liX_jerZDkg1NRSg&oe=670113F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "4236058733127537", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001694_4236058739794203_843853504506656205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BDA2RMLPg48Q7kNvgGtoWtE&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCKMqvceTqbkpj8NhyVp6ZRHiQ8HYEJ1tIF1VRN-7YfUg&oe=6701143B"}, "display_name": "VR Practical Shooting", "keywords": [], "long_description": "This app emphasize on using only one controller to mimic more intuitive grips for practical sports shooting in the case of handguns. User will be able to freely shoot different handguns in a free range, or go through competition style stages where scores and time will be shown at the end, with various penalties and range commands to follow. Features so far includes realistic ballistic, accurate paper scoring system (so even if a line break will count as a score, based on size of bullet hole that matches calibre of choice), haptic based trigger reset, physics steel targets and more. ", "short_description": "A VR trainer for the competitive shooting sport. "}]}, "developer_name": "blobworks", "developer_privacy_policy_url": "https://www.freeprivacypolicy.com/live/80c15757-0ebb-47fb-9432-c62c43503030", "developer_terms_of_service_url": null, "publisher_name": "blobworks", "support_website_url": null, "website_url": "https://tinyurl.com/blobworks", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supporte