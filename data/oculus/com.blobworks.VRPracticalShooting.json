Avyc-aLBTF-xI60gAsv&oh=00_AYD3exYIiHP-npXKnBHvOQ1cUWXnsH1vXxxSiCB5qODhAQ&oe=66F14998"}, {"file_name": "Practical04.png", "id": "506013484133607", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003242_506013490800273_1160939464028821919_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EM8fcy06FNAQ7kNvgG1l0tT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYBH7sd3qVRLhHxBCGHVqJeEj4W1C8TxjvWueiqXXukbiA&oe=66F146F8"}, {"file_name": "Practical05.png", "id": "1308348672870572", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003233_1308348676203905_6268088337758980308_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cMtwN0FgqUkQ7kNvgFBywW2&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYAE_1_eo-AvY3mSB5XAcsN7EX2VJslbwD8ZxCPM9ZlfhA&oe=66F141F6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer.png", "id": "4236058733127537", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001694_4236058739794203_843853504506656205_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tNNP-MrUhusQ7kNvgHt8Cbk&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aso1Avyc-aLBTF-xI60gAsv&oh=00_AYB5oSjHZztq9KfsruD-6vRwPYTkf0p10jyOLnfWnLLSew&oe=66F1423B"}, "display_name": "VR Practical Shooting", "keywords": [], "long_description": "Release date 20 November 2021\n\nVR Practical Shooting is a sandbox experience built for those who are interested in competition shooting and sandbox shooters. There are various free ranges, competition mode with detailed scoring, all using realistically modelled firearms and innovative controls to closely mimic the real thing in ways that feels natural. \n\nJoin the discord server for feedback and suggestions: https://discord.me/blobworks\nJoin the YouTube channel for frequent devlogs: https://www.youtube.com/c/blobworks\n", "short_description": "A VR trainer for the competitive shooting sport and those who enjoy plinking with firearms. "}]}, "developer_name": "blobworks", "developer_privacy_polic