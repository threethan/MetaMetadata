FOznrMzXJNtg0g&oe=674C5834"}, {"file_name": "Screenshot5.png", "id": "397612790004946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036641_397612793338279_7406487488091581_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MC6hxRs7DHsQ7kNvgFBx5PP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAXBGr6lk2noW2dD4rnVmcQuTdgHd_a665r8WU8L6yQbw&oe=674C3D4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TETRED_Cover.png", "id": "509367518295397", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982724_509367521628730_557426402027958475_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-X-aWNtndgkQ7kNvgGU2aa8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYATexbbmIQzTpQyYC3IwYRz8GG_4iWfZRXhBWh5kdzL7A&oe=674C67D9"}, "display_name": "TETRED", "keywords": [], "long_description": "The player looks from above into a playing area with a rectangular floor plan. 3D blocks made up of several cubes appear at the top of the shaft and slowly fall down. During this time, the player can rotate them around all three spatial axes and move them sideways. As with Tetris, the aim is to arrange the blocks in closed layers like a puzzle - as soon as a level is completely occupied, it disappears and the blocks above it slide down. The game is over when the remaining blocks reach the top of the shaft.\nThe game can be played in virtual and mixed reality.", "short_description": "TETRED - A Tetronimo 3D puzzle game for Virtual and Mixed Reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/retroxrealm/policy", "developer_terms_of_service_url": null, "publisher_name": "RetroXRealm", "support_website_url": null, "website_url": "https://sites.google.com/view/retroxrealm", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIR