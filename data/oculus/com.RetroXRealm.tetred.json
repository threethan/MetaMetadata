L89nIVQPsp5DYx1UozXA&oe=674C40F1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TETRED", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1728054000, "lastRevision": {"nodes": [{"id": "8772060356143468", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8772060332810137", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1210701999934553"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": []}, "id": "2359635364375761", "locale": "de_DE", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "TETRED", "keywords": [], "long_description": "Der Spieler blickt von oben in eine Spielfl\u00e4che mit einer rechteckigem Fl\u00e4che. Oben erscheinen 3D Bl\u00f6cke aus mehreren W\u00fcrfeln, die langsam nach unten fallen. W\u00e4hrenddessen kann der Spieler sie um alle drei Achsen drehen und seitw\u00e4rts verschieben. Wie bei Tetris geht es darum, die Bl\u00f6cke wie bei einem Puzzle in geschlossenen Schichten anzuordnen. Sobald eine Ebene komplett gef\u00fcllt ist, verschwindet diese und die dar\u00fcber liegenden Bl\u00f6cke rutschen nach unten. Das Spiel ist beendet, wenn die Bl\u00f6cke nicht mehr in die Spielfl\u00e4che passen.\nDas Spiel kann in virtueller und gemischter Realit\u00e4t gespielt werden.", "short_description": "TETRED \u2013 Ein Tetromino-3D-Puzzlespiel f\u00fcr Virtual und Mixed Reality."}, {"images": {"nodes": [{"file_name": "TETRED_CoverMini.png", "id": "2208749076175248", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982724_2208749082841914_8859701932686800914_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M58-vxajDJ0Q7kNvgGPMfws&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDttoOt9IOmrEPJ3HuPeMT19pKiSYmfJ5mTrh8nzPsuFw&oe=674C6897"}, {"file_name": "TETRED_Icon.png", "id": "1209868010194531", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75451787_1209868016861197_6811324181711238911_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0XxuqKzGLTgQ7kNvgFnsZif&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAvfOFetc0fPEpkfnetnVphizilVMsTKbaM2gQooWa9RQ&oe=674C575B"}, {"file_name": "TETRED_CoverPortrait.png", "id": "1142056243564934", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982724_1142056246898267_6161653771733025088_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hrSj43zkLhcQ7kNvgG-cfl0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALGU6maeHqFMZW5PV02Us78Pp29pQxrvH7w9_qLVE4jQ&oe=674C62D4"}, {"file_name": "TETRED_CoverLandscape.png", "id": "995456982475280", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371506_995456985808613_2360853735252150839_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10sCLzige00Q7kNvgGr6CsC&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2cdJA7zn03TNADK-GsJH0_7gp-7qM9qARHP5WExmfkQ&oe=674C5A25"}, {"file_name": "TETRED_Logo.png", "id": "870193447773646", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031424_870193451106979_5514401208869330091_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XR-YEUj1V7MQ7kNvgHCP7VE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2uTjJVx-I79C6lEtJkPYkbbt39WMrcWYkx3Wa7SERMQ&oe=674C39F6"}, {"file_name": "TETRED_CoverSquare.png", "id": "858314512405829", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_858314515739162_7700003212088574574_n.png?_