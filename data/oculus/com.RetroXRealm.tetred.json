"video_trailer_thumbnail": {"file_name": "TETRED_Cover.png", "id": "509367518295397", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982724_509367521628730_557426402027958475_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1Tc6y9wqBMQ7kNvgHz7nzT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDks2XfyXw6kr5TG8-4gWhGro3pVusi1MhbFSGmOKTVlg&oe=675AE859"}, "display_name": "TETRED", "keywords": [], "long_description": "The player looks from above into a playing area with a rectangular floor plan. 3D blocks made up of several cubes appear at the top of the shaft and slowly fall down. During this time, the player can rotate them around all three spatial axes and move them sideways. As with Tetris, the aim is to arrange the blocks in closed layers like a puzzle - as soon as a level is completely occupied, it disappears and the blocks above it slide down. The game is over when the remaining blocks reach the top of the shaft.\nThe game can be played in virtual and mixed reality.", "short_description": "TETRED - A Tetronimo 3D puzzle game for Virtual and Mixed Reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/retroxrealm/policy", "developer_terms_of_service_url": null, "publisher_name": "RetroXRealm", "support_website_url": null, "website_url": "https://sites.google.com/view/retroxrealm", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_intera