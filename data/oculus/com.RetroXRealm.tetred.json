_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBtIVYW3weFXrG-DJDy1jNYxz2Ab7Y2wNmYkSBV3B1gdA&oe=675ABC3F"}, {"file_name": "Screenshot2.png", "id": "965325932168598", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031503_965325935501931_5116951075548814257_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MO8G2URn07sQ7kNvgEnBo99&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCJ0BDtTc3P7gCdBGVfLuleZDbbOfHK90Ot2LFp0K4aSQ&oe=675ACC4C"}, {"file_name": "Screenshot6.png", "id": "1113864200072313", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035354_1113864203405646_1264412197261333365_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5b8Z5g-UkRcQ7kNvgEPJhhd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC8w5QYDgNYzrYExUMWYK8Y7kF5ilOFpGpQj8sDrW10iQ&oe=675AB5F3"}, {"file_name": "Screenshot5.png", "id": "397612790004946", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036641_397612793338279_7406487488091581_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hbH0wxjDW1wQ7kNvgFZf94b&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB2jzjayJc0U19bsQjVE9_3aqyBIbNfNsmDdePOZonaVQ&oe=675ABDCE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TETRED_Cover.png", "id": "509367518295397", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982724_509367521628730_557426402027958475_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1Tc6y9wqBMQ7kNvgHz7nzT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDks2XfyXw6kr5TG8-4gWhGro3pVusi1MhbFSGmOKTVlg&oe=675AE859"}, "display_name": "TETRED", "keywords": [], "long_description": "The game can be played in Virtual and Mixed Reality. The player looks from above into a rectangular playing area. 3D blocks made up of several cubes appear at the top of the shaft and slowly fall down. During this time, the player can rotate them around all three spatial axes and move them sideways. As with Tetris, the aim is to arrange the blocks in closed layers like a puzzle - as soon as a level is completely occupied, it disappears and the blocks above it slide down. The game is over when the remaining blocks reach the top of the shaft.\n", "short_description": "TETRED - A Tetromino 3D puzzle game in Virtual and Mixed Reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/retroxrealm/policy", "developer_terms_of_service_url": null, "publisher_name": "RetroXRealm", "support_website_url": null, "website_url": "https://sites.google.com/view/retroxrealm", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9818131084869718"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031378_1304818680696288_8996885262154567503_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gyn_jOw-D2sQ7kNvgHtV93c&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5U9cq4U40WJWzE_n56JK4w-jXm91cWKXWsfahvslatA&oe=675AB3E4"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "TETRED", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1728054000, "lastRevision