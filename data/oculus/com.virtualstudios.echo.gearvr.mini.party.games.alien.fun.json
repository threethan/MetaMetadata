872_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AkKn3zypVZMQ7kNvgGd4eT4&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aujm0PZK4Zn_f7dh_2u0TMk&oh=00_AYDf-FebBv2hy86zn2TGa5jVyJns6x18TB13de6xLOZN4w&oe=66EACCD7"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Echo Mini Games Party", "keywords": ["mini", "games", "quiz", "puzzle", "challenge"], "long_description": "ECHO is a funky alien.\nECHO likes playing games with you.\nBut ECHO doesn't like losers.\nNever lose against him... Otherwise he will kill you!\nTry to survive the challenges that ECHO is preparing for you!\n\nGame List :\n- SHIFUMI : The classical game where you have to choose between Rock, Paper and Scissors !\n- LIGHT GAME :  Try to reproduce the lighting sequence !\n- TIME BOMB : Play with a bomb, but when will it explode ?\n- TIME BOMB 2 : Play with a bomb, but when will it explode ? Your score grows up as long as you have the bomb.\n- LAST ONE : Don't be the last to keep the ball !\n- FIND ME : Try to find ECHO before time's up !\n- HIDDEN BOMB : 20 balls, one of them is a bomb !\n- MEMORY : Try to remember where are the correct balls !\n- BONTO : 3 Boxes, one ball, try to find it !\n- SPEED TOUCH : Be faster than ECHO to touch the speed button !\n\nMany more games are coming on the next updates !\n\nFrom creators of Beasts of Legend VR!", "short_description": "10 games in 1! Try to survive to ECHO's challenge! Have fun with your new friend!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://echovr.virtual-studios.fr/", "developer_terms_of_service_url": "http://echovr.virtual-studios.fr/", "publisher_name": "Virtual Studios", "support_website_url": null, "website_url": "http://echovr.virtual-studios.fr/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "PUZZLE"], "has_in_app_ads": false, "internet_connec