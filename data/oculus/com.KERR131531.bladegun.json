lear: defend the city from relentless assaults and restore order."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/blade-gun/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "KERR Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/blade-gun", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}, {"id": "1592192974313489"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8151832978183741"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8217705388263166", "version": "1.0"}, "id": "3722200114663094", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8151832971517075", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8217705388263166"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "3722200114663094"}]}, "change_log": null, "created_date": 1721569777, "id": "8217705388263166", "version": "1.0", "version_code": 3, "release_status": "RELEASED", "st