ATION", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": [], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "497850938567795"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12602103_710537365762797_1097881728_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Iksb5mvKNXIQ7kNvgGcM4Eh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG1pzyVOTkT137E9nXV40ls&oh=00_AYBzIcNXmY1ef2JbdnCrhsPH2Yrl_oCeik7mofVTqkHurg&oe=66F3E0D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Spirit Journey", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1471417200, "lastRevision": {"nodes": [{"id": "1045302075519332", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1188879784477485", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": null, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "1891518561146633", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12427558_1787948071450138_965258301_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PRHD-KdMy6UQ7kNvgFavmA4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AG1pzyVOTkT137E9nXV40ls&oh=00_AYAGWMZ-RGrT0mHXsjefU27v4B58Doc1CAe7nviCeQPadg&oe=66F40B06"}, {"file_name": "migrated_image.png", "id": "849403222211990", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12448847_618005938357119_485150258_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc