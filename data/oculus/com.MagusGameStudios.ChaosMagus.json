d_FRfGnWr2YKXMw&oe=67695F6A"}, {"file_name": "default_1.23.1.png", "id": "1074900153862647", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974744_1074900157195980_6960323804818040266_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bzo6BQsB8WgQ7kNvgEuuLkL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfDS71c9gqUBSsG9BzuUDTJiw3-rozzkkWf0raHa7DOQ&oe=67693A81"}, {"file_name": "default_1.30.1.png", "id": "346283717902236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86653846_346283721235569_656098948942624836_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D06yWWW2_gAQ7kNvgEq1YSD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJ0HIDda1taQw_UWTCHzWYKGGeiS8TmBKwvS1ZiL72OA&oe=67695A49"}, {"file_name": "default_1.39.1.png", "id": "715309547153168", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001714_715309550486501_3251260255275227124_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mqxeAhGhRp4Q7kNvgF51ohW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCU_EoplYf8sPoQMPJMMGKZzMS2vpzsD0OENZSlRqI1vA&oe=67694C47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape-2560x1440.png", "id": "744238797543669", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974645_744238800877002_8695878356957567661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8ZoIRj7JaAQ7kNvgFChfQE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCNgkfGHZOR4qHZ7MSSBkPwxIxYoGeO8ysBiieGEUEJ-Q&oe=67695E9E"}, "display_name": "Chaos Magus", "keywords": [], "long_description": "Embark on an odyssey of magical proportions where YOU are the beacon of hope! Unleash the raw might of a formidable wizard and feel the exhilarating rush of unparalleled magic cascading through your fingertips. Immerse yourself in a stunning world on the brink of chaos, under the shadow of primal elementals threatening to consume all in their path.\n\nThe fate of countless souls rests on your shoulders. As their savior, you are tasked with the monumental mission of delivering the people of these lands from the looming darkness. But fear not, for as you traverse the rich tapestry of forests, mountains, and ethereal planes, you'll unlock the secrets to over 200 mesmerizing spells. From the gentle glow of nature incantations to the roaring inferno of fire magic, you'll find a spell to face every threat of your adventure.\n\nYour mettle will be tested by more than just the elementals. Over 100 formidable adversaries, each with their unique skills and abilities, await your challenge. Confront fearsome bosses that will demand every ounce of your strategic prowess.\n\nYour journey is as much about wits as it is about might. Employ a combination of strategy, timing, and sheer creativity to craft your path to victory, obliterating all who dare stand in your way.\n\nAdventurer, write your chapter in the annals of magic. Dive into this epic journey, for the ultimate magical saga awaits your touch. The question remains: Are you truly prepared to leave your mark?", "short_description": "Unleash the might of a powerful wizard and let unparalleled magic surge through your fingertips! Dive deep into a world threatened by primal elementals. Save the people of these lands and master over 200 mesmerizing spells. Tackle 100+ formidable foes and fearsome bosses. Use your creativity and obliterate all who oppose you. Step into an epic journey and create your own legendary tale. Are you prepared for the ultimate magical saga?"}]}, "developer_name": "Magus Game Studios", "developer_privacy_policy_url": "https://www.chaosmagus.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Magus Game Studios", "support_website_url": null, "website_url": "https://www.chaosmagus.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968