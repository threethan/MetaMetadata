82789429", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39001703_690497386122762_8642551534181063229_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LuffMu9XV4AQ7kNvgEofADg&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAl4rlUcVyXAHdZVn11wYKVLGrs-0_Dhnh0w6ysiMo5ww&oe=6728C7A4"}, {"file_name": "Mini-Landscape-1080x360.png", "id": "270083166028911", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75210393_270083169362244_2238587949790166044_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_sNx5iXTWCIQ7kNvgGfZkT4&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYC0D8cSiH6PWaNJMJpwn2zgD2szAuJfeQfZN-YxKmv4yg&oe=6728AC8B"}]}, "id": "1238536917581864", "locale": "en_US", "screenshots": [{"file_name": "default_1.39.1.png", "id": "715309547153168", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/39001714_715309550486501_3251260255275227124_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8dufJWBytvQQ7kNvgEVVWTF&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYATO--mqLuJoAG6Zn9Sv-Al2ZnLkF35sQKK1wUayHSPfw&oe=6728B2C7"}, {"file_name": "EarthScreenSHotSmaller-2560x1440.png", "id": "1062258148661618", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/38982672_1062258151994951_4871279801927371428_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nEqZaXxSxggQ7kNvgEB9QrE&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYAV8F8sLysg5qj99xHyhrJ-F3RzaCS63rAH_2nzGez-kw&oe=6728CEB1"}, {"file_name": "Fire1408-2560x1440.png", "id": "471924398984343", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38982672_471924405651009_646439364058862937_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wfZGSv4VowoQ7kNvgFB-RgW&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYAJCj600kQYuD3-iacB1dgLOr3g1xOlUWJ_tIdLlba42Q&oe=6728C2A0"}, {"file_name": "Lightning1408-2560x1440.png", "id": "1021469925859024", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974648_1021469929192357_6976474847756219896_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eEPFWEptb6QQ7kNvgE6DMNi&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYCNwkKqx6slCD34iwxnaMpyrIYCJ_wcu5IHcN7s9fm_0w&oe=6728B1CE"}, {"file_name": "Celebrations1408Second-2560x1440.png", "id": "498462266102202", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/43997709_498462269435535_6054700393427840010_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NC_xCUKsxjYQ7kNvgGtueAR&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBWzRMTohfBnUzOn5PMi--LTWLPPbOQFQgfOOEKkggBpQ&oe=6728CC13"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Landscape-2560x1440.png", "id": "744238797543669", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974645_744238800877002_8695878356957567661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-GXu8BpyDMMQ7kNvgETXa7T&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDoi1-DlT3s8-R0m2sk0H5LuULijYtcNqCXLvS5Olx8Ag&oe=6728C51E"}, "display_name": "Chaos Magus", "keywords": [], "long_description": "# An Unparalleled Action Adventure that Blends Physics-Based Spellcasting with Dynamic Sword Fighting. \n\nDive into the adventure now and experience the magic firsthand!\n\n**Unleash the might of a powerful wizard** and let unparalleled magic surge through your fingertips! Use your creativity and obliterate all who oppose you.\n\n- **Deep Magic System:** Experience our unique magic system that lets you craft over 200 spells in real-time. Enjoy a hands-on sorcery experience that\u2019s both intuitive and deeply satisfying.\n\n- **Customize your playstyle:** more than 70 additional unique skills and pieces of equipment.\n\n- **Dynamic Combat:** Engage in swift, strategic battles where every choice counts. Confront over 100 unique enemies, each demanding a different strategy for victory.\n\n- **Immersive Physics:** Our advanced physics engine makes every spell cast and sword strike feel real, satisfying and immersive.\n\n-  **Expansive Content:** Explore 16 playable levels, each offering unique adventures and experiences. Test your skills in 15 additional challenges, providing hours upon hours of engaging and exhilarating gameplay.\n\nAre you ready for the ultimate magical saga?\n\n**Embark on your journey today and forge your legendary tale!**\n", "short_description": "An Unparalleled Action Adventure that Blends Physics-Based Spellcasting with Dynamic Sword Fighting. \n\nExperience a unique magic system that lets you craft over 200 spells in real-time. \nCustomize your playstyle with more than 70 additional unique skills and pieces of equipment.\nConfront above 100 distinct enemies, each demanding a different strategy for victory.\nAdvanced physics engine makes every spell feel satisfying and immersive.\nTriumph through 16 epic levels and 15 thrilling challenges."}]}, "developer_name": "Magus Game Studios", "developer_privacy_policy_url": "https://www.chaosmagus.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Magus Game Studios", "support_website_url": null, "website_url": "https://www.chaosmagus.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8043872458991550"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sin6-4.oculu