_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDoi1-DlT3s8-R0m2sk0H5LuULijYtcNqCXLvS5Olx8Ag&oe=6728C51E"}, "display_name": "Chaos Magus", "keywords": [], "long_description": "Embark on an odyssey of magical proportions where YOU are the beacon of hope! Unleash the raw might of a formidable wizard and feel the exhilarating rush of unparalleled magic cascading through your fingertips. Immerse yourself in a stunning world on the brink of chaos, under the shadow of primal elementals threatening to consume all in their path.\n\nThe fate of countless souls rests on your shoulders. As their savior, you are tasked with the monumental mission of delivering the people of these lands from the looming darkness. But fear not, for as you traverse the rich tapestry of forests, mountains, and ethereal planes, you'll unlock the secrets to over 200 mesmerizing spells. From the gentle glow of nature incantations to the roaring inferno of fire magic, you'll find a spell to face every threat of your adventure.\n\nYour mettle will be tested by more than just the elementals. Over 100 formidable adversaries, each with their unique skills and abilities, await your challenge. Confront fearsome bosses that will demand every ounce of your strategic prowess.\n\nYour journey is as much about wits as it is about might. Employ a combination of strategy, timing, and sheer creativity to craft your path to victory, obliterating all who dare stand in your way.\n\nAdventurer, write your chapter in the annals of magic. Dive into this epic journey, for the ultimate magical saga awaits your touch. The question remains: Are you truly prepared to leave your mark?", "short_description": "Unleash the might of a powerful wizard and let unparalleled magic surge through your fingertips! Dive deep into a world threatened by primal elementals. Save the people of these lands and master over 200 mesmerizing spells. Tackle 100+ formidable foes and fearsome bosses. Use your creativity and obliterate all who oppose you. Step into an epic journey and create your own legendary tale. Are you prepared for the ultimate magical saga?"}]}, "developer_name": "Magus Game Studios", "developer_privacy_policy_url": "https://www.chaosmagus.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Magus Game Studios", "support_website_url": null, "website_url": "https://www.chaosmagus.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6750192071692935"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1382911546448454"}, {"status": "PUBLISHED", "id": "867486461476082"}, {"status": "PUBLISHED", "id": "994327118335578"}]}, "baseline_offer": {"id": "867486461476082"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1382911546448454"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8573902539321870", "version": "2.14"}, "id": "255193827138618", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6750192061692936", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8573902539321870"