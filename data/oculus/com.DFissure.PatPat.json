y amidst busy work schedules or simply unwinding during leisure time, this game offers endless joy and relaxation. Come and explore this new musical world, where your soul dances to the rhythm of the music, and indulge in a journey of pure and delightful melodies!", "short_description": "This is a music rhythm game where you can tap beautiful drums on your desktop, follow the rhythm of the music, and create energetic beats. Come and experience it!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://yx10wesce3.feishu.cn/docx/TisGdeT21olHDax4FBWcgtuTn3e?from=from_copylink", "developer_terms_of_service_url": null, "publisher_name": "D-Fissure", "support_website_url": null, "website_url": "https://d-fissure.com/patpat/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6781327755232736"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3601862623407935"}]}, "baseline_offer": {"id": "3601862623407935"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1715186880, "status": "PUBLISHED", "id": "3601862623407935"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7265457050153135", "version": "1.1"}, "id": "1087034529081634", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidB