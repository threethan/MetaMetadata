ent.oculuscdn.com&_nc_gid=ARaXbBAd8o909Q_WS9LfEO7&oh=00_AYB7MlrjbfLqhCB2qydPnhrEOQlOrJlE7e0FPlUu6SwHVg&oe=66F3EAE1"}, {"file_name": "\u5fae\u4fe1\u56fe\u7247_20240402113954.png", "id": "739491748173878", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556799_739491751507211_443413676587343337_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_iqgR0WxnUEQ7kNvgEyUeqR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARaXbBAd8o909Q_WS9LfEO7&oh=00_AYCltae4ruEyd-uHzCrXvYYyShQSglPkPmP_rEi_i7Yq-Q&oe=66F3F01D"}, {"file_name": "\u5fae\u4fe1\u56fe\u7247_20240402114008.png", "id": "421406307140902", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974804_421406310474235_1381695160635557774_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F9RKKNRiWWIQ7kNvgH-Tn0e&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARaXbBAd8o909Q_WS9LfEO7&oh=00_AYBetTR5BhujOl3OaYZgvDN1oOtvNsJXXoetRZfqz7Wx5Q&oe=66F40582"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Frame 6.png", "id": "851657576973695", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75330716_851657580307028_764677618217052868_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G_vTG78vaSMQ7kNvgGVRggJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARaXbBAd8o909Q_WS9LfEO7&oh=00_AYB6QqbfC4cjXqHkKGaY_JZbW263Ykc43R1JVhnphjOdPg&oe=66F3EFA3"}, "display_name": "PatPat", "keywords": [], "long_description": "This music rhythm game takes you on a fantastic journey through vibrant and dynamic beats. In the game, you'll find yourself immersed in a captivating musical environment, creating wonderful musical echoes by tapping drums on your desktop. Each beat is accompanied by the melody of the music, as if engaging in an intimate conversation with it.\nWhether you're seeking a moment of tranquility amidst busy work schedules or simply unwinding during leisure time, this game offers endless joy and relaxation. Come and explore this new musical world, where your soul dances to the rhythm of the music, and indulge in a journey of pure and delightful melodies!", "short_description": "This is a music rhythm game where you can tap beautiful drums on your desktop, follow the rhythm of the music, and create energetic beats. Come and experience it!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://yx10wesce3.feishu.cn/docx/TisGdeT21olHDax4FBWcgtuTn3e?from=from_copylink", "developer_terms_of_service_url": null, "publisher_name": "D-Fissure", "support_website_url": null, "website_url": "https://d-fissure.com/patpat/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6781327755232736"}, "review_messages": ["", "", "", "", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931333_371726809172334_8475863406050334993_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1f5aUF3v6WUQ7kNvgHFk2d2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARaXbBAd8o909Q_WS9LfEO7&oh=00_AYCPjDfnfVkVZd3Q-bWXQDh9wOv6AM3CGF4uGEje7bSt8g&oe=66F3E6A7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "PatPat", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}], "release_date": 1715186880, "lastRevision": {"nodes": [{"id": "6559828750715972", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_m