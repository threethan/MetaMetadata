87_2205198085952726799_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=irrprZ74ITwQ7kNvgER1ib9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAR4PQ5o9wQVJh8npyfoqGWg-cAjW9DMmEfbff47r19RA&oe=677FA0D6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Christmas Tag v2", "keywords": [], "long_description": "\"Christmas Tag\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity.\nThe objective of Christmas Tag is simple yet delightful: players use virtual reality tools to create beautiful, glowing art installations throughout the game world.\nThese installations can take the form of intricate patterns, flowing designs, or even abstract masterpieces\u2014all designed to evoke a sense of peace and serenity.", "short_description": "\"Christmas Tag\" is a captivating VR game designed to immerse players in a tranquil yet engaging environment. Set in a serene virtual world filled with lush landscapes, calming music, and picturesque scenery, the game offers a unique experience of relaxation and creativity."}]}, "developer_name": "VIPER", "developer_privacy_policy_url": "https://sites.google.com/view/christmas-tag-privacy-policy/home", "developer_terms_of_service_url": null, "publisher_name": "VIPER", "support_website_url": null, "website_url": "https://sites.google.com/view/christmas-tag-home/home", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supporte