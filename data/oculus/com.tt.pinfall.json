CB85E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover.png", "id": "1819228061920273", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982452_1819228065253606_407037206585227872_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IC0ZhuAs5MAQ7kNvgHLr91G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAgfY2FZs8FRNIUskqXQMIeTUJdHXPDzomKERn1B0KjgQ&oe=672C958A"}, "display_name": "Pinfall", "keywords": [], "long_description": "Pinfall: The Ultimate VR Bowling Experience\n\nWelcome to \"Pinfall,\" where the classic sport of bowling transcends the ordinary and enters the realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Pinfall\" offers a fresh and captivating way to enjoy this beloved sport.\nGame Overview\n\n\"Pinfall\" is a cutting-edge VR game that redefines the bowling experience by placing players in a vibrant cosmic arena. The game challenges your precision, skill, and timing as you aim to score points by knocking down pins in various celestial-themed lanes. Each game session offers a unique adventure, filled with stunning visuals and dynamic gameplay.", "short_description": "Pinfall: The Ultimate VR Bowling Experience\n\nWelcome to \"Pinfall,\" where the classic sport of bowling transcends the ordinary and enters the realm of immersive virtual reality. Prepare to embark on a cosmic adventure that transforms traditional bowling into an exhilarating and futuristic experience. Whether you're a seasoned bowler or new to the game, \"Pinfall\" offers a fresh and captivating way to enjoy this beloved sport."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/pinfall/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TT Invention", "support_website_url": null, "website_url": "https://sites.google.com/view/pinfall", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8918526014829059"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035319_913320047227186_3191201182714266002_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4KE3PpukA8YQ7kNvgELYCiN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBbZZsopD4KkMpQL17qU24phMzFb6lUx_NV2x_I1Hyk0A&oe=672C9613"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Pinfall", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1720592132, "lastRevision": {"nodes": [{"id": "8836179869730341", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8836179819730346", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "994686741978838"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "cover_port.png", "id": "8326311784080562", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75230049_8326311790747228_1663951324216857508_n.png?_nc_cat=100