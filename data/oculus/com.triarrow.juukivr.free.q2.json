.com&oh=00_AYCQUVceJ9sKDqSqv3BZNKfmWjwQXDNF0hPfM8PI-7q1nQ&oe=670672F3"}, {"file_name": "juukivr_screen5.png", "id": "327278196718989", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974880_327278200052322_8316003477844941030_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPvyvz4_DPMQ7kNvgHeKK86&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMlqqKGzmYepEaKCsj9EAPDWGUV-VE8YyaKxPe0-sTNg&oe=6706563A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30d0\u30fc\u753b\u50cf.png", "id": "299485416372356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75495671_299485423039022_9155695604389481864_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rl-lp8Pty3sQ7kNvgH0OfEk&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHiyisH_QT3UqUdpdSjy0SS_zDvLr2je2F7H1mLMmeGA&oe=67065D0D"}, "display_name": "\u91cd\u6a5f\u3067Go", "keywords": [], "long_description": "Lever patterns to match the actual machine, for professionals and aspiring professionals.\nWith four patterns to choose from (JIS, Hitachi Komatsu, Mitsubishi, and Shinko), you can select the one that matches the type of actual operation or the type you are familiar with.\n\n\u25c6Recommended for the following people\nFor those who are not familiar with excavator operation.\nFor simulation before operating the actual machine\nFor training of technical intern trainees.\nFor heavy equipment geeks who really want to touch the actual equipment.\n\n\u25c6Training Contents\n(1) Stage 1: Excavation and loading at construction site\n(2) Stage 2: Excavation and loading at road construction\u3000\n(3) Stage 3: Transportation in mountain forest\n(4) Stage 4: Driving training\n\n\u25c6Leverage pattern\n\u3000Selectable from 4 patterns (JIS pattern, Hitachi/Komatsu pattern, Mitsubishi pattern, Shinko pattern)\n\n\u25c6Language\nLanguage can be selected from Japanese or English.\n\n\u25c6Speed setting\nThe following speeds can be set\nCrawler\nCrawler\nCrawler \u30fbTurning\nBoom\nBucket/Grapple open/close\nGrapple open/close\nGrapple back and forth\nGrapple swivel", "short_description": "App renewal! This is an operation training simulation of heavy machinery that faithfully reproduces real machines. Whether you drive real machines, want to practice before a practical test, or are a heavy equipment geek who just wants to try it out, test your skills!"}, {"images": {"nodes": [{"file_name": "vr_mini.png", "id": "3661877680714679", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003279_3661877684048012_2919574090992689810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sp4Ly-l-f8sQ7kNvgEfXpZs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5SXv1otPSSTXn90ZyLKBbAFYDqj8hogvrGwVQuGQYuQ&oe=67065383"}, {"file_name": "vr_tate.png", "id": "1806373263166768", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974778_1806373266500101_717688588527688494_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eGth5lZTIDoQ7kNvgGdG1iV&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4olpDyEYh4FQi5pBEJ9nKg1itMh7SzEIaUlV4Ypd5hA&oe=670666AF"}, {"file_name": "\u91cd\u6a5f\u3067Go\u5171\u901a\u30ed\u30b4\u900f\u904e\uff081440\u00d7744\uff09.png", "id": "1148342912806034", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476754_1148342916139367_5308110925051760345_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zgv9kgrGFVQQ7kNvgG-nIkw&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJvFjnOs3EMY-F5WtylHhBLxH_8cQxzTPonpJ5CfMsIg&oe=670650F6"}, {"file_name": "VR_icon_512x512.png", "id": "663042649246790", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520128_663042652580123_4619130062963117964_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9wmhRlHV7F4Q7kNvgGpq2dv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZXc_vadtJHhe50Pqv5J7dT7f_S_vkCNOYdtuXTBJBlQ&oe=67065037"}, {"file_name": "vr_h