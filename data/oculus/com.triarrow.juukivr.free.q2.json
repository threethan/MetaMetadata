06&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O0p3cHeYHrkQ7kNvgHUhDeD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3q0Qq6yG6kVkOS8ukx9Qm_tdKzxGERAzwUnlgE0uw8w&oe=675AD2F3"}, {"file_name": "juukivr_screen5.png", "id": "327278196718989", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974880_327278200052322_8316003477844941030_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S3hCarxDdOcQ7kNvgEaDXuM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkIXkQKExnRCCmqhdb8y83Yetg6MPEsO5boldtIUTtjg&oe=675AB63A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30d0\u30fc\u753b\u50cf.png", "id": "299485416372356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75495671_299485423039022_9155695604389481864_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3bAuGPEIkEQ7kNvgFTKyNb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA6kePOccEtTeqPpPu7_hVUQO-x0N0jV1QORI3ZEdN4FA&oe=675ABD0D"}, "display_name": "\u91cd\u6a5f\u3067Go", "keywords": [], "long_description": "Lever patterns to match the actual machine, for professionals and aspiring professionals.\nWith four patterns to choose from (JIS, Hitachi Komatsu, Mitsubishi, and Shinko), you can select the one that matches the type of actual operation or the type you are familiar with.\n\n\u25c6Recommended for the following people\nFor those who are not familiar with excavator operation.\nFor simulation before operating the actual machine\nFor training of technical intern trainees.\nFor heavy equipment geeks who really want to touch the actual equipment.\n\n\u25c6Training Contents\n(1) Stage 1: Excavation and loading at construction site\n(2) Stage 2: Excavation and loading at road construction\u3000\n(3) Stage 3: Transportation in mountain forest\n(4) Stage 4: Driving training\n\n\u25c6Leverage pattern\n\u3000Selectable from 4 patterns (JIS pattern, Hitachi/Komatsu pattern, Mitsubishi pattern, Shinko pattern)\n\n\u25c6Language\nLanguage can be selected from Japanese or English.\n\n\u25c6Speed setting\nThe following speeds can be set\nCrawler\nCrawler\nCrawler \u30fbTurning\nBoom\nBucket/Grapple open/close\nGrapple open/close\nGrapple back and forth\nGrapple swivel", "short_description": "App renewal! This is an operation training simulation of heavy machinery that faithfully reproduces real machines. Whether you drive real machines, want to practice before a practical test, or are a heavy equipment geek who just wants to try it out, test your skills!"}, {"images": {"nodes": [{"file_name": "vr_mini.png", "id": "3661877680714679", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003279_3661877684048012_2919574090992689810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w1vhxMcGn9EQ7kNvgHkZGLb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAylQNJu6KY-T8DrdISDMBr2rk76of0Gz_hIW63f3rYNA&oe=675AB383"}, {"file_name": "vr_tate.png", "id": "1806373263166768", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974778_1806373266500101_717688588527688494_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMA_bCkGcEgQ7kNvgFqIBKn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAikyFC4EotkQeaBl0Uvsqa0OGehnlWQkj8klgwuaLEOQ&oe=675AC6AF"}, {"file_name": "\u91cd\u6a5f\u3067Go\u5171\u901a\u30ed\u30b4\u900f\u904e\uff081440\u00d7744\uff09.png", "id": "1148342912806034", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476754_1148342916139367_5308110925051760345_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NcqwPBBA_g8Q7kNvgHFKjZE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDopWtbJwr_KTjCu3_2L9zQWc_Qad0ihzACw-5RfJW5iA&oe=675AE936"}, {"file_name": "VR_icon_512x512.png", "id": "663042649246790", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75520128_663042652580123_4619130062963117964_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Bou