06&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x4f_91L203wQ7kNvgEoFUL_&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA1h-mnpZapF99dInO5lGbaszZ4AndKVJS9_GIjA1TTSA&oe=67865473"}, {"file_name": "juukivr_screen5.png", "id": "327278196718989", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974880_327278200052322_8316003477844941030_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=glhEp6753zsQ7kNvgFC261E&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDUnHqpcsh69ki9ciE-utLzzFo8KeM1he2LYvvkt1QBSw&oe=678637BA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30d0\u30fc\u753b\u50cf.png", "id": "299485416372356", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75495671_299485423039022_9155695604389481864_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9m5DT4yGnIEQ7kNvgGBsFJv&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDvktqfvTo8qb9eBYe-FhJRaCcE0vl7eDRo1nm2AFyi-g&oe=67863E8D"}, "display_name": "\u91cd\u6a5f\u3067Go", "keywords": [], "long_description": "Lever patterns to match the actual machine, for professionals and aspiring professionals.\nWith four patterns to choose from (JIS, Hitachi Komatsu, Mitsubishi, and Shinko), you can select the one that matches the type of actual operation or the type you are familiar with.\n\n\u25c6Recommended for the following people\nFor those who are not familiar with excavator operation.\nFor simulation before operating the actual machine\nFor training of technical intern trainees.\nFor heavy equipment geeks who really want to touch the actual equipment.\n\n\u25c6Training Contents\n(1) Stage 1: Excavation and loading at construction site\n(2) Stage 2: Excavation and loading at road construction\u3000\n(3) Stage 3: Transportation in mountain forest\n(4) Stage 4: Driving training\n\n\u25c6Leverage pattern\n\u3000Selectable from 4 patterns (JIS pattern, Hitachi/Komatsu pattern, Mitsubishi pattern, Shinko pattern)\n\n\u25c6Language\nLanguage can be selected from Japanese or English.\n\n\u25c6Speed setting\nThe following speeds can be set\nCrawler\nCrawler\nCrawler \u30fbTurning\nBoom\nBucket/Grapple open/close\nGrapple open/close\nGrapple back and forth\nGrapple swivel", "short_description": "App renewal! This is an operation training simulation of heavy machinery that faithfully reproduces real machines. Whether you drive real machines, want to practice before a practical test, or are a heavy equipment geek who just wants to try it out, test your skills!"}, {"images": {"nodes": [{"file_name": "vr_mini.png", "id": "3661877680714679", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003279_3661877684048012_2919574090992689810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a_CDqQgPM-sQ7kNvgHVJz11&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCttIORMrMi3uahJtfZdjRn1rkdZtVx0bWtX6-UUrTz-w&oe=67863503"}, {"file_name": "vr_tate.png", "id": "1806373263166768", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974778_1806373266500101_717688588527688494_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=61iLk_OZYjAQ7kNvgFxYNGG&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDlDfYZ5WTzMdVQ2IbCBweV7SDldMJBcub6q0v3toftMg&oe=6786482F"}, {"file_name": "\u91cd\u6a5f\u3067Go\u5171\u901a\u30ed\u30b4\u900f\u904e\uff081440\u00d7744\uff09.png", "id": "1148342912806034", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75476754_1148342916139367_5308110925051760345_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=geXAkCk6rx0Q7kNvgEIoAwO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCnHwxw_Cxel8AhmThtswlOG0gTDcN8i3O3JAVDtqcfJA&oe=67863276"}, {"file_name": "VR_icon_512x512.png", "id": "663042649246790", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75520128_663042652580123_4619130062963117964_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZAzU