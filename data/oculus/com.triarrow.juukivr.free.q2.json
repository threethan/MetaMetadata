.oculuscdn.com/v/t64.5771-25/75272208_871347967995827_7736183644069071093_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xx_iPaYnfdcQ7kNvgFs10Py&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYBtOCBlLRYUsgvrxBRQEtVK-Hmh8jbDlXsL5WC98JuKcg&oe=66E03773"}, {"file_name": "juukivr_screen5.png", "id": "327278196718989", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974880_327278200052322_8316003477844941030_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hmhP5O8G-c4Q7kNvgFInKq6&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYDCwcwEmCzoWviquBC8R5YXzliVHriNWqMOjKe_-9QetA&oe=66E01ABA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30ab\u30d0\u30fc\u753b\u50cf.png", "id": "299485416372356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75495671_299485423039022_9155695604389481864_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SlKyq0bvIwwQ7kNvgFR_qP_&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYBcExz2GwIirBmJJh1vQZL7fYM2xvKQvW3iQ2YyBk9sQw&oe=66E0218D"}, "display_name": "\u91cd\u6a5f\u3067Go", "keywords": [], "long_description": "Lever patterns to match the actual machine, for professionals and aspiring professionals.\nWith four patterns to choose from (JIS, Hitachi Komatsu, Mitsubishi, and Shinko), you can select the one that matches the type of actual operation or the type you are familiar with.\n\n\u25c6Recommended for the following people\nFor those who are not familiar with excavator operation.\nFor simulation before operating the actual machine\nFor training of technical intern trainees.\nFor heavy equipment geeks who really want to touch the actual equipment.\n\n\u25c6Training Contents\n(1) Stage 1: Excavation and loading at construction site\n(2) Stage 2: Excavation and loading at road construction\u3000\n(3) Stage 3: Transportation in mountain forest\n(4) Stage 4: Driving training\n\n\u25c6Leverage pattern\n\u3000Selectable from 4 patterns (JIS pattern, Hitachi/Komatsu pattern, Mitsubishi pattern, Shinko pattern)\n\n\u25c6Language\nLanguage can be selected from Japanese or English.\n\n\u25c6Speed setting\nThe following speeds can be set\nCrawler\nCrawler\nCrawler \u30fbTurning\nBoom\nBucket/Grapple open/close\nGrapple open/close\nGrapple back and forth\nGrapple swivel", "short_description": "App renewal! This is an operation training simulation of heavy machinery that faithfully reproduces real machines. Whether you drive real machines, want to practice before a practical test, or are a heavy equipment geek who just wants to try it out, test your skills!"}, {"images": {"nodes": [{"file_name": "vr_mini.png", "id": "3661877680714679", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003279_3661877684048012_2919574090992689810_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KTXk2uiSwJoQ7kNvgFAbkrG&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYASoePBau1eE6eOwfvxzkSOchWtbqlbW6kDlr0DxSGmHQ&oe=66E01803"}, {"file_name": "vr_tate.png", "id": "1806373263166768", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974778_1806373266500101_717688588527688494_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wTnzU3lNQjYQ7kNvgHfJQMY&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYC4eR8ja5SEhmi2JgtZyRhBceDxlYfB2aPtYYOLKQFUZA&oe=66E02B2F"}, {"file_name": "\u91cd\u6a5f\u3067Go\u5171\u901a\u30ed\u30b4\u900f\u904e\uff081440\u00d7744\uff09.png", "id": "1148342912806034", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75476754_1148342916139367_5308110925051760345_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xRARw7b8DG4Q7kNvgFshJbj&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkcpuVhjSkHFL6gnEaFp3t&oh=00_AYBoL7nFVoUAGSOSuLJ6yJ9-z7B2ThJByCVtpIdJ41XWTg&oe=66E01576"}, {"file_name": "VR_icon_512x512.png", "id": "663042649246790", "image_type": "APP_IMG_ICON", "uri": "