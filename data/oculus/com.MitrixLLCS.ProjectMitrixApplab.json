nt.oculuscdn.com&oh=00_AYARlVessZ547SjFn7KWYL0VjV-dtnjbzcuN8fQXRPp3KA&oe=66D599E0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (1).png", "id": "7707588222621315", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035319_7707588225954648_4734747154780419881_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxNA8UcJnxYQ7kNvgHntbsZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYACYnXr42DBy1Qt3V-3n_nUqmnSsXcAWr4ul_wBmln5Yw&oe=66D5959C"}, "display_name": "Monkey Runners tag", "keywords": [], "long_description": "Embark on a thrilling adventure with Monkey Runners tag, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. Monkey Runners tag isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "Monkey Runners tag is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mitrixstudio/privacy-policy?authuser=4", "developer_terms_of_service_url": "https://sites.google.com/view/mitrixstudio/terms-of-service?authuser=4", "publisher_name": "MitrixStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/mitrixstudio", "category": null, "comfort_rating": null, "comfort_tags": [], "contex