sQ7kNvgH2jV7e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQFeBtVLmXHE1qeYaAF25v7NCUTk9F_boAvwwNAugN_g&oe=67333923"}, {"file_name": "3Gamess (1).png", "id": "492466579787154", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86872476_492466583120487_5617277881909469914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vJVVZitfdXUQ7kNvgGJB5lg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDVugAQzC5HmPFrJtXRGelNHsHGfjEsKL91hEIEXk7KCQ&oe=67333460"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (1).png", "id": "7707588222621315", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035319_7707588225954648_4734747154780419881_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RsahJDLBuPwQ7kNvgF3erKJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANHJnARe72hj_Z9P49PmCgUGuvZ2Gd33ni_3gi5RWxQw&oe=6733301C"}, "display_name": "ProjectApe Alpha", "keywords": [], "long_description": "Embark on a thrilling adventure with ProjectApe Alpha, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. ProjectApe Alpha isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "ProjectApe Alpha is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_name": null