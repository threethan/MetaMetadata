68223_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JlflGX0WyBUQ7kNvgGNfS2s&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdExQZTPoH3nKVqJXatCI3n5WUjz-KZpcNfuWqKvda2A&oe=672F50BB"}, {"file_name": "1Gamess (1).png", "id": "823121499252120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982693_823121502585453_4016638522269531593_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKCzWV1GvSIQ7kNvgG0GAeU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAOOcT6XFJ0_GcTT8fx1RCm1OZhzC99EAfIQPBEl2IWFQ&oe=672F44A3"}, {"file_name": "3Gamess (1).png", "id": "492466579787154", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86872476_492466583120487_5617277881909469914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d8aQRotQqbAQ7kNvgGzSN_W&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZ8dcp4M9oP36BV_Zbfliu0h8FQ_3Bh2phKzdwUlKSBQ&oe=672F3FE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (1).png", "id": "7707588222621315", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035319_7707588225954648_4734747154780419881_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7tXM31ZSvYQ7kNvgH32sYi&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBp3TSR4AzqcXUKeZkZNjpjGQFa9SU3k4LlpaeLGjHNBw&oe=672F3B9C"}, "display_name": "Monkey Runners tag", "keywords": [], "long_description": "Embark on a thrilling adventure with Monkey Runners tag, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. Monkey Runners tag isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "Monkey Runners tag is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/mitrixstudio/privacy-policy?authuser=4", "developer_terms_of_service_url": "https://sites.google.com/view/mitrixstudio/terms-of-service?authuser=4", "publisher_name": "MitrixStudios", "support_website_url": null, "website_url": "https://sites.google.com/view/mitrixstudio", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8154811071216647"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2570842749743222"}]}, "baseline_offer": {"id": "2570842749743222"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720223103, "status": "PUBLISHED", "id": "2570842749743222"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8171973842833703", "version": "1.1.1"}, "id": "961539992373997", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"