uscdn.com&_nc_gid=AYStR02QuuOkf199l1GtweV&oh=00_AYCsUc-DJWyCvkAgGVWs2rpPb9hQmgI0vPYy5oOdht9CBA&oe=66D6F023"}, {"file_name": "3Gamess (1).png", "id": "492466579787154", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86872476_492466583120487_5617277881909469914_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8xINZ80Kd9cQ7kNvgFbv5js&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYStR02QuuOkf199l1GtweV&oh=00_AYA1jlzaTohSOaZe6DQvV4XBJzAYci469WkpE4-LvhvX7A&oe=66D6EB60"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "file (1).png", "id": "7707588222621315", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035319_7707588225954648_4734747154780419881_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxNA8UcJnxYQ7kNvgEFxEjR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AYStR02QuuOkf199l1GtweV&oh=00_AYBEIAQPFC4ReUce2920gzjTNiX2QC4jaqY6vR-tSRXAbQ&oe=66D6E71C"}, "display_name": "Monkey Runners tag", "keywords": [], "long_description": "Embark on a thrilling adventure with Monkey Runners tag, an Action game that unfolds in a captivating canyon environment. Monkeys, known for their unique hand-based movement, are pursued by infected lava monkeys aiming to tag and eliminate them. As the chase intensifies, the game offers diverse settings like a Jungle-like Forest, a City with quirky hats, and a spooky Cave with lurking ghosts. Each environment presents unique challenges and experiences, enhancing the excitement and strategy of the game. Monkey Runners tag isn't just a game; it's an immersive journey into a world of action and suspense, where players must outwit their foes to emerge victorious.", "short_description": "Monkey Runners tag is a fun action game set in a Canyon environment where monkeys who move with their hands are chased by infected lava monkeys which try to tag the normal monkeys until there is none left. There is alternative environments like a jungle-like forest, a city map with hats and a cave with a scary mine where ghosts lurk."}]}, "developer_nam