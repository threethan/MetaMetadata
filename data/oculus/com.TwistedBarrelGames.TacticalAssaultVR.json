3-1.oculuscdn.com/v/t64.5771-25/75395601_867512478277827_2970593899150014400_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4eT5SNP7BsYQ7kNvgFtwhyA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDt0EbFn68442c5qiw5lm1tGvSOUIyueqQA2ALRJ8K_pw&oe=671E2E72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TacticalAssaultV2.00_01_53_58.Still002.png", "id": "1531785064233088", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974482_1531785067566421_4048926409712966455_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gKE73tAXjm4Q7kNvgGSbkA8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1tV9w_Qhktmt8l0NCDUQsS5NjCrlpQA7HkUUsqkb8RQ&oe=671E3A32"}, "display_name": "Tactical Assault VR", "keywords": [], "long_description": "Become part of an elite special forces unit and use real-world CQB (Close Quarters Battles) tactics to breach doors, clear rooms, and defeat the enemy threat.\n\nFEATURES:\n\n\u2022 Play Solo or with up to 6 friends in cross-play supported coop between PCVR and Meta Quest players.\n\n\u2022 Utilize an arsenal of weapons, scopes, sight attachments, explosives, and equipment.\n\n\u2022 Consider physics-based bullet drop and time-to-hit for a more challenging sim.\n\n\u2022 Use stealth to sneak up behind enemies with a silent knife kill or butt-stock hit to the head. Or go head-to-head against AI enemies that will take cover and attempt to flank your position.\n\n\u2022 Randomized Enemy positions make each play-through an unknown challenge.\n\n\u2022 Non-linear, asymmetrical maps give players an endless variety in how they choose to infiltrate and complete missions. Enter buildings through doors, climb ladders to reach rooftops or climb through windows. The choice is yours.\n\n\u2022 Train hard in 2 variations of the Room Randomizer killhouse (complete with overhead catwalk), solo or with your friends. Lobby hosts have full control to add enemies, hostages, targets, and randomized rooms.\n\n\u2022 Test your skills against other players in multiplayer 5v5 PvP", "short_description": "Tactical MilSim CQB (Close Quarters Battles) in Virtual Reality"}]}, "developer_name": "Twisted Barrel Games", "developer_privacy_policy_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Twisted Barrel Games", "support_website_url": null, "website_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "7929005383823857"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974716_1304383553548320_1310395885026789401_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2eLrSJ05tKYQ7kNvgGih3Tn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAaIwg74xUchzq8h1qciG7R3DSZHLz_uRRKBauJwFJpFA&oe=671E2EEC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tactical Assault VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Simulation", "id": "331529