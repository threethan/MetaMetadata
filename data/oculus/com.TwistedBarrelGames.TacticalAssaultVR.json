_871826815057963_7999414902838153684_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b8TlTfDHyaEQ7kNvgHAIBu_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC5lWitULyx_1So8oUYNIM_g3DlhHIJ0ya1Qb4FhrLIjA&oe=677A5844"}, {"file_name": "TacticalAssaultV2.00_01_30_12.Still010.png", "id": "1277087726327735", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974746_1277087729661068_4889255500841367634_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H0v5ArBfW0wQ7kNvgHJw4Vm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAPY33KLn8ABq8WVSL8b2TB2RlPJ1AhrzJQbTkzSt8Kw&oe=677A83A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TacticalAssaultVRTrailerCoverImage.png", "id": "3497936147171850", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75540506_3497936150505183_3880119875800127416_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iRHTDuobOLUQ7kNvgGdt-bd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbfa-Rj3tsJ-t_kUCWiCoBGq060xZMH375a2BaIkg-Qg&oe=677A7856"}, "display_name": "Tactical Assault VR", "keywords": [], "long_description": "**Become part of an elite special forces unit in Tactical Assault VR!**\n\n\u2022 Habie147 - \u2018Tactical Assault Is One Of The Best Hardcore Shooters I\u2019ve Played\u2019\n\n\u2022 Gamertag VR - \u2018The Best Tactical VR FPS On Quest\u2019\n\n\u2022 Controlled Pairs - \u2018The Best CQB Game I've Ever Played\u2019\n\nTactical Assault VR is an intense tactical shooter where you use real-world CQB (Close Quarters Battles) tactics to stack up, breach doors and eliminate threats. Play solo or join an online co-op special forces unit in missions around the world.\n\n# Features\n**PvE Missions: Solo or Online Multiplayer Co-Op with Up to 6 Players**\n{1487526115258066}\n\n**PvP: Competitive Online Multiplayer**\n{1082589306850803}\n\n**7 Non-Linear, Asymmetrical Maps**\n\nPlan your assault. The choice is yours.\n{448475627682065}\n\n**Game Mode Variety**\n\nBomb Defusal, Hostage Rescue, High-Value Target (HVT) Eliminations, Mini Games, Room Randomizer Killhouse\n{1946208202559962}\n\n**30+ Detailed Weapons and Counting**\n\nCustomize your loadout with tactical gear including vests, helmets, weapons, scopes, sights, grips and breaching equipment.\n{1007758587705278}", "short_description": "Tactical Assault VR is an intense tactical shooter where you use real-world CQB (Close Quarters Battles) tactics to stack up, breach doors and eliminate threats. Play solo or join an online co-op special forces unit in missions around the world."}]}, "developer_name": "HammerFire Interactive", "developer_privacy_policy_url": "https://hammerfireint.wixsite.com/tactical-assault-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "2080 Games", "support_website_url": null, "website_url": "https://hammerfireint.wixsite.com/tactical-assault-vr", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8990976124293439"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_1276706369913827_7647552110835028212_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D2OCRJukq2AQ7kNvgEIDuXZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzOOTyzuzJtLHsZtIPOerhl8NtUzXUhRtNgP1fz