771-25/38974746_1277087729661068_4889255500841367634_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tIhQOVSrVn4Q7kNvgHMBeST&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABOY2hveYO3xfj-XVaenPsBb-XNfNqu9SeYifi7OQqPA&oe=672CBB26"}, {"file_name": "4.png", "id": "8497240080361622", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569466_8497240083694955_1163791780926778165_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UGwZJU5NyWMQ7kNvgEo4ACJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4C9KZU77zbWImcVQdTXZc_qvOMYdiTNGn_5IzaHEIFQ&oe=672C8F00"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TacticalAssaultVRTrailerCoverImage.png", "id": "3497936147171850", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75540506_3497936150505183_3880119875800127416_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mwqln_DnQlYQ7kNvgH_kv4E&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA79xUOJS_mdvyEoEpbbvEy7ZUaqCBgqjdabqYL_JDx0g&oe=672CAFD6"}, "display_name": "Tactical Assault VR", "keywords": [], "long_description": "**Become part of an elite special forces unit in Tactical Assault VR!**\n\n\u2022 Habie147 - \u2018Tactical Assault Is One Of The Best Hardcore Shooters I\u2019ve Played\u2019\n\n\u2022 Gamertag VR - \u2018The Best Tactical VR FPS On Quest\u2019\n\n\u2022 Controlled Pairs - \u2018The Best CQB Game I've Ever Played\u2019\n\nTactical Assault VR is an intense tactical shooter where you use real-world CQB (Close Quarters Battles) tactics to stack up, breach doors and eliminate threats. Play solo or join an online co-op special forces unit in missions around the world.\n\n# Features\n**PvE Missions: Solo or Online Multiplayer Co-Op with Up to 6 Players**\n{1487526115258066}\n\n**PvP: Competitive Online Multiplayer**\n{1082589306850803}\n\n**6 Non-Linear, Asymmetrical Maps**\n\nPlan your assault. The choice is yours.\n{448475627682065}\n\n**Game Mode Variety**\n\nBomb Defusal, Hostage Rescue, High-Value Target (HVT) Eliminations, Mini Games, Room Randomizer Killhouse\n{1946208202559962}\n\n**30+ Detailed Weapons and Counting**\n\nCustomize your loadout with tactical gear including vests, helmets, weapons, scopes, sights, grips and breaching equipment.\n{1007758587705278}", "short_description": "Tactical Assault VR is an intense tactical shooter where you use real-world CQB (Close Quarters Battles) tactics to stack up, breach doors and eliminate threats. Play solo or join an online co-op special forces unit in missions around the world."}]}, "developer_name": "HammerFire Interactive", "developer_privacy_policy_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "2080 Games", "support_website_url": null, "website_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8666576510066737"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001728_1276706369913827_7647552110835028212_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kRqEHrEcbb0Q7kNvgHjeUlL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIfuZ_-L9su6tfBDX9joszWjEv7gB0U-mbsjbCaQFSYQ&oe=6