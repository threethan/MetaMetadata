6D6ED3A"}, {"file_name": "05.png", "id": "370038625185407", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422392_370038628518740_2936465798892377324_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fSbHJmblK24Q7kNvgH297nS&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4utccZZgJbLOYkP4J2gT5VfMgXJW2Z6s7NIYilNCBeQ&oe=66D6F8C8"}, {"file_name": "03.png", "id": "404213504899404", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031553_404213508232737_1503129241169604478_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NJ6qn_7bAC0Q7kNvgEYrpAR&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjaHzwbKVypuvYBOcbrY2_-db76Sx9lVgSeK6QCRA3hQ&oe=66D6DF90"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "744940850199945", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036630_744940853533278_1975672743797178257_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0SZL0FZUepUQ7kNvgGZjZZx&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYkYSd1tXwg1xbQTrY7b-_yRrwhXzk8L9z9JUfcLD1Vg&oe=66D70265"}, "display_name": "Tactical Assault VR", "keywords": [], "long_description": "Become part of an elite special forces unit and use real-world CQB (Close Quarters Battles) tactics to clear rooms, breach doors, and defeat the enemy threat.\n\nFEATURES:\n\n\u2022 Utilize an arsenal of weapons, scopes, sight attachments, explosives and equipment.\n\n\u2022 Take note of simulated wind and target distance with the wind meter and spotter scope. Calculate physics-based bullet drop and time-to-hit to improve your accuracy.\n\n\u2022 Use stealth to sneak up behind enemies with a silent knife kill. Or go head-to-head against enemies that will take cover and attempt to flank your position.\n\n\u2022 Randomized Enemy positions and doors, making each play-through an unknown challenge.\n\n\u2022 Non-linear maps give players an endless variety in how they choose to infiltrate and complete missions. Enter buildings through doors, climb ladders to reach rooftops, or climb through windows. The choice is yours.\n\nTactical Assault VR is currently an Early Access release and is updated regularly.", "short_description": "Tactical MilSim CQB (Close Quarters Battles) in Virtual Reality"}]}, "developer_name": "Twisted Barrel Games", "developer_privacy_policy_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Twisted Barrel Games", "support_website_url": null, "website_url": "https://twistedbarrelgames.wixsite.com/tactical-assault-vr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "707998687088613"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1773876819610591"}]}, "baseline_offer": {"id": "1773876819610591"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1654502400, "status": "PUBLISHED", "id": "1773876819610591"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7565001170224282", "version": "0.7.0"}, "id": "1336107373548228", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5190911237633299", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7565001170224282"}, "release_status": "RELEASED"}, "binary_release_channels": {"nod