140129288323_5561555470870503337_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lcRDOI8JOMgQ7kNvgFFNU3s&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2_OB7zXJgFe1BPtdG1mPMdjBAvTQPjRbdObnKo2Sc5Q&oe=6752DD62"}, {"file_name": "plumbing_safety_screenshot04.png", "id": "1151255549012131", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75604731_1151255552345464_6993748918551720932_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kf954GdSiqoQ7kNvgHBXN-9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtliEISSmArApIJTOm3QAa2-t1s53_HRR_RO9jdRARbg&oe=6752DAA3"}, {"file_name": "plumbing_safety_screenshot05.png", "id": "652496856043975", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984469_652496859377308_1384755879490752956_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FiI75qeokyIQ7kNvgEySSzs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZAhJ6EnAbWnUMYjqKjY0xRkkGkPN9G5xZ-8Y4-i8k7w&oe=6752E3A6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "plumbing_safety_2560x1440.png", "id": "1003673383901988", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031495_1003673387235321_2863088526016688718_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cpWYMDw_xykQ7kNvgH28n_e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkN7PKY3zuhDodpSYU94bnsDHM3056dVntPZp8oESmSg&oe=6752DE0F"}, "display_name": "Plumbing Safety", "keywords": [], "long_description": "Plumbing Safety is a standalone experience that allows players to learn about, and test their knowledge of, electrical safety for plumbing, with a particular focus on cutting copper pipes. \n\nThe application is designed to teach players how to safely cut copper pipes, while avoiding any risk of electrocution. Players guided are through the process of safely cutting a copper pipe, using various tools throughout.\n\nOnce this guided section is complete, the player\u2019s is tested by completing the same process with no guidance. Feedback is given automatically as the player progresses. ", "short_description": "Plumbing Safety is designed to teach players how to safely cut copper pipes, while avoiding any risk of electrocution. Do you make the cut?"}]}, "developer_name": "TAFE NSW", "developer_privacy_policy_url": "https://www.tafensw.edu.au/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TAFE NSW", "support_website_url": null, "website_url": "https://www.tafensw.edu.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "779078573099039"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "535851078219814"}]}, "baseline_offer": {"id": "535851078219814"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1652461140, "status": "PUBLISHED", "id": "535851078219814"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5125244264261683", "version": "1.1"}, "id": "305512381668630", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4866987500087362", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5125244264261683"}, "release_status": "RELEASED"}, "binary_