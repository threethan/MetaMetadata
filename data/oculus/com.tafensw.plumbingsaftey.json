s through the experience.", "short_description": "Plumbing Safety is designed to teach players how to safely cut copper pipes, while avoiding any risk of electrocution. Do you make the cut?"}]}, "developer_name": "TAFE NSW", "developer_privacy_policy_url": "https://www.tafensw.edu.au/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TAFE NSW", "support_website_url": null, "website_url": "https://www.tafensw.edu.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "766077984578096"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001703_1131852977632373_2405840331018594929_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T431pwrhXOIQ7kNvgH65SS3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALKJxm6rPxlbHWevAXKRLT0GFg949BlHNnFIO5yOSkhQ&oe=67850C15"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Plumbing Safety", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Hands-On Training", "id": "514087707868786"}], "release_date": 1652461154, "lastRevision": {"nodes": [{"id": "1607537312954428", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "