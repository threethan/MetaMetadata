cdn.com/v/t64.5771-25/39035367_345996614688415_6091305747581745182_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tz3FHswYMdwQ7kNvgG45IHB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAadBDAUcUMvrnrGh-9rrq2uMvegpwhaNvoszqwZdIgvw&oe=67388D56"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Title4.png", "id": "3684407775164294", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031383_3684407778497627_3309220346244564187_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EHe5qs1hA1QQ7kNvgEQjGD5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA7adgBFngxE2SJBRnTzSQ9zwhwW1IQ1smSVtQCCap3ww&oe=67386ECB"}, "display_name": "FantasyTavernTactics", "keywords": [], "long_description": "At times, outsmart your opponents with clever piece placements, and at other times, defeat enemies directly with weapons in hand. This is the emergence of an entirely new board game experience, unique to VR.\n\nIn the strategic phase, manipulate the board considering the attributes and roles of the pieces, while the combat phase tests the player's skill. Success in both phases brings victory closer. Various elements are incorporated, including events where all pieces are forcibly moved, or buffs/debuffs are applied, as well as a diverse array of characters, stages, and combat styles!\n\nNote: In-app purchases are optional, and more than half of the game can be enjoyed for free.", "short_description": "Master the art of manipulating pieces strategically to dominate the board, and confront enemies in battles led by the player."}, {"images": {"nodes": [{"file_name": "Title_size2.png", "id": "1735025513640858", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982481_1735025516974191_2634919696788977522_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oh4qopieb_kQ7kNvgH6Mtx4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKjNM7K0Fmy6rTNf6jSTNMm1rA2WxW_VPfKyal8uEAYQ&oe=6738875D"}, {"file_name": "Titl