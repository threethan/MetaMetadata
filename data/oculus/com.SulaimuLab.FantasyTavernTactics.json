ry closer. Various elements are incorporated, including events where all pieces are forcibly moved, or buffs/debuffs are applied, as well as a diverse array of characters, stages, and combat styles!\n\nNote: In-app purchases are optional, and more than half of the game can be enjoyed for free.", "short_description": "Master the art of manipulating pieces strategically to dominate the board, and confront enemies in battles led by the player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://general-germanium-276.notion.site/Privacy-Policy-for-FantasyTavernTactics-65a2a1f0ef4b48f48e29cec53719137e?pvs=4", "developer_terms_of_service_url": null, "publisher_name": "Yuki Yamada", "support_website_url": null, "website_url": "https://www.notion.so/FantasyTavernTactics-db0953c16312421e8414e212a3b87e2c", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6980684448636646"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "866933225100826"}]}, "baseline_offer": {"id": "866933225100826"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1700673980, "status": "PUBLISHED", "id": "866933225100826"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6985533024818455", "version":