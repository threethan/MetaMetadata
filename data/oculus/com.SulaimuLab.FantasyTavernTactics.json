ps://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031383_3684407778497627_3309220346244564187_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k098TB53gyYQ7kNvgG6jQ1X&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDhN76uicVTQvZhXU0llw7c3KJkm8mNWKhpNxJPZqnEBw&oe=6705044B"}, "display_name": "FantasyTavernTactics", "keywords": [], "long_description": "At times, outsmart your opponents with clever piece placements, and at other times, defeat enemies directly with weapons in hand. This is the emergence of an entirely new board game experience, unique to VR.\n\nIn the strategic phase, manipulate the board considering the attributes and roles of the pieces, while the combat phase tests the player's skill. Success in both phases brings victory closer. Various elements are incorporated, including events where all pieces are forcibly moved, or buffs/debuffs are applied, as well as a diverse array of characters, stages, and combat styles!\n\nNote: In-app purchases are optional, and more than half of the game can be enjoyed for free.", "short_description": "Master the art of manipulating pieces strategically to dominate the board, and confront enemies in battles led by the player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://general-germanium-276.notion.site/Privacy-Policy-for-FantasyTavernTactics-65a2a1f0ef4b48f48e29cec53719137e?pvs=4", "developer_terms_of_service_url": null, "publisher_name": "Yuki Yamada", "support_website_url": null, "website_url": "https://www.notion.so/FantasyTavernTactics-db0953c16312421e8414e212a3b87e2c", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "re