ame": "\u30b5\u30e0\u30cd5_3.png", "id": "345996608021749", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035367_345996614688415_6091305747581745182_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4O0o5r75EYUQ7kNvgGvO_kv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUAAJ5TF7nHa7iX3sl5CekOP8cwhDtsmo241EImMz0Mg&oe=6718E956"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Title4.png", "id": "3684407775164294", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031383_3684407778497627_3309220346244564187_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-Ck7xYOXWEgQ7kNvgFCV70O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAt6WeTD62OHVuO4JnwnKevCAyWpUMA2ndd5xKw6rWwzw&oe=6718CACB"}, "display_name": "FantasyTavernTactics", "keywords": [], "long_description": "At times, outsmart your opponents with clever piece placements, and at other times, defeat enemies directly with weapons in hand. This is the emergence of an entirely new board game experience, unique to VR.\n\nIn the strategic phase, manipulate the board considering the attributes and roles of the pieces, while the combat phase tests the player's skill. Success in both phases brings victory closer. Various elements are incorporated, including events where all pieces are forcibly moved, or buffs/debuffs are applied, as well as a diverse array of characters, stages, and combat styles!\n\nNote: In-app purchases are optional, and more than half of the game can be enjoyed for free.", "short_description": "Master the art of manipulating pieces strategically to dominate the board, and confront enemies in battles led by the player."}]}, "developer_name": null, "developer_privacy_policy_url": "https://general-germanium-276.notion.site/Privacy-Policy-for-FantasyTavernTactics-65a2a1f0ef4b48f48e29cec53719137e?pvs=4", "developer_terms_of_service_url": null, "publisher_name": "Yuki Yamada", "support_website_url": null, "website_url": "https://www.notion.so/FantasyTave