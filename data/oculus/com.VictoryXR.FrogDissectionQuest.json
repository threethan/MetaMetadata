1.oculuscdn.com/v/t64.5771-25/38974557_1523362687867603_8006254319467572752_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lQzhtnburMsQ7kNvgH39VXO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDyGqys9KQRVOAeF_q2ZxX2rOFkNfm1NKgWFZ_OhS6Hew&oe=67596F17"}, {"file_name": "screen_3840x2160_2019-03-01_10-23-46.png", "id": "771761426798191", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_771761430131524_1100158076390414683_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bkWR-HuJ5J0Q7kNvgGwgEBQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYAyhAolD5f-aOQIMWqj5XqublJyhjlyBUi3tn25VtxQ&oe=675988A1"}, {"file_name": "screen_3840x2160_2019-03-01_10-27-00.png", "id": "136188651734611", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_136188655067944_7185274200733071584_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TD_0l-QlhsQQ7kNvgGEUHPE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADYSAcPOJZgJMNDHhTGzBN_6QzeykuA_MgJQ9XR8cf1Q&oe=6759812E"}, {"file_name": "screen_3840x2160_2019-03-01_10-42-41.png", "id": "136968264983571", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003251_136968268316904_1114109492687052247_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bz-FVNis1UsQ7kNvgHXWdEH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC7jCnCMCRtsVUd-7TzL-CF2o52o2iUNP8Z63iUrU19ag&oe=675975C1"}, {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "347492349857576", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974738_347492353190909_3456758484560401732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6x6YcIWU3gYQ7kNvgEBDPft&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTSydg4lKxCPIii0PdvrB1nAbxQkfgFzZvXg0tp6W80g&oe=6759689B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "213573287218582", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569425_213573290551915_1186836567141116527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3zp71g7F3VAQ7kNvgEOedHE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCt6XlE6ZLEAc_Q8BhZxmYsls1hQJr9-fFvTBf9UudSeA&oe=6759617E"}, "display_name": "Dissection Simulator: Frog Edition", "keywords": [], "long_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users.\n\nAll of the instruction follows the Next Generations Science Standards (NGSS), the national science standards for the United States. The dissection experience is recreated to the finest detail so that they are a suitable substitute for the real thing in a classroom. Lifelike physical models mean that the frog appears as it would in a real dissection allowing science teachers to feel good about substituting virtual reality for the real thing. ", "short_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users."}]}, "developer_name": null, "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "conte