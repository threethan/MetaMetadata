GBUQ7kNvgEtmGYo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkuxLAWyet6pduBq7nrlJgJK8zk_6aDW_dyDrEWK4zbg&oe=670E4997"}, {"file_name": "screen_3840x2160_2019-03-01_10-23-46.png", "id": "771761426798191", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982601_771761430131524_1100158076390414683_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mw2Fbg8_Ru8Q7kNvgHOODyd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBkh5e5fDG8e1_8XpdI7Yy7arBF1MZmPm12W3TflHHteA&oe=670E6321"}, {"file_name": "screen_3840x2160_2019-03-01_10-27-00.png", "id": "136188651734611", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_136188655067944_7185274200733071584_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NBPB1o2zre0Q7kNvgFDFN0L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhguYrLv3Dpwf2iA7kpajcEDvX6Tk6RhnR66f-gN3S-Q&oe=670E5BAE"}, {"file_name": "screen_3840x2160_2019-03-01_10-42-41.png", "id": "136968264983571", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003251_136968268316904_1114109492687052247_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dGwYpebtaPwQ7kNvgHxdB6U&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD7n2bnOVgtjn_vSrnI706J0qtz48rIGnRMt5gnaF3AYA&oe=670E5041"}, {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "347492349857576", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974738_347492353190909_3456758484560401732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sN7UZ71UEmsQ7kNvgGhynIQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCKexF5f8XjEqhdqFqe51_6Nl8P7_D-wVoilamv4sTqag&oe=670E431B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "213573287218582", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569425_213573290551915_1186836567141116527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uwpmbwc4hPoQ7kNvgG3-Ptg&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtDU5K8c4RbMtNzA0Eqc8fAo0f7NHmqUrtssvYRvj8IA&oe=670E3BFE"}, "display_name": "Dissection Simulator: Frog Edition", "keywords": [], "long_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users.\n\nAll of the instruction follows the Next Generations Science Standards (NGSS), the national science standards for the United States. The dissection experience is recreated to the finest detail so that they are a suitable substitute for the real thing in a classroom. Lifelike physical models mean that the frog appears as it would in a real dissection allowing science teachers to feel good about substituting virtual reality for the real thing. ", "short_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users."}]}, "developer_name": null, "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_RE