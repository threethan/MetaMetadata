ntent.oculuscdn.com/v/t64.5771-25/38974557_1523362687867603_8006254319467572752_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gqjym6DHl08Q7kNvgF-86In&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYClK-cRbRY1q5tcoJk4S6E3jJ5f3MxHQKGfT_NQOi9Tbw&oe=66E6BC97"}, {"file_name": "screen_3840x2160_2019-03-01_10-23-46.png", "id": "771761426798191", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982601_771761430131524_1100158076390414683_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nxDjFsWo9VoQ7kNvgFbken8&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYBGKCc7OWC9wGjvmkfg76EVHQXe3_nfI9mM_Eb2i5p2Sw&oe=66E6D621"}, {"file_name": "screen_3840x2160_2019-03-01_10-27-00.png", "id": "136188651734611", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974634_136188655067944_7185274200733071584_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KmgmsKzDQfQQ7kNvgFOtlwZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYBtAkthOFAwPOl2Y2iUzAK2vfJA0UeIo6aeovdRMRPETw&oe=66E6CEAE"}, {"file_name": "screen_3840x2160_2019-03-01_10-42-41.png", "id": "136968264983571", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003251_136968268316904_1114109492687052247_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wc4lu3OAnMoQ7kNvgFHiSVK&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYCAKjnMr4I0nB-Ki2R_eHQD0iyb0cLXs5TK9jeQiTsx5A&oe=66E6C341"}, {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "347492349857576", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974738_347492353190909_3456758484560401732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7_xPsFvIiGcQ7kNvgHYpKHi&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYC10I5M967C1BshWFjeKAQMQzvX8zZTQkjCvXRz4WnTKA&oe=66E6B61B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "213573287218582", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569425_213573290551915_1186836567141116527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4UbeCvbsE0sQ7kNvgEkq6-M&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aw2-DlSBJZqqMOauTGanzOa&oh=00_AYDiJvBiqwOMWotGs6accdVlYCvI-ZZR9lcLayPGiVyrkw&oe=66E6AEFE"}, "display_name": "Dissection Simulator: Frog Edition", "keywords": [], "long_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users.\n\nAll of the instruction follows the Next Generations Science Standards (NGSS), the national science standards for the United States. The dissection experience is recreated to the finest detail so that they are a suitable substitute for the real thing in a classroom. Lifelike physical models mean that the frog appears as it would in a real dissection allowing science teachers to feel good about substituting virtual reality for the real thing. ", "short_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users."}]}, "developer_name": null, "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfor