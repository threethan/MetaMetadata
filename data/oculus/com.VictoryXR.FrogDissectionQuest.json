54319467572752_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TqjcFVXXpR0Q7kNvgH22xRH&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBgtkA0jUEp1zXtep_0A8az88S9BWf9-ncHQ-OHe_7v1Q&oe=6710EC97"}, {"file_name": "screen_3840x2160_2019-03-01_10-23-46.png", "id": "771761426798191", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982601_771761430131524_1100158076390414683_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fHE8Y4O0LQoQ7kNvgEEM0wy&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBQ3ao6oh_KDl8YYMVoPrp-htib7jHs6bLaXONGWBehzg&oe=67110621"}, {"file_name": "screen_3840x2160_2019-03-01_10-27-00.png", "id": "136188651734611", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974634_136188655067944_7185274200733071584_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NBPB1o2zre0Q7kNvgFLIV5v&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDWJDzPxPjnmdPuOxBmi_9zfYw7y4Cb1m-6uuDaJkpVLg&oe=6710FEAE"}, {"file_name": "screen_3840x2160_2019-03-01_10-42-41.png", "id": "136968264983571", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003251_136968268316904_1114109492687052247_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1Re6w_Byt30Q7kNvgGjhNcc&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYB7R6gjjjQNUF-QCcucvj3Muvh0xrfxQqU5fkrpGqUrqg&oe=6710F341"}, {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "347492349857576", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974738_347492353190909_3456758484560401732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sN7UZ71UEmsQ7kNvgEXee3m&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCh2DbnpGzOuRBZclH5hpn-uNcUff-8w6H4umzqQUrNvw&oe=6710E61B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "213573287218582", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57569425_213573290551915_1186836567141116527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2w1BWDv_6YwQ7kNvgEl0Fyx&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCJx5vrEz1XmOaShf6v03FxtUwWJnJJE3U6uYAObmHOXg&oe=6710DEFE"}, "display_name": "Dissection Simulator: Frog Edition", "keywords": [], "long_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users.\n\nAll of the instruction follows the Next Generations Science Standards (NGSS), the national science standards for the United States. The dissection experience is recreated to the finest detail so that they are a suitable substitute for the real thing in a classroom. Lifelike physical models mean that the frog appears as it would in a real dissection allowing science teachers to feel good about substituting virtual reality for the real thing. ", "short_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users."}]}, "developer_name": null, "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscr