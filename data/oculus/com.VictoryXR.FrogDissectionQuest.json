y6EQ7kNvgHxNgwD&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCo6wKvfJ_wn2MNQCq5dFQhHJRWwiuimdeSsgvhduxJ1w&oe=67011A97"}, {"file_name": "screen_3840x2160_2019-03-01_10-23-46.png", "id": "771761426798191", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982601_771761430131524_1100158076390414683_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfR_-nhkfeQQ7kNvgGkFvNE&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBpQj8BbuC7fdpLPbf3REkZJAEtTYDORSiVs6WV_1Zi8w&oe=67013421"}, {"file_name": "screen_3840x2160_2019-03-01_10-27-00.png", "id": "136188651734611", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974634_136188655067944_7185274200733071584_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4PMN-ZhS4QIQ7kNvgH4PROd&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD-GS4byly0_uw73l-6i-9-wqZ3E1HDjIS0z7ZBdSke4w&oe=67012CAE"}, {"file_name": "screen_3840x2160_2019-03-01_10-42-41.png", "id": "136968264983571", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39003251_136968268316904_1114109492687052247_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MqUD0S8rbbIQ7kNvgFiXp4-&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCcP3mPybmJr2bqWvUgRZq1cUZPivakLk00YkMuga1fFA&oe=67012141"}, {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "347492349857576", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974738_347492353190909_3456758484560401732_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4DXvqnXDGwkQ7kNvgG3TIQC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA2rUxFV06y_6Qo3dvss8q57HIw6QaMzOdK13S0w7l8Vg&oe=6701141B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-03-01_10-14-43.png", "id": "213573287218582", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569425_213573290551915_1186836567141116527_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wOwCgdLuaToQ7kNvgEAr7cL&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB7DFKna-BnXo3aVhHoWf8n6EpGtNv-2KUgf8qoKOf8jA&oe=67010CFE"}, "display_name": "Dissection Simulator: Frog Edition", "keywords": [], "long_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users.\n\nAll of the instruction follows the Next Generations Science Standards (NGSS), the national science standards for the United States. The dissection experience is recreated to the finest detail so that they are a suitable substitute for the real thing in a classroom. Lifelike physical models mean that the frog appears as it would in a real dissection allowing science teachers to feel good about substituting virtual reality for the real thing. ", "short_description": "VictoryXR's virtual reality frog dissection software is a hands-on dissection opportunity that users can experience through the power of virtual reality. This true to life experience covers each step that a student would take if they were dissecting a real frog in their classroom. Along the way, a hologram of our teacher - national runner-up Teacher of the Year, Wendy Martin - will pop up to provide instruction and information to users."}]}, "developer_name": null, "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SIMULATION", "EDUCATIONAL"], "has_in_app_ads": false, "internet_connection": "NOT_RE