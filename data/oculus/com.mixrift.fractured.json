0"}, {"file_name": "ss2.png", "id": "1153083632606543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982701_1153083635939876_4539489679555039939_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kQ6QsGrTlvwQ7kNvgGHnEeB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSU7ecPpBFhyyK8r65f07enhMLBPfUC07AyJgaGG1nMw&oe=67499DDC"}, {"file_name": "ss3.png", "id": "872645808218684", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031518_872645811552017_7366970088259224221_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VotD3d2b2QwQ7kNvgFrzacG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAiRg_cqDS-pNnF_U_yVPhFwH_IeD9uz1zwKp2fPZ_slQ&oe=674992FF"}, {"file_name": "ss5.png", "id": "1892662821248180", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974562_1892662824581513_2096364176695943357_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tbxf7pSm1I8Q7kNvgH__RHi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAp1L24clXvEJiH2JN2bLyl5xihNlR6Ex_JQKlzpr9RgA&oe=6749B3B5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "fractured trailer cover.png", "id": "757294396341830", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031574_757294399675163_1160182085240825206_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-NoQ31pxjwcQ7kNvgHjTSN4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMgjE-Dx3glkKulEifGcna_6OVHsdS8ffA5GwDMuVosg&oe=6749AAE9"}, "display_name": "Fractured: Mixed Reality 3D puzzle", "keywords": [], "long_description": "Fractured offers a soothing 3D puzzle experience in Mixed Reality right in your home. Reassemble 3D models that have shattered into pieces, all within the cozy atmosphere of your room. Immerse yourself in the flow of puzzling with pieces floating around you, accompanied by relaxing lo-fi music in the background. \n\nEnjoy an immersive take on an old time hobby by putting together the models piece by piece. Play either seated or standing! Simply drag an object from the menu out into your space and start puzzling! \n\n \ud83e\udde9 Assemble 3D puzzles in your own environment through Mixed Reality\n\n \ud83e\udde9 Ten unique puzzles\n\n \ud83e\udde9 Each model can break into 5, 15 and 25 pieces based on your chosen difficulty\n\n \ud83e\udde9 Resize the puzzle pieces to your liking\n\n \ud83e\udde9 22 calming songs\n\n\nRelax, unwind, and rediscover the joy of puzzling with Fractured \u2014 your ultimate Mixed Reality puzzle adventure.\n", "short_description": "Fractured brings relaxing 3D puzzling to your environment. Put together 3D models that fall on the floor and get broken into pieces, all in the cozy atmosphere of your home. Enter the flow of puzzling with pieces orbiting all around you, and calming lo-fi music in the background."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.mixrift.com/privacy-policy", "developer_terms_of_service_url": "https://www.mixrift.com/terms-of-use", "publisher_name": "MIXRIFT", "support_website_url": "https://www.mixrift.com/contact-us", "website_url": "https://mixrift.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7682424705129302"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "529643526613438"}, {"status": "PUBLISHED", "id": "2988498517970101"}, {"status": "PUBLISHED", "id": "551291237595246"}, {"status": "PUBLISHED", "id":