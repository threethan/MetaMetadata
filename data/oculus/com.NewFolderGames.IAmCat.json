gaming experience like no other. Prepare to be enthralled by its charm, depth, and endless entertainment that will keep you coming back for more.\n\nCurrently in Early Access, the game will continue to evolve with new content, exciting locations, intricate storylines, challenging missions, and compelling characters being added over time. \n\nStay tuned for an ever-growing world of adventures and mysteries waiting to be uncovered!", "short_description": "Meow and purr, in this virtual delight, I Am Cat - an adventure bright!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "221474260512660"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "432733266138847"}]}, "baseline_offer": {"id": "432733266138847"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716480360, "status": "PUBLISHED", "id": "432733266138847"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8100594656683419", "version": "1.0.11"}, "id": "1000601100950978", "channel_name": "LIV