scdn.com/v/t64.5771-25/57569446_423905457193075_3386428171821116355_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dmxH2W0MQwsQ7kNvgEJ-5cR&_nc_ht=scontent.oculuscdn.com&oh=00_AYDjCekpHXBW2woGKclNpJhM4dZ-ri2ka21FxYAeu6mXLQ&oe=66DD8200"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "I am cat  2560 x 1440.png", "id": "968901731212026", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/43931336_968901734545359_472725170425619285_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=javOOT0aJIQQ7kNvgFgxRKG&_nc_ht=scontent.oculuscdn.com&oh=00_AYBHTpA6xnBdWv4vNGZ-27hMANtYw9Fa-XfudREk6hjCUA&oe=66DD7393"}, "display_name": "I Am Cat - Early Access", "keywords": [], "long_description": "I Am Cat - a unique virtual reality game, there's nothing like it in the world! It's a sandbox adventure centered around a Cat protagonist bearing. A captivating journey where you embrace the role of a Cat. Immerse yourself in a world brimming with diversity and excitement, awaiting your exploration.\n\nOur standout feature is the cutting-edge locomotion system tailored for unparalleled character control. Experience an innovative and engaging mechanic that sets our game apart from the rest, adding depth and immersion to your gameplay.\n\nI Am Cat boasts a plethora of content, from expansive landscapes to captivating quests, vibrant characters, and interactive objects galore. Dive into a rich tapestry of possibilities, where every corner is teeming with surprises and challenges to conquer.\n\nI Am Cat is the epitome of coolness, offering a gaming experience like no other. Prepare to be enthralled by its charm, depth, and endless entertainment that will keep you coming back for more.\n\nCurrently in Early Access, the game will continue to evolve with new content, exciting locations, intricate storylines, challenging missions, and compelling characters being added over time. \n\nStay tuned for an ever-growing world of adventures and mysteries waiting to be uncovered!", "short_description": "Meow and purr, in this virtual delight, I Am Cat - an adventure bright!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://newfolderstudio.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "NEW FOLDER GAMES LTD", "support_website_url": null, "website_url": "https://newfolderstudio.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "221474260512660"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "432733266138847"}]}, "baseline_offer": {"id": "432733266138847"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1716480360, "status": "PUBLISHED", "id": "432733266138847"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8063640283712190", "version": "1.0.9"}, "id": "1000601100950978", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6061406827268889", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8063640283712190"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1000601100950978"}]},