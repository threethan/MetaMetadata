71488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wypyi7PsrMkQ7kNvgGljJJr&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBAWU2J9Z_kuT85fDCsKLVhhX0sOq4hVgZiQ0zIlB3Png&oe=66EAC027"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=954y3awvdsoQ7kNvgGXrhC9&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCtj7a_a6nO00qfmbQdXsnSAXxCBF64LIL6ztbtGMhBcA&oe=66EAC62B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Z0cDUjy9VMQ7kNvgGrAM7A&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBzhs-cF7sRUnxFXx0gy3hg8KItxPtXGF9hkCsKlIHxcA&oe=66EAAB56"}]}, "id": "1137501624009601", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Cover Art - Portrait.png", "id": "6647755272010080", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982588_6647755275343413_6975862371154701560_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gJCpO-urZOUQ7kNvgFKJbKf&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYDvFHWBRUg0N8oKkd_-Yr0nZJRQsZNTyx3jbi4JeL8whg&oe=66EAD434"}, {"file_name": "Fluent XR Mobile Icon.png", "id": "2082304598777986", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_2082304602111319_6670855186104070571_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QW_84W8BwC0Q7kNvgE8ZSaX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYByN_vAWPDAkUEs_vGmrLWaMXC8xfX5Ipy88pwZtdMAgQ&oe=66EABD2C"}, {"file_name": "Fluent XR Logo transparent.png", "id": "1984998648546806", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1984998651880139_3178193652368604560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2eiiFGPD7aEQ7kNvgH82E-D&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYC6fOBvex-yOmNO4AJbI1CZqxnUhNTbh7ziN54tcv0w8Q&oe=66EAB08E"}, {"file_name": "Fluent XR Cover Art.png", "id": "1753372745086018", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974868_1753372748419351_7413283912851125343_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HxaNMkDWtKUQ7kNvgHiT0ih&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCLNFB_IiBTn3BS_Z_GdaK1DB_A8vnfFbG0JhucDZWq9g&oe=66EAC5F5"}, {"file_name": "Fluent XR Cover Art - Square.png", "id": "1307619323205125", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_1307619326538458_7751189323196005702_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BVkGsN3FqKAQ7kNvgE9p4AZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBr8fzzYMp1ai4Cboa4WyL2w3dp8VlTXS6bSuiAMekcsw&oe=66EAA434"}, {"file_name": "Fluent XR Cover Art - Mini Landscape.png", "id": "1239723750053984", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230044_1239723753387317_7790772509280140276_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MWgCVuza0m8Q7kNvgFQhw9R&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYC4wucQo14Cneo29lCijWrc3x0dnFw_JQhvLpwQM57M6w&oe=66EAC81E"}, {"file_name": "Fluent XR PDP Art.png", "id": "1061096168226207", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_1061096171559540_9065798130022169599_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nV0dyFJOwasQ7kNvgEPMHg2&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYC3ZBgWMXRVG0CPL94VQdzezvwUCOS3lcuR1F8H4k_zjQ&oe=66EA9CB3"}]}, "id": "449609844722656", "locale": "en_US", "screenshots": [{"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "755435526614104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_755435529947437_3157283510711493706_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ZaaRWkW104Q7kNvgEEBIzV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCorOy5YPJNm-gCBCRnRBbJkU5tKcrJW6gJFkFJYPofyA&oe=66EAC23F"}, {"file_name": "Sequence 04.00_34_53_09.Still016.png", "id": "377326888090872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_377326891424205_2576812618867292544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D7WktOVUZycQ7kNvgFV56qx&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYAPwOmiK_XNjqjyXwi2UJc7mHMk2lyZyT1jbMb54lJvUA&oe=66EAC40E"}, {"file_name": "Sequence 04.00_49_22_19.Still025.png", "id": "1792607307852843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035387_1792607311186176_5280458374548206595_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kuCxXu4EqfAQ7kNvgF3HuaH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYAZ8gAB2mPcZN9Fhv2Yt0nDHjwyv90UZLnJI4x0bWl77A&oe=66EAC916"}, {"file_name": "Sequence 04.00_52_56_05.Still030.png", "id": "245249301718520", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031325_245249305051853_1598234300064219875_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUlV6b-FOhMQ7kNvgHfpe5l&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCAQNGbjliRsJBcvu4gQHroKYLWlg8MIRG3aLhi9OhxiA&oe=66EAA8B7"}, {"file_name": "Sequence 04.00_11_37_00.Still002.png", "id": "733795254815172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036675_733795258148505_1346935370172344005_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RDg6d9zPZ8cQ7kNvgHUpU-7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYDYgYe9HTZLN032TFSKd6YvBo3OPPyaO2sxYLo7ZdXqEg&oe=66EAAFF2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "894248482404839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_894248485738172_2991357501924730672_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=siA9fB7t2bYQ7kNvgFvv3Kl&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBmyPjK1NyxaD2fwlTEMFYqLD2uLIMbUL8fPBhUqGnUsA&oe=66EAC79B"}, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privac