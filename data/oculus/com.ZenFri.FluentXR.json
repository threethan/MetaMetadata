71488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWe_5RAQO-EQ7kNvgE2bdES&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYDY3uNckUDMAK9A1KA3rcacrDekt8xJgBxZ9eMrlJpolA&oe=66F157A7"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zBiyrA87z_YQ7kNvgHuzoxi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYCDK-A7qNLuGzNAABlJ9IZRpvCD2PvTA1iXVxc9ICgvEg&oe=66F15DAB"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0dFdUOgCEOkQ7kNvgH-zVx9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYCq8kULzQnD9DZ84jtSU_8d8ukk_57mhnb1t-4efBflNQ&oe=66F142D6"}]}, "id": "1137501624009601", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Cover Art - Portrait.png", "id": "6647755272010080", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982588_6647755275343413_6975862371154701560_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yYVmh5DNq4sQ7kNvgElGNYC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYA8UxB9iL-tlhHaXOJkDpNfMiiOyeRYTDvzq_0DrtzBqQ&oe=66F16BB4"}, {"file_name": "Fluent XR Mobile Icon.png", "id": "2082304598777986", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_2082304602111319_6670855186104070571_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Jq9aGtPW8YQ7kNvgFaYYln&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYCuTRdmasAj01ZuXkmJ01f2NB5wEGa7JJNiUkbpQ-Lqow&oe=66F154AC"}, {"file_name": "Fluent XR Logo transparent.png", "id": "1984998648546806", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1984998651880139_3178193652368604560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEme7nLX-iMQ7kNvgEZ2AUI&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYAtp3lfxgVCYLcf-Or7i8-SeTcQ54kOvPYSbe-jDQ4xhA&oe=66F1480E"}, {"file_name": "Fluent XR Cover Art.png", "id": "1753372745086018", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974868_1753372748419351_7413283912851125343_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UnhCYpXZjwUQ7kNvgFYRJ0c&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYDRJjEVoSWYS3vnXzR4j4L2YZsDwft1HDTTvnEGNc5ukw&oe=66F15D75"}, {"file_name": "Fluent XR Cover Art - Square.png", "id": "1307619323205125", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_1307619326538458_7751189323196005702_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7-0wpce0lvQQ7kNvgHF_r46&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYB9i0B9Zf2UT36H5LRTReTufU60zrA4qMtFD3ZeKY8SPw&oe=66F13BB4"}, {"file_name": "Fluent XR Cover Art - Mini Landscape.png", "id": "1239723750053984", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230044_1239723753387317_7790772509280140276_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UXPlfpkPHXMQ7kNvgEBh5hs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYB7wlnssOTo6m3jgukVk-tJ2LgQZpuTUOC_colP7-OSqw&oe=66F15F9E"}, {"file_name": "Fluent XR PDP Art.png", "id": "1061096168226207", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_1061096171559540_9065798130022169599_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vye1opy4Vg0Q7kNvgH_EUeC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYDtWcaKRBKwXa1LshjlnZ4oObzTQsc7q5B60Ogr9SXGzQ&oe=66F16C73"}]}, "id": "449609844722656", "locale": "en_US", "screenshots": [{"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "755435526614104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_755435529947437_3157283510711493706_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvUZHCtaaKMQ7kNvgGPio0r&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYDpn71zEy3Ova_3KTnbeXaf8X1yIosKhATT3O89j64tqw&oe=66F159BF"}, {"file_name": "Sequence 04.00_34_53_09.Still016.png", "id": "377326888090872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_377326891424205_2576812618867292544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u2QnwfSGiKsQ7kNvgFObtFi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYCA01Yla3STnyCcjEhqz5e-VwQemdUF7sKdOckqOA6anA&oe=66F15B8E"}, {"file_name": "Sequence 04.00_49_22_19.Still025.png", "id": "1792607307852843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035387_1792607311186176_5280458374548206595_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rahRWbMqE7MQ7kNvgED6Xht&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYBCK5czL6AGyZZTtYWjek2dVVTQknXDauWpb3nc17Xsdg&oe=66F16096"}, {"file_name": "Sequence 04.00_52_56_05.Still030.png", "id": "245249301718520", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031325_245249305051853_1598234300064219875_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMZAN1I3iJgQ7kNvgFKQLAS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYDMd-MKQObenevgWcvvaKK1BNh9-YGkkYYRO8pvXlVxcw&oe=66F14037"}, {"file_name": "Sequence 04.00_11_37_00.Still002.png", "id": "733795254815172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036675_733795258148505_1346935370172344005_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p83z0Na9g3kQ7kNvgHUEAod&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYCc1-avOEzdp-IRbGItuGS7lrfCH_AEOucqicP1KisLUA&oe=66F14772"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "894248482404839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_894248485738172_2991357501924730672_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0jO9fOJn5QUQ7kNvgHs-BQs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKlD3shROvt6h5BhcTxire-&oh=00_AYAfCf-B0N2Atf4e4PH4XRl04hy2xPRgc3UCyDr81ymyRw&oe=66F15F1B"}, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privac