A3ceKCsG_osI&oh=00_AYCACEvlEDSGKtneTvleafa7uymyTqECU8WwRGp8yuHUaA&oe=66EA9FBF"}, {"file_name": "FluentXR_Media Storage_Screenshot.png", "id": "3267266376829151", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974717_3267266380162484_3578961694161774596_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v8ppjBfIZMsQ7kNvgF4TTjC&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCr2Rr-hI9mUSAHHU4ePpVMyKzdhacLtA6KIAZ0Nz6Wqw&oe=66EAB916"}, {"file_name": "FluentXR_Throw Pillow_Screenshot.png", "id": "3559508997603615", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974691_3559509000936948_3261126970408815056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hwPgKITuvocQ7kNvgG60B7J&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYDeoFGBH4l0Y74xlmEZrpGD0ELF5D3evhNCpqsi1rHLbg&oe=66EAAFFD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Mobile Icon.png", "id": "2236631716529956", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974513_2236631719863289_7778467312643440417_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-OnyR55yLgAQ7kNvgGMoCh4&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYAmCMIH_KA6vKRHCuCZimu5f9TtL_g35kLGXEWqAV53nw&oe=66EAA315"}, {"file_name": "Fluent XR PDP Art.png", "id": "2055286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wypyi7PsrMkQ7kNvgGljJJr&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBAWU2J9Z_kuT85fDCsKLVhhX0sOq4hVgZiQ0zIlB3Png&oe=66EAC027"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=954y3awvdsoQ7kNvgGXrhC9&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYCtj7a_a6nO00qfmbQdXsnSAXxCBF64LIL6ztbtGMhBcA&oe=66EAC62B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Z0cDUjy9VMQ7kNvgGrAM7A&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2CfQziUvnYA3ceKCsG_osI&oh=00_AYBzhs-cF7sRUnxFXx0gy3hg8KItxPtXGF9hkCsKlIHxcA&oe=66EAAB56"}]}, "id": "358335263228750", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_url": null, "website_url": "https://zenfri.ca/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7093968170666792"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "995844588189802"}]}, "baseline_offer": {"id": "995844588189802"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1699893000, "status": "PUBLISHED", "id": "995844588189802"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7198485716881703", "version": "0.250"}, "id": "817807436557034", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6843469252383353", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7198485716881703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "817807436557034"}]}, "change_log": null, "created_date": 1702024228, "id": "7198485716881703", "version": "0.250", "version_code": 250, "r