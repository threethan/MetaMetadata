nt-iad3-2.oculuscdn.com&oh=00_AYBfUxR0WjG72YyklOoJYD2ibTICillgVgaJSD1fRLDGMg&oe=674DA2BF"}, {"file_name": "Sequence 04.00_34_53_09.Still016.png", "id": "377326888090872", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031365_377326891424205_2576812618867292544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p3Dc5WjrUvoQ7kNvgGzenAg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDH1i_Mj8avgoFYg399M9jCCOr4bFgVGf3Ln8uSR5sTxQ&oe=674DA48E"}, {"file_name": "Sequence 04.00_49_22_19.Still025.png", "id": "1792607307852843", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035387_1792607311186176_5280458374548206595_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a39m8T9ALbAQ7kNvgF3RvXg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAFRt2syJUH9m5Ut9ay4iYApAy_RtQeZbrWZhfkeOhlGA&oe=674DA996"}, {"file_name": "Sequence 04.00_52_56_05.Still030.png", "id": "245249301718520", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031325_245249305051853_1598234300064219875_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5qjsRwcMShUQ7kNvgGRz45y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJrh7Lpa_YwDZqY8oGd6hSLui3e7kVZwatwkbrgaA9gw&oe=674D8937"}, {"file_name": "Sequence 04.00_11_37_00.Still002.png", "id": "733795254815172", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036675_733795258148505_1346935370172344005_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=680Y20PbuUIQ7kNvgHzhd0X&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAG4atdTUcj_N009jok5Qh_IOKMdLwaolRlflTXH2BCtw&oe=674D9072"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "894248482404839", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974686_894248485738172_2991357501924730672_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uZ8P8HcJVw4Q7kNvgFioYo5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByRjSi9dR1-McAMJqRTmjpoVF98jy_uHK7JkvOog1gNA&oe=674DA81B"}, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_ur