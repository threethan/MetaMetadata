71488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NWe_5RAQO-EQ7kNvgGeSdFR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYCLTWYal2o445Jp-2DzPR8WVTR2iyIxqPVm-XOURT8qvw&oe=66F2A927"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zBiyrA87z_YQ7kNvgElJnfm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYBJfj9Lt0s6qLERygj2T977iiFjm2464OlTl-WlqR5wTQ&oe=66F2AF2B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xvOjFxtUpiwQ7kNvgHkWr4V&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYBhqRAJgQu8Gnw1ZET1oRWAecnv2DwI1TTSuU0D5V-eKA&oe=66F29456"}]}, "id": "1137501624009601", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Cover Art - Portrait.png", "id": "6647755272010080", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982588_6647755275343413_6975862371154701560_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CBCpTZyF22UQ7kNvgHCc5wz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAhozdtyLYKFCzVdW2tHJxBT74IgoB2Sli9Xbmj3cFj9g&oe=66F2BD34"}, {"file_name": "Fluent XR Mobile Icon.png", "id": "2082304598777986", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_2082304602111319_6670855186104070571_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCBHmVcq9dwQ7kNvgFQBbcS&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAQGQup7lXD_Cps1E-GIqc-3C34J7Q08BHMSYoMV4A0ng&oe=66F2A62C"}, {"file_name": "Fluent XR Logo transparent.png", "id": "1984998648546806", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1984998651880139_3178193652368604560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QEme7nLX-iMQ7kNvgGDSQT3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAbP-rovoRbWVsXsSbAnKSi3gxPyr76MMxHbQ67zHtMaw&oe=66F2998E"}, {"file_name": "Fluent XR Cover Art.png", "id": "1753372745086018", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974868_1753372748419351_7413283912851125343_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UnhCYpXZjwUQ7kNvgH0ml3m&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYBsxhDgqt7QGYm9TLFJdAPMyxgsQ1E5MKuzW85jkupmAw&oe=66F2AEF5"}, {"file_name": "Fluent XR Cover Art - Square.png", "id": "1307619323205125", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_1307619326538458_7751189323196005702_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7-0wpce0lvQQ7kNvgECPq8M&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYDyMvTcRrhgNDJJ4OeVkmCt3v9GowxEfDW8glFWFJSehg&oe=66F28D34"}, {"file_name": "Fluent XR Cover Art - Mini Landscape.png", "id": "1239723750053984", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230044_1239723753387317_7790772509280140276_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UXPlfpkPHXMQ7kNvgHpqsxL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYDIMHpfmwnTk2pqSbMPRjUTjZMPXnALZGk28jroR2iI5A&oe=66F2B11E"}, {"file_name": "Fluent XR PDP Art.png", "id": "1061096168226207", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_1061096171559540_9065798130022169599_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vye1opy4Vg0Q7kNvgFWtNTP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYDjsm4B1nY8GunRIOiSQMKH4KZyQZgsIrTQzLKEkLe7gg&oe=66F2BDF3"}]}, "id": "449609844722656", "locale": "en_US", "screenshots": [{"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "755435526614104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_755435529947437_3157283510711493706_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvUZHCtaaKMQ7kNvgGPhJxD&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYDDAgkrR-TOzamKPkwx_1pkO2ByrBWjklHeGWCPKmIpWQ&oe=66F2AB3F"}, {"file_name": "Sequence 04.00_34_53_09.Still016.png", "id": "377326888090872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_377326891424205_2576812618867292544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YcrzoaNJLJAQ7kNvgH9veLQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYDdcnyZ46u4j66A9WVwdwN3w4YzCWckAPchhUZ9bbcMvA&oe=66F2AD0E"}, {"file_name": "Sequence 04.00_49_22_19.Still025.png", "id": "1792607307852843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035387_1792607311186176_5280458374548206595_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rahRWbMqE7MQ7kNvgHNYTsK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAQS5bECtcyQehSOw6i4NdR8pwqHqu1Pjbo8HQlgNvZqQ&oe=66F2B216"}, {"file_name": "Sequence 04.00_52_56_05.Still030.png", "id": "245249301718520", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031325_245249305051853_1598234300064219875_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXF2kvn-B-AQ7kNvgHZPgHj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYCl5tQJ7nm7UUw5EA1ETh8fDOUg_YWZZJgWPo1Nph_eSw&oe=66F291B7"}, {"file_name": "Sequence 04.00_11_37_00.Still002.png", "id": "733795254815172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036675_733795258148505_1346935370172344005_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JOQl-uMRj3oQ7kNvgE6qFuQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAk2Nvy5jbWTvVbBLX5ufCd7Fu7pmtQpL3ttoH-wmnDzw&oe=66F298F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "894248482404839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_894248485738172_2991357501924730672_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0jO9fOJn5QUQ7kNvgENpR0N&_nc_ht=scontent.oculuscdn.com&_nc_gid=AJ4Opv-LEl-sREYAU7gjQsM&oh=00_AYAfKHkKx-65-wb2zQT8E8F5w2xfYQ4k1dIVtw7z5cYk3A&oe=66F2B09B"}, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privac