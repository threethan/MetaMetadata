961694161774596_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xf9cb_4m5J0Q7kNvgHLC4tq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3xuSwvUxPwTL2fb7A0N22i7hHSVNatIhCDS7HT4BAhg&oe=671CD216"}, {"file_name": "FluentXR_Throw Pillow_Screenshot.png", "id": "3559508997603615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974691_3559509000936948_3261126970408815056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W9qp95eCDHcQ7kNvgFS_F0A&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDpItdWBaRl1nRPQ0xWqqikUtU3M3mUkDcrCnvY-uwunw&oe=671CC8FD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Mobile Icon.png", "id": "2236631716529956", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974513_2236631719863289_7778467312643440417_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dkA_1LhEqkQQ7kNvgE4rDTn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAm2aCUi9pNXI8jjJEzNDAaU05ItalIqI69U1VTASy82w&oe=671CBC15"}, {"file_name": "Fluent XR PDP Art.png", "id": "2055286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1AS2_jmIxFQQ7kNvgFwkMYV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBX-jkiOz9hrvm_Su6V0-d6AhJ5n2FRmBjuSy97TkyrWQ&oe=671CD927"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jR1GhNiWI94Q7kNvgG6VE07&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqKhaRP0Qs5DCGgrQSevnZLSsF1jiDRzFjkX72Yqltgw&oe=671CDF2B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1-WNhiefI_4Q7kNvgGk4ulb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDK3RnPLtHSp2Epo6TKDwHR39EoHXg-29v3BZ3IumEwRg&oe=671CC456"}]}, "id": "358335263228750", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_url": null, "website_url": "https://zenfri.ca/", "category": null, "comfort_rating