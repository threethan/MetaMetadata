71488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wypyi7PsrMkQ7kNvgFYRDD6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYB4l82EJOCotTdJB2wHexNgXw0s6ROzAPw44vTpA0OA3w&oe=66EC11A7"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=954y3awvdsoQ7kNvgExNUmr&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYAVpCagSZ4zSSJt-1jJuiviSFR7CENc9heYaBImV7favg&oe=66EC17AB"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Z0cDUjy9VMQ7kNvgHvf8ol&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBejxCcsZAaH20MuqX8KrnWd0gNsUDVIMRdamZdSmRQUg&oe=66EBFCD6"}]}, "id": "1137501624009601", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Cover Art - Portrait.png", "id": "6647755272010080", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982588_6647755275343413_6975862371154701560_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gJCpO-urZOUQ7kNvgE7eXfT&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYAqkqXqmMcP2lNCKUpQqeNRCc-8cPMxxRg1uk1Gp_3DcA&oe=66EC25B4"}, {"file_name": "Fluent XR Mobile Icon.png", "id": "2082304598777986", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_2082304602111319_6670855186104070571_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QW_84W8BwC0Q7kNvgFahpxe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBDckuQXV-2zGBvZTA_oW0npGZM8zP4l1Bizpukoi08Mw&oe=66EC0EAC"}, {"file_name": "Fluent XR Logo transparent.png", "id": "1984998648546806", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1984998651880139_3178193652368604560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2eiiFGPD7aEQ7kNvgEemKkj&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYDh3Z_ra4IYVaN-VTyELzvCive5immVZbF6_9nEMcQp7g&oe=66EC020E"}, {"file_name": "Fluent XR Cover Art.png", "id": "1753372745086018", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974868_1753372748419351_7413283912851125343_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HxaNMkDWtKUQ7kNvgFKRcg9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYCbJQ-B9vY6oVT3rsX7BXWgP2cu-Fx4hJ0WB5xGUiKT-A&oe=66EC1775"}, {"file_name": "Fluent XR Cover Art - Square.png", "id": "1307619323205125", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75334061_1307619326538458_7751189323196005702_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BVkGsN3FqKAQ7kNvgG88lG2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBVEtaQ0KFaYHYA0gJjR12aGTaUVYjBBcbICsGJlsF1Wg&oe=66EBF5B4"}, {"file_name": "Fluent XR Cover Art - Mini Landscape.png", "id": "1239723750053984", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75230044_1239723753387317_7790772509280140276_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MWgCVuza0m8Q7kNvgERyj9X&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYDHiX475SvS5pXN8djeER0otXXdQDev_PzY-Sn-snT6Ig&oe=66EC199E"}, {"file_name": "Fluent XR PDP Art.png", "id": "1061096168226207", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340707_1061096171559540_9065798130022169599_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xfZRlqMRu7UQ7kNvgHl6QLK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYAL3Q0lrki6zJLj4lN6IG7_0rrlgBvX1zWGlYsi6da6UQ&oe=66EC2673"}]}, "id": "449609844722656", "locale": "en_US", "screenshots": [{"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "755435526614104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_755435529947437_3157283510711493706_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2ZaaRWkW104Q7kNvgHG3EvR&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYCkNrj7uVU0COC3RjqC86KUBpXlGvybP2oCp1GBTchUxw&oe=66EC13BF"}, {"file_name": "Sequence 04.00_34_53_09.Still016.png", "id": "377326888090872", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031365_377326891424205_2576812618867292544_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D7WktOVUZycQ7kNvgF2jagv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBWlo6gfE5a1-20r5rBs4_ogj9sDTq2I_bDLBc0jwDIMQ&oe=66EC158E"}, {"file_name": "Sequence 04.00_49_22_19.Still025.png", "id": "1792607307852843", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035387_1792607311186176_5280458374548206595_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NIz42OIjy4YQ7kNvgGelfaU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBO2ddkOavcfeNJxELdttsi2MzxxiNhozWKGTqM3z4oyw&oe=66EC1A96"}, {"file_name": "Sequence 04.00_52_56_05.Still030.png", "id": "245249301718520", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031325_245249305051853_1598234300064219875_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dUlV6b-FOhMQ7kNvgECpsYn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYA-XoDZyrFZCoxVKxqj2W-jgW0d_SOwgYAl7i2zmdzs1g&oe=66EBFA37"}, {"file_name": "Sequence 04.00_11_37_00.Still002.png", "id": "733795254815172", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036675_733795258148505_1346935370172344005_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RDg6d9zPZ8cQ7kNvgEeVUF7&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYC4ZtMIeJ5FdhIoPWZ7FyEbLV84Uj6uI14dqH3nam3bSQ&oe=66EC0172"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Sequence 04.00_27_46_18.Still011.png", "id": "894248482404839", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974686_894248485738172_2991357501924730672_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0sW3jEdHy-EQ7kNvgG4ySZG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEsmsxUlttAoKyVAhjdm6Ff&oh=00_AYBzo91HAVlm2KVBlC5-340i5Exwx9YyGMPNlo4CalsURQ&oe=66EC191B"}, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privac