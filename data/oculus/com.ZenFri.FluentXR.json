55286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zG0iGQYaajoQ7kNvgGfPT6B&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYCLEreeQJMYaF_6eB14zU8C_F-sddEp4-LkxdFAoDvKhg&oe=66E2D727"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sP-4fzSdaQwQ7kNvgFBkJv_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYBUAYQKk9MtCwy1KtB_t3d30Cdh27cIjB1NGgWx_SknDA&oe=66E2DD2B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mg0VwDSfU34Q7kNvgEtEeCH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYDIGY8akSdT463T4FKQphoNPKFE1q5LDbq06DB4-A8Bsg&oe=66E2C256"}]}, "id": "1137501624009601", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Cover Art - Portrait.png", "id": "6647755272010080", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982588_6647755275343413_6975862371154701560_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ckImln10HwYQ7kNvgF14EJg&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYActeg02qyyry_izo8iMg6SMw2KxJYRevXFqpBnEsFIDQ&oe=66E2EB34"}, {"file_name": "Fluent XR Mobile Icon.png", "id": "2082304598777986", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974858_2082304602111319_6670855186104070571_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JXJk-Pq4Nb0Q7kNvgHO8V0t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYCjRLRqv3Q84ukW1nsUdtaTbDplWId_p5QWJH8x9S4QBw&oe=66E2D42C"}, {"file_name": "Fluent XR Logo transparent.png", "id": "1984998648546806", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982562_1984998651880139_3178193652368604560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rI5LWzBIPUMQ7kNvgHilDob&_nc_ht=scontent.