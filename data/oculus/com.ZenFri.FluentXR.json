cTm3bccBoGT2pI--1Y&oh=00_AYDLyl4Pu3znAn0TuWHaC0tpkBPvbisOOIle4wIrt2I9tg&oe=66E2EEFF"}, {"file_name": "FluentXR_Media Storage_Screenshot.png", "id": "3267266376829151", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974717_3267266380162484_3578961694161774596_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fXbsuuJbcJ4Q7kNvgG3FhXB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYBwAvxwdhyaPZtTH2x-CK6f6I3e_yAzZHTM-6R7oQmfAQ&oe=66E2D016"}, {"file_name": "FluentXR_Throw Pillow_Screenshot.png", "id": "3559508997603615", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974691_3559509000936948_3261126970408815056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_zd8OyORgPAQ7kNvgFjSnEa&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYBSTGVV-Cxh-_jNMfjqR-MVdRf9jHR-E-bfPGyi1b-xzA&oe=66E2C6FD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Mobile Icon.png", "id": "2236631716529956", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974513_2236631719863289_7778467312643440417_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NlNnz98cxiIQ7kNvgGBRCXh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYDISwGyaI5lgdEsCCYISNLROf8chRyW1OCHLUEdv-Szyg&oe=66E2BA15"}, {"file_name": "Fluent XR PDP Art.png", "id": "2055286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zG0iGQYaajoQ7kNvgGfPT6B&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYCLEreeQJMYaF_6eB14zU8C_F-sddEp4-LkxdFAoDvKhg&oe=66E2D727"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sP-4fzSdaQwQ7kNvgFBkJv_&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYBUAYQKk9MtCwy1KtB_t3d30Cdh27cIjB1NGgWx_SknDA&oe=66E2DD2B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mg0VwDSfU34Q7kNvgEtEeCH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AQI0GcTm3bccBoGT2pI--1Y&oh=00_AYDIGY8akSdT463T4FKQphoNPKFE1q5LDbq06DB4-A8Bsg&oe=66E2C256"}]}, "id": "358335263228750", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_url": null, "website_url": "https://zenfri.ca/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7093968170666792"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "995844588189802"}]}, "baseline_offer": {"id": "995844588189802"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1699893000, "status": "PUBLISHED", "id": "995844588189802"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7198485716881703", "version": "0.250"}, "id": "817807436557034", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6843469252383353", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7198485716881703"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "817807436557034"}]}, "change_log": null, "created_date": 1702024228, "id": "7198485716881703", "version": "0.250", "version_code": 2