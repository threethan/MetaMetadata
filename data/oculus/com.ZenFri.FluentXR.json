961694161774596_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kQzMSPwa8asQ7kNvgEx_mju&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCoZMwIn7vIcBpDjgUbMMX7NW0curqxCl--fWFIrWQA7A&oe=67260C96"}, {"file_name": "FluentXR_Throw Pillow_Screenshot.png", "id": "3559508997603615", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974691_3559509000936948_3261126970408815056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_sCJOt5cC2gQ7kNvgHw6_GW&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB3W1e5Y9GlGTcLIvbHNiPyYgH-I1L1zH_i9b3M77JPXw&oe=6726037D"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Mobile Icon.png", "id": "2236631716529956", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974513_2236631719863289_7778467312643440417_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2huTxJDNQ2YQ7kNvgENPafZ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBtGDh0fUgJYnQ3iyvbesUusmEOAXOtHvy3H7tk7TRLaA&oe=67262ED5"}, {"file_name": "Fluent XR PDP Art.png", "id": "2055286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lg9CLPbXKsAQ7kNvgE1N7bR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD0Z26WQdTQO-dtu4Ot8dwPPJOzrRSxkUClwSH7WDvSSA&oe=672613A7"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h1m_h15-_G4Q7kNvgEyAMep&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAU-fj67OHysHD-CVufQv0j0_nun5Uz31GJCVyR7kgh1A&oe=672619AB"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qr2DIvjYQbIQ7kNvgGjKYeX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBGc9MihgwOEdxeyEPmd2K6TxX-hUeSsu-XKW7pZgG30Q&oe=67263716"}]}, "id": "358335263228750", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_url": null, "website_url": "https://zenfri.ca/", "category": null, "comfort_rating