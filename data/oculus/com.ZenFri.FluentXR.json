961694161774596_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J_-Mb1rjm-wQ7kNvgHkDX8k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRMAWgUg5PygZOki-VjSydVrcZX8ZNjUVlAymvGuD2hQ&oe=6741BC16"}, {"file_name": "FluentXR_Throw Pillow_Screenshot.png", "id": "3559508997603615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974691_3559509000936948_3261126970408815056_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6iRqbKAHCLoQ7kNvgGvEn3X&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-P9qTNDdJhRktTwWVepO0EQPY2hgWZRJ3JCd2yLf_eg&oe=6741B2FD"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey through your mixed reality home. FluentXR transforms your space into an interactive learning environment.\n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab.\n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and challenge yourself using the timer.\n\nCurrent Features:\nSpace: Living Room\nMain Language: English\nLearning: French / fran\u00e7ais\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, \u201cChess Set\u201d and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages, locations, and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.\n\nNext Expansion: \nSpace: Kitchen\nSpace: Bedroom\nMain Language: French\nLearning Language: Spanish / espa\u00f1ol \nLearning Language: English\nMini-Game: Sentence Scramble", "short_description": "Transform your language learning experience. \n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages, locations, and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}, {"images": {"nodes": [{"file_name": "Fluent XR Mobile Icon.png", "id": "2236631716529956", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974513_2236631719863289_7778467312643440417_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fuQe_NadAWIQ7kNvgHMFLCt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDdifP8jaMSfpNW7HwZ_oauEgwHKtHL5-h-fTLS00S-Rw&oe=6741A615"}, {"file_name": "Fluent XR PDP Art.png", "id": "2055286771488876", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_2055286774822209_4338361723960595313_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5IWkJaFHHakQ7kNvgEhl0cw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlbY7j84JzDEqLDa_iacBTMPvYlYqZ6IgOAotetlIbDg&oe=6741C327"}, {"file_name": "Fluent XR Cover Art.png", "id": "678364797690874", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974640_678364801024207_2897138990588590099_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fKOIeyt_0vUQ7kNvgHm8HwG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDw1MeTyJTLD3JEea6KYV24-r9F0yca3j-6fVVAC4vxSQ&oe=6741C92B"}, {"file_name": "Fluent XR Logo transparent.png", "id": "212845385153628", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974821_212845391820294_4065972029516719811_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SoAHNXe71OcQ7kNvgEN7iX9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfQbTEo0TbhBbKUd2HSeKwjVegYyFi0gax6NHUSRI7lA&oe=6741AE56"}]}, "id": "358335263228750", "locale": "en_GB", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "FluentXR", "keywords": [], "long_description": "Unlock a personalized language learning journey with FluentXR. Using mixed reality passthrough technology, FluentXR transforms your home into an interactive learning space. \n\nStep into a realm where learning is not just fun and effective, but also deeply personalized. FluentXR is not just another language learning app; it's your own private linguistics lab. \n\nTag real-world objects in your space with text and audio labels, making learning immersive and contextually relevant. Dive into our Word Shuffle mini-game to reinforce your skills and beat the timer. \n\nCurrent Features:\nTagging Language: English\nLearning Language: French\nMini-Game: Word Shuffle\n470+ available tags geared towards common living room objects such as \u201cCouch\u201d, \u201cTelevision\u201d, and \u201cGaming Console\u201d\n\nFluentXR is an ever-evolving platform, continually expanding its selection of languages and mini-games. Achieve language mastery with FluentXR\u2014where your home becomes your classroom.", "short_description": "Transform your language learning experience.\n\nUtilizing mixed-reality passthrough technology turn your home into a dynamic classroom. Tag real-world objects in your living room with 470+ customizable tags for learning French. Sharpen your skills through the Word Shuffle mini-game.\n\nFluentXR is an ever-evolving platform, updating with new languages and interactive mini-games. Dive into a context-rich home environment that's both captivating and practical."}]}, "developer_name": null, "developer_privacy_policy_url": "https://zenfri.ca/fluentxr-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "ZenFri Inc.", "support_website_url": null, "website_url": "https://zenfri.ca/", "category": null, "comfort_rating