zgB0YYqbbklG&oh=00_AYDkxq6sDJ_NaMJr20PyMvwHHwdAsdDec9dHgqFG2ZrRng&oe=66DD814F"}, {"file_name": "vlcsnap-2024-04-09-11h25m06s391.png", "id": "990153359378736", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566679_990153362712069_1829045077122921579_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Dqeacm5Ix4Q7kNvgF3zdbo&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATgsBOAwkSTzgB0YYqbbklG&oh=00_AYDKepVdU8ptQLkmzHi7WuL0c32BQmoYiaLOTI-J7IJAVw&oe=66DD7974"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "App_Cover_Landscape.png", "id": "1018296166299033", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982518_1018296169632366_1533638476091087477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EKqY3Z2OxD0Q7kNvgG5THa6&_nc_ht=scontent.oculuscdn.com&_nc_gid=ATgsBOAwkSTzgB0YYqbbklG&oh=00_AYBUpaBW288NB5oCLJzkfRY11l7-BidpRTtel92fPWJ2oA&oe=66DD823A"}, "display_name": "Camping Parasites VR", "keywords": [], "long_description": "In this VR experience participants are encouraged to explore a camping scenario, and attempt to complete several tasks. Each task emphasizes awareness of parasites in the wild that may be lurking, and teaches preventative measures to defend against parasite infection. It is a hand tracked only experience.\n\nIt was developed by Mr Evan Dekker and Dr Sarah Preston at Federation University (https://federation.edu.au) with funding from the Australian Society for Parasitology (https://www.parasite.org.au). The original concept and tasks were pitched by Parasitology higher degree by research students.\n\nPlease note that a play area of approximately 3m x 3m is required for this experience.", "short_description": "Camping Parasites VR is a virtual reality experience for preventative parasitology education whilst camping."}]}, "developer_name": null, "developer_privacy_policy_url": "https://federation.edu.au/__data/assets/pdf_file/0006/617199/CampingParasitesVR_Privacy_Policy.pdf", "developer_terms_of_service_url": null, "publisher_na