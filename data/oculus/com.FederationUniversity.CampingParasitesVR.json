024-04-09-11h25m06s391.png", "id": "990153359378736", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/57566679_990153362712069_1829045077122921579_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ZaPmfEd98sQ7kNvgEge0zF&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAX1yvtw-80Uf-PRR1nJE7Fom54HeQ7n1w7KDtnypgyKw&oe=6777B8F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "App_Cover_Landscape.png", "id": "1018296166299033", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982518_1018296169632366_1533638476091087477_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gppuKYjmpuUQ7kNvgGANzAZ&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAJIYVaXqtoOrpIZbaJtqC8l48KzW9Rxo8kn4bcoCcJTQ&oe=6777C1BA"}, "display_name": "Camping Parasites VR", "keywords": [], "long_description": "In this VR experience participants are encouraged to explore a camping scenario, and attempt to complete several tasks. Each task emphasizes awareness of parasites in the wild that may be lurking, and teaches preventative measures to defend against parasite infection. It is a hand tracked only experience.\n\nIt was developed by Mr Evan Dekker and Dr Sarah Preston at Federation University (https://federation.edu.au) with funding from the Australian Society for Parasitology (https://www.parasite.org.au). The original concept and tasks were pitched by Parasitology higher degree by research students.\n\nPlease note that a play area of approximately 3m x 3m is required for this experience.", "short_description": "Camping Parasites VR is a virtual reality experience for preventative parasitology education whilst camping."}]}, "developer_name": null, "developer_privacy_policy_url": "https://federation.edu.au/__data/assets/pdf_file/0006/617199/CampingParasitesVR_Privacy_Policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Federation University Australia", "support_website_url": null, "website_url": "https://federation.edu.au/", "category