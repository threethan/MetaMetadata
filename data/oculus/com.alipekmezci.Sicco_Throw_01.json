3326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "770328721556912"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "665216459062614"}, {"status": "PUBLISHED", "id": "267032952757248"}]}, "baseline_offer": {"id": "665216459062614"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1701726737, "status": "PUBLISHED", "id": "665216459062614"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6830197253686043", "version": "1.1"}, "id": "822701519378546", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6679998345372602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6830197253686043"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "822701519378546"}]}, "change_log": "An update has arrived!\n\nIn this update, I have added a new gun!\nWith this gun, you can throw balls more accurately.\nIt will be next to ball spawner, available in every game mode.\n\nI have also added block remover to the block shelf. With this, in mind you can remove unwanted blocks.\nIt is marked by recycle icon on the block shelf stand.\n\nSome Quality of Life changes:\n- Scoring sound is now scaling with the points you make.\n- When scoring without hitting all of the red blocks, an error sound and message is displayed.\n- Adjusted Levels of detail, so objects in world should look better.\n- Adjusted UI textures, UI should look clean.\n- Made general minor optimizations.", "created_date": 1694782788, "id": "6830197253686043", "version": "1.1", "version_code": 4, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6679998345372602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6830197253686043"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "822701519378546"}]}, "change_log": "Minor issues fixed.", "created_date": 1693402877, "id": "6772695812769521", "version": "1.0", "version_code": 3, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6679998345372602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6830197253686043"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "822701519378546"}]}, "change_log": "v.1.01\nMinor fixes", "created_date": 1693269868, "id": "6767420759963693", "version": "1.0", "version_code": 2, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}