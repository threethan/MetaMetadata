/v/t64.5771-25/38974634_1324076241685774_6491516265444031547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fv9TNcTtxqkQ7kNvgExGlpH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjv70OkZqcsBbhULk082zsx0Ii3GPuVaP88agQLoffSg&oe=677A887E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "575408754156188", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031340_575408757489521_3544856705457314205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GV8F1LqnDXoQ7kNvgHTDlsb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCot-WUGlKuBVGhsUyLnA9go0-edDZSs2AR67P94_CH3Q&oe=677A5914"}, "display_name": "SPARK", "keywords": [], "long_description": "SPARK is an immersive first-person shooter VR game with different game mode. You will enter a virtual world named SPARK, where you can join the online battlefield with your friends in Gold Royale, Dead Match and Riding Battle. \n\nGOLD ROYALE: Gold Royale is a brand-new game mode in VR, where players can team up or enter the battle alone, search for treasures in the battle, get loot from enemies, and eventually, evacuate within a specific time successfully, or you will lose all your backpack items.\n\nDEATHMATCH: Join the online battlefield with your friends in high-speed combat with up to ten people and beat back your opponents on a strategic and tactical level. \n\nRIDING BATTLE: Experience the unique Riding Battle, and conquer this world together with your precious horse!  \n\nWEAPON RACE: Fight with 12 players, every time you successfully kill a person, the weapon will be upgraded accordingly,  be ready to become the weapon master!\n\nSPARK is still having the beta test, if you find any glitches or need any support, please contact us: hello@sparkgame.com.cn\uff1bDiscord https://discord.gg/hUtVz3FdFA", "short_description": "SPARK is an immersive first-person shooter VR game. You will enter a virtual world named SPARK, where you can join the online battlefield with your friends in Gold Royale, Dead Match and Riding Battle. \n\nSquad up, then explore this world fearlessly, SPARK yourself in this SPARK world!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://sparkvr.games/PrivatePolicy.html", "developer_terms_of_service_url": null, "publisher_name": "SparkGame", "support_website_url": null, "website_url": "https://sparkvr.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1201344757459501"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001672_1343164036179780_7613096346823126132_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nvm24keZY74Q7kNvgE46gKw&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7fCCw1Io9vGC5N0ZLyL1MW0Z34n1o7GeLY3OJxFLvpw&oe=677A83B8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SPARK", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooter", "id": "3744040075834813"}], "release_date": 1657501200, "lastRevision": {"nodes": [{"id": "132485185955886", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4966618843395622", "is_first_pa