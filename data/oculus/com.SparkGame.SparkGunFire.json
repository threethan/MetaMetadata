/v/t64.5771-25/38974634_1324076241685774_6491516265444031547_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-NXbSwifR7cQ7kNvgGdtMWd&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC5hasowYOenWokN5kzTj4aLXB2-VoQXHDlorsaXi6zKA&oe=6711107E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "575408754156188", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031340_575408757489521_3544856705457314205_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jEslJTD9_0wQ7kNvgFc2Q7a&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDEp0rbEd643MTMUz6GjDtx8QAkiPg7avPr-bLOpuMGnA&oe=6710E114"}, "display_name": "SPARK", "keywords": [], "long_description": "SPARK is an immersive first-person shooter VR game with different game mode. You will enter a virtual world named SPARK, where you can join the online battlefield with your friends in Gold Royale, Dead Match and Riding Battle. \n\nGOLD ROYALE: Gold Royale is a brand-new game mode in VR, where players can team up or enter the battle alone, search for treasures in the battle, get loot from enemies, and eventually, evacuate within a specific time successfully, or you will lose all your backpack items.\n\nDEATHMATCH: Join the online battlefield with your friends in high-speed combat with up to ten people and beat back your opponents on a strategic and tactical level. \n\nRIDING BATTLE: Experience the unique Riding Battle, and conquer this world together with your precious horse!  \n\nWEAPON RACE: Fight with 12 players, every time you successfully kill a person, the weapon will be upgraded accordingly,  be ready to become the weapon master!\n\nSPARK is still having the beta test, if you find any glitches or need any support, please contact us: hello@sparkgame.com.cn\uff1bDiscord https://discord.gg/hUtVz3FdFA", "short_description": "SPARK is an immersive first-person shooter VR game. You will enter a virtual world named SPARK, where you can join the online battlefield with your friends in Gold Royale, Dead Match and Riding Battle. \n\nSquad up, then explore this world fearlessly, SPARK yourself in this SPARK world!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://sparkvr.games/PrivatePolicy.html", "developer_terms_of_service_url": null, "publisher_name": "SparkGame", "support_website_url": null, "website_url": "https://sparkvr.games/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1201344757459501"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39001672_1343164036179780_7613096346823126132_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8N6qKuLmfLUQ7kNvgF-APwo&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBZ3uI7BsFmb-cFnhiEK7N8tlW8-fnpSYffWfbi2aT2GQ&oe=67110BB8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SPARK", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Shooting", "id": "1436351953220286"}, {"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1657501200, "lastRevision": {"nodes": [{"id": "132485185955886", "rel