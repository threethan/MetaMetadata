reenshots_v1.4.3_001.png", "id": "1415490905552721", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39036614_1415490912219387_1134285747698351694_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sRSOC5tuSDoQ7kNvgG3ZScs&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYBwdo40nzpEaVvM0FF6H65Wb-NToCHBkXOkY0c5Yca-sA&oe=677E65A1"}, {"file_name": "ot_5 Screenshots_v1.4.3_002.png", "id": "279420567599964", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/39001671_279420570933297_930612309202747107_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sUO4PRtKd9kQ7kNvgEod3W0&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYDYkAY2ThkJpIZNA1t_cTSOQF7I3kEHLrO_kt49hTktAw&oe=677E79A1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "main_comp_v143cover.png", "id": "3011212115856902", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031379_3011212125856901_7312760783984654026_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yZ6iF_1-YrcQ7kNvgF_VNd1&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBuyEBSB7DkInMKrHHqPVWhOo9VQmpdOCOLyUirGhHfHw&oe=677E63D1"}, "display_name": "On Target VR Darts", "keywords": [], "long_description": "The ultimate darts simulation, featuring Meta Avatars and Multiplayer. 6 game modes including Cricket, along with 5 AAA quality rooms to play in. Experience the pinpoint accuracy of Quest while challenging your friends online in games of 501, 301, Cricket and Freethrow.\n\nShow off your fully customized darts by choosing from dozens of tips, barrels, shafts and flights. Create hundreds of combinations in our Dart Customization menu.\n\nSingle Player mode includes Cricket, 501, 301, and Around the world, all vs AI, as well as Freethrow and Speed Darts modes to get you warmed up. Gain achievements, and challenge players from around the world for top spot on one of our many Leaderboards.\n\nPlay in one of five beautifully rendered AAA quality scenes including the Black Hat Tavern, the Tournament Arena, Basement Rec Room, and a Brutalist Default Room that also has a Glow in the Dark theme.\n\nSee you in the Tavern!", "short_description": "Dive into the ultimate darts simulation on Quest, featuring Meta Avatars and an overhauled multiplayer system. \n\nEnjoy six different game modes, including Cricket, X01 and Around the World.\n\nPlay in one of five beautifully designed, AAA-quality rooms including The  Black Hat Tavern and Tournament Arena.\n\nChallenge friends worldwide and show off your customized darts with a variety of tips, barrels, shafts, and flights to choose from. Earn achievements and climb the global leaderboards."}]}, "developer_name": null, "developer_privacy_policy_url": "https://colugoproductions.com/index.php/otvrd/otvrd-privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Colugo Productions Inc.", "support_website_url": null, "website_url": "https://colugoproductions.com/index.php/otvrd/", "category": "GAMES", "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SPORTS", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ko", "en", "fr", "es", "uk", "ja", "pl", "zh_CN", "nl"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "8201612146545294"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/38982698_516226686701318_1526272247034150772_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=