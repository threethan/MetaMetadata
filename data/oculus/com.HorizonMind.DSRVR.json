47922400642508_7512259388101964924_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TVDxaxmvPVIQ7kNvgHQDJM-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWUSQa3RDgf7sLbG7y-uIqB&oh=00_AYDZyL2x1ICCTHAFYFLQAwvU7vtHV7biV3RVmlGekNuTeA&oe=66DED01D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Gift-MetaDeck.001.png", "id": "569742441743076", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031380_569742445076409_6137187394006939864_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tgO--AFscf0Q7kNvgFhDMvX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AWUSQa3RDgf7sLbG7y-uIqB&oh=00_AYDy7MjMtFELNlK6YdnZBEx6ZbitKs4QtYGQBwwuBrlw4g&oe=66DEEDAB"}, "display_name": "The Gift VR", "keywords": [], "long_description": "Let go of negative thoughts and feelings with empowering self-guided coaching experiences. Try your unique coaching experience now!\n\nBenefits\n- Release the source of your anxiety, fear and stress from your mind and body\n- Release negative self talk that keeps you from having what you want\n- Find answers to your own personal problems \n- Energize yourself when feeling tired\n \nWhat people say\n\"I have been far more at peace about the path I am on and feel more \u201cwhole\u201d despite the losses I have recently faced\"\n\"I feel like it was a weight that lifted from me by the end of it\"\n\"I truly feel both relaxed and invigorated\"", "short_description": "** Registration needed to access app **\n\nThe Gift VR is a therapeutic experience inspired by evidence based therapy modalities and neuroscience discoveries. \n\nLet go of negative thoughts and feelings with empowering self-guided experiences.\nFor the first time ever you can transform the root cause of your anxiety, fear and stress and find answers to your own personal problems all in VR."}]}, "developer_name": "HorizonMind", "developer_privacy_policy_url": "https://horizonmind.io/notices", "developer_terms_of_service_url": "https://horizonmind.io/terms", "publisher_name": "HorizonMind", "support