Jmgh8AfbisQ7kNvgEivS_q&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCVey3nXMsqIJVsG93chTjKUpN-V4Op_fz0sI7OWedT8Q&oe=672B70D2"}, {"file_name": "Screen Shot 5 Your space.png", "id": "1136097140232328", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031579_1136097143565661_155333843094921081_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ImzWP-WG2kQ7kNvgFrmc8R&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDgPQF0RTvYF3EQb52MBtEvnBB-cbMOWkEKJx3F4Skmaw&oe=672B6BC1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Image (Desktop).png", "id": "529473078197702", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974891_529473081531035_6256113112150572613_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9dQI_AG1mgQ7kNvgEdADku&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAebIhrEbgqwSY4eEP3SesahRuy7fPmVsBnvK6eBvrsTA&oe=672B6C80"}, "display_name": "The Gift - Beta", "keywords": [], "long_description": "Let go of negative thoughts with empowering self-guided coaching experiences.\nTry the beta coaching experience: \"The Gift\" now.\n\n\u201cThe Gift\u201d is a powerful VR coaching experience based on the world renowned Dynamic Spin Release (TM) coaching process developed by two of the world's leading coaching experts: Tim & Kris Hallbom.\n\nBenefits\n- Release the source of your anxiety, fear and stress from your mind and body\n- Release negative self talk that keeps you from having what you want\n- Find answers to your own personal problems \n- Energize yourself when feeling tired\n \nWhat people say\n\"I have been far more at peace about the path I am on and feel more \u201cwhole\u201d despite the losses I have recently faced\"\n\"I feel like it was a weight that lifted from me by the end of it\"\n\"I truly feel both relaxed and invigorated\"", "short_description": "Let go of negative thoughts with empowering self-guided coaching experiences.\nTry the beta coaching experience: \"The Gift\" now.\n\n