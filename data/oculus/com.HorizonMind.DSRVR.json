7kNvgEIrrAW&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAtbtAmoJLsaIMUP2ZOH_DNcfvgd86czubkLQcwVUwy4A&oe=677E559D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Gift-MetaDeck.001.png", "id": "569742441743076", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39031380_569742445076409_6137187394006939864_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-3w4z-duvvYQ7kNvgHdB5j9&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYCEmqNbTENwGtJv61ysr6NmBmsY4sYS_9rWK7U3EFo9QA&oe=677E732B"}, "display_name": "The Gift VR", "keywords": [], "long_description": "Let go of negative thoughts and feelings with empowering self-guided coaching experiences. Try your unique coaching experience now!\n\nBenefits\n- Release the source of your anxiety, fear and stress from your mind and body\n- Release negative self talk that keeps you from having what you want\n- Find answers to your own personal problems \n- Energize yourself when feeling tired\n \nWhat people say\n\"I have been far more at peace about the path I am on and feel more \u201cwhole\u201d despite the losses I have recently faced\"\n\"I feel like it was a weight that lifted from me by the end of it\"\n\"I truly feel both relaxed and invigorated\"", "short_description": "** Registration needed to access app **\n\nThe Gift VR is a therapeutic experience inspired by evidence based therapy modalities and neuroscience discoveries. \n\nLet go of negative thoughts and feelings with empowering self-guided experiences.\nFor the first time ever you can transform the root cause of your anxiety, fear and stress and find answers to your own personal problems all in VR."}]}, "developer_name": "HorizonMind", "developer_privacy_policy_url": "https://horizonmind.io/notices", "developer_terms_of_service_url": "https://horizonmind.io/terms", "publisher_name": "HorizonMind", "support_website_url": "https://www.horizonmind.io/", "website_url": "https://www.horizonmind.io/", "category": "APPS", "comfort_