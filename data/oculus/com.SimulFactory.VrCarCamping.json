ame": "trailer cover image.png", "id": "488958403744146", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75294244_488958410410812_388897917011316775_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P00zmaIl_zUQ7kNvgHcYOWH&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCIOvFFeK1RW7plOw6h3wMibKH8h2D9DxZDUafKMmG2pA&oe=67139ECF"}, "display_name": "VRCarCamping", "keywords": [], "long_description": " A new VR experience has arrived in the MetaQuest store for you: \"VR Camping Customizer\" is a unique game that combines car customization with the fascinating natural environment of virtual reality. More than just a camping experience, this game offers players the freedom of car design and the opportunity to explore different natural terrains.\n\n- Car customization: Players can design their own vehicle, apply a variety of accessories and customization options, and each vehicle can be fully tuned to their personal preferences.\n\n- Variety of natural environments: Players can explore different natural terrains, including mountains, oceans, forests, and more, and experience the beauty of nature in a realistic way.\n\n- Freedom modes: Create, share, and play modes with your friends to freely explore different camping areas. The camping experience in different environments is realistic and exciting on every level.\n\n\nPlayers first customize their own vehicle and then take it on a virtual camping trip. Each camping area is filled with unique environments, sounds of nature, and lifelike details. The game utilizes a realistic VR platform, giving players an authentic nature experience.\n\nFuture updates coming soon:\n- More car options\n- New camping locations and content\n- Tools for easy modding\n\nDownload the \"VR Camping Customizer\" from the MetaQuest store and enjoy adventures that are impossible in real life. The freedom of traveling in a virtual world is waiting for you.\n{1562070551182401}\n{7933566916698049}\n{566139789070580}\n{2087543311640085}\n{520874930469929}\n{862687135286693}\n{1024178352716116}", "short_description": "Welcome to the new world of virtual car camping!\nMake your custom item !\nCustomize your car !\nPlay with friends !"}]}, "developer_name": null, "developer_privacy_policy_url": "https://pamechanic.tistory.com/entry/SimulFatory-%EA%B0%9C%EC%9D%B8%EC%A0%95%EB%B3%B4-%EC%B7%A8%EA%B8%89-%EB%B0%A9%EC%B9%A8", "developer_terms_of_service_url": null, "publisher_name": "Not Exist", "support_website_url": null, "website_url": "https://pamechanic.tistory.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TRACKED_KEYBOARD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8533361076686687"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1054927459387241"}]}, "baseline_offer": {"id": "1054927459387241"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1728485700, "status": "PUBLISHED", "id": "1054927459387241"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8823195194369939", "version": "0.1.21"}, "id": "630819515817021", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6772767489412730", "is_concept": false, "l