vgG9JV5Y&_nc_ht=scontent.oculuscdn.com&oh=00_AYDw66ecEv7BYQwvrqTrIdwAjjiXlQSxuVfc099pBfj3IQ&oe=66DECBBD"}, {"file_name": "Wjou7N.png", "id": "1323066191237286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974820_1323066194570619_2749054776275632128_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fO9Oh0yGA5EQ7kNvgEhH3wv&_nc_ht=scontent.oculuscdn.com&oh=00_AYC-2kwIaU78pmuEZsODeJKYMjvE3BkYzG87gp0dK--YKQ&oe=66DECBF9"}, {"file_name": "8VSUoV.png", "id": "166031337993382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982618_166031341326715_6239646659911876608_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vqNIclK3cEkQ7kNvgFbdlQW&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNN1I2GF9YKbG_6TCmtHYDaG4ta28FF6KKtM8p9aOoPQ&oe=66DED033"}, {"file_name": "8Vnmoq.png", "id": "679365559490917", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035388_679365562824250_1728730018881732608_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x8e3WG7JlXkQ7kNvgEBWupr&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgxqw1pCOCiFnH8XqXqwvbiHLtEMrItkAyUOyh5bvXTw&oe=66DEDFE0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "75221316_1674234969391807_3739995600813293568_n(1).png", "id": "673694678060282", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035405_673694681393615_2026936782994030018_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=17dU0WeXzUwQ7kNvgHca9DR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYuIE-Nk-fLrBih1x5hdh5bL-66-nYrFoOQLZWtokjmw&oe=66DEC999"}, "display_name": "Jurassic World", "keywords": ["Jurassic", "Park", "Felix", "Apatosaurus", "Dinosaur"], "long_description": "Jurassic World: Apatosaurus \nThe Jurassic World: Apatosaurus VR Experience allows the viewer for the first time to see what it feels like to be in the presence and close proximity of a living dinosaur and to experience a sense of connection with it - with the mixture of awe, striking beauty and danger that this implies.\n\nJurassic World: BLUE \nDinosaurs have overtaken the turbulent Isla Nublar, but the threat of a natural disaster erupting looms eerily over the island. Follow Blue, a highly intelligent Velociraptor, on her quest for survival, using VR to experience her extraordinary sensorial abilities and awareness as she scours for food and water, searches for signs of life, and fights against some of the island\u2019s most threatening predators.", "short_description": "The Jurassic World: Apatosaurus VR Experience allows the viewer for the first time to see what it feels like to be in the presence and close proximity of a living dinosaur and to experience a sense of connection with it - with the mixture of awe, striking beauty and danger that this implies.\n\nIn Jurassic World: Blue\nFollow Blue, a highly intelligent Velociraptor, on her quest for survival, using VR to experience her extraordinary sensorial abilities and awareness."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "842287169851443"}, {"id": "687057922013375"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7339709686095293"}, "review_messages": [""]}]}, "cover_square_image": {"