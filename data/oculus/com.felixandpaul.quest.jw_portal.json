3-1.oculuscdn.com&oh=00_AYCUHVj3iDyYWjF0TvexPZdkPMVHa7tIvZh6M9L3TnlM5Q&oe=6752EF3E"}, {"file_name": "1QPMQs.png", "id": "537327353652399", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974555_537327356985732_2363211132199501824_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ltkJi3YUD1MQ7kNvgHdQ0cM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDKhkMvEzekL4NLNFbiRz4DY-ioxgE6rOJ7RN9Oak010Q&oe=6752CFBD"}, {"file_name": "Wjou7N.png", "id": "1323066191237286", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974820_1323066194570619_2749054776275632128_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wdkJT9Bg_nsQ7kNvgG4JOpF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDw9IGQARpdJynT1orUmJV9DfYqIEfs4mTSsV7Uk9opbA&oe=6752CFF9"}, {"file_name": "8VSUoV.png", "id": "166031337993382", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982618_166031341326715_6239646659911876608_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5H5FNuA9lCAQ7kNvgEnVYUU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDnwMuBIOqus0vns5ss2MHDxcGUTubhfaLZsiSm1uizXw&oe=6752D433"}, {"file_name": "8Vnmoq.png", "id": "679365559490917", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035388_679365562824250_1728730018881732608_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nz2YGpAPrwQQ7kNvgEKxOH7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB87cNMEfzE_wRpJo101YGFSc9OWC4GP-eS9QVBOMWztQ&oe=6752E3E0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "75221316_1674234969391807_3739995600813293568_n(1).png", "id": "673694678060282", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035405_673694681393615_2026936782994030018_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GgJAJzBg91EQ7kNvgEScB52&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA8rnBH1-01BOoot3zkbsq4AnoVhrcz1ceIjxbhWzzpwA&oe=6752CD99"}, "display_name": "Jurassic World", "keywords": ["Jurassic", "Park", "Felix", "Apatosaurus", "Dinosaur"], "long_description": "Jurassic World: Apatosaurus \nThe Jurassic World: Apatosaurus VR Experience allows the viewer for the first time to see what it feels like to be in the presence and close proximity of a living dinosaur and to experience a sense of connection with it - with the mixture of awe, striking beauty and danger that this implies.\n\nJurassic World: BLUE \nDinosaurs have overtaken the turbulent Isla Nublar, but the threat of a natural disaster erupting looms eerily over the island. Follow Blue, a highly intelligent Velociraptor, on her quest for survival, using VR to experience her extraordinary sensorial abilities and awareness as she scours for food and water, searches for signs of life, and fights against some of the island\u2019s most threatening predators.", "short_description": "The Jurassic World: Apatosaurus VR Experience allows the viewer for the first time to see what it feels like to be in the presence and close proximity of a living dinosaur and to experience a sense of connection with it - with the mixture of awe, striking beauty and danger that this implies.\n\nIn Jurassic World: Blue\nFollow Blue, a highly intelligent Velociraptor, on her quest for survival, using VR to experience her extraordinary sensorial abilities and awareness."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null