_232493298088419_2011921273113804800_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HHuJ8Z9rLKMQ7kNvgGgI2ay&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBNEThI7dRgjItPDBC7pPg0YNz_HlKVYMTvPTBHOEmEXg&oe=67558BD3"}, {"file_name": "zvFVmd.png", "id": "940407543096834", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43931329_940407546430167_4678072009366700032_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5YIRPScVg4sQ7kNvgGBBfpY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCMMWPWnRS0uqPEKy1b9vEiHLHZWKx7fi9heqZj5ytjw&oe=67558B41"}, {"file_name": "vuZ71p.png", "id": "710913689656480", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974469_710913692989813_4717902445148110848_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bdHuia3Rx0kQ7kNvgFMnQG5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB66gjEiHYItj9qK5BSiWPtRac0NdsWMH-avduWhDnUeg&oe=67559285"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/WZYrYs", "id": "767894786948607", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974497_767894790281940_4035857365050851328_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lVopTFgBhFMQ7kNvgGmK2mO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmW8efe5z7qTY2SunhbAD3LwsXRen7egWCVlSmpf93BQ&oe=67558B50"}, "display_name": "Pro Putt by Topgolf", "keywords": ["golf", "putting", "sports", "multiplayer", "fun"], "long_description": "Available May 28th!\n\nInspired by Tiger Woods for Xbox and Mario Golf, Pro Putt is the most fun you'll have with a putter in your hand!  Whether you\u2019re out to post a course record, playing a relaxing round with a friend, sinking shots in the Topgolf Putt Lounge, or in a heated head-to-head battle with the best in the game, Pro Putt gives you endless reasons to celebrate!\n\n\n- Physics model that looks and feels like it\u2019s rolling on a real green.\n- Exclusive Topgolf Putt Lounge where a high-end bay is always ready for you, day or night.\n- Multiplayer experience that is as much about the golf as it is about hanging out with friends.\n- Three beautiful courses to help you escape.\n- A 10,000 square foot practice green.\n- Competition to match your skill level.\n- Achievements and leaderboards for bragging rights!\n\nBetween the courses and the Putt Lounge we\u2019ve got something for everyone. With our varying difficulties it\u2019s simple enough for everyone and hard enough for real pros.", "short_description": "Available May 28th!\n\nInspired by Tiger Woods for Xbox and Mario Golf, Pro Putt is the most fun you'll have with a putter in your hand!  Whether you\u2019re out to post a course record, playing a relaxing round with a friend, sinking shots in the Topgolf Putt Lounge, or in a heated head-to-head battle with the best in the game, we have something for everyone.\n\n\n- Multiplayer\n- Realistic Physics\n- Exclusive Topgolf Putt Lounge\n- Three Epic Courses\n- Achievements and Leaderboards"}]}, "developer_name": "Golf Scope Inc.", "developer_privacy_policy_url": null, "developer_terms_of_service_url": "http://proputt.com/", "publisher_name": "GolfScope Inc.", "support_website_url": "http://proputt.com/", "website_url": "http://proputt.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "1322801214870728"}}]}, 