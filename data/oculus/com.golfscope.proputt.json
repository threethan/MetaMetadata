: "AndroidBinary", "id": "8020302094731800"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725657942, "id": "8076493582445984", "version": "768.0", "version_code": 11444, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8020302094731800"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": "New Update v767.4 \n\nVR FedExCup Playoffs Update:\n- Added badges and trophies, with the ability to hold and inspect them. Available after the VR TOUR Championship.\n- Updated tournament end summary for VR TOUR Championship.\n\nBug Fixes:\n- Players would not being able to resume their tournament round, resulting in a DNF, on courses they did not own.\n- Scramble rounds would become stuck if an opposing player leaves the round, and rejoins after the other team completes the hole.\n\nCourse Updates:\nEast Lake Golf Club - Cleaned up the waters edge around the sewer drain on Hole 1 and adjusted the OB line on the left side of Hole 7.\nCastle Pines - Hole 16 - Fixed a gap in the rock wall around the green that allowed the ball to fall thru if it came to rest there.\n", "created_date": 1724859094, "id": "8020302094731800", "version": "767.4", "version_code": 11393, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 60}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8020302094731800"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": null, "created_date": 1724275248, "id": "7980099238752086", "version": "766.92", "version_code": 11344, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 60}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8020302094731800"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": "New Update v766.91\n\nNew Course: East Lake Golf Club - Renovated Version\n\nReceive both the pre and post-renovated East Lake Golf Club for the price of one!\n\nThe new-look East Lake Golf Club will make its first public appearance at the 2024 TOUR Championship. Led by Andrew Green - coined as \u201cgolf\u2019s new hottest architect\u201d by Golf Digest - the project began immediately following the 2023 TOUR Championship with the goal of restoring the iconic property to its early 20th century roots. The most notable changes to the course are reflected in the topography, greens and bunkers to allow the course to play both firmer and faster. Streams and ponds were also a primary focus to bring back the native habitat and have water play as a more punishing hazard.\n\n**PLEASE NOTE**: Purchasing the post renovation East Lake Golf Club will also grant the pre-renovated East Lake for free. If you already own the original East Lake, you will automatically receive the post renovated East Lake for free. In game, the new version will be 'East Lake Golf Club' and the pre-renovated version will be 'East Lake 2023'.\n\nCourse Updates:\nCliffs - Cleaned up some 'triangles' on the course that would show on the Map interface\nCastle Pines - Cleaned up some lines within the skybox and fixed a seam between fairway and rough on Hole 13", "created_date": 1724264274, "id": "7979389145489762", "version": "766.91", "version_code": 11342, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 60}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8020302094731800"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1723859658, "id": "7952812651480745", "version": "766.3", "version_code": 11313, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 60}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}