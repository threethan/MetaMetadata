AndroidBinary", "id": "8109598172468858"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726182294, "id": "8115252595236749", "version": "767", "version_code": 11481, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8109598172468858"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": "New Update v768.03\n\nNew Course: The Hay\n\nThe Hay 9-Hole Par-3 Course\n- The Hay is a 9-hole par-3 course located at the Pebble Beach Resort offering a fun and accessible environment for players of all skill levels. Each hole is crafted to blend seamlessly with the natural beauty of Pebble Beach to showcase stunning ocean views.\n\nIncluded! The Hay 18-Hole Putting Course\n- In addition to its par-3 course, The Hay features an 18-hole putting course that provides an enjoyable and challenging experience for players of all skill levels.\n\nPerformance improvements\nWe've been diligently working to improve performance across our game, and this build marks the first phase of that effort. It includes enhancements aimed at boosting frame rates on all courses. This is just the first step in our continued effort and there will be more to come. This won't be a one-and-done fix but rather a series of incremental steps over time to bring you all a much smoother experience.\n- Note - this first round is focused on gameplay performance, not course specific performance, but thru this effort, it directly affects performance on courses.\n\nBug Fixes:\n- Updated the 'Smart' club selection setting from giving the player a 3W instead of Driver in certain instances.\n- Fixed an issue where transitioning between Quickplay and Tournaments could result in a broken state.\n", "created_date": 1726104967, "id": "8109598172468858", "version": "768.03", "version_code": 11477, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8109598172468858"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": "New Update v768.02\n\nNew Course: The Hay\n\nThe Hay 9-Hole Par-3 Course\n- The Hay is a 9-hole par-3 course located at the Pebble Beach Resort offering a fun and accessible environment for players of all skill levels. Each hole is crafted to blend seamlessly with the natural beauty of Pebble Beach to showcase stunning ocean views.\n\nIncluded! The Hay 18-Hole Putting Course\n- In addition to its par-3 course, The Hay features an 18-hole putting course that provides an enjoyable and challenging experience for players of all skill levels.\n\nPerformance improvements\nWe've been diligently working to improve performance across our game, and this build marks the first phase of that effort. It includes enhancements aimed at boosting frame rates on all courses. This is just the first step in our continued effort and there will be more to come. This won't be a one-and-done fix but rather a series of incremental steps over time to bring you all a much smoother experience.\n- Note - this first round is focused on gameplay performance, not course specific performance, but thru this effort, it directly affects performance on courses.\n\nBug Fixes:\n- Updated the 'Smart' club selection setting from giving the player a 3W instead of Driver in certain instances.\n- Fixed an issue where transitioning between Quickplay and Tournaments could result in a broken state.\n", "created_date": 1726084785, "id": "8108097475952261", "version": "768.02", "version_code": 11471, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8109598172468858"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726074238, "id": "8107326586029350", "version": "768.01", "version_code": 11468, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8109598172468858"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726018155, "id": "8102939446468064", "version": "768.01", "version_code": 11466, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 64}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}