ad3-2.oculuscdn.com&oh=00_AYAVEgnKnWrm0aA5rIDOhxzYZr1P1AamtgodMXyMhw5Caw&oe=674C38EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pdp.png", "id": "888125993078381", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86625126_888125996411714_8005611901755861351_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mNDYFEjPYh4Q7kNvgEsCg3t&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEvVz7X7I2y6W4NbFFmNPfhzAHpEQM4dj2Tm-d25gY_g&oe=674C3D0A"}, "display_name": "GOLF+", "keywords": ["golf", "sports", "multiplayer", "minigolf", "topgolf"], "long_description": "The ultimate VR Golf experience and the official VR Golf game of the PGA TOUR!\n\n\u201cThe GOLF+ VR platform is a forward-thinking way to enjoy the sport that is appealing to gamers and golfers of all levels.\u201d - PGA TOUR\n\n{941382827815458}\n\n\u201cThe visuals are fantastic. It\u2019s like morphing into another universe filled with vibrancy, dynamism and, most important, realism.\u201d - Sports Illustrated\n\n\u201cThe putting function \u2014 which simulator golf has never quite cracked \u2014 is particularly eye-opening.\u201d - GOLF Magazine\n\n# Includes:\n\n\u26f3\ufe0f Iconic Courses: 3 Free Courses and 25+ real-world destinations available for purchase including Pebble Beach, The Old Course at St Andrews, TPC Sawgrass and more.\n{7874775169289873}\n\n\ud83c\udfcc\ufe0fMultiplayer: Play with your circle of friends, or join public rounds and connect with golf enthusiasts worldwide.\n\n{552990800710948}\n\n\ud83c\udfc6 Competitive Play: Climb the ranks and compete globally on the GOLF+ TOUR, or go head to head in Battle mode.\n\n{462506986284946}\n\n\u2705 Real Golf Brands: Experience golf equipment from leading brands like Callaway, TaylorMade, and PXG.\n\n{464865413270594}\n\n\ud83d\udcc8 Performance Feedback: Advanced shot stats, strokes gained data, handicap system, and swing analyzer to help you understand and improve your game.\n\n\ud83c\udfaf Diverse Modes: From Match Play to Skins, Weekly Challenges and Topgolf, we have an experience for every player.\n\n\ud83c\udfde GOLF+ Clubhouse: A place to practice, fine tune your clubs, and play fun mini-games.\n\n\ud83d\udda5 Media Player: Seamlessly enjoy YouTube and other web media right on the course.", "short_description": "The ultimate VR Golf experience and the official VR Golf game of the PGA TOUR!\n\n\u26f3\ufe0f Iconic Courses: 3 Free courses and 25+ real-world destinations available for purchase including Pebble Beach.\n\ud83c\udfcc\ufe0f Multiplayer: Play with friends, or join public rounds.\n\ud83d\udcc8 Performance Feedback: Stats, strokes gained data, and handicap system.\n\ud83c\udfc6 Competitive Play: Compete on the GOLF+ TOUR.\n\ud83c\udfaf Diverse Modes: Match Play to Skins, to weekly challenges and Topgolf Las Vegas."}]}, "developer_name": "Golf Scope Inc.", "developer_privacy_policy_url": "https://www.golfplusvr.com/privacy-policy", "developer_terms_of_service_url": "https://www.golfplusvr.com/terms-and-conditions", "publisher_name": "GolfScope Inc.", "support_website_url": "http://golfplusvr.com/", "website_url": "http://golfplusvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8631750613586942"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https:/