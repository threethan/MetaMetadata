BLISHED", "id": "688407936206319"}, {"status": "PENDING", "id": "1622914038242826"}, {"status": "PUBLISHED", "id": "571508893845714"}, {"status": "PUBLISHED", "id": "888911662599319"}, {"status": "PUBLISHED", "id": "815856128946061"}, {"status": "PUBLISHED", "id": "315938857799060"}, {"status": "PENDING", "id": "1119214315718803"}, {"status": "PUBLISHED", "id": "368279302858435"}, {"status": "PUBLISHED", "id": "668776895387020"}, {"status": "PUBLISHED", "id": "656389436627753"}, {"status": "PENDING", "id": "1275624149803340"}, {"status": "PENDING", "id": "878855103124394"}, {"status": "PUBLISHED", "id": "733423188121461"}, {"status": "PENDING", "id": "311925444509416"}, {"status": "PUBLISHED", "id": "269048365270248"}, {"status": "PENDING", "id": "838939034532662"}, {"status": "PUBLISHED", "id": "707337583992707"}, {"status": "PENDING", "id": "675007897924030"}, {"status": "PENDING", "id": "1352582015611316"}, {"status": "PUBLISHED", "id": "1641114576373838"}, {"status": "PUBLISHED", "id": "564281488725242"}, {"status": "PUBLISHED", "id": "632558691761957"}, {"status": "PUBLISHED", "id": "832241798533929"}]}, "baseline_offer": {"id": "315938857799060"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "585297503873188"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8620937721334898", "version": "773.1"}, "id": "2309851355956647", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8620937721334898"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "2309851355956647"}]}, "change_log": "New Update v773.1\n\n## New Course: Te Arai Links - South Course\nLocated on the stunning east coast of New Zealand\u2019s North Island, Te Arai Links is one of golf\u2019s newest must-see destinations.\nThe South Course, a traditional links-style design by Coore & Crenshaw, features 16 holes with breathtaking ocean views, including eight that sit directly along the sea.\nDiscover why this masterpiece has quickly earned its place among the world\u2019s top courses.Performance Improvements - We have had a Quest 2 specific beta going over this last week specific to performance improvements.\n\n## Performance Updates\n\n### Quest 2 Only Update\nCourse Optimization - LOD Texture Updates (Level of Detail)\nCourses that are performant heavy have received an updated resolution treatment. Now, only the hole you are on will be in normal resolution, while the other holes around you will be in low resolution. Other holes will update if your shot lands there, or you teleport there when exploring.\n\n### Quest 2 and 3 Updates\n1. CPU Updates - Focused on club hitting ball and all that happens during and right before - smoothing out the club impact sequence. All sounds and effects around hitting a shot have been refactored to not interfere with the main action, club hitting the ball.  Shots should 'feel' much cleaner, especially the pitches, touchy shots and chipping.\n2. GOLF+ Tour - A big tournament specific performance update. Tournament play is much smoother, in line with regular rounds.\n3. Courses are running at about 15% more performant.\n4. \u2018Dead shots' caused by frame drops - Impact timing updates to protect against frame drops.\n5. Courses without crowds -  Fixed a bug causing a performance degradation when going out of bounds.\n\n### Courses with Additional Performance Optimizations:\n- Canyons\n- Castle Pines\n- Muirfield\n\n## Additional Quality and Bug Fixes:\n- [Customization] Some players seeing incorrect store cost and clubs defaulting back to original clubs after equipping\n- [Challenges] Restarting a challenge, the lie type will be the prior attempts 'restart' lie type\n- [MP] When playing lefty w/ right controller, clubs are seen as reversed for other players\n- [MP] Replay mid round would cause the game to lock-up in a 2 player MP game\n- [Battle] Players could hit a bug starting the battle on the 2nd hole\n- [UI] When using the 'hide menu' option it is impossible to see wind speeds\n- [UI] 'Invalid Drop' pill renders over main menu if cursor pointed at main menu\n- [GOLF+ Tour] Loss of wi-fi round posting DNF\n- [Course - Hay Putting] 2 player MP, standard turns - 2nd player to go to the next tee box could be placed too far away.\n\n## Remaining G+ TOUR Fall Schedule\n11/21 - 11/27: The Ocean Course at Kiawah Island\n11/28 - 12/4: Week 1 of Playoffs at Mystery Course???\n* Weekly and Daily Tournaments this week will earn 2x Points\n12/5 - 12/11: Week 2 of Playoffs at Lofoten Links\n* Weekly and Daily Tournaments this week will earn 3x Points", "created_date": 1732146527, "id": "8620937721334898", "version": "773.1", "version_code": 11869, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 71}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "2412327085529357", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8620937721334898"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1732120133, "id": "8619140911514579", "version": "773.1", "version_code": 11863, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 71}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppB