06&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ElKplfN4lCIQ7kNvgE2Y7m3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAISehXLeKRAhbJbTGrsTpK4__IEY_Kz0TWT3GOvn0J_Q&oe=6775313F"}, "display_name": "Creative Space: Unleash Your Imagination", "keywords": ["art", "build", "create", "zen", "relax"], "long_description": "Dive into Creative Space, the ultimate VR playground for artists, creatives, and anyone eager to explore their imagination. With its intuitive interface and open environment, creating masterpieces has never been easier or more fun.\n\nUser-Friendly Gameplay: Jump right in with no steep learning curve.\n\nIntuitive Design: Navigate effortlessly as you bring your ideas to life.\n\nEndless Creativity: Utilize orbs and cubes to craft anything you can dream up.\n\nSave and Load Projects: Easily continue your work whenever you want.\n\nCreative Space is a must-have for every Meta Quest owner, offering boundless opportunities to express your creativity.", "short_description": "Unleash your creativity in this intuitive, fun, Creative Space."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/creative-space", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"]