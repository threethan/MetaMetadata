6C5D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CRS 2560x1440.png", "id": "825963566336391", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982580_825963569669724_988132790043764915_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PLYTqc8U9C8Q7kNvgHXTjvm&_nc_ht=scontent.oculuscdn.com&_nc_gid=A9r0_SKf3gc3tkBlJHX4vEs&oh=00_AYCpdaw0pDTfcrjBoJWlolnxyJHEz-BO8N2ESKKNMGzlGw&oe=66E6CF3F"}, "display_name": "Creative Space: Unleash Your Imagination", "keywords": ["art", "build", "create", "zen", "relax"], "long_description": "Dive into Creative Space, the ultimate VR playground for artists, creatives, and anyone eager to explore their imagination. With its intuitive interface and open environment, creating masterpieces has never been easier or more fun.\n\nUser-Friendly Gameplay: Jump right in with no steep learning curve.\n\nIntuitive Design: Navigate effortlessly as you bring your ideas to life.\n\nEndless Creativity: Utilize orbs and cubes to craft anything you can dream up.\n\nSave and Load Projects: Easily continue your work whenever you want.\n\nCreative Space is a must-have for every Meta Quest owner, offering boundless opportunities to express your creativity.", "short_description": "Unleash your creativity in this intuitive, fun, Creative Space."}]}, "developer_name": "John Ray Games", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/creative-space", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "NO