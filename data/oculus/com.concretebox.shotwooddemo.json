7fQu&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgjjhScPcKnyN_7w4v8grKysgNzwcg35MBWdeDp2UhKw&oe=66DD89F2"}, {"file_name": "screenshot-5.png", "id": "1923238414795379", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984442_1923238418128712_4769228846090391027_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IZn5hMT-jPIQ7kNvgGYZ-yw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvXN9ukvztq3SuxfRJ7OdfysTfht-uNcGxEHXbENtCeQ&oe=66DDA085"}, {"file_name": "equipment-terminal.png", "id": "3958226264503543", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NZlSsvbGnrQQ7kNvgFSM8tC&_nc_ht=scontent.oculuscdn.com&oh=00_AYCO6MJBa8o_jcu-KYloklmK0oY5uxRCPRsE3fQiVfrz_w&oe=66DD7199"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xKfKeFOIqt0Q7kNvgHghpo0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDghRvmLNJ7HucESSeo2j2vu1R9DDh2jtwTzmN94_TwOw&oe=66DD9DBF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oNVKhWVz0ZoQ7kNvgEbUccx&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0y1fe-aAYQJV0WpMQejP9CpFlMxT-L3rss7EKTTgycQ&oe=66DD71DC"}, "display_name": "Shotwood Demo", "keywords": ["Shot", "Wood", "ShootWood", "Demo", "Free"], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\n{866219128900813}\n\n# Demo Features\n\nCheck out the awesome Shotwood gunplay with immediate access to some high end weaponry, plus the full practice range and 2 **shoot-house assessments**. Chill out in the home environment. Earn credits by completing runs and challenges, hunting the hidden cash wads, or mastering the ridiculous **Balloon Stabber** minigame. Spend credits on ammo, grenades, and gear - including the awesome **sidearm camera**. Find all the hidden clues to access a **secret demo area**!\n\n{427997739692963}\n\n# Full Game Features\n\nThe full Shotwood experience (not in demo) includes 8 shoot-house assessments with 15 challenges each and 3 modes, 20+ firearms, 9 tactical tools including **kamikaze drones** and the augmented visor, 2 minigame floors, playable arcade cabinet, facility induction process, **progression system**, working grievance booth, big secret area \"beyond the booth\", more **story** to uncover including 120 random announcements, 4 save slots, various difficulty options including **permadeath**, new game plus, and even more!\n\n{2300077013672023}\n\n# Tech Features\n\nShotwood runs at a **smooth 90hz refresh rate**, supports full room scale movement as well as seated play, and offers multiple options for movement, haptics, captions, and whole lot more.\n\nGrab this **FREE** demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.concretebox.net/privacy.html", "developer_terms_of_service_url": "https://www.concretebox.net/terms.html", "publisher_name": "Concrete Box", "support_website_url": "https://www.concretebox.net/support.html", "website_url": "https://www.concretebox.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics