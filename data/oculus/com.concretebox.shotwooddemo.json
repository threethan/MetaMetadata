0TqioLBJsUQ7kNvgG7UNmg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC88K1TIA8POcnN59jQOgIZMgUPxm_8d5jdgwjNOtbOrQ&oe=673C6697"}, {"file_name": "level-select.png", "id": "861445076021181", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031640_861445079354514_4968430877850706782_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lAnrI7PKWxcQ7kNvgEh0pX3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDH_H91KKqw_du0UkkTy_1SxII__eAzfBtXNQLakZIJdw&oe=673C75F2"}, {"file_name": "screenshot-5.png", "id": "1923238414795379", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984442_1923238418128712_4769228846090391027_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FLGPDog20lwQ7kNvgGMKgfd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNT01pqyF-btKM1QAJZdqyVfDjftZytsdJQFMKJTIRMA&oe=673C8C85"}, {"file_name": "equipment-terminal.png", "id": "3958226264503543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bme0mUFI0UcQ7kNvgHsy_r7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCdu0sFNd3KzIEtQp7qZNsJk34J3gJ5iCV-8U_bCK6SkQ&oe=673C95D9"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ySNQC14dXdYQ7kNvgGXFrze&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCitIAivklv7nFNj3WxcbIMpHF4lb2W3kNzEYthkOBRAg&oe=673C89BF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ki28XAuC-hoQ7kNvgF4nX18&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAve6-GxcajBgyUMuSJyXdsv2THGeJAg7jRbOOfWbNVMg&oe=673C961C"}, "display_name": "Shotwood Demo", "keywords": ["Shot", "Wood", "ShootWood", "Demo", "Free"], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\n{866219128900813}\n\n# Demo Features\n\nCheck out the awesome Shotwood gunplay with immediate access to some high end weaponry, plus the full practice range and 2 **shoot-house assessments**. Chill out in the home environment. Earn credits by completing runs and challenges, hunting the hidden cash wads, or mastering the ridiculous **Balloon Stabber** minigame. Spend credits on ammo, grenades, and gear - including the awesome **sidearm camera**. Find all the hidden clues to access a **secret demo area**!\n\n{427997739692963}\n\n# Full Game Features\n\nThe full Shotwood experience (not in demo) includes 8 shoot-house assessments with 15 challenges each and 3 modes, 20+ firearms, 9 tactical tools including **kamikaze drones** and the augmented visor, 2 minigame floors, playable arcade cabinet, facility induction process, **progression system**, working grievance booth, big secret area \"beyond the booth\", more **story** to uncover including 120 random announcements, 4 save slots, various difficulty options including **permadeath**, new game plus, and even more!\n\n{2300077013672023}\n\n# Tech Features\n\nShotwood runs at a **smooth 90hz refresh rate**, supports full room scale movement as well as seated play, and offers multiple options for movement, haptics, captions, and whole lot more.\n\nGrab this **FREE** demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": n