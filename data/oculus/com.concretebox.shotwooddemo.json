d57qzwFwJEQ7kNvgH5Pq68&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBqDujMuoXoJdKgGE7MqBYyz669QxJR6NVsvG_u75dBrg&oe=671CC297"}, {"file_name": "level-select.png", "id": "861445076021181", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031640_861445079354514_4968430877850706782_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8bSKUp2A6zQQ7kNvgEMDtLp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMGS1I94Q5L8WAFzu9-MMKf7s-x6IiJeDQVjaYm67XGQ&oe=671CD1F2"}, {"file_name": "screenshot-5.png", "id": "1923238414795379", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984442_1923238418128712_4769228846090391027_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TQgU-_14vNsQ7kNvgG5rKfA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHPxnPEw81z_wFJRJFnYyJAUn1Bqxhv_0_HZ1FBTdutA&oe=671CE885"}, {"file_name": "equipment-terminal.png", "id": "3958226264503543", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJLeYNKJOJcQ7kNvgGb6Wr9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzDQ8LBpBtG4vVdxWUA0AGEctHJpwKgfkqahJ7aMpu9w&oe=671CB999"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aHgIXK74tqcQ7kNvgHwaUi9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdNCucxiI8vSo6EiYrToJ4Wpm6GWmCOAeun_iy88IhJw&oe=671CE5BF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=shsU36VMqQUQ7kNvgH7j11U&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBP0tZjoCnJh7aHQ6Gg-O8tFHpJU4hwbVhYrsGnuttlw&oe=671CB9DC"}, "display_name": "Shotwood Demo", "keywords": ["Shot", "Wood", "ShootWood", "Demo", "Free"], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\n{866219128900813}\n\n# Demo Features\n\nCheck out the awesome Shotwood gunplay with immediate access to some high end weaponry, plus the full practice range and 2 **shoot-house assessments**. Chill out in the home environment. Earn credits by completing runs and challenges, hunting the hidden cash wads, or mastering the ridiculous **Balloon Stabber** minigame. Spend credits on ammo, grenades, and gear - including the awesome **sidearm camera**. Find all the hidden clues to access a **secret demo area**!\n\n{427997739692963}\n\n# Full Game Features\n\nThe full Shotwood experience (not in demo) includes 8 shoot-house assessments with 15 challenges each and 3 modes, 20+ firearms, 9 tactical tools including **kamikaze drones** and the augmented visor, 2 minigame floors, playable arcade cabinet, facility induction process, **progression system**, working grievance booth, big secret area \"beyond the booth\", more **story** to uncover including 120 random announcements, 4 save slots, various difficulty options including **permadeath**, new game plus, and even more!\n\n{2300077013672023}\n\n# Tech Features\n\nShotwood runs at a **smooth 90hz refresh rate**, supports full room scale movement as well as seated play, and offers multiple options for movement, haptics, captions, and whole lot more.\n\nGrab this **FREE** demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": n