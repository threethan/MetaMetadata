ps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4mDdeTyIyxwQ7kNvgGeCdxk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBre4Wg1zfAAz_5KUSeSooIN7VynSEAzb1FxAl3aEyjA&oe=674B1659"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KqXsoAaFvBYQ7kNvgH2EnmM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDebyHtd3Yx6s_nBwlVPk1eejE9jlQG9s1aP0AeF3QL_A&oe=674B0A3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZuR3Lo5aEQQ7kNvgGEbH3k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgRwJ4S-y1ggts5DbhPP7LyotlNUW9gLaL0vd9f1aqRw&oe=674B169C"}, "display_name": "Shotwood Demo", "keywords": [], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\nDEMO FEATURES\n\n - Awesome Shotwood gunplay\n - Immediate access to some guns\n - Sidearm camera, hand grenades\n - Full practice range\n - 2 shoot-house assessments\n - Some challenges and modes\n - Hidden cashwads to find\n - Attachments to unlock and buy\n - Balloon Stabber minigame\n - Home hub area\n - 35 ridiculous announcements\n - A secret demo area to discover!\n\nTECHNICAL FEATURES\n\n - 90hz refresh rate (Quest 2+)\n - Full roomscale support\n - Seated play support\n - Left handed support\n - Captions\n - Locomotion options\n - Solo / offline\n\nFULL GAME FEATURES (NOT IN DEMO)\n\n - All 8 shoot-house assessments\n - Full challenge board\n - Full access to all modes\n - Full arsenal of 20+ firearms\n - Kamikaze drones\n - Augmented visor\n - Even more Tactical Tools\n - Both minigame floors\n - SimpleJack arcade cabinet\n - Facility induction\n - Progression system\n - Functional grievance booth\n - Big secret area, beyond the booth\n - More story / lore to uncover\n - Full 120 random announcements\n - Multiple save slots\n - Difficulty options\n - Permadeath option\n - New game plus\n - And even more!\n\nLooking for a tactical room clearing sim? A fast-paced action shooter? A casual, unusual, indie-game to explore? Shotwood has you covered! Grab this FREE demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.concretebox.net/privacy.html", "developer_terms_of_service_url": "https://www.concretebox.net/terms.html", "publisher_name": "Concrete Box", "support_website_url": "https://www.concretebox.net/support.html", "website_url": "https://www.concretebox.net/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8077770712267033"}}]}, "scheduled_offer