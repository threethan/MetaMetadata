IEFhFadZfoQ7kNvgGi1vQK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD5CaebTKqbltopVNYBTII4mNtgT_z5onXK_gkTBxJCCQ&oe=67405B17"}, {"file_name": "level-select.png", "id": "861445076021181", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031640_861445079354514_4968430877850706782_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GkL_3DvRJ-sQ7kNvgFwR8vf&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDeYmK_ggDK6fIti8ON-NjIlWlRYpvKFO0FLiP8YR2W8A&oe=67406A72"}, {"file_name": "screenshot-5.png", "id": "1923238414795379", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984442_1923238418128712_4769228846090391027_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rzwkdE9-IcUQ7kNvgE8szSb&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAfio1HkK3Hhuu2LY6wRa5CyQO1JZGDbun6vvAm6mD8DQ&oe=67408105"}, {"file_name": "equipment-terminal.png", "id": "3958226264503543", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GIhOsEdC0vMQ7kNvgH1WqsX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBe68_7HuS74zNv-drHWg5qNa4Ek5UC4UlFIOfzTA10hg&oe=67408A59"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AyVY3hcJVEYQ7kNvgFEPaO_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCn_ZH3uE0eWJylS7XNIV27keU5Jm66e9B98se2d1IKwg&oe=67407E3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dCc-DKzrykUQ7kNvgFolCGc&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAplze39D5BgGs5gX_jvRK1PSyW07_RIpTr2mZJ6s8_Xg&oe=67408A9C"}, "display_name": "Shotwood Demo", "keywords": ["Shot", "Wood", "ShootWood", "Demo", "Free"], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\n{866219128900813}\n\n# Demo Features\n\nCheck out the awesome Shotwood gunplay with immediate access to some high end weaponry, plus the full practice range and 2 **shoot-house assessments**. Chill out in the home environment. Earn credits by completing runs and challenges, hunting the hidden cash wads, or mastering the ridiculous **Balloon Stabber** minigame. Spend credits on ammo, grenades, and gear - including the awesome **sidearm camera**. Find all the hidden clues to access a **secret demo area**!\n\n{427997739692963}\n\n# Full Game Features\n\nThe full Shotwood experience (not in demo) includes 8 shoot-house assessments with 15 challenges each and 3 modes, 20+ firearms, 9 tactical tools including **kamikaze drones** and the augmented visor, 2 minigame floors, playable arcade cabinet, facility induction process, **progression system**, working grievance booth, big secret area \"beyond the booth\", more **story** to uncover including 120 random announcements, 4 save slots, various difficulty options including **permadeath**, new game plus, and even more!\n\n{2300077013672023}\n\n# Tech Features\n\nShotwood runs at a **smooth 90hz refresh rate**, supports full room scale movement as well as seated play, and offers multiple options for movement, haptics, captions, and whole lot more.\n\nGrab this **FREE** demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": n