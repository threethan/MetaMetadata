nFbBfwQbO0Q7kNvgGDoyWy&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDwe5R9UZyA6j1cs8snCqMueNLF7J-VWFAoPtwRyGjonA&oe=67162B17"}, {"file_name": "level-select.png", "id": "861445076021181", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031640_861445079354514_4968430877850706782_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GQ2RpJ5SFlEQ7kNvgEuJfm2&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAPY99Zi9R6XgpMqUuG-eSQadeC_K3Nb5QmeWyaTj6A8A&oe=67163A72"}, {"file_name": "screenshot-5.png", "id": "1923238414795379", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38984442_1923238418128712_4769228846090391027_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qNm_-A3RYw0Q7kNvgGv6gmY&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCXVHURgXt3F7X8hZiyKUW2HBtFymWnbcy-c-BsqHPjhA&oe=67165105"}, {"file_name": "equipment-terminal.png", "id": "3958226264503543", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75203624_3958226267836876_1387244605674504322_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qdQlTJWQzdMQ7kNvgHrHBfc&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCXLvIoK2UgilVvONfNQ53GcWeftYJ3sfMPvpOv9RidSA&oe=67165A59"}, {"file_name": "screenshot-4_v2.png", "id": "1050360773266784", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39031417_1050360776600117_7915853884089917557_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8QohmRgIxqwQ7kNvgH1iMv7&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYByO-QmZs6hvn6reJRcij9To8pUEoigelV_bajEXV6I1Q&oe=67164E3F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1191951792116232", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982570_1191951798782898_1277406797779782208_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eLJBsmL9AOkQ7kNvgH_I90G&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDSlHZfDDrgJckmXUIrOhOxC1oCbyp1Gex-Wt6MvUhutw&oe=6716225C"}, "display_name": "Shotwood Demo", "keywords": ["Shot", "Wood", "ShootWood", "Demo", "Free"], "long_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!\n\n{866219128900813}\n\n# Demo Features\n\nCheck out the awesome Shotwood gunplay with immediate access to some high end weaponry, plus the full practice range and 2 **shoot-house assessments**. Chill out in the home environment. Earn credits by completing runs and challenges, hunting the hidden cash wads, or mastering the ridiculous **Balloon Stabber** minigame. Spend credits on ammo, grenades, and gear - including the awesome **sidearm camera**. Find all the hidden clues to access a **secret demo area**!\n\n{427997739692963}\n\n# Full Game Features\n\nThe full Shotwood experience (not in demo) includes 8 shoot-house assessments with 15 challenges each and 3 modes, 20+ firearms, 9 tactical tools including **kamikaze drones** and the augmented visor, 2 minigame floors, playable arcade cabinet, facility induction process, **progression system**, working grievance booth, big secret area \"beyond the booth\", more **story** to uncover including 120 random announcements, 4 save slots, various difficulty options including **permadeath**, new game plus, and even more!\n\n{2300077013672023}\n\n# Tech Features\n\nShotwood runs at a **smooth 90hz refresh rate**, supports full room scale movement as well as seated play, and offers multiple options for movement, haptics, captions, and whole lot more.\n\nGrab this **FREE** demo right now and... SHOOT SOME WOOD!", "short_description": "FREE vertical slice demo of Shotwood. Smash deadly wooden targets with realistic firearms & explosives while you try to escape from this ominous, ridiculous, mysterious facility. Shotwood is the casual (yet satisfyingly tactical) shoot-house themed game!"}]}, "developer_name": n