n11-1.oculuscdn.com&oh=00_AYCvd24C51Fi6HLtxg4Vxj7pzSu82leBhRCYslmmVj25dg&oe=6728A4FD"}, {"file_name": "i4.png", "id": "478291911327218", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974457_478291914660551_7364974676771227725_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o27GszFihJUQ7kNvgEcj6Lw&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYA8emRLuAB-3vyWNQn5toYTvjNji3bsx_x2nvBBg9WGjw&oe=6728A916"}, {"file_name": "i5.png", "id": "1127262891722848", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39035395_1127262895056181_2032311781746928441_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ht-El3hmFocQ7kNvgHg1ElM&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYD-d6-9nDZC6t-nCNKP4F4IK--0ysE5VjkJqRCD7at9mw&oe=6728C8B9"}, {"file_name": "I1 New.png", "id": "1501814837209111", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39031544_1501814840542444_3211106174534954323_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YU-ls7Go94AQ7kNvgFySR4P&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYC__bToaUwlk_jWB9-EYS5MweLMwUpk_6EgBcR8zqcJRA&oe=6728A7A1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pikaso_texttoimage_boxing-game-single-player-with-boxing-bag_batcheditor_fotor (1).png", "id": "762475215963505", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/86796210_762475219296838_3326290683811526484_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JZkp-NazJ1sQ7kNvgFgWO67&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYACq8SyULnToIbJoO9ur1tGpEV9mfZESZz4jV3KsScWbQ&oe=6728C34A"}, "display_name": "StrikeFit", "keywords": [], "long_description": "### Experience the Ultimate VR Fitness with StreakFit!\n\n**Step into the Future of Fitness with StreakFit!**\n\nRevolutionize your workout routine with StreakFit, the ultimate virtual reality fitness experience designed to make workouts engaging, immersive, and effective. Say goodbye to monotonous routines and hello to a dynamic, interactive fitness adventure!\n\n**Punch, Push, and Perform Like Never Before**\n\nUnleash your inner athlete with high-intensity workouts:\n\n- **Boxing Punch Bag**: Hone your boxing skills and deliver powerful punches on a virtual punch bag, improving strength, endurance, and coordination.\n- **Boxing Punch Ball**: Sharpen your reflexes and hand-eye coordination with our fast-moving punch ball.\n- **Pushups**: Build strength and endurance with virtual pushups, tracking form and performance to push your limits.\n\n**Visualize Your Progress with Real-Time Energy Graphs**\n\nStay motivated with dynamic energy expenditure graphs. StreakFit provides real-time feedback, allowing you to see immediate benefits and track your progress over time.\n\n**Why StreakFit?**\n\n- **Immersive VR Experience**: Feel like you're in a real gym with a highly realistic virtual environment.\n- **Fun and Engaging Workouts**: Varied and challenging activities keep your workouts interesting and fun.\n- **Track Your Progress**: Real-time energy graphs help you visualize effort and improvement.\n- **Fitness for Everyone**: Adjustable intensity levels cater to both beginners and seasoned athletes.\n\n**Join the StreakFit Community Today!**\n\n\n\n\n{461129256613304}\n{1476585626396419}", "short_description": "Experience the Future of Fitness with StreakFit!\n\nStreakFit offers an immersive VR fitness experience with high-intensity boxing and pushup routines. Train with a virtual punch bag and punch ball to improve your skills, and track your progress with real-time energy expenditure graphs.\n\nFeatures:\n\nBoxing Punch Bag: Perfect your punches.\nBoxing Punch Ball: Boost speed and accuracy.\nPushups: Enhance strength and endurance.\nDownload StreakFit now and revolutionize your workout routine!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/strikefit-privacy-policy/21ee2985-670e-4f35-840f-828f98e672f8/privacy", "developer_terms_of_service_url": null, "