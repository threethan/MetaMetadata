vgHfTEJw&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAFZlpFg3YnyZrx9WX7CWW3vrEgx8QdZElEHRgH2i5pA&oe=66D07439"}, {"file_name": "I1 New.png", "id": "1501814837209111", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031544_1501814840542444_3211106174534954323_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RD19RarWTuIQ7kNvgHwjZRR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWssbH1NApLTOaPwiZkciYWj8Mt6B3YpJs_jnaVy56ng&oe=66D05321"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pikaso_texttoimage_boxing-game-single-player-with-boxing-bag_batcheditor_fotor (1).png", "id": "762475215963505", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86796210_762475219296838_3326290683811526484_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wGhoDCdU468Q7kNvgHUYt-D&_nc_ht=scontent.oculuscdn.com&oh=00_AYC2joo1CbfOXcGSaSY-JoQX0ytMwdQnE2acKxaOA_XGGQ&oe=66D06ECA"}, "display_name": "StrikeFit", "keywords": [], "long_description": "### Experience the Ultimate VR Fitness with StreakFit!\n\n**Step into the Future of Fitness with StreakFit!**\n\nRevolutionize your workout routine with StreakFit, the ultimate virtual reality fitness experience designed to make workouts engaging, immersive, and effective. Say goodbye to monotonous routines and hello to a dynamic, interactive fitness adventure!\n\n**Punch, Push, and Perform Like Never Before**\n\nUnleash your inner athlete with high-intensity workouts:\n\n- **Boxing Punch Bag**: Hone your boxing skills and deliver powerful punches on a virtual punch bag, improving strength, endurance, and coordination.\n- **Boxing Punch Ball**: Sharpen your reflexes and hand-eye coordination with our fast-moving punch ball.\n- **Pushups**: Build strength and endurance with virtual pushups, tracking form and performance to push your limits.\n\n**Visualize Your Progress with Real-Time Energy Graphs**\n\nStay motivated with dynamic energy expenditure graphs. StreakFit provides real-time feedback, allowing you to see immediate benefits and track your progress over time.\n\n**Why StreakFit?**\n\n- **Immersive VR Experience**: Feel like you're in a real gym with a highly realistic virtual environment.\n- **Fun and Engaging Workouts**: Varied and challenging activities keep your workouts interesting and fun.\n- **Track Your Progress**: Real-time energy graphs help you visualize effort and improvement.\n- **Fitness for Everyone**: Adjustable intensity levels cater to both beginners and seasoned athletes.\n\n**Join the StreakFit Community Today!**\n\n\n\n\n{461129256613304}\n{1476585626396419}", "short_description": "Experience the Future of Fitness with StreakFit!\n\nStreakFit offers an immersive VR fitness experience with high-intensity boxing and pushup routines. Train with a virtual punch bag and punch ball to improve your skills, and track your progress with real-time energy expenditure graphs.\n\nFeatures:\n\nBoxing Punch Bag: Perfect your punches.\nBoxing Punch Ball: Boost speed and accuracy.\nPushups: Enhance strength and endurance.\nDownload StreakFit now and revolutionize your workout routine!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://doc-hosting.flycricket.io/strikefit-privacy-policy/21ee2985-670e-4f35-840f-828f98e672f8/privacy", "developer_terms_of_service_url": null, "publisher_name": "VisionXR (OPC)", "support_website_url": null, "website_url": "https://www.visionxr.co.in/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "RO