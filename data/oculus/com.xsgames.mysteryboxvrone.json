nc_sid=6e7a0a&_nc_ohc=7owHVyv53OwQ7kNvgG2XZMA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDcgfXWtDvQHnR9TGFZXn2D3jZjG8R0ez1LnCfyDSGBfQ&oe=6718F06A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4i_Vv8TiRUQ7kNvgHinSOb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBwhhqBGR-2N-ezR1RMpRis53RTHvAEHvwme9X-LplXuA&oe=6718EE02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9RB_dcf32IQ7kNvgE2SfG3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJRSOnDbp5ScQtZEljQJzFpbXh1qRtKdzQbe-9K-VCdQ&oe=6718DA84"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=swZAe4EZLegQ7kNvgHW9KPW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCr7cKDnT-Iu0AJyOGIVnnk0YlrVYB4kT0Z5oAmHxwDng&oe=6718F762"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFR3HYnBpYMQ7kNvgHPNILQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCKTScQ9b5tiLd1QWclX1r9YzyiK-LmpL-vfg_uVGLAAQ&oe=6718E173"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQnsajTrm4UQ7kNvgFd6JQ9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_0OLCdeCDaJo0p5bagnVb3G588dZO3F9Hr9IxSvmagQ&oe=6718E06F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CDD2Af0JwNMQ7kNvgFqLpaR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCD_h8i11HlfYMztc7AoX1zeMNwq7WE0mT1yIWCY6gMUg&oe=6718DC65"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ypQ3AbFEfkcQ7kNvgGxMGIE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvPchaRkuBRPnjiUtI5-VGtAJ9luoq8reblR9rmudnbw&oe=6718DB4D"}, {"file_name": "$RQ3SN6U.p