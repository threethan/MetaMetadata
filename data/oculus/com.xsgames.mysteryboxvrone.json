iad3-2.oculuscdn.com&oh=00_AYA3bQnZL1CnSpKL8SYKylkQtr9SwEPTM3-vjdHnhr2IrQ&oe=6767E6CA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rRmSK3uGKbYQ7kNvgGXYRba&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDGF-DN7yHWmouoXr4zA8Z5x6K_tct1cZeqIbChapeVKQ&oe=6768126E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "1539093960065384", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_1539093963398717_8886613911254029402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4nP36Tl3L9IQ7kNvgGD7b4U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYByZm22aLcT0ooIU6783lFCJUrtloUscjnsqpnFJruzAA&oe=6767EED2"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["escape", "room", "trivia", "puzzle", "mistero"], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}, {"images": {"nodes": [{"file_name": "mini_landscape_coverart.png", "id": "3787633628158330", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974796_3787633634824996_4791017203159274969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u6pzHsihsWEQ7kNvgEUSzzU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDD6Dr6E1Dbc3OIS5VTXuIZk-FzwhCkudIq2ZlgnBw8MQ&oe=6767EC75"}, {"file_name": "square_coverart.png", "id": "1707528066702789", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yspMOtDpz58Q7kNvgHu6JEh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAt9Qa3Gh3H7yXT7rDJDcHsI6wviyaSmbBGrZmZ-Y1eyg&oe=6767E600"}, {"file_name": "PDP_art.png", "id": "1589730438299064", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003263_1589730441632397_3766788920031563801_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJYWChIVL_EQ7kNvgHsp5AK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCw0oRhNxL3T78IOR_eA7S5Q6q6e2ouDn8F1Kbmg2eimw&oe=67681020"}, {"file_name": "landscape_coverart.png", "id": "1495530294473366", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982715_1495530297806699_4884690371615260421_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mhTdV8g3cxgQ7kNvgEpZ0wO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiacbLHkuwA1Qra-DBixJBr5j64xef-q5Rd7bokcDpbA&oe=6767ED07"}, {"file_name": "appIcon.png", "id": "949852623679480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974652_949852627012813_8337858694233804619_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xs5xai6jkDAQ7kNvgEDKadA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYATx25bkUD21xYRoancLfinxaSXVXMRCpnqlk04VuPcPQ&oe=6767FC01"}, {"file_name": "portrait_coverart.png", "id": "875039991054373", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982626_875039994387706_900327033248542707_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F0MsUg_F1ioQ7kNvgFsLTNX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBtHKgztgLYTD7DUq1TUmG4RTVksbu8nghvumT5fDh3bg&oe=6767E002"}, {"file_name": "logoTransparent.png", "id": "551559830957325", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982492_551559834290658_1182549563175349564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JRQP7SojXq8Q7kNvgEWGMl5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1moRAlCGKz6ZoYBHL-c97UTtiiM-Ab8vNMjvJkIij9g&oe=67680CF2"}]}, "id": "595101106417330", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uX1KuG1FQSQQ7kNvgGFJnG8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRlvRRwG5oF1USf6jBJaD72ASQDdA9J-cX1wnKuEp_vg&oe=67680A6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rarQ7iypW8EQ7kNvgGaLal0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAYFL7HAY6O1t_c9h8qeAiaRb4pFsFnb9t8PVgOJAMBpQ&oe=67680802"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NqWv3DqhnhMQ7kNvgFfXAcv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlDGX7QH1568Elllgcy1EFytxdR_C4w9M7cXAfXbl33g&oe=6767F484"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=snQugUdiQXsQ7kNvgGH0lzn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBlKE0Vg09QIzvJZZ3IOGZNbMdKPC5HsPuv8e1gJ9RlQg&oe=67681162"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nHgc51k99xIQ7kNvgFAOm2O&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhiRUxjSrXL5rXqlp6xtxGBnJCryoD9dBQwRMbFpLfDw&oe=6767FB73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "897861905346420", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982672_897861908679753_3996777238831042692_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0_6hRMst-y4Q7kNvgEkRifh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD2oHBEMuHnMRaCCron8w3wEA5mcGsaisvqgQOTKFp6Sw&oe=6767FDEB"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["puzzle", "escape", "room", "trivia", "brainteaser"], "long_description": "# AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "Crack awesome puzzles around various boxes, and discover the history of the world's most popular inventions!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8681944438587156"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yspMOtDpz58Q7kNvgHu6JEh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDXFJzB9z_mRPsqg2JoAkZducWbuB8OFuezmzHHFVEdvA&oe=6767E600"}, "is_concep