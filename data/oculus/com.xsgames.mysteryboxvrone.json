ams4-1.oculuscdn.com&oh=00_AYC3NvaNI6UpECSpjYvNhxM0nX5rFVnUB7szHWoh7n80Vg&oe=677BAD4A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U_7t35z73LkQ7kNvgEiKIVT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBzmD2axRCQIw_g9xl2nipHQFLmh_pHHD2-07gEYL0GIg&oe=677BD8EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "1539093960065384", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982581_1539093963398717_8886613911254029402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D9IEWYmJoCUQ7kNvgFeC0Nc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAViTZSkkwtwNGSUZhjM1tJF6dv52VZpNi5XabcCCDNjQ&oe=677BB552"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["escape", "room", "trivia", "puzzle", "mistero"], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}, {"images": {"nodes": [{"file_name": "mini_landscape_coverart.png", "id": "3787633628158330", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974796_3787633634824996_4791017203159274969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7i6nXoIO7iAQ7kNvgElShpZ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCOnW_Ehbb33nK6wh7TcZRBSnGY0psTq1cecjGa50PcEA&oe=677BB2F5"}, {"file_name": "square_coverart.png", "id": "1707528066702789", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vy5a4Y2YScgQ7kNvgFIm_8j&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAH9K_Ty7TFFtxuLRrezbM-565x99S9AEdOXpV8oDGo1w&oe=677BAC80"}, {"file_name": "PDP_art.png", "id": "1589730438299064", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003263_1589730441632397_3766788920031563801_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q1WfE1P9mdkQ7kNvgHE3TOl&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBxvYP-wLvH2SWbboujjJqvz1v1t4y-Gcm3KPPxPaDLIw&oe=677BD6A0"}, {"file_name": "landscape_coverart.png", "id": "1495530294473366", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982715_1495530297806699_4884690371615260421_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J8YJs47xuvoQ7kNvgFG5dC6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAKW8KVv3egO4q5m708OaKiYJsoB-7ttfqw2XJeXp9Iyw&oe=677BB387"}, {"file_name": "appIcon.png", "id": "949852623679480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974652_949852627012813_8337858694233804619_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0pa8GWiDk4sQ7kNvgElLQVB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBUQVkJevr0ZbzGRHzNb3PUAvWbo8IBXuTrNHS7zdPDsA&oe=677BC281"}, {"file_name": "portrait_coverart.png", "id": "875039991054373", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982626_875039994387706_900327033248542707_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fd49GMH0-20Q7kNvgGTvZ9w&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBiDW66mdHF_UqnkQmgB2wnhW07ocBgr6-QByUx-suZmQ&oe=677BDEC2"}, {"file_name": "logoTransparent.png", "id": "551559830957325", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982492_551559834290658_1182549563175349564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3JdfwAoonzMQ7kNvgE3Nu8L&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCTQ_ozsM8z881JC8VEh9Saq-t1oaN5nriC3aO_h9_nxA&oe=677BD372"}]}, "id": "595101106417330", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HVvuXuqW_qAQ7kNvgH848ci&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBlELTs9uAZK9up0hUQSKF3E1WBg1rRwN1XTUPvIn7DZg&oe=677BD0EA"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AbR8cJfThQoQ7kNvgF-YrZO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCmTQ-bFVuu-TsyiUO_kdFjD1lwi-bvz4czdbS9aEELVQ&oe=677BCE82"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kPBnq1oi-OIQ7kNvgG7DtRn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD0Mt-VuIe-GNpdy9h3eE8IMxjeIdvQ5p_i4O4TVIOMEA&oe=677BBB04"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xp5Z0zCZZbkQ7kNvgEFUp8k&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB9zS9U4x3Z5hAL_vJDAWXqG74KRoNcMwF9jREUCQEHHg&oe=677BD7E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b1DCk0-wtbcQ7kNvgH6-UW1&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCZ5Nck8dXU4WiUJkW7R_XyV4ACAd4yl3li0rahVRenew&oe=677BC1F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "897861905346420", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982672_897861908679753_3996777238831042692_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zLtkFpXgznwQ7kNvgFGvz0f&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDJlqa43saQUbburAXOJSRMzjDhmrCgzrVXJ8F3w3gPQQ&oe=677BC46B"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["puzzle", "escape", "room", "trivia", "brainteaser"], "long_description": "# AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "Crack awesome puzzles around various boxes, and discover the history of the world's most popular inventions!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8681944438587156"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vy5a4Y2YScgQ7kNvgFIm_8j&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCJ-X5zz8FrnktF6vc_xV3FQJBtu8cXr0CMKyShV2F9nA&oe=677BAC80"}, "is_concep