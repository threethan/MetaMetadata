71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iLIZYg9F-i8Q7kNvgFW1UYZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzXN7xj6TPZjXmwqTR_GlZXadYXpciJ57d5TReKlnqlQ&oe=66DC5262"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SLDxRsmTK_UQ7kNvgHNlMRA&_nc_ht=scontent.oculuscdn.com&oh=00_AYAX6mLawXXBOUDp9STkmhbDE8KGiOG60FCPpKWzvKp_Ig&oe=66DC3C73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e65-kld9MVoQ7kNvgHwGykp&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIPMGtyxWvuN2Mj_D8ZyGiuWVfOwSf-EdKRc7baw1SUA&oe=66DC3B6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LqbkxloP0_sQ7kNvgEIDxWP&_nc_ht=scontent.oculuscdn.com&oh=00_AYB3xiTv2-e7evrf4GMN-Rep2qJe3inPvzW-YusFZeWE5w&oe=66DC3765"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fFAnEjafV3wQ7kNvgGH6TlO&_nc_ht=scontent.oculuscdn.com&oh=00_AYCbpTkjW6AFeDJBja2Qt0P0VxJGjO5JI7GwQd8IBJXjQA&oe=66DC364D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a8WLCvTAC3AQ7kNvgHND0Js&_nc_ht=scontent.oculuscdn.com&oh=00_AYBx2YwWAn_G5I3uLPefT-FKgr2cPqDCQAECjeszL_UoOA&oe=66DC41A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=07uv2fJegJsQ7kNvgH-3KYN&_nc_ht=scontent.oculuscdn.com&oh=00_AYDInUfSaacd2lLEUy-ZRHSjxiWgGc_0GgAzb_mdnI84zQ&oe=66DC2BCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c9zDg035Rl4Q7kNvgGz4yr-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAJnX7EzhzGgbPFQk9YqVMhVu1JLbzUtZtaHemIUc