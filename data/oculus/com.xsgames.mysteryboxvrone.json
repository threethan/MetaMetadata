26_820373840077633_3034343047413447332_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GNT_hhr0KMEQ7kNvgEshQc3&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYD-U2s71ZnJzBMBPSfUIFvppPc-517_F_9SHB7Wn0CGjA&oe=671A3F5D"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yk2hEvtt3gkQ7kNvgFEe6fr&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYA9_0SEscQYv98uf-pq-Lpd_PL8v3IxWKCWIKRcKXf2zA&oe=671A2806"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AGCWhYsVpg4Q7kNvgGOkrI_&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDNm40xLcMzN1dIH3TU6pJ4i4I7HRoyMJYhv2_lpoQ0TA&oe=671A442E"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7owHVyv53OwQ7kNvgF6MrVY&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYAQLywWRcB3nfRKULOqwWNR42fsLTMwGc58P3kGTlhzkw&oe=671A41EA"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4i_Vv8TiRUQ7kNvgFBm9gl&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYC5cTzUfwBV52rXnHjurfY1q7aKZ79ZHlLtpBRY5J6M3A&oe=671A3F82"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9RB_dcf32IQ7kNvgEJg-tC&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAhNDqyK3CZ4EdqFku7IPmzq0a8ZRym3GJUqA23bEJfUA&oe=671A2C04"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=swZAe4EZLegQ7kNvgG-WOVg&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCV_JKXkZG-qCRkGnb_Jgi_VKkVlU7HblFYd2AoXZz9gw&oe=671A48E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFR3HYnBpYMQ7kNvgH_uW0d&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCIKGMT6g8f1fyxDgbmpHxIohc08-w7Af-JkGyyLVQTMw&oe=671A32F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQnsajTrm4UQ7kNvgF2_i1N&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDzTocz31mY3LFRxtg9eS9HP2ugkblEn-QywvMa2QVYHQ&oe=671A31EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iwq774Wk1DYQ7kNvgHPiIBn&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYBeyQAh7H1SyvJFpg9eajAGVKyl69TX-LBpdxoXl8_d5g&oe=671A2DE5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ypQ3AbFEfkcQ7kNvgFyX61P&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYAhqU5nmTmhnuUGVkCZnVkbiImLJ82BpFaIf4VtiP-9bQ&oe=671A2CCD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g2I0iSuWRlUQ7kNvgFZ3GsQ&_nc_zt=3&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYCxoVx7Sm47NtX35GHL_amyGNba7-aU3Q21OiwRL_WqCw&oe=671A3829"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XwmL43HyebEQ7kNvgHuZLal&_nc_zt=3&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYDBYbxHIb7OC7pY89Gctr_5vTTVE