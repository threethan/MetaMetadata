32_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_pS_hBF0dFcQ7kNvgFbp-Ak&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCW49SNgOPtK4iMyjvxpULXyfe1QV7fso56bbdhCBn7kw&oe=670678DD"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q51X5KwRCSUQ7kNvgHzxCkg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqxhdo1-p21NpsWiyJkk-xkgIILkDeMC6kLG8xleOAnQ&oe=67066186"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-LQFDG5cBGkQ7kNvgE8Igsj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrN4jIQjAHulO1hQtrxD19QOw9ZwSjH_jfpOvJ21g4nQ&oe=67067DAE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EGF1kw3tGj8Q7kNvgGnWMTX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDNbFEUuGa7ND-_T3qYUOGIiHkGA20lNqbd3CIBv_cXvQ&oe=67067B6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oPiEQTPaFSoQ7kNvgG-XPJY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnBfmLTX55lTicxyhXFI0_dX4qVXq2SdOjVWVm88Zp4Q&oe=67067902"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9NemTpjeMsUQ7kNvgHtxCJw&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1J9bU-4OaHKj1WAegAnior5LPtOuYXKicm4EAfzTOiw&oe=67066584"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xf-bIqsrGewQ7kNvgFkB1QP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9rj0Y--GXV2HYSbmDPjyduAW0-41YLqskMiP7j944TQ&oe=67068262"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7hrjKgI3IEQ7kNvgHRL90h&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBoy4CG3jXtQG3dxV9DBFGLu6Lhc3dnhQBLrN9TMBOIAQ&oe=67066C73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IEYfn3HcMUIQ7kNvgHLFJ1s&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCXlCefzBGoGNXtTnc9MizVkI2EEmqYaaYbhe4Ssh1E6Q&oe=67066B6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9GneEIdkktkQ7kNvgFjpKDN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYcA1p7AKkPGSry4PKQYD-UcbvxIH9T-gtTkBZJwm1kQ&oe=67066765"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3r6epgN6U3cQ7kNvgFpR7pz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4ESftHsW1GByqHFUxi4-u8P1o2Xmtb9OCwkwTJozGGw&oe=6706664D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RK98MNY1LH4Q7kNvgHa8gEU&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCjvT7LSrRSBC85Bw8lI5pUnu39xaK3DL8KjPHpk_t0cw&oe=670671A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_duiQnoO8icQ7kNvgGz5JKk&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNkw9VqnYbvj_9e4EE_75pug9sEFASYHgwLCwak0DaWA&oe=67065BCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhryO16yY-sQ7kNvgHn6wZw&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3YtU5s7lsnGAzeDrY3myArJcjxTpFntURGAr96vxH3g&oe=67067472"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wE8M1Bt28qQQ7kNvgEbJh2G&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBOkwVd2eDVv3SsZ0u2uZDx5fUtxIzEHoZ8IALGFAplRA&oe=670685C7"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XDleBeT0eKEQ7kNvgG25KWD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC4Q4DrCnDa3r-Di4sJcCvSIabtQjb9gfAPE6d3lOIqSw&oe=670659F8"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vm_x2cVUoRQQ7kNvgGBkIys&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqpw34nrckJV09nIcaKwdWjtjN_VmqVCe7KXhQM2k43Q&oe=67065AD8"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PS35QRo5WO8Q7kNvgE-I5ze&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJF_dYvAMiXmBT3pb0L77oWcMMbw35jDazD99L-D5FCA&oe=67065608"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ax0HvP8UInEQ7kNvgHOsnc-&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8rnqQh8cPXlASzMLTwjSMDuzE7tBLU8i79cyDQ9CA5g&oe=67068371"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qq68H54D6k8Q7kNvgF-qiLW&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC49ziJzUnagUwyvYIIGuY2eqen3pU2hcf7Ph3d8ewytw&oe=670657CA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z0tbMapIK90Q7kNvgFgQyT8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAfzEA_SuPkXFpVL0aRP0bt7enKkC--TBKjEbZTLRj3zw&oe=6706836E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LFPyUzLln0IQ7kNvgE9siFs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkooALp8VPw2jcvONPd7e0qi_NYETRjk-SGIQxZsc6Pg&oe=67065A4F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jDJUlJSjvesQ7kNvgHAZk0N&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUxGAOVCWtuFC_OS9uCcFA9KLEnOhJl9MYowJnyzbw5w&oe=6706680D"}, "is_concept": false, "is_test": false, "