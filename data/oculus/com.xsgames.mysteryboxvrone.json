nc_sid=6e7a0a&_nc_ohc=6BSKLVUMY1gQ7kNvgH7G9x_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZtrWp_271-ktQUiXGLoiB9umqpvdNXfqV-6RHaGRbDw&oe=67179EEA"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4i_Vv8TiRUQ7kNvgEvODFv&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA0E_PC8e_6s9_B1cAfk3Dd8Dkr25quyuOJNMxsl8YHTA&oe=67179C82"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j9RB_dcf32IQ7kNvgFrCOuZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUs5gQ-2wMH3P4e7T49C0KzHtPTJSUPcS877VB-cU4vg&oe=67178904"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TGaH-zH0VykQ7kNvgG6N4A7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA23jgXuB47KUrYANIvByXJ8BskVuZUpGMcFFqOSehz8A&oe=6717A5E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sFR3HYnBpYMQ7kNvgFyZ6oT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAysZ7WL5Cw7UBNv_el7C7DjSpuIp1JHNUtUXBCR8gZjA&oe=67178FF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xb4KsqxAfKIQ7kNvgHo5CUl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA0MVCdLZ5eBq9aJqQ1IMPYSyGiRLA-3RFspiTpbBS_2A&oe=67178EEF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CDD2Af0JwNMQ7kNvgGHcbvd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTxd4P0CzPev87qBSW92ui9--49fvNolpfWrAvAy4uNw&oe=67178AE5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ypQ3AbFEfkcQ7kNvgE_DXJf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwtsxg-TgHNesM_9vtM1Dgo27A24ZwNLMTV7fIoPBs5Q&oe=671789CD"}, {"file_name": "$RQ3SN6U.p