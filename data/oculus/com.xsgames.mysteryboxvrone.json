C05yYRRhlD2rdYrKlaMQ8EfEoCJy0WKFNp-9g&oe=67028482"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rm37M0oqvGIQ7kNvgGe38NA&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDhXBQfPTOl2-0xHwotTblB8AAF7cXm6mr2LpLuakyt8g&oe=67027104"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AK6dqKEJsdYQ7kNvgEwfd4W&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBV3IsiRhDKxvIZLQXxIct7qqHVicuCiuvBu5h44kkROA&oe=67028DE2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=908mnFqey4gQ7kNvgFAV8Hm&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBaGwLcghD5NguJoIDPU2mIN6PRrkCEzyBxLIzk-s1OSw&oe=670277F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j_4-IXO_i9gQ7kNvgHKlQlG&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYA5SfmwOfrlTwteuX1hcQt4mdf577kCExIbiCWkVl-l3Q&oe=670276EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Atd9-aepTBoQ7kNvgHPokHj&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB0WEZ_orxS3VXiYMdb1i-8ZKAseEn1EnpBmAucJSQzeg&oe=670272E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jtI9y3pwNlYQ7kNvgEjvqm3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAluYhrghLIrdFfxgkJLaZsi9tFPrKGzq4KhzfNRNIY8g&oe=670271CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q5QSNFN6ejUQ7kNvgGy-hNG&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCWt2T7MyM0nJavy-FKjyZ0d6A5T2gT0GG4mtdBf4EeVw&oe=67027D29"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "ht