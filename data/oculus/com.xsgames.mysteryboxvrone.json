57092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8iTCvTGvlMQ7kNvgE_Ltfn&_nc_ht=scontent.oculuscdn.com&oh=00_AYA3VuevSbBo9zWcUZYSssJteFwxk__gF8wPsiDBNX9k5Q&oe=66F95362"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NnxzZH0sP7cQ7kNvgFddRDl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDHyybX8n4qzhjg4cnDuECBzsp9lqrnNevkBnkxUFRiTA&oe=66F93D73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b80v2svgAu8Q7kNvgHaeCw5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZozkoIT4tvxsQfuNyrZZW_Si-23Xga6Un-LeDYYzI3A&oe=66F93C6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wiz7wZFGBnAQ7kNvgGLVtfp&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyqXz7i4UR_vCjQi9grkQHk1d5qw66WDGf55jr1MW55Q&oe=66F93865"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I-dv7PP4N6QQ7kNvgG12r_J&_nc_ht=scontent.oculuscdn.com&oh=00_AYBt69cQoNEHLEeYYpBpJtUskCsp-fTsf45W89jIgnECMg&oe=66F9374D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bsjizbFmQIAQ7kNvgF75cSe&_nc_ht=scontent.oculuscdn.com&oh=00_AYACDkZJRz6Bpg4QhcSv5qUWbnWvJw7q3EWxQlZVfNf67Q&oe=66F942A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PWW2AksmCJYQ7kNvgFh8qH_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCPbyANaF9lthBYbFS8CKkPXmxgu63xUgwmGN4-Ix8-RA&oe=66F92CCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_HL5fSCw1ngQ7kNvgFsiEyj&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoB3rkP9FPidkLbuIHgmf3VsMFTKauv6QXuT88gCvCjQ&oe