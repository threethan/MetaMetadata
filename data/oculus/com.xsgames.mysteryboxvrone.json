/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J-9cRoYyPaoQ7kNvgHvZkdw&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMuUXFcaAsniv-kLYzHnMEEuBlIjuJyC0JgnPUKRGIow&oe=66FFEE47"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jcVt4azQiDoQ7kNvgEMf3AI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnFQQ-Zl3rj4IdlTivgPY2IiyQZPxXOc5J1MJjqMv-cw&oe=66FFC278"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A9n_DzCi2-8Q7kNvgETDhog&_nc_ht=scontent.oculuscdn.com&oh=00_AYDe_DAtFVSw-F4oriLjIy6EkV01dpQ4FljwtnxjMvhU_g&oe=66FFC358"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EJzsISANZ5AQ7kNvgFcWZwa&_nc_ht=scontent.oculuscdn.com&oh=00_AYD_QKGcamRvHlHUgUldyl-QyAbRm4y78YkwTV_EpmLMhA&oe=66FFBE88"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aOxm7VZqO1AQ7kNvgGNgH7s&_nc_ht=scontent.oculuscdn.com&oh=00_AYDth_LZDBGqxBLHO8xQxTTf8wnpiaNMvdC7Euqp6qi5zg&oe=66FFEBF1"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whizWtu6P48Q7kNvgG1uHdT&_nc_ht=scontent.oculuscdn.com&oh=00_AYCmyBAs9ML5B_RWk0_kZWt-BZkg9Av-RhEZ4Kba7zFDgw&oe=66FFC04A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XXdWJrDtAvoQ7kNvgGdtxA2&_nc_ht=scontent.oculuscdn.com&oh=00_AYA5iJsYj-9FIdLVdrJM3uMFY_xdb6pSaDgGrf-C6uDI7A&oe=66FFEBEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6U6m641lZsQ7kNvgF2BWK3&_nc_ht=scontent.oculuscdn.com&oh=00_AYAUju2Q-CQil440uXZPsf6O5w9jHrLfqPjT07wfgrzOJg&oe=66FFC2CF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TX87X74cU5UQ7kNvgHWLulX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCCk8_J3vI0UgUlKJ4jXwfx5EMmT__XWSVN2inBH_M2wA&oe=66FFD08D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mystery Box VR: Hidden Secrets", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1723067263, "lastRevision": {"nodes": [{"id": "7984514294996844", "release_type": "SCHEDULED", "administration_status": "AP