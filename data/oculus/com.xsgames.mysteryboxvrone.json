32_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JwJ_qhpD2oEQ7kNvgH8AxBP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCosMBY73BFeSy7MaUoIWPJGv8o3TBzFfOKrIdCvCVJew&oe=670A6D5D"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dqp9o9u6Z0sQ7kNvgFm4CmD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAKMH5gpFu9VrscM6c20nzBdnstUeg-E_e9lrwP730RbQ&oe=670A5606"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yyOvg0Ngj_oQ7kNvgHh2-2E&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDsU90pcAYUKXIldgxo8SofvUwt-ZN1YgznMAJrS7qedg&oe=670A722E"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V-U6xz2uNGEQ7kNvgGzoiqA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7xVCfHt5bd11ZAvL90zktNf2jSxOIPbTAmml3TBh5kw&oe=670A6FEA"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nUyKXI3eBG8Q7kNvgG-WjQt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEL39f1g6FfQMf9nV9L5MPLmQyor3TeKRNpkQFukRIrA&oe=670A6D82"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dTDc6QScb4QQ7kNvgGqxOVA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCDPsn40zQNx5sNxl1BWbDqInx6cdK2JIFfwQMyaWOAOQ&oe=670A5A04"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fgrJ141ViGIQ7kNvgHA1g8q&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBerMbhWMbgtRaCnM8REFGoKmtTlhon8dZowgsiZ85O3w&oe=670A76E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n1gZIaHAXQcQ7kNvgFRMe7X&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAciID73zHcclmT59sXToP-77IBX-AIXjYiHyihhLwBjw&oe=670A60F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pWZJ4wC1slcQ7kNvgHamApn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnS06Veg02BF7xyyX0qXWun0Hu7sTlUZJ81SEmz_LIMg&oe=670A5FEF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2LxVgn3MotwQ7kNvgFOl4WO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBe69FtOfZRW9fMHYtykOWiihAJ05XgVhguS_pSDCUR4w&oe=670A5BE5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQpeLJ_Z5ekQ7kNvgGPOI3W&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC7TS52CJ5aqYgTFQ_lMb3AaLASnVcwmERmH6z3Upe5pw&oe=670A5ACD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJbmiTlckm8Q7kNvgGJicWR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCqIoWa34VA2hF5jP_OI1CWJo1z9fASpqj7p1JghhFU-w&oe=670A6629"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GiEOO1q1LuYQ7kNvgHttW0D&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlSq9FiezyPaTtV-SYc4vzfHTwiiBGiZqxXbRKxEyLuA&oe=670A504B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oc