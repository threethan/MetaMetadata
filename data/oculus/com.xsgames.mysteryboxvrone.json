71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AK6dqKEJsdYQ7kNvgEwfd4W&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBV3IsiRhDKxvIZLQXxIct7qqHVicuCiuvBu5h44kkROA&oe=67028DE2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=908mnFqey4gQ7kNvgFAV8Hm&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBaGwLcghD5NguJoIDPU2mIN6PRrkCEzyBxLIzk-s1OSw&oe=670277F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j_4-IXO_i9gQ7kNvgHKlQlG&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYA5SfmwOfrlTwteuX1hcQt4mdf577kCExIbiCWkVl-l3Q&oe=670276EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Atd9-aepTBoQ7kNvgHPokHj&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB0WEZ_orxS3VXiYMdb1i-8ZKAseEn1EnpBmAucJSQzeg&oe=670272E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jtI9y3pwNlYQ7kNvgEjvqm3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAluYhrghLIrdFfxgkJLaZsi9tFPrKGzq4KhzfNRNIY8g&oe=670271CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q5QSNFN6ejUQ7kNvgGy-hNG&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCWt2T7MyM0nJavy-FKjyZ0d6A5T2gT0GG4mtdBf4EeVw&oe=67027D29"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PY0kb_hRWXQQ7kNvgHD8p0a&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBdF71vK-cHM4KMxZ3B3dPBlQ64gSs1s1imQmM-PBy5vA&oe=6702674B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LlgRH7V2-kIQ7kNvgFilPYt&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAh2drEzENQhHZqd6xbDpnpe4dDNp2Jc3Wx-LRmzAXhsw&oe=67027FF2"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A8w78C2HHtMQ7kNvgHYrsiu&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAA-g-kSlKa1ge5SRlNFxrjONwdA9Byp-saftxLFuVHyA&oe=67029147"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pfh1PXyw9NEQ7kNvgEjwer1&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAyEmNL1fpd4gsRuLhNhwxU2gRVEvdMUn22HyT_tzL00g&oe=67026578"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-eoRy6I2kAoQ7kNvgEEKNAz&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBXz2xAUMKfvxqrjtWoZWSx-34aeFMUB0TWcRkvXaPvnQ&oe=67026658"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-c6t3rWCr8oQ7kNvgELMGvA&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCeU3QstfI4jNvDg8NqiHkftY5ZyBJErYf8h0jV49mgLg&oe=67026188"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMGb20luzUgQ7kNvgGuxixM&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAbs8mhbNkz3GY6D7PiCykwlguN-jRZugI3IB1dKOK0XA&oe=67028EF1"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whizWtu6P48Q7kNvgG3uQ10&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBnaC-yrLav0t8mMdY3fVcBuCITn5pufv2qpZsbAo8P3Q&oe=6702634A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wR8NGAdI68IQ7kNvgGWyfWt&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC6q9g7-v3FG1Y7F1S1rwADmEnmK2sL6X18cO32XUIv5Q&oe=67028EEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=27Tq-7Q19LQQ7kNvgHU-B7P&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDs8tp24LFepdT-cI39deFwZLW5-LaoCryewJTLVwZ1QA&oe=670265CF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pjfh7GIAqfwQ7kNvgHuikdu&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBwWWFHK7pyqFt15xtg3pBT5Fv-pJEfxdlbADcCGQU8zg&oe=6702738D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mystery Box VR: Hidden Secrets", "platform": "ANDROID_6DOF", "context_category