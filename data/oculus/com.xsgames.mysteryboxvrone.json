32_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3cghq4xHrwQ7kNvgEjzNOa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzMnP4p7u4ZktVPvRjDcDIrRQIh4RPwm4qN2REqzXopw&oe=6713A7DD"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VXQmW3yB0eYQ7kNvgFHZFQq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYApCArszNuTm0UG3vQTbskTMbBcGV2Ike5bZ9lr9xvHWA&oe=67139086"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Sr57cFXMjMQ7kNvgFuz4Dl&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfmB2HKyiU4pR3gKEnHHu3ywtNmvWagB9RP4XSguuNyw&oe=6713ACAE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6jefcV2WRAQ7kNvgHZ2gD4&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRlhlVMmbOzVhzh9UCkTu4CCm3geNiyLw1kXCW3mI3mQ&oe=6713AA6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eXtE3sFYWewQ7kNvgFw1jWm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-1K2s78WKuAewxxUHHwPV6Io1I0Cbhc4mRazMtq5xWg&oe=6713A802"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SEvsNjXlXNAQ7kNvgHysamP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrdbS8wy4nS_OMJVnIxeeWFVIUFyH1a6F_RnSTDLfHyg&oe=67139484"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXT2zwdJkOgQ7kNvgHRu22_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXOGPbI5W65VoqAS0lcjznuYkIQjbIrX8Bs4YjSZid6Q&oe=6713B162"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKtx6S9uEmcQ7kNvgHiOdtP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJv_DEG5wKcPYemoItm8R_NixNxkZ8xjUsykCnejIJ4w&oe=67139B73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dilzsAfVBXQQ7kNvgEMWFHj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA78GnitVkAYJK32rJVFtj_IMa-ikvGeCxcarW5S6j2xQ&oe=67139A6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-vrMMXf85AQ7kNvgEm5XE0&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCp-T_t9VdFlyW0NBPDuL0t0QbujaRuqtQdKzpu4f_J1g&oe=67139665"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDPbRYiACvcQ7kNvgG6Bae9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0R00YjyKOD8hQbv-fbub8aptMu_uKpc2kPvmqB9LZLw&oe=6713954D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5o98FKVVazkQ7kNvgHpiFtl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAemzNS4QPVQTV8N0L4SZJZu-11oETcLstY9KvkLFi-VQ&oe=6713A0A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c359C28a3FEQ7kNvgH_kiwQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCY8wKHjKqaKioSbCF3OTQrpTTK50XysF8VVeZ5VZoi1g&oe=67138ACB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z4S8CyjIeXQQ7kNvgE8KBPK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCqGcigXpOl2lIiLCr1i-XF0tth_v-8OHAaDOIVuGx1w&oe=6713A372"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x4lJPhlSDEoQ7kNvgHK9biO&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3f4VxyYjeyW_rZrkbyvxVuWrOH2wZd0-LRdj9GwdTkg&oe=6713B4C7"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=opymjlrw16oQ7kNvgHAOGvB&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYMtYVDUtR9Z-vw0kAhjHv-gk8Sb-Mwq2YQebSgNE9Pg&oe=671388F8"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TJGh0r8Fq5AQ7kNvgF9iAV1&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiv0oVLAPJADCQx_LQBSgedVcuvdPr9zPgUv_vWBZpqg&oe=671389D8"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2Lt8JM4VbpYQ7kNvgEoCz3o&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBF9NPb03MQFRwXoXllMB5SPuoYcuPpRaHf4wtJLG912g&oe=67138508"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lj8jzZ7IfqAQ7kNvgFZCiBn&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAD4s_WelfkjkxkhcBKjpIfY8B4QKV9XRelzTJDC4FaJg&oe=6713B271"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qaQJANLzZNQQ7kNvgGNMpm_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQd1Zl4RSG9cTnuU8mkYXEw1W89B9dYZ7jFX3WH3y1-A&oe=671386CA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=inse495eMHoQ7kNvgGEK47y&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBH4CGh6Bsw12-LRkOKpZImrDXTnIMRgfMxkUeXeWnm7w&oe=6713B26E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l9CkU9xJWv0Q7kNvgFgEIeY&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHV89QlFVURrRY1jlwiW5cyLuuSBliT7fl3x11agOqIw&oe=6713894F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MameXt4dyNkQ7kNvgHI4KJd&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB0QI8y-YfSnVSRUPlXawbaptW0egpP-6YvVc0Wsq3ecA&oe=6713970D"}, "is_concept": false, "is_test": false, "