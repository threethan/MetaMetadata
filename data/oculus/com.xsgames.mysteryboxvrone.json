uluscdn.com&oh=00_AYAqpScRBOlVuKcbEBCqmJ96BHMkwqmCoXoOYBE4wpDmZw&oe=672E086A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=99BBXYDJEq8Q7kNvgFN9JcL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5LEx0p2swKpjSdjURBU_aiuOJzPqK2DZ-8jQjf1EfkA&oe=672E0602"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n5uyTzHhUO0Q7kNvgHTg0Rd&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAQdsb5hf5qqt9ZrdAA-t6t7-wdxqSXzpzvw8cVmVVzvA&oe=672DF284"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1gfuWZZ9ptcQ7kNvgFR8UxB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCcomdJBHyfXflESG_Vl0Z4b59vaCqsPWODDEEMGQGueA&oe=672E0F62"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Q3jTFE76-oQ7kNvgHur9DP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCiXa-Ff9AIIUGtJuwysBmUYx40kGEWavxUt02FxCa5SQ&oe=672DF973"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vsDjVC7B-o4Q7kNvgGrr7NB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFNG6DIV_1CHr2DBOxjzsViH0DRABVc8SOtgROOaNnTQ&oe=672DF86F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hHSx5fUHjbcQ7kNvgECApPm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBNC0Hb4rGVlmQwumZrK2pgjo3nyw6YvYhi5k-b2HesDA&oe=672DF465"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Os1iFRvwEo8Q7kNvgH0hui3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDatVdjULqHqPzXAHqA-4HPw4dX4SPd8yTnfkJ9ye28PA&oe=672DF34D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "