26_820373840077633_3034343047413447332_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xcq6mz40cPkQ7kNvgGFyXfJ&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBysndfqDWZmjhxuooy5qXCh6PYhdNFVp2Nl-7pu--6tA&oe=67164ADD"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wiH0hVzU5WQQ7kNvgHGMRtU&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYC8Rn9VZeQdd_bbZybf23a3Pj-YkUOIRDAl5sxW3dtU1A&oe=67163386"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mBQwxAU9_xMQ7kNvgEMIVFf&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAMN-vwH9jYEsuccRlNlbkl74iY2HTVwWoCRrenKFYG5g&oe=67164FAE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6BSKLVUMY1gQ7kNvgHWF2WY&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBcvjBclPZZj29Uxg3jrtUuUdPOxs6W01g-ZaMM5Nm62Q&oe=67164D6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eXtE3sFYWewQ7kNvgHoV1M1&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD9KuQ_6QShra78XNadslWGAe5JV4vkxfQPGOwCA-8xGw&oe=67164B02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SEvsNjXlXNAQ7kNvgGin7Ev&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYD_Mh06IFUnw-t1oAhJVSxDl5VixJp9ZCqJsoI2pJeEOg&oe=67163784"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TGaH-zH0VykQ7kNvgGe__pG&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBtocM0NU8LQyjkvxF9fY0XP9KckB--4_MY37mIlKGzOA&oe=67165462"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKtx6S9uEmcQ7kNvgEIK3Y9&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCE3I_Grby-1aSojZ8esUGj7mTGAU7cv_svKK3PczMGaQ&oe=67163E73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xb4KsqxAfKIQ7kNvgFkyaCI&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCaL2nW-V4a_OIRN-Twc-5DzrdmFVWVoydQoeczmTihqw&oe=67163D6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CDD2Af0JwNMQ7kNvgGJq7IR&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD2lWUdCnpBRFsAiqMPvYmMiygeVb4VbDg6Dn_ajLcD0g&oe=67163965"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDPbRYiACvcQ7kNvgEegoev&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCmLxeHVMa0XtsZ5g3FqVcJKSs31cVMYEWgePAOJhtRxg&oe=6716384D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5XxNikRItdMQ7kNvgGb3IZR&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAB8IY5cxtemtLjLYNwlvaFsXf-NcjEFoF0QgiqgPYOKQ&oe=671643A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UnXStekItKoQ7kNvgHAfDLj&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYB2HT4qa9-swesYzJ07gqlsMbXsPraBAs6snvFd0Iz29A&oe=67162DCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z4S8CyjIeXQQ7kNvgHvZjBZ&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYBfy-8xsLrd66ukB7SjBPwmQhwEezVQyvdNYEDCBKhePQ&oe=67164672"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d8CeyRoppvIQ7kNvgE-XNm_&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBtkPNKisT1mo6871YZHrw_HJDWyRRE9TZIPnVsevNfBw&oe=671657C7"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qGNF2eoT4HoQ7kNvgFXtoPY&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAsdIIp9E1Z955MpFoo6WoFWYzKgZn0u5RdV1jP3MsXPg&oe=67162BF8"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LGB9NaIkPDwQ7kNvgFlVYKm&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCKPKVuAntoo0xW2_7xs3SY1_w21kWaTLYEsieih47toQ&oe=67162CD8"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pCbnP2ZhJ2kQ7kNvgFmnNa1&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAV3Z9ObpXCT6yD6m_M-KJl_8XHhWHOXHVS0WhcVq7M3w&oe=67162808"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n7bIIKAf384Q7kNvgHweF_C&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYDpFjjhGvizwPxPOVMc8dTIi3NJB8DBg7MXALHY5QF2uA&oe=67165571"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qaQJANLzZNQQ7kNvgHLV3qv&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYAnCZIBwAY31BJUo5ov6NiXHoExXrYraA8ShHxSwUxDRw&oe=671629CA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rXGPvStk61kQ7kNvgEwH6uA&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBsZbXseJTFvkNZI_NZoOZzTEg8FE4GzxmpBYdJmuMsdQ&oe=6716556E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TKrka70-eAoQ7kNvgFPY6aa&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD3mqjrROrd5Umo7Y1l_REiQZhBnIVATmRdEcv-gHPdcA&oe=67162C4F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png