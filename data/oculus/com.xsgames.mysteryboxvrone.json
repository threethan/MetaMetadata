HxDhwolTRv5iicPvIJ0GcIQLLmNtQFHEg7i9A&oe=6703D602"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9NemTpjeMsUQ7kNvgGORQU2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAW8iIZVsCCzVEINBESl_g3oMZH3Nuqw0xFFdYKL3ytQ&oe=6703C284"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AK6dqKEJsdYQ7kNvgGrcKM_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALKgTbFc7UrBZ_PnZ7f3D-Reb6F8w5WEvgTpzI0YxeIw&oe=6703DF62"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W7hrjKgI3IEQ7kNvgFqsFGx&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJJ4LRYjSx7lBP_qe5V_bPWNKozDQRXhRjZKwCYkM-aQ&oe=6703C973"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j_4-IXO_i9gQ7kNvgHikFzs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCV5l6iYVDM9xd0bpPWOWrkDtqLBvSwwle5MD4T1yMnRA&oe=6703C86F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Atd9-aepTBoQ7kNvgF7xNKN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3LE8j0oyU6RwdEL7W2txGJyO87207z6H4y3y31MnKng&oe=6703C465"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3r6epgN6U3cQ7kNvgHwxceW&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIWDCC5BD_MRmlpueOntV1GX9mUOAWOgz_gMcyrefUzA&oe=6703C34D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q5QSNFN6ejUQ7kNvgH0lFrX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvZrfX2TC7v29KA3czXxdNCM67UELSZjaoSzgJTTCv5w&oe=6703CEA9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "ht