ame": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UI2935NSYZQQ7kNvgH7Dkr0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC2HT25L_eEPw_BNmTv4budBB_N98Bo9czomrhy9o3yw&oe=66D1A586"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C6dS0LzktaEQ7kNvgGqc3lD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDPSbqqMoJ5OvyJgC6y6Yno2RZiqEvh0tKvpCv4JokbEQ&oe=66D1C1AE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QhhsryMpLlgQ7kNvgEPjJRG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyJYpeSyqzW_8f9wdGGvEgF87wCNeu5XQ7zmsm9rq49w&oe=66D1BF6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DGYl6SZjP88Q7kNvgES2Yzv&_nc_ht=scontent.oculuscdn.com&oh=00_AYAikIQI3sFebRmQXAzQJn2Xw1bXInHgt8K0gL6wL_ZS3w&oe=66D1BD02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=32axxo1qr9QQ7kNvgHXeBIJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWgMtqIJGz-whAGho6PXxuuIkTkVpPlgxyKL-3DsKs3A&oe=66D1A984"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HihBJpN8pi4Q7kNvgHRxgJM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrn7zHVBGOu1EBWtasr0QVZMeEQuzBrAyWKRO98NKs6Q&oe=66D1C662"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OvZj5T0JH1IQ7kNvgF10GB8&_nc_ht=scontent.oculuscdn.com&oh=00_AYB99uBU4WYBupdA4g0FfgbBf3eEKTbKWUKAxJrSW00kPA&oe=66D1B073"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvlY3AfDAtYQ7kNvgEzBQu8&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2dTSheKl9LBW8ws0hdcg8nZ51DFkPccjDBCj73AyChw&oe=66D1AF6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t5bIIvti268Q7kNvgHYi8Bl&_nc_ht=scontent.oculuscdn.com&oh=00_AYCy9pWrGLJPbenzdoeStkcuS--pJSdZe5A8aoQUy_VUmg&oe=66D1AB65"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BBdnk3FqO1QQ7kNvgEJFpt1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqodzmPsWywsrIAiQMrkAKQ2dkZGdcrSPtGxnbVPVpoQ&oe=66D1AA4D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Omy0fmvKD48Q7kNvgGn8TWG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAThaVPCLrrg5stEoN_Aqsi0E0jg7WqEMBJiF1dHOp42w&oe=66D1B5A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UdGT84-UWpsQ7kNvgH5jgUD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVWOltWbRjM24tiqrpU9uLbpV9QVj3qbeLZI81PgVeMg&oe=66D19FCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_y1iVCkYlpsQ7kNvgFEozpj&_nc_ht=scontent.oculuscdn.com&oh=00_AYBux4bN5uxSHiv9xEobwg1PVRMdUgIVzoK0gIwzv7AmGQ&oe=66D1B872"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vlKKyBMvq9MQ7kNvgGqM1qi&_nc_ht=scontent.oculuscdn.com&oh=00_AYCIrCbIxif9PZFEMI4vA8LPKksdbDrFo2QKNQUUKIApVA&oe=66D19187"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g7m3JeNiLosQ7kNvgEckNIV&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKPB2EQo6YzWVzN-XS6FTQUCHwAUOCoODF25-04I3iYw&oe=66D19DF8"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3CKefW6IHZAQ7kNvgH7s4P2&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4t6pxcUMns1YiM0UZDjkZ5Jc1eB6_BEdYTUE4Je1QvQ&oe=66D19ED8"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8_cAPujPWYgQ7kNvgH_xGV_&_nc_ht=scontent.oculuscdn.com&oh=00_AYAiRV6QGhaL3XHnE3hEk3yN30FXjqpyLGY10huNdZJ5Iw&oe=66D19A08"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R5TGDjQCA0EQ7kNvgEOMXIr&_nc_ht=scontent.oculuscdn.com&oh=00_AYAZOJoFax369cPeP6e-hPCZ1DYzyHNvY3-Y4TrgvHY-gA&oe=66D1C771"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k37wE-71CBMQ7kNvgGKLH_P&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwm9lO3kkFs6HrjBpqFKwKxIZPz0M3MiyLXktEjvtPpg&oe=66D19BCA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1mkgyzP-A0kQ7kNvgE8uapR&_nc_ht=scontent.oculuscdn.com&oh=00_AYATtE8htXFtb0d3Oxq21knnuecmbsmszSUlVuqs4I3RDw&oe=66D1C76E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z1W7_OLmU94Q7kNvgHXQRLs&_nc_ht=scontent.oculuscdn.com&oh=00_AYBQ5W1Hox2_bQn30IGiz1O4nrD2QqK38y9bpsxyGPTAwQ&oe=66D19E4F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OLjL_x4ZKz4Q7kNvgGcCc5p&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrllgt_gX50pnxqpNmKwtd2iSt6bQ8UnQqf2aOpmc0Yw&oe=66D1AC0D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mystery Box VR: Hidden Secrets", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164460465"}, {"topic_name": "Puzzle", "id": "377978390272490"}, {"topic_name": "Strategy", "id": "275629210202852"}], "release_date": 1723067263, "lastRevision": {"nodes": [{"id": "7984514294996844", "release_type": "SCHEDULED", "administration_status