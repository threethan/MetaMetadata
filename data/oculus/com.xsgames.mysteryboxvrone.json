57092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JY4yhlumShkQ7kNvgHWs1Mb&_nc_ht=scontent.oculuscdn.com&oh=00_AYAqTkk2F-351Bj6NE5fBzcvEUYbzfydrsbch8Jbm4I39w&oe=66F018E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cdrG-Ogkwy0Q7kNvgHtx8TP&_nc_ht=scontent.oculuscdn.com&oh=00_AYC8y4k6odIR1FS5_7pZou35HMbuSeTDWXaCFl4csysKPw&oe=66F002F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vrWhoTNbzk8Q7kNvgHT2EUj&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0aIKpNsDVzdl24yW76Rj5IVqUxMi5ai2dRUWXlFBnjg&oe=66F001EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zpXyxMZTE_8Q7kNvgE88tBW&_nc_ht=scontent.oculuscdn.com&oh=00_AYBWHH7Mj1JwZREiCXYUcBYQckYZu7fhJT_Mma_B9kNPWQ&oe=66EFFDE5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ECN7xRvPkAQ7kNvgGiFej2&_nc_ht=scontent.oculuscdn.com&oh=00_AYClVF6mh1VLjsbZzsgXtH2WTTWOhzVnW-K0FkbjBeTX4A&oe=66EFFCCD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JKj7NZ_gYGYQ7kNvgHrH6hg&_nc_ht=scontent.oculuscdn.com&oh=00_AYA0HC05p0z8ylqcQ3xJHTqmSdU32Fc07usxudgoLAfTRg&oe=66F00829"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jVgS747sdKYQ7kNvgEZeX0Z&_nc_ht=scontent.oculuscdn.com&oh=00_AYDvMHmEQFKv77kTukrh_Fdjl9JGBxu9DghmidPytD0V5A&oe=66EFF24B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KCJE_ivoy5AQ7kNvgGigM64&_nc_ht=scontent.oculuscdn.com&oh=00_AYC6lMTyPHiJBRXXwj_bWYqqchczOUDhuQ7JOACa3Q_EIQ&oe=66F00AF2"}, {"file_name": "ml.png", "id": "758804276241553", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86627649_758804279574886_1746818431198727649_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VqXMFy1dFckQ7kNvgHrzlFu&_nc_ht=scontent.oculuscdn.com&oh=00_AYCRFu9kXd6VWE36nAqqZc9hAodhVjDr0CtBXCWO4byP5A&oe=66F01C47"}, {"file_name": "$RWJKXUS.png", "id": "406345889120457", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_406345892453790_2806525102226368153_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rk4n0EcSpbwQ7kNvgHOCm8C&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_Jv_0lJ-nJqVqpHiJWqc3OlbUIPI2VkT-pQmSxzSo_A&oe=66EFF078"}]}, "id": "476818348415672", "locale": "it_IT", "screenshots": [{"file_name": "4.png", "id": "499755402636525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035304_499755405969858_5224076533156194641_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JTkk3QiXib0Q7kNvgF5tzFf&_nc_ht=scontent.oculuscdn.com&oh=00_AYClW0pXVpiv60uar2hOsCkaPOkhUZB5J4zawNY9WSOpnQ&oe=66EFF158"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MKpEbumjmSoQ7kNvgGOsm87&_nc_ht=scontent.oculuscdn.com&oh=00_AYCoRMBWiiyBDLSk8SbCvbY_RIs_gtDPNRoAVau4EuDspw&oe=66EFEC88"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k8ACzHiVOfwQ7kNvgFAquTH&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmREZ5ZG07j9qUPvHBqQfvdepLrd2N2iJK91hqgEcP7w&oe=66F019F1"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LYWeAQGqP2YQ7kNvgFGhvzl&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqYZEaImMZ0FYRLtpPnf1A4pjNQ795KFGwUeEo3RCdMw&oe=66EFEE4A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WxP4WVF7FXAQ7kNvgHIMPf0&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-omvST-EinppCaHoHUugncjmmvBbmDH4nsnqTX00Ilg&oe=66F019EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FppIli4eFvUQ7kNvgE10MfI&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzSi8xjSE37OU_8m5kgDvanh-OwHmFc82HwpPmXzEufg&oe=66EFF0CF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1492753298037057"}]}, "baseline_offer": {"id": "1492753298037057"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1723067263, "status": "PUBLISHED", "id": "1492753298037057"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7985366698244937", "version": "1.0"}, "id": "374461648749950", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7984514264996847", "is_concept": false, "latest_released_binary": 