n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eXtE3sFYWewQ7kNvgFw1jWm&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA-1K2s78WKuAewxxUHHwPV6Io1I0Cbhc4mRazMtq5xWg&oe=6713A802"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SEvsNjXlXNAQ7kNvgHysamP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDrdbS8wy4nS_OMJVnIxeeWFVIUFyH1a6F_RnSTDLfHyg&oe=67139484"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXT2zwdJkOgQ7kNvgHRu22_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXOGPbI5W65VoqAS0lcjznuYkIQjbIrX8Bs4YjSZid6Q&oe=6713B162"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKtx6S9uEmcQ7kNvgHiOdtP&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJv_DEG5wKcPYemoItm8R_NixNxkZ8xjUsykCnejIJ4w&oe=67139B73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dilzsAfVBXQQ7kNvgEMWFHj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA78GnitVkAYJK32rJVFtj_IMa-ikvGeCxcarW5S6j2xQ&oe=67139A6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H-vrMMXf85AQ7kNvgEm5XE0&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCp-T_t9VdFlyW0NBPDuL0t0QbujaRuqtQdKzpu4f_J1g&oe=67139665"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDPbRYiACvcQ7kNvgG6Bae9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD0R00YjyKOD8hQbv-fbub8aptMu_uKpc2kPvmqB9LZLw&oe=6713954D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5o98FKVVazkQ7kNvgHpiFtl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAemzNS4QPVQTV8N0L4SZJZu-11oETcLstY9KvkLFi-VQ&oe=6713A0A9"}, {"file_name": "3898264