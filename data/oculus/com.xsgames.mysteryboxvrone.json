dn.com&oh=00_AYC0CYACUgu4WChJyxWPUbu6kiKPrvFSCXIqSf4Cxiw2Kw&oe=67308AD8"}, {"file_name": "1.png", "id": "996476465820891", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57574726_996476469154224_2905129728707462238_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Inh64VVt1M0Q7kNvgFHmOYi&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB9-lrUItBh9qzyyHyuWRBTIjc_u_3189JinGi021ipOw&oe=67308608"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lICnKICosN8Q7kNvgE4Q8nU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBv7gVufY7E5VTPK_907LhT61TewBy2nekDe7reqmjo_A&oe=6730B371"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aRsIJZfqaUEQ7kNvgHYipgy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC2mNQFDzzF2PS-0Ex7KlaDIrS3Wq-iCtrEhfEJoE3ulA&oe=673087CA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=435kn9jqxUgQ7kNvgHCAjwU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCTUGqd_OSBFp__pC0OZv7giObt3_3cTGcDMgt8RuCvEA&oe=6730B36E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a6Pe-OnBoAgQ7kNvgGznx_s&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBgrfiA104lCv4oCYD29r7UP1ytNUS9TgcLAPqYMesYEw&oe=67308A4F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, 