ams4-1.oculuscdn.com&oh=00_AYCwRTst-d6JnhxtXcnEt2HFBqBrGPmH6-TQ-_g8ApZAGA&oe=675D5ACA"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lE8FwXHiJTIQ7kNvgG4oNAQ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBP04AihhDBiEjwdS6onNMlD7JvMOtI8HjvRGrv_Jz6fw&oe=675D866E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "1539093960065384", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982581_1539093963398717_8886613911254029402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7d2x-7R0bBAQ7kNvgHJCnFs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYColmUo0K-hKqyydQP1bL8ooziHtlLWzgJ6NEmLsPdpjw&oe=675D62D2"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["escape", "room", "trivia", "puzzle", "mistero"], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}, {"images": {"nodes": [{"file_name": "mini_landscape_coverart.png", "id": "3787633628158330", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974796_3787633634824996_4791017203159274969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bWR5ch-4uVcQ7kNvgHHb-UR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC79M8Qk5JP9_Mu48kEvsj1x9WCVxzdNPb8sjfPxqkqJg&oe=675D6075"}, {"file_name": "square_coverart.png", "id": "1707528066702789", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KComxKIwvwsQ7kNvgECXRBx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAMJek51tGKndavBmfYun6LNJhXoJPNdN3iD4nji-YxZQ&oe=675D5A00"}, {"file_name": "PDP_art.png", "id": "1589730438299064", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003263_1589730441632397_3766788920031563801_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DpphG8fIpvcQ7kNvgEpi4lI&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCqpPF1m2y3bgeyFpokahshFub9aBGBuxvhoiC5SzuR-Q&oe=675D8420"}, {"file_name": "landscape_coverart.png", "id": "1495530294473366", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982715_1495530297806699_4884690371615260421_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zI0YCSwnvvUQ7kNvgEG9Ddh&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCdYMjgkoD7avgeVvUblZrx_vHOVE1Alh8A8tQ6zvBGhQ&oe=675D6107"}, {"file_name": "appIcon.png", "id": "949852623679480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974652_949852627012813_8337858694233804619_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvC697TitJMQ7kNvgGFG8qU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAE-lR5VRznCnTkuUeeh32wDNnMIFYonoNu53YEVxKjNw&oe=675D7001"}, {"file_name": "portrait_coverart.png", "id": "875039991054373", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982626_875039994387706_900327033248542707_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y_duizdWQaMQ7kNvgGP9o1a&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCPbkEqjb0VqK7Uyfxrak4FSw7Ig-E_TZaiT49PH1OxDg&oe=675D8C42"}, {"file_name": "logoTransparent.png", "id": "551559830957325", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982492_551559834290658_1182549563175349564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zXvinNwjhzAQ7kNvgEJK3e9&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCRPAkrj2EwhA_SC4jOV5hQ7vgHxrU2ubOLSerbvxkpjg&oe=675D80F2"}]}, "id": "595101106417330", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SVgSqTTgaHEQ7kNvgEr4k52&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBSt30t-BtYBBwYSDe9ROTbQRy3u2Tds6InKmKu3Bt_tQ&oe=675D7E6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-8AodC_u7TUQ7kNvgGB0khE&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAVjqFBZQ8scBj7W8lRBWn-IH630wHhh39UUuUgoc8Q8w&oe=675D7C02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vu-9fh-p8NQQ7kNvgGXJVNZ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAmCGMVi6-ik-25AIjyPkIu5sCYwW5VYTrRl8BdKpfN8Q&oe=675D6884"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=42C7WzZPhBIQ7kNvgE8JkGF&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBvnyMAcMI_9KSAFcEoVJqfrZqJpAq-QwXln9-18rhBfQ&oe=675D8562"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xGfrKIP3NDsQ7kNvgGryXo-&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCdQFY4oJLzFcK7aoSXDlHpOKQ-qFP5vI4JAsmgGDeK0w&oe=675D6F73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "897861905346420", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982672_897861908679753_3996777238831042692_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S2BttNdmEP0Q7kNvgGWYyvA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD97BNaeDlKQzZA86jUeVtVDxN86mnfijgQgzXtFQFGDA&oe=675D71EB"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["puzzle", "escape", "room", "trivia", "brainteaser"], "long_description": "# AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "Crack awesome puzzles around various boxes, and discover the history of the world's most popular inventions!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8681944438587156"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KComxKIwvwsQ7kNvgECXRBx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDA7rk4RswcFz40merm-Oyv4mPYlp3yrDcD1Hjd80mfIg&oe=675D5A00"}, "is_concep