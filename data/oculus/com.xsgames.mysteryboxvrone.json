ots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QhhsryMpLlgQ7kNvgGkHgv8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYAaBbheUCyS2UiIuOJ70oMMWx_Lx9ZF2HZAzoUDs4ShRQ&oe=66D4626A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vsd5IhIlMYAQ7kNvgHyebdB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYAQhPh8Lm4sqIcbbzWpb9Gj69Bb63efD_QdOHutEwwFFg&oe=66D46002"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNlHFMg5d30Q7kNvgGO3JyV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYCSvKFMtkCH6mPN0Jnh-oAikTm54bkBVxo9GCogEHLeGA&oe=66D44C84"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HihBJpN8pi4Q7kNvgHnnFRi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYAheNoVla9yIqHb77kwZ8HCCdvZDb6V1w5zibKLjlXoWA&oe=66D46962"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rgJ35XxCVEEQ7kNvgH4qYtx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYArsPVAix5WNQlIOinabyy7SiH5FjInB-z2Gv44K3bUcQ&oe=66D45373"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvlY3AfDAtYQ7kNvgGKl9Hs&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYDFNwJZKgfiHRV_ZBSIk_b_1GkM5T5K0Xw3EY31pSCWJg&oe=66D4526F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cT4i5u62nPUQ7kNvgEqVXU8&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuUHTCUTTTrJajGB1DBi_Dr&oh=00_AYDgk5L60hkoe3IWDdnY54gPYDKcovZ-KShm_VaNeccl2g&oe=66D44E65"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_27206