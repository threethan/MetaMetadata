71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SRispc79oFoQ7kNvgE6TbB0&_nc_ht=scontent.oculuscdn.com&oh=00_AYCvSi-sHCC6Io_KGBVu-EObjdArbwdy2U4IkJq6Q6yEHg&oe=66CB2EE2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vbBtzY444RkQ7kNvgHjorKZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvGhPKtq0NATby0zR7yeBZiBkwySkclaWrUXBP1ibqTQ&oe=66CB18F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B3M5cQPu0t4Q7kNvgEg2Z8z&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5CtkbzOU2ij2LHDSRYH_PJWibr7KoMum4OGVf8TVGeQ&oe=66CB17EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J52Izfy9YUwQ7kNvgFLX30x&_nc_ht=scontent.oculuscdn.com&oh=00_AYBgUBdZYYMsRaNhrMHGH0FApBvcAPD7NGIQqCj14bjK4Q&oe=66CB13E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aRH2OuncY20Q7kNvgGCVaOh&_nc_ht=scontent.oculuscdn.com&oh=00_AYAlb6jZsNV9lfreg5mlZ3h0cvpgtduA-PcK7c0ch9z1-Q&oe=66CB12CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7OJLPaW2ay8Q7kNvgG94qMY&_nc_ht=scontent.oculuscdn.com&oh=00_AYCLo8HMktuLgrq-FZbUVOUdsWXPZkDlzP0z1ON7MdNKRA&oe=66CB1E29"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uk4snV-oLy4Q7kNvgE-kz-Q&_nc_ht=scontent.oculuscdn.com&oh=00_AYAWrfR94SQ8dOVHQoapNxMRQKC3WRXaD-pm_aPGYpHQ_Q&oe=66CB084B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C_TaRW6q6dUQ7kNvgHbgJOg&_nc_ht=scontent.oculuscdn.com&oh=00_AYAC2gdESrkl1hMrlAt3C0X5OadHTc8PX-hxxGCZxQg