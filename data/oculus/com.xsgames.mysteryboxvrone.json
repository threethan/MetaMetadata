71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NIZY0MEbas8Q7kNvgGZkpV4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVWo_EPQDZuJbtOoa4G63NDlzf-fj8JJnFW9ojdm2G1w&oe=66D85DE2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O-iDPbcqqkEQ7kNvgEg3qFC&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7wAXZLepXboU0fTWMRq3lZiegQOd3flnClrbhnnT_BQ&oe=66D847F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oNWNanCkQh4Q7kNvgEY4aYJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYA-M2Jn7bBMOLa4M2_8FUMem-kfrmfjJNk792LI_BGdUQ&oe=66D846EF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8AUY4DQG8E8Q7kNvgEtA7BC&_nc_ht=scontent.oculuscdn.com&oh=00_AYBR_hfAQW4oti8xze586osz5Nl8_rrxCLJR814CQz4H_w&oe=66D842E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rf4uPG7MOUkQ7kNvgFKZgGd&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhsasbNnYneC0hORxT8t3nv-9SL3RsMkqJcnbCRnVkkQ&oe=66D841CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VjTrjr4LZgoQ7kNvgHyYXDW&_nc_ht=scontent.oculuscdn.com&oh=00_AYD6ur2VWfh60O69yo6GJIrYd1Fgf1crQnOQ-r9TFyyk4A&oe=66D84D29"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C3plIR6FGRYQ7kNvgF_sBTn&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8BUb6FZpoxGcMPfo3QqUPefS44aVkeWoBsUWOB4lTyw&oe=66D8374B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TmwS7izAYOMQ7kNvgEJSOt3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDJdSnCFJ37D8P_qPoZBpy6oAnFjaS21xZTaULPo2x