F6oNGye598V0wwSqtXJlIqR6h0INADBd7B5QO2w&oe=670A77F1"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BwtaVaf9yvoQ7kNvgEjzl-M&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCV7MtWxcZPPjbY3mouH_y5-lx3UWcu5uCwDeYyiuvDPw&oe=670A4C4A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dH_jp70lmHMQ7kNvgFZY32L&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC55M4Oi58J1zwcSvXUY78Lszvr4ZRSw--onR8loKAisw&oe=670A77EE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XT38xT6xel0Q7kNvgHccqx2&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCOb48K3nmDfEpWLsW4cKEj4p3pXN2Q-684XHYuhxmgxQ&oe=670A4ECF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75630190_1006934984091677_254542230474638094_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-xrQDsOK8AQ7kNvgENa8rl&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCflfOt087vZwuiezNIZ2vygXXwebt-hTx-UiLdp5-h9g&oe=670A5C8D"}, "is_concept": false, "is_test": false, "