32_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hC4B-A6s2UcQ7kNvgE1Pej3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPYq_gw0gaGQLns9QcIeAZuJTE0IxAQvzjuJMSS9sJ7g&oe=672379DD"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SqQ8vkJYbsYQ7kNvgHO-rEV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJ1qU6XhwQRJYgs2S3bmkvriLIrrCsvQdSQsFCgZ5iUw&oe=67236286"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MTKUN__2s5cQ7kNvgFpxj45&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbekJzHs3_3sDiXYEgf14aMYDbXzsqVigw07CBKCB9Vw&oe=67237EAE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v8J4-iaV28sQ7kNvgHj_AhD&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANu1MWnvVipj88XE4TbmP9pGEo3FJyIVA2XHsG-GXDrA&oe=67237C6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MzqIkA_krmMQ7kNvgG7kn8W&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYhZGK3JmLtxX15v_BikUze9w27VYXA4iRy31OiesGkQ&oe=67237A02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0fEBGiYxujsQ7kNvgHoYtlf&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD6NUkM7ecGHPoe2hg7IJiDf5OqdK1uGxtkxZaT19IaYQ&oe=67236684"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=41-L32bPFNkQ7kNvgHoTzW_&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA_Jq5-YD_jiC09AhJlqCjqwxITIolO84lquWBGUGVd8A&oe=67238362"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fpf0Xmrin0sQ7kNvgFG3xPr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDYYIAB00Y2SvQSWeHwd2-DvqPXtMEPvohkts5RDa1NLA&oe=67236D73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6td63JFBanAQ7kNvgHBHQtj&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC1CO6f9l2yCTKXVzs4uwtR_EEOQAaDSDKxXwFYXVEAFQ&oe=67236C6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=igSDW2rSZB8Q7kNvgGXF-Zt&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsbq-Z90I148UIuxdadWfQqQLqJDsmAsGaXkM9LSiOAg&oe=67236865"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ga-PKtLQrScQ7kNvgE24YO-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCNNCTFlEPZZYre0p5h_ziwl9R9Qj1bWEXLcNeuMYCV3A&oe=6723674D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dhlonav3cKAQ7kNvgEY061W&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD5muYbCjyOQ8ucO3re2f4E00bXuoelMMJqMiLHaAor7Q&oe=672372A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WhEnIB8vNCAQ7kNvgFCRsRK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAYJQ1qdWK6a0zxQu6fkir3g3ru_EQZknrYJzM4GkBBgQ&oe=67235CCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oc