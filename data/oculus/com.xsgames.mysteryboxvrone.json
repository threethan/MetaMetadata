n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o5gJVVNgIo0Q7kNvgGUR_JM&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBDi5UoqwtpiMwRw8Zaat16kTYyi10foNrxLB0QfShO1w&oe=670BBF02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YvOTL4n09HcQ7kNvgG0exL1&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAA9K1EJjbZO-ORlydocU2D20Akc4sTwF22KWbLMWDYqw&oe=670BAB84"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fgrJ141ViGIQ7kNvgFizktC&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAnOqpzxFDh6HIAb-fTt0029YR8K8QK8E07S0QZi5WaoA&oe=670BC862"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fSTPVIMraRUQ7kNvgFLTOx9&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCjPz8Fmxq_4AUGgb4l2tSvwdnaRAw0r0V-Ca_Ubw2fIw&oe=670BB273"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pWZJ4wC1slcQ7kNvgH3U3F_&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD7CB0BKOkMhGbG3GPIHNlIJFvOQmPsbclKOGqySmxYXw&oe=670BB16F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2LxVgn3MotwQ7kNvgF5TY7e&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCSM07Z0VzzHRSM3OOJTqN2QubHQ0hz-C2A19sthZl6dA&oe=670BAD65"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yNBSIoKALnQQ7kNvgEwqFIY&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBROm1ZlbrRA6Aa_T1Cw4cMeC4nDk9BHwZH_OVIgX3g6w&oe=670BAC4D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aJbmiTlckm8Q7kNvgEZdQxj&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYC-eu3-Z4XpY5N_PYHyJcYvL8FIG_-73S6nOVPunt4gGg&oe=670BB7A9"}, {"file_name": "3898264