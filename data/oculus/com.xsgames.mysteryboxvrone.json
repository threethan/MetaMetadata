kNvgELMGvA&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCeU3QstfI4jNvDg8NqiHkftY5ZyBJErYf8h0jV49mgLg&oe=67026188"}, {"file_name": "2.png", "id": "2203761473315962", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75469623_2203761476649295_9180026026436178997_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMGb20luzUgQ7kNvgGuxixM&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAbs8mhbNkz3GY6D7PiCykwlguN-jRZugI3IB1dKOK0XA&oe=67028EF1"}, {"file_name": "5.png", "id": "1600206790893068", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974920_1600206794226401_7626143159008067194_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=whizWtu6P48Q7kNvgG3uQ10&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBnaC-yrLav0t8mMdY3fVcBuCITn5pufv2qpZsbAo8P3Q&oe=6702634A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wR8NGAdI68IQ7kNvgGWyfWt&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC6q9g7-v3FG1Y7F1S1rwADmEnmK2sL6X18cO32XUIv5Q&oe=67028EEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "827399829365065", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75262743_827399832698398_2324097237178561690_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=27Tq-7Q19LQQ7kNvgHU-B7P&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDs8tp24LFepdT-cI39deFwZLW5-LaoCryewJTLVwZ1QA&oe=670265CF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": null, "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8009010552547218"}}]}, "s