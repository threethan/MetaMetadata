32_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3cghq4xHrwQ7kNvgGrrlD0&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBTcWrzxirRoJmq56a793UL3I9disXTf1ORt85j8zuqZA&oe=671104DD"}, {"file_name": "ml.png", "id": "502579852256353", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39036644_502579858923019_3842705229132857953_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VXQmW3yB0eYQ7kNvgGFqsoe&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC5l6Qlslg7cnImRvAarH6c-xuCyjj2S3o9E2a5gwclRA&oe=6710ED86"}, {"file_name": "landscape.png", "id": "465213706424419", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003266_465213709757752_680111565771229398_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=krBiXeJ6PNwQ7kNvgESDMbf&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCSo6McNVPL65JP6ZIPhiSLINrtxDdl_utHQjErO1bZNg&oe=671109AE"}]}, "id": "695307962768721", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6jefcV2WRAQ7kNvgHya_AF&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAjd3HwUlK9wkTQ9s9PCYr8BAkTxbp-Mb9CoESx0naotA&oe=6711076A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2XcG48Q5AxoQ7kNvgGriQpv&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDjnqLFIIHZqWQCy3joJBnR-e12yRC7vNKp51MY9mF1_A&oe=67110502"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6Ks6vUThhHwQ7kNvgEyZ6xG&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCKE6God3J4ORN0Vivz69pUhWQRzpEK6C2AI3uQ2V5shQ&oe=6710F184"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KXT2zwdJkOgQ7kNvgEg3RcN&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAMiUTzIdsRj58T7OgFsHV0iZimRT0pJIX7RsvRaIM_lQ&oe=67110E62"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OsZfkrlSb2oQ7kNvgFqLQV_&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBD1cEZvchNZ3gqenm5f6BmEr2ssT5jDBEIbdshFBwoNQ&oe=6710F873"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dilzsAfVBXQQ7kNvgExpYsp&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCi4AnL-Gs2r1UdfcLErB3yyBBJ9TnWlc6sw165fmIRSw&oe=6710F76F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6ocwpCwrqJkQ7kNvgGdv-ci&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDsUUupkPIH6UI1tx5BCjnM_O6HOhU8r0NutYrkK_lKzA&oe=6710F365"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jEkVhigWJGgQ7kNvgGSMoTj&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCSXGsqoxCbZmqEjg0tPtJqhpCY8TSCGADF1IyhQL3-EA&oe=6710F24D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1e9Xb5KFYSMQ7kNvgEliiMe&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDYiWEkKiOwvjxihhjPfo22TXgCSegZVVAWkFBtrmsthA&oe=6710FDA9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8svkcR0ABzYQ7kNvgF44lyd&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC6JoviUrkvxJxb42rlvX8Uexh_v8x-sWiKkVla8rZXrg&oe=6710E7CB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sea1-1.oc