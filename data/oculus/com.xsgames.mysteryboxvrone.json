71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HihBJpN8pi4Q7kNvgHRxgJM&_nc_ht=scontent.oculuscdn.com&oh=00_AYCrn7zHVBGOu1EBWtasr0QVZMeEQuzBrAyWKRO98NKs6Q&oe=66D1C662"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OvZj5T0JH1IQ7kNvgF10GB8&_nc_ht=scontent.oculuscdn.com&oh=00_AYB99uBU4WYBupdA4g0FfgbBf3eEKTbKWUKAxJrSW00kPA&oe=66D1B073"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mvlY3AfDAtYQ7kNvgEzBQu8&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2dTSheKl9LBW8ws0hdcg8nZ51DFkPccjDBCj73AyChw&oe=66D1AF6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t5bIIvti268Q7kNvgHYi8Bl&_nc_ht=scontent.oculuscdn.com&oh=00_AYCy9pWrGLJPbenzdoeStkcuS--pJSdZe5A8aoQUy_VUmg&oe=66D1AB65"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BBdnk3FqO1QQ7kNvgEJFpt1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqodzmPsWywsrIAiQMrkAKQ2dkZGdcrSPtGxnbVPVpoQ&oe=66D1AA4D"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Omy0fmvKD48Q7kNvgGn8TWG&_nc_ht=scontent.oculuscdn.com&oh=00_AYAThaVPCLrrg5stEoN_Aqsi0E0jg7WqEMBJiF1dHOp42w&oe=66D1B5A9"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UdGT84-UWpsQ7kNvgH5jgUD&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVWOltWbRjM24tiqrpU9uLbpV9QVj3qbeLZI81PgVeMg&oe=66D19FCB"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_y1iVCkYlpsQ7kNvgFEozpj&_nc_ht=scontent.oculuscdn.com&oh=00_AYBux4bN5uxSHiv9xEobwg1PVRMdUgIVzoK0gIwzv7A