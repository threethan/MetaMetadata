nc_sid=6e7a0a&_nc_ohc=6BSKLVUMY1gQ7kNvgHWF2WY&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBcvjBclPZZj29Uxg3jrtUuUdPOxs6W01g-ZaMM5Nm62Q&oe=67164D6A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eXtE3sFYWewQ7kNvgHoV1M1&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD9KuQ_6QShra78XNadslWGAe5JV4vkxfQPGOwCA-8xGw&oe=67164B02"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SEvsNjXlXNAQ7kNvgGin7Ev&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYD_Mh06IFUnw-t1oAhJVSxDl5VixJp9ZCqJsoI2pJeEOg&oe=67163784"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TGaH-zH0VykQ7kNvgGe__pG&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBtocM0NU8LQyjkvxF9fY0XP9KckB--4_MY37mIlKGzOA&oe=67165462"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jKtx6S9uEmcQ7kNvgEIK3Y9&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCE3I_Grby-1aSojZ8esUGj7mTGAU7cv_svKK3PczMGaQ&oe=67163E73"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xb4KsqxAfKIQ7kNvgFkyaCI&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCaL2nW-V4a_OIRN-Twc-5DzrdmFVWVoydQoeczmTihqw&oe=67163D6F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CDD2Af0JwNMQ7kNvgGJq7IR&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYD2lWUdCnpBRFsAiqMPvYmMiygeVb4VbDg6Dn_ajLcD0g&oe=67163965"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fDPbRYiACvcQ7kNvgEegoev&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCmLxeHVMa0XtsZ5g3FqVcJKSs31cVMYEWgePAOJhtRxg&oe=6716384D"}, {"file_name": "$RQ3SN6U.p