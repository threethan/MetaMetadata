ams4-1.oculuscdn.com&oh=00_AYBQ02xAXd8FcYlP27VN3PiRQyrDapOABWgxIuneQPr4Dg&oe=6780F34A"}, {"file_name": "3.png", "id": "1053463469622332", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395599_1053463472955665_4671093965273907425_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OdzmrBzXRfAQ7kNvgEGpxVp&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCXn9b2iXmJ_DZ-W5v1hPK0o7AR3-lithElIs2BsHL88w&oe=67811EEE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "1539093960065384", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982581_1539093963398717_8886613911254029402_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xFzE18ghq-MQ7kNvgFeydrs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDrugSxxfw7Caw4MooRfxzdcthI7pMRx4_meqNvQaD-og&oe=6780FB52"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["escape", "room", "trivia", "puzzle", "mistero"], "long_description": "# UN'ESPERIENZA DI GIOCO UNICA\nInteragisci con oggetti, maniglie, pulsanti e ruote su ciascun lato. Risolvi gli enigmi e raccogli le tessere del puzzle nascoste su un lato casuale delle scatole.\n\n# SEMBRA COS\u00cc REALE!\nNon sarai in grado di confrontare la realt\u00e0 con la finzione.\n\n\n# SCOPRI LE INVENZIONI\nUna volta sbloccate tutte le 8 caselle di un pacchetto livelli, puoi comporre un puzzle e scoprire una breve storia di un'invenzione.\n\n\n# PENSA FUORI DAGLI SCHEMI\nNon \u00e8 sempre facile fuggire dalla stanza, quindi usa tutto il tuo QI per risolvere gli enigmi. C'\u00e8 una logica dietro a tutti, anche dove sembra che non lo sia!\n\n# AUDIO D'ATMOSFERA\nGioca con le cuffie per immergerti in questa fantastica avventura.\n\n# ]SUGGERIMENTI DISPONIBILI\nSei rimasto bloccato su qualche enigma? Nessun problema, puoi comunque ricevere un suggerimento utile! Puoi anche contattarmi nel caso in cui davvero non riesci a risolvere un indovinello, sar\u00f2 felice di aiutarti ;)\n\n\n# SUPPORTO MULTILINGUA\nDisponibile in inglese, francese, italiano, tedesco, spagnolo, russo e giapponese.\n\nLa lingua del gioco cambier\u00e0 automaticamente in base alle impostazioni della lingua del tuo dispositivo", "short_description": "Un gioco VR di escape room in cui devi risolvere enigmi intriganti per aprire scatole e scoprire simpatiche storie su invenzioni popolari!"}, {"images": {"nodes": [{"file_name": "mini_landscape_coverart.png", "id": "3787633628158330", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974796_3787633634824996_4791017203159274969_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mD_RUryh4X8Q7kNvgEMXV0T&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDoc5BO0sv4kUE8hUXdDjbcWAEfuEd6-GRStusMS26PMw&oe=6780F8F5"}, {"file_name": "square_coverart.png", "id": "1707528066702789", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gckeEKi7z-wQ7kNvgFjFApW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAwVBU8umzjgr_7KUOoP0y5jCCOpBaOvfPZLwuL4fbR8A&oe=6780F280"}, {"file_name": "PDP_art.png", "id": "1589730438299064", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003263_1589730441632397_3766788920031563801_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NQHAxQKv29QQ7kNvgEErU3j&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDtxwSRmAdG8UhknTIxv9_XC4kOoiSX5dYmv26Xwgljow&oe=67811CA0"}, {"file_name": "landscape_coverart.png", "id": "1495530294473366", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982715_1495530297806699_4884690371615260421_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zln-c7PuqRkQ7kNvgHR07Q2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDpeZ-HeNJULPdKoVAgmP5I0we0DIpyGO6ce5pURGX6Ug&oe=6780F987"}, {"file_name": "appIcon.png", "id": "949852623679480", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974652_949852627012813_8337858694233804619_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=COkumA0t_PgQ7kNvgGM4Y8m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBhT-DSje7-er-Zsmmns6iW92ZuX26CoAMltu_iCGqUmg&oe=67810881"}, {"file_name": "portrait_coverart.png", "id": "875039991054373", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982626_875039994387706_900327033248542707_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JvbMHZKUVrAQ7kNvgF3BE3S&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD-5MGorrSN_XiYx3SHbHh43XU8jWvJWz6PkaniKcl4Yw&oe=6780EC82"}, {"file_name": "logoTransparent.png", "id": "551559830957325", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982492_551559834290658_1182549563175349564_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X2GtAtTSj-YQ7kNvgEubvGv&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCjg1ekxsSStJ5OfLkZENDVQ5OkP7V_J5hoaOCWxwZlBQ&oe=67811972"}]}, "id": "595101106417330", "locale": "en_US", "screenshots": [{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=66pj807RO5MQ7kNvgGv263h&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAZgGwwY1zo3son8bsOAl9SCqEZTkSGOjxvxAma13ui5A&oe=678116EA"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AYMxAS6C68wQ7kNvgG5HpKA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCCYNw9jpEE_OvmsTjE2IwDhz8DXr6650MG1VZIKoImRA&oe=67811482"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_NlatASHXfEQ7kNvgEb28k8&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAgb5NhFJDiVeqElDnX9-G9_AXHuC0mgScLZbE5kAOOZA&oe=67810104"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R7SBvOiuHJ0Q7kNvgEtZLYY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBHTIPR9-e4B9jLDWSTZdU0plG8TGdTWh7ihoo2qEk_BQ&oe=67811DE2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e5wHgHwi7dIQ7kNvgFNsAJl&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAXXvRRkfppAWhsvLCnJf05vIRQvdXkAiyO5RIgQ_V8Yg&oe=678107F3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_coverart.png", "id": "897861905346420", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982672_897861908679753_3996777238831042692_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DzSPh71BxfQQ7kNvgFrTCq0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCMBFAqnYfK-nNdPrSIb4_mo91ApHbsIKsyKirZ8uVT9A&oe=67810A6B"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": ["puzzle", "escape", "room", "trivia", "brainteaser"], "long_description": "# AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "Crack awesome puzzles around various boxes, and discover the history of the world's most popular inventions!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://xsgames.co/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "XSGames", "support_website_url": "https://xsgames.co/", "website_url": "https://xsgames.co/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "it", "ru", "de", "fr", "ja", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8681944438587156"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035329_1707528070036122_8050080456656857270_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gckeEKi7z-wQ7kNvgFjFApW&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCdqfnj1FWI93IxBtSBjRvXjJUlKXJwI_MY9scNbLQGcQ&oe=6780F280"}, "is_concep