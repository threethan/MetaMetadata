[{"file_name": "4.png", "id": "964615488773393", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982581_964615495440059_2784752763184915334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DPrnTNyHPhkQ7kNvgHQbiOe&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYBCVipvFdvgcQ5-pQt19FBfuvT6UvePd2epRdC4WvZEoQ&oe=66F4066A"}, {"file_name": "2.png", "id": "1943374952743027", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974836_1943374956076360_2484593514118294358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WIRi6gVEdmIQ7kNvgHaQ7ej&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYAbqnjHksis-TDO0NT1aoWXl08kSP1deot9vWBV1kYmYw&oe=66F40402"}, {"file_name": "1.png", "id": "445060168517426", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462964_445060171850759_5520915542327767111_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gajwz_RbCUAQ7kNvgH01aB7&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYARSw6xjhxXJDFMTAE5AKv6JBOqbpGwASlAlS_YOXDzSQ&oe=66F3F084"}, {"file_name": "5.png", "id": "467916352871409", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003282_467916356204742_1871921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UGkqbV64SIoQ7kNvgHjbF7v&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYD6heducIC6DNo_1fJ6MrMXHK6B0B7_dxVX_Ok7TC0Mrg&oe=66F40D62"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tEzNt1I9b7YQ7kNvgFr6KbU&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYB7Pcb_r_KodqRSB5Evmrs5VI-qiP7ODTdTa8hp5B0q8w&oe=66F3F773"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M0MInr-PIg0Q7kNvgG8YK0r&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYDD2a7JDmLYh36pZygrBMGxS03DjqVZQni8VuVvpq_QIw&oe=66F3F66F"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j3m0G_lh8bMQ7kNvgH2ZYpF&_nc_ht=scontent.oculuscdn.com&_nc_gid=A2i0mH1Y-j_VC4AAiZstECq&oh=00_AYDQmgivqdCh90UEtrQZBkOY7DudKkX2RBS6JMPXeJ9qDg&oe=66F3F265"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_27206954847