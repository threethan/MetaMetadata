71921057092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7-fMHhXz1kIQ7kNvgEvx5z5&_nc_ht=scontent.oculuscdn.com&oh=00_AYCYglSSS4cZsUMgxyv057_dHV-hEiYqSTFmxplhrJPN0Q&oe=66D074E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OvZj5T0JH1IQ7kNvgHfal81&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoVSIqD2ihflMRXGRPUrKpaR4ajEtYEMVokPbmNCVxTg&oe=66D05EF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M37GXSs_mUoQ7kNvgG6WY6j&_nc_ht=scontent.oculuscdn.com&oh=00_AYC5D-en4VVdJ8W0_7G69jcdAQ7hiICbAZqYUi5-PT45xw&oe=66D05DEF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t5bIIvti268Q7kNvgE3YOZ_&_nc_ht=scontent.oculuscdn.com&oh=00_AYDFREJCqrVbat8ssgj2_HpyEiWIQvmFUxz6mAJOX3U6BQ&oe=66D059E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BBdnk3FqO1QQ7kNvgHX4ag5&_nc_ht=scontent.oculuscdn.com&oh=00_AYDRr8XyIc3VViIsDoVnqsBKrI69miWSsELKUow6viAjeg&oe=66D058CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Omy0fmvKD48Q7kNvgE-AihF&_nc_ht=scontent.oculuscdn.com&oh=00_AYCaxn4Yxir8oN49MNLvMkyXPk71Vt0n3weUwV8Laz5TWg&oe=66D06429"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UdGT84-UWpsQ7kNvgFKaKhH&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEOmTJkBUDMg9lh7NY_HqOBcqjVsPW3Cq3kDLGhTPqsw&oe=66D04E4B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_y1iVCkYlpsQ7kNvgFdIZh-&_nc_ht=scontent.oculuscdn.com&oh=00_AYCAa-ETPAAELpSFknrXVBeFTPHrWhKmpi8TXF8qGnT