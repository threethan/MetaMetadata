57092171900_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L8iTCvTGvlMQ7kNvgE4uz-u&_nc_ht=scontent.oculuscdn.com&oh=00_AYDexJi2AmJdYGlUT0j6u52BXCpwQ0Vc5w5udexwaXXDPQ&oe=66FAA4E2"}, {"file_name": "3.png", "id": "1934382610375855", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974473_1934382613709188_7156337812617042679_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NnxzZH0sP7cQ7kNvgHgOHqU&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhNIL8gWrsccZpTTtuddy4TCYgkv0_H4NzaviXtT8Reg&oe=66FA8EF3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape.png", "id": "1524760081483769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974531_1524760084817102_6497712644828891067_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b80v2svgAu8Q7kNvgEhKo_J&_nc_ht=scontent.oculuscdn.com&oh=00_AYCy2gVbqFKcePiCMk2r_hSW_Z_k07UzxVlGYkKffKC0xg&oe=66FA8DEF"}, "display_name": "Mystery Box VR: Hidden Secrets", "keywords": [], "long_description": " AN IMMERSIVE VR PUZZLE EXPERIENCE\nInteract with objects, handles, buttons, and wheels on each side. Crack enigmas and collect hidden puzzle tiles on a random side of the boxes.\n\nYou won't be able to compare reality with fiction.\n\n# DISCOVER INVENTIONS\nOnce you unlock all 8 boxes of a Level Pack, you can compose a puzzle and discover a brief history of an invention.\n\nIt's not always easy to escape the room, so use all your IQ to crack the riddles. There's a logic behind all of them, even where it seems it's not!\n\n# IMMERSIVE SOUNDTRACK\nPlay the game with your headphones to get immersed in this amazing adventure.\n\n# HINTS\nGot stuck on some enigma? No worries, you can still get a helpful hint! You can also get in touch with me in case you really can't make it through a riddle, I'll be glad to help ;)\n\n# MULTILANGUAGE\nAvailable in English, French, Italian, German, Spanish, Russian, and Japanese.\n\nThe game language will change automatically based on the language settings of your device", "short_description": "A VR escape room game where you have to solve intriguing riddles to open boxes and discover nice stories about popular inventions!"}, {"images": {"nodes": [{"file_name": "$R36BSY5.png", "id": "3678762505771822", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031430_3678762509105155_2151975047074617165_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wmjAiVjsKX0Q7kNvgEMUa_1&_nc_ht=scontent.oculuscdn.com&oh=00_AYAh5dPshYcdJGX5WOsru-n3msfwRU6jGtKQ2Duw5kZF4g&oe=66FA89E5"}, {"file_name": "$R81V725.png", "id": "2720695481426567", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75262743_2720695484759900_604086922326600035_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I-dv7PP4N6QQ7kNvgFi1VU4&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgdkkPpFwX8W3kKIRu_Yzi-HNkHi3hxe98jKOy_j_jGQ&oe=66FA88CD"}, {"file_name": "$RQ3SN6U.png", "id": "1552311425628973", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982519_1552311428962306_1218130395049083834_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rxyUiNn5Ha4Q7kNvgHV7lIX&_nc_ht=scontent.oculuscdn.com&oh=00_AYAoNt0hAtYmMnaVq8YKH96J-J48vB_Tq5Dma4CBJjHCLw&oe=66FA9429"}, {"file_name": "38982645_1000853181732648_5055517427829171192_n.png", "id": "1043990680394008", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031625_1043990683727341_3557431131423146005_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hSauA8i2VwEQ7kNvgHq0pA7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCXKcsbUKoUkLihrPDl-RTk-QvMegoc2MYH4fUGUMGJjg&oe=66FA7E4B"}, {"file_name": "heroCover.png", "id": "806897208225124", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031463_806897211558457_6079827820297623902_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_HL5fSCw1ngQ7kNvgGdXMGU&_nc_ht=scontent.oculuscdn.com&oh=00_AYDCILAsGuO_i-uXqFXo1dNJMxAtRxp_kNCWw1-TEj_DXA&oe