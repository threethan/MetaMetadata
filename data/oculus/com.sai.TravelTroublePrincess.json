n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mw4RcGh0vjsQ7kNvgHCduHz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAcJkcRFIln_J9VoxZvFhgBGwAn8GQMtqqFDS2rAuNj9w&oe=67348E67"}, {"file_name": "SC5.png", "id": "1784506765249116", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974694_1784506768582449_6895755964083707435_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RGRQe2TG8ccQ7kNvgH2FlfR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYByD9TF6kDxbpSia-7fgk8RSeitx-8jhFmvrFRocjsG9g&oe=67348193"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "samune.png", "id": "5379994402061102", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974694_5379994405394435_5538481077284453792_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wP4hmzdcioYQ7kNvgEkFqhA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC0Al2nO-jIudz9o-0j1O1o0_6NJKwS1nfbrfksrca_SQ&oe=67347EB7"}, "display_name": "Travel Trouble Princess", "keywords": [], "long_description": "\n-------------------------------------------------\nOperation Description\n\nA Button :\nAsk your princess to jump.\n\nSword in the right hand :\nSwinging a sword against a monster to reduce the monster's HP.\n\n\nLeft-hand umbrella :\n\nBy covering the princess with the shadow of the umbrella\nthe princess's health will not be depleted.\n\n-----------------------------------------------------------------------\nStory\n\nOnce upon a time,\nthere was a kind-hearted princess.\nShe was heartbroken by the world's ongoing war with monsters.\n\nOne day, she decides to go to the temple of the God of Creation\nat the end of the world to pray for peace.\n\nYou are the knight who protects her.\nUse your sword to drive away monsters along the way, and\nUse your umbrella to provide her with shade.", "short_description": "Wield your sword.\nand guide the princess on her journey!\n\nWith the sword in her right hand, she drives away her enemies, and\nThe left-hand umbrella provides shade and keeps the princess from losing energy.\nA new type of VR run game is now available!\n\nWhether or not the princess can make it safely through her journey is\ndepends on your two hands!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2022/07/travel-trouble-princess.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2022/07/about-travel-trouble-princess.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "889281508414867"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3381828945375339"}]}, "baseline_offer": {"id": "3381828945375339"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1658854800, "status": "PUBLISHED", "id": "3381828945375339"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5517690534918230", "version": "1.1"}, "id": "157078366587299", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4545932035427423", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "5517