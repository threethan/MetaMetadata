9oH3N&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCrmA1vRNvX9ivjrJg62qlx6EPWy3Hum4SkaCOOb7x1Rg&oe=6708F449"}, {"file_name": "SC4.png", "id": "3324288601139765", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974714_3324288604473098_3091196282987557911_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bzn0Db4zia0Q7kNvgFJB5dx&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4k1wu-_YPDgtbofQFGE5HQ1bSdeBEP-VpRzCV8gYlNQ&oe=67090CE7"}, {"file_name": "SC5.png", "id": "1784506765249116", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974694_1784506768582449_6895755964083707435_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vfaPhAkr7DYQ7kNvgH0aW0u&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDsVtIHNJa0PdbxqInNiRnWUJSW9wn0vEzUonwoTPFmDA&oe=67090013"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "samune.png", "id": "5379994402061102", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974694_5379994405394435_5538481077284453792_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k6ZTW47GungQ7kNvgECwrLa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAV7hRStFp_dUjlFER_zw3IQPtISgiEc09JQepvUCFTw&oe=6708FD37"}, "display_name": "Travel Trouble Princess", "keywords": ["Princess", "Journey", "RUN", "Cute", "Adventure"], "long_description": "\n-------------------------------------------------\nOperation Description\n\nA Button :\nAsk your princess to jump.\n\nSword in the right hand :\nSwinging a sword against a monster to reduce the monster's HP.\n\n\nLeft-hand umbrella :\n\nBy covering the princess with the shadow of the umbrella\nthe princess's health will not be depleted.\n\n-----------------------------------------------------------------------\nStory\n\nOnce upon a time,\nthere was a kind-hearted princess.\nShe was heartbroken by the world's ongoing war with monsters.\n\nOne day, she decides to go to the temple of the God of Creation\nat the end of the world to pray for peace.\n\nYou are the knight who protects her.\nUse your sword to drive away monsters along the way, and\nUse your umbrella to provide her with shade.", "short_description": "Wield your sword.\nand guide the princess on her journey!\n\nWith the sword in her right hand, she drives away her enemies, and\nThe left-hand umbrella provides shade and keeps the princess from losing energy.\nA new type of VR run game is now available!\n\nWhether or not the princess can make it safely through her journey is\ndepends on your two hands!"}, {"images": {"nodes": []}, "id": "472538309033365", "locale": "ja_JP", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Travel Trouble Princess", "keywords": ["Journey", "Cute", "RUN", "Adventure", "\u304a\u59eb\u69d8"], "long_description": "\u64cd\u4f5c\u8aac\u660e\n\nA\u30dc\u30bf\u30f3:\n\u304a\u59eb\u3055\u307e\u306b\u30b8\u30e3\u30f3\u30d7\u3092\u3057\u3066\u3082\u3089\u3046\n\n\u53f3\u624b\u306e\u5263:\n\u30e2\u30f3\u30b9\u30bf\u30fc\u306b\u5bfe\u3057\u3066\u5263\u3092\u632f\u308b\u3046\u3053\u3068\u3067\n\u30e2\u30f3\u30b9\u30bf\u30fc\u306eHP\u3092\u6e1b\u3089\u3059\u3053\u3068\u304c\u3067\u304d\u308b\n\n\u5de6\u624b\u306e\u5098:\n\u304a\u59eb\u3055\u307e\u3092\u5098\u306e\u5f71\u3067\u8986\u3046\u3053\u3068\u3067\n\u304a\u59eb\u69d8\u306e\u4f53\u529b\u304c\u6e1b\u3089\u306a\u3044\u3088\u3046\u306b\u3067\u304d\u308b\n\n------------------------------------------------------\nStory\n\n\u3080\u304b\u3057\u3080\u304b\u3057\u3001\n\u3042\u308b\u3068\u3053\u308d\u306b\u5fc3\u512a\u3057\u3044\u304a\u59eb\u3055\u307e\u304c\u3044\u307e\u3057\u305f\u3002\n\n\u5f7c\u5973\u306f\u9b54\u7269\u3068\u306e\u4e89\u3044\u304c\u7d9a\u304f\u3053\u306e\u4e16\u754c\u306b\u3001\n\u3068\u3066\u3082\u5fc3\u3092\u75db\u3081\u3066\u3044\u307e\u3057\u305f\u3002\n\n\n\n\u3042\u308b\u65e5\u3001\n\u5f7c\u5973\u306f\u6c7a\u610f\u3057\u307e\u3059\u3002\n\n\u4e16\u754c\u306e\u679c\u3066\u306b\u3042\u308b\u5275\u6210\u795e\u306e\u795e\u6bbf\u306b\u304a\u3082\u3080\u304d\u3001\n\u4e16\u754c\u306e\u5e73\u548c\u3092\u7948\u308b\u3053\u3068\u3092\n\n\n\u3000\u3000\u3042\u306a\u305f\u306f\u304a\u59eb\u3055\u307e\u3092\u5b88\u308b\u9a0e\u58eb\u3067\u3059\u3002\n\n\u5263\u3067\u30e2\u30f3\u30b9\u30bf\u30fc\u3092\u8ffd\u3044\u6255\u3044\u3001\n\u5098\u3067\u65e5\u9670\u3092\u4f5c\u3063\u3066\u3042\u3052\u306a\u304c\u3089\u3001\n\u5f7c\u5973\u306e\u9053\u4e2d\u3092\u5b88\u3063\u3066\u4e0a\u3052\u3066\u304f\u3060\u3055\u3044", "short_description": "\u3042\u306a\u305f\u306e\u5263\u3092\u632f\u308a\n\u304a\u59eb\u3055\u307e\u306e\u65c5\u8def\u3092\u5c0e\u3053\u3046\uff01\n\n\u53f3\u624b\u306e\u5263\u3067\u6575\u3092\u8ffd\u3044\u6255\u3044\u3001\n\u5de6\u624b\u306e\u5098\u3067\u65e5\u9670\u3092\u4f5c\u308a\u304a\u59eb\u3055\u307e\u306e\u4f53\u529b\u304c\u6e1b\u3089\u306a\u3044\u3088\u3046\u306b\u3057\u3066\u3044\u304f\u3001\n\u65b0\u611f\u899a\u306eVR\u30e9\u30f3\u30b2\u30fc\u30e0\u304c\u767b\u5834!\n\n\u304a\u59eb\u3055\u307e\u304c\u7121\u4e8b\u306b\u65c5\u3092\u9032\u3081\u308b\u3053\u3068\u304c\u3067\u304d\u308b\u304b\u306f\u3001\n\u3042\u306a\u305f\u306e\u4e21\u306e\u624b\u306b\u304b\u304b\u3063\u3066\u3044\u307e\u3059\uff01"}]}, "developer_name": null, "developer_privacy_policy_url": "https://saivrgames.blogspot.com/2022/07/travel-trouble-princess.html", "developer_terms_of_service_url": null, "publisher_name": "MaSaitoh", "support_website_url": null, "website_url": "https://saivrgames.blogspot.com/2022/07/about-travel-trouble-princess.html", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_p