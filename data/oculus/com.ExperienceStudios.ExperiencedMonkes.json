-lhr8-2.oculuscdn.com&oh=00_AYDzX-iJhQy4wg1xzeF7-f1ZgxyjGiRhyNZqknaazZS9pA&oe=67123CF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot 3 APPLAB.png", "id": "1003286644275061", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982501_1003286647608394_8346372999363423708_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7rJiFfHLSUQ7kNvgGHrKOR&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYD01gotazQVBPbKQ3ya7lXsPFUVVpBUckXUTddHJrxiaA&oe=671262EA"}, "display_name": "Experienced Monkes", "keywords": [], "long_description": "Experienced Monkes is a VR game built off of the popular locomotion system (it's open source and it is the locomotion system the popular game \"Gorilla Tag\" uses) called Gorilla Locomotion. The locomotion works by hitting your hands off of objects to move. In Experienced Monkes, you immerse yourself in the role of a monkey in a forest habitat. The game is currently in beta as I'm writing this and there isn't much *yet*, but in the future more improvements will be made such as more maps, and custom hats and things to wear, and more! Enjoy!", "short_description": "This is a Gorilla Tag fan-game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/experiencedmonkesvr/privacy-policy-v2", "developer_terms_of_service_url": null, "publisher_name": "Project Experience Monkes Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/experiencedmonkesvr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1573854509480616"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in