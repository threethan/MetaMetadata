4125178036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HYL6v4LxmaIQ7kNvgGo4Y6j&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCE29BK-h-nByIFeAWttVZdldSFrAxYnG5cFYJIsLvn0g&oe=676D3478"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshot 3 APPLAB.png", "id": "1003286644275061", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982501_1003286647608394_8346372999363423708_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XyWiz0M6NTQQ7kNvgHCvkwK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1bj81bINFwluptP0JA_zxe0YXBre09Vv-cDy2XKXzBA&oe=676D5A6A"}, "display_name": "Experienced Monkes", "keywords": [], "long_description": "Experienced Monkes is a VR game built off of the popular locomotion system (it's open source and it is the locomotion system the popular game \"Gorilla Tag\" uses) called Gorilla Locomotion. The locomotion works by hitting your hands off of objects to move. In Experienced Monkes, you immerse yourself in the role of a monkey in a forest habitat. The game is currently in beta as I'm writing this and there isn't much *yet*, but in the future more improvements will be made such as more maps, and custom hats and things to wear, and more! Enjoy!", "short_description": "This is a Gorilla Tag fan-game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/experiencedmonkesvr/privacy-policy-v2", "developer_terms_of_service_url": null, "publisher_name": "Project Experience Monkes Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/experiencedmonkesvr/home", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_me