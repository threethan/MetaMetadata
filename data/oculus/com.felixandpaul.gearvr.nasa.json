7&_nc_sid=6e7a0a&_nc_ohc=pPq-L2YUSvYQ7kNvgGByJyx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzY4OqzREFFWoyWo-S5sY7O&oh=00_AYDYSLb5C871elqNELJ9KN_0VrhOqDKvl2QzB397qglXwg&oe=66F40282"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nasa_trailer2.png", "id": "846547252212407", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482156_846547255545740_4106685108088471552_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9w4_vAR4U4EQ7kNvgGrFhqW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AzY4OqzREFFWoyWo-S5sY7O&oh=00_AYBrLsKWbdy8NIKuKuCWhLMP5hfcfHGUbX25oZEE3ompyA&oe=66F4091F"}, "display_name": "Space Explorers", "keywords": ["Space", "Explorers", "Exploration", "NASA", "Astronaut"], "long_description": "Space Explorers is a cinematic VR series about the new age of space exploration. Witness firsthand the lives of veteran and novice NASA astronauts alike as they navigate the trials and sacrifices of their training and missions. Explore the dynamics and camaraderie of space programs around the world and the collaboration between the public and private space agencies, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our galaxy, our universe and our origins.", "short_description": "Space Explorers is a cinematic VR series about the new age of space exploration. Witness the lives of NASA astronauts as they navigate the trials and sacrifices of their training and missions. Explore the camaraderie of space programs around the world, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our universe and our origins."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://www.felixandpaul.com/privacy", "developer_terms_of_service_url": "http://www.felixandpaul.com/?info%2Flicense", "publisher