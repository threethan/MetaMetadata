695_2096356263966511_3431599537163075584_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g_ld5hW2S5QQ7kNvgFld0cq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5rJNAsaCX26tgdzsW0EMpk9FABzet-JJTn6NzwDwpAw&oe=676692A1"}, {"file_name": "migrated_image.png", "id": "877218846037624", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410355_651920528476264_1072364453757976576_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e1peceAGFYwQ7kNvgG1rNrn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtkxu6gN0-L2IOqeUrKhm4xzi5588kJ7O-zKUNY0sBcw&oe=6766A3AF"}, {"file_name": "migrated_image.png", "id": "241274247030841", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410200_651477035192149_7431839919544205312_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=N_k-nZrJ864Q7kNvgEOOcQq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABmz83k2pXpWUvcK2d1u7xVRRzczAsUWPyg7ATpCWXVA&oe=6766B12B"}, {"file_name": "migrated_image.png", "id": "199337851358054", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12427574_183051265872321_6132098677365276672_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FN24OjdI0DQQ7kNvgE-bmXa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCYZ0NQwUbKjmOyEtZyYqgT3ZTMs8HXsVxI-Xa_tDZN2w&oe=67669B9E"}, {"file_name": "migrated_image.png", "id": "142501333802171", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12534042_371680596569289_1291321706119430144_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5bv1FTk__8IQ7kNvgESpij0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCjq2sHZ59xehFEihqBvsu_UFNmd3rEnb1pE-ZJF8ptWg&oe=67669940"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nasa_graphic_main_Amaze_2560x1440_24bits_v004.png", "id": "869165291465000", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036604_869165294798333_2872983519313643631_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fEgeil30mlsQ7kNvgFBevfm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVU8IyWyKB5Nr3o7xrJTRkxgPzlYsEeJy0IXY1nLcNFw&oe=6766A935"}, "display_name": "Space Explorers", "keywords": ["Space", "Explorers", "NASA", "Felix", "Astronaut"], "long_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness firsthand the lives of veteran and novice NASA astronauts alike as they navigate the trials and sacrifices of their training and missions. Explore the dynamics and camaraderie of space programs around the world and the collaboration between the public and private space agencies, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our galaxy, our universe and our origins. Narrated by Brie Larson.", "short_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness the lives of NASA astronauts as they navigate the trials and sacrifices of their training and missions. Explore the camaraderie of space programs around the world, and discover the latest advancements and plans for deep space exploration."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CO