695_2096356263966511_3431599537163075584_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BrPRna5rpIUQ7kNvgEvEyQD&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDjcrUSV9VF55K-1PLNZY3LBY-G2nAz1uKVHSfEw8pE6A&oe=67386E21"}, {"file_name": "migrated_image.png", "id": "877218846037624", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410355_651920528476264_1072364453757976576_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RWoVFE8AXyoQ7kNvgGGhfV6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDbn8H28G582d0kc9xm4iJN9RsI3Tg_UuoxtvJoc_LLdQ&oe=67387F2F"}, {"file_name": "migrated_image.png", "id": "241274247030841", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410200_651477035192149_7431839919544205312_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p2IvsmpZx6oQ7kNvgHmOBr3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmtqOFwe3Aw54p-9sxbC0dScukOc5M6SmdcGNt3-0etg&oe=67388CAB"}, {"file_name": "migrated_image.png", "id": "199337851358054", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12427574_183051265872321_6132098677365276672_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VGUDRsoXM5gQ7kNvgEVk5It&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBVk6uY42To38mNLK1WTrJYBqzRe4S6VuQHJ9z3ul4fhw&oe=6738771E"}, {"file_name": "migrated_image.png", "id": "142501333802171", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12534042_371680596569289_1291321706119430144_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJUlCGHK5IUQ7kNvgGz0WX1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAahNGelWT5I40WMXfp-LvONmOTLcd9ikonNIQf5RgkIw&oe=673874C0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nasa_graphic_main_Amaze_2560x1440_24bits_v004.png", "id": "869165291465000", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036604_869165294798333_2872983519313643631_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pi5exzeKYOYQ7kNvgEdrIID&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDzQO9f44i-ULeVTwABcNV8R5iH6YVRngNMWz2W13e-OQ&oe=673884B5"}, "display_name": "Space Explorers", "keywords": ["Space", "Explorers", "NASA", "Felix", "Astronaut"], "long_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness firsthand the lives of veteran and novice NASA astronauts alike as they navigate the trials and sacrifices of their training and missions. Explore the dynamics and camaraderie of space programs around the world and the collaboration between the public and private space agencies, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our galaxy, our universe and our origins. Narrated by Brie Larson.", "short_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness the lives of NASA astronauts as they navigate the trials and sacrifices of their training and missions. Explore the camaraderie of space programs around the world, and discover the latest advancements and plans for deep space exploration."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_C