695_2096356263966511_3431599537163075584_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qIUgElxgewIQ7kNvgHMPuj1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJ6028sPD7mgDH_m4IoNaFIQ4TJUFGrrK2qh00jfouHQ&oe=677A5921"}, {"file_name": "migrated_image.png", "id": "877218846037624", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410355_651920528476264_1072364453757976576_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Qkeg1j1H2QwQ7kNvgE68pxh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAPmiJ-y-bR0LVeSjNIiAF01x1HQU-8tJAVkomA03NNfA&oe=677A6A2F"}, {"file_name": "migrated_image.png", "id": "241274247030841", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12410200_651477035192149_7431839919544205312_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aO4w21SZCSUQ7kNvgHRwnCl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCph_GILBE0d6-lVZ0_cYwoKNYB76g3YEqGJjFfQ4Fspg&oe=677A77AB"}, {"file_name": "migrated_image.png", "id": "199337851358054", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12427574_183051265872321_6132098677365276672_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9XIkI999W6wQ7kNvgH4wydw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9I3Oxu0Y39OA8Gmz4hxGlPvJYgq6B0CfY8fRw--XMQA&oe=677A621E"}, {"file_name": "migrated_image.png", "id": "142501333802171", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12534042_371680596569289_1291321706119430144_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xno-wqiH7iEQ7kNvgHxGSh-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCB0HIkQJYABJEGnEZS3A2GPWDQG6FGYSfSHAeWFw7qnA&oe=677A5FC0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nasa_graphic_main_Amaze_2560x1440_24bits_v004.png", "id": "869165291465000", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036604_869165294798333_2872983519313643631_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uU2XYmxuUaQQ7kNvgEjplCL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC46Yzxtx56_0C40M2xnaQy-H2KCDOXXg5DRqSExO0J3A&oe=677A6FB5"}, "display_name": "Space Explorers", "keywords": ["Space", "Explorers", "NASA", "Felix", "Astronaut"], "long_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness firsthand the lives of veteran and novice NASA astronauts alike as they navigate the trials and sacrifices of their training and missions. Explore the dynamics and camaraderie of space programs around the world and the collaboration between the public and private space agencies, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our galaxy, our universe and our origins. Narrated by Brie Larson.", "short_description": "*** Episode 2 Live Now! ***\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness the lives of NASA astronauts as they navigate the trials and sacrifices of their training and missions. Explore the camaraderie of space programs around the world, and discover the latest advancements and plans for deep space exploration."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "NARRATIVE", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CO