66FA8C9D"}, {"file_name": "02.png", "id": "1666388994214694", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974759_1666388997548027_8985707929372247545_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JKDlGGnHbOkQ7kNvgGOR0BD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDTHfp40BBbCkTuT6N_fFoLDA1PNArhGnl4NkKX7RvKhg&oe=66FA8DC3"}, {"file_name": "04.png", "id": "963781772181703", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974503_963781775515036_4908510560411157677_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6rZAPVQGue4Q7kNvgEe3kG8&_nc_ht=scontent.oculuscdn.com&oh=00_AYBulungzzPEWQ2unFdMPP09XLEeY5pA33ktj8ozpCOk7A&oe=66FA844E"}, {"file_name": "05.png", "id": "819642416821586", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036645_819642420154919_5213770894862090542_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lCyp7rlutKwQ7kNvgGSV4Lx&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7VDpmZhfFxQ5PPheMbIg9YX5K25D5woc3H0P_-lmCJw&oe=66FA7F1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "LandscapeV2.png", "id": "8404126199630691", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974886_8404126202964024_113125977374139482_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dyDBY2rw_0sQ7kNvgG852c4&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8bbVF7bAVlcT8X98yktr5r-UO5Qa5RVFHfgnzyQ6HjA&oe=66FAA699"}, "display_name": "Out There", "keywords": ["Musical", "Animation", "AR", "MR", "Immersive"], "long_description": "\"Out There\" - A Pioneering Immersive Musical Experience on Meta Quest 3\n\nStep into a new dimension of entertainment with \"Out There,\" the world's first immersive musical designed exclusively for Meta Quest 3. Crafted by the visionary team at Wilkins Avenue AR, this experience redefines storytelling by merging advanced spatial computing technology with emotionally resonant narratives.\n\n\"Out There\" showcases the exceptional voice talent of Grammy and Emmy-nominated artist Vanessa Williams, and is produced in collaboration with Pollen Music Group. Leveraging spatial audio and an innovative mix of 3D and traditional Disney-style 2D animation, this musical envelops you in a captivating, multi-dimensional world.\n\nEmbark on a magical journey that transcends traditional entertainment, and discover the future of immersive experiences with \"Out There.\" Available now on Meta Quest 3.", "short_description": "\"Out There\" - A Pioneering Immersive Musical Experience on Meta Quest 3\n\nEmbark on a magical journey that transcends traditional entertainment, and discover the future of immersive experiences with \"Out There.\" Available now on Meta Quest 3."}]}, "developer_name": null, "developer_privacy_policy_url": "https://fr.wilkins-avenue.com/out-there-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Wilkins Avenue AR", "support_website_url": null, "website_url": "https://www.wilkins-avenue.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "668538087410124"}, {"id": "548013192910304"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8147786528646969"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "495792250049077"}]}, "baseline_offer": {"id": "495792250049077"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726472340, "status": "PUBLISHED", "id": "495792250049077"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_r