234347724", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031553_636404241014390_1838612218958400332_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ytti79sKwW0Q7kNvgEAmvTF&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBWNm2wc1ds0up_GVY2cqjKmJRpBobFWfg5bWxuJTKDRw&oe=67615434"}, {"file_name": "vvr2_mech.png", "id": "2037722399738501", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031592_2037722403071834_286561429508580258_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pc2wNbJuQlUQ7kNvgG67EzC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfqP3Wwy3wO0PSTXmNU_1HG4GkatUEo6wT286B4knL6A&oe=67617CED"}, {"file_name": "vvr2_headsets.png", "id": "993804061541740", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031449_993804064875073_7169650324035892299_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v4JsHg5vC_UQ7kNvgGBzxXq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDtLdItr9Ku-amZat_5f5n0pqewhmMveAdO1JsFq9kyQ&oe=676180DB"}, {"file_name": "vvr2_pilotableheadset.png", "id": "464558895019957", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984454_464558901686623_4704462431511288520_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTMq83KCfM0Q7kNvgGIyiU3&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXirbiECcIeGg0fc_G2rW_idf2ajZZrlYA3u-w105uzw&oe=6761721C"}, {"file_name": "vvr2_topiary.png", "id": "309300464465148", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974530_309300467798481_7124195197241332063_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eCPZE1zP-8wQ7kNvgFT-K8B&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB4beyqfw_tLNEwhTn68-z69ya5vLo0BLEU6G7PgtsB-g&oe=67616535"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VVR2_Landscape_pink.png", "id": "1300347197124357", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974680_1300347200457690_6713516443300692446_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ceMZ0e9xxikQ7kNvgGb8UVJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5Mzxwfcq6TyzKQTD9RQ7xh4Mz6z5C-bpMgu9A_tQ2Ew&oe=67617C25"}, "display_name": "Virtual Virtual Reality 2", "keywords": [], "long_description": "When a metaverse shuts down, what happens to the avatars left behind?\n\nIn this darkly funny action/adventure game, pilot your mech body through the chaos of a dying metaverse, rescuing abandoned avatars along the way. Each new avatar-roommate brings unique tools to aid your escape back to meatspace!\n\nDo you have what it takes to overcome the digital destruction and interpersonal drama before you\u2019re logged off for good?\n\n\u2022 Run, jump and boost your Chaz mech across treacherous server-scapes.\n\u2022 Fly VR headset spaceships to capture other avatars.\n\u2022 Use your trusty dog-puppet to charm the data deleters into doing your bidding.\n\u2022 Vacuum up debris from the metaverse to use as fuel and ammo.\n\u2022 Slow time with CPGoo to dodge laser attacks.\n\u2022 Hookshot and pull yourself up through the clouds toward corporate HQ.\n\u2022 Take a rhythmic break in Scottsdale\u2019s ASMR Spa.\n\u2022 Achieve self-actualization as an artichoke whispers at you.", "short_description": "When a metaverse shuts down, what happens to the avatars left behind?\n\nIn this darkly funny action/adventure game, pilot your mech body through the chaos of a dying metaverse, rescuing abandoned avatars along the way. Each new avatar-roommate brings unique tools to aid your escape back to meatspace!\n\nDo you have what it takes to overcome the digital destruction and interpersonal drama before you\u2019re logged off for good?"}]}, "developer_name": "Tender Claws", "developer_privacy_policy_url": "https://tenderclaws.info/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Tender Claws", "support_website_url": null, "website_url": "https://tenderclaws.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "