luscdn.com/v/t64.5771-25/38974751_712354023408453_7478492730701503284_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WuOhg3pTWtgQ7kNvgFsW7Ha&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDiMIgZCHASQJpeUmfr9ykly4pR7rDE9Vt1o3O6GxixPw&oe=676FD7C3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MOOD_Cover_2560x1440.png", "id": "3199990370274868", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031433_3199990373608201_3634187053865464482_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MVDNuRF0R-AQ7kNvgHYf5aZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7tSf2RAftMECfLVlrQ21se9p9FIe1hEQCmpmYrH7uqw&oe=676FE27A"}, "display_name": "MOOD", "keywords": [], "long_description": "MOOD is the gym for your mental fitness.\nThere are many paths toward a happier you.  That\u2019s why we strive to find the best instructors from a wide diversity of fields including:\n\n- All meditative & mystical traditions\n- Psychology & neuroscience \n- Practices rooted in music, art & movement\n- Peak performance coaching\n\nOur goal is for MOOD to house the most comprehensive library of mental well-being instructional content anywhere in the world\n\nNEW FEATURES IN THIS VERSION\n\n- Get to know more about the practitioners that are guiding you.\n- Find an experience that better suits you by filtering based on meditation categories.\n- Discover new practitioners joining our community and collaborating with us.\n- Now we have the ability to post brand new experiences every week.\n\nGive us your feedback!  Email us: info@moonshot.la", "short_description": "ACHIEVE PEACE OF MIND IN 10 MINUTES OR LESS\nMaster your mental state with MOOD\u2019s one-of-a-kind virtual reality experiences:\n\n- Learn from the most innovative teachers in the world\n- Find the mindset tools that are right for you\n- Choose from an unprecedented variety of practices & techniques"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.moonshot.la/mood-pr