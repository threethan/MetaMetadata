6E2E70A"}, {"file_name": "Screenshot_8.png", "id": "712354020075120", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974751_712354023408453_7478492730701503284_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EIJ-w8xmqcoQ7kNvgGf7maI&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aopii1xGA817hCSorkmAYYN&oh=00_AYDrc8GyjFdjn1ExeBK5cal4Y9M2Er3xRIc9hRG6ObRaXQ&oe=66E2C743"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MOOD_Cover_2560x1440.png", "id": "3199990370274868", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031433_3199990373608201_3634187053865464482_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPJLXqkH3_oQ7kNvgGtL9m1&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aopii1xGA817hCSorkmAYYN&oh=00_AYDimdKVayD6-_rRSKfIIWDm4B_yb39HbVYCKLcNzQyM-w&oe=66E2D1FA"}, "display_name": "MOOD", "keywords": [], "long_description": "MOOD is the gym for your mental fitness.\nThere are many paths toward a happier you.  That\u2019s why we strive to find the best instructors from a wide diversity of fields including:\n\n- All meditative & mystical traditions\n- Psychology & neuroscience \n- Practices rooted in music, art & movement\n- Peak performance coaching\n\nOur goal is for MOOD to house the most comprehensive library of mental well-being instructional content anywhere in the world\n\nNEW FEATURES IN THIS VERSION\n\n- Get to know more about the practitioners that are guiding you.\n- Find an experience that better suits you by filtering based on meditation categories.\n- Discover new practitioners joining our community and collaborating with us.\n- Now we have the ability to post brand new experiences every week.\n\nGive us your feedback!  Email us: info@moonshot.la", "short_description": "ACHIEVE PEACE OF MIND IN 10 MINUTES OR LESS\nMaster your mental state with MOOD\u2019s one-of-a-kind virtual reality experiences:\n\n- Learn from the most innovative teachers in the world\n- Find the mindset tools that are right for you\n- Choose from an unprecedented variety of practices & techniques"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.moonshot.la/mood-privacy-1", "developer_terms_of_service_url": null, "publisher_name": "Moonshot", "support_website_url": null, "website_url": "https://www.moonshot.la/mood", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "RELAXATION_MEDITATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "482015257153052"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031596_1232921150578831_8681388477415419205_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KIdFo3MuwAMQ7kNvgFjFVz3&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aopii1xGA817hCSorkmAYYN&oh=00_AYApNisbcRYd3LBkdWIRipU6nHMkxXiXOf8_BaoVNNFafg&oe=66E2E34C"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MOOD", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1645250400, "lastRevision": {"nodes": [{"id": "141535254924059", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5282365225124529", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "3021033961545615"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Logo_Transparent-9000x1440.png", "id": "3141463722796007", "image_type": "APP