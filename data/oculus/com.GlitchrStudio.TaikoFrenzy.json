e=66D191C6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": [], "long_description": "Grab your sticks, it's time to unleash your rhythm skills. \n\nTaiko Frenzy is a percussion rhythm game that takes place in a stunning colorful scenary with original soundtracks exclusively composed for the game\n\nThe App Lab version is meant to get feedbacks from the community in order to turn this demo into a full game that everyone could enjoy.\n\nThere are currently 2 tracks in the game with 2 difficulty levels. We have plans adding more tracks in the next future so stay tuned for updates.\n\nIf you want to try hard, you can climb the leaderboard to become the one and only Taiko Master. Be aware that those leaderboards might be reset during the development of the game.", "short_description": "Grab your sticks, it's time to unleash your rhythm skills. Dive in Taiko Frenzy and become a Taiko Master."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.glitchr-studio.com/wp-content/uploads/2023/02/Taiko-Frenzy-Privacy-Policy-2023.pdf", "developer_terms_of_service_url": null, "publisher_name": "Glitchr Studio", "support_website_url": null, "website_url": "https://www.glitchr-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "507762234584213"}}]}, "schedule