f9vOBqUgb_ejVX2QOWBUR5ei7TQiPLF5Lpqwc1OKw&oe=674852A8"}]}, "id": "3836930819913230", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["\u592a\u9f13", "\u8282\u594f", "\u97f3\u4e50", "\u65e5\u672c", "\u9f13"], "long_description": "\u6293\u8d77\u4f60\u7684\u9f13\u68d2\uff0c\u6572\u51fb\u8282\u594f\uff0c\u91ca\u653e\u4f60\u5185\u5fc3\u7684\u592a\u9f13\u5927\u5e08\uff01\n                                                                                                                                                                               \n{1159582745173481}\n\n# \u6572\u51fb\u8282\u594f\nTaiko Frenzy \u662f\u4e00\u6b3e\u8bbe\u7f6e\u5728\u4ee4\u4eba\u60ca\u53f9\u7684\u591a\u5f69\u573a\u666f\u4e2d\u7684\u6253\u51fb\u4e50\u8282\u594f\u6e38\u620f\u3002\u6c89\u6d78\u5728\u53d7\u65e5\u672c\u6c11\u4fd7\u542f\u53d1\u7684\u5e7b\u60f3\u4e16\u754c\u4e2d\uff0c\u4eab\u53d7\u4e13\u4e3a\u6e38\u620f\u521b\u4f5c\u7684\u539f\u521b\u97f3\u4e50\u3002\u63a7\u5236\u4f60\u7684\u51fb\u6253\u529b\u5ea6\uff0c\u5728\u91cd\u97f3\u62cd\u4e2d\u53d6\u5f97\u6210\u529f\uff0c\u5e76\u5b8c\u7f8e\u914d\u5408\u8282\u594f\uff0c\u91ca\u653e\u4ee4\u4eba\u60ca\u53f9\u7684\u6a31\u82b1\u98ce\u66b4\uff0c\u63d0\u5347\u4f60\u7684\u5f97\u5206\u5e76\u521b\u9020\u8ff7\u4eba\u7684\u89c6\u89c9\u76db\u5bb4\u3002\n\n{338357219281131}\n\n# \u6309\u4f60\u81ea\u5df1\u7684\u8282\u594f\u8fdb\u6b65\n\u6bcf\u9996\u539f\u521b\u66f2\u76ee\u63d0\u4f9b 4 \u4e2a\u96be\u5ea6\u7ea7\u522b\uff0c\u63d0\u4f9b\u4e00\u4e2a\u5956\u52b1\u6027\u7684\u5b66\u4e60\u66f2\u7ebf\uff0c\u6613\u5b66\u96be\u7cbe\uff01\u4f7f\u7528\u5404\u79cd\u6e38\u620f\u4fee\u6539\u5668\u81ea\u5b9a\u4e49\u6311\u6218\u3002\u722c\u4e0a\u6392\u884c\u699c\uff0c\u52aa\u529b\u89e3\u9501\u6240\u6709\u5956\u724c\uff0c\u4e89\u53d6\u6210\u4e3a\u7ec8\u6781\u592a\u9f13\u5927\u5e08\u3002\n\n{1651411545456699}\n\n# \u89e3\u9501\u4f20\u5947\u76ae\u80a4\n\u4f60\u5728\u6b4c\u66f2\u4e2d\u7684\u8fdb\u6b65\u5c06\u901a\u8fc7\u7ecf\u9a8c\u503c\u548c\u6210\u5c31\u5f97\u5230\u5956\u52b1\uff0c\u89e3\u9501\u8d85\u8fc7 100 \u79cd\u5316\u5986\u54c1\u3002\u6ee1\u8db3\u4f60\u6536\u85cf\u5bb6\u7684\u7075\u9b42\uff0c\u5c55\u793a\u4f60\u72ec\u7279\u7684\u98ce\u683c\uff01\n\n{1693743141161579}\n\n# \u521b\u4f5c\u4f60\u81ea\u5df1\u7684\u6b4c\u66f2\n\u8ba9\u4f60\u7684\u521b\u9020\u529b\u6d41\u6dcc\uff0c\u901a\u8fc7\u81ea\u5b9a\u4e49\u6b4c\u66f2\u529f\u80fd\u548c\u521b\u4f5c\u5de5\u5177\uff0c\u521b\u4f5c\u5e76\u6f14\u594f\u4f60\u4e2a\u6027\u5316\u7684\u9f13\u4e50\u6770\u4f5c\uff0c\u5c06\u4f60\u7684\u521b\u9020\u529b\u7f6e\u4e8e\u805a\u5149\u706f\u4e0b\u3002\n\n{400833926274321}\n\n\u4f60\u51c6\u5907\u597d\u8fce\u63a5\u6311\u6218\u4e86\u5417\uff1f\u7acb\u5373\u4e0b\u8f7d Taiko Frenzy \u5e76\u901a\u8fc7\u6253\u9f13\u8fbe\u5230\u5927\u5e08\u7ea7\u6c34\u5e73\uff01", "short_description": "\u6293\u4f4f\u9f13\u69cc\uff0c\u6572\u8d77\u8282\u594f\uff0c\u91ca\u653e\u4f60\u5185\u5fc3\u7684\u592a\u9f13\u5927\u5e08\uff01"}, {"images": {"nodes": [{"file_name": "Cover_Landscape_zh-TW.png", "id": "1421632341832919", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982625_1421632345166252_1383231890696977755_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e85KlUqGMqkQ7kNvgFhEz5J&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDI_PJzd-dgsQV_B4c9iBMRtOIiDsz2y8ermbnyfg33cQ&oe=674861E5"}, {"file_name": "Logo_zh-TW.png", "id": "1324889268164468", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86655520_1324889271497801_122734889199439543_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PzPnaFEV1lEQ7kNvgEQeqRY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtL91tyrXwPWszEOgegYhj4O7D2OCbUhNuSJNHN4_eyg&oe=67486E0B"}, {"file_name": "CoverImageSafeAreaTemplateHero_zh-TW.png", "id": "1165958878001010", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t6