65622147377099}\n\n# \u30d3\u30fc\u30c8\u3092\u523b\u3080\nTaiko Frenzy \u306f\u3001\u7f8e\u3057\u3044\u30ab\u30e9\u30d5\u30eb\u306a\u98a8\u666f\u3092\u821e\u53f0\u306b\u3057\u305f\u6253\u697d\u5668\u30ea\u30ba\u30e0\u30b2\u30fc\u30e0\u3067\u3059\u3002\u65e5\u672c\u306e\u6c11\u9593\u4f1d\u627f\u306b\u30a4\u30f3\u30b9\u30d1\u30a4\u30a2\u3055\u308c\u305f\u30d5\u30a1\u30f3\u30bf\u30b8\u30fc\u306e\u4e16\u754c\u306b\u6d78\u308a\u3001\u30b2\u30fc\u30e0\u5c02\u7528\u306b\u4f5c\u66f2\u3055\u308c\u305f\u30aa\u30ea\u30b8\u30ca\u30eb\u30b5\u30a6\u30f3\u30c9\u30c8\u30e9\u30c3\u30af\u3092\u697d\u3057\u3093\u3067\u304f\u3060\u3055\u3044\u3002\u6253\u6483\u306e\u5f37\u3055\u3092\u30b3\u30f3\u30c8\u30ed\u30fc\u30eb\u3057\u3066\u30a2\u30af\u30bb\u30f3\u30c8\u306e\u3042\u308b\u30d3\u30fc\u30c8\u306b\u6210\u529f\u3057\u3001\u5b8c\u74a7\u306a\u30bf\u30a4\u30df\u30f3\u30b0\u3067\u30d3\u30fc\u30c8\u306b\u5408\u308f\u305b\u3066\u3001\u606f\u3092\u5451\u3080\u3088\u3046\u306a\u685c\u306e\u5d50\u3092\u89e3\u304d\u653e\u3061\u3001\u30b9\u30b3\u30a2\u3092\u4e0a\u3052\u3066\u9b45\u60d1\u7684\u306a\u8996\u899a\u52b9\u679c\u3092\u751f\u307f\u51fa\u3057\u307e\u3057\u3087\u3046\u3002\n\n{442188918534415}\n\n# \u81ea\u5206\u306e\u30da\u30fc\u30b9\u3067\u9032\u3080\n\u5404\u30aa\u30ea\u30b8\u30ca\u30eb\u30c8\u30e9\u30c3\u30af\u306f\u3001\u5b66\u3073\u304c\u3044\u306e\u3042\u308b4\u3064\u306e\u96e3\u6613\u5ea6\u30ec\u30d9\u30eb\u3092\u63d0\u4f9b\u3057\u3001\u7c21\u5358\u306b\u5b66\u3079\u308b\u304c\u30de\u30b9\u30bf\u30fc\u3059\u308b\u306e\u306f\u96e3\u3057\u3044\uff01\u3055\u307e\u3056\u307e\u306a\u30b2\u30fc\u30e0\u30e2\u30c7\u30a3\u30d5\u30a1\u30a4\u30a2\u3067\u30c1\u30e3\u30ec\u30f3\u30b8\u3092\u30ab\u30b9\u30bf\u30de\u30a4\u30ba\u3057\u307e\u3057\u3087\u3046\u3002\u30ea\u30fc\u30c0\u30fc\u30dc\u30fc\u30c9\u306b\u767b\u308a\u3001\u3059\u3079\u3066\u306e\u30e1\u30c0\u30eb\u3092\u30a2\u30f3\u30ed\u30c3\u30af\u3057\u3066\u7a76\u6975\u306e\u592a\u9f13\u306e\u9054\u4eba\u3092\u76ee\u6307\u3057\u3066\u304f\u3060\u3055\u3044\u3002\n\n{426537417003905}\n\n# \u4f1d\u8aac\u306e\u30b9\u30ad\u30f3\u3092\u30a2\u30f3\u30ed\u30c3\u30af\n\u66f2\u306e\u9032\u884c\u306b\u4f34\u3044\u3001XP\u3084\u5b9f\u7e3e\u3067\u5831\u916c\u304c\u4e0e\u3048\u3089\u308c\u3001100\u4ee5\u4e0a\u306e\u30b3\u30b9\u30e1\u30c6\u30a3\u30c3\u30af\u30a2\u30a4\u30c6\u30e0\u304c\u30a2\u30f3\u30ed\u30c3\u30af\u3055\u308c\u307e\u3059\u3002\u30b3\u30ec\u30af\u30bf\u30fc\u9b42\u3092\u6e80\u8db3\u3055\u305b\u3001\u3042\u306a\u305f\u306e\u30e6\u30cb\u30fc\u30af\u306a\u30b9\u30bf\u30a4\u30eb\u3092\u62ab\u9732\u3057\u307e\u3057\u3087\u3046\uff01\n\n{1143560876794112}\n\n# \u81ea\u5206\u306e\u66f2\u3092\u4f5c\u308d\u3046\n\u30ab\u30b9\u30bf\u30e0\u66f2\u306e\u6a5f\u80fd\u3068\u4f5c\u66f2\u30c4\u30fc\u30eb\u3067\u5275\u9020\u529b\u3092\u767a\u63ee\u3057\u3001\u500b\u6027\u3042\u3075\u308c\u308b\u592a\u9f13\u306e\u540d\u4f5c\u3092\u4f5c\u66f2\u3057\u3066\u6f14\u594f\u3057\u3001\u3042\u306a\u305f\u306e\u5275\u9020\u6027\u3092\u5149\u308a\u8f1d\u304b\u305b\u307e\u3057\u3087\u3046\u3002\n\n{1514821989444860}\n\n\u6311\u6226\u306b\u6311\u3080\u6e96\u5099\u306f\u3067\u304d\u307e\u3057\u305f\u304b\uff1f\u4eca\u3059\u3050 Taiko Frenzy \u3092\u30c0\u30a6\u30f3\u30ed\u30fc\u30c9\u3057\u3066\u3001\u6253\u697d\u5668\u306e\u30de\u30b9\u30bf\u30fc\u306b\u306a\u308a\u307e\u3057\u3087\u3046\uff01\n\n\n\n\n", "short_description": "\u3042\u306a\u305f\u306e\u30b9\u30c6\u30a3\u30c3\u30af\u3092\u63b4\u3093\u3067\u3001\u30ea\u30ba\u30e0\u3092\u523b\u307f\u3001\u5185\u306a\u308b\u592a\u9f13\u30de\u30b9\u30bf\u30fc\u3092\u89e3\u304d\u653e\u3068\u3046\uff01"}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "2503079049859049", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974868_2503079053192382_6561820935551193528_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b2HgE2YPsaMQ7kNvgG3LQ6v&_nc_ht=scontent.oculuscdn.com&oh=00_AYAV58i2dv3FFEBNjd_5KfWvNR9XKUUXmlK6alAfejsrLg&oe=66D1A929"}, {"file_name": "Cover_MiniLandscape.png", "id": "1029221412172052", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254874_1029221418838718_5450302450968066231_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=00nmV98tm-gQ7kNvgFq6svr&_nc_ht=scontent.oculuscdn.com&oh=00_AYBIFQxZYsOUnkbu8m17ehJ8YiFvuRVk1dz159TNrXHUNw&oe=66D1A5A6"}, {"file_name": "Cover_Landscape_en.png", "id": "997128198823994", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75280977_997128202157327_2068164725340737300_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sKtEghiMldkQ7kNvgH_oNkE&_nc_ht=scontent.oculuscdn.com&oh=00_AYBds9SYKNf74_Ae6ju4EWsBr3lk5uZ-1TbiOGPmAYSbPA&oe=66D19BDE"}, {"file_name": "Logo.png", "id": "773548887701177", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031410_773548891034510_3149581187629526321_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uYC2eN7BvcIQ7kNvgFIOmdY&_nc_ht=scontent.oculuscdn.com&oh=00_AYClObWAKTbqCcKXNHAjl04uXgGwa4SCMHno-66GBLx0mA&oe=66D1B298"}, {"file_name": "Cover_Portrait.png", "id": "524554866581685", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974889_524554869915018_5242899519902843975_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7KY2ecBbPj8Q7kNvgGUar2E&_nc_ht=scontent.oculuscdn.com&oh=00_AYAh6kgxH5o_sXI9C3LkHgiu9wR8oJOfZDw2CC0btzphQg&oe=66D1B7AB"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "520768007063344", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282160_520768010396677_8161029491680076254_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=crBIIPjoZqwQ7kNvgFUnIS1&_nc_ht=scontent.oculuscdn.com&oh=00_AYATVapXFARwi6F8-iK1O4qS7Mr9zpjQlH3Ndgzy6o-KVQ&oe=66D1C7EC"}, {"file_name": "Cover_Square.png", "id": "493883856580584", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363517_493883859913917_2703600091346182637_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dbwauypFHfkQ7kNvgEhObBU&_nc_ht=scontent.oculuscdn.com&oh=00_AYB4Z-erHmyMAQiTExmTJNVTw0D8HEnyGeCUc9O5eBq_DA&oe=66D1ACFE"}]}, "id": "897014205572544", "locale": "en_US", "screenshots": [{"file_name": "Screen5.png", "id": "693511179661100", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75340712_693511182994433_3672078632480644482_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tlf4ZVcAYukQ7kNvgGBeUtl&_nc_ht=scontent.oculuscdn.com&oh=00_AYDUxF-s1w4jZqPwTyXaq3X__BiCyY__T_MgcEG3jULoIg&oe=66D1C457"}, {"file_name": "ScreenStore4.png", "id": "598963052430681", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031474_598963055764014_6966633497372650118_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XAt9jMEHZ18Q7kNvgEU5Jjg&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMd9eKeYywf5sRr6n6WNyqBRwfgruJdhF-U1sIhjLZbQ&oe=66D191E4"}, {"file_name": "ScreenStore1.png", "id": "709188557931825", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75203626_709188561265158_5153774901681218720_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vO4HZM1uoRUQ7kNvgGs5Qy8&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKQ29vK0Ro5pYIvDz7T53ZcoZ0mIH9uRToBOPwei_RyA&oe=66D1A3BB"}, {"file_name": "ScreenStore2.png", "id": "313491285047525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566687_313491288380858_1744161976014076201_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IWbPv4VKAGMQ7kNvgFMRDpm&_nc_ht=scontent.oculuscdn.com&oh=00_AYD6aG2ot1AFZMVokWKHQbwTEdqby40hSTZDR5CPmQLCgg&oe=66D1AB9E"}, {"file_name": "ScreenStore3.png", "id": "920322393434478", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65395359_920322400101144_4067210821865743250_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DAKi17XU_eAQ7kNvgFD_S9s&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgLtEmScz2iBDppYHnlTSARm3IIYZ-qmTnf7ej2zXmPA&oe=66D1C6E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape_en.png", "id": "382112371294107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_382112374627440_4335625546601176072_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OEMhW4CaDTQQ7kNvgG6KjcA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBokbwMjO0QXqN9WotOOX70BEfpF2TWyghNRRXY6V293w&oe=66D1AAAA"}, "display_name": "Taiko Frenzy", "keywords": ["taiko", "rhythm", "music", "japan", "drum"], "long_description": "Grab your sticks, drum up the beat and unleash your inner Taiko Master\n                                                                                                                                \n{2791919407633655}\n\n# DRUM UP THE BEAT\nTaiko Frenzy is a percussion rhythm game set in a stunning, colorful scenery. Immerse yourself in fantasy world inspired by Japanese folklore with original soundtracks exclusively composed for the game.\nControl the strength of your strikes to succeed in the accented beats and perfect your timing to the beat to unleash breathtaking sakura storms, boosting your score and creating a mesmerizing visual spectacle.\n\n{767564721869167}\n\n# PROGRESS AT YOUR OWN PACE\nEach original track offers 4 difficulty levels providing a rewarding learning curve, easy to learn, hard to master! Customize the challenge with various game modifiers.\nClimb the leaderboards and strive to unlock all the medals, aiming to become the ultimate Taiko Master.\n\n{339385065598065}\n\n# UNLOCK LEGENDARY SKINS\nYour progress in songs is rewarded with XP and achievements, unlocking over 100 cosmetics. Satisfy your collector\u2019s soul and showcase your unique style!\n\n{398008806557102}\n\n# CREATE YOUR OWN SONGS\nLet your creativity flow with the custom song feature and creation tool, enabling you to compose and play your personalized drumming masterpieces, putting your creativity in the spotlight.\n\n{1152563649212920}\n\nAre you ready to take on the challenge? Download Taiko Frenzy now and drum your way to mastery!", "short_description": "Grab your sticks, drum up the beat and unleash your inner Taiko Master!"}, {"images": {"nodes": [{"file_name": "Cover_Landscape_zh-TW.png", "id": "1421632341832919", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982625_1421632345166252_1383231890696977755_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuLtB-u7tIgQ7kNvgGvfRkd&_nc_ht=scontent.oculuscdn.com&oh=00_AYAhpQq2-m75eK_KeAWOHitNa7gzzCWcAZfArgZMkgUGPg&oe=66D1BAE5"}, {"file_name": "Logo_zh-TW.png", "id": "1324889268164468", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655520_1324889271497801_122734889199439543_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r1Jxu89PiG4Q7kNvgGchv0r&_nc_ht=scontent.oculuscdn.com&oh=00_AYA6qCwAdOkIzhPwaim9uMQRylo6SmcKxLvHsTcaC4PfDQ&oe=66D1C70B"}, {"file_name": "CoverImageSafeAreaTemplateHero_zh-TW.png", "id": "1165958878001010", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363517_1165958881334343_333837645415310319_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sl2qYX2a_PEQ7kNvgFTtBs2&_nc_ht=scontent.oculuscdn.com&oh=00_AYAgpLWIVMewTJeR_DszZrA-mVWdlqCP8-VK-Rc05xhqYg&oe=66D19965"}, {"file_name": "Cover_MiniLandscape_zh-TW.png", "id": "805013794954001", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_805013798287334_2286381046419825308_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mfrl4GLohaYQ7kNvgGoJJx4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdHzyENtreIPeE3IAkrIv_h3WDlMpK8u9CJ00FzFl_9w&oe=66D1B737"}, {"file_name": "Cover_Square_zh-TW.png", "id": "426520120418127", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974626_426520123751460_2908513296605964884_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ef-YhInmhvEQ7kNvgHacbwL&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5dSybP-uRVWGv58H2pgIx6xEcx6bTnzca_YxvGPKCvg&oe=66D1A2AF"}, {"file_name": "Cover_Portrait_zh-TW.png", "id": "374910322097379", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974758_374910325430712_4140426874018496963_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MMxGonMuqwAQ7kNvgFhxxBU&_nc_ht=scontent.oculuscdn.com&oh=00_AYCd25OODWY15E8FP-G3qJ3aWml3QNYHVrpen_xv1r8A0w&oe=66D1BD08"}]}, "id": "838012125113591", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["\u592a\u9f13", "\u7bc0\u594f", "\u97f3\u6a02", "\u65e5\u672c", "\u9f13"], "long_description": "\u6293\u8d77\u4f60\u7684\u9f13\u68d2\uff0c\u6572\u64ca\u7bc0\u594f\uff0c\u91cb\u653e\u4f60\u5167\u5fc3\u7684\u592a\u9f13\u5927\u5e2b\uff01\n                                                                                                                                                                               \n{370770162136537}\n\n# \u6572\u64ca\u7bc0\u594f\nTaiko Frenzy \u662f\u4e00\u6b3e\u8a2d\u5b9a\u5728\u4ee4\u4eba\u9a5a\u5606\u7684\u591a\u5f69\u5834\u666f\u4e2d\u7684\u6253\u64ca\u6a02\u7bc0\u594f\u904a\u6232\u3002\u6c89\u6d78\u5728\u53d7\u65e5\u672c\u6c11\u4fd7\u555f\u767c\u7684\u5e7b\u60f3\u4e16\u754c\u4e2d\uff0c\u4eab\u53d7\u5c08\u70ba\u904a\u6232\u5275\u4f5c\u7684\u539f\u5275\u97f3\u6a02\u3002\u63a7\u5236\u4f60\u7684\u64ca\u6253\u529b\u5ea6\uff0c\u5728\u91cd\u97f3\u62cd\u4e2d\u53d6\u5f97\u6210\u529f\uff0c\u4e26\u5b8c\u7f8e\u914d\u5408\u7bc0\u594f\uff0c\u91cb\u653e\u4ee4\u4eba\u9a5a\u5606\u7684\u6afb\u82b1\u98a8\u66b4\uff0c\u63d0\u5347\u4f60\u7684\u5f97\u5206\u4e26\u5275\u9020\u8ff7\u4eba\u7684\u8996\u89ba\u76db\u5bb4\u3002\n\n{979090080212739}\n\n# \u6309\u4f60\u81ea\u5df1\u7684\u7bc0\u594f\u9032\u6b65\n\u6bcf\u9996\u539f\u5275\u66f2\u76ee\u63d0\u4f9b 4 \u500b\u96e3\u5ea6\u7d1a\u5225\uff0c\u63d0\u4f9b\u4e00\u500b\u734e\u52f5\u6027\u7684\u5b78\u7fd2\u66f2\u7dda\uff0c\u6613\u5b78\u96e3\u7cbe\uff01\u4f7f\u7528\u5404\u7a2e\u904a\u6232\u4fee\u6539\u5668\u81ea\u8a02\u6311\u6230\u3002\u722c\u4e0a\u6392\u884c\u699c\uff0c\u52aa\u529b\u89e3\u9396\u6240\u6709\u734e\u724c\uff0c\u722d\u53d6\u6210\u70ba\u7d42\u6975\u592a\u9f13\u5927\u5e2b\u3002\n\n{7698205680235034}\n\n# \u89e3\u9396\u50b3\u5947\u76ae\u819a\n\u4f60\u5728\u6b4c\u66f2\u4e2d\u7684\u9032\u6b65\u5c07\u901a\u904e\u7d93\u9a57\u503c\u548c\u6210\u5c31\u5f97\u5230\u734e\u52f5\uff0c\u89e3\u9396\u8d85\u904e 100 \u7a2e\u5316\u599d\u54c1\u3002\u6eff\u8db3\u4f60\u6536\u85cf\u5bb6\u7684\u9748\u9b42\uff0c\u5c55\u793a\u4f60\u7368\u7279\u7684\u98a8\u683c\uff01\n\n{2109860372727271}\n\n# \u5275\u4f5c\u4f60\u81ea\u5df1\u7684\u6b4c\u66f2\n\u8b93\u4f60\u7684\u5275\u9020\u529b\u6d41\u6dcc\uff0c\u901a\u904e\u81ea\u8a02\u6b4c\u66f2\u529f\u80fd\u548c\u5275\u4f5c\u5de5\u5177\uff0c\u5275\u4f5c\u4e26\u6f14\u594f\u4f60\u500b\u6027\u5316\u7684\u9f13\u6a02\u5091\u4f5c\uff0c\u5c07\u4f60\u7684\u5275\u9020\u529b\u7f6e\u65bc\u805a\u5149\u71c8\u4e0b\u3002\n\n{453189640635695}\n\n\u4f60\u6e96\u5099\u597d\u8fce\u63a5\u6311\u6230\u4e86\u55ce\uff1f\u7acb\u5373\u4e0b\u8f09 Taiko Frenzy \u4e26\u901a\u904e\u6253\u9f13\u9054\u5230\u5927\u5e2b\u7d1a\u6c34\u5e73\uff01", "short_description": "\u6293\u4f4f\u9f13\u69cc\uff0c\u6572\u8d77\u7bc0\u594f\uff0c\u91cb\u653e\u4f60\u5167\u5fc3\u7684\u592a\u9f13\u5927\u5e2b\uff01"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.glitchr-studio.com/wp-content/uploads/2023/02/Taiko-Frenzy-Privacy-Policy-2023.pdf", "developer_terms_of_service_url": null, "publisher_name": "Glitchr Studio", "support_website_url": null, "website_url": "https://taikofrenzy.glitchr-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_co