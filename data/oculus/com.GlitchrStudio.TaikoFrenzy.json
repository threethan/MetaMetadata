 skills. Dive in Taiko Frenzy and become a Taiko Master."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.glitchr-studio.com/wp-content/uploads/2023/02/Taiko-Frenzy-Privacy-Policy-2023.pdf", "developer_terms_of_service_url": null, "publisher_name": "Glitchr Studio", "support_website_url": null, "website_url": "https://www.glitchr-studio.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "507762234584213"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "1214170306377408"}, {"status": "PUBLISHED", "id": "338415105617299"}, {"status": "PUBLISHED", "id": "1002653194033282"}]}, "baseline_offer": {"id": "338415105617299"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726765200, "status": "PUBLISHED", "id": "1214170306377408"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8703344313021808", "version": "1.1.2"}, "id": "1298141654331007", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5801769383179330", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8703344313021808"}, "release_status": "RELEASED