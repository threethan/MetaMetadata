=vO4HZM1uoRUQ7kNvgFCSbwQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYBA80zlm6JUlzAQw3bl2p19nXn5IxsNVllrfpTt4VZDOQ&oe=66D0523B"}, {"file_name": "ScreenStore2.png", "id": "313491285047525", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566687_313491288380858_1744161976014076201_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IWbPv4VKAGMQ7kNvgHUmzP6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYAELdB64biI4es0VGCoUsWd91DG_hIWofmT6b081tA4EQ&oe=66D05A1E"}, {"file_name": "ScreenStore3.png", "id": "920322393434478", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65395359_920322400101144_4067210821865743250_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DAKi17XU_eAQ7kNvgFDpuWK&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYA2UiQimrIV9R_ds7DMTR7h5FHjopoIalgyUg1ug59F1w&oe=66D07569"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape_en.png", "id": "382112371294107", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984467_382112374627440_4335625546601176072_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OEMhW4CaDTQQ7kNvgEZc7Df&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYAm_t4ZNBiRG6PmYdDneI2ySWOZ5jBFUhz46opPiIIuug&oe=66D0592A"}, "display_name": "Taiko Frenzy", "keywords": ["taiko", "rhythm", "music", "japan", "drum"], "long_description": "Grab your sticks, drum up the beat and unleash your inner Taiko Master\n                                                                                                                                \n{2791919407633655}\n\n# DRUM UP THE BEAT\nTaiko Frenzy is a percussion rhythm game set in a stunning, colorful scenery. Immerse yourself in fantasy world inspired by Japanese folklore with original soundtracks exclusively composed for the game.\nControl the strength of your strikes to succeed in the accented beats and perfect your timing to the beat to unleash breathtaking sakura storms, boosting your score and creating a mesmerizing visual spectacle.\n\n{767564721869167}\n\n# PROGRESS AT YOUR OWN PACE\nEach original track offers 4 difficulty levels providing a rewarding learning curve, easy to learn, hard to master! Customize the challenge with various game modifiers.\nClimb the leaderboards and strive to unlock all the medals, aiming to become the ultimate Taiko Master.\n\n{339385065598065}\n\n# UNLOCK LEGENDARY SKINS\nYour progress in songs is rewarded with XP and achievements, unlocking over 100 cosmetics. Satisfy your collector\u2019s soul and showcase your unique style!\n\n{398008806557102}\n\n# CREATE YOUR OWN SONGS\nLet your creativity flow with the custom song feature and creation tool, enabling you to compose and play your personalized drumming masterpieces, putting your creativity in the spotlight.\n\n{1152563649212920}\n\nAre you ready to take on the challenge? Download Taiko Frenzy now and drum your way to mastery!", "short_description": "Grab your sticks, drum up the beat and unleash your inner Taiko Master!"}, {"images": {"nodes": [{"file_name": "Cover_Landscape_zh-TW.png", "id": "1421632341832919", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982625_1421632345166252_1383231890696977755_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JuLtB-u7tIgQ7kNvgErX6x-&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYDcn04WDPAN5QuxzterNViYh8QjIrSypvbKdEF4A4D4fw&oe=66D06965"}, {"file_name": "Logo_zh-TW.png", "id": "1324889268164468", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86655520_1324889271497801_122734889199439543_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lYiA5tJZNskQ7kNvgGreQxh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYDB7KbkSiWlv1Y51Cs5eHixkA6ge3QJkOaohbW5YNgUKg&oe=66D0758B"}, {"file_name": "CoverImageSafeAreaTemplateHero_zh-TW.png", "id": "1165958878001010", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363517_1165958881334343_333837645415310319_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=loLqLwxvWkEQ7kNvgFjgphz&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYAHpXo0a5NJo2pK9iBmTWr4d0_hM7aeLGJp3HJPg_U6fA&oe=66D047E5"}, {"file_name": "Cover_MiniLandscape_zh-TW.png", "id": "805013794954001", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974517_805013798287334_2286381046419825308_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PrZh6QvNFwkQ7kNvgFBFVT5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYDM73kvuUOa7N2CP35o7qZXSbla8-Wrtmj5TlON0hZdXA&oe=66D065B7"}, {"file_name": "Cover_Square_zh-TW.png", "id": "426520120418127", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974626_426520123751460_2908513296605964884_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIE0w7qflaQQ7kNvgGmfWIA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYDKOkQyAPrTDiW-WVBPi8VxSinF6eXOpqJERjjzcnmQaA&oe=66D0512F"}, {"file_name": "Cover_Portrait_zh-TW.png", "id": "374910322097379", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974758_374910325430712_4140426874018496963_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MMxGonMuqwAQ7kNvgEH5c88&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqYaA&oh=00_AYApLAH79WDfuyQNICjzqK1mvW12NCr5O6lgRc285oPkFg&oe=66D06B88"}]}, "id": "838012125113591", "locale": "zh_TW", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["\u592a\u9f13", "\u7bc0\u594f", "\u97f3\u6a02", "\u65e5\u672c", "\u9f13"], "long_description": "\u6293\u8d77\u4f60\u7684\u9f13\u68d2\uff0c\u6572\u64ca\u7bc0\u594f\uff0c\u91cb\u653e\u4f60\u5167\u5fc3\u7684\u592a\u9f13\u5927\u5e2b\uff01\n                                                                                                                                                                               \n{370770162136537}\n\n# \u6572\u64ca\u7bc0\u594f\nTaiko Frenzy \u662f\u4e00\u6b3e\u8a2d\u5b9a\u5728\u4ee4\u4eba\u9a5a\u5606\u7684\u591a\u5f69\u5834\u666f\u4e2d\u7684\u6253\u64ca\u6a02\u7bc0\u594f\u904a\u6232\u3002\u6c89\u6d78\u5728\u53d7\u65e5\u672c\u6c11\u4fd7\u555f\u767c\u7684\u5e7b\u60f3\u4e16\u754c\u4e2d\uff0c\u4eab\u53d7\u5c08\u70ba\u904a\u6232\u5275\u4f5c\u7684\u539f\u5275\u97f3\u6a02\u3002\u63a7\u5236\u4f60\u7684\u64ca\u6253\u529b\u5ea6\uff0c\u5728\u91cd\u97f3\u62cd\u4e2d\u53d6\u5f97\u6210\u529f\uff0c\u4e26\u5b8c\u7f8e\u914d\u5408\u7bc0\u594f\uff0c\u91cb\u653e\u4ee4\u4eba\u9a5a\u5606\u7684\u6afb\u82b1\u98a8\u66b4\uff0c\u63d0\u5347\u4f60\u7684\u5f97\u5206\u4e26\u5275\u9020\u8ff7\u4eba\u7684\u8996\u89ba\u76db\u5bb4\u3002\n\n{979090080212739}\n\n# \u6309\u4f60\u81ea\u5df1\u7684\u7bc0\u594f\u9032\u6b65\n\u6bcf\u9996\u539f\u5275\u66f2\u76ee\u63d0\u4f9b 4 \u500b\u96e3\u5ea6\u7d1a\u5225\uff0c\u63d0\u4f9b\u4e00\u500b\u734e\u52f5\u6027\u7684\u5b78\u7fd2\u66f2\u7dda\uff0c\u6613\u5b78\u96e3\u7cbe\uff01\u4f7f\u7528\u5404\u7a2e\u904a\u6232\u4fee\u6539\u5668\u81ea\u8a02\u6311\u6230\u3002\u722c\u4e0a\u6392\u884c\u699c\uff0c\u52aa\u529b\u89e3\u9396\u6240\u6709\u734e\u724c\uff0c\u722d\u53d6\u6210\u70ba\u7d42\u6975\u592a\u9f13\u5927\u5e2b\u3002\n\n{7698205680235034}\n\n# \u89e3\u9396\u50b3\u5947\u76ae\u819a\n\u4f60\u5728\u6b4c\u66f2\u4e2d\u7684\u9032\u6b65\u5c07\u901a\u904e\u7d93\u9a57\u503c\u548c\u6210\u5c31\u5f97\u5230\u734e\u52f5\uff0c\u89e3\u9396\u8d85\u904e 100 \u7a2e\u5316\u599d\u54c1\u3002\u6eff\u8db3\u4f60\u6536\u85cf\u5bb6\u7684\u9748\u9b42\uff0c\u5c55\u793a\u4f60\u7368\u7279\u7684\u98a8\u683c\uff01\n\n{2109860372727271}\n\n# \u5275\u4f5c\u4f60\u81ea\u5df1\u7684\u6b4c\u66f2\n\u8b93\u4f60\u7684\u5275\u9020\u529b\u6d41\u6dcc\uff0c\u901a\u904e\u81ea\u8a02\u6b4c\u66f2\u529f\u80fd\u548c\u5275\u4f5c\u5de5\u5177\uff0c\u5275\u4f5c\u4e26\u6f14\u594f\u4f60\u500b\u6027\u5316\u7684\u9f13\u6a02\u5091\u4f5c\uff0c\u5c07\u4f60\u7684\u5275\u9020\u529b\u7f6e\u65bc\u805a\u5149\u71c8\u4e0b\u3002\n\n{453189640635695}\n\n\u4f60\u6e96\u5099\u597d\u8fce\u63a5\u6311\u6230\u4e86\u55ce\uff1f\u7acb\u5373\u4e0b\u8f09 Taiko Frenzy \u4e26\u901a\u904e\u6253\u9f13\u9054\u5230\u5927\u5e2b\u7d1a\u6c34\u5e73\uff01", "short_description": "\u6293\u4f4f\u9f13\u69cc\uff0c\u6572\u8d77\u7bc0\u594f\uff0c\u91cb\u653e\u4f60\u5167\u5fc3\u7684\u592a\u9f13\u5927\u5e2b\uff01"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.glitchr-studio.com/wp-content/uploads/2023/02/Taiko-Frenzy-Privacy-Policy-2023.pdf", "developer_terms_of_service_url": null, "publisher_name": "Glitchr Studio", "support_website_url": null, "website_url": "https://taikofrenzy.glitchr-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "939033889924114"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "zh_TW", "ja", "ko", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8268602166496027"}, "review_messages": ["Approving this update! You are welcome to set the release date when you want to. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75363517_493883859913917_2703600091346182637_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dbwauypFHfkQ7kNvgHkDAUC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AhGEmiT3MVmGYlTriZqqY