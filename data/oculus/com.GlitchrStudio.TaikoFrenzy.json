1oQ1yZB4p2uu3XnCpafKTgapHwOD9yaUHZ1Zuw&oe=66D1C433"}, {"file_name": "Cover_Portrait_ko.png", "id": "1403973363618090", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036668_1403973366951423_3449716425556368760_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dnvDd7X8VZIQ7kNvgHfkkxT&_nc_ht=scontent.oculuscdn.com&oh=00_AYB2pqR3sAN-ta9NGn7cLxPfRFu2gN_ipq5dVvgYmt8hXQ&oe=66D1BCE8"}, {"file_name": "Logo_ko.png", "id": "1036976667537920", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031511_1036976670871253_5394129446520014173_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KJ7eAwTDlqQQ7kNvgE_qs5F&_nc_ht=scontent.oculuscdn.com&oh=00_AYDz8R9fFCuc_Cp6GL_Kbigj-cy-O0Xb0cT_E5qwt_DJ6A&oe=66D193A9"}, {"file_name": "Cover_Square_ko.png", "id": "885553080059333", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75245820_885553083392666_6427236336595069224_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iNborUCbnUsQ7kNvgFUHRaE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAIUkivb1V70bQZoKYsipGJbYVKQrxVNbUBCvDZyOj2Fg&oe=66D1A80D"}, {"file_name": "CoverImageSafeAreaTemplateHero_ko.png", "id": "867283361950969", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974832_867283365284302_1940816258932580553_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DxRGDbj4x2UQ7kNvgHFaKh9&_nc_ht=scontent.oculuscdn.com&oh=00_AYDI6b6oyqVlKIK2Ugoytt-6BUD_wrV8AxgXLyKIjnVNxg&oe=66D1BF5D"}, {"file_name": "Cover_MiniLandscape_ko.png", "id": "465711569698889", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974902_465711573032222_2631041649902484778_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YV6ou58SwdQQ7kNvgECWQPr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbGQrPlooa9kJ5IPjCt5jtK9lmMJswsM-qwWK1Dn4ibA&oe=66D1B930"}]}, "id": "27183354337929949", "locale": "ko_KR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["\ud0dc\uace0", "\ub9ac\ub4ec", "\uc74c\uc545", "\uc77c\ubcf8", "\ub4dc\ub7fc"], "long_description": "\uc2a4\ud2f1\uc744 \uc7a1\uace0 \ube44\ud2b8\ub97c \uc6b8\ub9ac\uba70 \ub0b4\uba74\uc758 \ud0c0\uc774\ucf54 \ub9c8\uc2a4\ud130\ub97c \ud574\ubc29\uc2dc\ud0a4\uc138\uc694!\n                                                                                                                                                                   \n{1135612544156549}\n\n# \ube44\ud2b8\ub97c \uc6b8\ub9ac\uc138\uc694\nTaiko Frenzy\ub294 \uba4b\uc9c0\uace0 \ub2e4\ucc44\ub85c\uc6b4 \ud48d\uacbd\uc744 \ubc30\uacbd\uc73c\ub85c \ud55c \ud0c0\uc545\uae30 \ub9ac\ub4ec \uac8c\uc784\uc785\ub2c8\ub2e4. \uc77c\ubcf8 \ubbfc\uc18d\uc5d0 \uc601\uac10\uc744 \ubc1b\uc740 \ud658\uc0c1\uc801\uc778 \uc138\uacc4\uc5d0 \ubab0\uc785\ud558\uace0, \uac8c\uc784\uc744 \uc704\ud574 \ub3c5\uc810\uc801\uc73c\ub85c \uc791\uace1\ub41c \uc624\ub9ac\uc9c0\ub110 \uc0ac\uc6b4\ub4dc\ud2b8\ub799\uc744 \uc990\uae30\uc138\uc694. \uac15\uc57d\uc744 \uc870\uc808\ud558\uc5ec \uc561\uc13c\ud2b8 \ube44\ud2b8\ub97c \uc131\uacf5\uc801\uc73c\ub85c \uce58\uace0, \ube44\ud2b8\uc5d0 \ub9de\ucdb0 \ud0c0\uc774\ubc0d\uc744 \uc644\ubcbd\ud558\uac8c \ub9de\ucdb0 \uc810\uc218\ub97c \ub192\uc774\uace0 \uc228\ub9c9\ud788\ub294 \ubc9a\uaf43 \ud3ed\ud48d\uc744 \uc77c\uc73c\ud0a4\uba70 \uba4b\uc9c4 \uc2dc\uac01\uc801 \ud6a8\uacfc\ub97c \ub9cc\ub4dc\uc138\uc694.\n\n{1164405538339917}\n\n# \uc790\uc2e0\uc758 \uc18d\ub3c4\ub85c \uc9c4\ud589\ud558\uc138\uc694\n\uac01 \uc624\ub9ac\uc9c0\ub110 \ud2b8\ub799\uc740 \ubc30\uc6b0\uae30 \uc27d\uc9c0\ub9cc \ub9c8\uc2a4\ud130\ud558\uae30 \uc5b4\ub824\uc6b4 \ubcf4\ub78c \uc788\ub294 \ud559\uc2b5 \uace1\uc120\uc744 \uc81c\uacf5\ud558\ub294 4\uac00\uc9c0 \ub09c\uc774\ub3c4 \uc218\uc900\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4! \ub2e4\uc591\ud55c \uac8c\uc784 \ubaa8\ub514\ud30c\uc774\uc5b4\ub85c \ub3c4\uc804\uc744 \ub354\uc6b1 \ub9de\ucda4 \uc124\uc815\ud558\uc138\uc694. \ub9ac\ub354\ubcf4\ub4dc\uc5d0 \uc62c\ub77c \ubaa8\ub4e0 \uba54\ub2ec\uc744 \uc7a0\uae08 \ud574\uc81c\ud558\uace0 \uad81\uadf9\uc758 \ud0c0\uc774\ucf54 \ub9c8\uc2a4\ud130\uac00 \ub418\uae30 \uc704\ud574 \ub178\ub825\ud558\uc138\uc694.\n\n{343827455421551}\n\n# \uc804\uc124\uc801\uc778 \uc2a4\ud0a8\uc744 \uc7a0\uae08 \ud574\uc81c\ud558\uc138\uc694\n\uace1\uc758 \uc9c4\ud589 \uc0c1\ud669\uc5d0 \ub530\ub77c XP\uc640 \uc5c5\uc801\uc774 \ubcf4\uc0c1\uc73c\ub85c \uc8fc\uc5b4\uc9c0\uba70 100\uac1c \uc774\uc0c1\uc758 \ud654\uc7a5\ud488\uc744 \uc7a0\uae08 \ud574\uc81c\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc218\uc9d1\uac00\uc758 \uc601\ud63c\uc744 \ub9cc\uc871\uc2dc\ud0a4\uace0 \ub3c5\ud2b9\ud55c \uc2a4\ud0c0\uc77c\uc744 \ubf50\ub0b4\uc138\uc694!\n\n{977919040544654}\n\n# \uc790\uc2e0\ub9cc\uc758 \uace1\uc744 \ub9cc\ub4e4\uc5b4\ubcf4\uc138\uc694\n\ucee4\uc2a4\ud140 \uace1 \uae30\ub2a5\uacfc \uc791\uace1 \ub3c4\uad6c\ub85c \ucc3d\uc758\ub825\uc744 \ubc1c\ud718\ud558\uc5ec \ub098\ub9cc\uc758 \ub3c5\ucc3d\uc801\uc778 \ub4dc\ub7ec\ubc0d \uac78\uc791\uc744 \uc791\uace1\ud558\uace0 \uc5f0\uc8fc\ud558\uba70 \ucc3d\uc758\uc131\uc744 \ube5b\ub0b4\uc138\uc694.\n\n{1161769201914355}\n\n\ub3c4\uc804\uc5d0 \ub9de\uc124 \uc900\ube44\uac00 \ub418\uc168\ub098\uc694? \uc9c0\uae08 Taiko Frenzy\ub97c \ub2e4\uc6b4\ub85c\ub4dc\ud558\uace0 \ub9c8\uc2a4\ud130\uc758 \uae38\ub85c \ub098\uc544\uac00\uc138\uc694!", "short_description": "\uc2a4\ud2f1\uc744 \uc7a1\uace0, \ube44\ud2b8\ub97c \ub354\ud558\uba70 \ub0b4\uba74\uc758 \ud0dc\uace0 \ub9c8\uc2a4\ud130\ub97c \uc120\ubcf4\uc774\uc138\uc694!"}, {"images": {"nodes": []}, "id": "1996441194148284", "locale": "fr_FR", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["taiko", "rythme", "musique", "japon", "tambour"], "long_description": "Attrape tes baguettes, suis le rythme et lib\u00e8re le Ma\u00eetre Taiko qui sommeille en toi !\n                                                                                                                \n{782090407373623}\n\n# SUIS LE FLOW\nTaiko Frenzy est un jeu de rythme de percussions se d\u00e9roulant dans un d\u00e9cor magnifique et color\u00e9. Plonge dans le monde du folklore japonais avec des bandes son originales compos\u00e9es exclusivement pour le jeu.\nContr\u00f4le la force de tes frappes pour r\u00e9ussir les coups accentu\u00e9s et peaufine ta synchronisation avec le rythme pour d\u00e9clencher des temp\u00eates de sakura \u00e0 couper le souffle, augmentant ton score et cr\u00e9ant un spectacle visuel envo\u00fbtant.\n\n{651484593846080}\n\n# PROGRESSE A TON RYTHME\nChaque piste originale propose 4 niveaux de difficult\u00e9 offrant une courbe d'apprentissage gratifiante, facile \u00e0 apprendre, difficile \u00e0 ma\u00eetriser ! Personnalise le d\u00e9fi avec les modificateurs de jeu.\nGrimpe dans les classements et d\u00e9bloque toutes les m\u00e9dailles pour devenir l'ultime Ma\u00eetre Taiko.\n\n{1444694516252830}\n\n# D\u00c9BLOQUE DES SKINS L\u00c9GENDAIRES\nTa progression dans les diff\u00e9rentes chansons sera r\u00e9compens\u00e9e par de l'XP et des succ\u00e8s, te permettant de d\u00e9bloquer plus de 100 objets cosm\u00e9tiques. De quoi combler ton \u00e2me de collectionneur et d'afficher ton style unique.\n\n{950186906584202}\n\n# CR\u00c9ER TES PROPRES CHANSONS\nLaisse ta cr\u00e9ativit\u00e9 s'exprimer avec la fonction de chanson personnalis\u00e9e et l'outil de cr\u00e9ation, te permettant de composer et de jouer tes chefs-d'\u0153uvre au Taiko.\n\n{1107309587008061}\n\nT\u00e9l\u00e9charge Taiko Frenzy d\u00e8s maintenant et trouve ton chemin vers la ma\u00eetrise !", "short_description": "Attrape tes baguettes, suis le rythme et lib\u00e8re le Ma\u00eetre Taiko qui sommeille en toi !"}, {"images": {"nodes": [{"file_name": "Cover_MiniLandscape_zh.png", "id": "2002342523556608", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003265_2002342526889941_8157551003552751029_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L6uloOyiDeUQ7kNvgHJvYwk&_nc_ht=scontent.oculuscdn.com&oh=00_AYBkVobyLfYv7Xn7ub-YUF1vs1mliyOeKpLb6Lko5UZ7ug&oe=66D1A33A"}, {"file_name": "CoverImageSafeAreaTemplateHero_zh.png", "id": "1174320437148054", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974832_1174320440481387_3107585493104306157_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IO0qZAVN_EYQ7kNvgFJFFLR&_nc_ht=scontent.oculuscdn.com&oh=00_AYAYt7wJpLxxyq8MhDpZBWqpRIoDnEmKQJetV6zjgnfaLw&oe=66D1BA61"}, {"file_name": "Cover_Portrait_zh.png", "id": "1067274101664291", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75549074_1067274104997624_4427438373740702545_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nkVHTvAV8pgQ7kNvgHwWhvx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCevop6JpcAgDOAcTK9reOMJHwnhW3M1VRBITrD4yESDQ&oe=66D1BF29"}, {"file_name": "Cover_Landscape_zh.png", "id": "1028007738831221", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75280977_1028007742164554_5834946696643934687_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WLOtnlHGbYEQ7kNvgGjTlyJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYD11SA0o0zvagF-vkggqWMzy9WMZxj5EVlS3UL6VCaVJg&oe=66D1AED7"}, {"file_name": "Cover_Square_zh.png", "id": "851602993607449", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75572757_851602996940782_3735501911195253024_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5_DTw8b-70oQ7kNvgFHUBlW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAW8k1ZA7nJ2W5L1BdIlZ1lLve_8YWvxoqgTvOk7xPMsQ&oe=66D1AFC1"}, {"file_name": "Logo_zh.png", "id": "395684026132343", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_395684029465676_4689665585573181650_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eb0mJFQSQCYQ7kNvgFn_LqM&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkVmWROEwmYFpil2EDXYaetpfXV2ENgS2-dJaczsKGdQ&oe=66D1ABA8"}]}, "id": "1166901527943574", "locale": "zh_CN", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Taiko Frenzy", "keywords": ["\u592a\u9f13", "\u8282\u594f", "\u97f3\u4e50", "\u65e5\u672c", "\u9f13"], "long_description": "\u6293\u8d77\u4f60\u7684\u9f13\u68d2\uff0c\u6572\u51fb\u8282\u594f\uff0c\u91ca\u653e\u4f60\u5185\u5fc3\u7684\u592a\u9f13\u5927\u5e08\uff01\n                                                                                                                                                                               \n{1159582745173481}\n\n# \u6572\u51fb\u8282\u594f\nTaiko Frenzy \u662f\u4e00\u6b3e\u8bbe\u7f6e\u5728\u4ee4\u4eba\u60ca\u53f9\u7684\u591a\u5f69\u573a\u666f\u4e2d\u7684\u6253\u51fb\u4e50\u8282\u594f\u6e38\u620f\u3002\u6c89\u6d78\u5728\u53d7\u65e5\u672c\u6c11\u4fd7\u542f\u53d1\u7684\u5e7b\u60f3\u4e16\u754c\u4e2d\uff0c\u4eab\u53d7\u4e13\u4e3a\u6e38\u620f\u521b\u4f5c\u7684\u539f\u521b\u97f3\u4e50\u3002\u63a7\u5236\u4f60\u7684\u51fb\u6253\u529b\u5ea6\uff0c\u5728\u91cd\u97f3\u62cd\u4e2d\u53d6\u5f97\u6210\u529f\uff0c\u5e76\u5b8c\u7f8e\u914d\u5408\u8282\u594f\uff0c\u91ca\u653e\u4ee4\u4eba\u60ca\u53f9\u7684\u6a31\u82b1\u98ce\u66b4\uff0c\u63d0\u5347\u4f60\u7684\u5f97\u5206\u5e76\u521b\u9020\u8ff7\u4eba\u7684\u89c6\u89c9\u76db\u5bb4\u3002\n\n{338357219281131}\n\n# \u6309\u4f60\u81ea\u5df1\u7684\u8282\u594f\u8fdb\u6b65\n\u6bcf\u9996\u539f\u521b\u66f2\u76ee\u63d0\u4f9b 4 \u4e2a\u96be\u5ea6\u7ea7\u522b\uff0c\u63d0\u4f9b\u4e00\u4e2a\u5956\u52b1\u6027\u7684\u5b66\u4e60\u66f2\u7ebf\uff0c\u6613\u5b66\u96be\u7cbe\uff01\u4f7f\u7528\u5404\u79cd\u6e38\u620f\u4fee\u6539\u5668\u81ea\u5b9a\u4e49\u6311\u6218\u3002\u722c\u4e0a\u6392\u884c\u699c\uff0c\u52aa\u529b\u89e3\u9501\u6240\u6709\u5956\u724c\uff0c\u4e89\u53d6\u6210\u4e3a\u7ec8\u6781\u592a\u9f13\u5927\u5e08\u3002\n\n{1651411545456699}\n\n# 