k61A&_nc_ht=scontent.oculuscdn.com&_nc_gid=Avu-oPWMhvvlerbLlkfaJ9J&oh=00_AYBgD5eox7NGZGvllGr7ug-tel1XBBfs7EINNwY-8embjg&oe=66F5334B"}, {"file_name": "ss5.png", "id": "424017539154215", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/227864397_424017542487548_6318361129991840326_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IdsBiy-gM4gQ7kNvgH8kl3o&_nc_ht=scontent.oculuscdn.com&_nc_gid=Avu-oPWMhvvlerbLlkfaJ9J&oh=00_AYBzg8pr264Zdk0Yf2IzGoK-Gt4Mus5c0aA950GlzQgklA&oe=66F56462"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MovieDancingBeat_2_Moment.png", "id": "263801118918752", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031398_263801122252085_2116618039480190141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YnLewrkieP8Q7kNvgGX1ENl&_nc_ht=scontent.oculuscdn.com&_nc_gid=Avu-oPWMhvvlerbLlkfaJ9J&oh=00_AYC5D3-IbZJSqtcPeqNFqpa4ENuDqelSfKAOOelShEKS9g&oe=66F53719"}, "display_name": "Dancing Beat on Video", "keywords": [], "long_description": "Dancing Beat on Video is a rhythm game base on your favorite YouTube videos\n.\nHow to play:\nYou can copy URL or ID of your favorite YouTube video (from browser) and paste it in the game. Or just select a trending video in the list videos in your selected location. The game will analysis and generate notes based on beats of the song. \nHit notes to get score and finish the video to win. Miss 50 notes lead to fail.\nYou have to hit the note with a moving controller. Touching the note in too low speed will miss the note.\n.\nNOTICE: \nThe video will play online so it requires a high speed internet connection to avoid lagging streaming (or try to wait for loading, press \"A\" button to pause and press replay to solve lagging).\nThe videos have age restriction is not allowed to play.\n.\nHope you enjoy your favorite videos in Dancing Beat.", "short_description": "A rhythm game based on your favorite YouTube videos"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.naetib.com/p