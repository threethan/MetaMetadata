n.com/v/t64.5771-25/227864397_424017542487548_6318361129991840326_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4TZS60--I9IQ7kNvgGTlTnb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAYUOgS4xcEaz5hKJSXXA19jOBPcLkiYGzmQk1gnqQRCQ&oe=6718FCE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MovieDancingBeat_2_Moment.png", "id": "263801118918752", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031398_263801122252085_2116618039480190141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QSQ2X9MsmZ0Q7kNvgETTuJM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDlZKeoV_ctrPb30BwrH92tQWvXsxvt_JeDNv53zwKAxA&oe=6718CF99"}, "display_name": "Dancing Beat on Video", "keywords": [], "long_description": "Dancing Beat on Video is a rhythm game base on your favorite YouTube videos\n.\nHow to play:\nYou can copy URL or ID of your favorite YouTube video (from browser) and paste it in the game. Or just select a trending video in the list videos in your selected location. The game will analysis and generate notes based on beats of the song. \nHit notes to get score and finish the video to win. Miss 50 notes lead to fail.\nYou have to hit the note with a moving controller. Touching the note in too low speed will miss the note.\n.\nNOTICE: \nThe video will play online so it requires a high speed internet connection to avoid lagging streaming (or try to wait for loading, press \"A\" button to pause and press replay to solve lagging).\nThe videos have age restriction is not allowed to play.\n.\nHope you enjoy your favorite videos in Dancing Beat.", "short_description": "A rhythm game based on your favorite YouTube videos"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.naetib.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Naetib", "support_website_url": null, "website_url": "https://www.naetib.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_categor