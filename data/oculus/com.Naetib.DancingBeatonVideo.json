uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035420_417580676620811_8357530107499312898_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3WSxEV0g0jUQ7kNvgFwMos7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCkLbjOiZudjInpgMs4tB7bOgCbRJnL8L8dcwfvycntNQ&oe=66F6A909"}, "display_name": "Dancing Beat on Video", "keywords": [], "long_description": "Dancing Beat on Video is a rhythm game base on your favorite YouTube music videos for dancing or fitness\n.\nHow to play:\n[Please watch the short video to see how to play easily]\n.\nYou can copy URL or ID of your favorite YouTube video (from a browser) and paste it in the game. Or just select a video in the list of trending videos in your selected location. The game will analyze and generate series of notes based on beats of the song. \nDance and hit notes to get score and finish the video to win. Missing too many notes will lead to fail.\nYou have to hit the note with a moving controller. Touching the note in too low speed will miss the note.\n.\nNOTICE: \nThe video will play online so it requires a high speed internet connection to avoid lagging streaming. Tip to solve lagging:  try to wait for loading, press \"A\" button to pause and press replay.\nThe videos have age restriction is not allowed to play.\n.\nHope you enjoy your favorite videos in Dancing Beat!", "short_description": "A rhythm game based on your favorite YouTube music videos for dancing or fitness"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.naetib.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Naetib", "support_website_url": null, "website_url": "https://www.naetib.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "MUSIC_VIDEO", "SPORTS"], "has_in_app_ads": false, "internet_connec