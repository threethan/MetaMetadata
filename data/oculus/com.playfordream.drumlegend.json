.png", "id": "300409502712698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75286676_300409506046031_7075151105749574940_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8DSGhbA-LS8Q7kNvgFJ4bZS&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5ucoKhJ-QFVVtSoB3k6ONi&oh=00_AYDVNl7HHvGG71roDXSWRS7834y7C182kflFaz9K-oVcBw&oe=66DED977"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u5c01\u9762\u98ce\u666f 2560x1440.png", "id": "924741425935792", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422370_924741429269125_5581551878028527069_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1UpMs1qDnAIQ7kNvgFFKB7E&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5ucoKhJ-QFVVtSoB3k6ONi&oh=00_AYAEDZZz8Jy3w0p3ARDRS1weQhdfBo2azeExeI-jF3fNkw&oe=66DEE2C7"}, "display_name": "Drum Legend", "keywords": [], "long_description": "We proudly launch Drum Legend 2.0 !\n\nThe game now support Custom Songs!\nVisit our Discord for Import Guide and get the Song Editor.\nDiscord\uff1ahttps://discord.gg/CdCkmZ6UJ5\n\nDrum Legend is a music rhythm game with multiple drumming gameplay options. In the 'Drum Maestro' mode,you can simulate a band drummer ,learn a variety of drumming skills, and play your favorite music.In the 'Rhythm Rush' mode, challenge yourself with more difficult tracks, aim for higher scores. \n\n- Drum Maestro:\nSimulate playing the drum kit and get a taste of being in a band!\nThis mode comes with a certain level of difficulty. If you haven't played the drum kit before, you can start practicing with the 'Practice Album' song pack.\nEnjoy a refined drumming experience with professionally designed drum charts, gradually becoming a VR Soulful Drummer.\n\n- Rhythm Rush:\nDon't make any miss, smash all notes accurately!\nThis mode is easy to pick up, but achieving SSS ranks or challenging level 9+ tracks requires continuous practice.\nEvery season, we release new featured song packs with meticulously designed music and charts for an exhilarating rhythmic experience.\n\nWe are a pioneering team dedicated to exploring new music entertainment experiences in the XR world. 'Drum Legend' is our first music rhythm application, and we welcome your feedback to help us improve the product experience.\n\nDiscord\uff1ahttps://discord.gg/CdCkmZ6UJ5\n", "short_description": "Drum Legend is a music rhythm game with multiple drumming gameplay options. In the 'Drum Maestro' mode,you can simulate a band drummer ,learn a variety of drumming skills, and play your favorite music.In the 'Rhythm Rush' mode, challenge yourself with more difficult tracks, aim for higher scores. "}]}, "developer_name": "Shanghai Magibeat Technology Co., Ltd.", "developer_privacy_policy_url": "https://mqvwzgqbgw.feishu.cn/docx/TroodKHf0orxRqxcuW4ce6ninMg?from=from_copylink", "developer_terms_of_service_url": null, "publisher_name": "Shanghai Magibeat Technology Co., Ltd.", "support_website_url": null, "website_url": "https://www.magibeat.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["MUSIC", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "zh_HK", "zh_TW"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "24383457334635883"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031653_721822433175968_7145545796919010178_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hkTBKSwa2_MQ7kNvgH44usH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5ucoKhJ-