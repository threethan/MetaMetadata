5xFzxHDzJUh-GJyUipNkNjw3wNcmi-w&oe=66FFDC05"}, {"file_name": "X8_Screeshot_3.png", "id": "1040455070484569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974675_1040455073817902_5952188263882058155_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YVpPnRqO7wQQ7kNvgGHC80e&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMoh-qQQOv4ItqJOpb2apTlTS1xtsnfEzo-8CAZHkg2A&oe=66FFBEEB"}, {"file_name": "X8_Screeshot_4.png", "id": "874489511016763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429286_874489514350096_4682216129783741819_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LTkc8fK3MUoQ7kNvgFFesw_&_nc_ht=scontent.oculuscdn.com&oh=00_AYCjYcdFALPPxxdsNNob7o_LVuXpAy-d68Is7GxBNXc-kQ&oe=66FFBE59"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sBpNgN6N-10Q7kNvgFZQa2j&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-3Og_lwGbAIzu8FxMhUkAI3a0KeV5Hen4VaieOkSkTg&oe=66FFDD46"}, "display_name": "X8 Japan Only Version", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "Notice: This app is only available for players in the Japan region. The ability to play with other regions is not affected by downloading this version.\n\nThe next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "pub_X8_mobileIcon_512x512_JapaneseVersion_EN.png", "id": "1450599135831858", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982572_1450599139165191_346366013348741175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=os67Yz8dgcUQ7kNvgFTG1GZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDopwxvdkCCUG8kTa9mzuwYI-EY465AKZwWa7e5VZYMWw&oe=66FFE53B"}, {"file_name": "pub_X8_Portrait_1008x1440_JapaneseVersion_EN.png", "id": "1109869060134850", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974831_1109869063468183_5181508584830529846_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QmApnIYgTEAQ7kNvgGXGNfd&_nc_ht=scontent.oculuscdn.com&oh=00_AYACP4uEg0hEfZLsX60pnmwDEujaT1CPpP-zTU_SmTlNqg&oe=66FFE1F8"}, {"file_name": "pub_x8_Logo_556x164 (1).png", "id": "1048228632988358", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031376_1048228636321691_7456933450426039179_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Oa9WIOg2joQ7kNvgEJLx1b&_nc_ht=scontent.oculuscdn.com&oh=00_AYCowCZDyuYd7b38tLpmpRufMZ5mPhVEPO51KBN1pNSmPQ&oe=66FFEFDB"}, {"file_name": "pub_X8_Hero_3000x900_JapaneseVersion_EN.png", "id": "1034034371442143", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422384_1034034374775476_4878743714299508484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lSWnMXnbnkMQ7kNvgH7hDeY&_nc_h