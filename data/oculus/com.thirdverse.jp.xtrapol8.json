r": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0N6XmiepSBAQ7kNvgGRkZuT&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCfNtrLBE6fNruQcHnsOlZ6vxda2GCzRnUp6x9udFOWYw&oe=672A0D46"}, "display_name": " X8\uff08\u30a8\u30c3\u30af\u30b9\u30a8\u30a4\u30c8\uff09", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/privacy-policy", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://playx8vr.com/", "category": "GAMES