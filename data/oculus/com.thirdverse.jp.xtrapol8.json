o5JxncXv-px11epEF-aAoJ_POQevqxx6BlzNw&oe=66DC4385"}, {"file_name": "X8_Screeshot_3.png", "id": "1040455070484569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974675_1040455073817902_5952188263882058155_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FS70Lpqnt_QQ7kNvgEs5iva&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJ6S8XS5m92EHzTFqKRoUQlN2V0tFsnIdmLkk5lOPU1Q&oe=66DC266B"}, {"file_name": "X8_Screeshot_4.png", "id": "874489511016763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429286_874489514350096_4682216129783741819_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jElAUINOhFsQ7kNvgG401xO&_nc_ht=scontent.oculuscdn.com&oh=00_AYC3S5aWmHa3UjptxwPr15pn7bZiNCk3mwVwRCepRliU2w&oe=66DC25D9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U-OpQpciq_wQ7kNvgES8-nB&_nc_ht=scontent.oculuscdn.com&oh=00_AYAEoMVBEfZ8LpSxaazHJSvavRsoZoxriwmjDUTiGWv_yg&oe=66DC44C6"}, "display_name": "X8 Japan Only Version", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "Notice: This app is only available for players in the Japan region. The ability to play with other regions is not affected by downloading this version.\n\nThe next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "pub_X8_mobileIcon_512x512_JapaneseVersion_EN.png", "id": "1450599135831858", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982572_1450599139165191_346366013348741175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G15mWVZ42uYQ7kNvgHTp5cX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDSkb5graHsPpSwgWlR9kSxiQnAFzt-yO9qY_dpPUGJOw&oe=66DC4CBB"}, {"file_name": "pub_X8_Portrait_1008x1440_JapaneseVersion_EN.png", "id": "1109869060134850", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974831_1109869063468183_5181508584830529846_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z_eH-M8qLgwQ7kNvgE2HSL4&_nc_ht=scontent.oculuscdn.com&oh=00_AYBhQu_xD9KKy_8fHKqXAVmAnINHh_D-EYGN2bt3ndW2Hw&oe=66DC4978"}, {"file_name": "pub_x8_Logo_556x164 (1).png", "id": "1048228632988358", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031376_1048228636321691_7456933450426039179_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DqzJOkRbYpkQ7kNvgG6_nts&_nc_ht=scontent.oculuscdn.com&oh=00_AYB_Oc9PcMb2vLluAA1Ud7dXDe5Io4Hqv4zYNUnx_XCViQ&oe=66DC1F1B"}, {"file_name": "pub_X8_Hero_3000x900_JapaneseVersion_EN.png", "id": "1034034371442143", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422384_1034034374775476_4878743714299508484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ohju8qMzv7sQ7kNvgHBoDuN