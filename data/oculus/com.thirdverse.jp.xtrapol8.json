WaGan2tZ7tdXom4PFOs5FBzhNGyvDDpNb9Bow&oe=66CF1485"}, {"file_name": "X8_Screeshot_3.png", "id": "1040455070484569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974675_1040455073817902_5952188263882058155_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r69TZgpomoQQ7kNvgFpowLP&_nc_ht=scontent.oculuscdn.com&oh=00_AYC4ZdP1R32mGXsw0k4LAMhcU3tR5o0VIWU_8l4CobaXGQ&oe=66CEF76B"}, {"file_name": "X8_Screeshot_4.png", "id": "874489511016763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429286_874489514350096_4682216129783741819_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-7klofc6o7AQ7kNvgF07dRo&_nc_ht=scontent.oculuscdn.com&oh=00_AYCTyqAAuKYnKPsUfTovIP6Nq1aFr7v-GGw43NSthhB7KA&oe=66CEF6D9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nhi9EL_HT1kQ7kNvgGAaN1J&_nc_ht=scontent.oculuscdn.com&oh=00_AYDthr7TDy4N8M5PCmVyJjEgWa6r0iLUPLdqJi_iuv2hCQ&oe=66CF15C6"}, "display_name": "X8 Japan Only Version", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "Notice: This app is only available for players in the Japan region. The ability to play with other regions is not affected by downloading this version.\n\nThe next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "pub_X8_mobileIcon_512x512_JapaneseVersion_EN.png", "id": "1450599135831858", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982572_1450599139165191_346366013348741175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=44JhMOgx9AUQ7kNvgGwMiz0&_nc_ht=scontent.oculuscdn.com&oh=00_AYDL8fS8sSF35MvR5MZVU28NYtUP4P3-2kqWah58K1PyLA&oe=66CF1DBB"}, {"file_name": "pub_X8_Portrait_1008x1440_JapaneseVersion_EN.png", "id": "1109869060134850", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974831_1109869063468183_5181508584830529846_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nfuxQ6hRohkQ7kNvgHPFxgW&_nc_ht=scontent.oculuscdn.com&oh=00_AYAcpIwX2MbVGGnDqA10eFWKtEquk6HoZxAvJbrqyoFUnw&oe=66CF1A78"}, {"file_name": "pub_x8_Logo_556x164 (1).png", "id": "1048228632988358", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031376_1048228636321691_7456933450426039179_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_LjLcw4UdyoQ7kNvgFxA7cM&_nc_ht=scontent.oculuscdn.com&oh=00_AYAsk-HxMUNL9cHy2NU_UJbX_E67U8Y1Sxx0fY6DH_XImQ&oe=66CEF01B"}, {"file_name": "pub_X8_Hero_3000x900_JapaneseVersion_EN.png", "id": "1034034371442143", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422384_1034034374775476_4878743714299508484_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sxTQ0DQeSgcQ7kNvgFixOpi