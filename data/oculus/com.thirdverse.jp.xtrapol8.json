FwEIGW8kElUQ7kNvgF8p5Qw&_nc_ht=scontent.oculuscdn.com&oh=00_AYDmwMKqUf6_sUlc5yXoj2hIwvVnqq4x0w6WQAc0mCeQNA&oe=66F7D559"}, {"file_name": "X8_Screeshot_5.png", "id": "876296407181897", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195908_876296410515230_3075551154467889785_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SlLqn-TDgUYQ7kNvgFoT4g5&_nc_ht=scontent.oculuscdn.com&oh=00_AYC0JUc9a2HREYCD1ZhW5FfBeCya_XhxcAtLYXVJcTy2Ig&oe=66F7D701"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hCXaZZM2AnAQ7kNvgHYO9PZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYAszXr8obm254Ob5mzksN1A7a5CMZjD2UIaHnCd13ecrg&oe=66F7F446"}, "display_name": " X8\uff08\u30a8\u30c3\u30af\u30b9\u30a8\u30a4\u30c8\uff09", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "The next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thirdverse.io/privacy-policy", "developer_terms_of_service_url": "https://www.thirdverse.io/ja/terms-of-service", "publisher_name": "Thirdverse, Co., Ltd.", "support_website_url": null, "website_url": "https://playx8vr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER", "ACTION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "ja", "ko", "es"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "6691859974223249"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8105371009538798", "version": "0.1.20979"}, "id": "1058397751959211", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6691859957556584", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8105371009538798"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727124661