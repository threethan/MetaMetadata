vgEIBJhK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYClUzAmfXCKvq_N2TMVQlKg6coBp9FfjjHdPC1om5gP0A&oe=66E03E9B"}, {"file_name": "X8_Screeshot_2.png", "id": "278632141241417", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974523_278632144574750_5812622351914226576_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NxMNjJHKkZIQ7kNvgEaAjCJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYBRaeztWxsPdioohcEO93pzLsWNQcCGKqyELqSztipk2w&oe=66E03805"}, {"file_name": "X8_Screeshot_3.png", "id": "1040455070484569", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974675_1040455073817902_5952188263882058155_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dIG524LVDxIQ7kNvgGy1qC8&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYAoHFoXFA7QfKn8vhQqwkf7Uxife9pRf6QPKZazvelFsw&oe=66E01AEB"}, {"file_name": "X8_Screeshot_4.png", "id": "874489511016763", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75429286_874489514350096_4682216129783741819_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CQ5tE5J_P50Q7kNvgGP2DKi&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYDy39NbpAw4P13lUqXuv-I549d6fchKLRwpMqhiaYlP2w&oe=66E01A59"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cVIXb_WNh7AQ7kNvgFY_bbG&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYCGoCi5TggoO-LzCFbN_g_BYHPgD-mZQcdI-MF04ck91g&oe=66E03946"}, "display_name": "X8 Japan Only Version", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "Notice: This app is only available for players in the Japan region. The ability to play with other regions is not affected by downloading this version.\n\nThe next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "pub_X8_mobileIcon_512x512_JapaneseVersion_EN.png", "id": "1450599135831858", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982572_1450599139165191_346366013348741175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=al0XyiqOnmYQ7kNvgELTHOn&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYDOlSoYxEE9YSMcWDO6mhrDOj2P4jzDY74PJ_lMuNDGRA&oe=66E0413B"}, {"file_name": "pub_X8_Portrait_1008x1440_JapaneseVersion_EN.png", "id": "1109869060134850", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974831_1109869063468183_5181508584830529846_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tg0tBWyPJKkQ7kNvgHyh3jk&_nc_ht=scontent.oculuscdn.com&_nc_gid=A95ihf7YM8dgPUlRYWdn8lq&oh=00_AYBROkED07l-a_fWn5n52-yiaOBKnZ2OpY0NYaHLCiv3vA&oe=66E03DF8"}, {"file_name": "pub_x8_Logo_556x164 (1).png", "id": "104822863298835