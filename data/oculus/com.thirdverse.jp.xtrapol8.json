n.com/v/t64.5771-25/38974523_278632144574750_5812622351914226576_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UPmRVOr7rXYQ7kNvgFSio1i&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAnTpg6XFh7FB0bNUkqxM9ZhIvVhTKvNLfkD8vSBqvT4g&oe=67012D85"}, {"file_name": "X8_Screeshot_3.png", "id": "1040455070484569", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974675_1040455073817902_5952188263882058155_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YVpPnRqO7wQQ7kNvgHSpi54&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDmlP2vG2QmHuaC6nzJ-UrbcC5HXjc8DLYnz28kWym8bQ&oe=6701106B"}, {"file_name": "X8_Screeshot_4.png", "id": "874489511016763", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75429286_874489514350096_4682216129783741819_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LTkc8fK3MUoQ7kNvgF1_xR9&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCnef32yqXDzN955FAdIdQDOgxPNZR37mRWqSFGmgqx-Q&oe=67010FD9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "pub_X8_Landscape_2560x1440.png", "id": "1506605506773756", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974734_1506605510107089_8692912931667106540_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OFDvE-F1xKcQ7kNvgGDoeMD&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBITqcSf6AU0r9Rpf2R2pMoF52W1L65rra3FOYnlf6muw&oe=67012EC6"}, "display_name": "X8 Japan Only Version", "keywords": ["free", "shooter", "pvp", "fps", "hero"], "long_description": "Notice: This app is only available for players in the Japan region. The ability to play with other regions is not affected by downloading this version.\n\nThe next generation in Hero Shooters is FREE TO PLAY\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds.\n\nFORCE MULTIPLY!\nSynergize your gunplay with versatile hero abilities -- activate turrets, tripwires, smokes and more; customize your loadout with an arsenal of weapons and armor to gain the competitive edge.\n\nMASTER DEMOLITION MODE!\nTake turns to Attack and Defend by planting or defusing the Syphon across maps designed to test your creative strategies. Show off your skills and conquer your opponents on the battlefield.\n\nThe arena is set. Fighting is the only way out.\nAre you up to the challenge?", "short_description": "X8 is the FREE TO PLAY next generation Hero Shooter!\n\nExecuting its directive to assemble worthy opponents, the rogue mod X8 has collected characters from across different game franchises. Players embody a variety of heroes and engage in 5v5 VR battles to restore a path back to their worlds."}, {"images": {"nodes": [{"file_name": "pub_X8_mobileIcon_512x512_JapaneseVersion_EN.png", "id": "1450599135831858", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982572_1450599139165191_346366013348741175_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=os67Yz8dgcUQ7kNvgET8_2-&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD3HxZGkAQURMfrrJzSeM_ciGw7A5BiQrK5ebDkUrEgfw&oe=670136BB"}, {"file_name": "pub_X8_Portrait_1008x1440_JapaneseVersion_EN.png", "id": "1109869060134850", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974831_1109869063468183_5181508584830529846_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CsJtd8OEnREQ7kNvgHlUGf8&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAODnFqJvrxxyCPB2xAS-Kfg4D0W8xtmMA9ar_096jPNw&oe=67013378"}, {"file_name": "pub_x8_Logo_556x164 (1).png", "id": "1048228632988358", "image_type": "APP_IMG_IMMERSIVE_LAYER_LOGO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031376_1048228636321691_7456933450426039179_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8Oa9WIOg2joQ7kNvgEwwmfc&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCj4Bjj8SaKB_Phs2lqf_aJQiFRGJIX5-8HgNnaC15TvQ&oe=6701415B"}, {"file_name": 