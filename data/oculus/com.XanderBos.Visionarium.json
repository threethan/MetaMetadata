 quest 2 is a psychedelic audio-driven visual spectacle. Enter this artistic VR experience that takes you on an immersive journey through mystical realms. Come out on the other side, transformed, in awe."}]}, "developer_name": "Sander Bos", "developer_privacy_policy_url": "https://www.sander-bos.nl/privacy", "developer_terms_of_service_url": null, "publisher_name": "Sander Bos", "support_website_url": null, "website_url": "https://sander-bos.nl/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "821316815620740"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1197375077651555"}]}, "baseline_offer": {"id": "1197375077651555"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1674147780, "status": "PUBLISHED", "id": "1197375077651555"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6202539089758468", "version": "13"}, "id": "3396212103958754", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6096590377020007", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6202539089758468"}, "release_status": "RELEASED"}, "binary_release