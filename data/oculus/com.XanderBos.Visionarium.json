3298477_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NBls_LU3XMYQ7kNvgFQT5-8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB9RJpN9qXJFAZWY2aomiWcOWi5gsNuGPAb76H0SJSgnQ&oe=6783B1A0"}, {"file_name": "screenshots4.png", "id": "742815200175052", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_742815203508385_4141576407430143694_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VI9ndyCg7S8Q7kNvgFKGgZv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBsTSe3NMjl8317shnl79IHR5CuaCBQ9WbWy8ZL6HfpXw&oe=6783A95B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshots4.png", "id": "899765744797476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974807_899765748130809_6083189611760282390_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CX681ooNmCEQ7kNvgFESqF0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA-efsCkL6cK3sdTcdsoDdhZ-bIZhfCVdVTSgASlesPvg&oe=6783A161"}, "display_name": "Visionarium", "keywords": [], "long_description": "The visionary journey continues! Visionarium  is a follow up VR experience by multimedia artist and solo indie developer Sander Bos Now available for quest.\n\nThis audio driven journey features an archetypal mystical experience, inviting the player to surrender to the darkness as a way to break through and enter visionary states.\n\nMost of the artwork is painted in Tiltbrush and other VR creation tools, trying to make the most out of VR as a new artform.\n\nPlease note that this release of Visionarium is developed for quest 2 and is a different experience then its previous release for other headsets. \n\nFeaturing music tracks from  Kaminanda, Kalya Scintilla and Dreamstate Logic.", "short_description": "Visionarium for quest 2 is a psychedelic audio-driven visual spectacle. Enter this artistic VR experience that takes you on an immersive journey through mystical realms. Come out on the other side, transformed, in awe."}]}, "developer_name": "Sander Bos", "developer_p