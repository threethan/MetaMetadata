3298477_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bMx0iaMN-7YQ7kNvgHg_K6N&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAk9iD1NOcoOSeKawjHctT8XE47Ryw63YQaWHywb0X7ng&oe=674469A0"}, {"file_name": "screenshots4.png", "id": "742815200175052", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_742815203508385_4141576407430143694_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NdXXdUchDOcQ7kNvgH1st7L&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYANino_2NjYIFcuUZWtr_HhTSUbbc-QuSsgDqAgIb9d1A&oe=6744615B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshots4.png", "id": "899765744797476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974807_899765748130809_6083189611760282390_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4W2RdLR3rscQ7kNvgFbRQ2d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCgcVYBCgVlHu7Jk7bltTEyUqFDO1ETdvjCIF74etZETA&oe=67445961"}, "display_name": "Visionarium", "keywords": [], "long_description": "The visionary journey continues! Visionarium  is a follow up VR experience by multimedia artist and solo indie developer Sander Bos Now available for quest.\n\nThis audio driven journey features an archetypal mystical experience, inviting the player to surrender to the darkness as a way to break through and enter visionary states.\n\nMost of the artwork is painted in Tiltbrush and other VR creation tools, trying to make the most out of VR as a new artform.\n\nPlease note that this release of Visionarium is developed for quest 2 and is a different experience then its previous release for other headsets. \n\nFeaturing music tracks from  Kaminanda, Kalya Scintilla and Dreamstate Logic.", "short_description": "Visionarium for quest 2 is a psychedelic audio-driven visual spectacle. Enter this artistic VR experience that takes you on an immersive journey through mystical realms. Come out on the other side, transformed, in awe."}]}, "developer_name": "Sander Bos", "developer_p