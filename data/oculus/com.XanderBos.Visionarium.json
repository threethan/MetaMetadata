3298477_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=huI2meJFFmoQ7kNvgH9nv1q&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBahM7WqMY_1Qz-yZB08F0956fEOezYHge8gf2rxm6cbA&oe=673497A0"}, {"file_name": "screenshots4.png", "id": "742815200175052", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982685_742815203508385_4141576407430143694_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4wNzGLrQKZIQ7kNvgHLCsWI&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC9P65rC1D4Two7Qvx2bx5yzu8T1ZguKBSHSpQ3rTxGQA&oe=67348F5B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshots4.png", "id": "899765744797476", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974807_899765748130809_6083189611760282390_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-E2HubBnDDIQ7kNvgHx3CTe&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDlu44G8iZO3t3y4ZOa8nFl3rmHqYuGhVAFaOwJKzYBoQ&oe=67348761"}, "display_name": "Visionarium", "keywords": [], "long_description": "The visionary journey continues! Visionarium  is a follow up VR experience by multimedia artist and solo indie developer Sander Bos Now available for quest.\n\nThis audio driven journey features an archetypal mystical experience, inviting the player to surrender to the darkness as a way to break through and enter visionary states.\n\nMost of the artwork is painted in Tiltbrush and other VR creation tools, trying to make the most out of VR as a new artform.\n\nPlease note that this release of Visionarium is developed for quest 2 and is a different experience then its previous release for other headsets. \n\nFeaturing music tracks from  Kaminanda, Kalya Scintilla and Dreamstate Logic.", "short_description": "Visionarium for quest 2 is a psychedelic audio-driven visual spectacle. Enter this artistic VR experience that takes you on an immersive journey through mystical realms. Come out on the other side, transformed, in awe."}]}, "developer_name": "Sander Bos", "developer_p