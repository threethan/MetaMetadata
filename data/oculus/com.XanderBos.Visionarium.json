3298477_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3_J9WocmzyQQ7kNvgEQtlut&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBzKVLCXByeA6ET07_Xzc4ikj-JRBibTLRtihOntxDy_A&oe=67504720"}, {"file_name": "screenshots4.png", "id": "742815200175052", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982685_742815203508385_4141576407430143694_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K-BzYaielRgQ7kNvgGkN4pP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZoMfM77ooErsKDpNxZaTJHTGpKYPluSESt1PSKyDxQg&oe=67503EDB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screenshots4.png", "id": "899765744797476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974807_899765748130809_6083189611760282390_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hdz1qfacQ8oQ7kNvgEVo3Ec&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnVD-x5O6nevyBq4luTZ1HLjmURFPCpH5CQa1syTnV7w&oe=675036E1"}, "display_name": "Visionarium", "keywords": [], "long_description": "The visionary journey continues! Visionarium  is a follow up VR experience by multimedia artist and solo indie developer Sander Bos Now available for quest.\n\nThis audio driven journey features an archetypal mystical experience, inviting the player to surrender to the darkness as a way to break through and enter visionary states.\n\nMost of the artwork is painted in Tiltbrush and other VR creation tools, trying to make the most out of VR as a new artform.\n\nPlease note that this release of Visionarium is developed for quest 2 and is a different experience then its previous release for other headsets. \n\nFeaturing music tracks from  Kaminanda, Kalya Scintilla and Dreamstate Logic.", "short_description": "Visionarium for quest 2 is a psychedelic audio-driven visual spectacle. Enter this artistic VR experience that takes you on an immersive journey through mystical realms. Come out on the other side, transformed, in awe."}]}, "developer_name": "Sander Bos", "developer_p