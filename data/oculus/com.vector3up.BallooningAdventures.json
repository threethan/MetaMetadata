"id": "212859093285900", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410461_1703915193259196_77303351129145344_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=psEjCOj9UgEQ7kNvgEcqcXh&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoq0Lu4yZkyjySH3H1GR7OP&oh=00_AYCG0nsp5rqWsT_1H0-jlwA1pB6VshN6DlYokwVd5OW0QA&oe=66E18B89"}, {"file_name": "migrated_image.png", "id": "252458705909036", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482342_352008968508909_6411536963404300288_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hs1FeYiVqkgQ7kNvgHgMRCL&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoq0Lu4yZkyjySH3H1GR7OP&oh=00_AYCgOhNXZMlDaHt09PSMRihRLciuat30yoLuj6i2UAlalg&oe=66E1926D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "StoreCoverArt_2560x1440.png", "id": "369902480024073", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410454_369902483357406_2751058636217253888_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ExjxiumOTTEQ7kNvgFBO_ab&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aoq0Lu4yZkyjySH3H1GR7OP&oh=00_AYC67MTwYQtRKcDtv3Ba4QkwM15Q3YmB75KDbAmEDhKfbA&oe=66E18554"}, "display_name": "Ballooning Adventures", "keywords": ["balloon", "simulator", "flight", "relaxing", "beautiful"], "long_description": "Take to the skies in a hot air balloon and explore a vast beautiful landscape. Ballooning Adventures has been specially developed for Gear VR. Using the built in touchpad or a gamepad, pilot your balloon through breathtaking scenery. Find all of the secrets and explore all three realms. An uplifting soundtrack will accompany you through this dreamlike experience. After a while you will become an expert balloon pilot, accurately triggering each collectable. Fly thousands of feet up, find your target then swoop down to skim across the fields and drift through narrow canyons. Ballooning Adventures employs a vectored thrust and drift mechanic that combines the gentleness of balloon fight with a steerable and intuitive control.\n\nPlay to relax and escape, or complete all missions and 100% the game. ", "short_description": "Take to the skies in a hot air balloon and explore a vast beautiful landscape."}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.vector3up.co.uk/ballooning-adventures-privacy-policy.html", "developer_terms_of_service_url": "http://www.vector3up.co.uk/ballooning-adventures-terms-of-service.html", "publisher_name": "Vector3Up", "support_website_url": null, "website_url": "http://www.vector3up.co.uk/ballooningadventures.html", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ACTION", "ARCADE", "EXPLORATION", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "940564779914751"}}]}, "scheduled_offers": {"count": 17, "nodes": [{"status": "PUBLISHED", "id": "259656324882884"}, {"status": "CANCELLED", "id": "137357633633506"}, {"status": "PUBLISHED", "id": "600512116812022"}, {"status": "PUBLISHED", "id": "1666083466852660"}, {"status": "PUBLISHED", "id": "1752302098399575"}, {"status": "PUBLISHED", "id": "547260666121373"}, {"status": "CANCELLED", "id": "398232740610190"}, {"status": "PUBLISHED", "id": "965443500291894"}, {"status": "PUBLISHED", "id": "623074448037851"}, {"status": "PUBLISHED", "id": "564580990680905"}, {"status": "PUBLISHED", "id": "310804633022272"}, {"status": "PUBLISHED", "id": "150669688981983"}, {"status": "PUBLISHED", "id": "2152167341696432"}, {"status": "PUBLISHED", "id": "2182044268690439"}, {"status": "PUBLISHED", "id": "1742476219146775"}, {"status": "PUBLISHED", "id": "152323465595070"},