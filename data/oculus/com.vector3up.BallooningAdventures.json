nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OjMhMxoHZJgQ7kNvgFkWvIL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfxO35IQm79shI33ZsSTEa_&oh=00_AYDbyg6ormm9E9HjYnpmAyGwK34YpW9RFt30BM6i8UbjSw&oe=66F3E0A9"}, {"file_name": "Screenshot_Low_Wide_2560x1440.png", "id": "441069600581684", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974827_441069603915017_6275985623359077382_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VUUqeHGCiP0Q7kNvgFQ2BdH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfxO35IQm79shI33ZsSTEa_&oh=00_AYDzoCQGE4mjAGN2q0qVWkWx1rjiJXeXqMAzBHqljaA3Gw&oe=66F3D8AD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "StoreCoverArt_2560x1440.png", "id": "326566892052330", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982584_326566895385663_4441488385814727431_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1JJBIeZ68eMQ7kNvgH5yEWk&_nc_ht=scontent.oculuscdn.com&_nc_gid=AfxO35IQm79shI33ZsSTEa_&oh=00_AYCwsiFwX9MNdEXwW-U2Oj0iGFM7FVqOg8vxdoZDe7LUMQ&oe=66F3E58E"}, "display_name": "Ballooning Adventures", "keywords": [], "long_description": "Take to the skies in a hot air balloon and explore a vast beautiful landscape. Pilot your balloon through breathtaking scenery. Find all of the secrets and explore all three realms. An uplifting soundtrack will accompany you through this dreamlike experience. After a while you will become an expert balloon pilot, accurately triggering each collectible. Fly thousands of feet up, find your target then swoop down to skim across the fields and drift through narrow canyons. Ballooning Adventures employs a vectored thrust and drift mechanic that combines the gentleness of balloon fight with a steerable and intuitive control.\n\nPlay to relax and escape, or complete all missions and 100% the game. ", "short_description": "Take to the skies in a hot air balloon and explore a vast beautiful landscape."}]}, "developer_name": null, "developer_privacy_policy_url": "https://63bf4148e3666.site123.me/", "developer_terms_of_servi