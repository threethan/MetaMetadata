_nc_gid=Abv4gxPOJXtIutOZdV8mPxQ&oh=00_AYCK6pvpx_J7uCHpHeaNHpxUnqfXLRyhGZ0jSEyt-muByA&oe=66E2EE60"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/pmAnrh", "id": "156014975921448", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371507_156014979254781_6908529318809305088_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lij7ViMVbiEQ7kNvgECe-si&_nc_ht=scontent.oculuscdn.com&_nc_gid=Abv4gxPOJXtIutOZdV8mPxQ&oh=00_AYA-ICgndse3tXF27uZBnPUJ82Iz9Az9YZCPHlUFFjPWxQ&oe=66E2C2B1"}, "display_name": "Space Junk", "keywords": ["space", "junk", "magnet", "debris", "shoot"], "long_description": "Space Junk is an arcade shooter where you blast garbage and magnetize metal trash into your ship!\n\nTake on the role of a Space Junk Operative and work in zero-gravity to clean up orbital debris!\n\n10 challenging stages. \n10 different music tracks.\nOver 30 minutes of original game play.\nPlay again to beat your high scores.\n\n\u201cThe year is 2054.  Orbital debris is at critical levels and someone must take action.  That someone is you!  Empty Space Incorporated was created to clean up all the space junk orbiting the planet and make a profit in the process.  Your training starts now.  Good luck, Space Junker.\"\n\n\nMade with Unity exclusively for Oculus Go.\n\nPlease leave review feedback so we can make improvements in future versions.\n\nLook out for more stages and new locations coming soon.", "short_description": "Shoot asteroids and collect space junk with a magnet!"}]}, "developer_name": "John Rowlands", "developer_privacy_policy_url": "http://www.cestriansoftware.com/space-junk/privacy-policy/", "developer_terms_of_service_url": "http://www.cestriansoftware.com/space-junk/licensing/", "publisher_name": "Cestrian Software", "support_website_url": null, "website_url": "http://www.cestriansoftware.com/space-junk/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "extern