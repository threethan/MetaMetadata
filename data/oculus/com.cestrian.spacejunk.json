e": "ScreenShot5.png", "id": "339808587315522", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031450_339808590648855_7348019694279176940_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zwKERTyhSBgQ7kNvgGhKzG3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxarJE00nVhCh3Z8UgAK_d_0DREtSlKJTpGrtwten8eA&oe=675995E7"}, {"file_name": "ScreenShot3.png", "id": "182597576594931", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974444_182597579928264_1491608471790034217_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rtpjgljoZZEQ7kNvgHW-Lic&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAiE6OTZdmBe8Dr-cTrC8yn6VZ9gHAmbm4jcDquahGzBQ&oe=6759887B"}, {"file_name": "ScreenShot4.png", "id": "147281473885122", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982441_147281477218455_2707899911583084471_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BroyaBoFv1oQ7kNvgHj5hME&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRrSDLzxKmUCVYtWNYEifskO5Si-hJINQ-7w3d7biAzg&oe=67598D05"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SpaceJunk-Landscape.png", "id": "466040047768418", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974591_466040051101751_162512089677994575_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RcYXM-9dHWoQ7kNvgGOJjtq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBI5z9YcjwOVk1PHtHpIKZayVlapqAfC_PhZmrmpy97aQ&oe=67597B50"}, "display_name": "Space Junk", "keywords": [], "long_description": "Space Junk is an arcade shooter where you blast garbage and magnetize metal trash into your ship!\n\nTake on the role of a Space Junk Operative and work in zero-gravity to clean up orbital debris!\n\n20 challenging stages.\n12 different music tracks.\nOver 45 minutes of original game play.\nPlay again to beat your high scores.\n\n\u201cThe year is 2054.  Orbital debris is at critical levels and someone must take action.  That someone is you!  Empty Space Incorporated was created to clean up all the space junk orbiting the planet and make a profit in the process.  Your training starts now.  Good luck, Space Junker.\"\n\nPlease leave review feedback and share what you think about Space Junk.  ", "short_description": "Shoot asteroids and collect space junk with a magnet!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.cestriansoftware.com/space-junk/privacy-policy/", "developer_terms_of_service_url": "http://www.cestriansoftware.com/space-junk/licensing/", "publisher_name": "Cestrian Software", "support_website_url": null, "website_url": "http://www.cestriansoftware.com/space-junk/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "976778066586070"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "274568514002246"}, {"status": "PUBLISHED", "id": "728960324876554"}]}, "baseline_offer": {"id": "728960324876554"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1618295400, "status": "PUBLISHED", "id": "274568514002246"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5263254343795347", "version": "1.4"}, "id": "345377706662359", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary