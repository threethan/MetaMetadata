991285612662_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YTfmYDlwJzYQ7kNvgECZXSZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKxMiHV2I62BM7y-dZsiXBM&oh=00_AYDtmMZ3hbFgUqq5ugnsw-_Pb6sXeoVpl-NkmoHrUgeoBg&oe=66EC1799"}, {"file_name": "20190117_025255.png", "id": "2815766318741083", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75375083_2815766322074416_3388905810994569704_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HKep_HADzUcQ7kNvgGWqGN3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKxMiHV2I62BM7y-dZsiXBM&oh=00_AYDd8DL6hiSm5h6dBR4vKCg313QzmYdQ4e5KEL8JP2GHvg&oe=66EC1B99"}, {"file_name": "select2.png", "id": "360852952275944", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974673_360852955609277_289561917377990546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w_6fAz5c_DQQ7kNvgESXybo&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKxMiHV2I62BM7y-dZsiXBM&oh=00_AYChGDR9y6r4MhZ9rU-eP-HTC3vXyXMLbJxbKUs4nw1q8A&oe=66EC1670"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "walkable360applab_16x9.png", "id": "2928143990796935", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222945_2928143994130268_4675042322529854180_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TIDjJOVkm-gQ7kNvgGZ8L7f&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKxMiHV2I62BM7y-dZsiXBM&oh=00_AYDvJWlgdCVAs7WmJzKkOjNPwEeWBspdeKyvyPh6EqGZ_A&oe=66EBFAA3"}, "display_name": "Walkable 360 Video", "keywords": [], "long_description": "You can experience VR video as real as ever!\nVR usually cannot close up or walk around because there is some gaps between a point where a player stands and a ground which 360 degree footage shows.  However, this new VR called \"Walkable 360 Video\", you can walk around as if you were there because it creates three dimension not using Stereo Panorama which takes photo with two lenses like our eyes so that it depicts as if you are seeing 3D picture or photogrammetry.\n\n\u25a0Operation Method\nTouch Controller\n  Menu button...Display menu\n  Right hand trigger...Select\n\nHand Tracking\n  Look at your raised palm and pinch...Display menu\n  Pinch with your right hand...Select", "short_description": "You can enjoy experience walking around through 360 degrees view."}]}, "developer_name": null, "developer_privacy_policy_url": "https://w360v.forgevision.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "ForgeVision", "support_website_url": null, "website_url": "https://w360v.forgevision.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["ja", "en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1712407615928294"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195904_1405343146469944_8168917841517985146_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=almq9k3iUGoQ7kNvgHsWyxO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AKxMiHV2I62BM7y-dZsiXBM&oh=00_AYDuCk7zIlZe5Aa9FhTOH6NwwHoxWrOC10AxZ6Ztk5eRzw&oe=66EC2389"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Walkable 360 Video", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Travel & Exploration", "id": "726368587961803"}], "release_date": 1623452448, "lastRevision": {"nodes": [{"id": "5623614957656579", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_m