_sid=6e7a0a&_nc_ohc=dqClVpdGOuIQ7kNvgHyeXNP&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAab1HKSFZwlB5UN0I_ShtfM7BJbrwlTzjfZwaQcHQI5Q&oe=670A6E19"}, {"file_name": "select2.png", "id": "360852952275944", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974673_360852955609277_289561917377990546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2UU2ViDB1q8Q7kNvgFFqfoa&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBpPKdgk53YhpYJS7esvN9jBnS0OK9O1jySHatsZVZxw&oe=670A68F0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "walkable360applab_16x9.png", "id": "2928143990796935", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222945_2928143994130268_4675042322529854180_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WpsIvqfRbEIQ7kNvgH4VIP4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCAo7iltDfAZqd32yw3noxDvBjnpAatZLkcu4rGY9-w_Q&oe=670A4D23"}, "display_name": "Walkable 360 Video", "keywords": [], "long_description": "You can experience VR video as real as ever!\nVR usually cannot close up or walk around because there is some gaps between a point where a player stands and a ground which 360 degree footage shows.  However, this new VR called \"Walkable 360 Video\", you can walk around as if you were there because it creates three dimension not using Stereo Panorama which takes photo with two lenses like our eyes so that it depicts as if you are seeing 3D picture or photogrammetry.\n\n\u25a0Operation Method\nTouch Controller\n  Menu button...Display menu\n  Right hand trigger...Select\n\nHand Tracking\n  Look at your raised palm and pinch...Display menu\n  Pinch with your right hand...Select", "short_description": "You can enjoy experience walking around through 360 degrees view."}]}, "developer_name": null, "developer_privacy_policy_url": "https://w360v.forgevision.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "ForgeVision", "support_website_url": null, "website_url": "https://w360v.forgevision.com/", "