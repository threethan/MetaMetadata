FB019"}, {"file_name": "20190117_025255.png", "id": "2815766318741083", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75375083_2815766322074416_3388905810994569704_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IUVv4fSR_RsQ7kNvgGcTHaV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDIU5v3lrnRB2wkORXIi9H-7e6N3RQh9l75fr8PDNm45g&oe=670FB419"}, {"file_name": "select2.png", "id": "360852952275944", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974673_360852955609277_289561917377990546_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cm3bf6TOpY4Q7kNvgH2D5uo&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD8kydiTi09WrudULIlsRxO5cmzsyzr0n_7vjuNEZhIoQ&oe=670FAEF0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "walkable360applab_16x9.png", "id": "2928143990796935", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75222945_2928143994130268_4675042322529854180_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dc510mObisgQ7kNvgFhumSE&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDgH87jme41ly10ZQWCWsH3fr-6wP7J-PZCmEZZ6tKZjg&oe=670F9323"}, "display_name": "Walkable 360 Video", "keywords": [], "long_description": "You can experience VR video as real as ever!\nVR usually cannot close up or walk around because there is some gaps between a point where a player stands and a ground which 360 degree footage shows.  However, this new VR called \"Walkable 360 Video\", you can walk around as if you were there because it creates three dimension not using Stereo Panorama which takes photo with two lenses like our eyes so that it depicts as if you are seeing 3D picture or photogrammetry.\n\n\u25a0Operation Method\nTouch Controller\n  Menu button...Display menu\n  Right hand trigger...Select\n\nHand Tracking\n  Look at your raised palm and pinch...Display menu\n  Pinch with your right hand...Select", "short_description": "You can enjoy experience walking around through 360 degrees view."}]}, "developer_name": nul