7a0a&_nc_ohc=ZtueeaKd9QQQ7kNvgEurzZJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFkcC2dBhwZRUYuozJFSGwws6shTRwmC2esW1G0SVDJg&oe=66F94570"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "walkable360applab_16x9.png", "id": "2928143990796935", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75222945_2928143994130268_4675042322529854180_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BHdFP_Al-JQQ7kNvgE5G6Nr&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnZaq5aH05enm5aZ9XMZEgy0bewfWWT2KvCa_5-WKdGg&oe=66F929A3"}, "display_name": "Walkable 360 Video", "keywords": [], "long_description": "You can experience VR video as real as ever!\nVR usually cannot close up or walk around because there is some gaps between a point where a player stands and a ground which 360 degree footage shows.  However, this new VR called \"Walkable 360 Video\", you can walk around as if you were there because it creates three dimension not using Stereo Panorama which takes photo with two lenses like our eyes so that it depicts as if you are seeing 3D picture or photogrammetry.\n\n\u25a0Operation Method\nTouch Controller\n  Menu button...Display menu\n  Right hand trigger...Select\n\nHand Tracking\n  Look at your raised palm and pinch...Display menu\n  Pinch with your right hand...Select", "short_description": "You can enjoy experience walking around through 360 degrees view."}]}, "developer_name": null, "developer_privacy_policy_url": "https://w360v.forgevision.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "ForgeVision", "support_website_url": null, "website_url": "https://w360v.forgevision.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT"