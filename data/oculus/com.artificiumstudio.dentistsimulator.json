76"}, {"file_name": "A3.png", "id": "509012097783012", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974797_509012101116345_3769447530632067397_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GzHItBZg_H4Q7kNvgGRTwPa&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6sO52un4VK0lFonyrgM1JP&oh=00_AYDZd3jI7u45k-Gtd0uQQtdGPXTsAR9CfgC55JxNzTvlFg&oe=66E82253"}, {"file_name": "A4.png", "id": "529272851897969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_529272855231302_6722582152083879361_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nuc8miemcsoQ7kNvgE6G3OV&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6sO52un4VK0lFonyrgM1JP&oh=00_AYDyO_EZ2J-5tlLV6UWNjoOdPzkYtQpOzGBRLRDpcnPVvQ&oe=66E8116A"}, {"file_name": "A1.png", "id": "417074373961187", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_417074377294520_5021579418415336080_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9vNARozRFMMQ7kNvgF6BsKB&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6sO52un4VK0lFonyrgM1JP&oh=00_AYDFa2m4r7ALq2zxf8DkKM0OlbzdCpH2Syvo4lWdtgpbiw&oe=66E80A96"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_2560x1440_red.png", "id": "1802121196813645", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_1802121200146978_779631418884175797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wfi828zeQQ4Q7kNvgGlIpEd&_nc_ht=scontent.oculuscdn.com&_nc_gid=A6sO52un4VK0lFonyrgM1JP&oh=00_AYBhylaXOtoQXtzg4lcFaC8vjDwsHLutOcSFIddi8T2SmA&oe=66E807CE"}, "display_name": "Dentist Simulator", "keywords": [], "long_description": "Who has never been afraid to go to the dental office?\nBut now, it's your turn to be the dentist!\nSo get the anesthetic syringe and the pliers, because all the teeth will be yours.\nBut... watch out! Sharp instruments must be used wisely.\nSo, welcome to the most real and fun dentist simulator in the store!\nYou will have to apply anesthesia, cut and remove gums, extract one or more teeth,\nstop bleeding, and prescribe medication.\nSurely you are already able to perform these tasks, right? \nFrom now on it is you who will put your virtual hands inside the mouths of patients,\nBut, take it easy, so as not to leave them stressed or toothless.", "short_description": "Who has never been afraid to go to the dental office?\nBut now, it's your turn to be the dentist!\nSo get the anesthetic syringe and the pliers, because all the teeth will be yours.\nWelcome to the most real and fun dentist simulator in the store!\nYou will have to apply anesthesia, cut and remove gums, extract one or more teeth, stop bleeding, and prescribe medication.\nBut, take it easy, so as not to leave them stressed or toothless."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artificiumstudio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Artificium Studio", "support_website_url": null, "website_url": "https://artificiumstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "506905431403192"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "432987499192797"}, {"status": "PUBLISHED", "id": "1590193098171619"}, {"status": "PUBLISHED", "id": "629494775524241"}]}, "baseline_offer": {"id": "1590193098171619"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "432987499192797"}]}, "liveChan