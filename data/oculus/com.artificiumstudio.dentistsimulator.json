"}, {"file_name": "A4.png", "id": "529272851897969", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982727_529272855231302_6722582152083879361_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OzXWzL-17ZMQ7kNvgF_ehCU&_nc_ht=scontent.oculuscdn.com&oh=00_AYA96OGNclmRxEjDZflN6givxrHlun8mxH9G4a_OKfflOw&oe=66FD296A"}, {"file_name": "A1.png", "id": "417074373961187", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974493_417074377294520_5021579418415336080_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kveI0on8fTsQ7kNvgGujFXC&_nc_ht=scontent.oculuscdn.com&oh=00_AYA55D3klgQ8mqd7ot2TRPhIm8O_aBF_vmdtytRnwtF2Vg&oe=66FD2296"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "landscape_2560x1440_red.png", "id": "1802121196813645", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_1802121200146978_779631418884175797_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eoe7NvCKNV4Q7kNvgGXeUMJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDgCT07_NHQEIXGenMzWevFvOr8T7A93Ih-r-AnCbWvmw&oe=66FD1FCE"}, "display_name": "Dentist Simulator", "keywords": [], "long_description": "Who has never been afraid to go to the dental office?\nBut now, it's your turn to be the dentist!\nSo get the anesthetic syringe and the pliers, because all the teeth will be yours.\nBut... watch out! Sharp instruments must be used wisely.\nSo, welcome to the most real and fun dentist simulator in the store!\nYou will have to apply anesthesia, cut and remove gums, extract one or more teeth,\nstop bleeding, and prescribe medication.\nSurely you are already able to perform these tasks, right? \nFrom now on it is you who will put your virtual hands inside the mouths of patients,\nBut, take it easy, so as not to leave them stressed or toothless.", "short_description": "Who has never been afraid to go to the dental office?\nBut now, it's your turn to be the dentist!\nSo get the anesthetic syringe and the pliers, because all the teeth will be yours.\nWelcome to the most real and fun dentist simulator in the store!\nYou will have to apply anesthesia, cut and remove gums, extract one or more teeth, stop bleeding, and prescribe medication.\nBut, take it easy, so as not to leave them stressed or toothless."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artificiumstudio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Artificium Studio", "support_website_url": null, "website_url": "https://artificiumstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "506905431403192"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "432987499192797"}, {"status": "PUBLISHED", "id": "1590193098171619"}, {"status": "PUBLISHED", "id": "629494775524241"}]}, "baseline_offer": {"id": "1590193098171619"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "432987499192797"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9360170204024999", "version": "4.0"}, "id": "2387664808052816", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8431883286853700", "is_concept": false, "late