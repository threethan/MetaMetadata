patients,\nBut, take it easy, so as not to leave them stressed or toothless.", "short_description": "Who has never been afraid to go to the dental office?\nBut now, it's your turn to be the dentist!\nSo get the anesthetic syringe and the pliers, because all the teeth will be yours.\nWelcome to the most real and fun dentist simulator in the store!\nYou will have to apply anesthesia, cut and remove gums, extract one or more teeth, stop bleeding, and prescribe medication.\nBut, take it easy, so as not to leave them stressed or toothless."}]}, "developer_name": null, "developer_privacy_policy_url": "https://artificiumstudio.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Artificium Studio", "support_website_url": null, "website_url": "https://artificiumstudio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "REQUIRED", "genres": ["SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "506905431403192"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "432987499192797"}, {"status": "PUBLISHED", "id": "1590193098171619"}, {"status": "PUBLISHED", "id": "629494775524241"}]}, "baseline_offer": {"id": "1590193098171619"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1729789200, "status": "PUBLISHED", "id": "432987499192797"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9360