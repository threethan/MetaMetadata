159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974447_774439057298492_2915913410607392668_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TcVx-OJj5JUQ7kNvgEUvNZI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBX-YTww89VeE0Zl11jHK411r2LP73un4KWPMxQ_qYB9Q&oe=677D1A4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TableOfTales_CoverImage_Video.png", "id": "527498059052597", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_527498062385930_8535412789414279458_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=deFcJHL2IIwQ7kNvgHOgiHF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDTOqaWkwgGk98MBNKxzabllp_rkWpGpd3iQjTijjVE4Q&oe=677D2E06"}, "display_name": "Table of Tales: The Crooked Crown", "keywords": ["RPG", "Board", "Cards", "Mixed", "Reality"], "long_description": "Embark on a single-player narrative-driven campaign featuring a fully-voiced Dungeon Master companion, who appears as a mechanical talking bird called Arbitrix.\n- Guide a party of four scoundrels through a captivating story that is shaped by important world-changing choices!\n- High Replayability. No one playthrough is the same as another based on critical choices you make on the way, including throwing your scoundrels overboard!\n- Use powerful magic, battle, charm or sneak your way through more than 24 enthralling encounters.\n- Tactical turn-based combat and encounters feature dice, cards, skill checks and over 40 different types of enemy.\n- Each scoundrel has their own skill and stat upgrade path. Choose different abilities or magic each time you play.\n- The magical table transforms before your eyes. You need to see it to believe it!\n- Use controllers or your hands to interact with the figurines and cards.\n- Mixed Reality Play Mode.", "short_description": "Table of Tales: The Crooked Crown is a role playing adventure that brings tabletop gaming to life with animated miniatures, dice-rolling, and card-based abilities and magic. Take a seat at the magical table, captain the helm, and lead your party of scoundrels as they venture through a world of swashbuckling and sorcery.\nNow with a Mixed Reality play mode option."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinmangames.com.au/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Tin Man Games Pty. Ltd.", "support_website_url": "http://tinmangames.com.au/blog/?page_id=135", "website_url": "https://tinmangames.com.au/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "RPG"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7074678069290091"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974645_5692615697421224_3712722582516054466_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tv4nVpz0zbgQ7kNvgF-DBFM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCWw5y1hVTVEic0QyyDo6Pm35BNhBf0maqpd2wcp2ej_w&oe=677CF9EC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Table of Tales: The Crooked Crown", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Tabletop", "id": "1676485315806614"}, {"topic_name": "Role Playing", "id": "821934236779161"}], "release_date": 1657818014, "