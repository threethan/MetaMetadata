ard!\n- Use powerful magic, battle, charm or sneak your way through more than 24 enthralling encounters.\n- Tactical turn-based combat and encounters feature dice, cards, skill checks and over 40 different types of enemy.\n- Each scoundrel has their own skill and stat upgrade path. Choose different abilities or magic each time you play.\n- The magical table transforms before your eyes. You need to see it to believe it!\n- Use controllers or your hands to interact with the figurines and cards.", "short_description": "Table of Tales: The Crooked Crown is a role playing adventure that brings tabletop gaming to life with animated miniatures, dice-rolling, and card-based abilities and magic. Take a seat at the magical table, captain the helm, and lead your party of scoundrels as they venture through a world of swashbuckling and sorcery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinmangames.com.au/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Tin Man Games Pty. Ltd.", "support_website_url": "http://tinmangames.com.au/blog/?page_id=135", "website_url": "https://tinmangames.com.au/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1676485315806614"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "RPG"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1886351848234445"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "3567619180205680"}, {"status