n.com/v/t64.5771-25/38974561_3189721954682107_1522685397824527534_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PIHtyo3_DDoQ7kNvgFAwTSI&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCL5h-QNdXHwXcKy8iGqZ1thTPC9MyBsDKEGAjuaWm86A&oe=67052D0A"}, {"file_name": "TTTCC_screen_09.png", "id": "306628688350057", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974670_306628691683390_52503083219129247_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nAm6gvRKZwgQ7kNvgF26Glw&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA-zHJPcS6SlKrwpDDri0FpqR_IlPb2qSxnbBO8YbYxUQ&oe=67051719"}, {"file_name": "TTTCC_screen_10.png", "id": "774439053965159", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974447_774439057298492_2915913410607392668_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pCRuxRK0tCQQ7kNvgHz6y1H&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4A6f1I7sARhUagREioJOsC_w6WB7gEUBijOtBlgLoZw&oe=670521CE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TableOfTales_CoverImage_Video.png", "id": "527498059052597", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_527498062385930_8535412789414279458_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=32O0WueroJYQ7kNvgFgZ54o&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBoaRE4vWHvz6dH7ej0Yv46bXnKeQbUTbXbzjew06sP4Q&oe=67053586"}, "display_name": "Table of Tales: The Crooked Crown", "keywords": [], "long_description": "Embark on a single-player narrative-driven campaign featuring a fully-voiced Dungeon Master companion, who appears as a mechanical talking bird called Arbitrix.\n- Guide a party of four scoundrels through a captivating story that is shaped by important world-changing choices!\n- High Replayability. No one playthrough is the same as another based on critical choices you make on the way, including throwing your scoundrels overboard!\n- Use powerful magic, battle, charm or sneak your way through more than 24 enthralling encounters.\n- Tactical turn-based combat and encounters feature dice, cards, skill checks and over 40 different types of enemy.\n- Each scoundrel has their own skill and stat upgrade path. Choose different abilities or magic each time you play.\n- The magical table transforms before your eyes. You need to see it to believe it!\n- Use controllers or your hands to interact with the figurines and cards.", "short_description": "Table of Tales: The Crooked Crown is a role playing adventure that brings tabletop gaming to life with animated miniatures, dice-rolling, and card-based abilities and magic. Take a seat at the magical table, captain the helm, and lead your party of scoundrels as they venture through a world of swashbuckling and sorcery."}]}, "developer_name": null, "developer_privacy_policy_url": "https://tinmangames.com.au/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Tin Man Games Pty. Ltd.", "support_website_url": "http://tinmangames.com.au/blog/?page_id=135", "website_url": "https://tinmangames.com.au/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}, {"id": "961172191044986"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "RPG"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1886351848234445"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "1979186315880246"}, {"status": "PENDING", "id": "280314008305119"}, {"status": "PUBLISHED", "id": "1134192074386293"}, {"status": "PUBLIS