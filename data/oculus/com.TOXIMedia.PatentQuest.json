e.png", "id": "1106487173742604", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031373_1106487177075937_9073466908907623770_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QPPF8ukb6IgQ7kNvgHbt1b9&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlJ5bHIcGDBEyXS9ahY7_dmx4InCvugy5SQZh18oX52w&oe=670CEC48"}, {"file_name": "cover.png", "id": "345268781901363", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75240105_345268785234696_2910883297320675045_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YjqBmuMKnjwQ7kNvgEy53Ff&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvyZat-rU7A9N2dsKJaqosXuJ85egt68tY5NA9A_PL8Q&oe=670D1C15"}, {"file_name": "landscape cover.png", "id": "339635525427422", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75222942_339635528760755_4929072176242943488_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=foMpRa35QsMQ7kNvgE22lMi&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCG5Yfxt4vKGZO7XSEVQa1Ybz47JOLuXBwdGTw3csGElw&oe=670D11A9"}]}, "id": "1398867104165449", "locale": "en_US", "screenshots": [{"file_name": "screen1.png", "id": "1044592687016467", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375085_1044592690349800_4996245620976450412_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zaIrHdGjEP8Q7kNvgGHDjQX&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD72aHFbGPN_45dfhjXu0ajoMwjgyL9MWA5uQV2Pg6cjA&oe=670CFB81"}, {"file_name": "screen3.png", "id": "1137668554137612", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38984474_1137668557470945_2394862766751249054_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=klXhomwLud4Q7kNvgFARUHV&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDSe_XbWek_akR4GEOsNy1fEDVtw1NYb7W4dfOpkP2oaA&oe=670D195B"}, {"file_name": "screen2.png", "id": "449473321071476", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974780_449473327738142_2984052074568605684_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ex1mewF101EQ7kNvgFCk2S3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkIWDtDpW6RPU720aRr9kLAZSj7ql4mRTxOXeEuTkf9Q&oe=670CEB72"}, {"file_name": "screen5.png", "id": "396058783418042", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001723_396058786751375_268819880560138811_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z2v8JB3s6HUQ7kNvgFu3ZlV&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDAyM9J-vTv_3CCPzEVjCqB6TGNvWyFw3RIQRynctMiSw&oe=670D06F5"}, {"file_name": "screen4.png", "id": "422971063815286", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036675_422971067148619_2099123969476747266_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ssn17IpxXYwQ7kNvgFRUA1V&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDpovCgejp9FXR-YjdPM59Angnh7tbgtir7PlfIie-Eqg&oe=670CFCF0"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer thumb.png", "id": "451647504013932", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974466_451647507347265_8116685871920833186_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=od3mCKNDT0MQ7kNvgEKBw20&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCZkO3zcv-HRyThiw9lQnMBa9ioczZpGktvSVPCm_WC8g&oe=670CFA82"}, "display_name": "Patent Quest", "keywords": [], "long_description": "Explore the cutting-edge of VR with \"Patent Quest,\" developed by TOXI.media in collaboration with PatSnap. This game melds virtual reality with intellectual challenge, perfect for tech enthusiasts and gamers alike.\n\n**Gameplay:**\n\"Patent Quest\" features a novel mechanic where players use their hands or controllers to sort patterns on a VR conveyor belt into the correct categories. Choose from \"Time Trial,\" racing against the clock, or \"Endless,\" where accuracy is critical and a single mistake ends the game.\n\n**Features:**\n- **Intuitive VR Controls:** Natural hand movements or VR controllers provide a deeply immersive experience.\n- **Two Exciting Modes:** Test your skills with Time Trial's pace or Endless mode's precision.\n- **Retro Aesthetics:** Relish in the nostalgic look of Windows 95, combining retro charm with modern VR.\n- **Dynamic Soundtrack:** The original music by Ferm\u00edn Delia enhances the immersive experience.\n\n**Why Play?**\n\"Patent Quest\" is a journey into the heart of innovation. Ideal for those who relish technological challenges and retro computing aesthetics.\n\n**Master the art of patent categorization in VR! Available now on the Meta Quest Store.**", "short_description": "Dive into innovation with this VR game by TOXI.media and PatSnap. Sort patterns on a conveyor belt using intuitive VR controls. Choose between Time Trial and Endless modes, and enjoy a Windows 95 retro aesthetic. Perfect for tech enthusiasts and gamers looking for a challenge. Available now!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://toxi.media/patent-quest-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TOXI.Media", "support_website_url": null, "website_url": "https://toxi.media/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7738688696186819"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "793407032972821"}, {"status": "PUBLISHED", "id": "3682964005325339"}]}, "baseline_offer": {"id": "793407032972821"}, "is_approv