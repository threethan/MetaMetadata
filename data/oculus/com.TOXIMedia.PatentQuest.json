": "screen2.png", "id": "449473321071476", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974780_449473327738142_2984052074568605684_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FNcZEc-NAKcQ7kNvgG1Vj5u&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDTwqgd26B8tHSx3GBHN0zEmj73UQ8iugtIFWeNM_4HCQ&oe=67263032"}, {"file_name": "screen5.png", "id": "396058783418042", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001723_396058786751375_268819880560138811_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Qx0JQfs15wQ7kNvgEopSph&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAm8MI8TvXph0uhsboz78Jtj0RcedMRenJA92q3iTKXaA&oe=67261375"}, {"file_name": "screen4.png", "id": "422971063815286", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036675_422971067148619_2099123969476747266_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R-jgnIGubAAQ7kNvgGy4_Sx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBkjiu-UYzWwocStx3hS8sOkbX-VOh6YM8qSiUXDgMZrA&oe=67260970"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer thumb.png", "id": "451647504013932", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974466_451647507347265_8116685871920833186_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SsshMpKgcusQ7kNvgFpBqdt&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDMkuebx5rx60EUaC-2-8VIZv3V05ILEukAWYZYVotInA&oe=67260702"}, "display_name": "Patent Quest", "keywords": [], "long_description": "Explore the cutting-edge of VR with \"Patent Quest,\" developed by TOXI.media in collaboration with PatSnap. This game melds virtual reality with intellectual challenge, perfect for tech enthusiasts and gamers alike.\n\n**Gameplay:**\n\"Patent Quest\" features a novel mechanic where players use their hands or controllers to sort patterns on a VR conveyor belt into the correct categories. Choose from \"Time Trial,\" racing against the clock, or \"Endless,\" where accuracy is critical and a single mistake ends the game.\n\n**Features:**\n- **Intuitive VR Controls:** Natural hand movements or VR controllers provide a deeply immersive experience.\n- **Two Exciting Modes:** Test your skills with Time Trial's pace or Endless mode's precision.\n- **Retro Aesthetics:** Relish in the nostalgic look of Windows 95, combining retro charm with modern VR.\n- **Dynamic Soundtrack:** The original music by Ferm\u00edn Delia enhances the immersive experience.\n\n**Why Play?**\n\"Patent Quest\" is a journey into the heart of innovation. Ideal for those who relish technological challenges and retro computing aesthetics.\n\n**Master the art of patent categorization in VR! Available now on the Meta Quest Store.**", "short_description": "Dive into innovation with this VR game by TOXI.media and PatSnap. Sort patterns on a conveyor belt using intuitive VR controls. Choose between Time Trial and Endless modes, and enjoy a Windows 95 retro aesthetic. Perfect for tech enthusiasts and gamers looking for a challenge. Available now!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://toxi.media/patent-quest-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TOXI.Media", "support_website_url": null, "website_url": "https://toxi.media/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7738688696186819"}}]