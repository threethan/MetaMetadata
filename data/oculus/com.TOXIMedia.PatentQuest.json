0WzZTGw1hef2N_w&oe=66F924F2"}, {"file_name": "screen5.png", "id": "396058783418042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001723_396058786751375_268819880560138811_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LnWSSg-VrEoQ7kNvgGifl8L&_nc_ht=scontent.oculuscdn.com&oh=00_AYBm8iYYGktOg-t_BlwYgt1qm-CREhTW9Qe7gjQ9nF7U3w&oe=66F94075"}, {"file_name": "screen4.png", "id": "422971063815286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036675_422971067148619_2099123969476747266_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z3IDnAjEimoQ7kNvgHFabO-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVko_7syinewBSVuJUiqre1EdhypsG2NK8T8XPbUXN-Q&oe=66F93670"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailer thumb.png", "id": "451647504013932", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974466_451647507347265_8116685871920833186_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vCo2PDwq9YgQ7kNvgFZ0CWK&_nc_ht=scontent.oculuscdn.com&oh=00_AYBmTceKDV2X-z4-KSMjASF3vk0mAVgpgI5ptKdAjUPqoQ&oe=66F93402"}, "display_name": "Patent Quest", "keywords": [], "long_description": "Explore the cutting-edge of VR with \"Patent Quest,\" developed by TOXI.media in collaboration with PatSnap. This game melds virtual reality with intellectual challenge, perfect for tech enthusiasts and gamers alike.\n\n**Gameplay:**\n\"Patent Quest\" features a novel mechanic where players use their hands or controllers to sort patterns on a VR conveyor belt into the correct categories. Choose from \"Time Trial,\" racing against the clock, or \"Endless,\" where accuracy is critical and a single mistake ends the game.\n\n**Features:**\n- **Intuitive VR Controls:** Natural hand movements or VR controllers provide a deeply immersive experience.\n- **Two Exciting Modes:** Test your skills with Time Trial's pace or Endless mode's precision.\n- **Retro Aesthetics:** Relish in the nostalgic look of Windows 95, combining retro charm with modern VR.\n- **Dynamic Soundtrack:** The original music by Ferm\u00edn Delia enhances the immersive experience.\n\n**Why Play?**\n\"Patent Quest\" is a journey into the heart of innovation. Ideal for those who relish technological challenges and retro computing aesthetics.\n\n**Master the art of patent categorization in VR! Available now on the Meta Quest Store.**", "short_description": "Dive into innovation with this VR game by TOXI.media and PatSnap. Sort patterns on a conveyor belt using intuitive VR controls. Choose between Time Trial and Endless modes, and enjoy a Windows 95 retro aesthetic. Perfect for tech enthusiasts and gamers looking for a challenge. Available now!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://toxi.media/patent-quest-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TOXI.Media", "support_website_url": null, "website_url": "https://toxi.media/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7738688696186819"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "793407032972821"}, {"status": "PUBLISHED", "id": "3682964005325339"}]}, "baseline_offer": {"id": "793407032972821"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717776840, "status": "PUBLISHED", "id": "793407032972821"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinar