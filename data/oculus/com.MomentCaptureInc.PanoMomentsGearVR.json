o", "photo", "video"], "long_description": "PanoMoments aren\u2019t photos, nor are they videos. We like to describe them as 360\u00b0 living VR photos, and unlike normal VR content, they\u2019re captured using a rotating camera system. No stitching is required! The result is an entirely new creative VR medium that couples time and space, and we've barely scratched the surface of the possibilities.\n\nIf you'd like to get a notification upon new featured content, please sign up on PanoMoments.com\n\nMany thanks go out to the following folks who helped bring PanoMoments to life:\n- Chris Dickinson - https://plus.google.com/u/0/communities/110296186842409327827\n- Robert Rouhani - https://github.com/Robmaister\n- Our Kickstarter Backers - https://www.kickstarter.com/projects/dustinkerstein/capture-360-living-photos-with-panomoments", "short_description": "PanoMoments aren\u2019t photos, nor are they videos. We like to describe them as 360\u00b0 living VR photos, and unlike normal VR content, they\u2019re captured using a rotating camera system. No stitching is required! The result is an entirely new creative VR medium that couples time and space, and we've barely scratched the surface of the possibilities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.panomoments.com/company/terms", "developer_terms_of_service_url": "https://www.panomoments.com/company/terms", "publisher_name": "Moment Capture, Inc.", "support_website_url": null, "website_url": "https://www.panomoments.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", 