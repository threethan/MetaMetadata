ge.png", "id": "205726240679147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162753_544736885917987_3876582183665664000_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VX8vwbNrdt0Q7kNvgGpoPOW&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0gw9YXVHBEZioK7E5pYPrqI7NXoTjrWMRZEq1bh27hQ&oe=66DC536A"}, {"file_name": "migrated_image.png", "id": "1124551851230119", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162771_500567393627299_415025472951287808_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LD9uAW_ZHVcQ7kNvgH0-L4-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAg8ITqAs4_LheSA2PIkaeQThXclLYhDR5bUrorTrhfWA&oe=66DC2181"}, {"file_name": "migrated_image.png", "id": "886661881747058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162698_1455173604559805_803987920414310400_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I_kgbIIEzi8Q7kNvgE2DNQZ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJU2LwkO4rVwEWk1Tw5LfjGPxcvzJugMs2wUUNqiZLzA&oe=66DC422E"}, {"file_name": "migrated_image.png", "id": "202593424303355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_354552064983179_8327910693244239872_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ORPKLP5-aJUQ7kNvgETEMXq&_nc_ht=scontent.oculuscdn.com&oh=00_AYCov5NoT6dZ5uxb_QVswWLzeqiTYoRC3I_VNsyI5QDFGQ&oe=66DC32B0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PanoMoments VR", "keywords": ["panorama", "photosphere", "360photo", "photo", "video"], "long_description": "PanoMoments aren\u2019t photos, nor are they videos. We like to describe them as 360\u00b0 living VR photos, and unlike normal VR content, they\u2019re captured using a rotating camera system. No stitching is required! The result is an entirely new creative VR medium that couples time and space, and we've barely scratched the surface of the possibilities.\n\nIf you'd like to get a notification upon new featured content, please sign up on PanoMoments.com\n\nMany thanks go out to the following folks who helped bring Pano