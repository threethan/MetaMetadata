ge.png", "id": "205726240679147", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162753_544736885917987_3876582183665664000_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cjYXZt9rU3IQ7kNvgFv6SUB&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbwIy3cjX6No5VByT6AkdYSwhcb-IMYHMF8zh1nOVh-A&oe=66E58DEA"}, {"file_name": "migrated_image.png", "id": "1124551851230119", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162771_500567393627299_415025472951287808_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ls0ZTzH8i1cQ7kNvgHf4FKE&_nc_ht=scontent.oculuscdn.com&oh=00_AYAq3WX7KFH1D5gkU2Vla1nukz6ymqbZJIPuqyepNaOMLA&oe=66E55C01"}, {"file_name": "migrated_image.png", "id": "886661881747058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162698_1455173604559805_803987920414310400_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zwk3yvR6ADMQ7kNvgGqb7_4&_nc_ht=scontent.oculuscdn.com&oh=00_AYCVlluMSIAbS7I6Sn6V_Cj61-HrwqDGFh-a5ajReO2-kw&oe=66E57CAE"}, {"file_name": "migrated_image.png", "id": "202593424303355", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162708_354552064983179_8327910693244239872_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bz2pDZ-OzBUQ7kNvgH4ROh0&_nc_ht=scontent.oculuscdn.com&oh=00_AYAH_erFTchBLNIuQlZOWyx3C3X3YkrPpk4poTI8cyQPRA&oe=66E56D30"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PanoMoments VR", "keywords": ["panorama", "photosphere", "360photo", "photo", "video"], "long_description": "PanoMoments aren\u2019t photos, nor are they videos. We like to describe them as 360\u00b0 living VR photos, and unlike normal VR content, they\u2019re captured using a rotating camera system. No stitching is required! The result is an entirely new creative VR medium that couples time and space, and we've barely scratched the surface of the possibilities.\n\nIf you'd like to get a notification upon new featured content, please sign up on PanoMoments.com\n\nMany thanks go out to the following folks who helped bring Pano