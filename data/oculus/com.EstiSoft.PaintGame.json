tps://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982638_882254459998276_4848248971273463867_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0qTLzUQ3j38Q7kNvgGKWfOV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC0u80fugjOT2yPmugN9Nc3Dgz_eBMwxKbMgOjxMK4_MA&oe=67223305"}, {"file_name": "Image Sequence_002_0001.png", "id": "3052778984861860", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_3052778991528526_2160245597216781486_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zZn04-Jtwb4Q7kNvgH62IMq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvHmK7kw-C9_uNCZ_YTKbUU8n0TY8XYl7HtHxugH-9Fw&oe=672217E4"}, {"file_name": "Image Sequence_004_0001.png", "id": "1234415007803505", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570314_1234415014470171_5840151572007061523_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hL2zJK4uPbUQ7kNvgGiv4Pe&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAaqbCxDcskTweE98_dXaF46wzJHlLEa5EbC7UH3LGecw&oe=67222CC9"}, {"file_name": "Image Sequence_001_0040.png", "id": "828156329463203", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031526_828156332796536_2310305986228064983_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PmRVuEP_I0UQ7kNvgHHNJ4D&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBD9KwpsgZBQIP7LGQ9fubnd5MzLU9LHvbsfpJiS9yPOA&oe=6722239E"}, {"file_name": "Ekran g\u00f6r\u00fcnt\u00fcs\u00fc 2024-09-18 020328.png", "id": "934090152071173", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974804_934090155404506_6460402099056169683_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yNDnom4tbeYQ7kNvgFxExk4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-ktPbthXy45DJ8r8mVZCWze898jAIyBox1nxuFZaKsA&oe=672200A3"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Ekran g\u00f6r\u00fcnt\u00fcs\u00fc 2024-09-18 020328.png", "id": "1079606530222391", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982535_1079606536889057_3737180341847276457_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oitK3tgLiFIQ7kNvgGDnWG4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAW-W8H-yJNLGOvmjL37JYd6boQRfl3JJsIlL2DQ2lAIg&oe=672218FF"}, "display_name": "Spray Art", "keywords": ["paint", "paintable", "car", "garage", "comfort"], "long_description": "Dive into the vibrant world of 'Spray Art,' a revolutionary VR game that transforms you into a master graffiti artist without leaving your home. Designed for creativity enthusiasts and artists alike, this game offers an unparalleled platform to express yourself through spray paint in a fully immersive environment.\n\nIn 'Spray Art,' you will navigate through various interactive 3D spaces\u2014from gritty urban alleyways to blank warehouse walls or even trains\u2014each providing a unique canvas for your artwork. The game uses intuitive VR controls to simulate real spray painting techniques, giving you the ability to create detailed and expansive murals with precision and flair.\n\nAs you start your artistic journey, choose from an extensive palette of colors and special effects to make your artwork pop. Adjustable nozzles, spray distances, and color blending tools allow for intricate designs and textures, mirroring the thrill of real-world graffiti art. With each session, you\u2019ll unlock new tools and environments, continually challenging your creativity and skills.\n\n'Spray Art' not only focuses on freehand painting but also incorporates challenges and missions to enhance your experience. Complete specific mural requests, participate in time-based art competitions, or learn new styles from virtual mentors. Each challenge pushes the boundaries of your creativity and might even teach you a bit about art history and graffiti culture along the way.", "short_description": "Unleash your creativity in 'Spray Art,' a unique VR experience where you become a graffiti artist. This immersive game lets you spray paint across various 3D surfaces and settings, from urban walls to expansive canvases. With a range of colors and tools at your disposal, create stunning, vibrant murals in a virtual world. Perfect your skills, explore artistic expressions, and let your imagination run wild. \u2018Spray Art\u2019 is where art meets innovation in virtual reality!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://drive.google.com/file/d/1_l_GxTpD64zBNaY3TAnGXtCB1cmJE-E7/view", "developer_terms_of_service_url": null, "publisher_name": "Esti Soft", "support_website_url": null, "website_url": "https://www.bilgiplatformu.net/post/spray-art", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8456955141010057"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1224152272048632"}]}, "baseline_offer": {"id": "1224152272048632"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726747141, "status": "PUBLISHED", "id": "1224152272048632"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8456979674340937", "version": "0.2.0"}, "id": "536304302383154", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8449734055065499", "