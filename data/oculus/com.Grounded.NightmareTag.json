oe=67878A4D"}, {"file_name": "NT_Portrait.png", "id": "574674905302775", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001707_574674908636108_343596491557932727_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LQgO7SkR5gkQ7kNvgFGzwl6&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBIvKKjThQc7anQUVBk2_lAOnmaZWKF5y6cQVqCbmJXYA&oe=6787A0FC"}]}, "id": "4001286983435099", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-07-01 153903.png", "id": "3151034505205916", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38982461_3151034508539249_6569976495400496386_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8dQXQmmmWRwQ7kNvgFMBuKE&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAMnFDkpj6gkJW5rPRFi1jPsnfmbbBOLZ42DFi8uFD0MA&oe=67879C5D"}, {"file_name": "Screenshot 2023-09-08 133257.png", "id": "988025082484613", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982659_988025089151279_6146952839061566164_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-6Vo8bYZ9EsQ7kNvgEJFbEh&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYACm7bD_vuJnLna7RCmKoTRWUrM2o6vTpFJVo4Pi1UEhQ&oe=67878CE8"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s1R3WUpBy4IQ7kNvgG9zP-G&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYAix6aQ-Y1BQzkaLod_FdnEcqAMwPCbzIl62u-smgzLTQ&oe=6787A941"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vIunmMfPPGoQ7kNvgEH2H19&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAePZBQXfa3es33R09xm5h-Iv9AEmMCQ563ck0rp7EvJg&oe=678797C1"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LaJs978K8fkQ7kNvgEIouf1&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBe9oFdeQCvrvrPV9vJPiPSpsbDpdo89ZzsCNnDvkV9JQ&oe=6787B227"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NT_Landscape.png", "id": "1310626570182926", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031597_1310626576849592_3549401258384373051_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=knU_8U7rgokQ7kNvgHW6BXC&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCzWL9qN0z2yUrGP-JtQzOn969KLJgR8vt1TroFTkoKmg&oe=67879197"}, "display_name": "Nightmare Tag", "keywords": ["Multiplayer", "horror", "pvp", "scary", "tag"], "long_description": "Nightmare Tag is a PvP horror experience packed full of INTENSE CHASES & JUMP SCARES! Be one of the mortal humans trying to escape the experience. Or, become the blood-hungry monster to terrify your friends! This game will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they complete the objective!\n- Two playable monsters with different customizable abilities\n- Unique controller motion movement to run, jump, grapple, and tear humans apart!\n\nRUN AND HIDE FOR YOUR LIFE: \n- Join your friends as you run and hide from the monsters!\n- Hide by remaining completely motionless, making you invisible to the monster\n- Physical running motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n\nMULTIPLE GAME MODES:\n- Quick Tag\n- VHS Run\n- Elimination\n- Capture the Fruit\n\nPROGRESSION\n- Gain XP from playing games\n- Unlock new Characters\n- 9 upgradable perks for the Monsters\n- 8 upgradable perks for the Humans\n\nGENERAL ADMISSION (IAP):\n- Unlock full progression system\n- Required to unlock Mimic and Charles\n- +3000 tokens", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared with a set of surreal tools. Or, become a blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Grounded", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8793270077453065"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031436_601930728883059_4123221405039425016_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y66-2tEaPfAQ7kNvgHdBK2L&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCJhDRV3__pK1X6WeSNdAHJjemKo7YiCQ-FQV7OuvBB