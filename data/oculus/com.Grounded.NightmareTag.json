/39031478_1506391309901023_7084336627287014605_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xby2cIFUjukQ7kNvgEIIvD1&_nc_ht=scontent.oculuscdn.com&oh=00_AYB-jg76FmXD8kxy2wUXsDjWr1VBTEQL5lPzp1-mcCS7Pg&oe=66E2CF71"}, {"file_name": "Transparent Logo 1440x14400.png", "id": "1013363519916265", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031500_1013363523249598_1754276221208357233_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UHyQ9K6WksgQ7kNvgHNqb_u&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMDvnoZncFePwrST8e268KbnDkqnICpwzkJBq3Mi99hw&oe=66E2CE3E"}, {"file_name": "Cover Art_Landscape_2560x144020.png", "id": "643749887888029", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404392_643749891221362_5543497447286405852_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rsIJkZ3xqE8Q7kNvgHHY-eI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBvPui64t6V-w8CygQadwG3s7OrzVBFUc7CjnTl4j9aSA&oe=66E2DA22"}, {"file_name": "Cover Art_Square_1440x14400.png", "id": "241953468499740", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003256_241953471833073_8403766953236806835_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hB6ajX4MH4oQ7kNvgGvkvAI&_nc_ht=scontent.oculuscdn.com&oh=00_AYBznmTS6RVMSFwRfjulTku4UDOf9roMDNpJV_a2ptyeyQ&oe=66E2C9E7"}]}, "id": "257195683984065", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-07-01 153903.png", "id": "3151034505205916", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_3151034508539249_6569976495400496386_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xPMdgy_poFQQ7kNvgFDpa-U&_nc_ht=scontent.oculuscdn.com&oh=00_AYCQR1rqtKiyEnKplRik4VvFbwWT2xFmnPbffyINLb_0Iw&oe=66E2D0DD"}, {"file_name": "Screenshot 2023-09-08 133257.png", "id": "988025082484613", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982659_988025089151279_6146952839061566164_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZ-r96b7-GAQ7kNvgGyp09I&_nc_ht=scontent.oculuscdn.com&oh=00_AYDLra93sGZ5GM0vIVQthBp1gfQaW-IK1pM0rf-5J3QcyQ&oe=66E2C168"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xyTHumxvl_kQ7kNvgFNfPHX&_nc_ht=scontent.oculuscdn.com&oh=00_AYDKak86BAOLVuFj1X5FzKvSkL4ob-_o7QAnCCp-DvW-9w&oe=66E2DDC1"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RG6x1STuYT4Q7kNvgF1feVG&_nc_ht=scontent.oculuscdn.com&oh=00_AYCC8kWTiYh1qHXmcr6lSoOmbIoGVAlmr1aVnnJHf9hj4A&oe=66E2CC41"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RNwPL3VWDdwQ7kNvgHtbjw0&_nc_ht=scontent.oculuscdn.com&oh=00_AYC_ZkPm_OzwQ_r8-BoNDMqUZWnUEonLERGyocBvDnbVhg&oe=66E2E6A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art_Landscape_2560x144020.png", "id": "6675375442547548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_6675375449214214_374955904288494240_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uGmxsm_h5QUQ7kNvgH5D3g3&_nc_ht=scontent.oculuscdn.com&oh=00_AYCKMDvHpefRAUZVs0uOOflPrSAv2fqE_e1DvW8n4VmZnw&oe=66E2D87A"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they escape the liminal Dreamscape!\n- Unique controller motion movement to use your claws to run, jump, and tear apart humans!\n- Track & hunt humans using your many abilities!\n- Eliminate all the humans to win as the monster\n\nRUN FOR YOUR LIFE: \n- Join your friends as you Run and Hide from the Nightmare!\n- Hide by being completely motionless, making you invisible to the monster\n- Physical Running Motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- VHS Run\n- Quick Tag\n- Elimination (requires General Admission)\n- Capture the Fruit (requires General Admission)\n+ A variety of game and map settings to shake things up!\n\nGENERAL ADMISSION (IAP):\n- Unlock 6 more zones\n- Play Elimination and Capture the Fruit", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Enver Studio", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2