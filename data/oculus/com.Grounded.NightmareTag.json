=1-7&_nc_sid=6e7a0a&_nc_ohc=eCsYF43c5OMQ7kNvgFnFE3I&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDDG2g0-TNM7c_ygPnhsrcx7NhJgtavtXRN9hY-6qs_1A&oe=670FA3DD"}, {"file_name": "Screenshot 2023-09-08 133257.png", "id": "988025082484613", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982659_988025089151279_6146952839061566164_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AZ9o_3JfgJ0Q7kNvgF0fDFo&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYD2pFsdeVgPy-Y_vzS74QOAT2zyjBeuuewkAYttAYDwpw&oe=670F9468"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FLHlLwoymlcQ7kNvgEUuYw7&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBeMgWsR51kRsm_E6QRFcjdjhOtJCJRrr4XWbZrt5wU1A&oe=670FB0C1"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pXMj3mA747MQ7kNvgHA5fcE&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBuwl4DonO0U5aY8ys7WHwuf1SQidihwbf0IZrdo82LaA&oe=670F9F41"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=krXQgbM_htsQ7kNvgE5A_fW&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCg5ZxE8EOJlEWBP78cJUGw8JWkFoofOERVrcQSsaaJew&oe=670FB9A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art_Landscape_2560x144020.png", "id": "6675375442547548", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982461_6675375449214214_374955904288494240_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Hlvkt7Gnn64Q7kNvgEbgmxZ&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDvTNWUGyOL2swRG4j9JwyhMals6a2yYhXA_g6f7w_cWQ&oe=670FAB7A"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they escape the liminal Dreamscape!\n- Unique controller motion movement to use your claws to run, jump, and tear apart humans!\n- Track & hunt humans using your many abilities!\n- Eliminate all the humans to win as the monster\n\nRUN FOR YOUR LIFE: \n- Join your friends as you Run and Hide from the Nightmare!\n- Hide by being completely motionless, making you invisible to the monster\n- Physical Running Motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- VHS Run\n- Quick Tag\n- Elimination (requires General Admission)\n- Capture the Fruit (requires General Admission)\n+ A variety of game and map settings to shake things up!\n\nGENERAL ADMISSION (IAP):\n- Unlock 6 more zones\n- Play Elimination and Capture the Fruit", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Enver Studio", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6670285176418243"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "218528594386661"}]}, "baseline_offer": {"id": "218528594386661"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1697774400, "status": "PUBLISHED", "id": "218528594386661"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8487576851355724", "version": "0.9.7.34"}, "id": "449389333794642", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5351957704917670", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8487576851355724"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE