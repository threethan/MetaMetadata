17991941321366", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75429297_317991944654699_8132604058635258848_n.png?_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U9gU4gIr9e8Q7kNvgGyBc6X&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBF0si96RweEKgxFrk4wrhBxJpBPPFXw4ENsRlR0zIUAA&oe=670661B4"}]}, "id": "2559960064187138", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 2023-07-01 153903.png", "id": "3151034505205916", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982461_3151034508539249_6569976495400496386_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n12hNgegGXwQ7kNvgEzympQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADXJkDszJEUPg10KWbV23Cqb4pxbQYJBP-b3xpgAmo7w&oe=6706695D"}, {"file_name": "Screenshot 2023-09-08 133257.png", "id": "988025082484613", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982659_988025089151279_6146952839061566164_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AOEpIr7H9GAQ7kNvgH-UF6Z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdoTa6Zl5vk13kwxsRwqtjpImqBsqKNL4OHIZ1I4iQbg&oe=670659E8"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Lenzt7PL4XUQ7kNvgG7YVds&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAIz61z-8HcmbyUSRltyE_l4OJ1qbjGhEHJeaCKns63Fg&oe=67067641"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOGxUKMXN9UQ7kNvgHFq4Ri&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFqEMIIUG8SZ5oM-h-O5eQatbOxvGOVRG4ov1EOVy20A&oe=670664C1"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eCTTPnYzgNoQ7kNvgGhhbS4&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDK5VuFlUC_2VMXfihfY4fZjoVCXUB5jZ1FatEL3m00qA&oe=67067F27"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NT_Trailer thumbnail.png", "id": "7460848107298063", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974915_7460848110631396_5479251481820064772_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tOyZ7YobJj0Q7kNvgF5RhYS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCCsngQHirLjSCYJDoQRczmSSQbeRTzKX4zOdruFVIAlQ&oe=67068304"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "Nightmare Tag is a PvP horror experience packed full of INTENSE CHASES & JUMP SCARES! Be one of the mortal humans trying to escape the experience. Or, become the blood-hungry monster to terrify your friends! This game will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they complete the objective!\n- Unique controller motion movement to run, jump, and tear humans apart!\n- Track & hunt humans using your many upgradable abilities\n- Eliminate all the humans to win as the monster\n\nRUN AND HIDE FOR YOUR LIFE: \n- Join your friends as you run and hide from the monsters!\n- Hide by remaining completely motionless, making you invisible to the monster\n- Physical running motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- Quick Tag\n- VHS Run (requires General Admission)\n- Elimination (requires General Admission)\n- Capture the Fruit  (requires General Admission)\n\nPROGRESSION\n- Gain XP from playing games\n- 4 upgradable perks for the Entity (Monster)\n- 4 upgradable perks for Antonio (Human)\n\nGENERAL ADMISSION (IAP):\n- Unlock all zones\n- Unlock all game modes\n- Unlock all upgradable perks\n- +3000 tokens", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Grounded", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7527951810651571"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75298470_1529884641074249_2780252905263947192_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J4GZ43-Nf3wQ7kNvgGfpPYv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAXLU0