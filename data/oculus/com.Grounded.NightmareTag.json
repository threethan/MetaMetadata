c_ohc=QPWOsfELnHIQ7kNvgE6YKeV&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnZSrd7tQ0e3Oh03X5EwbQxk3wDaXkeKgaD_7JIVH-PQ&oe=66D59268"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jAkMOQeLX_EQ7kNvgElJ-gS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBrlBOcH_dIVcuR8dPgiVQw1Tv_KDy2FA7k-2Ul0qoDXA&oe=66D5AEC1"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nAj-V2uOQeMQ7kNvgG3RuxS&_nc_ht=scontent.oculuscdn.com&oh=00_AYAxoWyYz634ZLzAF8nk3IO_egYoZLS6BWXcwy5Uy-xBiQ&oe=66D59D41"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a8E6V07yU6kQ7kNvgGlhhbk&_nc_ht=scontent.oculuscdn.com&oh=00_AYArRB2NRW304uhmSiZn92Kuu1bMSfxJez26T6tyYlMnew&oe=66D5B7A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art_Landscape_2560x144020.png", "id": "6675375442547548", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982461_6675375449214214_374955904288494240_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F-HxieYOBIsQ7kNvgHJlIci&_nc_ht=scontent.oculuscdn.com&oh=00_AYCNclhQq5I0leEIxImwfvAOKjb3SwqPUw9vZpdaVO65Hg&oe=66D5A97A"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they escape the liminal Dreamscape!\n- Unique controller motion movement to use your claws to run, jump, and tear apart humans!\n- Track & hunt humans using your many abilities!\n- Eliminate all the humans to win as the monster\n\nRUN FOR YOUR LIFE: \n- Join your friends as you Run and Hide from the Nightmare!\n- Hide by being completely motionless, making you invisible to the monster\n- Physical Running Motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- VHS Run\n- Quick Tag\n- Elimination (requires General Admission)\n- Capture the Fruit (requires General Admission)\n+ A variety of game and map settings to shake things up!\n\nGENERAL ADMISSION (IAP):\n- Unlock 6 more zones\n- Play Elimination and Capture the Fruit", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Enver Studio", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": 