3-1.oculuscdn.com&oh=00_AYB4SEivKXYJ4GlJUUNggEJmR6DjgOgn-IhtJQfvHClKzw&oe=6703C65D"}, {"file_name": "Screenshot 2023-09-08 133257.png", "id": "988025082484613", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982659_988025089151279_6146952839061566164_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bEVl__wHuBEQ7kNvgFXRBPy&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZAT6qwWlSvAy8i_GDZYx3YTRXVyv-H8StL5xH-j2dew&oe=6703B6E8"}, {"file_name": "Screenshot 2023-09-08 122812.png", "id": "996168804943983", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974635_996168808277316_5512783578632717843_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ET1kYM_z-74Q7kNvgHd439l&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBRrMg48LL061Zuf6MaETfSVGh_WPluXvK-xD5LG-Flpg&oe=6703D341"}, {"file_name": "Trailer.00_00_30_23.Still001.png", "id": "222821904141208", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974812_222821907474541_2052841613157010489_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PJyEjpvTbK8Q7kNvgGKsDmj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDENNuZQ-i0ZqxUJTD0TATnvLycEyHhchNJpViI2GcVPw&oe=6703C1C1"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5chhmzc5dKwQ7kNvgEkGa92&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsW9U3ZFFVTeTJ4GKxbTOKY-ToX6SdIRRBwRsKiJ6qDA&oe=6703DC27"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Art_Landscape_2560x144020.png", "id": "6675375442547548", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982461_6675375449214214_374955904288494240_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lIiPT4RpVtQQ7kNvgEG4fR8&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAqiS-_B2BnRa9R8bZay3ZC1_l2HbDAbEm7Yj7kTLVZEA&oe=6703CDFA"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they escape the liminal Dreamscape!\n- Unique controller motion movement to use your claws to run, jump, and tear apart humans!\n- Track & hunt humans using your many abilities!\n- Eliminate all the humans to win as the monster\n\nRUN FOR YOUR LIFE: \n- Join your friends as you Run and Hide from the Nightmare!\n- Hide by being completely motionless, making you invisible to the monster\n- Physical Running Motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- VHS Run\n- Quick Tag\n- Elimination (requires General Admission)\n- Capture the Fruit (requires General Admission)\n+ A variety of game and map settings to shake things up!\n\nGENERAL ADMISSION (IAP):\n- Unlock 6 more zones\n- Play Elimination and Capture the Fruit", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, 