HgEyJEXHQ&oe=66ED5841"}, {"file_name": "Screenshot 2023-09-10 180945.png", "id": "1003308547591264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4RtOEtviOAQQ7kNvgGK3Y-m&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnhL_2TZdBSajieDbRSlb-0&oh=00_AYAl2GRZAXUXklFQFzKQqCMldmzWZocDJTWiRZH-ZkgIIg&oe=66ED72A7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NT_Trailer thumbnail.png", "id": "7460848107298063", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974915_7460848110631396_5479251481820064772_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QsATy6_oYg8Q7kNvgFqgcsH&_nc_ht=scontent.oculuscdn.com&_nc_gid=AnhL_2TZdBSajieDbRSlb-0&oh=00_AYCgPhZIuKRYv7J1NPrVMCr73vcWn6QcOEx8ly7DPT_dMA&oe=66ED7684"}, "display_name": "Nightmare Tag", "keywords": [], "long_description": "Nightmare Tag is a PvP horror experience packed full of INTENSE CHASES & JUMP SCARES! Be one of the mortal humans trying to escape the experience. Or, become the blood-hungry monster to terrify your friends! This game will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they complete the objective!\n- Unique controller motion movement to run, jump, and tear humans apart!\n- Track & hunt humans using your many upgradable abilities\n- Eliminate all the humans to win as the monster\n\nRUN AND HIDE FOR YOUR LIFE: \n- Join your friends as you run and hide from the monsters!\n- Hide by remaining completely motionless, making you invisible to the monster\n- Physical running motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n- Complete the objective win as the humans!\n\nMULTIPLE GAME MODES:\n- Quick Tag\n- VHS Run (requires General Admission)\n- Elimination (requires General Admission)\n- Capture the Fruit  (requires General Admission)\n\nPROGRESSION\n- Gain XP from playing games\n- 4 upgradable perks for the Entity (Monster)\n- 4 upgradable perks for Antonio (Human)\n\nGENERAL ADMISSION (IAP):\n- Unlock all zones\n- Unlock all game modes\n- Unlock all upgradable perks\n- +3000 tokens", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared only with your flashgun, scanner, and a variety of surreal attachments. Or, become the blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Grounded", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "275629210202852"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7527951810651571"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https: