8547591264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974663_1003308550924597_4301389862031791654_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gqmSlvSvaR8Q7kNvgGH_pwX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCprP2omrT87Bo2fSZxhRVrpdoex6g0ltdh-QEKKK3O3g&oe=67826C27"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "NT_Landscape.png", "id": "1310626570182926", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031597_1310626576849592_3549401258384373051_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Genum0EH1PgQ7kNvgFOprpI&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBM-GSKBdwGqi1UDsjOGrrsOROes2fFfhDen8pv89d6pQ&oe=67824B97"}, "display_name": "Nightmare Tag", "keywords": ["Multiplayer", "horror", "pvp", "scary", "tag"], "long_description": "Nightmare Tag is a PvP horror experience packed full of INTENSE CHASES & JUMP SCARES! Be one of the mortal humans trying to escape the experience. Or, become the blood-hungry monster to terrify your friends! This game will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! \n\nBECOME THE NIGHTMARE: \n- Find & chase your friends before they complete the objective!\n- Two playable monsters with different customizable abilities\n- Unique controller motion movement to run, jump, grapple, and tear humans apart!\n\nRUN AND HIDE FOR YOUR LIFE: \n- Join your friends as you run and hide from the monsters!\n- Hide by remaining completely motionless, making you invisible to the monster\n- Physical running motion allows you to sprint when you are found and need to escape!\n- Your flashgun is your only weapon, use it to see where you're going and stun the monster!\n- Use your scanner to locate the monster, reunite with other humans, find power-ups, and find the objective.\n\nMULTIPLE GAME MODES:\n- Quick Tag\n- VHS Run\n- Elimination\n- Capture the Fruit\n\nPROGRESSION\n- Gain XP from playing games\n- Unlock new Characters\n- 9 upgradable perks for the Monsters\n- 8 upgradable perks for the Humans\n\nGENERAL ADMISSION (IAP):\n- Unlock full progression system\n- Required to unlock Mimic and Charles\n- +3000 tokens", "short_description": "A multiplayer PvP Horror Experience packed full of INTENSE CHASES & JUMP SCARES! In Nightmare tag, you can either be one of the mortal humans trying to run and hide for your life, geared with a set of surreal tools. Or, become a blood-hungry monster to terrify your friends! Nightmare tag will have you and your friends screaming, laughing, yelling, & sweating until your headset runs out of power! "}]}, "developer_name": "Grounded", "developer_privacy_policy_url": "https://www.groundedfilms.ca/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Grounded", "support_website_url": null, "website_url": "https://www.groundedfilms.ca/vrdevelopment", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1023770785722696"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "SOCIAL"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8793270077453065"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031436_601930728883059_4123221405039425016_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ij5cd6b0H9gQ7kNvgGSOm8q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAwhh0dg_ANO0A7-FVry_fbqXiNe2Lr7IRWRcJVDUxw