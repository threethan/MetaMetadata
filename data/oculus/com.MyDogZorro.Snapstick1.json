.com&oh=00_AYCbTUjGnsIMu9o5oiCti1B8bnsxueaLr10ZufrOSPcF7A&oe=670D1826"}]}, "id": "1241677333678909", "locale": "en_US", "screenshots": [{"file_name": "Screen_v1_Marbx.png", "id": "1263389548414825", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974634_1263389551748158_2765195033493256870_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vNn3kk79dDoQ7kNvgE4VUfy&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDWdXzSITnqwxPVHLFsZxWKzosNdQHu1xeKaIU38QX9cA&oe=670D07FF"}, {"file_name": "Screen_Preorder_v1_FencesA.png", "id": "389290203820351", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974907_389290207153684_3232133899963617660_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wxZy5BBygvEQ7kNvgE2Kz0M&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBTZXUJtM2Vwg09lssu6_ji45O6BM3emPPGNM24klQpag&oe=670CED0E"}, {"file_name": "Screen_v1_DogCaught.png", "id": "369808306099120", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982619_369808309432453_6590369838727546791_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VFULmI3KtxUQ7kNvgHwbXn7&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDCawG0KR7YTcf_QVi7rV-HcDuZwpYcCA6fnx4uUv1Z4g&oe=670D1381"}, {"file_name": "Screen_Preorder_v1_LasersSpectacle.png", "id": "3418916431742181", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974681_3418916435075514_2077016708238167722_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=owaUeS5OGXkQ7kNvgFWHXvK&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzGRMkf60XfGahNAV2rDIhhDyDYqtNRiyfOu3w4g7QMA&oe=670CF15C"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Th_Pur8Si-gQ7kNvgETttWA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcxMJBxErL9cY6Z1mTBGkerD50vLz-xy6Ly6vEx-sNHw&oe=670D12BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WsaosUKdgNEQ7kNvgFaxVXv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC-GRV8bUVuBFHIw_FPAufyToyD-0zoQ827DbBWHC-iig&oe=670D1F07"}, "display_name": "Snapstick", "keywords": ["slapstick", "puzzle", "snap", "funny", "indie"], "long_description": "Snapstick is a bonkers **puzzle game** about **love** and **puns**. Prepare for a nonstop variety show of mechanics that will tickle your mind, and very silly characters that will warm your heart. Expect the unexpected, ok?\n\n\n# BRAIN-FLIPPING VARIETY\nSolve ingenious 3D mazes, build coaster tracks, reflect lasers, and MUCH more. Spatially reason in all the dimensions.\n{1223440118880908}\n\n# PLAY CUPID\nThis starts off cute and quickly flies off the rails. Things get ruff.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady!\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}\n\n# WE\u2019RE ALL CONTENT\n* 500+ puzzles by the multi-award-winning puzzle designer of Linelight\n* 60+ original mechanics\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario+Rabbids)\n* ...And much, much more!!!\n* Anti-climatic bullet points", "short_description": "Snapstick is a bonkers puzzle game bursting with love. Expect the unexpected!\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, redirect laser beams in all 3 dimensions, and MANY more. It's a jungle of mechanics!\n\nFEEL: Experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.