 dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8186299241427562"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "514449824672081"}, {"status": "PUBLISHED", "id": "501793939002779"}, {"status": "PUBLISHED", "id": "364805969800524"}]}, "baseline_offer": {"id": "514449824672081"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727974800, "status": "PUBLISHED", "id": "514449824672081"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8880320492025430", "version": "1.0.0.3"}, "id": "1006917164261315", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8186299231427563", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8880320492025430"}, "release_status": "RELEASED"}, "binary_release_