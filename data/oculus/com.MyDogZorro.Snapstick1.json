&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TvY5iw7NdekQ7kNvgHDSyWk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgKL4Yi44UL31gvjezyjTUei0t7q3qiV_3SzJqn3BGuA&oe=6718E73D"}]}, "id": "1504746733737028", "locale": "en_US", "screenshots": [{"file_name": "Screen_0_Marbx.png", "id": "1481093952607513", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1481093955940846_2157622238062465464_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=czlnLiQg9BEQ7kNvgEzVGmU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJd-ejZgMz_7cAPkykdH11sDay8IRKXSJyTFeNNntGRw&oe=6718CC83"}, {"file_name": "Screen_1_Lasers.png", "id": "875909670960284", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974554_875909674293617_6894347120185569387_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Uy9t76VXtaAQ7kNvgHG_9dz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTViIu7QahHZ_snu1vac14KCWmWqqZfbKTOT_hnmnypg&oe=6718E80B"}, {"file_name": "Screen_2_Toilet_Passthrough.png", "id": "399092643246026", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003226_399092653246025_3513024666909186113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XuK9MuRxKaEQ7kNvgEt5Fjj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAEKGSvI6CDZQ_fslgE012KBtOTR9htjpHs6ns4bugtRA&oe=6718D60C"}, {"file_name": "Screen_Preorder_v1_FencesA.png", "id": "389290203820351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974907_389290207153684_3232133899963617660_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7guhProuPbEQ7kNvgFvvF-u&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCpuNz3QfFeYjxioGEfMDpx760HKI-BLrDV8Xk7MpKA0g&oe=6718CA8E"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aO4zHo7oKSIQ7kNvgH2E0lq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnnJHxfUc4yCPR4e1OCRjaujDyEvy1RylIqnxbI_AuwQ&oe=6718F03B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nMZZsATsI6QQ7kNvgFon0oL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDBhlV28Z1xiyf0jxEDYRnSZWJWWnSwB7qv9Zyz80AtIA&oe=6718FC87"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "Snapstick is a bonkers **puzzle game** filled with **love**. Prepare for a nonstop variety show of mechanics that will tickle your mind, and wacko characters that will warm your heart. Expect the unexpected, ok?\n\n\n# BRAIN-FLIPPING VARIETY\nSolve 3D mazes, build coaster tracks, reflect lasers, and MUCH more. Spatially reason in all the dimensions.\n{1223440118880908}\n\n# PLAY CUPID\nThis starts off cute and quickly flies off the rails. Things get ruff.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady!\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}\n\n# WE\u2019RE ALL CONTENT\n* 500+ puzzles by the multi-award-winning puzzle designer of Linelight\n* 60+ original mechanics\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario+Rabbids)\n* ...And much, much more!!!\n* Anti-climatic bullet points", "short_description": "Snapstick is a bonkers experience of great puzzles and terrible jokes. It's bursting with variety and surprises. Expect the unexpected!\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, redirect laser beams in all 3 dimensions, and MANY more. It's a jungle of mechanics!\n\nFEEL: Experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8720554664668681"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003282_887062212940575_3207042186952200491_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q9V0YreOlYQQ7kNvgH5VPhQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDIQPdPRMedahw-EIB7F2bOZiwDw8gYznOoX9dIT_nqXA&oe=6718F132"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snapstick", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1727974800, "lastRevision": {"nodes": [{"id": "8186299268094226", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8186299231427563", "is_