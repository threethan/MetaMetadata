&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KwhE5dwybiUQ7kNvgEBhM3F&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD55n_IG6Emu2R0G8GoLD4y4_Tw4LKJyB3RF55fkN0a3A&oe=671E2D3D"}]}, "id": "1504746733737028", "locale": "en_US", "screenshots": [{"file_name": "Screen_0_Marbx.png", "id": "1481093952607513", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1481093955940846_2157622238062465464_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G7A3UZqjubEQ7kNvgGgh-F9&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBIZF9ZPtSdsjP3iK6Rl8hBShKXCXg64DrwydH1mD6Lmw&oe=671E1283"}, {"file_name": "Screen_1_Lasers.png", "id": "875909670960284", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974554_875909674293617_6894347120185569387_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HKqyc7F_8KUQ7kNvgFO-o-k&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3jCMbO91VjS5swEgXJ8EFNTIOdMUhMM7r3LDC9hC6Pw&oe=671E2E0B"}, {"file_name": "Screen_2_Toilet_Passthrough.png", "id": "399092643246026", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003226_399092653246025_3513024666909186113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g76dPspdQAcQ7kNvgEfYrZ2&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCckFEfQGYVGQ23hfC4XoKZ9hZ1n-33lKvNecwk60W9aQ&oe=671E1C0C"}, {"file_name": "Screen_Preorder_v1_FencesA.png", "id": "389290203820351", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974907_389290207153684_3232133899963617660_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QH14rYQVwmoQ7kNvgGchd29&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRqCVsk2wTQiIfbOiwA8V_fPOtNgVSVSPKwJ87xR2_aA&oe=671E108E"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lTR3sH0OjvkQ7kNvgFg5Kce&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBHsitToJvLj3wke7mbKs9DIbUmnteJAuT2jVf_AsSuEA&oe=671E363B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jxcMG0zpIqYQ7kNvgGiekMS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYARPDaFXiM7C00gAs-26CPBczGb9jfj5CbWXks0cfrFRw&oe=671E0A47"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "Snapstick is a bonkers **puzzle game** filled with **love**. Prepare for a nonstop variety show of mechanics that will tickle your mind, and wacko characters that will warm your heart. Expect the unexpected, ok?\n\n\n# BRAIN-FLIPPING VARIETY\nSolve 3D mazes, build coaster tracks, reflect lasers, and MUCH more. Spatially reason in all the dimensions.\n{1223440118880908}\n\n# PLAY CUPID\nThis starts off cute and quickly flies off the rails. Things get ruff.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady!\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}\n\n# WE\u2019RE ALL CONTENT\n* 500+ puzzles by the multi-award-winning puzzle designer of Linelight\n* 60+ original mechanics\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario+Rabbids)\n* ...And much, much more!!!\n* Anti-climatic bullet points", "short_description": "Snapstick is a bonkers experience of great puzzles and terrible jokes. It's bursting with variety and surprises. Expect the unexpected!\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, redirect laser beams in all 3 dimensions, and MANY more. It's a jungle of mechanics!\n\nFEEL: Experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8720554664668681"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003282_887062212940575_3207042186952200491_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AonE3Oe6QjgQ7kNvgHTytPp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDCCxwAXCCLcIWYngMGlW_3kQihPTBFcSHRgTKf8hOYSQ&oe=671E3732"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snapstick", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1727974800, "lastRevision": {"nodes": [{"id": "8186299268094226", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8186299231427563", "is_