&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LM5IQiCxmxIQ7kNvgFRe1AN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBgh3g4xfUA7Z-PrUGMQDdRn5vblNHNC9GcBmW4aj9TPw&oe=678510A6"}]}, "id": "2428232660842370", "locale": "en_US", "screenshots": [{"file_name": "Screen_0_Marbx.png", "id": "1481093952607513", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1481093955940846_2157622238062465464_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ErCvA0AWI0MQ7kNvgHJtJST&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0MMhAIDbLOSQnriH6e4rJeNJcOECz_3WuUj9HqTiQfw&oe=6784E783"}, {"file_name": "Screen_1_Lasers.png", "id": "875909670960284", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974554_875909674293617_6894347120185569387_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0Tuc9RndTq4Q7kNvgE8BbpJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBqlCZBbGJMjMmMiB3aBFcKnzKDxQpRv9Wypo11GdiFuA&oe=6785030B"}, {"file_name": "Screen_2_Toilet_Passthrough.png", "id": "399092643246026", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003226_399092653246025_3513024666909186113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sAsClCkiCqQQ7kNvgF5I004&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLaOV-VhVosPHYsWxu0DKC6GhF4cnzkYjmWceTaSZmUw&oe=6784F10C"}, {"file_name": "Screen_v1_FencesA.png", "id": "1809628033134368", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982612_1809628036467701_5448370794054911283_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kGN0mba-hoYQ7kNvgF-dBuK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDclyuLX7Qxci24lDMM7mYO1ew5uq8Lqn6mumKT8_PIhw&oe=678506F0"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CSKJmsa1yRAQ7kNvgGciREP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBW4cC-jZSw8RNVs-M2LRC8Gs8s1K9hU3UzgXNC0OIbGg&oe=67850B3B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0UtPqTz43oAQ7kNvgEkudXj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfq9oef-igPxgbVL5mHfVBVoH2ltdjGPZx0D0yiJm9yA&oe=67851787"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "Snapstick is a **perfectly normal puzzle game** about connecting things together. It's perfect for normal people. Okay? Okay. Don't worry about it.\n\n\n# WHAT'S IN THE BOX?\n* 500+ puzzles by the multi-award-winning designer of Linelight\n* 60+ original mechanics\n* A memorable cast of very normal characters\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007)\n* ...And much, much more!!!\n* Anti-climatic bullet points\n\n# PUZZLES, PUZZLES, PUZZLES\nBuild objects, solve 3D mazes, build coasters, bounce lasers, and much more. Scratch itches deep in your brain.\n{1223440118880908}\n\n# PLAY CUPID\nThis dog is a normal character with a normal storyline.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady.\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}", "short_description": "Snapstick is a perfectly normal puzzle game for perfectly normal people. It's filled with great puzzles, terrible jokes, and chock-full o' variety and surprises. Expect the unexpected.\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, bounce laser beams, and MANY more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "deve