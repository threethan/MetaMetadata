oh=00_AYDveZvgqMX2QqOMRwkStFxwOKp5XcAp_RgNkTW4Eyvlbg&oe=677BB68C"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IX-YPi_ZXqkQ7kNvgGgCSI9&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBWfWlfWBFRlBIzD-d4pk-73G-5mhIdLENbldpAgpa31Q&oe=677BD0BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hef84e6NLqMQ7kNvgGrAvio&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAoqqRgxXi_t9gtOq0mnjRVY6mM2y0ULGEyLde6Me5TJA&oe=677BA4C7"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "# \ud83c\udf84 ~~~ FREE HOLIDAY UPDATE! ~~~ \ud83c\udf84\n\nWe've just added a brand new chapter featuring **20 new holiday-themed levels** to nourish your festive spirits! Wrap gifts, build snowmen, and most importantly, deliver a pregnant raptor to the hospital to deliver its out-of-wedlock child. Experience the miracle of Christmas! {1352694472384853}\n# \ud83c\udf84 ~~~~~~~~~~~~~~~~~~~~~~ \ud83c\udf84\n.\n\nAside from that, Snapstick is a **perfectly normal puzzle game** about connecting things together. It's perfect for normal people. Okay? Okay. Don't worry about it.\n\n\n# WHAT'S IN THE BOX?\n* 500+ puzzles by the multi-award-winning designer of Linelight\n* 60+ original mechanics\n* A memorable cast of very normal characters\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007)\n* ...And much, much more!!!\n* Anti-climatic bullet points\n\n# PUZZLES, PUZZLES, PUZZLES\nBuild objects, solve 3D mazes, build coasters, bounce lasers, and much more. Scratch itches deep in your brain.\n{1223440118880908}\n\n# PLAY CUPID\nThis dog is a normal character with a normal storyline.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady.\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}", "short_description": "~~~\ud83c\udf84 FREE HOLIDAY UPDATE! \ud83c\udf84 ~~~\nWrap gifts, build a snowman, and most importantly, deliver a pregnant raptor to the hospital to deliver its out-of-wedlock child. Ho, ho, oh!\n</\ud83c\udf84>\n\nSnapstick is a perfectly normal puzzle game for perfectly normal people. It's filled with great puzzles, terrible jokes, and chock-full o' variety and surprises. Expect the unexpected.\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, bounce laser beams, and MANY more."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9023048197752658"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com