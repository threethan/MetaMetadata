YDPsgvuS-QVjiQYyIUBH9fJQ0__HLZed9VMS06Sgv9pUg&oe=674D8ADC"}, {"file_name": "Screen_Preorder_v1_Punchline0.png", "id": "962264205584287", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295751_962264208917620_1294629659748263180_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nqFjYWfCg4AQ7kNvgFnthrX&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCT7mAIkoYUNi0F2oQPoQEpN3LBJdbODCDGL6VNBQBebQ&oe=674DAC31"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer_Preorder_v1_ThumbnailB.png", "id": "2457094281347939", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75286673_2457094284681272_2062835017525816130_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vi-KNdkROLYQ7kNvgFhiiFb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIcoAJLVKPXpDSfVbpYwq41qpcffKDCs4Zt7X8l4XCig&oe=674DB11F"}, "display_name": "Snapstick", "keywords": [], "long_description": "# FEATURES\n- Over 600 puzzles\n- Over 5 hours of real good gameplay\n- Over 60 unique mechanics\n- 0 apologies\n- There are 5 bullet points\n\n\n# THINGS YOU'LL DO\n- Grab\n- Snap\n- Stick\n- Win\n- Buy\n- This\n- Game\n\n\n# EVEN MORE INTERESTING DETAILS\n- Over 600 puzzles designed by a multi-award-winning puzzle designer who is much better at designing puzzles than writing store copy\n- Over 2 jokes written by an award-winning puzzle designer who is much better at designing puzzles than writing over 2 jokes\n- Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario + Rabbids Kingdom Battle), who is much better at designing puzzles than writing music, but he had very controlling parents\n- Dogs\n- Passthrough and hands support, because it's hip\n- Music\n- Over 20 unresolved low-priority bugs\n- \u2026And so much more!!!\n- Anticlimactic bullet-points\n\n[headset and controllers sold separately]", "short_description": "Snapstick is a bonkers puzzle game about love. Play delirious, VR-rich mechanics and experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8186299241427562"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "514449824672081"}, {"status": "PUBLISHED", "id": "501793939002779"}, {"status": "PUBLISHED", "id": "364805969800524"}]}, "baseline_offer": {"id": "514449824672081"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727974800, "status": "PUBLISHED", "id": "514449824672081"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8880320492025430", "version": "1.0.0.3"}, "id": "1006917164261315", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8186299231427563", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8880320492025430"}, "release_status": "RELEASED"}, "binary_release_