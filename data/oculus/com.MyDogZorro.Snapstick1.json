&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3PyGsgSycMQ7kNvgEMeKfT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDH_5-Cp7_3dDhuKEOJn_yxNbKpuE4SR-8Li9qZOmCAEA&oe=67320226"}]}, "id": "533483436113193", "locale": "en_US", "screenshots": [{"file_name": "Screen_0_Marbx.png", "id": "1481093952607513", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_1481093955940846_2157622238062465464_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tgR8ui0blMcQ7kNvgGiHWsG&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCrj8_Jdc2Nfd-fOuUH48n_x2OVWgRMv97pyamLF8ua6g&oe=6731D903"}, {"file_name": "Screen_1_Lasers.png", "id": "875909670960284", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974554_875909674293617_6894347120185569387_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J3IoJ6xclXwQ7kNvgENde4f&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDE6a7FMMOYOUtGJZAkJCECHcVY38wbVc_bELWZn52S3w&oe=6731F48B"}, {"file_name": "Screen_2_Toilet_Passthrough.png", "id": "399092643246026", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003226_399092653246025_3513024666909186113_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u7YioOhfCcIQ7kNvgHAzUqK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA9WugHf7pqleK54KKfbgB1Yzznhq3kDwnqEMs7Xew2PA&oe=6731E28C"}, {"file_name": "Screen_Preorder_v1_FencesA.png", "id": "389290203820351", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974907_389290207153684_3232133899963617660_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y18itcVIcq8Q7kNvgGWl6es&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXNImtKqFAXt5OAlCWzXeYTz8T83Xv8poLXAw5hZRhXw&oe=6731D70E"}, {"file_name": "Screen_Preorder_v1_PlanetRings.png", "id": "1010280957553281", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1010280960886614_8548514678587306840_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tfFDhm_rTyEQ7kNvgFKcC8h&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDfxgtVU2uLuR6Pa0HzBVUzhRb7jdIYFB41LsEhvZRnfA&oe=6731FCBB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k-iHiALCTqYQ7kNvgHxqhZS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRGgfMK1qSkDYqj1wC2yojnLV2I_f12tKsWh8yoniwWQ&oe=67320907"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "Snapstick is a **perfectly normal puzzle game** about connecting things together. It's perfect for normal people. Okay? Okay. Don't worry about it.\n\n\n# WHAT'S IN THE BOX?\n* 500+ puzzles by the multi-award-winning designer of Linelight\n* 60+ original mechanics\n* A memorable cast of very normal characters\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007)\n* ...And much, much more!!!\n* Anti-climatic bullet points\n\n# PUZZLES, PUZZLES, PUZZLES\nBuild objects, solve 3D mazes, build coasters, bounce lasers, and much more. Scratch itches deep in your brain.\n{1223440118880908}\n\n# PLAY CUPID\nThis dog is a normal character with a normal storyline.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady.\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}", "short_description": "Snapstick is a perfectly normal puzzle game for perfectly normal people. It's filled with great puzzles, terrible jokes, and chock-full o' variety and surprises. Expect the unexpected.\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, bounce laser beams, and MANY more. You really never know what\u2019s coming next.\n\nFEEL: Experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8802179733172840"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031413_1111167727188203_7809864837003436616_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z_DtcjAG_lIQ7kNvgEA1Nn7&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAUBavSY7aL2GvO6frkZiB8wZ288Syuq33x8RJB2J-_Xg&oe=6731E129"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snapstick", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1727974800, "lastRevision": {"nodes": [{"id": "8186299268094226", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8186299231427563", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "A