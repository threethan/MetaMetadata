# EVEN MORE INTERESTING DETAILS\n- Over 600 puzzles designed by a multi-award-winning puzzle designer who is much better at designing puzzles than writing store copy\n- Over 2 jokes written by an award-winning puzzle designer who is much better at designing puzzles than writing over 2 jokes\n- Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario + Rabbids Kingdom Battle), who is much better at designing puzzles than writing music, but he had very controlling parents\n- Dogs\n- Passthrough and hands support, because it's hip\n- Music\n- Over 20 unresolved low-priority bugs\n- \u2026And so much more!!!\n- Anticlimactic bullet-points\n\n[headset and controllers sold separately]", "short_description": "Snapstick is a bonkers puzzle game about love. Play delirious, VR-rich mechanics and experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8186299241427562"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "514449824672081"}, {