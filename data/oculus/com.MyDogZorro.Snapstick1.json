tjapvgvk_e48MgDlkxoH2LIzB8A&oe=6724CDBB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerThumbnail.png", "id": "510259041956853", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982674_510259045290186_8234367733913918752_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qbANBYl0xgMQ7kNvgGl3O5d&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDdkP6Shp2zWghwOIrqVVU6heHqxVQPirzYyIPBa7diEg&oe=6724DA07"}, "display_name": "Snapstick", "keywords": ["puzzle", "funny", "build", "easy", "slapstick"], "long_description": "Snapstick is a bonkers **puzzle game** filled with **love**. Prepare for a nonstop variety show of mechanics that will tickle your mind, and wacko characters that will warm your heart. Expect the unexpected, ok?\n\n\n# BRAIN-FLIPPING VARIETY\nSolve 3D mazes, build coaster tracks, reflect lasers, and MUCH more. Spatially reason in all the dimensions.\n{1223440118880908}\n\n# PLAY CUPID\nThis starts off cute and quickly flies off the rails. Things get ruff.\n{495296376732218}\n\n# SHADOW WORK\nPlay with size, rotation, and light. This part is pretty shady!\n{3925841577697925}\n\n# RUNNING JOKES\nWe apologize for nothing.\n{1747873889318890}\n\n# HANDS ON\nOptionally ditch those controllers and get fully immersed. Experience a white-glove service!\n{1057724902413239}\n\n# WE\u2019RE ALL CONTENT\n* 500+ puzzles by the multi-award-winning puzzle designer of Linelight\n* 60+ original mechanics\n* Featuring music by the legendary Grant Kirkhope (Banjo-Kazooie, GoldenEye 007, Mario+Rabbids)\n* ...And much, much more!!!\n* Anti-climatic bullet points", "short_description": "Snapstick is a bonkers experience of great puzzles and terrible jokes. It's bursting with variety and surprises. Expect the unexpected!\n\nDO: Assemble roller coasters, match shadows to silhouettes, connect streets to unite dogs, redirect laser beams in all 3 dimensions, and MANY more. It's a jungle of mechanics!\n\nFEEL: Experience themes of toilet love, dog infidelity, secret-agent-couple's-counseling, ASMR planets, and more. It gets weird."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mydogzorro.com/privacy/", "developer_terms_of_service_url": null, "publisher_name": "My Dog Zorro", "support_website_url": null, "website_url": "https://www.mydogzorro.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8788900237834123"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031413_1111167727188203_7809864837003436616_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VJcYqCFVoXcQ7kNvgEwJ-jA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCbVzKcxaWfurV8K2pIWt0nIE1V1jUR1fHlH66ovOI_vg&oe=6724B229"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Snapstick", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1727974800, "lastRevision": {"nodes": [{"id": "8186299268094226", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8186299231427563", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platfo