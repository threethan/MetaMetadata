kBSZ1gUP8jY9YpUIgubRwyI0SJ8-CyxFNtDTw&oe=6720B3B0"}, "display_name": "Grenade Junky", "keywords": ["rocket", "jump", "deathmatch", "multiplayer", "boomer"], "long_description": "The Aliens are coming for Earth, but not if you have anything to say about it. Your mission is simple, go through the Alien Stargate and cause as much havoc and destruction as possible. \nGRENADE JUNKY is an explosive boomer shooter filled with platforming fun and waves of Aliens to fight off. Lay waste to the destructible environments and show the Aliens what Earth is made of!\n\nNEW UPDATE INCLUDES MULTIPLAYER TEAM DEATHMATCH\nPut your grenade jumping skills to the ultimate test in online 3v3 team death match. You'll never play an online shooter as chaotic as this.", "short_description": "GRENADE JUNKY is a Boomer Shooter Platformer built for VR. Multiplayer and Singleplayer modes feature destructible environments, chaotic combat, and all the explosions you could ask for."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.verticalshift.net/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Corrupted Media Productions", "support_website_url": "https://verticalshift.net/cmp", "website_url": "http://verticalshift.net/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8905625169469427"}, "review_messages