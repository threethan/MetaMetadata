: "1013391109069652", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035392_1013391112402985_3081196146907133047_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fs5hSzHMx2kQ7kNvgHYbf1-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDsFGvwI9WgH5YZArI9Gz3cQZckzz2uyZKPyzwfE3qL_w&oe=672617DF"}, {"file_name": "screenshot_6.png", "id": "913955736073738", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75375766_913955739407071_6008632019843998102_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Si_5KLKZLF0Q7kNvgE0dVqA&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCwMfLApOsVgIbyOJMM14nwurPDUN6wqmlb1Qo-Jph1pg&oe=672605FB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "HandPhysicsLab_banner_video_2560_1440.png", "id": "357207155483141", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974483_357207158816474_1904261332127684456_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xVBfkx81D2IQ7kNvgE13MVR&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBbg0fHK4aEfJ5RD6l4zpkNBChGkoYXq1TIK0og4373Yg&oe=672604CF"}, "display_name": "Hand Physics Lab", "keywords": ["hand", "tracking", "physics", "puzzle", "lab"], "long_description": "Enjoy VR like never before by having full control of your hands and fingers to interact physically with your environment and many different objects and experiences! \n\nDiscover the unique universe of Hand Physics Lab where you will need to fulfill a variety of tasks and puzzles with nothing but your hands!\n\nYou will go through more than 80 different puzzles and experiences to unlock multiple playgrounds where you will have full freedom to draw, build and play!\n\nFrom painting eggs with your fingers, building cube towers, using magnets and telekinesis, shaking hands with your clone, petting a virtual cat, and so much more!\n\nYou will definitely put your hands in action!\n\n**Fully playable with hand tracking and/or touch controllers**\n\n**IMPORTANT NOTICE**\nThe quality of your experience when using hand tracking will heavily depend on your lighting conditions. Please read the guidelines (in-game) on how to optimize your play space for best hand tracking conditions.", "short_description": "Enjoy VR like never before by having full control of your hands and fingers to interact physically with your environment and many different objects and experiences! "}]}, "developer_name": "Dennys Kuhnert - Holonautic", "developer_privacy_policy_url": "https://www.holonautic.com/privacy-policy", "developer_terms_of_service_url": "https://www.holonautic.com/#contact", "publisher_name": "Holonautic", "support_website_url": "https://www.holonautic.com/privacy-policy", "website_url": "https://www.holonautic.com/hand-physics-lab", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4920704197979282"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031330_1401574353694495_4566637736836607084_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ar5ne4Nq08cQ7kNvgGyny-N&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCH78w1lFvYPBxYjqanQBR42q6ubkw2W6wzWnEi3HWYfg&oe=67260B71"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hand Physics Lab", "platform": "ANDROID_6DOF", 