 your experience when using hand tracking will heavily depend on your lighting conditions. Please read the guidelines (in-game) on how to optimize your play space for best hand tracking conditions.", "short_description": "Enjoy VR like never before by having full control of your hands and fingers to interact physically with your environment and many different objects and experiences! "}]}, "developer_name": "Dennys Kuhnert - Holonautic", "developer_privacy_policy_url": "https://www.holonautic.com/privacy-policy", "developer_terms_of_service_url": "https://www.holonautic.com/#contact", "publisher_name": "Holonautic", "support_website_url": "https://www.holonautic.com/privacy-policy", "website_url": "https://www.holonautic.com/hand-physics-lab", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "377978390272490"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "PUZZLE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "4920704197979282"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031330_1401574353694495_4566637736836607084_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ml9kT67rlmEQ7kNvgFbsLzg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDC0g5UX9JWvpdAd_bdaQ62HwcaOLCaTbOrPeO_gkvciQ&oe=671B7F71"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_n