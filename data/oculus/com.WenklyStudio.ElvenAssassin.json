e7a0a&_nc_ohc=Y_g9NDtDKvkQ7kNvgG9MGK9&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA7GGLPiXMViqZ8rVb-qWFFVZcSCYSjEVb2N7ajYfOyCA&oe=67238466"}, {"file_name": "migrated_image.png", "id": "2847504151984584", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982632_604667453397889_6569113966260256768_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fV-vFEj48R4Q7kNvgFfMrWh&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVPdWEnm6oFpL5T4i4s13iAxyZQN5n1Y4U8C7Q6uP5ZA&oe=67237C97"}, {"file_name": "EA6.png", "id": "7953607638047084", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75210889_7953607648047083_3724161981674506504_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7ZrfT8oGdjYQ7kNvgGCrofC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC7-h3dc-XEqcdvW8mkXr35uo8H6ew-_DQDz7fdxUEjQQ&oe=67235F95"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape-3.png", "id": "1618060635367734", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75282159_1618060642034400_3971430498575760352_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4nrtgghH9qUQ7kNvgENt0SH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFNnkuYkkuNn9H5jrRkSIoYQWwhrOrZDJD-Jrrx3-HRA&oe=67235251"}, "display_name": "Elven Assassin", "keywords": ["bow", "online", "archery", "rpg", "multiplayer"], "long_description": "Is there anything more epic than slaying hordes of orcs and dragons with a bow in Virtual Reality? When nothing comes to your mind, then you probably should try this. If you thought: \"Of course, slaying them with my friends online in co-op mode!\" then this is a matter of destiny.\n\nBECOME AN ELVEN ASSASSIN.\nTake a bow and kill hundreds of enemies that want to get into the elven town and destroy it. As an elven assassin, you will make spectacular shots like long-distance headshots.\n\nPIECE OF CAKE, THEN?\nNot really. The Orcs are running fast, they break into houses to hide from your arrows, and when they get furious, their massive axe is thrown to splash your head into pieces. \n\nASSASSIN UNITED.\nUp to four assassins may unite to defend the town. Communicate using voice chat, but watch your language. \n\nDisclaimer: \nAny similarity to any other fantasy movie, game, or book is purely coincidental.", "short_description": "Take a bow and kill hordes of orcs in the epic castle defense game. You can play alone or unite with other assassins in online co-op mode. PS. Be careful to avoid massive axes thrown at you by orc warriors."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacypolicy", "developer_terms_of_service_url": "https://www.wenklystudio.com/_files/ugd/957014_bb46a3f320c84dc3ac8a4c15f507bf3a.pdf", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/elven-assassin", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "24902782602703482"}, "review_messages": ["Approving this update. "]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75556281_3372025449610589_1206488216322750101_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6u5XhVRrJB4Q7kNvgEJvPKG&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZmT9Gy6_IMqpVX_R14c9i6yLaCMvNbNF90sJ7q56-TA&oe=67235938"}, "is_concept": fa