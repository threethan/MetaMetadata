64.5771-25/75308615_648775336610558_3187600010506862349_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gATQLH07ZCsQ7kNvgGGrtSI&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYCkExzIAIS53mxvQwuIXvWueVZ-HU729ZLIzzleGHlBYw&oe=6728CA66"}, {"file_name": "migrated_image.png", "id": "2847504151984584", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982632_604667453397889_6569113966260256768_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yxSYcUfgpnYQ7kNvgGJPS2k&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYA4hyzJxcWmQgBUHMA3mm05-zQLwZD0pFFMsrooQ2Y8BA&oe=6728C297"}, {"file_name": "EA6.png", "id": "7953607638047084", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75210889_7953607648047083_3724161981674506504_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lNxuHqc-EekQ7kNvgHSiD_F&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCV0PvrHUX6Y2_ZDEbStqmsqczEDiuv0u5AN1R4MWejPg&oe=6728A595"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape-3.png", "id": "1618060635367734", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75282159_1618060642034400_3971430498575760352_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LGJxUkTDvG8Q7kNvgEtvool&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAP3UL4y3GXuRGt8PtV9FIDC_ue38xN-5cih2Hehe7dBg&oe=67289851"}, "display_name": "Elven Assassin", "keywords": ["bow", "online", "archery", "rpg", "multiplayer"], "long_description": "Is there anything more epic than slaying hordes of orcs and dragons with a bow in Virtual Reality? When nothing comes to your mind, then you probably should try this. If you thought: \"Of course, slaying them with my friends online in co-op mode!\" then this is a matter of destiny.\n\nBECOME AN ELVEN ASSASSIN.\nTake a bow and kill hundreds of enemies that want to get into the elven town and destroy it. As an elven assassin, you will make spectacular shots like long-distance headshots.\n\nPIECE OF CAKE, THEN?\nNot really. The Orcs are running fast, they break into houses to hide from your arrows, and when they get furious, their massive axe is thrown to splash your head into pieces. \n\nASSASSIN UNITED.\nUp to four assassins may unite to defend the town. Communicate using voice chat, but watch your language. \n\nDisclaimer: \nAny similarity to any other fantasy movie, game, or book is purely coincidental.", "short_description": "Take a bow and kill hordes of orcs in the epic castle defense game. You can play alone or unite with other assassins in online co-op mode. PS. Be careful to avoid massive axes thrown at you by orc warriors."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacypolicy", "developer_terms_of_service_url": "https://www.wenklystudio.com/_files/ugd/957014_bb46a3f320c84dc3ac8a4c15f507bf3a.pdf", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/elven-assassin", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "821934236779161"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "24902782602703482"}, "review_messages": ["Approving this update. "]}]}, "cover_square_image": {"uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75556281_3372025449610589_1206488216322750101_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3QYzRGw5p8AQ7