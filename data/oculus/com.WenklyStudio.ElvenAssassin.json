}, {"file_name": "migrated_image.png", "id": "2847504151984584", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982632_604667453397889_6569113966260256768_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9PUbXYO_FToQ7kNvgEUyglg&_nc_ht=scontent.oculuscdn.com&oh=00_AYC2a-EYKCqMcM12PoFZcIQEToh7Tb5K-BMih5ID7243BQ&oe=66EEC097"}, {"file_name": "EA6.png", "id": "7953607638047084", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210889_7953607648047083_3724161981674506504_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V_s5keF2OQgQ7kNvgGgWvOx&_nc_ht=scontent.oculuscdn.com&oh=00_AYA2GLNUrZs6v1ORxfATeJ9rjkPbqdnqHGJOWYCzg1LRCg&oe=66EEA395"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover Landscape-3.png", "id": "1618060635367734", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282159_1618060642034400_3971430498575760352_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=InX3Wesdaj4Q7kNvgHhXxYy&_nc_ht=scontent.oculuscdn.com&oh=00_AYDbwOrFdYMQWDuVDXf3WHwwL1bP4Bw68EWxIxcP3kqsfA&oe=66EE9651"}, "display_name": "Elven Assassin", "keywords": ["bow", "online", "archery", "rpg", "multiplayer"], "long_description": "Is there anything more epic than slaying hordes of orcs and dragons with a bow in Virtual Reality? When nothing comes to your mind, then you probably should try this. If you thought: \"Of course, slaying them with my friends online in co-op mode!\" then this is a matter of destiny.\n\nBECOME AN ELVEN ASSASSIN.\nTake a bow and kill hundreds of enemies that want to get into the elven town and destroy it. As an elven assassin, you will make spectacular shots like long-distance headshots.\n\nPIECE OF CAKE, THEN?\nNot really. The Orcs are running fast, they break into houses to hide from your arrows, and when they get furious, their massive axe is thrown to splash your head into pieces. \n\nASSASSIN UNITED.\nUp to four assassins may unite to defend the town. Communicate using voice chat, but watch your language. \n\nDisclaimer: \nAny similarity to any other fantasy movie, game, or book is purely coincidental.", "short_description": "Take a bow and kill hordes of orcs in the epic castle defense game. You can play alone or unite with other assassins in online co-op mode. PS. Be careful to avoid massive axes thrown at you by orc warriors."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.wenklystudio.com/privacypolicy", "developer_terms_of_service_url": "https://www.wenklystudio.com/_files/ugd/957014_bb46a3f320c84dc3ac8a4c15f507bf3a.pdf", "publisher_name": "Wenkly Studio Sp. z o.o.", "support_website_url": null, "website_url": "https://www.wenklystudio.com/elven-assassin", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "RPG", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "24902782602703482"}, "review_messages": ["Approving this update. "]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556281_3372025449610589_1206488216322750101_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IX8NWn7HILgQ7kNvgHVHbz9&_nc_ht=scontent.oculuscdn.com&oh=00_AYCx6U5lX5Ltp3J8h3Zri01wEagXtXuUXQ4YMlq7aP8bDw&oe=66EE9D38"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Elven Assassin", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "co