teresting multiplayer game. You can swing between the skyscrapers, race through the streets and swing around the worlds with your friends.  \n\nThis game is free.", "short_description": "Fight with titans by the spider web, or play as the titan to kill Web-Guys."}]}, "developer_name": null, "developer_privacy_policy_url": "http://web.manyatang.com/titan_vs_web-guy/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "Fengu Studio", "support_website_url": null, "website_url": "http://web.manyatang.com/titan_vs_web-guy", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2710427532541308"}, {"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP"], "id": "27744703478509959"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "554115090768002"}]}, "baseline_offer": {"id": "554115090768002"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1733580600, "status": "PUBLISHED", "id": "554115090768002"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "28049128368067467", "version": "1.5.1"}, "id": "559863376672847", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "27714106704902970", "is