ms to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose good humans.", "short_description": "A touching, funny, infuriating, harrowing and ultimately hopeful experience, drawn from true stories of people with profound physical disabilities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.talkingmimes.com/TLA_Privacy.pdf", "developer_terms_of_service_url": "https://talkingmimes.com/TMMD_ToS.pdf", "publisher_name": "TLA Technologies", "support_website_url": "https://talkingmimes.com/#email", "website_url": "https://www.talkingmimesmustdie.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "359032266060667"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "596589495078231"}]}, "baseline_offer": {"id": "596589495078231"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1624462500, "status": "PUBLISHED", "id": "596589495078231"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8081565055259235", "version": "2.10"}, "id": "293473372263471", "channel_name": "LIVE"}]