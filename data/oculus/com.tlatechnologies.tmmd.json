7o6By-WC&oh=00_AYCC88uL5fjWKfu0uLPeawRXWykoMtYflou1e35zdKGy5A&oe=66D5A221"}, {"file_name": "TMMD_Oculus_Cover_16x9.png", "id": "861449778898610", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569423_861449782231943_9221024484292308671_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XJ6d7jqJN_wQ7kNvgFv7IH9&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU5QKFhYPS-MUfv7o6By-WC&oh=00_AYAlz4VP4YjyEYxVI1ke-9qWvGzyu2wHSgU-NgPe5FVHWw&oe=66D59644"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TMMD_Oculus_Cover_16x9.png", "id": "1239254960080580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75254876_1239254963413913_6147596762429332943_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q3J-fxCSa9AQ7kNvgGuDua1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU5QKFhYPS-MUfv7o6By-WC&oh=00_AYBNnhGxpSHsURCsAUmSlnv_Ca2B66WxnUneFsUdVMGD8w&oe=66D5A0F4"}, "display_name": "Talking Mimes", "keywords": [], "long_description": "This is a narrative video experience (not a game) with a companion workshop available from https://www.talkingmimes.com/#AppAndWorkshops\n\nTalking Mimes is a touching, funny, infuriating, harrowing and ultimately hopeful experience. A virtual reality narrative drawn from true stories of people with profound physical disabilities. An emotional education piece developed for everyone - whether you're a caregiver, teacher, support worker, health professional, family member, friend, lover, hater, or total stranger to disability. \n\nAlmost all of us will have an access need at some point in our lives, and we will be at the mercy of others. Talking Mimes aims to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose good humans.\n\nClosed Captions and Audio Description available in English.", "short_description": "This is a narrative video experience (not a game) with a companion workshop available from https://www.talkingmimes.com/#AppAndWorkshops\n\nTalking Mimes is a touching, funny, infuriating, harrowing and ultimately hopeful experience, drawn from true stories of people with profound physical disabilities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.talkingmimes.com/TLA_Privacy.pdf", "developer_terms_of_service_url": "https://talkingmimes.com/TMMD_ToS.pdf", "publisher_name": "TLA Technologies", "support_website_url": "https://talkingmimes.com/#email", "website_url": "https://www.talkingmimesmustdie.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7643394815742930"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_1322715901714458_7457104381727058986_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SXNsRdf_DsMQ7kNvgFoTBlL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU5QKFhYPS-MUfv7o6By-WC&oh=00_AYDRGReesz8k2KJA_Yv87xPQux5QkYsA59C9aK2G5qsl4g&oe=66D5A355"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Talking Mimes", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_to