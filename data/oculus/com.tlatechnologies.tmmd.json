tent-iad3-1.oculuscdn.com/v/t64.5771-25/75443237_1192568717922254_1207839696072229435_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EzGkjUm8UUgQ7kNvgENgmsI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBYeyNz78s24dipuYTTL5b1EEdpfezj51Scf5PYgpxCxg&oe=67503D6F"}, {"file_name": "vlcsnap-2018-10-26-22h58m44s843.png", "id": "518677602476869", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572930_518677605810202_5106324542655240980_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fonADrTTuBIQ7kNvgH44pXT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArtdt-bVs3sgMd2bA11Sod_V9AP9p4LO1-8AmrWesxGg&oe=6750331C"}, {"file_name": "vlcsnap-2018-10-26-23h01m05s634.png", "id": "4347537548643049", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476596_4347537551976382_58274570620411688_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4eXX9F8qMUIQ7kNvgH2BHHa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA10h0KnP79Y0b9DgotdE6EU8pe8KsDqrRlVxV7AVhVpg&oe=67503730"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Talking Mimes Must Die", "keywords": [], "long_description": "Talking Mimes Must Die is a touching, funny, infuriating, harrowing and ultimately hopeful experience. A virtual reality narrative drawn from true stories of people with profound physical disabilities. An emotional education piece developed for everyone - whether you're a caregiver, teacher, support worker, health professional, family member, friend, lover, hater, or total stranger to disability. \n\nAlmost all of us will have an access need at some point in our lives, and we will be at the mercy of others. Talking Mimes aims to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose good humans.", "short_description": "A touching, funny, infuriating, harrowing and ultimately hopeful experience, drawn from true stories of people with profound physical disabilities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.talkingmimes.com/TLA_Privacy.pdf", "developer_terms_of_service_url": "https://talkingmimes.com/TMMD_ToS.pdf", "publisher_name": "TLA Technologies", "support_website_url": "https://talkingmimes.com/#email", "website_url": "https://www.talkingmimesmustdie.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "359032266060667"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "596589495078231"}]}, "baseline_offer": {"id": "596589495078231"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1624462500, "status": "PUBLISHED", "id": "596589495078231"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8081565055259235", "version": "2.10"}, "id": "293473372263471", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3968804079868707", "is_concept": false, "latest_releas