/v/t64.5771-25/38982571_1317920316251010_8408194208831164109_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8XSkzR1FdV4Q7kNvgETM9sz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDdNRTjB8vyuC83U3pX1QiaKQDknaYOPHgeqKaBi-E6rA&oe=6773F0C2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TMMD_Oculus_Cover_16x9.png", "id": "1239254960080580", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75254876_1239254963413913_6147596762429332943_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j4bBHSjPwqMQ7kNvgFtZpfT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDgtPcWYX6c-KaTJMy7GRQy5HW5GiMwVoJbcV9HPJrbcw&oe=6773D4F4"}, "display_name": "Talking Mimes", "keywords": [], "long_description": "This is a narrative video experience (not a game) with a companion workshop available from https://www.talkingmimes.com/#AppAndWorkshops\n\nTalking Mimes is a touching, funny, infuriating, harrowing and ultimately hopeful experience. A virtual reality narrative drawn from true stories of people with profound physical disabilities. An emotional education piece developed for everyone - whether you're a caregiver, teacher, support worker, health professional, family member, friend, lover, hater, or total stranger to disability. \n\nAlmost all of us will have an access need at some point in our lives, and we will be at the mercy of others. Talking Mimes aims to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose good humans.\n\nClosed Captions and Audio Description available in English.", "short_description": "This is a narrative video experience (not a game) with a companion workshop available from https://www.talkingmimes.com/#AppAndWorkshops\n \nTalking Mimes is a touching, funny, infuriating, harrowing and ultimately hopeful experience, drawn from true stories of people with profound physical disabilities."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.talkingmimes.com/TLA_Privacy.pdf", "developer_terms_of_service_url": "https://talkingmimes.com/TMMD_ToS.pdf", "publisher_name": "TLA Technologies", "support_website_url": "https://talkingmimes.com/#email", "website_url": "https://www.talkingmimesmustdie.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPERIENCE_360_NON_GAME", "NARRATIVE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD", "GAMEPAD_VIA_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8677261559022912"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036641_1322715901714458_7457104381727058986_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kt-hbou9KvMQ7kNvgH0mMCn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBXi99FgR0kpx8hJe-mfLmPatGNwjR7X9Tx8FI8-yhScQ&oe=6773D755"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Talking Mimes", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1624462512, "lastRevision": {"nodes": [{"id": "4089777794447724", "release_type": "SCHEDULED", "administration_status": "APPROVED