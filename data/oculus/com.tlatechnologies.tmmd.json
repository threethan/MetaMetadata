ent-iad3-1.oculuscdn.com/v/t64.5771-25/75443237_1192568717922254_1207839696072229435_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9HWhZCh0DMQ7kNvgGZd91i&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDJ6C-26NNC-U9Jgtd5Gs3mXWLH24VgNHCKy6PI7aUvPw&oe=677D106F"}, {"file_name": "vlcsnap-2018-10-26-22h58m44s843.png", "id": "518677602476869", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572930_518677605810202_5106324542655240980_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SMNXmObJFHgQ7kNvgGk3T-C&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB5LB658F9AvSoCE8gwOOaOPkTx-BDjzK2Okb7lpsGSYA&oe=677D061C"}, {"file_name": "vlcsnap-2018-10-26-23h01m05s634.png", "id": "4347537548643049", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75476596_4347537551976382_58274570620411688_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jOEJwcgKNE8Q7kNvgEJdw4x&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6IOEY5URNZ_reEdJb_LsKSBD0cqB5D8O-Iz1ffZCWOw&oe=677D0A30"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Talking Mimes Must Die", "keywords": [], "long_description": "Talking Mimes Must Die is a touching, funny, infuriating, harrowing and ultimately hopeful experience. A virtual reality narrative drawn from true stories of people with profound physical disabilities. An emotional education piece developed for everyone - whether you're a caregiver, teacher, support worker, health professional, family member, friend, lover, hater, or total stranger to disability. \n\nAlmost all of us will have an access need at some point in our lives, and we will be at the mercy of others. Talking Mimes aims to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose 