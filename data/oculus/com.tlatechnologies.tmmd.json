ent-ams4-1.oculuscdn.com/v/t64.5771-25/75443237_1192568717922254_1207839696072229435_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7i0kEXqrjH0Q7kNvgHLL9Dc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBJ-n1NH8GQp6_eGl_2obYAbgPTquoiR4PXwoO6JI9JWA&oe=675D6C6F"}, {"file_name": "vlcsnap-2018-10-26-22h58m44s843.png", "id": "518677602476869", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572930_518677605810202_5106324542655240980_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aQAXYvXq4wAQ7kNvgH9tlBN&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAL46zOn0n30P-neNJUnrLjW4g_FlB8S-xMUjGKAc44iw&oe=675D621C"}, {"file_name": "vlcsnap-2018-10-26-23h01m05s634.png", "id": "4347537548643049", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75476596_4347537551976382_58274570620411688_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9bRU_y9wEfAQ7kNvgHdK8A1&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCZjLYVmMXq2XjSjL5khrZB7WHz_4iq6ZXZFiyZp8O04w&oe=675D6630"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Talking Mimes Must Die", "keywords": [], "long_description": "Talking Mimes Must Die is a touching, funny, infuriating, harrowing and ultimately hopeful experience. A virtual reality narrative drawn from true stories of people with profound physical disabilities. An emotional education piece developed for everyone - whether you're a caregiver, teacher, support worker, health professional, family member, friend, lover, hater, or total stranger to disability. \n\nAlmost all of us will have an access need at some point in our lives, and we will be at the mercy of others. Talking Mimes aims to better inform our behaviour towards those of us that have these needs now. To start a practical conversation around safety and respect. To actively reject the soft bigotry of low expectations. To peel back the layers of alienation and teach us how to be less accidentally condescending arseholes, and more on purpose 