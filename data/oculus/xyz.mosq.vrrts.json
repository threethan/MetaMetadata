.com/v/t64.5771-25/75340715_838519150087415_63241492529224115_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ky7nEdLfSw8Q7kNvgFxZEa9&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYAsQ7obrZ_V5YY4Bfu4x7iTPejhonHzdGfpS6OwsrqNpg&oe=675198FD"}, {"file_name": "20210525-021212.png", "id": "208898750900245", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39001711_208898754233578_1590425003260610296_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M4pvvnB20_0Q7kNvgGtAvmJ&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAlHntbETVD1PJk1XrpF0B8FycNmbtfHWgW_mildFKBGA&oe=6751A113"}, {"file_name": "20210525-014936.png", "id": "490029918982047", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982562_490029922315380_2472132374884165007_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D2pu3y8BBswQ7kNvgG-xzb_&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBKcDT0wvuZX9A3UR0-AsFYCcBoF5WUSGOAf4EXQvQL-w&oe=67518B72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2021-05-29 23.06.46.png", "id": "873940063188913", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974479_873940066522246_2661076465911733640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UlAhmm4o0VkQ7kNvgG24Vnp&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDz2uPbOxHTLb1qAJC4FJ7rg6BrIPgTbwEbq3BwCIo4JA&oe=67519D1A"}, "display_name": "Playing VR with Girl Friend", "keywords": [], "long_description": "[Description]\nEnjoy the conversation with your girl friend!\nThis is a strategy game.\nPlace the units in the map using your hand.\nDestory the enemy's Base to win!\nDefeat the enemies before they destroy your Base.\n\n[How to Play]\nUse your hand or a controller to play!\nPress the button, pick up the units and release them in the map!\nThe left and right sticks allow you to move the user's position slightly.\n\n[Type of Units]\n-Base\nThis is the Base.\nBuild your Base stronger!!\n\n-Fighter\nA common flying unit.\nGround & Air Attack.\n\n-Factory\nA factory unit.\nIt generates cash.\n\n-Bomber\nA flying unit skilled for\nbombing and ground attack.\n\n-Tank\nAn anti-ground unit.\nAttacks with rapid fire.\n\n-Anti-aircraft Artillery\nA placement unit using missles.\nEffective to flying units.\n\n-Sheild\nA placement unit for defense.\nIt has high durability.\n", "short_description": "Let's play a VR video game with your girl friend!\nThis time it's a strategy game.\nPick up the units and release them in the map.\nThe units will start fighting automatically."}, {"images": {"nodes": [{"file_name": "PdpArt_3000x900_JP.png", "id": "266102791924715", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974650_266102795258048_1135847423250422851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A-L4GiZSutsQ7kNvgGvaibG&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYByFd7rB-gn8wvNnIuAP2RHwghN26kHercN1onf7jMXXQ&oe=67518A34"}, {"file_name": "Art_1008x1440.png", "id": "4244000545622202", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974522_4244000548955535_6121386002098751284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wv7wMOsr8bcQ7kNvgEP9TBx&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDBiZpSLqM5evZqyDHPVuMH6bs66Go3_--tGyGOr7mZJg&oe=6751AAC5"}, {"file_name": "Art_2560x1440.png", "id": "3609745079249612", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974800_3609745082582945_8822499596742085698_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wbWhMzc_GzYQ7kNvgE8PjF4&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYA_Jy7RLBY5bwEadatT9ygDzCBaFnMSBJPk4nVjcfvr2w&oe=6751A28C"}, {"file_name": "Art_1440x1440.png", "id": "302813054883485", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974499_302813058216818_2349166245113285037_n.png?_nc_cat=1