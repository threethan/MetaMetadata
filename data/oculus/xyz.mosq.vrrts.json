_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBC6xP6OrnzO7oQ4MN5h8o-xWR-pQcKuDSAYYSKDZb1hg&oe=6724B872"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2021-05-29 23.06.46.png", "id": "873940063188913", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974479_873940066522246_2661076465911733640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n2SwfY7WhAQQ7kNvgExp8Iq&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBzLrYE9vCWomg_qVPXFUdV61RJ6qRIuUWYCgU9bLWrPg&oe=6724CA1A"}, "display_name": "Playing VR with Girl Friend", "keywords": [], "long_description": "[Description]\nEnjoy the conversation with your girl friend!\nThis is a strategy game.\nPlace the units in the map using your hand.\nDestory the enemy's Base to win!\nDefeat the enemies before they destroy your Base.\n\n[How to Play]\nUse your hand or a controller to play!\nPress the button, pick up the units and release them in the map!\nThe left and right sticks allow you to move the user's position slightly.\n\n[Type of Units]\n-Base\nThis is the Base.\nBuild your Base stronger!!\n\n-Fighter\nA common flying unit.\nGround & Air Attack.\n\n-Factory\nA factory unit.\nIt generates cash.\n\n-Bomber\nA flying unit skilled for\nbombing and ground attack.\n\n-Tank\nAn anti-ground unit.\nAttacks with rapid fire.\n\n-Anti-aircraft Artillery\nA placement unit using missles.\nEffective to flying units.\n\n-Sheild\nA placement unit for defense.\nIt has high durability.\n", "short_description": "Let's play a VR video game with your girl friend!\nThis time it's a strategy game.\nPick up the units and release them in the map.\nThe units will start fighting automatically."}, {"images": {"nodes": [{"file_name": "Art_1008x1440.png", "id": "4244000545622202", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974522_4244000548955535_6121386002098751284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NyMrC8qX-ewQ7kNvgHqph0E&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCjyWWiStbqCPTdO1o5JO-A8kIfF4RBkivnFAgwSPYNFA&oe=6724D7C5"}, {"file_name": "Art_2560x1440.png", "id": "3609745079249612", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974800_3609745082582945_8822499596742085698_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G4n03OpQ444Q7kNvgGfABmZ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBeiCLDuCEpFnoRcDKKd730Zh7RBk-FAQZH4goMZ_scgQ&oe=6724CF8C"}, {"file_name": "Icon_512x512_JP.png", "id": "1572766619588975", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974802_1572766622922308_961628044886678894_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TbKS-yytG60Q7kNvgGxFnTV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBQsICb_Mq7QeA8lVtp6IJwY8v4XHr4QFMV2n8VRwHyGA&oe=6724AFA6"}, {"file_name": "Art_1440x1440.png", "id": "302813054883485", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974499_302813058216818_2349166245113285037_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zve0RTPY_dUQ7kNvgGYAOxE&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB3A6oIgNsGrOz7j9a0dqwJ-zEUnWWJVfjrNqZEGymovw&oe=6724A5C1"}, {"file_name": "PdpArt_3000x900_JP.png", "id": "266102791924715", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974650_266102795258048_1135847423250422851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cxcsHtonLRsQ7kNvgHLTumy&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDxuXhBbBu67cHrLNe2KkILV_aPgCrF92jAupgTsd1iLw&oe=6724B734"}, {"file_name": "LargeLogoJP.png", "id": "202796668155431", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035470_202796671488764_2028465106236577141_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nzXXvXs1nAgQ7kNvgF6e2hW&_nc_zt=3&_n