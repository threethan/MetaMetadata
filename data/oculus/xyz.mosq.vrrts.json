.com/v/t64.5771-25/75340715_838519150087415_63241492529224115_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5Tfujihy9SwQ7kNvgFJ7UYJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDqdiXdP9l0xD6pvyQBhkMRq_YbUO1Ea_oTwDHrOEDL5g&oe=6741C6FD"}, {"file_name": "20210525-021212.png", "id": "208898750900245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001711_208898754233578_1590425003260610296_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WBc0peEhiLkQ7kNvgG2lbDp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJYkaq_vLkooyuuOsMaTjj61t4XgMaI3fmjpdiWODM8A&oe=6741CF13"}, {"file_name": "20210525-014936.png", "id": "490029918982047", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982562_490029922315380_2472132374884165007_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tBW6TSgqS_gQ7kNvgFaiTSf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCnk21nQoxxCK0svqB12eMex5UZXe4SqnekwLuISvxffQ&oe=6741B972"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2021-05-29 23.06.46.png", "id": "873940063188913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974479_873940066522246_2661076465911733640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CG40xT_WbmkQ7kNvgFAHbbU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCgZL4jZ_e0pKydNDWxbke6p_GKHZeLhXxWkPaxiZz6MA&oe=6741CB1A"}, "display_name": "Playing VR with Girl Friend", "keywords": [], "long_description": "[Description]\nEnjoy the conversation with your girl friend!\nThis is a strategy game.\nPlace the units in the map using your hand.\nDestory the enemy's Base to win!\nDefeat the enemies before they destroy your Base.\n\n[How to Play]\nUse your hand or a controller to play!\nPress the button, pick up the units and release them in the map!\nThe left and right sticks allow you to move the user's position slightly.\n\n[Type of Units]\n-Base\nThis is the Base.\nBuild your Base stronger!!\n\n-Fighter\nA common flying unit.\nGround & Air Attack.\n\n-Factory\nA factory unit.\nIt generates cash.\n\n-Bomber\nA flying unit skilled for\nbombing and ground attack.\n\n-Tank\nAn anti-ground unit.\nAttacks with rapid fire.\n\n-Anti-aircraft Artillery\nA placement unit using missles.\nEffective to flying units.\n\n-Sheild\nA placement unit for defense.\nIt has high durability.\n", "short_description": "Let's play a VR video game with your girl friend!\nThis time it's a strategy game.\nPick up the units and release them in the map.\nThe units will start fighting automatically."}, {"images": {"nodes": [{"file_name": "PdpArt_3000x900_JP.png", "id": "266102791924715", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_266102795258048_1135847423250422851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=um3w0O_cbNEQ7kNvgGXvOMa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDfnBBPf63g9yq0GKY6rqcfYXCHJsxb2Qu99jsa9FWjmw&oe=6741B834"}, {"file_name": "Art_1008x1440.png", "id": "4244000545622202", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_4244000548955535_6121386002098751284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylhzzIGXJmAQ7kNvgFowbvE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAcJ0D1m09CXgs9quTtPoUmlsJ0aEv9ojZkg9udYzggdQ&oe=6741D8C5"}, {"file_name": "Art_2560x1440.png", "id": "3609745079249612", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_3609745082582945_8822499596742085698_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=goElvnIreA0Q7kNvgESmg1r&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCkhBFxbe4dGXBsD6YIhUVhoJGUv00_y9O8LccxDhCExw&oe=6741D08C"}, {"file_name": "Art_1440x1440.png", "id": "302813054883485", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974499_302813058216818_2349166245113285037_n.png?_nc_cat=1