.com/v/t64.5771-25/75340715_838519150087415_63241492529224115_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GjeL-HPmt1gQ7kNvgGfewS6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxP1Ty7RS6UPOcR4_sFGm4PqAcFvDYiKZBQe6TGSoBOQ&oe=6723747D"}, {"file_name": "20210525-021212.png", "id": "208898750900245", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001711_208898754233578_1590425003260610296_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S9KD26xAsbsQ7kNvgG4tovE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAJsebe-Hk2ctIRwtgm7jBhRFiOGHjsQeTHBIP85J_vDQ&oe=67237C93"}, {"file_name": "20210525-014936.png", "id": "490029918982047", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982562_490029922315380_2472132374884165007_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=befWnwiS-k4Q7kNvgGVCxOf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBeElb3eTOLxxaHVaht2VJX2athNKaUw55Poexgk616Ug&oe=672366F2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2021-05-29 23.06.46.png", "id": "873940063188913", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974479_873940066522246_2661076465911733640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n2SwfY7WhAQQ7kNvgGuFBCn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA4dTz-n0A6LS8lEXb5-99gNZPRaE8vUrvJ4kUcGAIdig&oe=6723789A"}, "display_name": "Playing VR with Girl Friend", "keywords": [], "long_description": "[Description]\nEnjoy the conversation with your girl friend!\nThis is a strategy game.\nPlace the units in the map using your hand.\nDestory the enemy's Base to win!\nDefeat the enemies before they destroy your Base.\n\n[How to Play]\nUse your hand or a controller to play!\nPress the button, pick up the units and release them in the map!\nThe left and right sticks allow you to move the user's position slightly.\n\n[Type of Units]\n-Base\nThis is the Base.\nBuild your Base stronger!!\n\n-Fighter\nA common flying unit.\nGround & Air Attack.\n\n-Factory\nA factory unit.\nIt generates cash.\n\n-Bomber\nA flying unit skilled for\nbombing and ground attack.\n\n-Tank\nAn anti-ground unit.\nAttacks with rapid fire.\n\n-Anti-aircraft Artillery\nA placement unit using missles.\nEffective to flying units.\n\n-Sheild\nA placement unit for defense.\nIt has high durability.\n", "short_description": "Let's play a VR video game with your girl friend!\nThis time it's a strategy game.\nPick up the units and release them in the map.\nThe units will start fighting automatically."}, {"images": {"nodes": [{"file_name": "PdpArt_3000x900_JP.png", "id": "266102791924715", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_266102795258048_1135847423250422851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sBr2-k66SqsQ7kNvgGCn3zN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3az-IVNhUyW9u8O5JaxyPp5jkxw4EOs3BaLtoYdtySA&oe=672365B4"}, {"file_name": "Art_1008x1440.png", "id": "4244000545622202", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974522_4244000548955535_6121386002098751284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NyMrC8qX-ewQ7kNvgG2dif-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDQmN7SQzO8kVdcmIy9BOuoPS2p-qD209nyeBeE1lDPqw&oe=67238645"}, {"file_name": "Art_2560x1440.png", "id": "3609745079249612", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974800_3609745082582945_8822499596742085698_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y13D6cinXwMQ7kNvgH8f-Xg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8O0dBeUKmBLiQ7oRcGPJwvVVXnOyaU6Rx7uMV8DETjQ&oe=67237E0C"}, {"file_name": "Art_1440x1440.png", "id": "302813054883485", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974499_302813058216818_2349166245113285037_n.png?_nc_cat=1