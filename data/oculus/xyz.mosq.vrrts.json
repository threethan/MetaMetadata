.com/v/t64.5771-25/75340715_838519150087415_63241492529224115_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EIhz50qhZQUQ7kNvgGurf-V&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCU0oQhzjw3ElBh08vj5t63ENlkcOL7a_xdLHkcvrQi7w&oe=672A0BFD"}, {"file_name": "20210525-021212.png", "id": "208898750900245", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/39001711_208898754233578_1590425003260610296_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vAancyZ-v1gQ7kNvgHhRRMt&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAPrL24lVLLj36e57grJbSOHjkOl6Wj0HIEzO8ZsnCaLg&oe=672A1413"}, {"file_name": "20210525-014936.png", "id": "490029918982047", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/38982562_490029922315380_2472132374884165007_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aqB7Rh3k1qEQ7kNvgGuQ-PG&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYBqasK1uccZ94TgHkqmhBhxpi8JEoaqIs3QDHuqmT3VcQ&oe=6729FE72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8 2021-05-29 23.06.46.png", "id": "873940063188913", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974479_873940066522246_2661076465911733640_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NEzMIRhatb8Q7kNvgF2GYt2&_nc_zt=3&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYCBijGaS1uM7Tw5L9lgXt1_yBGBoM5TshhREFb1lZIwTA&oe=672A101A"}, "display_name": "Playing VR with Girl Friend", "keywords": [], "long_description": "[Description]\nEnjoy the conversation with your girl friend!\nThis is a strategy game.\nPlace the units in the map using your hand.\nDestory the enemy's Base to win!\nDefeat the enemies before they destroy your Base.\n\n[How to Play]\nUse your hand or a controller to play!\nPress the button, pick up the units and release them in the map!\nThe left and right sticks allow you to move the user's position slightly.\n\n[Type of Units]\n-Base\nThis is the Base.\nBuild your Base stronger!!\n\n-Fighter\nA common flying unit.\nGround & Air Attack.\n\n-Factory\nA factory unit.\nIt generates cash.\n\n-Bomber\nA flying unit skilled for\nbombing and ground attack.\n\n-Tank\nAn anti-ground unit.\nAttacks with rapid fire.\n\n-Anti-aircraft Artillery\nA placement unit using missles.\nEffective to flying units.\n\n-Sheild\nA placement unit for defense.\nIt has high durability.\n", "short_description": "Let's play a VR video game with your girl friend!\nThis time it's a strategy game.\nPick up the units and release them in the map.\nThe units will start fighting automatically."}, {"images": {"nodes": [{"file_name": "PdpArt_3000x900_JP.png", "id": "266102791924715", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974650_266102795258048_1135847423250422851_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2pCMiEZVlhwQ7kNvgFI9fOs&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBn-KEVUsTG-Je8bwWXyTEZyFqrOs5T3fQrEaBVXwjI1w&oe=6729FD34"}, {"file_name": "Art_1008x1440.png", "id": "4244000545622202", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974522_4244000548955535_6121386002098751284_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dU2ky6pUUEkQ7kNvgEUKeOh&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYAuOm4Cl0hS4rr50LTMMvON1gSN2Wkm4-PXFm7ifI-G-w&oe=672A1DC5"}, {"file_name": "Art_2560x1440.png", "id": "3609745079249612", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974800_3609745082582945_8822499596742085698_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yYs-r3WjzeYQ7kNvgHxffzU&_nc_zt=3&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYCX6BnnlkE18esoXK4_e3UnWAh1kctZ9d9l-79VPg9fEg&oe=672A158C"}, {"file_name": "Art_1440x1440.png", "id": "302813054883485", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/38974499_302813058216818_2349166245113285037_n.png?_nc_cat=1