98D9"}, {"file_name": "migrated_image.png", "id": "863543127392978", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162745_1043450449056171_1107328641_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9wFnjbzCx_sQ7kNvgFMlmr2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAswaoFRALphvdTDwyNeAb26R-WY6xAEIZl0Nq-HSfoJA&oe=676EA2A4"}, {"file_name": "migrated_image.png", "id": "204855680781206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138771_856803251097648_1060911761_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vXvLfKg67mEQ7kNvgFgPi0j&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1t2D3IpIWkhqnl7o5crV3tbAhqJ7_8svlwawHRchdAQ&oe=676E7B31"}, {"file_name": "migrated_image.png", "id": "1578426772332750", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162739_338068802983630_591907603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4zhPDdczStAQ7kNvgHH4QQP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDQ6lfRnfqabaDAx4Y7IP2mTxYOQ56UZ11D_u9MywHWw&oe=676E9A75"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Starry", "keywords": ["puzzle", "VanGogh", "jigsaw"], "long_description": "You will be facing  the illusory world, making up of endless stars, by putting up your VR glasses, and your mission is to turn pieces of the puzzles into the masterpieces of Van Gogh. VR technology enables very single piece of the puzzle to be presented as vivid object that you feel you were about to touch, and you will certainly be immersed in the artistic spirit within the whole picture. Keep your brain working, and conquer the puzzles.\n\nThis VR game stands out from its genre by providing you the experience of taking deep thinking, and enjoying the calm in the present moment. Also, while making full use of VR technology, this game does not offer any dizzy feeling. Try restoring Van Gogh\u2019s masterpieces through your virtual hands instead of traditional way of clicking and dragging! ", "short_description": "Starry: a VR puzzle game: getting a close look to the masterpieces of Van Gogh (and experience the  nature of art from pieces.)"}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "DJH", "support_website_url": null, "website_url": "http://www.dajuh.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PUZZLE", "EXPLORATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3187004521623310"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "493532737499357"}]}, "baseline_offer": {"id": "493532737499357"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1462950000, "status": "PUBLISHED", "id": "493532737499357"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "1009811585756452", "version": "1.0"}, "id": "210946909295210", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "828220430616369", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "1009811585756452"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "210946909295210"}]}, "change_log": "Initial Version", "created_date": 1460061445, "id": "1009811585756452", "version": "1.0", "version_code": 1, "release_status": "