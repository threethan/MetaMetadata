7648_1060911761_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=akGEM3CXfLcQ7kNvgHdmi9n&_nc_ht=scontent.oculuscdn.com&oh=00_AYCnXn_VkQ0EU1SlU-hatfwp-R3ZvnPSrhkFmDW0yLCgkQ&oe=66D6DEB1"}, {"file_name": "migrated_image.png", "id": "1578426772332750", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162739_338068802983630_591907603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ik7V62eF_XEQ7kNvgEz9MFP&_nc_ht=scontent.oculuscdn.com&oh=00_AYDWQ5EpJPYuZsQYKo3yYuSoP9SbMl6QRBpAGqNS_tL3lQ&oe=66D6FDF5"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Starry", "keywords": ["puzzle", "VanGogh", "jigsaw"], "long_description": "You will be facing  the illusory world, making up of endless stars, by putting up your VR glasses, and your mission is to turn pieces of the puzzles into the masterpieces of Van Gogh. VR technology enables very single piece of the puzzle to be presented as vivid object that you feel you were about to touch, and you will certainly be immersed in the artistic spirit within the whole picture. Keep your brain working, and conquer the puzzles.\n\nThis VR game stands out from its genre by providing you the experience of taking deep thinking, and enjoying the calm in the present moment. Also, while making full use of VR technology, this game does not offer any dizzy feeling. Try restoring Van Gogh\u2019s masterpieces through your virtual hands instead of traditional way of clicking and dragging! ", "short_description": "Starry: a VR puzzle game: getting a close look to the masterpieces of Van Gogh (and experience the  nature of art from pieces.)"}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "DJH", "support_website_url": null, "website_url": "http://www.dajuh.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["PUZZLE", "