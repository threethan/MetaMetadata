39D9"}, {"file_name": "migrated_image.png", "id": "863543127392978", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162745_1043450449056171_1107328641_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=owNObsdgo9EQ7kNvgHrfYL3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBOIHHz9Jgixa_mjZJJ7ZTYQf6_dlag3HcmYSqK89veAw&oe=673743A4"}, {"file_name": "migrated_image.png", "id": "204855680781206", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138771_856803251097648_1060911761_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WDcd6PYab70Q7kNvgEEbxQP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCH1x02kFayyYviu_aMdzk4NGAMRD_VHwRhu_U66X4wrA&oe=67371C31"}, {"file_name": "migrated_image.png", "id": "1578426772332750", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162739_338068802983630_591907603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qbwkFIGUYfUQ7kNvgEkJQ9w&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAHw2T1xuXjVpUSlJVyo7c_8yrxW2gcC_J276ZKgDkV7A&oe=67373B75"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Starry", "keywords": ["puzzle", "VanGogh", "jigsaw"], "long_description": "You will be facing  the illusory world, making up of endless stars, by putting up your VR glasses, and your mission is to turn pieces of the puzzles into the masterpieces of Van Gogh. VR technology enables very single piece of the puzzle to be presented as vivid object that you feel you were about to touch, and you will certainly be immersed in the artistic spirit within the whole picture. Keep your brain working, and conquer the puzzles.\n\nThis VR game stands out from its genre by providing you the experience of taking deep thinking, and enjoying the calm in the present moment. Also, while making full use of VR technology, this game does not offer any dizzy feeling. Try restoring Van Gogh\u2019s masterpieces through your virtual hands instead of traditional way of clicking and dragging! ", "short_