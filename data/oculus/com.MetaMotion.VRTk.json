1385791666465226950_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uhxYJPTlfjsQ7kNvgGKKTSa&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBJOUAlqasbUKOLXGmVKLQNuK3YgSpBMIqz6d-Ss7Igiw&oe=67260106"}, {"file_name": "2.png", "id": "1510749549800522", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031326_1510749553133855_5521612830231743833_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZVTdN1WXGWEQ7kNvgEAN8u7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCW5MlGGikNWxOv4nG6k9Yomz_-Z-5JFGtBaQFQ7MbexQ&oe=67261294"}, {"file_name": "screenTwo.png", "id": "310818568759658", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982559_310818572092991_4752830113586683661_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3vgKQmvN2oIQ7kNvgGLcSGk&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCcV-zOr54mxdyG3owvhO20cN3w5EJgCN-LwN513mb5ZQ&oe=67260278"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560.png", "id": "496184586497363", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75340704_496184593164029_4525583177375546426_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZvL1PNOzMoYQ7kNvgG4QJSO&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBfHtMuEb4iRPhtxRYM07PM19G2GW8OhpbMLYKMOQEW6A&oe=67262DFC"}, "display_name": "STEPMASTER", "keywords": [], "long_description": "**STEPMASTER** is an educational VR application that aids users to view, practice, and enjoy learning a variety of exercises.\n\n- **One-For-All Training System**: Taekwondo, Taichi, Yoga, Dance, and other contents are, and will be, available for learning--in a single application. \n\n- **Demonstration by Experts**: STEPMASTER delivers the most precise demonstration made by experts of each field. All demonstrations are motion-captured and carefully calibrated.\n\n- **Advanced Motion Analysis System**: STEPMASTER estimates movements of a user to compare it with the demonstration. The app further gives scores based on similarity and provides useful feedbacks for future improvements.\n\nThe goal of STEPMASTER is to make every exercise easy to start and entertaining to master. Start anew or sharpen your skills, here at STEPMASTER!!", "short_description": "Learn exercises and practice towards perfection. Watch the demonstration of experts and get a feedback for future improvements. Take a step-by-step approach to master every single content in STEPMASTER!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://metamotion.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "https://metamotion.io/", "support_website_url": null, "website_url": "https://metamotion.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}, {"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7931582356950722"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "433355106214122"}]}, "baseline_offer": {"id": "433355106214122"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727400660, "status": "PUBLISHED", "id": "433355106214122"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8226037164171905", "version": "1.0.0"}, "id": "1168892177438930", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isA