ng to master. Start anew or sharpen your skills, here at STEPMASTER!!", "short_description": "Learn exercises and practice towards perfection. Watch the demonstration of experts and get a feedback for future improvements. Take a step-by-step approach to master every single content in STEPMASTER!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://metamotion.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "https://metamotion.io/", "support_website_url": null, "website_url": "https://metamotion.io/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "2776542286000603"}, {"id": "619566195371476"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ko"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7931582356950722"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "433355106214122"}]}, "baseline_offer": {"id": "433355106214122"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1727400660, "status": "PUBLISHED", "id": "433355106214122"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8082919815150308", "version": "1.0.0"}, "id": "1168892177438930", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7047676595341307", "is_concept": false, "