gHbZEyV&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBrsEt6CcZCIz-jSJkfSjQmcKCdtaArMVrn8WFEw_4hbw&oe=6751A4AA"}, {"file_name": "Fishy5Carpet.png", "id": "952188878827457", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982568_952188882160790_1451990759880653684_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kDcvlhFVUFYQ7kNvgHD5GLI&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYDt9yEzwTu4iTD-W3g_YZOIucZONzszpwO0EZgZidufnA&oe=67518E07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FishGameLogo.png", "id": "1513283632457562", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974448_1513283639124228_8382515463982883350_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HbkHAy3RmsUQ7kNvgE75BNA&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCIrufODLwR_tbbk27HT1c5wguVQCcnW-uUdRkCvWMlDA&oe=67518D18"}, "display_name": "Fish Game", "keywords": [], "long_description": "Become fish with friends!\n\nSwim around - \nFish Game uses it's own unique hand based locomotion to make the fishy experience on top.\n\nPlay mini games - \nThere are a few different mini games to play on the different maps, a few honourable mentions are the two originals Swords and Boats.\nIn Swords you have 3 lives, you must hit the other fish until you're the last one standing.\nIn Boats angry fishermen are trying to catch you with their evil fishing net!\n\nChat with friends - \nJoin public rooms and chat with new fish, maybe you'll even find a new friend!\nIf you aren't in the mood to talk with new fish, you can always make a private room and send the code to your friends.\n\nThere's a lot more to do - \nYou can play the Sandbox mode where you can make your own creations.\nYou can customise yourself by changing your name, colour and maybe even put on a nice hat to finish off your look.", "short_description": "Become the fish you've always dreamt of being!"}]}, "developer_name": "fchb1239", "developer_privacy_policy_url": "https://fishg