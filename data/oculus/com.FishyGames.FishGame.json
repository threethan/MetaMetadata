9446_496464436233593359_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ES66KsqPKjQQ7kNvgHbvJhH&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARjsgJ3xq2BFxkpXdUfFz3b&oh=00_AYC_48imNP6XgmsKrnaA7qyAEr0PLWUXTya1r8BZJ40JlA&oe=66D314AA"}, {"file_name": "Fishy5Carpet.png", "id": "952188878827457", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982568_952188882160790_1451990759880653684_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-AAYcAvBOmgQ7kNvgGG4slO&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARjsgJ3xq2BFxkpXdUfFz3b&oh=00_AYB9F61q-X6MsGSsKNXoFrl1ltPcBcZkyxJI44JPJROkSQ&oe=66D2FE07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FishGameLogo.png", "id": "1513283632457562", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974448_1513283639124228_8382515463982883350_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3GevIRNcXkYQ7kNvgGUX2lR&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARjsgJ3xq2BFxkpXdUfFz3b&oh=00_AYDeNbvs2hqFd3LLfTEiEndolmkDqBLAe-fPcDxRDoiakg&oe=66D2FD18"}, "display_name": "Fish Game", "keywords": [], "long_description": "Become fish with friends!\n\nSwim around - \nFish Game uses it's own unique hand based locomotion to make the fishy experience on top.\n\nPlay mini games - \nThere are a few different mini games to play on the different maps, a few honourable mentions are the two originals Swords and Boats.\nIn Swords you have 3 lives, you must hit the other fish until you're the last one standing.\nIn Boats angry fishermen are trying to catch you with their evil fishing net!\n\nChat with friends - \nJoin public rooms and chat with new fish, maybe you'll even find a new friend!\nIf you aren't in the mood to talk with new fish, you can always make a private room and send the code to your friends.\n\nThere's a lot more to do - \nYou can play the Sandbox mode where you can make your own creations.\nYou can customise yourself by changing your name, colour and maybe even put on a nice hat to finish off your look.", "short_description": "Become the fish you've always dreamt of being!"}]}, "developer_name": "fchb1239", "developer_privacy_policy_url": "https://fishgamevr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Voxoun Games", "support_website_url": null, "website_url": "https://fishgamevr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1252701098962077"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035393_246353534109052_782581163245396990_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o_xqvV9ijCsQ7kNvgG9wwJA&_nc_ht=scontent.oculuscdn.com&_nc_gid=ARjsgJ3xq2BFxkpXdUfFz3b&oh=00_AYCEU0cdMXyWMM6G1dp7dlXAOnvDWTe-MhT8GWXEjtbcLA&oe=66D30CCC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Fish Game", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Casual", "id": "394813081514456"}, {"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1647529186, "lastRevision": {"nodes": [{"id": "426036548974172", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6556848877722096", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "pl