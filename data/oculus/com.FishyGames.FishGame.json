gGtKIfD&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBlJ_dUhZCQFna2Ujc3tiJ6McENgtmQ49Mhhbr8lItP0w&oe=6734A3AA"}, {"file_name": "Fishy5Carpet.png", "id": "952188878827457", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982568_952188882160790_1451990759880653684_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ao3NgKp4dTMQ7kNvgHh0_38&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDvsAgjFn0u0BG9CndnN2q8Oon3iRVs1jCC9OHzInhvzA&oe=67348D07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "FishGameLogo.png", "id": "1513283632457562", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974448_1513283639124228_8382515463982883350_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9O30LzGXrQQ7kNvgEdqQTm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAhXKKBCkE1J9hlhkMa_W9IGL4qDbg_gMhPCa8cQydtaQ&oe=67348C18"}, "display_name": "Fish Game", "keywords": [], "long_description": "Become fish with friends!\n\nSwim around - \nFish Game uses it's own unique hand based locomotion to make the fishy experience on top.\n\nPlay mini games - \nThere are a few different mini games to play on the different maps, a few honourable mentions are the two originals Swords and Boats.\nIn Swords you have 3 lives, you must hit the other fish until you're the last one standing.\nIn Boats angry fishermen are trying to catch you with their evil fishing net!\n\nChat with friends - \nJoin public rooms and chat with new fish, maybe you'll even find a new friend!\nIf you aren't in the mood to talk with new fish, you can always make a private room and send the code to your friends.\n\nThere's a lot more to do - \nYou can play the Sandbox mode where you can make your own creations.\nYou can customise yourself by changing your name, colour and maybe even put on a nice hat to finish off your look.", "short_description": "Become the fish you've always dreamt of being!"}]}, "developer_name": "fchb1239", "developer_privacy_policy_url": "https://fishg