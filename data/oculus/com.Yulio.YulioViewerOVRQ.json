om your designer, follow the simple instructions to connect your headset with your email address and then grab your headset - your virtual reality experience will be downloaded automatically and ready to view!\n", "short_description": "Yulio Viewer is your window into the world of ultra-realistic architecture and interior designer virtual reality experiences.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.yulio.com/privacy-policy/", "developer_terms_of_service_url": "https://www.yulio.com/terms-and-conditions/", "publisher_name": "Yulio Technologies Inc.", "support_website_url": null, "website_url": "https://www.yulio.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "364925122131893"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036637_1141832839590811_4874200333757723735_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bQXE6pfW2-kQ7kNvgHmAAV7&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCpIPtkC5Fsmn-loNnm8ZzFmA23upeiU5uigz2epEtBdQ&oe=67262242"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Yulio Viewer", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Creativity"