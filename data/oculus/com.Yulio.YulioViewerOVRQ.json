3_437380030797229_906737917844460691_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T8hRgK-BvpwQ7kNvgG9lr-a&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACswdTONPcxCSQhEUm-oXit&oh=00_AYBasLYE2lHzt1FOc4Y9zpT4z-HEfjE8C_fGbaIXQjTfew&oe=66F6A6E5"}, {"file_name": "12386263_1577312859241599_54120433_n.png", "id": "255006216030821", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566687_255006219364154_1393567386080094374_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wdg5IShFxtMQ7kNvgGXt9bn&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACswdTONPcxCSQhEUm-oXit&oh=00_AYC3ZJSPp9nLz481t-7b_qaFxJTRnR3AbfgIBYAnmYzQNA&oe=66F68DB9"}, {"file_name": "12727795_175792849497784_1186982942_n.png", "id": "248815500092853", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974735_248815503426186_3102150384443732344_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=C77aIQllHiIQ7kNvgFJxhqf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACswdTONPcxCSQhEUm-oXit&oh=00_AYA0n2S4Ar8fzYqRhhTf_-PeR4OHI_CHr4srw2IFoLDNjw&oe=66F6A738"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "12386263_1386300711400057_1121902864_n.png", "id": "737356153590454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196218_737356156923787_581073310781518135_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6IS6r7rsWr4Q7kNvgEnBTyu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACswdTONPcxCSQhEUm-oXit&oh=00_AYBscZ8MTmWbPkrOiIbZneQq6Gyd9DFitT7Or0arcgBXbQ&oe=66F67DBB"}, "display_name": "Yulio Viewer", "keywords": [], "long_description": "Yulio Viewer is your window into the world of ultra-realistic architecture and interior designer virtual reality experiences. \n\nWith Yulio, designers use state of the art CAD (Computer Aided Design) tools like 3DS Max\u2122, Revit\u2122, and SketchUp\u2122 to produce virtual reality content and transform it into sharable Virtual Reality Experiences. \n\nVisit the Yulio.com Gallery to see some of the best experiences being created by professional architecture and design firms today - and check back often, we\u2019re publishing new content all the time.\n\nJust click a link from the Gallery or from your designer, follow the simple instructions to connect your headset with your email address and then grab your headset - your virtual reality experience will be downloaded automatically and ready to view!\n", "short_description": "Yulio Viewer is your window into the world of ultra-realistic architecture and interior designer virtual reality experiences.  "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.yulio.com/privacy-policy/", "developer_terms_of_service_url": "https://www.yulio.com/terms-and-conditions/", "publisher_name": "Yulio Technologies Inc.", "support_website_url": null, "website_url": "https://www.yulio.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["UTILITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "364925122131893"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036637_1141832839590811_4874200333757723735_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kO3sJC65S24Q7kNvgGZd51Y&_nc_ht=scontent.oculuscdn.com&_nc_gid=ACswdTONPcxCSQhEUm-oXit&oh=00_AYCiTq0EeYax4s9v1ONqJAb9wiTN7FV0sQJSGrza9mRc5Q&oe=66F6AC42"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Yulio Viewer", "platform": "ANDROID_6DOF", "context_category": n