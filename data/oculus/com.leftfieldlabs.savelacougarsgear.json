fWkmmDEQ7kNvgHPNNLE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDN_X1zi5PEwqYkL_Hozsfm9CaxVH4s7sr81JFAWXHmnQ&oe=67694CDF"}, {"file_name": "migrated_image.png", "id": "233542874704281", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138787_214465339093990_224169126455672832_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Koxnx1hNXrMQ7kNvgEWfIMt&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAqocGEgaR3SU_PMaEh_E5wtYJQnM2S4zZylgrrF0oOYQ&oe=6769587E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Save LA Cougars VR", "keywords": ["savelacougars", "cougars", "VR", "save", "angeles"], "long_description": "Did you know there is a mountain lion living in the middle of Los Angeles? In this VR experience you\u2019ll meet P-22, the most famous cougar in the world.\n\nP-22 crossed two of LA\u2019s infamous freeways to find a new home, and is now trapped by traffic and separated from others of his kind. His plight as a lonely bachelor has inspired people all over the world to help all the mountain lions living in the Los Angeles area, who are facing extinction, by building the largest wildlife crossing in the world over one of the busiest freeways in the country.\n\nIn this VR app, you\u2019ll see LA through a mountain lion\u2019s eyes, and also get a glimpse of what the proposed wildlife crossing will look like.\n \nProduced by Pacific Virtual Reality for the National Wildlife Federation\u2019s #SaveLACougars campaign - learn more and get involved at www.savelacougars.org", "short_description": "A virtual reality experience for Gear VR"}]}, "developer_name": "Left Field Labs", "developer_privacy_policy_url": "https://www.leftfieldlabs.com/privacy", "developer_terms_of_service_url": "https://www.leftfieldlabs.com/privacy", "publisher_name": "National Wildlife Federation", "support_website_url": null, "website_url": "https://savelacougars.org/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "co