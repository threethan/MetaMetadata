HpEeR1tzPXjG9D2O2RlxrVDOH0HByEA&oe=66E95648"}, {"file_name": "Overview.png", "id": "1027198147974330", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982685_1027198151307663_4389398395153643146_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8scBGUCpxa8Q7kNvgGzXWj1&_nc_ht=scontent.oculuscdn.com&_nc_gid=APpCnm9-XFGqyQE8rnmcDC7&oh=00_AYAl2WsF7eQnF8NGJxEg7M_aXNWT0SyF8xRjJm9mpTRWCg&oe=66E98474"}, {"file_name": "Zurich.png", "id": "1406898146388006", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035382_1406898149721339_4793714632801808312_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7e7cRWx1fsgQ7kNvgE16yta&_nc_ht=scontent.oculuscdn.com&_nc_gid=APpCnm9-XFGqyQE8rnmcDC7&oh=00_AYCtxn63-UlGQqKl-uwkTybvsKC_NAumazTfF--zWj0tSQ&oe=66E9642B"}, {"file_name": "download.png", "id": "584876336667498", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974901_584876343334164_8546539559473869809_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MNzJjJM-UfYQ7kNvgEdsLbv&_nc_ht=scontent.oculuscdn.com&_nc_gid=APpCnm9-XFGqyQE8rnmcDC7&oh=00_AYBUICHsBumvdeBvS1O_j7g9PWq6CRU5FQIZFk1G4SDtqA&oe=66E95554"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "maxresdefault.png", "id": "735983904142580", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003244_735983910809246_8127394115187789742_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rdm4CtE6DgwQ7kNvgEPVoPC&_nc_ht=scontent.oculuscdn.com&_nc_gid=APpCnm9-XFGqyQE8rnmcDC7&oh=00_AYCoyC1E6CmroJEFX0IpbIoMpoCMYlFHOwY_DcjBPohk0g&oe=66E94D6C"}, "display_name": "WeezyVR", "keywords": [], "long_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home.\n\nThrough our comprehensive booking system, you can try your destinations before you fly. Check out hotels, cities and tourist destinations in VR before you commit to your booking. We can help you find your dream holiday by offering you comprehensive 360 views ahead of time - so there are no bad surprises when you arrive.", "short_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://weezy-vr.com/weezy-vr-privacy-policy/", "developer_terms_of_service_url": "https://weezy-vr.com/impressum/", "publisher_name": "Weezy VR", "support_website_url": null, "website_url": "https://weezy-vr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "631845091470045"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "601288968111038"}]}, "baseline_offer": {"id": "601288968111038"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1660672800, "status": "PUBLISHED", "id": "60128896811103