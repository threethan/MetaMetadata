cdn.com&oh=00_AYCW-diPXwLOqGyctCL6poBL5tx08bojTDwDFfL6ftDDdA&oe=6721FCB4"}, {"file_name": "Zurich.png", "id": "1406898146388006", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035382_1406898149721339_4793714632801808312_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y52eTrcxeh0Q7kNvgF7FnEZ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAjJTusKXuEJpNroM_EHtXaWrKDTQcxy65eL4ECJA3ZQ&oe=672214AB"}, {"file_name": "download.png", "id": "584876336667498", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974901_584876343334164_8546539559473869809_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zt8Y_wuk8TAQ7kNvgGgEVxC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBR3ndGfxzUe5QpTiT3954QcAVBVL7vIOjpVOPT9aByPg&oe=672205D4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "maxresdefault.png", "id": "735983904142580", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003244_735983910809246_8127394115187789742_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O5fFXdtoBy0Q7kNvgHEJ3Le&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD8GcfS-1Qj7Orsq2QA8YhphTJhJ0mkdGzVzKXTfCJvvA&oe=6721FDEC"}, "display_name": "WeezyVR", "keywords": [], "long_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home.\n\nThrough our comprehensive booking system, you can try your destinations before you fly. Check out hotels, cities and tourist destinations in VR before you commit to your booking. We can help you find your dream holiday by offering you comprehensive 360 views ahead of time - so there are no bad surprises when you arrive.", "short_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://weezy-vr.com/weezy-vr-privacy-policy/", "developer_terms_of_service_url": "https://weezy-vr.com/impressum/", "publisher_name": "Weezy VR", "support_website_url": null, "website_url": "https://weezy-vr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "631845091470045"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "601288968111038"}]}, "baseline_offer": {"id": "601288968111038"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1660672800, "status": "PUBLISHED", "id": "601288968111038"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6830112877074741", "version": "1.8_01"}, "id": "1314877375710646", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename