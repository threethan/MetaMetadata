c_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BwMaL6DHXwIQ7kNvgF0tqPT&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYA31B3Dh11RcRV8td2oJCeVJ2LWTR8bRESHLhJWdHJgSA&oe=677E7DF4"}, {"file_name": "Zurich.png", "id": "1406898146388006", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/39035382_1406898149721339_4793714632801808312_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QKVfEVz_JSwQ7kNvgE_R3mK&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYBK8RNTf73q4GlVDtJBzpZeJhcE0I3pNPEdZu6Q8Mytxg&oe=677E5DAB"}, {"file_name": "download.png", "id": "584876336667498", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/38974901_584876343334164_8546539559473869809_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XIT_62Li6o4Q7kNvgE10hpD&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAj06NyfS-OeZhIHAqj91nrUndnYyE01O6gjHYCaFq8fg&oe=677E4ED4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "maxresdefault.png", "id": "735983904142580", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/39003244_735983910809246_8127394115187789742_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FSmyvXHoExkQ7kNvgHsRQqE&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYC4pn4Ae-1cEL1ZYsO7lFaejHd9WOG34XooUKVIul8FyA&oe=677E7F2C"}, "display_name": "WeezyVR", "keywords": [], "long_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home.\n\nThrough our comprehensive booking system, you can try your destinations before you fly. Check out hotels, cities and tourist destinations in VR before you commit to your booking. We can help you find your dream holiday by offering you comprehensive 360 views ahead of time - so there are no bad surprises when you arrive.", "short_description": "Weezy VR means travel in Virtual Reality.\nGo on virtual trips in destinations of your choosing.\nFind and explore destinations with simple filters, and pick and choose your favourite hotels, then book them to explore in real life!\n\nJoin us on a trip to the top of the Eiffel Tower, ballooning in a Ugandan safari park or lie down and relax on the white beaches of the Dominican Republic - all from the comfort of your own home."}]}, "developer_name": null, "developer_privacy_policy_url": "https://weezy-vr.com/weezy-vr-privacy-policy/", "developer_terms_of_service_url": "https://weezy-vr.com/impressum/", "publisher_name": "Weezy VR", "support_website_url": null, "website_url": "https://weezy-vr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["TRAVEL", "EXPLORATION", "EXPERIENCE_360_NON_GAME"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "631845091470045"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "601288968111038"}]}, "baseline_offer": {"id": "601288968111038"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1660672800, "status": "PUBLISHED", "id": "601288968111038"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6830112877074741", "version": "1.8_01"}, "