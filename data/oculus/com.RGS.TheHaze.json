91763625_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1qzHSMgYx1EQ7kNvgHvxGRS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCHnab2inbY5t6BTsv7APq9H6gm4xTJO6Y7ng2Hgqn0mQ&oe=6718F977"}, "display_name": "The Haze", "keywords": [], "long_description": "The Haze is a stunning multiplayer survival shooter inspired by DayZ. Traverse an eerie largescale map with a mysterious forest looking for supplies and weapons to stay alive while you encounter the never ending hunger and thirst that if not managed correctly can be your downfall. Watch out for other players trying to survive or team up and enrich your odds. However, beware of various defensive mechanisms throughout the map that can cause you to bleed.. and maybe creatures. ", "short_description": "The Haze is a stunning multiplayer survival shooter inspired by DayZ. Traverse an eerie largescale map with a mysterious forest looking for supplies and weapons to stay alive while you encounter the never ending hunger and thirst that if not managed correctly can be your downfall. Watch out for other players trying to survive or team up and enrich your odds. However, beware of various defensive mechanisms throughout the map that can cause you to bleed.. and maybe creatures. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.privacypolicies.com/live/aa5cdd85-ff06-42cb-aff2-a5614262c675", "developer_terms_of_service_url": null, "publisher_name": "N/A", "support_website_url": null, "website_url": "https://robertsongamingstudios.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "889588098232891"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended