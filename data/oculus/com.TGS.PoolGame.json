64756210167", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/86796155_398664759543500_2706445515973291901_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bqcd2G3gIaIQ7kNvgExCX7p&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCRCdoYLRPBuFDda00naz_YAFfgjHh-H7hoCdaIZ8EdVQ&oe=671B7C43"}, {"file_name": "38974500_357368075045296_1291658929771642880_n.png", "id": "257358954110865", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031441_257358957444198_1243485050372084504_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1lJHPkePSEsQ7kNvgHuBQ1B&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB5zJGQYZZd4JT351z9cSXzkAAH3gbPuGSco-IaZVIm-g&oe=671B80CD"}, {"file_name": "38974776_145862073032626_7297916684566790144_n.png", "id": "1554773452038676", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982548_1554773455372009_2813697591237283979_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=til9gICVjhsQ7kNvgF3RDNB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBp_HOEQ4V5ECPh_tVR8t8xte_hFFF6McaXGEwiXr8l3g&oe=671B9A7D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974546_439839219876673_5452841653813379072_n.png", "id": "355975184104668", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982608_355975187438001_5373475364883358199_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=asnSzI5zX3oQ7kNvgGnToL_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYADm02RE4KWioP-DLbBD75D5CE56aQJILJ01APnNi6FXg&oe=671B9EB5"}, "display_name": "Pool Game", "keywords": [], "long_description": "Enter the immersive world of Pool Game Solo, the VR billiards experience that lets you hone your skills or simply unwind in style.  Step into a meticulously detailed virtual pool hall, complete with rich textures and atmospheric lighting.  Pick up your virtual cue with intuitive controls that mimic the real deal - feel the weight, the balance, and the satisfying click of a perfect shot. \n\nChallenge yourself in Solo Mode, perfecting trick shots, mastering spins, and racking up impressive scores.  In the mood for competition?  Face off against a cunning AI opponent in various difficulty levels, each offering a unique test of pool prowess.  Showcase your skills with a variety of classic game modes, from the timeless Eight-Ball to the fast-paced Nine-Ball. \n\nPool Game Solo isn't just about competition - it's about pure VR billiards bliss.  Soundtrack to your liking?   No problem!  The game integrates with your personal music library for a truly personalized experience.   Pool Game Solo - Rack up some fun, all by yourself, or go toe-to-toe with the AI.  The choice is yours.\n\nGame Features :\n- Play Solo or with AI\n- Impressive visuals, great animations and double fun\n- Play easy, hard\n- Supports battery saver\n\nTips: The goal of game is for simulation realistic experience only.", "short_description": "Step into the world of billiards like never before with Pool Game Solo VR!  Sharpen your skills or unwind in stunning virtual environments. Play solo, hone your technique, or challenge the cunning AI.  Intuitive VR controls put the perfect shot at your fingertips.  Rack up some fun with Pool Game Solo VR! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.thundergamestudio.com/metapolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Thunder Game Studio", "support_website_url": null, "website_url": "https://www.thundergamestudio.com/metapolicy.html", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null,