_TT.png", "id": "786945162524421", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035393_786945165857754_6686634840838891674_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pLm8UD6tWXoQ7kNvgG10oEK&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa9STDudegWBLn20kP_97i0&oh=00_AYCliHId02uI7mnmDTSuYDw-jTpOdkx0YI8ryDEmWrabjQ&oe=66DD9B53"}, {"file_name": "Puchh_TT.png", "id": "565723898685764", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/65402154_565723902019097_3828549971285361301_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4N26KbKg_2IQ7kNvgGXoCLe&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa9STDudegWBLn20kP_97i0&oh=00_AYAIyBEN8kS5pQF-RylNHgXbBfWux6EShhVniXMCE4rp7g&oe=66DD933A"}, {"file_name": "TrolleyProblem_TT.png", "id": "333911948937328", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75302220_333911952270661_693404555226828054_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1lc8vhexO0MQ7kNvgGcjeVT&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa9STDudegWBLn20kP_97i0&oh=00_AYA9T7WpY5AKu7e6-jrKKeGcOjKObbvidvSuZywjxKHZ1w&oe=66DD9C59"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "1655861528141445", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001703_1655861534808111_468555271150108197_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fmxd2DDM1gEQ7kNvgFVYWTB&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa9STDudegWBLn20kP_97i0&oh=00_AYBmCKFR5cQHQAPO5K4OM5Y4ErMzPn_3PfnHxOV3g9CCZQ&oe=66DD7170"}, "display_name": "Time Titans VR", "keywords": [], "long_description": "Time Titans VR is a singleplayer action shooter that allows the user to manually slow down time to get an advantage in combat. Shoot, punch and slice through enemies while slowing down time to unleash mayhem or dodge counter attacks. \n\nSlow time at the push of a button while you move freely to wreak havoc on the opposition. \n\nGun down enemies during the slow motion bliss. \n\nBash your enemies to pieces with maces, battleaxes, sais, swords and an assortment of other melee weapons.\n\nTest your moral compass as you're put through simulated ethical dilemmas to see if you're worthy of joining \"The Corporation\" to work as a mercenary. Your decisions will impact the story and determine if  you get the job after the grueling interview process. \n\nAre you the right fit for the job? Find out. \n", "short_description": "Time Titans VR is a Singleplayer action shooter that allows the user to manually slow down time to get an advantage in combat. Shoot, punch and slice through enemies while slowing down time to unleash mayhem or dodge counter attacks. "}]}, "developer_name": "Phocore Inc.", "developer_privacy_policy_url": "https://www.phocoregames.com/privacy-policy", "developer_terms_of_service_url": "https://www.phocoregames.com/privacy-policy", "publisher_name": "Phocore Inc.", "support_website_url": null, "website_url": "https://www.phocoregames.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}, {"id": "459781504968480"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1085785358587291"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003243_655669045899842_863590056398870483_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NYat-Psqem8Q7kNvgGNHlza&_nc_ht=scontent.oculuscdn.com&_nc_gid=Aa9STDudegWBLn20kP_97i0&oh=