VTQ&oe=67407FA6"}, {"file_name": "gunworld_attachments_orange_boost_2560_1440.png", "id": "1705455986968574", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75395604_1705455990301907_5380814990569573591_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eOphIve2N0oQ7kNvgE2qVvd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBY8uYWU8UbPh9x0b18ZPyGJe0paOgp07yoM_LafdbbUA&oe=674053F3"}, {"file_name": "sniping_2_2560_1440.png", "id": "1073333151125068", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974642_1073333154458401_4160547289602466508_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a9t7PSr-vokQ7kNvgFdaqM_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBVe8cY-6Es2pw12OJplRr_HYFHTeG_88Is6sgf0hBhww&oe=67407B98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gimp_landscape_cover_blast_3.png", "id": "440683875320342", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974750_440683878653675_8627408282569271893_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hE7rMzzEZZ0Q7kNvgEUNj8Q&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAdCZflvGzUv_xcEKW5N4SMu7hgaLWmBiSYwou74VZVJg&oe=674083B9"}, "display_name": "Gun World VR", "keywords": [], "long_description": "# Play the most immersive sandbox multiplayer shooter in Gun World VR\n- Become Elite - 'Gun World VR has over 400 guns and attachments'\n- Sandbox Experience - 'Spawn unlimited weapons and build endless loadouts'\n- Multiplayer Physics- 'Experience Physics in multiplayer mode with friends'\n \nGun World VR is multiplayer sandbox shooter with realistic physics and over 400 guns and attachments. Become the best tactical soldier and assault positions with your friends. Build anything in sandbox mode.\n\n \n\n# \n# Features\n# PvE Missions: Solo or Online Multiplayer Co-Op with Up to 8 Players \n{1698171884084267}\n# PvP Mode: Competitive Modes and Maps\n{576661228143983}\n# Tactical Teamwork: Trust your teamates and friends\n{475675245514985}\n# Procedural Compound Raid: Play different maps everytime\n{877926837430604}\n# Breach and Clear: Assault positions with your pals\n{533088592860767}\n# Tactics applied: Strategize your assault path\n{1604474137162060}\n# Breach and Clear: Flush enemies out\n{1206195163783608}\n# Sandbox mode: Experience physics and building loadouts\n{593476859695271}", "short_description": "Play the most immersive sandbox multiplayer shooter in Gun World VR\n\n- Become Elite - 'Gun World VR has over 400 guns and attachments'\n- Sandbox Experience - 'Spawn unlimited weapons and build endless loadouts'\n- Multiplayer Physics- 'Experience Physics in multiplayer mode with friends'\n\nGun World VR is multiplayer sandbox shooter with realistic physics and over 400 guns and attachments. Become the best tactical soldier and assault positions with your friends. Build anything in sandbox mode."}]}, "developer_name": "Alto Interactive", "developer_privacy_policy_url": "https://github.com/superdude12399/PrivacyPolicy", "developer_terms_of_service_url": null, "publisher_name": "Alto Interactive", "support_website_url": null, "website_url": "https://www.altointeractive.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "1990104051447093"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8710221145732262"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "