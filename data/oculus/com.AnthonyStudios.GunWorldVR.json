"}, {"file_name": "38974869_1076516886436882_5688509789127821580_n.png", "id": "1067502675086856", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974670_1067502678420189_1664499263559034905_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hvvufvWrgZkQ7kNvgG-3slE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAIy31ka8XqycXaxQvDoFnbE5qNmpKxzI2cmEIjYPTuMA&oe=6739EFC3"}, {"file_name": "75294243_588476852190632_1196586670719807144_n.png", "id": "1055075706132986", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031556_1055075709466319_5937226536109632973_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bio4bC9VrP8Q7kNvgEKJ-YS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBBJvb4pj6-nQLpImja2Z1vc15RWinOuyBlfZ-IxTKrJw&oe=6739F29B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "gimp_landscape_cover_blast_3.png", "id": "440683875320342", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974750_440683878653675_8627408282569271893_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oMJeIMMV_KIQ7kNvgHX4v8G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDmTBoccBO5Iyfm3ghJTxcEuYKEZuHoIzhla8eqX1qVbA&oe=6739EC39"}, "display_name": "Gun World VR", "keywords": [], "long_description": "# Play the most immersive sandbox multiplayer shooter in Gun World VR\n- Become Elite - 'Gun World VR has over 400 guns and attachments'\n- Sandbox Experience - 'Spawn unlimited weapons and build endless loadouts'\n- Multiplayer Physics- 'Experience Physics in multiplayer mode with friends'\n \nGun World VR is multiplayer sandbox shooter with realistic physics and over 400 guns and attachments. Become the best tactical soldier and assault positions with your friends. Build anything in sandbox mode.\n\n \n\n# \n# Features\n# PvE Missions: Solo or Online Multiplayer Co-Op with Up to 8 Players \n{1698171884084267}\n# PvP Mode: Competitive Modes and Maps\n{576661228143983}\n# Tactical Teamwork: Trust your teamates and friends\n{475675245514985}\n# Procedural Compound Raid: Play different maps everytime\n{877926837430604}\n# Breach and Clear: Assault positions with your pals\n{533088592860767}\n# Tactics applied: Strategize your assault path\n{1604474137162060}\n# Breach and Clear: Flush enemies out\n{1206195163783608}\n# Sandbox mode: Experience physics and building loadouts\n{593476859695271}", "short_description": "Play the most immersive sandbox multiplayer shooter in Gun World VR\n\n- Become Elite - 'Gun World VR has over 400 guns and attachments'\n- Sandbox Experience - 'Spawn unlimited weapons and build endless loadouts'\n- Multiplayer Physics- 'Experience Physics in multiplayer mode with friends'\n\nGun World VR is multiplayer sandbox shooter with realistic physics and over 400 guns and attachments. Become the best tactical soldier and assault positions with your friends. Build anything in sandbox mode."}]}, "developer_name": "Alto Interactive", "developer_privacy_policy_url": "https://github.com/superdude12399/PrivacyPolicy", "developer_terms_of_service_url": null, "publisher_name": "Alto Interactive", "support_website_url": null, "website_url": "https://www.altointeractive.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SHOOTER"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8667913956629648"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scon