t-iad3-2.oculuscdn.com/v/t64.5771-25/39031490_785975773636023_5774077651952433056_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5w5UJGWWJ7AQ7kNvgEeFP_X&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAtoqH63sLMMVQlVnf18FhEgN9vnW6Dp679q1hGQSL_hw&oe=6749B063"}, {"file_name": "image (17).png", "id": "28478207675111592", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39003244_28478207685111591_905859814148920282_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_ZmP2DO1SNkQ7kNvgHcFoF9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDSHyWgzhi50Gxl7mb0ETV55XNTVswCXC_kxdWB0Ilq4A&oe=6749C328"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974634_909550917814070_689497312463467760_n.png", "id": "1424435685610487", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035379_1424435688943820_6224227522805441679_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8h2b-PHv4aEQ7kNvgG_wlah&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAQI1lhWlMKU5CHpefOGLLy_6Sf7l__NTOwhH8CNZ3oug&oe=6749A562"}, "display_name": "Last Stand", "keywords": ["pvp", "shoot", "horror", "action", "duel"], "long_description": "**Get Last Stand now for the special introductory early access price of just $7.99\u2014available for a limited time only!**\n\nStep into the future of mixed reality with Last Stand, from the makers of Drop Dead: The Cabin. This is the world\u2019s first multi-location mixed reality PvP shootout. Your living room becomes a battlefield as you eliminate your opponent while fending off a relentless zombie invasion. Move, dodge, and take cover in a fully immersive combat zone.\n\n{1067517198339345}\n\n**1v1 Mixed Reality PvP Combat**\n\nBattle opponents from anywhere\u2014each player fights from their own home. Turn your living room into a battlefield, outsmarting rivals with real-world strategy.\n\n{1232934048025689}\n\n**Precision Full-Body Tracking**\n\nDodge bullets like in The Matrix or land headshots like John Wick! Our full-body tracking ensures every movement feels accurate and responsive, immersing you deeply in the action.\n\n{428700763582659}\n\n**Your Room, Your Advantage**\n\nTransform your living room from a Netflix haven into a tactical stronghold. Your couch becomes a fortress; your table, a shield. Outsmart and outmaneuver\u2014your home is part of the fight!\n\n{1127967098666563}\n\n**Cinematic Shootouts at Home**\n\nExperience intense gunfights and explosive combat, with dynamic destruction shaping every encounter. With dynamic destruction, every round is as intense as a blockbuster.\n\n**Last Stand is an early access title pushing the boundaries of mixed reality. Join our community on Discord to share feedback and help us shape the future of the game.**\n\nVisit **LastStandXR.com** to learn more and join the discord.", "short_description": "Grab Last Stand now for the special introductory price of just $7.99\u2014available for a limited time only!\n\nStep into the future of mixed reality with Last Stand, from the makers of Drop Dead: The Cabin. This is the world\u2019s first multi-location mixed reality PvP shootout. Your living room becomes a battlefield as you eliminate your opponent while fending off a relentless zombie invasion. Move, dodge, and take cover in a fully interactive, immersive combat zone."}]}, "developer_name": null, "developer_privacy_policy_url": "https://soulassembly.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Soul Assembly", "support_website_url": "https://Laststandxr.com/", "website_url": "https://Laststandxr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMEN