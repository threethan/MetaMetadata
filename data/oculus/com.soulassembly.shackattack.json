d3-2.oculuscdn.com&oh=00_AYDe8DbZUoepZLE-q2_HKUNTEquKEv2-zKNscqHC0upY3Q&oe=6749A975"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SA-LS-Meta-VideoCover-2560x1440.png", "id": "8770630689667401", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982555_8770630713000732_6259191283680804636_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=EoM8S_voK7oQ7kNvgGlKz32&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCUq5wSzhMA4aPjo_y4CqB0cmUgjl87BFkuOjvaXU0PkQ&oe=6749BB28"}, "display_name": "Last Stand", "keywords": ["pvp", "shoot", "horror", "action", "duel"], "long_description": "Step into the future of mixed reality with Last Stand, from the makers of Drop Dead: The Cabin. This is the world\u2019s first multi-location mixed reality PvP shootout. Your living room becomes a battlefield as you eliminate your opponent while fending off a relentless zombie invasion. Move, dodge, and take cover in a fully immersive combat zone.\n\n{1067517198339345}\n\n**1v1 Mixed Reality PvP Combat**\n\nBattle opponents from anywhere\u2014each player fights from their own home. Turn your living room into a battlefield, outsmarting rivals with real-world strategy.\n\n{1232934048025689}\n\n**Precision Full-Body Tracking**\n\nDodge bullets like in The Matrix or land headshots like John Wick! Our full-body tracking ensures every movement feels accurate and responsive, immersing you deeply in the action.\n\n{428700763582659}\n\n**Your Room, Your Advantage**\n\nTransform your living room from a Netflix haven into a tactical stronghold. Your couch becomes a fortress; your table, a shield. Outsmart and outmaneuver\u2014your home is part of the fight!\n\n{1127967098666563}\n\n**Cinematic Shootouts at Home**\n\nExperience intense gunfights and explosive combat, with dynamic destruction shaping every encounter. With dynamic destruction, every round is as intense as a blockbuster.\n\n**Last Stand is an early access title pushing the boundaries of mixed reality. Join our community on Discord to share feedback and help us shape the future of the game.**\n\nVisit **LastStandXR.com** to learn more and join the discord.", "short_description": "Step into the future of mixed reality with Last Stand, from the makers of Drop Dead: The Cabin. This is the world\u2019s first multi-location mixed reality PvP shootout. Your living room becomes a battlefield as you eliminate your opponent while fending off a relentless zombie invasion. Move, dodge, and take cover in a fully interactive, immersive combat zone."}]}, "developer_name": null, "developer_privacy_policy_url": "https://soulassembly.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Soul Assembly", "support_website_url": "https://Laststandxr.com/", "website_url": "https://Laststandxr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "644354873106712"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "24613461644967569"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "560892123222944"}, {"status": "PUBLISHED", "id": "563960119563944"}, {"status": "PUBLISHED", "id": "8495327620588762"}, {"status": "PUBLISHED", "id": "1235565814217464"}]}, "baseline_offer": {"id": "563960119563944"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1734372000, "status": "PUBLISHED", "id": "560892123222944"}]}, "liveChannel": {"nodes": [{"latest_suppo