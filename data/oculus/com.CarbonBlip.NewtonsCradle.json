a0a&_nc_ohc=uah99bBmk-gQ7kNvgHUrYPK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBz-toPIm3eWYK-1As0DxPRDUrGFkZPys1TLVnppQT2PA&oe=6783AE20"}, {"file_name": "nc_screenshot04.png", "id": "1720787304782393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974453_1720787308115726_6761797374087610772_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQCI1hqamWEQ7kNvgFwfTxk&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAx9IJQjv6s2OPk4WuHOi8vg9JnG-nwEG4fZ3EiMvRbhw&oe=67839AE1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape Cover Art.png", "id": "363462395460148", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035374_363462398793481_5485136492560721182_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7rrJ9BfofsQ7kNvgEJb43R&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBMpZdR6bkTlgCFEQP-FGYhK88BwoxYb2U8eBUvutc1jw&oe=67839B0C"}, "display_name": "Newton's Cradle", "keywords": [], "long_description": "The universe revolves at your command!  In Newton's Cradle, you create stylized planets, stars and black holes.  When you set objects loose into space they orbit around each-other governed by the laws of Newtonian gravity.   \n\nRelax in a cosmic snow-globe of your own creation, or study complex systems of many stars.  \nCustomize the size and appearance of each object you create.  Set their speed and angular momentum to create orbits of varying shapes, then trace the curved paths your heavenly bodies take through space.  \nStop time to set up the perfect initial conditions.  Speed up time to watch your cosmos evolve quickly, or rewind the clock and retrace its steps.   \nMove through space in any direction to observe your creations from any angle.\nSet your stars in motion in Newton's Cradle!", "short_description": "Create planets and set them in motion in a realistic orbital physics sandbox!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.carbonblip.com/privacypolicy",