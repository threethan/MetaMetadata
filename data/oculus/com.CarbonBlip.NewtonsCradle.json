s sandbox!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.carbonblip.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Carbon Blip", "support_website_url": null, "website_url": "https://www.carbonblip.com/newtonscradle", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SPACE_UNIVERSE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "307369478096069"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974519_969103743868047_5478334009049180231_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=33Og2_vZxJYQ7kNvgGjtseO&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUYhycgiirY67fjPWJZgK-1&oh=00_AYAC7BGCAgKppGlRUcnXsO-joZ4TAHOgyyf5EvV_R8Zp0g&oe=66EEAD87"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Newton's Cradle", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1631314194, "lastRevision": {"nodes": [{"id": "266734608613988", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4217931814923260", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "294868865744398"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "Logo.png", "id": "1652807941575474", "image