n in a realistic orbital physics sandbox!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.carbonblip.com/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "Carbon Blip", "support_website_url": null, "website_url": "https://www.carbonblip.com/newtonscradle", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SPACE_UNIVERSE", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "307369478096069"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4238363326213442", "version": "1.5"}, "id": "524771338782122", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4217931814923260", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4238363326213442"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "524771338782122"}]}, "change_log": "Default orbit traces to \"on\".\nFixed sfx when trying to revisit planet skins before the 0th list element.\nMinor tweak to HUD.\nRemoved unn