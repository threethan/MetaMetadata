a0a&_nc_ohc=DI4gICNbD_gQ7kNvgEZkyOU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAYKtdD5vX6-sU7FBX84EXPzHPvwY7Q5xA8WnZGFR5hew&oe=67713920"}, {"file_name": "nc_screenshot04.png", "id": "1720787304782393", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974453_1720787308115726_6761797374087610772_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qY2OIDEKLFkQ7kNvgGFX2XK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDg1fQJ3iFl4LyukkxA1MdghTDuW0KdwVTDhISRcWCrhQ&oe=677125E1"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape Cover Art.png", "id": "363462395460148", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035374_363462398793481_5485136492560721182_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E2Uqanzt0GUQ7kNvgEBRAH4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFZWrEEoh_zge5VFtsrOoi8iTa-uapd-DLjottub_Kww&oe=6771260C"}, "display_name": "Newton's Cradle", "keywords": [], "long_description": "The universe revolves at your command!  In Newton's Cradle, you create stylized planets, stars and black holes.  When you set objects loose into space they orbit around each-other governed by the laws of Newtonian gravity.   \n\nRelax in a cosmic snow-globe of your own creation, or study complex systems of many stars.  \nCustomize the size and appearance of each object you create.  Set their speed and angular momentum to create orbits of varying shapes, then trace the curved paths your heavenly bodies take through space.  \nStop time to set up the perfect initial conditions.  Speed up time to watch your cosmos evolve quickly, or rewind the clock and retrace its steps.   \nMove through space in any direction to observe your creations from any angle.\nSet your stars in motion in Newton's Cradle!", "short_description": "Create planets and set them in motion in a realistic orbital physics sandbox!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.carbonblip.com/privacypolicy",