 the real world as well. This is the lite version of our app. To experience Healium Pro with a Brainlink Lite EEG headband, a data fitness dashboard, our video curriculum on neuromeditation, and updated content, please email hello@tryhealium.com. Note: this is a self-awareness tool and is not a treatment or diagnostic tool for any disease or medical condition. ", "short_description": "Beautiful nature escapes and stories that feed your soul and recalibrate your digital diet. "}]}, "developer_name": "StoryUP, Inc. dba Healium", "developer_privacy_policy_url": "https://www.tryhealium.com/privacy", "developer_terms_of_service_url": "https://www.tryhealium.com/terms-and-conditions/", "publisher_name": "StoryUP, Inc. dba Healium", "support_website_url": "https://www.tryhealium.com/faq/", "website_url": "https://www.tryhealium.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "RELAXATION_MEDITATION", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "2472158762918326"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031347_692857978078249_4127191329267344863_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7C3TO53OfbQQ7kNvgGw_u_8&_nc_ht=scontent.oculuscdn.com&_nc_gid=Ao1lJgHSc9_gzRVLU8OKVZI&oh=00_AYAppWZ5qi5-t55kFSFfOaQuW12ogbpjt7CcxcmhUKKr-A&oe=66E17BA1"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Healium", "pl