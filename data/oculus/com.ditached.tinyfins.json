009599067318563_7115049800448406729_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DA0qirxt-VoQ7kNvgHRcFHN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC422xAh2T-XPiO7aH_sBSbh3Hs9v2W4AHyuu6h7jm6TA&oe=6718E11C"}, {"file_name": "3.png", "id": "505314558539966", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982535_505314561873299_7915904230603270306_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bl1-shXKQx0Q7kNvgFH6a_n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBJRhEgeynniVjtwc0UuMRbFTiULKbxO0hIiXCNx_aWhg&oe=6718E4F2"}, {"file_name": "4.png", "id": "2862364257246355", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031514_2862364260579688_306087352317523359_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T0E5tDIqw50Q7kNvgGgwmAc&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDYzNL2ly-QogX6xcYsL6mecxY_uAm_HOlRJqaKbh45pg&oe=6718E640"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer COver.png", "id": "1288041185499986", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982466_1288041188833319_1651999487860440247_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K9_vr3mGXgUQ7kNvgHutIKk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDrV_0eOIJoofy3safYUeILTIJiydFSMhuEjrxi9uar3Q&oe=6718E911"}, "display_name": "TinyFins", "keywords": ["cute", "highscore", "underwater", "fish", "mixedreality"], "long_description": "Tiny Fins lets you swim free in an ocean playground, guiding a school of cute fish with a sweep of your hand. Dive past colorful clams, snag bunches of bubbles, and avoid hungry sharks!\n\nWhy you will love it: Super-smooth controls that make sudden sprints and quick pivots a cinch when you\u2019re gliding through the water. They\u2019re a lifesaver when you go from popping a string of bubbles to deftly avoiding a spiky puffer fish!\n\nFeatures include:\n- Shark, pufferfish and squid enemies\n- Highscore system with the ability to unlock ranks and trophies\n- Intuitive, flowy controls\n- Collecting fish of different colors", "short_description": "Tiny Fins lets you swim free in an ocean playground, guiding a school of cute fish with a sweep of your hand. Dive past colorful clams, snag bunches of bubbles, and avoid hungry sharks!\n\nWhy you will love it: Super-smooth controls that make sudden sprints and quick pivots a cinch when you\u2019re gliding through the water. They\u2019re a lifesaver when you go from popping a string of bubbles to deftly avoiding a spiky puffer fish!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://tiny-fins.com/imprint.html", "developer_terms_of_service_url": null, "publisher_name": "Ditached GmbH", "support_website_url": null, "website_url": "https://ditached.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "fr", "fr_CA", "ja", "zh_CN", "zh_HK", "zh_TW"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26652350321030138"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "559210789767808"}, {"status": "PUBLISHED", "id": "2046530205764406"}, {"status": "PUBLISHED", "id": "1319438632776054"}]}, "baseline_offer": {"id": "559210789767808"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1725987600, "status": "PUBLISHED", "id": "559210789767808"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": 