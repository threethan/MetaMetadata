8982654_419123241047102_365603553195041247_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n6R0v-zZblMQ7kNvgGR_uhT&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYB1PRS-VhbakxnzxFD-_lU3hsUQinZG4aPjVBgu2mnkJQ&oe=675ECF73"}, {"file_name": "screenshot2.png", "id": "1426207118025390", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75556798_1426207121358723_2648143554158698554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ULnE0VkWIYIQ7kNvgGVC0Uv&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAZutj7DdgTm296YoZK9EX48qvWIws0_xAliSEVQZbVgw&oe=675EB203"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "990589445769829", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38974857_990589449103162_6151257044926900171_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=w6vQ4oZ6PXkQ7kNvgHYW_rQ&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYD4_wvZEQ6ygtRuYBeVNyz64n9PY0tioMqFKKh5EbnmHg&oe=675EA650"}, "display_name": "WhiteboardXR", "keywords": [], "long_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's Pictures folder onto real life surfaces. It supports images scaling and transparency, and works great for tracing transparent line art images onto whiteboards.\n\nThis app is best used with transparent images. The app will not automatically remove the background or trace out an image, only display an image onto a moveable plane.\n\nThis app does need permission to read from the internal storage to access the images to display. A stationary boundary is recommended. Also, the window for drawing will center on your POV during start up.", "short_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's storage onto real life surfaces. It supports images scaling and transparency, and works for tracing transparent line art images onto whiteboards or chalkboards."}]}, "developer_name": null, "developer_pri