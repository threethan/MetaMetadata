8982654_419123241047102_365603553195041247_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GyicJxG4K6wQ7kNvgHUTu50&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTTnTZgN4x1dc8YqpmD3UsCe6vwhLyCqlgEyGtPEXLXA&oe=676BFE73"}, {"file_name": "screenshot2.png", "id": "1426207118025390", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556798_1426207121358723_2648143554158698554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YWL_vzvq8qUQ7kNvgFjXR-4&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA4Gq13fE_0WrQQI7xx66wJcycpf2ZB2wVPuEhAu_dmUA&oe=676BE103"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "990589445769829", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974857_990589449103162_6151257044926900171_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8yfvg1urSD0Q7kNvgHYshPJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDnUEzpyd590gCovg8sOdiqIXfRs3GrbwdK7mVOa3sqzQ&oe=676BD550"}, "display_name": "WhiteboardXR", "keywords": [], "long_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's Pictures folder onto real life surfaces. It supports images scaling and transparency, and works great for tracing transparent line art images onto whiteboards.\n\nThis app is best used with transparent images. The app will not automatically remove the background or trace out an image, only display an image onto a moveable plane.\n\nThis app does need permission to read from the internal storage to access the images to display. A stationary boundary is recommended. Also, the window for drawing will center on your POV during start up.", "short_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's storage onto real life surfaces. It supports images scaling and transparency, and works for tracing transparent line art images onto whiteboards or chalkboards."}]}, "developer_name": null, "developer_pri