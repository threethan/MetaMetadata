ot5.png", "id": "419123221047104", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982654_419123241047102_365603553195041247_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S30xF_MVdE0Q7kNvgHXH8lG&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASX8pcWfdH5hQIPyG-oUuvi&oh=00_AYBJNmXHp-CdCeUhJCMox9FoytRQKtCYB1YLN3riMmQ4tw&oe=66E6D6F3"}, {"file_name": "screenshot2.png", "id": "1426207118025390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556798_1426207121358723_2648143554158698554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ReovYjpW1gEQ7kNvgGGHRMY&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASX8pcWfdH5hQIPyG-oUuvi&oh=00_AYAZx2kuR5Bk8M29kIWPq67Sct-4PBEayCz7OuoyGoswGw&oe=66E6B983"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "990589445769829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974857_990589449103162_6151257044926900171_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XjkFzq_28PcQ7kNvgE6ljwX&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASX8pcWfdH5hQIPyG-oUuvi&oh=00_AYDkm379qXMfD355oqaoU5k_BL3gsIe4j_qSJ-_gsyz_9w&oe=66E6ADD0"}, "display_name": "WhiteboardXR", "keywords": [], "long_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's Pictures folder onto real life surfaces. It supports images scaling and transparency, and works great for tracing transparent line art images onto whiteboards.\n\nThis app is best used with transparent images. The app will not automatically remove the background or trace out an image, only display an image onto a moveable plane.\n\nThis app does need permission to read from the internal storage to access the images to display. A stationary boundary is recommended. Also, the window for drawing will center on your POV during start up.", "short_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's storage onto real life surfaces. It supports images scaling and transparency, and works for tracing transparent line art images onto whiteboards or chalkboards."}]}, "developer_name": null, "developer_privacy_policy_url": "https://odachivr.art/privacy-policy.md", "developer_terms_of_service_url": null, "publisher_name": "OdachiVR", "support_website_url": null, "website_url": "https://odachivr.art/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7353648504715921"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974895_967264691617410_8137657320660460585_n.png?stp=dst-png_s360x360&_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OwdE1OxLNcEQ7kNvgHIdIWl&_nc_ht=scontent.oculuscdn.com&_nc_gid=ASX8pcWfdH5hQIPyG-oUuvi&oh=00_AYD61qqFqAaO56knbB6XFBppG1Kcs1i_s4tLidXHHCIrCg&oe=66E6C408"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "WhiteboardXR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Creativity & Design", "id": "323450648956687"}], "release_date": 1716583020, "lastRevision": {"nodes": [{"id": "7353648518049253", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7353648491382589", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {