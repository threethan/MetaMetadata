ot2.png", "id": "1426207118025390", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556798_1426207121358723_2648143554158698554_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Sy0jupRtApYQ7kNvgER75Hx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCll84HLzs0HwYJszLApHS3y3AsC18lU3aFawk8Tvzptg&oe=66FD2303"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "trailerCover.png", "id": "990589445769829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974857_990589449103162_6151257044926900171_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Za5ZvC39LYQ7kNvgHH5t7u&_nc_ht=scontent.oculuscdn.com&oh=00_AYC7FPtIo_w-frjYMbocrcjYMepdOz2-eIXZMjnNLs6ekg&oe=66FD1750"}, "display_name": "WhiteboardXR", "keywords": [], "long_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's Pictures folder onto real life surfaces. It supports images scaling and transparency, and works great for tracing transparent line art images onto whiteboards.\n\nThis app is best used with transparent images. The app will not automatically remove the background or trace out an image, only display an image onto a moveable plane.\n\nThis app does need permission to read from the internal storage to access the images to display. A stationary boundary is recommended. Also, the window for drawing will center on your POV during start up.", "short_description": "WhiteboardXR is a standalone app that allows you to trace images loaded from your Quest's storage onto real life surfaces. It supports images scaling and transparency, and works for tracing transparent line art images onto whiteboards or chalkboards."}]}, "developer_name": null, "developer_privacy_policy_url": "https://odachivr.art/privacy-policy.md", "developer_terms_of_service_url": null, "publisher_name": "OdachiVR", "support_website_url": null, "website_url": "https://odachivr.art/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "3626922114