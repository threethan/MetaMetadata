68_149986445493898_1448925397902163968_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oPM32Kf0gN8Q7kNvgEiUOGX&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDuHR850G7nVYIdG6tMByIEdN_pRtkQDVxECMH5GIFLRw&oe=6724D5F0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "MIST", "keywords": ["VR", "RoomEscape", "horror", "Decryption"], "long_description": " On December 24th, Dana\u2019s child was getting cold in his arms as the chimes of midnight struck. After his parents had died, and his wife died in childbirth, the young businessman had lost his last relative. \n\n   Shortly afterwards, rumor has it that the young businessman went mad. He always holds the picture of his family and talks to the people around him with a creepy smile. People all ridiculed him. Gradually, the townsfolk forgot about him, and he and his house were forgotten in this wasteland.\n", "short_description": "\"MIST \" is a first-person perspective escape decryption game. Players are in an abandoned foreign house where it has cold floors, decrepit furniture and swaying lights. This environment allows players to continuously discover new clues. After players solve the puzzles and walk out of every room, they can successfully escape from the house at last. "}]}, "developer_name": null, "developer_privacy_policy_url": "http://www.mq11034182.icoc.me/", "developer_terms_of_service_url": "http://www.mq11034182.icoc.me/", "publisher_name": "Jacky Xiong", "support_website_url": null, "website_url": "http://www.mq11034182.icoc.me/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["EXPLORATION", "HORROR", "PUZZLE", "SIMULATION", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supporte