ent.oculuscdn.com&oh=00_AYC38og9HJ8bHk5jobTmhc7fQj2kVDxG-bK4BKgedFOwUA&oe=66CF017C"}, {"file_name": "Hide__Seek_optimized.png", "id": "819139260311698", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196218_819139263645031_4824084042172444226_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g52Kh5my_x4Q7kNvgFowy3z&_nc_ht=scontent.oculuscdn.com&oh=00_AYBVyqKtoxHW7JIzbrguQ3OwCENMicglusneHu43PygRTQ&oe=66CEF0E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BISCUS_BANNER_4_optimized_1_optimized.png", "id": "1475700723152962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1475700726486295_8979946353592351396_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QN6OJvHWkKkQ7kNvgGsL0XX&_nc_ht=scontent.oculuscdn.com&oh=00_AYCMMUoDL2DqMyMOCsMVLE3ew0ADIkAatE1XUWhmx-HGHQ&oe=66CF0D80"}, "display_name": "Biscus VR", "keywords": [], "long_description": "Welcome to Biscus Vr, where you can explore and enjoy a diverse range of game modes, each offering a unique challenge and excitement. Dive into the mysterious world of Murder Mystery, where every player could be a friend or a foe. Survive the Infection outbreak by either spreading the contagion or evading the infected. Relive the classic fun of Freeze Tag with a modern twist.\n\nFor those who dare, face your fears in the spine-chilling Horror mode. Test your agility and reflexes in Color Switch, where quick thinking is the key to victory. Finally, experience the explosive excitement of Bomb Tag, where you must avoid being caught with the ticking time bomb.\n\nMaster a variety of unique abilities and strategies to dominate each game mode. We hope you enjoy the endless fun and challenges that await you. Dive in and start playing now!\n\n", "short_description": "Welcome to Biscus Vr, where you can explore different game modes and master a variety of unique abilities. We hope you enjoy the exciting challenges and endless fun that await you. Dive in and start playing now!\n\n"}]}, "developer_na