4.5771-25/39031391_1000447411436099_5331248526557978676_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UVMYiv5QhZgQ7kNvgHw_fBz&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCbn69VJ_ku1kSOVQEQ8KZ00AJ7SpvdV2XPGIe7UDr2uQ&oe=6707B1FC"}, {"file_name": "Hide__Seek_optimized.png", "id": "819139260311698", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75196218_819139263645031_4824084042172444226_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9BrkxhoZeOEQ7kNvgG84XUi&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBf6Sc68DKVdmbg1UW8kJDJxFeyzKw75IX7Acpmvxh5KA&oe=6707D9A2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BISCUS_BANNER_4_optimized_1_optimized.png", "id": "1475700723152962", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031326_1475700726486295_8979946353592351396_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aMxma9Bok2kQ7kNvgFrDQMs&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFsyZUm1k1lgbGItmsgw0s8JtqmUFgPzdcsMnGv3c5wg&oe=6707BE00"}, "display_name": "Biscus VR", "keywords": [], "long_description": "Welcome to Biscus Vr, where you can explore and enjoy a diverse range of game modes, each offering a unique challenge and excitement. Dive into the mysterious world of Murder Mystery, where every player could be a friend or a foe. Survive the Infection outbreak by either spreading the contagion or evading the infected. Relive the classic fun of Freeze Tag with a modern twist.\n\nFor those who dare, face your fears in the spine-chilling Horror mode. Test your agility and reflexes in Color Switch, where quick thinking is the key to victory. Finally, experience the explosive excitement of Bomb Tag, where you must avoid being caught with the ticking time bomb.\n\nMaster a variety of unique abilities and strategies to dominate each game mode. We hope you enjoy the endless fun and challenges that await you. Dive in and start playing now!\n\n", "short_description": "Welcome to Biscus Vr, where you can explore different game modes and master a variety of unique abilities. We hope you enjoy the exciting challenges and endless fun that await you. Dive in and start playing now!\n\n"}]}, "developer_name": "Crispyo", "developer_privacy_policy_url": "https://sites.google.com/view/biscusvrprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "Crispyo", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCynIU49ZUvQmV1pwWAtQkgw", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "411892083130028"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "TRACKED_KEYBOARD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7062818353766766"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569466_1584631522086296_2699541838368498594_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8wO4J2e7noYQ7kNvgFoGL3U&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCBsx5-b1rUFJAxFpEPvCmf6Hp9ie9z4AewcP6gDKHZ5Q&oe=6707A790"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Biscus VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Horror", "id": "411892083130028"}, {"topic_name": "Casual", "id": "394813081514456"}], "release_date": 172221