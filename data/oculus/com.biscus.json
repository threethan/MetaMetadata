Dive in and start playing now!\n\n", "short_description": "Welcome to Biscus Vr, where you can explore different game modes and master a variety of unique abilities. We hope you enjoy the exciting challenges and endless fun that await you. Dive in and start playing now!\n\n"}]}, "developer_name": "Crispyo", "developer_privacy_policy_url": "https://sites.google.com/view/biscusvrprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "Crispyo", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCynIU49ZUvQmV1pwWAtQkgw", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "TRACKED_KEYBOARD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7062818353766766"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569466_1584631522086296_2699541838368498594_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E3RRQ-i7S-AQ7kNvgF6Mi3k&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDwBIzo0sMrwPPCBxWNEi0A8KLaN79-EMldnk4TTDihYQ&oe=6763F090"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Biscus VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}], "release_date": 1722212459, "lastRevision": {"nodes":