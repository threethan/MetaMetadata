 agility and reflexes in Color Switch, where quick thinking is the key to victory. Finally, experience the explosive excitement of Bomb Tag, where you must avoid being caught with the ticking time bomb.\n\nMaster a variety of unique abilities and strategies to dominate each game mode. We hope you enjoy the endless fun and challenges that await you. Dive in and start playing now!\n\n", "short_description": "Welcome to Biscus Vr, where you can explore different game modes and master a variety of unique abilities. We hope you enjoy the exciting challenges and endless fun that await you. Dive in and start playing now!\n\n"}]}, "developer_name": "Crispyo", "developer_privacy_policy_url": "https://sites.google.com/view/biscusvrprivacypolicy/home", "developer_terms_of_service_url": null, "publisher_name": "Crispyo", "support_website_url": null, "website_url": "https://www.youtube.com/channel/UCynIU49ZUvQmV1pwWAtQkgw", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "TRACKED_KEYBOARD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "CO_OP", "SINGLE_USER"], "id": "7062818353766766"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7851883268193600", "version": "2.8"}, "id": "418037437551531", "channel_name": "LIVE"}]}