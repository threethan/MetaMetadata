04511277", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75617327_502738107844610_3214106008865293768_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Wb2BYbQ3hkEQ7kNvgHJp_Ab&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAsOZIVDKMETUc_QLOdBmFx&oh=00_AYAVuvmuhJXRE8snkLMuRRZalkLY7NGJKAw8DJVhEM6JDQ&oe=66EC1258"}, "display_name": "Meteoric VR", "keywords": [], "long_description": "Destroy all the meteorites before they destroy you! You need good peripheral vision and perfect aim to succeed in this game. It\u2019s easy to play but hard to master.\n\nMeteoric VR is a first-person space shooter where the objective is to defend the planet from flying meteors. One hit is enough to lose it all. Our signature feature is a unique movement that you have to make with your hands to achieve successful shooting.\n\nKey features:\n- Fully implemented hand tracking\n- Fitness element\n- Addictive gameplay supported by adaptive music\n- Multiplayer with mobile device players\n\nMultiplayer\nAre you tired of not being involved when your friend plays on a VR headset? Don't worry, we got you. You can now challenge him in-game through a mobile app.You can get into the battle either as a UFO or you can fire meteors. Get the free app!\n\nJoin our Discord community to get the newest updates and premium content. We also answer your questions on a daily basis. \n\nJOIN US \u2192 https://discord.gg/KSr8rDuhEF", "short_description": "Meteoric VR is a first-person space shooter where the player shoots down flying meteors. You need good peripheral vision and perfect aim. Our signature feature is a unique movement that you have to make with your hands to achieve successful shooting.\n\nKey features:\n- Fully implemented hand tracking\n- Fitness element \n- Adaptive music\n- Multiplayer with mobile device players\n\nChallenge your friend who plays on a VR with your phone! Play as a UFO or spawn meteors on him. Get the free app!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://meteoricvr.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Meteoric s.r.o.", "support_website_url": null, "website_url": "https://meteoricvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SHOOTER", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "297655215674761"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1413227069385676"}, {"status": "PUBLISHED", "id": "1176241689925180"}, {"status": "PUBLISHED", "id": "6101945966552790"}, {"status": "PUBLISHED", "id": "364937578389017"}, {"status": "PUBLISHED", "id": "1527415734319662"}]}, "baseline_offer": {"id": "6101945966552790"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1751320800, "status": "PUBLISHED", "id": "1413227069385676"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6365650743535746", "version": "1.8.0"}, "id": "1230754430746025", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4128981423869367", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "6365650743535746"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1230754430746025"}]}, "change_log": null, "create