8982626_999921863547072_7311913239955111936_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=stiA047r1K8Q7kNvgEpJmQn&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAhjqHG8eQyVbPMISmsCUQawsqg302f2vKmPw2t9stulA&oe=674D9971"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art Gate", "keywords": ["Art", "Gallery", "Museum", "Social", "Collector"], "long_description": "Jump into an art opening through the hyper social VR world of Art Gate. 100 people can simultaneously visit a gallery, exhibition tour, or artist talk. If you see an artwork you feel would be a nice addition to your collection you can buy the piece from within your VR headset. Art Gate is a virtual reality marketplace for collectors to acquire Post-War and Contemporary Art. Real artwork and real people from around the globe connect in this virtual world. Pop on your headset and start rubbing shoulders with the innovators of the art world in Art Gate VR. \n\n-Join social art events with up to 100 people\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries", "short_description": "Art Gate is a virtual reality marketplace for collectors to acquire Post-War and Contemporary Art. \n\n-Join social art events with up to 100 people\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries"}]}, "developer_name": "Art Gate VR Inc.", "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.artgatevr.com/app/terms.php", "publisher_name": "Art Gate VR Inc.", "support_website_url": "http://artgatevr.com/", "website_url": "http://artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ART_CREATIVITY", "EDUCATIONAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_are