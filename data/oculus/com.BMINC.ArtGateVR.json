_image.png", "id": "790952711392118", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982626_999921863547072_7311913239955111936_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6aZ3fg8w5tMQ7kNvgFy1C4i&_nc_ht=scontent.oculuscdn.com&_nc_gid=AAwiWYlCUhRUHuZeWPIqk1W&oh=00_AYBMF0M6dHnPZdAf-rgeHyIyFzZLjP4OFe65sbPAvvVlaA&oe=66EC0A71"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Art Gate", "keywords": ["Art", "Gallery", "Museum", "Social", "Collector"], "long_description": "Jump into an art opening through the hyper social VR world of Art Gate. 100 people can simultaneously visit a gallery, exhibition tour, or artist talk. If you see an artwork you feel would be a nice addition to your collection you can buy the piece from within your VR headset. Art Gate is a virtual reality marketplace for collectors to acquire Post-War and Contemporary Art. Real artwork and real people from around the globe connect in this virtual world. Pop on your headset and start rubbing shoulders with the innovators of the art world in Art Gate VR. \n\n-Join social art events with up to 100 people\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries", "short_description": "Art Gate is a virtual reality marketplace for collectors to acquire Post-War and Contemporary Art. \n\n-Join social art events with up to 100 people\n-Buy and sell artwork\n-Connect with international artists, collectors, and galleries"}]}, "developer_name": "Art Gate VR Inc.", "developer_privacy_policy_url": "https://artgatevr.com/privacy-policy/", "developer_terms_of_service_url": "https://www.artgatevr.com/app/terms.php", "publisher_name": "Art Gate VR Inc.", "support_website_url": "http://artgatevr.com/", "website_url": "http://artgatevr.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["ART_