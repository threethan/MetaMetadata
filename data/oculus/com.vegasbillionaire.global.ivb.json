f playing from your favorite spot with our user-friendly seated gaming experience. \n\n\n# Vegas is coming home! \n# Join now to start your journey and capture the essence of Vegas from anywhere in the world!\n\n", "short_description": "Vegas is coming home! Join now to start your journey and capture the essence of Vegas from anywhere in the world!"}]}, "developer_name": "iLab", "developer_privacy_policy_url": "https://vegasbillionaire.centurygame.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Century Games", "support_website_url": "https://centurygames.helpshift.com/hc/en/147-vegas-billionaire-casino/contact-us/", "website_url": "https://www.centurygames.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1023770785722696"}, {"id": "1700921480735423"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8116272571810814"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "753012993651391"}]}, "baseline_offer": {"id": "753012993651391"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1730977500, "status": "PUBLISHED", "id": "753012993651391"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8267057583398978", "version": "1.1.1"}, "id": "1032736938479301", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{