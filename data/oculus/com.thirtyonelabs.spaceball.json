U9YBIhJn9Ey4M4wn2w&oe=66E6AFC8"}, {"file_name": "Screenshot 5.png", "id": "736965018021034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_736965024687700_5943873289997148396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u6fnZUtmkL8Q7kNvgFPx1du&_nc_ht=scontent.oculuscdn.com&_nc_gid=AScbxwialOKzIyTnJp8RSxH&oh=00_AYBuzUODXidGr6tuMQKFEMNDB2p_aXpNwHRp6c8qF4BWrQ&oe=66E6AFE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "548960833700775", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_548960837034108_7555882882005759514_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uH3uAFAb4VkQ7kNvgF5aqVL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AScbxwialOKzIyTnJp8RSxH&oh=00_AYCWGH55_Mcgz3wjHzaTQM1QIRn6ow0W2CLZQgNPg81Uvg&oe=66E6D378"}, "display_name": "Space Ball", "keywords": [], "long_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game.\n\nYou are an astronaut athlete. Your task is to win. Take the ball and kick it into the goal. Jump across the entire field. Have fun and compete!\n\nIn the game, you move around on your hands. No smooth movement, no teleports, just jumping on your hands across the entire field.\n\nThe rules of the game are simple. You must take the ball and drive it into the opposing team's goal. In football mode, you can only hit the ball with your body or hit it with your hands. In other modes (basketball and handball), you can grab the ball with the Grip button on your controllers and throw the ball wherever you want.\n\nFor more control over your movement in the air, you can use dash. To do this, you need to press the A or X button on your controllers and your character will rush in the direction you are looking.\n\nTo rotate in the game, you can rotate your head or use the stick rotation on any of your controllers.\n\nCooperate with other players and have tons of fun in your competitive matches.\n\nThe game is in early access.", "short_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/f878b844-29a5-4c96-9046-204d86949be4", "developer_terms_of_service_url": null, "publisher_name": "31 Labs", "support_website_url": null, "website_url": "https://spaceballvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "1979414825739152"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "232724079192267"}]}, "baseline_offer": {"id": "232724079192267"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677796440, "status": "PUBLISHED", "id": "232724079192267"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7269294816470750", "version": "0.8.0.0"}, "id": "1005940030811277", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6032030750197169", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7269294816470750"}, "release_status": "