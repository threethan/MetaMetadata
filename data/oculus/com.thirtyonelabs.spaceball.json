0912870498837", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75195912_680912873832170_3894765762612694807_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4zFEyqdSIS4Q7kNvgHt-Kfh&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDMPMF3ofEQ1UdcI7A8XSjvxP5a19InvYf04DOvuxHCOQ&oe=672B4563"}]}, "id": "722826559432952", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 1.png", "id": "752059313159548", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031621_752059316492881_3160292831861218141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pw0ohcAtYqwQ7kNvgE4MA2f&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDPVRYkwptk_wW7U1V1dIgaQontNjGsb5HI4a9juagIbw&oe=672B5144"}, {"file_name": "Screenshot 2.png", "id": "513840667356357", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031542_513840674023023_4960648718376860532_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aegsHS5UBYMQ7kNvgH9-MJp&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD1aZHrX1qaa0GHTTyml9Umrqk8Pe-j_PUE6weryRCzaQ&oe=672B6589"}, {"file_name": "Screenshot 3.png", "id": "919222459209236", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75371511_919222462542569_5810086399487682696_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D5omFTBASfkQ7kNvgHM5rZJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBfLnWhD4a-sYFcnSxunB3k0NQi8-SmhqGol7hFl7n3YQ&oe=672B42AF"}, {"file_name": "Screenshot 4.png", "id": "689137563008787", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57569471_689137566342120_295951212839820955_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OIQdz_U4l2MQ7kNvgH5k-gf&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBFYYDTTyJZqxFpNy9kMvXDiqftEbV8V2IYGS4A9jpivA&oe=672B3DC8"}, {"file_name": "Screenshot 5.png", "id": "736965018021034", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974456_736965024687700_5943873289997148396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=juT5tT5MJGwQ7kNvgHyU0Uk&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCT6ZScMUjjt7h9LenjARj20WQkMIIcFVruGQg_fe000A&oe=672B3DE2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "548960833700775", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982552_548960837034108_7555882882005759514_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=f3FwKfoeJPoQ7kNvgGMWuZo&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDlZGgmO0wC-7XtR3_wcE4PHax7Q6PRYe9DQ-H_jWiJ7Q&oe=672B6178"}, "display_name": "Space Ball", "keywords": [], "long_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game.\n\nYou are an astronaut athlete. Your task is to win. Take the ball and kick it into the goal. Jump across the entire field. Have fun and compete!\n\nIn the game, you move around on your hands. No smooth movement, no teleports, just jumping on your hands across the entire field.\n\nThe rules of the game are simple. You must take the ball and drive it into the opposing team's goal. In football mode, you can only hit the ball with your body or hit it with your hands. In other modes (basketball and handball), you can grab the ball with the Grip button on your controllers and throw the ball wherever you want.\n\nFor more control over your movement in the air, you can use dash. To do this, you need to press the A or X button on your controllers and your character will rush in the direction you are looking.\n\nTo rotate in the game, you can rotate your head or use the stick rotation on any of your controllers.\n\nCooperate with other players and have tons of fun in your competitive matches.\n\nThe game is in early access.", "short_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game."}]}, "developer_name": null, "de