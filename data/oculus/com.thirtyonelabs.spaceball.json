0912870498837", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75195912_680912873832170_3894765762612694807_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ojlAZy5hR0Q7kNvgEg4fMf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUkZaSBsw5AyT1vfzMeUBGTlbLfmYYtgcOqTOb84fukA&oe=674EDDE3"}]}, "id": "722826559432952", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 1.png", "id": "752059313159548", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031621_752059316492881_3160292831861218141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4Q9ytwnmgqQQ7kNvgE1MawN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAHwbn01Xvea75t4K4wH8W2PWt_CjSwrwfWFXuSMZ6tGw&oe=674EE9C4"}, {"file_name": "Screenshot 2.png", "id": "513840667356357", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031542_513840674023023_4960648718376860532_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U1abtf7ht-IQ7kNvgHTHMPK&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBO_6sbHjBCAoGSdMchxpHJ6CFO_r1GYxUFhROu3LMYKw&oe=674EFE09"}, {"file_name": "Screenshot 3.png", "id": "919222459209236", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75371511_919222462542569_5810086399487682696_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yxwe7efxKawQ7kNvgEBYQ5G&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBsRVDIkUsy-hvatCXKEu_PCS2jy-ybAdy4EvrCNHpZMw&oe=674EDB2F"}, {"file_name": "Screenshot 4.png", "id": "689137563008787", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57569471_689137566342120_295951212839820955_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NFBDnGvFVBsQ7kNvgHmtJh0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYALTDQhWvBmntemyWhvnfuel1G86sLfJR2xjAoTkKeXjg&oe=674ED648"}, {"file_name": "Screenshot 5.png", "id": "736965018021034", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_736965024687700_5943873289997148396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lPmWOi2FU9EQ7kNvgFwE215&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8kRWDyQPONgy4MXMtqDUEwOI6-YhIr9420xkGr9BBMw&oe=674ED662"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "548960833700775", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982552_548960837034108_7555882882005759514_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QQr6Wp5-6t0Q7kNvgHJSAYZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApgD_KjTeFbPMvK0TTB7IUEVAXLeRtHR0JLrBPRkoGWg&oe=674EF9F8"}, "display_name": "Space Ball", "keywords": [], "long_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game.\n\nYou are an astronaut athlete. Your task is to win. Take the ball and kick it into the goal. Jump across the entire field. Have fun and compete!\n\nIn the game, you move around on your hands. No smooth movement, no teleports, just jumping on your hands across the entire field.\n\nThe rules of the game are simple. You must take the ball and drive it into the opposing team's goal. In football mode, you can only hit the ball with your body or hit it with your hands. In other modes (basketball and handball), you can grab the ball with the Grip button on your controllers and throw the ball wherever you want.\n\nFor more control over your movement in the air, you can use dash. To do this, you need to press the A or X button on your controllers and your character will rush in the direction you are looking.\n\nTo rotate in the game, you can rotate your head or use the stick rotation on any of your controllers.\n\nCooperate with other players and have tons of fun in your competitive matches.\n\nThe game is in early access.", "short_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game."}]}, "developer_name": null, "de