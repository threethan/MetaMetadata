0912870498837", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75195912_680912873832170_3894765762612694807_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rWB9O7iMSDMQ7kNvgHeR6lA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBTc26nTNYOLC5qAajb_PEVEI5q0TiSMuRo59KFyKCKLg&oe=67405D63"}]}, "id": "722826559432952", "locale": "en_US", "screenshots": [{"file_name": "Screenshot 1.png", "id": "752059313159548", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031621_752059316492881_3160292831861218141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e09e6envj4sQ7kNvgFZbacx&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBxjldKfgkARGZFHN2kOE6_MEEk5qdho_bYlnXMC-lzrw&oe=67406944"}, {"file_name": "Screenshot 2.png", "id": "513840667356357", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031542_513840674023023_4960648718376860532_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mnQlg3-gA7kQ7kNvgFEnvMa&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAOly8ZbJku4CpENcS38VEh83e5Vauu_0_2eeNkYY89UQ&oe=67407D89"}, {"file_name": "Screenshot 3.png", "id": "919222459209236", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75371511_919222462542569_5810086399487682696_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WZVqxOtMWlQQ7kNvgE7SrAS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCIY8S56llS0Nz6q_MmWUq5n3Es36PVraEHyWJfmdPNcg&oe=67405AAF"}, {"file_name": "Screenshot 4.png", "id": "689137563008787", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57569471_689137566342120_295951212839820955_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RPxQR7btlvgQ7kNvgHbZaAL&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD8BG_rYdXf1p9eIbKShkGtZON4Y93NS2XoTfPu5hMAFQ&oe=674055C8"}, {"file_name": "Screenshot 5.png", "id": "736965018021034", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974456_736965024687700_5943873289997148396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n5YN_dPV_vgQ7kNvgGGijzg&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC-3zhAviGUZVVIJyoVLCxTPOCdWs6z0YkoKbiSRomtgQ&oe=674055E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "548960833700775", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982552_548960837034108_7555882882005759514_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wpD4IFf3J2AQ7kNvgGUt70_&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB4f4KzG0whdu9UHd4i6hCukfgjWT1iLZZ0vlqsIk-lUQ&oe=67407978"}, "display_name": "Space Ball", "keywords": [], "long_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game.\n\nYou are an astronaut athlete. Your task is to win. Take the ball and kick it into the goal. Jump across the entire field. Have fun and compete!\n\nIn the game, you move around on your hands. No smooth movement, no teleports, just jumping on your hands across the entire field.\n\nThe rules of the game are simple. You must take the ball and drive it into the opposing team's goal. In football mode, you can only hit the ball with your body or hit it with your hands. In other modes (basketball and handball), you can grab the ball with the Grip button on your controllers and throw the ball wherever you want.\n\nFor more control over your movement in the air, you can use dash. To do this, you need to press the A or X button on your controllers and your character will rush in the direction you are looking.\n\nTo rotate in the game, you can rotate your head or use the stick rotation on any of your controllers.\n\nCooperate with other players and have tons of fun in your competitive matches.\n\nThe game is in early access.", "short_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game."}]}, "developer_name": null, "de