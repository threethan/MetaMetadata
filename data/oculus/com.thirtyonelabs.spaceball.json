nt.oculuscdn.com/v/t64.5771-25/38974577_5891268730972684_3626123934385605398_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BEt7WGjqssEQ7kNvgG0joZK&_nc_ht=scontent.oculuscdn.com&oh=00_AYCwjZDXu_N5aMhbyZvixdSEopDn5aENz2CDuSp9uTQBIA&oe=66D318FC"}, "display_name": "Space Ball", "keywords": [], "long_description": "\ud83c\udfc0\ud83e\udd8d Play basketball in space with the agility of a gorilla \u2013 Space Ball is out of this world VR sports like you've never seen before!\n\nDownload for free and enjoy:\n- \ud83c\udf0c Space Arenas: Slam dunk in wild space settings.\n- \ud83d\ude80 Gorilla Moves: Leap and glide for amazing shots in multiplayer.\n- \ud83e\udd16 Tons of Modes: Choose from basketball, soccer, or handball in 1v1, 2v2, or 3v3, plus cool challenges.\n\nElevate Your Game with Space Pass:\n- \ud83d\ude32 New Courts: Explore awesome new space arenas.\n- \ud83c\udf20 Unique Characters: Switch it up with different characters.\n- \ud83c\udfa8 Exclusive Gear: Grab special skins, helmets, and more.", "short_description": "\ud83c\udfc0\ud83e\udd8d Play basketball in space with the agility of a gorilla \u2013 Space Ball is out of this world VR sports like you've never seen before!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/f878b844-29a5-4c96-9046-204d86949be4", "developer_terms_of_service_url": null, "publisher_name": "31 Labs", "support_website_url": null, "website_url": "https://spaceballvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_