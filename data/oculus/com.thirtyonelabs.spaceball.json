ontent.oculuscdn.com/v/t64.5771-25/39031621_752059316492881_3160292831861218141_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ouJN6KdNaZoQ7kNvgFnRDl3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDxqU39F0AYyo3a1ewnN23bCJxqp1FjL1hYt5B3OPyfSQ&oe=66D2FCC4"}, {"file_name": "Screenshot 2.png", "id": "513840667356357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031542_513840674023023_4960648718376860532_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=06o8KaRYSEgQ7kNvgG78rKU&_nc_ht=scontent.oculuscdn.com&oh=00_AYASJEdP3yyM105rNL8CyHx_o_ctIlAtE1CUZ4bLxErGlg&oe=66D31109"}, {"file_name": "Screenshot 3.png", "id": "919222459209236", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371511_919222462542569_5810086399487682696_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FmyaVI61jWcQ7kNvgEJ1mHS&_nc_ht=scontent.oculuscdn.com&oh=00_AYBPjoT1H-6Kfy2_SbxMGHObTnA78Y1-wVoyc5iDNVtnKw&oe=66D2EE2F"}, {"file_name": "Screenshot 4.png", "id": "689137563008787", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_689137566342120_295951212839820955_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WpeWkQiDbzEQ7kNvgFv_Jpz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCZOQz8tj_oe4x2E70nyw0ThXyU8c1B-PDhMAMkBF6fqw&oe=66D2E948"}, {"file_name": "Screenshot 5.png", "id": "736965018021034", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_736965024687700_5943873289997148396_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=34H0po0AIFgQ7kNvgFxDnJJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBx0uq9i9PRZand9N0PLMr0GunAiYDH2tTYpSVwecOf0w&oe=66D2E962"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Video Cover.png", "id": "548960833700775", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982552_548960837034108_7555882882005759514_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EF6vwxKwXoAQ7kNvgHhXgAh&_nc_ht=scontent.oculuscdn.com&oh=00_AYCF-KbD_4vrXkyh05-rQdstuD9MEw4J8oD1LwsYf17W2A&oe=66D30CF8"}, "display_name": "Space Ball", "keywords": [], "long_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game.\n\nYou are an astronaut athlete. Your task is to win. Take the ball and kick it into the goal. Jump across the entire field. Have fun and compete!\n\nIn the game, you move around on your hands. No smooth movement, no teleports, just jumping on your hands across the entire field.\n\nThe rules of the game are simple. You must take the ball and drive it into the opposing team's goal. In football mode, you can only hit the ball with your body or hit it with your hands. In other modes (basketball and handball), you can grab the ball with the Grip button on your controllers and throw the ball wherever you want.\n\nFor more control over your movement in the air, you can use dash. To do this, you need to press the A or X button on your controllers and your character will rush in the direction you are looking.\n\nTo rotate in the game, you can rotate your head or use the stick rotation on any of your controllers.\n\nCooperate with other players and have tons of fun in your competitive matches.\n\nThe game is in early access.", "short_description": "Play a fun game of Space Ball with your friends! Football, basketball, handball: any mode you like is available in this sporty and dynamic game."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/f878b844-29a5-4c96-9046-204d86949be4", "developer_terms_of_service_url": null, "publisher_name": "31 Labs", "support_website_url": null, "website_url": "https://spaceballvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "r