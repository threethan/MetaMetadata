700627_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MCN5UErtQEcQ7kNvgHAmNFT&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCnAR5wqTMB6zSXGHf-1vlMwxEzg6p46WpYRZkN0AdpFQ&oe=673717CB"}, {"file_name": "9.png", "id": "1820253981785948", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75375766_1820253985119281_1762543515722905339_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ziOqCaATt_0Q7kNvgEhom9U&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB-oqezjg7UYtcnh9DxV5cwxkDE24qSTCI7NDlfz3FWYg&oe=67371B27"}, {"file_name": "8.png", "id": "1157608512202885", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974805_1157608515536218_3510889081973928631_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwdo8Tny1vcQ7kNvgFYwTtB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA350BW8w1m-L3Fc7vJm73gtrJunXazvByA1WKFKO-bmA&oe=67371BDC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer Cover Page.png", "id": "3531955493736129", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031431_3531955500402795_8164986880065759034_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HzrBj9Wuj0wQ7kNvgGwK6LV&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBB5s1fVeJkiEw8C2QngGuh_XkPONKnpP0w326RoywTEw&oe=67374057"}, "display_name": "Rescue The Holes", "keywords": [], "long_description": "Hey there!\n\nRescue The HOLES is an indie mixed reality puzzle game where you have to help rescue and navigate cute loopy characters, known as \"HOLES\", through a series of pipes, traps and other dangers without touching them! \n\nThis game was originally designed and created by an indie engineer who grew up with Attention Deficit Disorder (ADD) with the social mission of building games to help improve focus, resilience and problem solving in ADD folks, and somehow evolved into something cuter?\n\nYou can set the general game difficulty mode if you find the level too difficult or easy, under the settings panel.\n\nEasy - Each HOLE recovers its HP, after taking damage.\nNormal - HOLES do not recover, with a finite HP.\nHard - HOLES only take 1 hit.\n\nThere are currently 30 levels of various difficulty levels, with the goal of reaching 150 levels by end of this year! Each level has also a difficulty category:\n\n1) Beginner (Green)\n2) Intermediate (Yellow)\n3) Hard (Red)\n4) Insane (Purple)\n\nHelp the HOLES navigate through these obstacles and challenges:\n\n1) Pipes - Avoid coming into contact with the pipes, these deal frictional damage to the HOLES.\n2) Traps - Avoid the traps that deal maximum damage!\n3) Junction switches - Find and activate the switches to cross-junctions and obstacles to reach the final destination.\n4) Fattening cheese - Grow bigger to overcome bigger pipes\n5) Timer\n\nDo give HOLES a chance! Thank you for supporting my project!", "short_description": "Challenge your focus and resilience by guiding cute loopy characters called HOLES, through a series of pipes, traps and other dangers, without touching them!\n\nComplete and progress through harder and more complex levels as you improve your mental resilience and psychomotor skills! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.RescueTheHoles.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Jonotaku", "support_website_url": null, "website_url": "https://www.RescueTheHoles.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_m