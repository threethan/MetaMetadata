f&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCkMBUQ7rkjTYXl-6lRUCpBr3uKTq7xSIv2gu9bzrbPRw&oe=670511FD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1992352341165327", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75326673_1992352344498660_5689810170846410426_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MDD0zhEQV_sQ7kNvgGO7Q8Z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3sH8PWPJl_ZAJylyzWbfEH7k_NfuiErZGM_19iS2RzQ&oe=67052E50"}, "display_name": "Chamvr | Bowling & Arcade", "keywords": [], "long_description": "\ud83c\udfae Immerse Yourself in the Ultimate VR Bowling Experience! \ud83c\udf1f\n\nRediscover classic arcade games in stunning VR environments, and get ready for even more thrilling games on the horizon!\n\n\ud83d\udd79\ufe0f Features:\n\u2728 Online Multiplayer: Connect with friends and players from around the world as you compete in your favorite games.\n\n\ud83c\udfb3 8 Spectacular Bowling Lanes: Perfect your bowling skills in stunningly designed VR lanes. Rack up strikes, spares, and unforgettable moments!\n\n\ud83c\udfaa Arcade Extravaganza: We've brought the arcade to your VR headset! Try your hand at the ever-addictive Ski-ball, showcase your shooting prowess in Basketball, and prove your precision in Darts.\n\n\ud83c\udfb2 Classic Tabletop Games: Whether it's a battle of wits in Dominoes or a race to play the perfect card in Crazy Eights, we've got your favorite card games to enjoy with friends.\n\nJoin us today and be part of the VR gaming revolution! \ud83c\udf10\ud83d\udd79\ufe0f \n\nFor more info, and issues please email me at:\nbraulio@chamvr.com", "short_description": " Play Bowling and Arcade games with your VR friends"}]}, "developer_name": null, "developer_privacy_policy_url": "https://chamvr.com/privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Chamvr Inc", "support_website_url": null, "website_url": "https://www.chamvr.com/", "category": "APPS", "com