essed on.  \n\nPlayers select appropriate PPE items and \u201cdress\u201d a virtual mannequin to show their knowledge of the PPE requirements of specific workplaces. Once complete, their attempt is assessed automatically, and feedback is given accordingly.  ", "short_description": "PPE is a standalone experience that allows players to assess their knowledge of the personal protective equipment (PPE) required to participate in various key workplaces. Workplaces include a construction site, a science lab, a welding bay, a veterinary x-ray clinic and a commercial kitchen."}]}, "developer_name": "TAFE NSW", "developer_privacy_policy_url": "https://www.tafensw.edu.au/vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "TAFE NSW", "support_website_url": null, "website_url": "https://www.tafensw.edu.au/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "667230424980420"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974854_452185629749854_7705099886611669872_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x1EzaftdlBEQ7kNvgEmKLrJ&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB2JkzC0VteTyyhp8ASF4oZJqaGDyBjED15qAA-Dxsl4Q&oe=67752A48"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Personal Protective 