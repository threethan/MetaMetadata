iler": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D09tr8zhsQYQ7kNvgF7eRKa&_nc_ht=scontent.oculuscdn.com&oh=00_AYACnCso2kp_F_m0lmOc7gGWbEbs3IMJuMXVpo3cfOHDww&oe=66EEC091"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lEbLQGhP0vgQ7kNvgHsuu37&_nc_ht=scontent.oculuscdn.com&oh=00_AYACM6lUqpjMygYsS7Q_m8k1UiTIPDvbZorgTnWCERBExg&oe=66EE954E"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "1189446091593130", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982665_1189446094926463_7411146096846439131_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FcLKQ0ItGnEQ7kNvgHAmWYl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAaqABAFe5s4G59OycHLb4Zxh_Sz7nygyaXp1miGCRJiQ&oe=66EEA60