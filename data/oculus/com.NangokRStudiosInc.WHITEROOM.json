2-1.oculuscdn.com/v/t64.5771-25/75556793_1114046219630994_3918445094753091228_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vNyR2OUrWl8Q7kNvgHsrWEq&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDXNUcpFh8CfmTOrB8tYzE_cKakdA1D3WAJCFxdMsSx5g&oe=677BB078"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0VYlDpUWPK0Q7kNvgHiOfrV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBLLBej2fjBroJpOnOhUt9oxxVt4eDgBwQVu31c8redog&oe=677BD111"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FukB7IcJHNAQ7kNvgEWGNzZ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAfPlGvsZld-3g-sqG455Luq8feYVkP3L6F9l3uKF8YFw&oe=677BA5CE"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "