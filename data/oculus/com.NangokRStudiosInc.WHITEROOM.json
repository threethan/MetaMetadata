=1-7&_nc_sid=6e7a0a&_nc_ohc=9I94Y4WXtosQ7kNvgH9sx3R&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCB-SQBuFIM_d0mh87MgkrdwtpTHfKnvWXeUCnTVdnZKw&oe=670114F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AiQH3Ph7AssQ7kNvgHa_1qB&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD24qFdK11pi5NMEY-39LAuMHNOdiwkxNUWrQImWUdLVQ&oe=67013591"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DbSZslFfoIEQ7kNvgFwDmju&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA-g2puhTziika_RVdYJXvjMYU3-fnpk16oX0jvxPNSIQ&oe=6701428E"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "1189446091593130", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982665_