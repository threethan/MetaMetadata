nt-sin11-2.oculuscdn.com/v/t64.5771-25/75556793_1114046219630994_3918445094753091228_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pA2S-1MaS7cQ7kNvgHHNyaF&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYCuEGMEI9f9RXvHfT2qK6rsjyyi8N7WetfpZya2vLSCmg&oe=677E5378"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HUUqLQGS_RwQ7kNvgE4Nkas&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYBcy9mtllRIBxnatQquVO7SFME9o_gA1xxJIBM67tCpZg&oe=677E7411"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GugHcxI2lYwQ7kNvgFH2iYy&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYB7GZJ1ekX_1w4upN4b2aOZ1HS4Uov11BcvjQdZ5PG8WQ&oe=677E48CE"}, {"file_name": "CoverImageSafeAreaTemplateSquare.p