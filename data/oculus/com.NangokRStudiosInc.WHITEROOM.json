3-1.oculuscdn.com/v/t64.5771-25/75556793_1114046219630994_3918445094753091228_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UmzkiFCvg0kQ7kNvgGVHP5P&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDHLx8B1NhsOgn0lQ-mQfAZ8AQYSvi0cd9SZXe4KEdR_A&oe=67878DF8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ukXf7SUdSW0Q7kNvgELfnR0&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYABiuUXeRNZqclDECFajjWsE9Lg-RnAm8QQj8wcW-KD4A&oe=6787AE91"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0sHXvElEXtcQ7kNvgEuMbib&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCY-Tj0AWVUy0H-y3jUYnmKZd4l_y3qgNzXuY65ORFqRA&oe=6787BB8E"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "