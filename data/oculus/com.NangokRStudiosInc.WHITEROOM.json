=1-7&_nc_sid=6e7a0a&_nc_ohc=dEZ-qWkk9MMQ7kNvgEPMzmE&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAAAQ_uuVRSqBk8w8TYFwE3oxh-zR3ZtUW3i-VwFuQjrA&oe=671F6778"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xd0RS3WfW6EQ7kNvgEZFkfF&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBnbo6KV5DqLf9WhRccVsv-fRYLBxbufipjjmXxu2yqYA&oe=671F8811"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o9nXllsdlt4Q7kNvgEwDvbb&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBziP0Oor4LSxjn-0fH0Hn5Rf2RVPl64ismKnaK1yKrbg&oe=671F5CCE"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "1189446091593130", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982665_