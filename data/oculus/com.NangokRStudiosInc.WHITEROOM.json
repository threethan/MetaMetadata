3-1.oculuscdn.com/v/t64.5771-25/75556793_1114046219630994_3918445094753091228_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u0-Sm3VUy9sQ7kNvgFJAxkS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDf10NO6h1j8x40yLeCYvlx_uiw_2bO0UlJIMqnaRF9Vw&oe=676FD2F8"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=laNqfi5RhyMQ7kNvgF2By3-&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAb15riT0Cy6T3IgkoMvIkkpvtnwKq-H4AQrRCbAvNVMA&oe=676FF391"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lUcJMn2c2rwQ7kNvgF6BVeg&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTHS3KnchbZoDYodDHHJJ9w_1jKndJ5H29FVBhdMHUhQ&oe=6770008E"}, {"file_name": "CoverImageSafeAreaTemplateSquare.png", "id": "