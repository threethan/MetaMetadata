E2E4C3"}, {"file_name": "WR_V5_Store_Quest_E.png", "id": "1114046212964328", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556793_1114046219630994_3918445094753091228_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ieJYyF_-uJIQ7kNvgGKZBQZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuLDbxCmpm2wzecXtyc74WA&oh=00_AYDbxA3Hvi7fbol6o9dj4GKNlvRYovI9WOD8fij7dQn3eQ&oe=66E2C278"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WR_V5_Store_Quest_Video_Thumbnail.png", "id": "1115066816204493", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75272215_1115066819537826_2999547195316242706_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JxR6zvtkZDoQ7kNvgF2XDf4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuLDbxCmpm2wzecXtyc74WA&oh=00_AYCRvT2zUkGHoFAnniPYwvv3C669NIpRdmU7OK32Ta3Lww&oe=66E2E311"}, "display_name": "WHITEROOM", "keywords": [], "long_description": "Making metaverse deployment safe and simple for enterprises\n\nWHITEROOM is a metaverse platform designed for enterprises that supports both VR (virtual reality) and MR (mixed reality).\n\nIt supports multi-devices, multimedia, and multi-users, so you can participate in meetings as an avatar from any location and on any device as long as there is a network environment. You can communicate while sharing 3D models, office documents, PDFs, images, videos, etc. in the Metaverse space.\n\nBy supporting both VR and MR, it is possible to establish a real contact point in the metaverse space, enabling new communication that connects the field and the office.", "short_description": "Making metaverse deployment safe and simple for enterprises"}, {"images": {"nodes": [{"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "5310090842368585", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031484_5310090845701918_1084593935181500038_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KYuF7MYJ7g0Q7kNvgG-ancP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AuLDbxCmpm2wzecXtyc74