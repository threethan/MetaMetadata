49733_88251435089237656_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hbS_ZZB7cl8Q7kNvgEfgVpt&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYDZMtVx9ba-J5CQ1cRJ3JzOja59Ea9GxGSNbbphQbZelg&oe=66EEA7F7"}, {"file_name": "screen_3840x2160_2019-05-30_08-44-34.png", "id": "279099493586373", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031621_279099496919706_6850500814805696919_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xzHaCztukhMQ7kNvgHkFzwq&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYBnluEJYhOqLP6ydpso8XtGTgMvqswOMUfckZAS2TEkWg&oe=66EE90CC"}, {"file_name": "screen_3840x2160_2019-05-30_08-55-47.png", "id": "764791054472946", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974789_764791057806279_6625982238707003044_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S4-Sn4TFg54Q7kNvgHwtS-Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYCxUdqVpLkEJRDa9SwVDs2AadI2jTURqWOCPB4P9OUYhA&oe=66EEB660"}, {"file_name": "screen_3840x2160_2019-05-30_08-59-36.png", "id": "1087691371706859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982479_1087691375040192_2883170994051929962_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JwfHmmPADAIQ7kNvgHWLOyN&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYD_NFYngpowY3NEkyfGBRQFwFFTnUUKTELvEl6OXMKyuw&oe=66EE98C1"}, {"file_name": "screen_3840x2160_2019-05-30_08-50-39.png", "id": "1969634163178042", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031539_1969634166511375_1933600362679177853_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pc1iTGPAMqEQ7kNvgEkJVmf&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYB7b5zmLuXyskA_k7_t2ZU21Vskx3BERh1j1_eYXGJwmQ&oe=66EEB500"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "screen_3840x2160_2019-05-30_08-50-39.png", "id": "2495285880766998", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031363_2495285884100331_7543578855093933327_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D6JcuYVTSEMQ7kNvgE08BJu&_nc_ht=scontent.oculuscdn.com&_nc_gid=ArN-oDa-EppGyPzqh6mjci2&oh=00_AYBMMp7FpuwuNX49iDYSJVuG3Um_tJFpG3YS_8qtPHlzTA&oe=66EEBCCB"}, "display_name": "Dissection Simulator: Cat Edition", "keywords": [], "long_description": "Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality cat dissection in Dissection Simulator: Feline Edition. Learn the fundamentals of the feline anatomy through its various systems in our fully immersive VR experience.\n\nThe entire program adheres to the Next Gen Science Standards (NGSS), America\u2019s framework for science learning. In addition, we\u2019ve implemented the processes and procedures of Carolina Biological--America\u2019s leading supplier of science education materials. Using original and lifelike physical models, the dissection experience is recreated to the finest detail and is a comparable substitute for actual live specimen classroom dissections.\n\nSchools can save on expensive and rising annual costs of animal specimens. Additionally, acquisitions are reliable and not dependent on animal procurement. Learning pacing is user-controlled to ensure maximum understanding of the teaching while moving through the program.", "short_description": "Join Wendy Martin, national award-winning science teacher, to guide you through a virtual reality cat dissection in Dissection Simulator: Feline Edition. Learn the fundamentals of the feline anatomy through its various systems in our fully immersive VR experience."}]}, "developer_name": "VictoryXR", "developer_privacy_policy_url": "https://victoryxr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VictoryXR", "support_website_url": null, "website_url": "https://victoryxr.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genre