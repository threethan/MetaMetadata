T COUNTS."}]}, "developer_name": null, "developer_privacy_policy_url": "http://deepbrain.xyz/chase_n_hunt/privacy-policy.html", "developer_terms_of_service_url": "http://deepbrain.xyz/chase_n_hunt/privacy-policy.html", "publisher_name": "Pixelwave", "support_website_url": null, "website_url": "http://www.deepbrain.xyz/chase_n_hunt", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en_US", "en", "en_AU", "en_CA", "en_ZA", "en_GB"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "616211903008281"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12410280_1925393340826038_309328531114950656_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oO7Eopxt8cEQ7kNvgGpvOod&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUeG7w1bdKvtFh7f3qruWuw&oh=00_AYBHjKPt3kGs6iAUFerXkLqSSQScmBpWmhb19r0aJeLmrQ&oe=66EFE51F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Chase 'n Hunt", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1501693200, "lastRevision": {"nodes": [{"id": "1507591815963582", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1439818472776831", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "145778262667699"}, "iarc_email": null, "msrp": null, "translations": {