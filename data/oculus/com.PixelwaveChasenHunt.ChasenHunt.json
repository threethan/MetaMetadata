n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Dcojgv1B6KwQ7kNvgH1YCho&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBjyul-XSq7OSKklZ5v6Y_J2nlHQBz7UbW0Wa-usj0CvQ&oe=6787B2AC"}, {"file_name": "migrated_image.png", "id": "212993736778839", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/11162704_113128252736918_120924812808814592_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CzLKuDkV_DkQ7kNvgHrSrAB&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYD9G5y9UfPRY6D5UwshawK9uOIaR-E5BsxJpTgXzaqDjg&oe=6787891C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2Chase 'n Hunt___video Cover Art 2650x1440px.png", "id": "2424906467812543", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75307245_2424906471145876_4523350578648896172_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MfKeNS_APgMQ7kNvgEwQlOm&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYB2c64QktQpGB6I5sJJ93QnakzBav5-NqNyKvAmg5OeUQ&oe=6787A3E4"}, "display_name": "Chase 'n Hunt", "keywords": ["Hunt", "Openseason", "Hunter", "Telescopic", "Gun"], "long_description": "An extraordinary FPS hunting experience in Gear VR.\nChase, Target and Shoot at the head of your prey. Meanwhile collect gold & ammo to level up your telescopic sniper rifle but always be on your toes, cause in this game there is a fair chance you might get hunted! \n\n*Additional features\nThe Animals have limited AI.\nThree different levels, and more to come.\nLow poly environment.\nOnly 70 MB free space required.\n\n*How To Play\n1. Tap and hold on touchpad/controller to WALK.\n2. Single or Double Tap to SHOOT.\n3. Swipe Up for telescopic ZOOM sight.", "short_description": "Welcome to an unique First Person experience to chase and hunt in a low poly VR Open Season. Don't go easy with the hunting habitat, There's a fair chance you might get Hunted!\nPlease note: ONLY HEADSHOT COUNTS."}]}, "developer_name": null, "developer_privacy_policy_url": "http://deepbrain.xyz/chase_n_hunt/privacy-pol