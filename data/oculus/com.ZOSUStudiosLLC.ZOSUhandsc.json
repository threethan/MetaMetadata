90_4370501832604500949_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uYqI5XbzsrgQ7kNvgEMJzk2&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB47t3LI19PZuVCAkZjQ2L1Ig7MqD3h1s4yDDoDG-Sd9Q&oe=67752DA5"}, {"file_name": "4D49BA4F-50E6-4D28-A5AF-89DEB0E4A7B6.png", "id": "668372381381047", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75262739_668372384714380_800470237049529823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eD8OiONAVYwQ7kNvgGCWllj&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAKXMwkHmtds2DiCbKNopMfPMzGqYSndoGy3le3pSPKjw&oe=67751234"}, {"file_name": "4E912B6F-F4E4-40C4-86FD-80F02E0BF854.png", "id": "644678620629672", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39001702_644678623963005_500612251056301328_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KLyuuAwTebQQ7kNvgHm5N3Y&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCFGJftu0ssDw128aE8p0IKXNi8RJhZV3cNcJhqTP9BPw&oe=67752423"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "6F81E256-DCEF-4DF5-8C57-988C9E030CF3.png", "id": "620909299718749", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38982469_620909303052082_7936272622065240700_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hQGLohuBoGoQ7kNvgHPReHi&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBt8z7lJou-N0tizmwR6CPSKSCkc1gjZQ_Jvy0R2aOxLg&oe=67752DD8"}, "display_name": "Animalz Mixed Reality", "keywords": ["animals", "augmentedreality", "mixedreality", "zoo", "handtracking"], "long_description": "Create an interactive Zoo in your home with over 60 animals!\n- pass through enabled to see animals in your actual surroundings in mixed reality\n- animals are placeable and moveable with random spawn options and deletion options\n- variety of pre-made and customizable animal placements:\n-- full sized animals\n-- half sized animals\n-- tabletop sized animals\n- animals include: tigers, rhinos, hippos, lions, great white sharks, turtles, bears, zebras, deer, lizards, elephants, mountain goats, farm animals, dogs, cats, many birds, t-Rex and other dinosaurs, boars, leopards, and many more\n\nUpdates:\n- new flying bird level\n- added large animal level with no visual grab aids \n- added ability to switch hand models\n- two new sea turtle levels, they include swimming turtles and baby turtle spawners!\n", "short_description": "Create an interactive Zoo in your home with over 60 animals!\n- pass through enabled to see animals in your actual surroundings in mixed reality\n- animals are placeable and moveable with random spawn options and deletion options\n- variety of pre-made and customizable animal placements:\n-- full sized animals\n-- half sized animals\n-- tabletop sized animals\n- animals include: tigers, rhinos, hippos, lions, great white sharks, turtles, bears, zebras, deer, elephants, dinosaurs, birds, and more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DINOSAURS", "CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8032056330203928"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/3903161