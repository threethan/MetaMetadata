90_4370501832604500949_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9TonqQSpBWsQ7kNvgElMzk3&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDinoiO2pYchY_IFi8nLvp4lQgEgxVHgV9e8AAoZmTpVg&oe=674071A5"}, {"file_name": "4D49BA4F-50E6-4D28-A5AF-89DEB0E4A7B6.png", "id": "668372381381047", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75262739_668372384714380_800470237049529823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WGzaCd1gQFUQ7kNvgGFAgWO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDgE8adVq-ej35WZ0Daw_B0P-hhJ6SpaeBi8UaDXK0Z_w&oe=67405634"}, {"file_name": "4E912B6F-F4E4-40C4-86FD-80F02E0BF854.png", "id": "644678620629672", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001702_644678623963005_500612251056301328_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LbWneW2vM5MQ7kNvgGUQDpv&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDEIwG85g4fqWwO0U8OLjR1uWJAUf4018ZKVd6AA_M86Q&oe=67406823"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "6F81E256-DCEF-4DF5-8C57-988C9E030CF3.png", "id": "620909299718749", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982469_620909303052082_7936272622065240700_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QIpa-HyKGfIQ7kNvgHvTK3N&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBHtd2ylNo2Y8dQfi8PIa6ETjYwKlji7I1TnhYeDsKXrg&oe=674071D8"}, "display_name": "Animalz Mixed Reality", "keywords": ["animals", "augmentedreality", "mixedreality", "zoo", "handtracking"], "long_description": "Create an interactive Zoo in your home with over 60 animals!\n- pass through enabled to see animals in your actual surroundings in mixed reality\n- animals are placeable and moveable with random spawn options and deletion options\n- variety of pre-made and customizable animal placements:\n-- full sized animals\n-- half sized animals\n-- tabletop sized animals\n- animals include: tigers, rhinos, hippos, lions, great white sharks, turtles, bears, zebras, deer, lizards, elephants, mountain goats, farm animals, dogs, cats, many birds, t-Rex and other dinosaurs, boars, leopards, and many more\n\nUpdates:\n- new flying bird level\n- added large animal level with no visual grab aids \n- added ability to switch hand models\n- two new sea turtle levels, they include swimming turtles and baby turtle spawners!\n", "short_description": "Create an interactive Zoo in your home with over 60 animals!\n- pass through enabled to see animals in your actual surroundings in mixed reality\n- animals are placeable and moveable with random spawn options and deletion options\n- variety of pre-made and customizable animal placements:\n-- full sized animals\n-- half sized animals\n-- tabletop sized animals\n- animals include: tigers, rhinos, hippos, lions, great white sharks, turtles, bears, zebras, deer, elephants, dinosaurs, birds, and more!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "DINOSAURS", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8032056330203928"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/390316