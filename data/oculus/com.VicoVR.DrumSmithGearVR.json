zYHGniAdvMgOjfP5RzJlfPg&oe=671B726E"}, {"file_name": "migrated_image.png", "id": "1047710655609252", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162708_142530406514090_1994676008757755904_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xqDUmHZwKEkQ7kNvgFJJAkT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8Di5A5ZscB3cJVajt31bLgboJknd5TvGDj4HQxGuXhw&oe=671B68C2"}, {"file_name": "migrated_image.png", "id": "192791608681342", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/11162769_199535897257732_399451599413444608_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kibEyac5itYQ7kNvgFL3JRn&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCYUTW17z5WdJETMLDVNVLk70Pf2_gGypKFDBL4cTByZg&oe=671B9476"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Drum Smith", "keywords": ["Drum", "Music", "Drummer", "Beat", "Drumsticks"], "long_description": "The Drum Smith is a first person VR drum simulator.\nHave you ever wanted to feel what it is like to be a drummer? Now you have a chance to be one!\nYou can play the drums without music or with it \u2013 just choose the melody and beat the drum when it is indicated.  Try different difficulty modes to get your skills on a whole new level!\n\nYou can play this VR game using VicoVR Full Body Motion Controller if you want full body motion version of the game. Or you can play it like any other cardboard game in any virtual reality headset you like.\n\nWe recommend playing this game with VicoVR Controller to move your whole body in virtual worlds. More info here: http://vicovr.com", "short_description": "The Drum Smith is a first person VR drum simulator."}]}, "developer_name": "3DiVi Company", "developer_privacy_policy_url": "http://vicovr.com/", "developer_terms_of_service_url": "http://vicovr.com/", "publisher_name": "3DiVi Company", "support_website_url": null, "website_url": "http://vicovr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["CASUAL", "EDUCATIONAL", "MUSIC", "SIMULATION", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "236495205318947"}, "review_messages": ["", "Hello,\n\nI wanted to provide some feedback, as changes are needed to the assets submitted.\n\nYour Hero image needs to include your app name/logo centered on the image.\n\nMore information can be found here: (https://static.oculus.com/documents/oculus-store-art-guidelines.pdf)\n\nPlease reach out to submission@oculus.com for any questions.\n\nBest,\n\nThe Oculus Store Team\n", "Hello,\n\nUpon further inspection of your application, there appears to be an issue with the head model within your app that is causing a \"fish eye\" effect.  This is usually caused when the camera model is adjusted within your game engine.  \n\nTo view this issue, load into the main menu and move your head left and right.  The drum set in front of the user can be seen slighting zooming in and out, which ultimately causes discomfort.\n\nFor any additional questions, please reach out to submission@oculus.com.\n\nThanks,\n\nThe Oculus Store Team", "Hello,\n\nPlease remove references to VicoVR from within your app.  Please reach out to submission@oculus.com for any questions.\n\nThanks,\n\nThe Oculus Store Team", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/11162753_1497432326999002_5236504589200523264_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iT-NzA7elGwQ7kNvgGsCYZB&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7-NKfbNNocra0oV7rQkUmlzG9d-jaz0QS