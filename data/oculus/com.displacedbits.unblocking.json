-25/38982564_5869051346459947_1630510606486275388_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qUNIRjtWxdkQ7kNvgGcOcHm&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgOT78hW_2Un5RFhdbnV62T&oh=00_AYAkInFcfsjuDJyW8z0DYUkQAj_u7O-JMUrQvBvEdNMrug&oe=66EE9A8C"}, {"file_name": "vlcsnap-2022-10-18-00h44m40s935.png", "id": "477768967652191", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031652_477768970985524_1638729582372390748_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_gFthOxtKnwQ7kNvgFKfSil&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgOT78hW_2Un5RFhdbnV62T&oh=00_AYBLwhfjLjPMRARWjh5g6yxE7BxZZIq65EKx3DtvZG9NxQ&oe=66EE91B1"}, {"file_name": "vlcsnap-2022-10-18-00h43m15s092.png", "id": "1509837652789379", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031325_1509837656122712_6205336813125663610_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zcwcE9xykGAQ7kNvgGcshCd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgOT78hW_2Un5RFhdbnV62T&oh=00_AYC1HLoAW_iFx5frm-csRJNzBPsdLtxIpaCPbLpGVHuSsA&oe=66EEB8C4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "999586500844262", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86619817_999586507510928_4989718642238371594_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NL_4NL1tiAcQ7kNvgEv4zRF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AgOT78hW_2Un5RFhdbnV62T&oh=00_AYDd7JHQny1eqaH3QdXEWvDR34RUAz-w2kcW-zfznYwGww&oe=66EEAC55"}, "display_name": "Unblocking", "keywords": [], "long_description": "Unblocking is a casual VR game based on dragging piece blocks to clear lines/boards.\nIt supports 3 game modes:\n\n- Puzzle (multiple levels to complete by clearing all blocks on the boards)\n- Relax (time based mode which extends its countdown based on the number of lines completed)\n- Arcade (make lines of different colors using all the available pieces before the time runs out in order to avoid the loss of lifes)", "short_description": "Unblocking is a casual VR game based on dragging piece blocks. Players need to use those piece blocks to remove the blocks displayed on boards (unblock) to score and get the highest score possible (king).  \nThe game presents 3 game modes: Puzzle, Relax and Arcade."}]}, "developer_name": null, "developer_privacy_policy_url": "https://unblockingvr.com/privacy.html?v=2", "developer_terms_of_service_url": null, "publisher_name": "Displaced Bits", "support_website_url": null, "website_url": "https://unblockingvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "567904974897088"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "2201007036766286"}, {"status": "PUBLISHED", "id": "573772321343061"}]}, "baseline_offer": {"id": "2201007036766286"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1685658341, "status": "PUBLISHED", "id": "2201007036766286"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "5462067537255098", "version": "1.0.2"}, "id": "855041548825860", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "5289108477884339", "is_concept": false, "latest_released_binary": {"__