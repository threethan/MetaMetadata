10_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bOgJ04aB5QAQ7kNvgFmlDE3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDJ9CpFzDdUjjs_-HO2ZLEqT6vJMHsNoOM3qf2v7f5RaA&oe=67655FC4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover_Landscape.png", "id": "999586500844262", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86619817_999586507510928_4989718642238371594_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0V2l9NqsS4YQ7kNvgGLrOWi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDRlszgQKUQFKLiuA46bqoMGHvpq0uuzS5FFGlWJY9ZiQ&oe=67655355"}, "display_name": "Unblocking", "keywords": [], "long_description": "Unblocking is a casual VR game based on dragging piece blocks to clear lines/boards.\nIt supports 3 game modes:\n\n- Puzzle (multiple levels to complete by clearing all blocks on the boards)\n- Relax (time based mode which extends its countdown based on the number of lines completed)\n- Arcade (make lines of different colors using all the available pieces before the time runs out in order to avoid the loss of lifes)", "short_description": "Unblocking is a casual VR game based on dragging piece blocks. Players need to use those piece blocks to remove the blocks displayed on boards (unblock) to score and get the highest score possible (king).  \nThe game presents 3 game modes: Puzzle, Relax and Arcade."}]}, "developer_name": null, "developer_privacy_policy_url": "https://unblockingvr.com/privacy.html?v=2", "developer_terms_of_service_url": null, "publisher_name": "Displaced Bits", "support_website_url": null, "website_url": "https://unblockingvr.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}, {"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_M