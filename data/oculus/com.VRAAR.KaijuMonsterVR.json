cdn.com/v/t64.5771-25/39035392_693152655047772_2108233531423139494_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5TJNAMj_de0Q7kNvgFSlH0t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM0kbG58gpm6nJqMridHCGc&oh=00_AYCITmYw7Kt34ngQK-Qxn2xMlMfGlJ8xzeCkrWiiO6v12A&oe=66ED5B76"}, {"file_name": "Untitled-1Artboard-8.png", "id": "2847277212236301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572957_2847277215569634_4501882019301753093_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=942VjmSG75gQ7kNvgGp3pGU&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM0kbG58gpm6nJqMridHCGc&oh=00_AYA0KjOaoZoQBnKn7b6rkVBKFzbWJmg6OKYIMDEnCZNqxw&oe=66ED73A9"}, {"file_name": "Untitled-1Artboard-10.png", "id": "358667762801351", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572936_358667776134683_8498211574584889911_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I5C3qGY-tQkQ7kNvgF36tzP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM0kbG58gpm6nJqMridHCGc&oh=00_AYA2NO4JJcRExOfPw6kn_7G8lfcY70Ngpk1TIprOUKuptg&oe=66ED768D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverVid.png", "id": "916182359387562", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75371507_916182366054228_6307206232331541846_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4uwlmPiPCfoQ7kNvgHGLpEc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM0kbG58gpm6nJqMridHCGc&oh=00_AYB5yxH8tdtIfdRThJemCEmV6HFa71nMODjtGl2n158OFQ&oe=66ED5DFD"}, "display_name": "KAIJU MONSTER VR", "keywords": [], "long_description": "Make yourself at home in one of the five metropolises torn straight out of the 90s\nYou look at them and feel an irrepressible urge to destroy, don't you?\nDo not hesitate any longer, enter the game and do your work of destruction\nBut be careful, people living in them will resist sending more and more military units at you\nKAIJU MONSTER VR FEATURES:\nPhysics - Destroy urban environment based on physics.\nResistance - Fight enemy military units (planes, tanks, rocket turrets, etc.).\nArmament - Shoot laser beams and anti-gravity weapon from your hands.\nReverse card - Pick up and throw enemy units to cause havoc.\nWatch yourself - Manage your energy level and temperature by destroying buildings and water sources (water towers, ice cream trucks, etc.). \nVariety -  Play in five themed cities with three difficulty levels each.", "short_description": "You play as a giant monster whose only desire is destruction.\nConfront enemy units, ravage cities and cause as much destruction as possible."}]}, "developer_name": null, "developer_privacy_policy_url": "https://vraar.pl/privacy_policy/", "developer_terms_of_service_url": null, "publisher_name": "Vraar S.A.", "support_website_url": null, "website_url": "https://vraar.pl/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1613690212364793"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982678_3110206759226632_1908169759045364275_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gfMfSWenaScQ7kNvgG5hW5R&_nc_ht=scontent.oculuscdn.com&_nc_gid=AM0kbG58gpm6nJqMridHCGc&oh=00_AYBuFnIbpSWAL3baVGyERjmj8ziPjzbDrRglMCuIBPrC-Q&oe=66ED44DD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "KAIJU MONSTER VR", "platform": "ANDROID_6DOF", "c