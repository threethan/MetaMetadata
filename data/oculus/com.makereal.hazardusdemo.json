luscdn.com&oh=00_AYD1Gu0BWjQjDvNk-YQW5G9YM6FJtqZl2coaGdPuDieMNg&oe=67163F45"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Hazard Us Screenshots 6.png", "id": "1671348349962172", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38982548_1671348359962171_3410448400815165034_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tMbz54inks0Q7kNvgGgTNN2&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYARZjLQ53hRl27XpTAPWFPRl5CK5WjTeBPf7nuGnMLKOQ&oe=67163F9A"}, "display_name": "Hazard Us ( Demo )", "keywords": [], "long_description": "Gather your friends! Solve puzzles! Dodge traps! Die! A lot! This world is Hazard Us!\n\nIn this quirky, hilarious romp you and your fellow explorers will meet in your home base before heading off through a mystical portal to explore an ancient tomb full of hidden dangers. Work together to solve physics based puzzles. Leap out of the way of dangers. Sip tea and brush up on your British accents!\n\nHazard Us is a cooperative Escape Game with chaotic and silly dangers around every corner. It will challenge players to use their wits, reactions and teamwork to survive. Can you grab the Cursed Idol without losing your lives in the process?!?", "short_description": "Gather your friends! Solve puzzles! Dodge traps! Die! A lot! This world is Hazard Us!\n\nHazard Us is a cooperative Escape Game with chaotic and silly dangers around every corner. It will challenge players to use their wits, reactions and teamwork to survive. Can you grab the Cursed Idol without losing your lives in the process?!?\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://makereal.co.uk/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Make Real Ltd", "support_website_url": null, "website_url": "https://makereal.co.uk/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "26918901644604