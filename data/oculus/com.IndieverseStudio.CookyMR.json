: "6.png", "id": "1236712964349904", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036671_1236712967683237_2718887497966310573_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Oa-fQ-H_01IQ7kNvgEgsQRm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBlq8odqJsA6fWKqL3AmcFpJJ8hSvB6F8ImjMM0y38pVA&oe=676423AA"}, {"file_name": "5.png", "id": "434035262954817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572933_434035266288150_659112195802918355_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7GC716ovUN0Q7kNvgFbKmro&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA0HD_7eO-URZA4CwDK1CVbiJLT-yj9E-ZzYjMj07nf5w&oe=6763EEE5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cooky MR Banner Art (2560x1440).png", "id": "1206811570749903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568684_1206811574083236_555128594483862489_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XbzxZmkt9rkQ7kNvgGxKMWv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTO6BY5Zf689Wa_bGZL6apQSyqrQh9XP3G7Sprb_Mgyg&oe=67641D10"}, "display_name": "CookyMR", "keywords": [], "long_description": "Welcome to Cooky MR, a mixed-reality experience where your room transforms into a bustling takeaway restaurant kitchen! As the owner, you'll set up your virtual space with cool equipment like pizza ovens and juice dispensers. Fulfil orders, earn Cooky coins, compete with nearby restaurants and sabotage competitors to become the best chef in town. Ready to strategize and expand your virtual food empire?\n\nThe game is in the early development phase and we would be truly grateful if you could join our Discord community (https://discord.gg/RvwDbFuhh3) and help us make CookyMR not just good, but great!\n \nYou can also win Discord Nitro for a month. To know more, visit our discord channel (https://discord.gg/RvwDbFuhh3) and checkout #playtest. ", "short_description": "Dive into a thrilling mixed-reality adventure, juggling a bustling takeaway restaurant, sprucing up your virtual kitchen, whipping up delicious orders, earning shiny coins, and sabotaging competing restaurants to become the ultimate culinary tycoon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://indieverse-studio.notion.site/Privacy-Policy-for-CookyMR-ce209a244fcc4369a4712528cc522c4e", "developer_terms_of_service_url": null, "publisher_name": "Indieverse Labs", "support_website_url": null, "website_url": "https://www.indieverse.studio/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26840639675534933"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031470_1161934685046308_1715031666633801946_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GiEngZX-pu0Q7kNvgF3gq0d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0b2fjYpsKGyJhHZafR4sE2cYES-4luj2XPC37_QNVfA&oe=67640CEC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CookyMR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1721289824, "lastRevision": {"nodes": [{"id": "26840639712201596", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application":