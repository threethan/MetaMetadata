ng restaurants to become the ultimate culinary tycoon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://indieverse-studio.notion.site/Privacy-Policy-for-CookyMR-ce209a244fcc4369a4712528cc522c4e", "developer_terms_of_service_url": null, "publisher_name": "Indieverse Labs", "support_website_url": null, "website_url": "https://www.indieverse.studio/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26840639675534933"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031470_1161934685046308_1715031666633801946_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S35G2MprEc8Q7kNvgGOT3J5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQYeKc_5qoV0sLMS745lj4XkTvuP5p7_tykGtrn3DDAQ&oe=672F50EC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "CookyMR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Simulation", "id": "331529188132278"}], "release_date": 1721289824, "lastRevision": {"nodes": [{"id": "26840639712201596", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "26840639652201602", "is_first_party": false, "enables_in_app_ads": false, "is_concept": 