6219_2184847561893647_1716403508271863703_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HcAU8ekbz4oQ7kNvgHnLhq1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA5jfkOi_Fc3Ob33H8W5V06aX5WRkWhKh4KyjwnoKUuSg&oe=670E4C43"}, {"file_name": "6.png", "id": "1236712964349904", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036671_1236712967683237_2718887497966310573_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5_Hlzy8DXTMQ7kNvgHb1-mz&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD5RKsRMmu9BjNJ2oGrK885Ib5fpMD8hfczKgF5r0vwPA&oe=670E39EA"}, {"file_name": "5.png", "id": "434035262954817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572933_434035266288150_659112195802918355_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mrUDdmscyCcQ7kNvgGpcwqz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApK0v2qQA8rC27mMc5X2skqPOfx6cYtTNys8XiDBDMiA&oe=670E3D65"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cooky MR Banner Art (2560x1440).png", "id": "1206811570749903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568684_1206811574083236_555128594483862489_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vu0P65etrAMQ7kNvgHNJBs5&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAlJ2C-1KHTpPYe4pRzaYsA-j6ozHxKO_e0RpPif-BvDw&oe=670E6B90"}, "display_name": "CookyMR", "keywords": [], "long_description": "Welcome to Cooky MR, a mixed-reality experience where your room transforms into a bustling takeaway restaurant kitchen! As the owner, you'll set up your virtual space with cool equipment like pizza ovens and juice dispensers. Fulfil orders, earn Cooky coins, compete with nearby restaurants and sabotage competitors to become the best chef in town. Ready to strategize and expand your virtual food empire?\n\nThe game is in the early development phase and we would be truly grateful if you could join our Discord community (https://discord.gg/RvwDbFuhh3) and help us make CookyMR not just good, but great!\n \nYou can also win Discord Nitro for a month. To know more, visit our discord channel (https://discord.gg/RvwDbFuhh3) and checkout #playtest. ", "short_description": "Dive into a thrilling mixed-reality adventure, juggling a bustling takeaway restaurant, sprucing up your virtual kitchen, whipping up delicious orders, earning shiny coins, and sabotaging competing restaurants to become the ultimate culinary tycoon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://indieverse-studio.notion.site/Privacy-Policy-for-CookyMR-ce209a244fcc4369a4712528cc522c4e", "developer_terms_of_service_url": null, "publisher_name": "Indieverse Labs", "support_website_url": null, "website_url": "https://www.indieverse.studio/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "394813081514456"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26840639675534933"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "765153085692514"}]}, "baseline_offer": {"id": "765153085692514"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721289824, "status": "PUBLISHED", "id": "765153085692514"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27186487760950121", "version": "0.4"}, "id": "1182739573037131", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "prima