itro for a month. To know more, visit our discord channel (https://discord.gg/RvwDbFuhh3) and checkout #playtest. ", "short_description": "Dive into a thrilling mixed-reality adventure, juggling a bustling takeaway restaurant, sprucing up your virtual kitchen, whipping up delicious orders, earning shiny coins, and sabotaging competing restaurants to become the ultimate culinary tycoon!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://indieverse-studio.notion.site/Privacy-Policy-for-CookyMR-ce209a244fcc4369a4712528cc522c4e", "developer_terms_of_service_url": null, "publisher_name": "Indieverse Labs", "support_website_url": null, "website_url": "https://www.indieverse.studio/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "26840639675534933"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "765153085692514"}]}, "baseline_offer": {"id": "765153085692514"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1721289824, "status": "PUBLISHED", "id": "765153085692514"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "27186487760950121", "version": "0.4"}, "id": "1182739573037131", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinar