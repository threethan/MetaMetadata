6674624272", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75330721_1558536677957605_1060253767776290790_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ehHKIxIu8GoQ7kNvgGIb2Al&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOiPbuBFQ7lS-YF4N8RPg0Z2D_xyUgxn7d-GlIezFoEQ&oe=672F3FB6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover-landscape2560x1440.png", "id": "7903373243039338", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974552_7903373246372671_146632390350675800_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gXVnjf05dKUQ7kNvgEvDyEl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYArhJCR_XaI_ZjSiTtX9kH1iLyRCyoTD3tH8gNFNi5N8w&oe=672F5333"}, "display_name": "StellarX", "keywords": ["Tool", "Productivity", "Collaboration", "Education", "Creativity"], "long_description": "StellarX is the best way to create virtual and mixed reality interactive experiences without a single line of code. Build your own immersive Space for training, design testing, or just for fun-- the uses are boundless. StellarX is intuitive, so create freely and our UI will support you.\n\nShare your Space and collaborate in real-time. Your Space users can use any of the Meta Quest headsets, or join in from their desktop. \n\nHere are some other things you might like: \n\n\u2022 Build scenarios with our assets or import your own 3D models and media from places like SketchFab, Blender, and more easily into your StellarX Asset Hub web portal and instantly use them within StellarX\n\u2022 Easily create dynamic scenarios in your Space that change based on a user\u2019s actions\n\u2022 Bring your virtual scenarios to the real-world with StellarX\u2019s Mixed Reality features\n\u2022 Add Sound, Teleport Points, and use the Avatar Recorder to unlock full spatial immersion\n\n", "short_description": "StellarX is the best way to create virtual and mixed reality interactive experiences without a single line of code. Build your own immersive Space for training, design testing, or just for fun-- the uses are boundless. StellarX is intuitive, so create freely and our UI will support you.\n\nShare your Space and collaborate in real-time. Your Space users can use any of the Meta Quest headsets, or join in from their desktop. "}]}, "developer_name": "OVA inc.", "developer_privacy_policy_url": "https://www.stellarx.ai/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "OVA inc.", "support_website_url": "https://help.ova.ai/", "website_url": "https://stellarx.ai/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1725996564472128"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PRODUCTIVITY", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "26867256172889284"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_1595182961260754_3790030889606148706_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l4z6xlPAa-AQ7kNvgEyWZtH&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCU5a5HNOWBd8e81fu1xPqeaKLC3TsAhvJdBpI-pHuh3w&oe=672F5BFE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "StellarX", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "World Creation", "id": "1725996564472128"}], "release_date": 1682614800, "lastRevision": {"nodes": [{"id": "8132958700