eresting puzzles\n- Characters in Egyptian mythology\n- Range of weapons for combat\n- Three acts set in different worlds! "}]}, "developer_name": null, "developer_privacy_policy_url": "https://bugbystudios.com/privacy.html", "developer_terms_of_service_url": "https://bugbystudios.com/terms.html", "publisher_name": "BUGBY STUDIOS LLP", "support_website_url": null, "website_url": "https://bugbystudios.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27498999916411632"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974446_902405328496719_7758797096360440716_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vgBy8vUHcEsQ7kNvgGBgvH-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDaYp5-aK1Jx_fI5Z7mZQXTOwNS2xpT0Paw1eHJtPEvOQ&oe=675972DE"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Unknown Lands", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name": "Adventure", "id": "2691890164460465"}], "release_date": 1716305280, "lastRevision": {"nodes": [{"id": "24942418685403114", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {