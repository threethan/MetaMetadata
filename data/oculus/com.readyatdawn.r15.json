dn.com&oh=00_AYDp-_eCz9I0qq6eY4jZv787NQ60SJyJj1B201n8CAnF9g&oe=673C8493"}, {"file_name": "R5Xpgm.png", "id": "2886564201462505", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75356795_2886564208129171_5789537115243020288_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S1DTYdSubZAQ7kNvgGEqNK9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAeH-fzY15iTJiZfAyA6onItj47eZZlDt4C4PIV1hkSlA&oe=673C94B6"}, {"file_name": "echo_vr_quest_screenshot_02.png", "id": "2881206595463338", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75299164_2881206598796671_2671293087391543884_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AaG3LZe6Kl0Q7kNvgFqtMlw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAs3GofExj6I2iAtB_o_OHg5Ps5ynzXNcfD3JanOslBUA&oe=673C7015"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "echo_vr_F2P_store_cover_art_landscape_2560x1440.png", "id": "1347122086136777", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003235_1347122089470110_637273835345929250_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EVnD97wREZgQ7kNvgHklLgU&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBjgTESDpYfYky8yzxRkA48Mmm2A98b3UX4ThLkfeEMA&oe=673C7DDF"}, "display_name": "Echo VR", "keywords": ["Free", "Multiplayer", "Sports", "Social", "Games"], "long_description": "After almost six years of zero-G competitive action, Ready At Dawn will cease operations of Echo VR on August 1st, 2023 - 10:00 AM Pacific. The time has come for the studio to focus on new projects, which we look forward to sharing in the future. \n\nIt has been our pleasure to see this community grow, compete, and bring so much passion to the game over the years. Thank you. More information: https://medium.com/@EchoGames/an-update-on-the-future-of-echo-vr-7f074dca1ed1\n\nWant to meet and talk to other fans and the developers directly or form your own esports team?  Head to the Echo Games community-run Discord channel: https://discord.com/invite/vXbazs5\n\nEcho VR also features cross-play between Quest and Rift.\n\nPlease note that Echo VR requires Oculus runtime version 16 or greater.", "short_description": "After almost six years of zero-G competitive action, Ready At Dawn will cease operations of Echo VR on August 1st, 2023 - 10:00 AM Pacific. The time has come for the studio to focus on new projects, which we look forward to sharing in the future. \n\nIt has been our pleasure to see this community grow, compete, and bring so much passion to the game over the years. Thank you. More information: https://medium.com/@EchoGames/an-update-on-the-future-of-echo-vr-7f074dca1ed1"}]}, "developer_name": "Ready At Dawn", "developer_privacy_policy_url": "http://www.readyatdawn.com/privacy-policy", "developer_terms_of_service_url": "http://www.readyatdawn.com/terms-conditions", "publisher_name": "Oculus Studios", "support_website_url": "https://support.readyatdawn.com/hc/en-us", "website_url": "https://www.oculus.com/echo-vr/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "SOCIAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "2781999365268237"}, "review_messages": ["Approving!"]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974491_572854258225162_1542212651903290156_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dvJZzzI5lb8Q7kNvgG-BlNx&_nc_zt=3&_nc_ht=scontent-iad