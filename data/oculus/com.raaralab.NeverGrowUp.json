d. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.krakxr.co/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "RAARAlab", "support_website_url": null, "website_url": "https://www.krakxr.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "23928352013478270"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982509_3292805371016572_2824227852296364782_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IIuZtDK9THEQ7kNvgEPTOzo&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBqb0YveSuqNoO6P0PA45ZDbFL1x4zII39w_d4KInYSIA&oe=67580EEC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Never Grow Up", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1722006349, "lastRevision": {"nodes": [{"id": "8602176059855781", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "8602175973189123", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "856101618831704"}, "iarc_email": null, "msrp": null, "translations": {"node