 score low in this weird, artsy brawler. Play nice, and maybe you will make a new friend. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.krakxr.co/privacypolicy", "developer_terms_of_service_url": null, "publisher_name": "RAARAlab", "support_website_url": null, "website_url": "https://www.krakxr.co/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "23928352013478270"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2794352434036119"}]}, "baseline_offer": {"id": "2794352434036119"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1722006349, "status": "PUBLISHED", "id": "2794352434036119"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25017663627880431", "version": "1.84"}, "id": "921375312209980", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "8602175973189123", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "25017663627880431"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "921375312209980"}]}, "change_log": null, "created_date": 1711805397, "id": "2501766362