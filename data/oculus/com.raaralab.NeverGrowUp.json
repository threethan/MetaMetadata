52834_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ta5FiI4jZTIQ7kNvgECdpmE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYABe4GpPp_Qoe9feXtHZgGMg9C8WOaov_fd5Vsx-ezpaw&oe=67066000"}, {"file_name": "NGU_screenshot_L1_2560_32b.png", "id": "732145675199556", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982570_732145678532889_2577805792418955577_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mlzz_QQje-wQ7kNvgGLUL7f&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdBaKJ8R4mVOKOnU89tLHOEOGQ2thofTDSXZclo4wesA&oe=67065BFE"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "coverimage-trailer-laurels-32bit.png", "id": "739937187631178", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57569471_739937190964511_4106518476436590547_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bb_udMvwKu0Q7kNvgEP9wYC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDacdeclwI6pSkHBiWhlcSFCSDcxz0YgG_2BRsO14gm1Q&oe=67066A75"}, "display_name": "Never Grow Up", "keywords": [], "long_description": "Do you remember your favourite games you liked to play as a kid?  Never Grow Up lets you re-discover childhood play through a series of 7 mini-games -- but not alone! A goofy \u201cminion\u201d demands you play with it, too. This little troublemaker will be your companion, antagonist, nemesis and plaything. Time is limited as the ice cream monster's slime invades the scene while you figure out how to play together. In this game, a high score means a big loss. Learn more about the meaning of the ace score in between the mini-games. ", "short_description": "Make peace with your raging inner child. Play with your new frenemy in seven rounds of childish games while an ill-tempered ice cream monster melts all over your charmingly gross playpen. Keep your frenemy's ace score low in this weird, artsy brawler. Play nice, and maybe you will make a new friend. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.krakxr.co/privacypolicy", "developer_te