=idhdjJDSp8YQ7kNvgFBH1tY&_nc_ht=scontent.oculuscdn.com&_nc_gid=AosCfgyJwdCD1Lnk_Lpb3vo&oh=00_AYBAhDWMoaiMzYmVhkqMAUFM3WfybPnjUUdLJ6BToNCIgQ&oe=66F1451E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tumbnail.png", "id": "681720729911680", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641341_681720733245013_4348477775890339095_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fd-kDkLesR4Q7kNvgEdwzHh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AosCfgyJwdCD1Lnk_Lpb3vo&oh=00_AYA6sGc08vKsDB58MCZ3HF6rzIC0bfvytBeSn-r3MQa_5Q&oe=66F13B09"}, "display_name": "VR Blast", "keywords": [], "long_description": "\u26a1Lock N\u2019 Load!\u26a1\nVR Blast is an incredible roguelite arcade shooter that takes you into a unique world where you blast Blocks with awesome weapons!\ud83d\udd2b\nDive into the arcade with immersive graphics, gameplay, and music - sitting or standing, VR Blast will blow your mind! Find the perfect match, trigger explosions and eliminate Shielded Blocks to avoid overloading the Board - or it\u2019s game over!\ud83d\udd79\ufe0f Unlock upgrades and choose the ultimate powerups to reach the furthest level possible!\n\ud83d\ude80The arcade is waiting - let\u2019s blast!\ud83d\ude80\n\n\ud83c\udfb6ORIGINAL MUSIC\nA plethora of incredible original music composed by amazing artists for the best Block-busting experience!\n\n\ud83c\udfb2POWERUPS GALORE\nVariety of powerups to unlock and choose from, making each run different and unique!\n\n\ud83d\udd2bAWESOME WEAPONS\nIncredible unique weapons to unlock and choose from!\n\n\ud83e\udde9WHOLE LOTTA BLOCKS\nTons of special useful and harmful Block types that will make every level feel new!", "short_description": "\u26a1Lock N\u2019 Load!\u26a1\nVR Blast is an incredible roguelike arcade shooter that takes you into a unique world where you blast Blocks with a variety of awesome weapons!\ud83d\udd2b Dive into The Arcade with immersive graphics, gameplay, and music- sitting or standing, VR Blast will blow your mind! \ud83d\udd79\ufe0f \nFind the perfect match, trigger satisfying explosions, eliminate shielded Blocks and choose the ultimate powerups to avoid overloading the board - or it\u2019s game over! \ud83c\udfae\u274c\n\ud83d\ude80The Arcade is waiting - let\u2019s blast!\ud83d\ude80"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.inperson.io/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "inperson", "support_website_url": null, "website_url": "https://www.inperson.io/vrblast", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "872481217215569"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404387_3088008264775110_2995504772146601424_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wjLGMnZnKXIQ7kNvgEvDZF6&_nc_ht=scontent.oculuscdn.com&_nc_gid=AosCfgyJwdCD1Lnk_Lpb3vo&oh=00_AYAlxmkqKBDacjAkbPx-Cjv2NZvP7Ntk0wT7q40tGDH8QQ&oe=66F1660D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Blast", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Action", "id": "45978150496848