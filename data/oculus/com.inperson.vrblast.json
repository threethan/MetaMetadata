, "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75207238_545404223488445_8172260993523166885_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7_Rt0rYuuIQ7kNvgFiNYEe&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYCj6vHyOfKCinut2E9IRmgaVNLbyOZfoVgrNPZo9x_o1g&oe=66EC2B23"}]}, "id": "6248130691897684", "locale": "en_US", "screenshots": [{"file_name": "PScreen5.png", "id": "386705252908770", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75367594_386705259575436_6858802487304339607_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fQxZkBv_ksUQ7kNvgHPyj9H&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYBoZMuHKWyDxor9obPHjsCv6Sen20XD9pVKNJ6eQBDoSA&oe=66EBFB22"}, {"file_name": "Pscreen2.png", "id": "262487086081941", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75210389_262487089415274_129632542270175836_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T5xiDYBrJLsQ7kNvgFzPNoO&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYD30YAbZqnsvkASKVRxo9Al2R0dAKyohO7hmjtWz57XLQ&oe=66EC0851"}, {"file_name": "PScreen3.png", "id": "997626697843382", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031387_997626704510048_9056159485069973244_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z3heUxoY6Y8Q7kNvgFLs08d&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYBNg8u3m9JYaMZxKDdCaSeUa__y6kWAnHcbU4hByyqLMA&oe=66EC28C6"}, {"file_name": "Pscreen1.png", "id": "498911371949854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75556792_498911378616520_3402432354417979040_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uUS0iQy4ddkQ7kNvgF13cSx&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYAMsQiyret8K0gvnV3Y5wSE7gBrzA1AmUMtyT8mQ44DuQ&oe=66EC26E0"}, {"file_name": "PScreen4.png", "id": "283275040667626", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75462964_283275044000959_6989615064382068054_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_aid=0&_nc_ohc=C8vYmSd4as8Q7kNvgF8QzE2&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYCGswc1d8Fmy7Fuf_D1O-LtKL880mlpr9ExGu6S8eCQUg&oe=66EBFF1E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Tumbnail.png", "id": "681720729911680", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75641341_681720733245013_4348477775890339095_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F0iH5FPLqpcQ7kNvgFe1FZ-&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYAYKcEGmYfaRfni2o6zlFoJJSuEkbPJuw19BAYLskc4_A&oe=66EBF509"}, "display_name": "VR Blast", "keywords": [], "long_description": "\u26a1Lock N\u2019 Load!\u26a1\nVR Blast is an incredible roguelite arcade shooter that takes you into a unique world where you blast Blocks with awesome weapons!\ud83d\udd2b\nDive into the arcade with immersive graphics, gameplay, and music - sitting or standing, VR Blast will blow your mind! Find the perfect match, trigger explosions and eliminate Shielded Blocks to avoid overloading the Board - or it\u2019s game over!\ud83d\udd79\ufe0f Unlock upgrades and choose the ultimate powerups to reach the furthest level possible!\n\ud83d\ude80The arcade is waiting - let\u2019s blast!\ud83d\ude80\n\n\ud83c\udfb6ORIGINAL MUSIC\nA plethora of incredible original music composed by amazing artists for the best Block-busting experience!\n\n\ud83c\udfb2POWERUPS GALORE\nVariety of powerups to unlock and choose from, making each run different and unique!\n\n\ud83d\udd2bAWESOME WEAPONS\nIncredible unique weapons to unlock and choose from!\n\n\ud83e\udde9WHOLE LOTTA BLOCKS\nTons of special useful and harmful Block types that will make every level feel new!", "short_description": "\u26a1Lock N\u2019 Load!\u26a1\nVR Blast is an incredible roguelike arcade shooter that takes you into a unique world where you blast Blocks with a variety of awesome weapons!\ud83d\udd2b Dive into The Arcade with immersive graphics, gameplay, and music- sitting or standing, VR Blast will blow your mind! \ud83d\udd79\ufe0f \nFind the perfect match, trigger satisfying explosions, eliminate shielded Blocks and choose the ultimate powerups to avoid overloading the board - or it\u2019s game over! \ud83c\udfae\u274c\n\ud83d\ude80The Arcade is waiting - let\u2019s blast!\ud83d\ude80"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.inperson.io/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "inperson", "support_website_url": null, "website_url": "https://www.inperson.io/vrblast", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "939033889924114"}, {"id": "459781504968480"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "CASUAL", "MUSIC"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "872481217215569"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75404387_3088008264775110_2995504772146601424_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_hNOqGv95lEQ7kNvgGqxe0Z&_nc_ht=scontent.oculuscdn.com&_nc_gid=An4IV7yLJ5-K8k4WKjKdUHY&oh=00_AYBdSsIc7-qWjPEihUf4bMPdPLkvP46a_IPOqN7cewY3jQ&oe=66EC200D"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VR Blast", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Music & Rhythm", "id": "939033889924114"}, {"topic_name": "Action", "id": "45978150496848