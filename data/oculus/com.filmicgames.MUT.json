77_1300537893992390_8529547455366557532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Vdu7HDaAOhsQ7kNvgHS9id0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCs_E67MoWg1Usx7XJSm_mbqqFUXMOwuRNLsrxUrifhzw&oe=6749BF4C"}, {"file_name": "MutantBoxingLeague-031.png", "id": "253587871073402", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982609_253587874406735_7178836111610468479_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YCWDxAgj1J4Q7kNvgEjXEQp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDicfX6jZT0hM2Wts8lIkWYJzjNwJyhhDv0sZzbZlVP2Q&oe=6749A2C2"}, {"file_name": "MutantBoxingLeague-03.png", "id": "803737228109369", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035321_803737231442702_8964584080987227603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uPz25YdQxOIQ7kNvgG8hTDI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAlcfncVKTrpbZf6B-VdWI4wr4ex6_Kg6b9-hQmt9Zgfg&oe=67498D32"}, {"file_name": "MutantBoxingLeague-04.png", "id": "294515520233523", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75639798_294515523566856_4775055710151128191_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YtTMKreiStEQ7kNvgH3IdIG&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYByrlx70TdhgM2oZFDMllZ3Dq4HJyBxGSpMuZ1G03Ed7g&oe=6749A9BD"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-cover.png", "id": "348786024450996", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036670_348786027784329_8943992481801574654_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=voz5EeS1HDoQ7kNvgGgOgmu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC76X1Y7WdFLFxjSwjCG-nj1isbLkC1LaoRswmeY3wMbg&oe=6749908E"}, "display_name": "Mutant Boxing League", "keywords": [], "long_description": "Make your daily workout into something fun!\n\n- Fight different boxers, each with their own unique boxing style and abilities.\n- Progress through the matches to unlock and explore new opponents, environments and gloves.\n- Learn how to effectively utilize special gloves like the power glove and speed glove.\n- Play with family or friends and beat personal highscores.\n\nTraining is something you could really enjoy while playing this game. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will also learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked, you need to complete different mini-games in time to be able to continue the fight.\n\nNow, let's play and become an unstoppable boxing champion!", "short_description": "Box against fantasy creatures in nice outdoor environments. Exercise while having as fun! Mutant Boxing League is like playing an boxing arcade game while exercising!"}]}, "developer_name": "Filmic Studios", "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_service_url": null, "publisher_name": "Filmic Studios", "support_website_url": null, "website_url": "https://filmicstudios.se/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "636204241946284"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PUBLISHED", "id": "355020867681591"}, {"status": "PUBLISHED", "id": "869132048460971"}, {"status": "PUBLISHED", "id": "1082557849663749"}, {"status"