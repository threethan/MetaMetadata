smFW-_I6sumd-RaJg&oe=66F3EBBB"}, {"file_name": "MutantBoxingLeague-021.png", "id": "1300537890659057", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568677_1300537893992390_8529547455366557532_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=297qA6JoE94Q7kNvgEVqFyW&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALKS1SOwsnjjFXllB9ASnYV&oh=00_AYAKK66OBAxtBWNv63g8nm02ictw3h9W0giHOgGh6SrSxg&oe=66F40DCC"}, {"file_name": "MutantBoxingLeague-031.png", "id": "253587871073402", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982609_253587874406735_7178836111610468479_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mJWmLFKdEH8Q7kNvgFR7nxJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALKS1SOwsnjjFXllB9ASnYV&oh=00_AYAk_eCxMtpgYHjufY7vS7E7w-Cp1cHCvdI34-e0rT2XfQ&oe=66F3F142"}, {"file_name": "MutantBoxingLeague-03.png", "id": "803737228109369", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035321_803737231442702_8964584080987227603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eEJ8JNsKQzwQ7kNvgE3VtwF&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALKS1SOwsnjjFXllB9ASnYV&oh=00_AYBGaEDscySkxmDkvKWGp1221KMhnZlHtD6lLxzOvJhU9g&oe=66F3DBB2"}, {"file_name": "MutantBoxingLeague-04.png", "id": "294515520233523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75639798_294515523566856_4775055710151128191_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F1skckgW2P0Q7kNvgGFroO8&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALKS1SOwsnjjFXllB9ASnYV&oh=00_AYBZq_9tZ3-9wng-9DWxNNrck5njOMFLpxVbQ8jmwSfNwg&oe=66F3F83D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-cover.png", "id": "348786024450996", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036670_348786027784329_8943992481801574654_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZKFhE015LAQ7kNvgEXTxWg&_nc_ht=scontent.oculuscdn.com&_nc_gid=ALKS1SOwsnjjFXllB9ASnYV&oh=00_AYCZuEoUu8mkVw6AZ3KwdW3iivv0nBorqBnJcHnUH_l95A&oe=66F3DF0E"}, "display_name": "Mutant Boxing League", "keywords": [], "long_description": "Make your daily workout into something fun!\n\n- Fight different boxers, each with their own unique boxing style and abilities.\n- Progress through the matches to unlock and explore new opponents, environments and gloves.\n- Learn how to effectively utilize special gloves like the power glove and speed glove.\n- Play with family or friends and beat personal highscores.\n\nTraining is something you could really enjoy while playing this game. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will also learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked, you need to complete different mini-games in time to be able to continue the fight.\n\nNow, let's play and become an unstoppable boxing champion!", "short_description": "Box against fantasy creatures in nice outdoor environments. Exercise while having as fun! Mutant Boxing League is like playing an boxing arcade game while exercising!"}]}, "developer_name": "Filmic Studios", "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_service_url": null, "publisher_name": "Filmic Studios", "support_website_url": null, "website_url": "https://filmicstudios.se/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGL