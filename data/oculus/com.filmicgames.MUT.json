01.png", "id": "201031789722147", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974692_201031793055480_7909991526784956407_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VWGPob4j7VQQ7kNvgE2Oqr5&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA3DL1WgwV8qWk_fRrlC9w1dDK0hDFqH3IIQC0LRLb7XQ&oe=670E4B17"}]}, "id": "803138058658021", "locale": "en_US", "screenshots": [{"file_name": "MUT_MixedReality_v03.png", "id": "1034325991644540", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196228_1034325994977873_8857528486086216701_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R5DbVBwANSAQ7kNvgFN6sku&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBRP1sW8BgY6VLMEvonzDM_6kOyU8XwiJcJZSawf2q_2Q&oe=670E3CE6"}, {"file_name": "MUT-screenshots_0007_Layer-0.png", "id": "1403611273863011", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75422371_1403611277196344_3442382668598893127_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VGA-ptkFA0QQ7kNvgGGkeZC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAnankt6zv_oaRaez6HeMEMQ1QdxJ9U7RrtQZmCuuOm6g&oe=670E536B"}, {"file_name": "MUT-screenshots_0003_Layer-5.png", "id": "1355168329217380", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003240_1355168332550713_4865820336372095908_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pFy-zjUudVgQ7kNvgFJ-1h2&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC_4QQ5v434U4jGT_InjD_cgjElSxRco1DvN3m9byohXg&oe=670E3A85"}, {"file_name": "MUT-screenshots_0005_Layer-2.png", "id": "772068054815910", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031620_772068058149243_6797316192420197363_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=trF9h2xgRxMQ7kNvgGnLWaC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYANb5qBbKMokla6bqlnSAXwkUBV8ykaZ0gUTh0_07noYg&oe=670E6236"}, {"file_name": "MUT-screenshots_0006_Layer-1.png", "id": "2615536645274227", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974482_2615536648607560_6052236317170598783_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E_nRD8sfML4Q7kNvgFOio5Q&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAFkcqdDXvsGgaZjMHjWmnHEafuvRQdryaYNr32bEnW4g&oe=670E41F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Promotiontest-2.png", "id": "463471329898859", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982510_463471333232192_8427622215650267924_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MllBrsYEZ2gQ7kNvgGUh_We&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD4JdB0DrtEHWk16jcKqBqq_QXUgQRoBClI2sO6WY1QqA&oe=670E554D"}, "display_name": "Mutant Boxing League", "keywords": ["boxing", "fighting", "exercise", "train", "workout"], "long_description": "Inject some fun into your daily workout and dominate as a boxing champion!\n\n* Experience the latest update with Mixed Reality boxing mode, allowing you to train in even the smallest spaces.\n* Fight different boxers, each with their own unique boxing style and abilities.\n* Progress through the matches to unlock and explore new opponents, environments and gloves.\n* Boxing tutorials - learn how to attack and defend.\n* Learn how to effectively utilize special gloves like the power glove and speed glove.\n* Several Minigames to master and compete with Global Highscores.\n* Try Challenges that unlocks unique boxing glove skins.\n* Weekly Challenges to keep you in shape! \n* Hardcore mode for the real experienced boxers.\n\nOur aim is to make training as enjoyable as possible. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked down, complete different mini-games in time, to continue the fight.\n\nDon't wait any longer - step into the ring and unleash your inner warrior. \n\nJoin our Discord!\nhttps://discord.com/invite/k9bCaKbXks\n{1083050756747663}", "short_description": "Spice up your daily workout with some fun and become an unstoppable force in the mutant boxing world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_service_url": null, "publisher_name": "Filmic Studios", "support_website_url": "https://filmicstudios.se/#Contact", "website_url": "https://filmicstudios.se/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7417207228380285"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570307_7054802327945500_8551928990858318411_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vuPCZ1qf6XIQ7kNvgEFhuyC&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCxg5RULbTeI6alTaK2g2sfIY_nvW3IVEBIj_iFc3FZ2g&oe=670E705F"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mutant Boxing League", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1703156400, "lastRevision": {"nodes": [{"id": "5903243303110026", "release_type": "S