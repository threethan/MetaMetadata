36648607560_6052236317170598783_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1xwz_XADusEQ7kNvgE8XBKs&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB1Y-8M_0KIJvM81S8U41TTuFPvQEF5Msnshg_4WkHX-w&oe=6707AA74"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Promotiontest-2.png", "id": "463471329898859", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982510_463471333232192_8427622215650267924_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=48O4Me_wxwgQ7kNvgFvc41V&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDkKKOl3Pj0IXeKoJ-bILRnLtUrUBHjIMjCOhbd97R65w&oe=6707BDCD"}, "display_name": "Mutant Boxing League", "keywords": ["boxing", "fighting", "exercise", "train", "workout"], "long_description": "Inject some fun into your daily workout and dominate as a boxing champion!\n\n* Experience the latest update with Mixed Reality boxing mode, allowing you to train in even the smallest spaces.\n* Fight different boxers, each with their own unique boxing style and abilities.\n* Progress through the matches to unlock and explore new opponents, environments and gloves.\n* Boxing tutorials - learn how to attack and defend.\n* Learn how to effectively utilize special gloves like the power glove and speed glove.\n* Several Minigames to master and compete with Global Highscores.\n* Try Challenges that unlocks unique boxing glove skins.\n* Weekly Challenges to keep you in shape! \n* Hardcore mode for the real experienced boxers.\n\nOur aim is to make training as enjoyable as possible. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked down, complete different mini-games in time, to continue the fight.\n\nDon't wait any longer - step into the ring and unleash your inner warrior. \n\nJoin our Discord!\nhttps://discord.com/invite/k9bCaKbXks\n{1083050756747663}", "short_description": "Spice up your daily workout with some fun and become an unstoppable force in the mutant boxing world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_service_url": null, "publisher_name": "Filmic Studios", "support_website_url": "https://filmicstudios.se/#Contact", "website_url": "https://filmicstudios.se/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7417207228380285"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570307_7054802327945500_8551928990858318411_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=baOa6JKjZuwQ7kNvgEzAS6z&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB278wP8EZux_3NUKoYBnlWQRxvnD2Cz9lUGOAEHXA8_A&oe=6707D8DF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Mutant Boxing League", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}, {"topic_name": "Fighting", "id": "2710427532541308"}, {"topic_name": "Action", "id": "459781504968480"}], "release_date": 1703156400, "lastRevision": {"nodes": [{"id": "5903243303110026", "release_type": "S