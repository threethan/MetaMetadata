4406735_7178836111610468479_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-6GkJh4MNe8Q7kNvgG15RN7&_nc_ht=scontent.oculuscdn.com&oh=00_AYAjeHrnF90ehB_wWFsS3EdWw1r73T6PXgyfGIcPjlHL5w&oe=66D6F042"}, {"file_name": "MutantBoxingLeague-03.png", "id": "803737228109369", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035321_803737231442702_8964584080987227603_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QCcn_ZHHN00Q7kNvgEjpGRd&_nc_ht=scontent.oculuscdn.com&oh=00_AYCJ_xI2xIrt_QGqyu6x1nRxKrY-hZeqFmAFzyQ09uoA1A&oe=66D6DAB2"}, {"file_name": "MutantBoxingLeague-04.png", "id": "294515520233523", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75639798_294515523566856_4775055710151128191_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yv3CTCims5oQ7kNvgH7oOU9&_nc_ht=scontent.oculuscdn.com&oh=00_AYAvIYM0vF3j8xBJANZAeECsPN8T9vkzn5JR3xjE4_gw0g&oe=66D6F73D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Trailer-cover.png", "id": "348786024450996", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036670_348786027784329_8943992481801574654_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cJHuJe3VNZMQ7kNvgFbiKai&_nc_ht=scontent.oculuscdn.com&oh=00_AYCOJ9ZZrQlfncFQQy7v2H4uB2CHZBKYqqJAq8vNNwAruQ&oe=66D6DE0E"}, "display_name": "Mutant Boxing League", "keywords": [], "long_description": "Make your daily workout into something fun!\n\n- Fight different boxers, each with their own unique boxing style and abilities.\n- Progress through the matches to unlock and explore new opponents, environments and gloves.\n- Learn how to effectively utilize special gloves like the power glove and speed glove.\n- Play with family or friends and beat personal highscores.\n\nTraining is something you could really enjoy while playing this game. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will also learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked, you need to complete different mini-games in time to be able to continue the fight.\n\nNow, let's play and become an unstoppable boxing champion!", "short_description": "Box against fantasy creatures in nice outdoor environments. Exercise while having as fun! Mutant Boxing League is like playing an boxing arcade game while exercising!"}]}, "developer_name": "Filmic Studios", "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_service_url": null, "publisher_name": "Filmic Studios", "support_website_url": null, "website_url": "https://filmicstudios.se/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "2710427532541308"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "636204241946284"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "869132048460971"}, {"status": "PUBLISHED", "id": "1082557849663749"}, {"status": "PUBLISHED", "id": "1017869112607772"}]}, "baseline_offer": {"id": "1082557849663749"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "869132048460971"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7461543243946683", "version": "1.0"}, "id": "955599339071504", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"no