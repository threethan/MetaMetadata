909991526784956407_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9hHbMGI2Td4Q7kNvgEHR2GT&_nc_ht=scontent.oculuscdn.com&oh=00_AYBUDtCdIYLbbPJcYPI_c62TH-BDHehJYzSzjah7nJ4Plg&oe=66FFCA97"}]}, "id": "803138058658021", "locale": "en_US", "screenshots": [{"file_name": "MUT_MixedReality_v03.png", "id": "1034325991644540", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75196228_1034325994977873_8857528486086216701_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rs8FceIQ0vkQ7kNvgGFvrUm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAObQUK_sVSsWd6SvYbJ8DAGS26epKsXEDSUie3Mkwa_w&oe=66FFBC66"}, {"file_name": "MUT-screenshots_0007_Layer-0.png", "id": "1403611273863011", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75422371_1403611277196344_3442382668598893127_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JG4Y50HvNhsQ7kNvgGli69u&_nc_ht=scontent.oculuscdn.com&oh=00_AYB02vn3u14o8y4KpxN8uRFzdtSSlu1ULqze6Dnm9wuoWQ&oe=66FFD2EB"}, {"file_name": "MUT-screenshots_0003_Layer-5.png", "id": "1355168329217380", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003240_1355168332550713_4865820336372095908_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SowUsslHh3wQ7kNvgGSX8CJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYBdnIXsnMGVhaQI3GtFZRR4YsY1uDFJNEjMDvsXwrfdpg&oe=66FFBA05"}, {"file_name": "MUT-screenshots_0005_Layer-2.png", "id": "772068054815910", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031620_772068058149243_6797316192420197363_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=F2-oAqqnZFEQ7kNvgE4khum&_nc_ht=scontent.oculuscdn.com&oh=00_AYA4FHGTXYYx-xdfKcYwZXzPaF9yyzQvgcL9wmpfp07PQA&oe=66FFE1B6"}, {"file_name": "MUT-screenshots_0006_Layer-1.png", "id": "2615536645274227", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974482_2615536648607560_6052236317170598783_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rHQMvmDwvKQQ7kNvgGd51iL&_nc_ht=scontent.oculuscdn.com&oh=00_AYBqH9YBK25iQVOXKfmB55TGBBqinlX-RWiTUcOtbg01zg&oe=66FFC174"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Promotiontest-2.png", "id": "463471329898859", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982510_463471333232192_8427622215650267924_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cv_1JRy47boQ7kNvgG4rMC7&_nc_ht=scontent.oculuscdn.com&oh=00_AYCa75AEELn4kQRz9Kh1CemPsOgpiVhUQdXFzyvcbKj0eQ&oe=66FFD4CD"}, "display_name": "Mutant Boxing League", "keywords": ["boxing", "fighting", "exercise", "train", "workout"], "long_description": "Inject some fun into your daily workout and dominate as a boxing champion!\n\n* Experience the latest update with Mixed Reality boxing mode, allowing you to train in even the smallest spaces.\n* Fight different boxers, each with their own unique boxing style and abilities.\n* Progress through the matches to unlock and explore new opponents, environments and gloves.\n* Boxing tutorials - learn how to attack and defend.\n* Learn how to effectively utilize special gloves like the power glove and speed glove.\n* Several Minigames to master and compete with Global Highscores.\n* Try Challenges that unlocks unique boxing glove skins.\n* Weekly Challenges to keep you in shape! \n* Hardcore mode for the real experienced boxers.\n\nOur aim is to make training as enjoyable as possible. With open outdoor environments, different levels and opponents that all have the different abilities and skills, you will learn to be a better boxer. Boxing is not all about attack, but also learn how to block and dodge punches. And when or if you get knocked down, complete different mini-games in time, to continue the fight.\n\nDon't wait any longer - step into the ring and unleash your inner warrior. \n\nJoin our Discord!\nhttps://discord.com/invite/k9bCaKbXks\n{1083050756747663}", "short_description": "Spice up your daily workout with some fun and become an unstoppable force in the mutant boxing world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://filmicstudios.se/privacy", "developer_terms_of_