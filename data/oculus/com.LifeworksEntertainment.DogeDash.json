luscdn.com&oh=00_AYA1ZGQxTs68SYMsjmVuM8qUAfaHYecUYxkhWgTd2vWaww&oe=677D22B4"}, {"file_name": "Screenshot 2023-03-27 123304 (1).png", "id": "2559398800864462", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75485573_2559398804197795_7632348446689205350_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LdYodFS52LMQ7kNvgHfw2MY&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCtFdJXCrZ0PlwVu3bsXDQOrqepA_Rpz5cV2Q8wgOegWw&oe=677D0412"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Screenshot 2023-03-27 100746 (1).png", "id": "1283113655945863", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974715_1283113659279196_2083987246601336658_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X0Bs2ZdRxE4Q7kNvgFbM7BM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAj3J5eKTA04i8r7JTSRmEU3T0HpFqd5BIYIg6kaKLbng&oe=677CFEF9"}, "display_name": "Doggo Dash", "keywords": [], "long_description": "Doggo Dash is an up-and-coming game that focuses on fun and quality. In this game, you get to explore many different maps each with a unique experience and adventure to have with you and your friends! In this multiplayer experience, you run around and play as a cute dog you can dress up and make yourself the most fashionable dog there is, show off your look to other people or chill with your style! Treat yourself to some virtual food and roam with a new virtual pet you choose at the pet shop! play around on the main map! We are devoted to making a fun engaging experience that is frequently getting updated and better. There's only so much you can find in a description hop in and find the experiences and memories that can only be found by trying for yourself!", "short_description": "In this multiplayer experience, you get to roam the world of dogs and feel what it's like to be a doggo yourself! Explore many maps and modes with you and your friends! Dress up however you like, and buy virtual food and pets to enjoy! We want to make your experience better than other similar games we want your experience to be memorable and significantly over others! You can experience the best VR doggo game today if you play now!"}]}, "developer_name": "Lifeworks Entertainment, LLC", "developer_privacy_policy_url": "https://www.lifeworksent.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Lifeworks Entertainment, LLC", "support_website_url": "https://www.lifeworksent.com/help", "website_url": "https://www.lifeworksent.com/home", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1700921480735423"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "CASUAL", "ADVENTURE"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "6310545295701683"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982606_187994563987715_5628913611246512954_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RU_EklqGy8UQ7kNvgHk_9tf&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAGoVC7U7bX0XbCIXkG_b0oUjrYyxq_Yu6Fd_NZNpMumA&oe=677D04B6"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Doggo Dash", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Party Game", "id": "1700921480735423"}], "release_date": 1651179600, "lastRevision": {"nodes": [{"id": "546749580209467", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata