57112319_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FRdYkoILpAwQ7kNvgF2lRnE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBy7LSA1hbeS1q2SBEGXPciMdZHI2LTIsZW00myyH_nlQ&oe=6762B3D9"}, {"file_name": "4.png", "id": "476814113357761", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974444_476814116691094_2722520741253232304_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HBceqDPoVJMQ7kNvgHktq33&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAL9KJKCBqS-1h8FeZA0tOUCii8u7UONBEywgAmcnaOQ&oe=6762BA26"}, {"file_name": "5.png", "id": "591791961703854", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974442_591791965037187_1567443598110120584_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=RF3XvglDhVIQ7kNvgEZqFGu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCvBKo7_onEd6Lekp7AR8w09VRH1RqfAUzv9Z8PHJHMoA&oe=6762A15A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "new artwork3.png", "id": "471767567345164", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974450_471767570678497_728062309251349919_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K9hG6SBQcKEQ7kNvgGMJgX1&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6UjtPnd-YDYbQpDGmdpHbgf2vOTTlCzobBCBaOk0mTw&oe=6762B367"}, "display_name": "Alienation", "keywords": [], "long_description": "Alienation, is an action-packed shooting game combined with sci-fi storytelling inspired by classic sci-fi action movies such as The Matrix, Equilibrium, and Ghost in the Shell. Alienation, puts you in the center of adrenaline rushed cinematic experiences. Each level comes with a different story, music-based gameplay, and a unique design to deliver a synchronized experience.\n- Go all in! Play all episodes back to back without interruptions!\n- Different play modes for different skills! Play harder and put yourself higher on the world leaderboard!\n- Find your very own style in shooting aliens and dodging the bullets! Flow with the rhythm in a music based arcade adventure!\n- Hardcore music! Hard rock, Industrial Electronics and of course Metal!\n- Go after achievements! Finish each episode to Unlock new achievements and new episodes!", "short_description": "Alienation, is an action-packed shooting game combined with sci-fi storytelling inspired by classic sci-fi action movies such as The Matrix, Equilibrium, and Ghost in the Shell. Alienation, puts you in the center of adrenaline rushed cinematic experiences. Each level comes with a different story, music-based gameplay, and a unique design to deliver a synchronized experience."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.51aliens.com/privacy-policy/", "developer_terms_of_service_url": "https://www.51aliens.com/terms-conditions/", "publisher_name": "51 Aliens LLC", "support_website_url": "https://www.51aliens.com/contact-us/", "website_url": "https://www.51Aliens.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "228244852856904"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974684_299159254960956_3949817783405154567_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q8Rbx1QSJnQQ7kNvgEiFVMM&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhcb37U2v2-UVY2O5ALUdWkOVusgZxP-Lh1