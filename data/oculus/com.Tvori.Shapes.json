n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FdvJEZHdwz4Q7kNvgHTNyt6&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCctBR-DuF6C_li5IodMGkEnPRUFuAE5TxJr6AphJrSIw&oe=670F9ED5"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nuroNZOHnkwQ7kNvgGTslm6&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBT-_4jBCCq3WnViPzouWLIZVp4WAomo5H1J7pXNnm1PQ&oe=670FBF68"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a48HtoxrLq4Q7kNvgFt2x3m&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBv-07ldITnWSOi522D2Gzw_MLyUzSrgGORU85f0brinQ&oe=670FC010"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0_jIM6HnnEoQ7kNvgHOhwja&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA9DffCkpKM5qqNyjdY4tGhCuO2lFKd2Sk1PPMuLQsMlA&oe=670FB707"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SiEUlK_FTuwQ7kNvgEDueKV&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDEWTEbEqGluClH2glY13JerB11QPIejytnPFLRAirVBQ&oe=670F8F46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eYwmyUYWnCIQ7kNvgHYrSLu&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBxwP12HS6qZTnptaOtVL1wMiK_NbIIAogYZT8hSzGbHw&oe=670FAE3C"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636653600, "status": "PUBLISHED", "id": "571145954169062"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8144388965690557", "version": "4.0.13.11103"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8144388965690557"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.0.12->4.0.13\n\n**`IMPROVEMENTS`**\n\n- Added a \"Create New Space\" button to the Samples section in the Lobby.\n\n- AR visuals improved.\n\n**`BUG FIXES`**\n\n- Fixed when headset simulation works incorrectly after exiting Play mode.\n\n- Fixed when floor grid is not visible when under the floor.\n\n- Fixed when AR mode does not work in Play mode and after.\n\n- Fixed when AR simulation stops working after toggling Passthrough mode on and off.\n\n- Fixed when paint tool does not apply color to text when pointing at it.\n\n- Fixed when some objects remain visible or invisible with AR mode enabled.\n\n- Fixed when some objects in onboarding retain the last used material or opacity.\n\n- Fixed when X-Y rotations for viewpoints' head work only once.\n\n- MR previews (blue) are now available for spaces and holonotes.\n\n- Show Sign-Up window immediately when landing in the Lobby for the first time after the tutorial.\n\n- Enlarged the Skip button for interactive onboarding.\n\n- Added Jeremy's avatar for welcoming in the interactive onboarding.\n\n- TYPO corrected in \"Zooming outdoor\" copy in the interactive onboarding.\n\n- Various typos corrected in the interactive onboarding.\n\n- Added analytics for copy/paste operations between spaces.\n\n- Fixed when \u0438readcrumbs are missing in the Library when onboarding is skipped.\n\n- Exception during onboarding for left-handed users fixed\n\n- Fixed when old images are shown in video hints right before the video loads in the interactive onboarding.", "created_date": 1727959825, "id": "8144388965690557", "version": "4.0.13.11103", "version_code": 11103, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8144388965690557"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727956488, "id": "8143899625739491", "version": "4.0.13.11002", "version_code": 11002, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinar