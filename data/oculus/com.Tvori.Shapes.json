=5ByelOjuGUQQ7kNvgFc6wJ6&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC02ZDYgY0ZaQiBcO_dk9CGVPNVtS3KniRXSUbXTP7phw&oe=67557E55"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UhbiN3vV0BQQ7kNvgHEmaPH&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQ6Bi05Oz6oj5H_YjdzAErdQIK3gBf8N1UO6UE7S8CXQ&oe=67559EE8"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SycEGidS180Q7kNvgH9r0tW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCMPOnqFymqvYPPQGxb1D3CjNCmWoM1Mu1R9dW3zTRFJA&oe=67559F90"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EUkEmX5PgqsQ7kNvgFJtAO5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDPwPA6MCFQv0xRy-1eeR7lRchC8_B-q-N-c1CgZrHvuw&oe=67559687"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fImf_EsaxI4Q7kNvgGpBy-R&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCyMGx3jt1F8G6P3LkDUIZKtnxJ9XFc973Yna_DX5O-TA&oe=67556EC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gGFlJwamNp8Q7kNvgGGIBvz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDTbmkUD5CVwLcNd2KMFyXBIGpD-yY87ddLCk7MdNjtTQ&oe=67558DBC"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "2034377863730095"}, {"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "2034377863730095"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8525467027582747", "version": "4.19.0.12494"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8525467027582747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733240096, "id": "8526508410811942", "version": "4.19.0.12506", "version_code": 12506, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8525467027582747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733235376, "id": "8526174957511954", "version": "4.19.0.12502", "version_code": 12502, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8525467027582747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.0.18->4.19.0\n\n**`FEATURES`**\n\n-  Scene switcher UI was returned.\n\n-  Implemented a progress indicator.\n\n**`IMPROVEMENTS`**\n\n-  Resurrected Pico platform functionality.\n\n-  \"Show avatars\" is now OFF by default.\n\n-  Refactored scene systems to prepare for migration to state-based scenes.\n\n-  Polished Figma view for improved usability.\n\n-  Improved Bindings Updater to address issues with object offsets during controller movement.\n\n-  Supported scene changes using the new Scenes Menu on the controller during object grabbing or Gizmo use.\n\n**`BUG FIXES`**\n\n- Fixed exception and freeze when adding stages with objects to a collaborative session without an internet \nconnection.\n\n- Menu no longer jumps when the user moves using teleport.\n\n- Exception fixed while grabbing certain objects\n\n- Interactions no longer stay in the background when the object is transferred to the scene.\n\n- Fixed exception after pausing\n\n- Move button in import preview is no longer available after the trial ends.\n\n- Spaces now open in the correct mode instead of always defaulting to MR mode.\n\n- Fixed incorrect scene indexing on the controller in Play mode.\n\n- Commenters and viewers can no longer change space names.\n\n- Interactions are no longer duplicated when duplicating or copy-pasting a scene.\n\n- Group bounds are no longer shown during interactivity scene previews.\n\n- Scene numbers are now synced correctly in Same Page mode between versions 18 and 19.\n\n- Scene numbers are now synced on interactivity cards.\n\n- Fixed issue where controllers appeared \"empty\" when pointing at objects with interactivity in Play mode.\n\n- Hover effect now works for viewers and commenters in Play mode.\n\n- Background notification now displays when changing spaces.\n\n- Viewpoints are now correctly handled as part of scenes and the background.\n\n- Added pop-up explaining why the Paste button is inactive for free users in the selection menu.\n\n- Trial notifications now display correctly for Pro and Community Pro plans.\n\n- Fixed \"VIEW-ONLY\" message always appearing.\n\n- Resolved pop-up overlapping issues.\n\n- Added notifications about the 14-day trial in workspaces.\n\n- Objects beyond the workspace boundary can no longer be grabbed.\n\n- Undo/Redo functionality is now blocked after permission changes.\n\n- Trial notifications now correctly display for Team plans when storage is full.\n\n- Resolved overlap issues between plan and view pop-ups.\n\n- Fixed when Camera tool label  is active in the Toolswitcher.\n\n- Corrected text for free users when attempting to create a new space.\n\n- Avatar visibility now updates dynamically during presentations.\n\n- Trial notifications now correctly appear in the Share panel for Enterprise plans.\n\n- Paid plans can now add more than 10 scenes.\n\n- Participants can now see the presenter\u2019s avatar.\n\n- Fixed missing trial notifications in workspaces.\n\n- Education users can now see the Projects tab in the app.\n\n- Fixed outline display for the current scene.", "created_date": 1733225130, "id": "8525467027582747", "version": "4.19.0.12494", "version_code": 12494, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8525467027582747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733164138, "id": "8521896264606490", "version": "4.19.0.12489", "version_code": 12489, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8525467027582747"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1733155597, "id": "8521354087994041", "version": "4.19.0.12486", "version_code": 12486, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}