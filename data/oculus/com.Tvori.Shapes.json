ges_2.png", "id": "1200521743765444", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036672_1200521747098777_3607383089734677798_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ax2r96kF340Q7kNvgEeEevM&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYBdD0-X91ipjMX9X5vMMTFbSgRSakKG0Em3bk-34aaKeA&oe=66F540D5"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mZa6SzLw4-4Q7kNvgFbxdvu&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYD0F2Y8hPkAmirlh7alEYZX3-mC0ibso2g0qwiIvsETKw&oe=66F56168"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HLLZR4IG0HQQ7kNvgGJXT6x&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYC1fv7VXcSJ1J59mXo1S7JZj03C4c_bB3lESx3GFBYA8w&oe=66F56210"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YHhGNwo1DEsQ7kNvgGZyxAU&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYC4TT9o-AYEbs8YQ0NlAZZ4csdZorARhzZun6Pez1Kzmw&oe=66F55907"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bKtsgffbuz4Q7kNvgEVwpwr&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYCCLkrNN3dcBTTZy-Kvv968Rv48o_Eh2TlNYIDj7kSDrA&oe=66F53146"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IUBx0h-YzzAQ7kNvgHixamT&_nc_ht=scontent.oculuscdn.com&_nc_gid=APkAQj0gJUW_sFWZn2bm_qK&oh=00_AYBluGyQpwLQn0YrXmQ9VAXeya6BuKDSgEMsE2Bb1lcP2Q&oe=66F5503C"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636653600, "status": "PUBLISHED", "id": "571145954169062"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8010858105710311", "version": "4.0.10.11049"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8010858105710311"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726745367, "id": "8011895895606532", "version": "4.0.11.11050", "version_code": 11050, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8010858105710311"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.0.9->4.0.10\n\nImprovements:\n\n-Added new samples to library\n\n-Added one more tutorial\n\n-Made animated transition between Sky and Passthrough\n\n-New stages appear at the end of the list.\n\n-Snapping to the surface no longer switches direct selection to ray selection.\n\n-\"My files\" tab is now the default for the library.\n\n-Recolored asset library assets from FFFFFF to 9B9B9B. and icons to pure FFFFFF\n\n-Spaces now start in VR by default.\n\n-Added laser straightening during snapping.\n\n-Iteration of UX polishing.\n\n-Rotation snapping now works with the laser pointer.\n\n-Added color dropper button in the Paint tool.\n\n-Returned duplicate toolbit on the dominant hand.\n\n-The audio spatializer now works for objects attached to the body.\n\n-Tool switches to selection when an asset is grabbed from the asset menu.\n\n-Snapping orb can now be grabbed.\n\n-The hand menu now opens when an object is selected.\n\n-Teleport to viewpoint on Play is now available in the Prototyping section.\n\nFixes:\n\n-Fixed laggy object snap when rotation snap is enabled.\n\n-Background scene issue when switching scenes is fixed.\n\n-Model preview no longer spawns in the center when scale factor is set to auto.\n\n-The delete button is now displayed for project spaces.\n\n-Fixed when line from interactivity to the object is visible in play mode.\n\n-Color change for multi-selected objects with groups is now functional.\n\n-Snapping to surfaces now works correctly with newly grabbed procedural cubes.\n\n-Paint tool ray is no longer interrupted by furniture in Room-scale mode.\n\n-Objects are no longer snapped to the wrong side of the floor.\n\n-Interactivity for deleted objects no longer refers to them.\n\n-Fixed when toolbar opens on the Text tool for the first time.\n\n-Objects are no longer duplicated when grabbed.\n\n-Text color can now be changed via the Paint tool.\n\n-VR and real controllers now match correctly for Quest Pro and Quest 3.\n\n-Frame drops while selecting are fixed.\n\n-Interactivity is now cleared from the object when the option that uses it is changed.\n\n-The Delete interactivity button now responds in all cases.\n\n-Selection with modification pressed now works correctly.\n\n-Space now opens immediately when using the \"Open in VR\" feature", "created_date": 1726735835, "id": "8010858105710311", "version": "4.0.10.11049", "version_code": 11049, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8010858105710311"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1726735505, "id": "8010821069047348", "version": "4.0.10.11048", "version_code": 11048, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8010858105710311"}, "release_status": "RELEASED"