=VllPKmKjaFIQ7kNvgFhxKzB&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDNWVho5Yk-1fdeXAkwKRzi3iNfXiaY7PWbtHpw-xsj0w&oe=675EB8D5"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WmlRzx8MAYQ7kNvgGoH80P&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCE4JybLnuY0hMnkc8133dK3sxD0BPtsh4WQnpQfmyszg&oe=675ED968"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qAse39f7UwMQ7kNvgE4JEPS&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDR27xQSBb1N1fT26zw4scfDISV5fWUSgIR11efLzhmbg&oe=675EDA10"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gUJ2YgZMHqEQ7kNvgG5yVPs&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYB1qAOvrPjfRI9Zw5-GZh6Ppv2TDNxzLJ4c1Ar0NZu0hw&oe=675ED107"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G0ol5uRRwnMQ7kNvgEnauqA&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDqOMcjfrFyErh_dR4KkHagmygOEdLkWrrivcjFh0SBPA&oe=675EA946"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bGRAdoBfGFcQ7kNvgEmHJnN&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYBwh_hH5yHiLV0xmcrCWhYAaRtzBK2jjBmNt0lI3FR7Jg&oe=675EC83C"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PENDING", "id": "2034377863730095"}, {"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "2034377863730095"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8558198290976287", "version": "4.19.1.12551"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8558198290976287"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.19.0->4.19.1\n\n- SXR-6749: Fixed issue where Follow mode in VR cannot be stopped if started by a web user.\n\n- SXR-6802: Resolved issues with attached groups breaking after exiting Play mode.\n\n- SXR-6808: Fixed workspace-related problems for free users.\n\n- SXR-6812: File names are no longer cut off in the Move pop-up and file preview.\n\n- SXR-6823: Scene switching via the stick now functions