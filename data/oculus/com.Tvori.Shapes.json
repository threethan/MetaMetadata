=awnRF7KsL1sQ7kNvgE9ESgV&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBVDgtILWB-MlooEFc0bJCZ5kmEQwRn7PKFy6m6A0RHsA&oe=67582155"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nXmNkXWcm74Q7kNvgErJ_9i&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCztdSQ0S0TwFeVS7j4ZdEUrUs6oBACoO5THn_r_w8a_w&oe=675841E8"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SycEGidS180Q7kNvgFTEcrJ&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYA4F5TmqAgpKJP-95lD7ajZpJQJ12l8u0c_PrXDU7dAZg&oe=67584290"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EUkEmX5PgqsQ7kNvgGLr-Xb&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCgR_NGrixVDXbIn2J7NpvpB9jXYzTj4W_hfQpnulzqJw&oe=67583987"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q14aIRdCqeIQ7kNvgGic8YN&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCZhyl4Dqx3CJPONude8hTFQueuzRCLLRn-rmdug1dmSA&oe=675811C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ee3A--CV52IQ7kNvgH-I9SQ&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYCdx-0_ct9zJ9Xe1q_p9X3ynyJo66UdbCXfSggLmPxzHQ&oe=675830BC"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "A