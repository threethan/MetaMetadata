Gp7m6yRQHApcnMSkq53GtHY5GQkWEF9Ce5hg&oe=66FE7B55"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XS8l548yJecQ7kNvgFAUIp-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBRrpKIaF3WkBsp2DPscYaZCpIrUeWhPIYo0RcKLPpv2A&oe=66FE9BE8"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bYDVgpYkAAkQ7kNvgF0dZbc&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxmQ63iKv0g3RQfMo0NticVKKEGDbp5mjOKFabVFDRug&oe=66FE9C90"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k9V4zZb0RdoQ7kNvgGya_GJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCFdjYZAz4SMiqfspYFN7Uewz6T3S9chn5ROGZIPl805g&oe=66FE9387"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fsfw_qMhJgoQ7kNvgETnlt6&_nc_ht=scontent.oculuscdn.com&oh=00_AYDpJ7zyh_kirehlO0g07ly3sxnvxDpVkYAROGC56rLHOw&oe=66FE6BC6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6OuRI0Hi3hQQ7kNvgGO3ebf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDQIgyvl46JpCU4a_hBx4OyKG05bMIMzw2uuYsYDPOrWw&oe=66FE8ABC"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636653600, "status": "PUBLISHED", "id": "571145954169062"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8074772159318905", "version": "4.0.11.11082"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8074772159318905"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727455545, "id": "8088068084655979", "version": "4.0.12.11087", "version_code": 11087, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8074772159318905"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727342450, "id": "8075744932554961", "version": "4.0.12.11085", "version_code": 11085, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8074772159318905"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.0.10->4.0.11\n\nFEATURES\n\nImplemented Onboarding Tutorial 2.0.\n\nIMPROVEMENTS\n\nAll values entered in the numpad before acceptance are added to the Undo/Redo stack.\n\nEyedropper in the Paint tool picks up the opacity along with the material, not just the color.\n\nBUG FIXES\nFixed when inspector's pop-ups do not close when objects are deselected.\n\nFixed when incorrect color displayed in the color pop-up for objects with the default color.\n\nFixed when incorrect color in the preview of the Color tool.\n\nFixed when object twitches when rotating along the X-axis through the transform.\n\nFixed when the beam stops interacting with the UI if permissions are changed while the user is holding an object.\n\nFixed when them beam doesn't interact with the UI after pausing while grabbing an object.\n\nFixed when gizmo visual is shifted after Play mode if the object is attached to the viewpoint.\n\nRemoved an unnecessary point for the rotation gizmo in the center of the space.\n\nNow it is possible to use spaces and symbols except Latin characters and numbers in folder names.\n\nFixed when scene is not duplicated completely.\n\nFixed when app crashes after exiting Play mode.\n\nPop-ups block interaction with modal windows.\n\nFixed exception when trying to close the Holonote pop-up\n\nGroup objects remain highlighted after being deleted via the Inspector and then returning.\n\nFixed when the keyboard does not close when switching scenes.\n\nFixed when the keyboard is shown when navigating through a space link.\n\n Fixed when toolbar gets stuck when pointing at multi-selected objects.\n\nFixed when clicking on a user label does not move you to their scene.\n\nFixed exception occurs when canceling the value for the Text size property.\n\nFixed exception in Play mode with \"Play sound\" interactivity\n\nFixed when incorrect color preview for icons.\n\n Fixed when eyedropper does not pick up opacity from the text.\n\n Fixed when incorrect color displayed when the Passthrough material is set.\n\n Tool switcher is now always accessible, even when pointing at the menu or in ray mode.\n\n Enabled access to the sample from the Empty Lobby.\n\n Fixed errors when using holonote viewpoint.\n\nThe keyboard now closes when the presentation starts.", "created_date": 1727334738, "id": "8074772159318905", "version": "4.0.11.11082", "version_code": 11082, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8074772159318905"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727279899, "id": "8068571599938961", "version": "4.0.12.11078", "version_code": 11078, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {