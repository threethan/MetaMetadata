ges_2.png", "id": "1200521743765444", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036672_1200521747098777_3607383089734677798_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mKlfh8HjjNYQ7kNvgG2Jg36&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYBMnPp5Cn_oCMF0lYetVyr5If42_2OTYNcE3iP4zB3MiA&oe=66E6C055"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=phlPBJtGD4oQ7kNvgFUh-Sv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYAFbGrRUzpSwwMhA1IM_4J2lVKAqX6p7Jld7HTtskoIVg&oe=66E6A8A8"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q75qJ9eGOAUQ7kNvgEeIYnx&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYBRqnn1SDbYdgIF8ZmOovLYOUN3a55ufo847ol3plJJ9A&oe=66E6A950"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8us3flyGLVwQ7kNvgEwKIAe&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYBDv6qoB4Y5urE8TpMJiz1TET465K_-mkPVlDA9PjUOgQ&oe=66E6D887"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pWPO-W9wlhAQ7kNvgGnKlfJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYCo8bsoct3s0malwnVN3RAcZlKUYebYIwPNg_c69zeIPA&oe=66E6B0C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=2PzqZHQVZe4Q7kNvgEhgtCM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AdkPStvFNMuOURs3bSqYbC-&oh=00_AYAMLOWKexeLhID0vgJUt9M8qZ2UGG1olRNG_Aw25wlucw&oe=66E6CFBC"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636653600, "status": "PUBLISHED", "id": "571145954169062"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7776624349133689", "version": "4.0.9.11003"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7776624349133689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725268856, "id": "7887214134741376", "version": "4.0.10.11016", "version_code": 11016, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7776624349133689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725023869, "id": "7870866693042787", "version": "4.0.10.11010", "version_code": 11010, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7776624349133689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1724687042, "id": "7846364278826362", "version": "4.0.10.11008", "version_code": 11008, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7776624349133689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "957823275050861"}]}, "change_log": "4.0.8->4.0.9\n\nFEATURES\n-Improved attachment to viewpoints.\n\nIMPROVEMENTS\n\n-Optimized skybox implementation.\n\n-Enhanced Floor Grid Shader performance.\n\n-Updated environment and space pop-ups.\n\nBUG FIXES\n\n-Resolved issue where room walls were visible outside the designated space.\n\n-Fixed visual issues with buttons during new stage creation when certain limits were displayed.\n\n-Implemented a workaround for issues with unavailable room scale mode.\n\n-Addressed missing \"move to scene\" button, ensuring objects can be moved from the background to the scene.\n\n-Corrected issues with space renaming via the share panel.\n\n-Fixed space name overflow on space cards.\n\n-Resolved snapping issues where procedural primitives' boundaries were displayed incorrectly.\n\n-Ensured viewpoints have teleport options after Play mode.\n\n-Fixed tool change behavior when selecting objects for interactivity.\n\n-Corrected snapping display when the beam interacts with the UI near a surface.\n\n-Fixed an issue where the pointer visual was sometimes too large and flickered on objects.\n\n-Resolved issue where room walls were visible during space loading after a pause.\n", "created_date": 1723634178, "id": "7776624349133689", "version": "4.0.9.11003", "version_code": 11003, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "7776624349133689"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1723626091, "id": "7776087145854076", "version": "4.0.9.11001", "version_code": 11001, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}