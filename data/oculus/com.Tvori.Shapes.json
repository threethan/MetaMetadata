n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g9w9KfYdC1AQ7kNvgGYhM5h&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB7-dDzAOCIjsYNv_YMHhbYmXI6oizyUh_WtMyIQQnG0g&oe=6703C155"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mR_btHz7yJYQ7kNvgHdugCc&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCDGgJaD80adR6hEpgO1ygJEv2xI67_8mo3Pg5BqG8D9Q&oe=6703E1E8"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lW6vZnW4HFMQ7kNvgHoanF3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCTWPEuTqTtLCF160Z8WBCh8WNeaotgxQmrgxHJQ8JA8g&oe=6703E290"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T_lXYx-QDhoQ7kNvgGte4S6&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAs4BEYYRRi-6BKTuFRdngvq0bAa9OfKktOdNTAOcrR6Q&oe=6703D987"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lxeTig0ltHEQ7kNvgGnMNMK&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBFzb6Pl2evvxEEyoXQMTWjfLZMARzL_M9UbgV_fZ1gzw&oe=6703B1C6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n4nTpWc9jrsQ7kNvgEYgdWl&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBkAA_ObOHagRSvoHPGSQK33_2kBSdnCkyU1eomzhjoug&oe=6703D0BC"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "UTILITY", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER", "CO_OP"], "id": "669986557689391"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "571145954169062"}]}, "baseline_offer": {"id": "571145954169062"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636653600, "status": "PUBLISHED", "id": "571145954169062"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8124114631051324", "version": "4.0.12.11093"}, "id": "957823275050861", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8124114631051324"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1727883379, "id": "8135285053267615", "version": "4.0.13.11097", "version_code": 11097, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "3899112273551602", "is_concept": false, "latest_released_binary": {"__type