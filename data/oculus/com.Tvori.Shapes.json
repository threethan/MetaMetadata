=IIUDXE6UJ-8Q7kNvgHDAtRN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBxx-i_rfsA5uxloKVTeLP-_BpIANJdol2vexXBOioBFA&oe=676BE7D5"}, {"file_name": "39001713_223349033116769_8748754183405016471_n.png", "id": "979932645923001", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/54823267_979932649256334_2640165192087190174_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K5LbA8Rm4l4Q7kNvgFSZ56m&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbp2QXzC-DH_qLQeniLcxzNFT2vg2Um_uGx5zgk3JP7w&oe=676C0868"}, {"file_name": "39031326_407934624379009_7988013580606512958_n.png", "id": "589551415589111", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974672_589551418922444_8061948627572672850_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Yjj1pDnGfsEQ7kNvgEQnjcs&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDVyxE8688Vh6rbY11GbTey7HEonPF0B06wEl-znkajOw&oe=676C0910"}, {"file_name": "39031421_258029306252074_3905259204676634223_n.png", "id": "363989018851641", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982460_363989022184974_8098055552428199935_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Dyw4e7PeBIQ7kNvgEAj2pf&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdEDMJqiGzbbL1nrBsNswcZ-_jCp8lIvSo9xnp0pF6tA&oe=676C0007"}, {"file_name": "39031524_646313359867400_4057001895794062954_n.png", "id": "322429766309947", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75295893_322429769643280_5491338988962958060_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=a_uMZfDnLO0Q7kNvgF1UN6e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_2j1m84IspEryFPCqrERzwOg_qzjm05ef0ruN6Z7nQw&oe=676BD846"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "38974502_4304547806258767_5679781568628605185_n.png", "id": "1029488971208582", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031414_1029488974541915_8768645250726725118_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P3Xt3fs7SIgQ7kNvgGR8MRD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA1d4H1OjeUN0eI8IWueXSJR58Pd0gRDym58D3ghI3UjA&oe=676BF73C"}, "display_name": "ShapesXR", "keywords": ["design", "collaboration", "prototyping", "storytelling", "productivity"], "long_description": "ShapesXR is a collaborative design tool to prototype AR and VR content and user experience for real-world products. \n\nIt enables remote product teams with the tool for brainstorming & ideation in 3D, rapid prototyping, instant sharing and real-time co-editing. It's a platform for live synchronization between all stakeholders, agile iterations on designs and thus accelerated product time-to-market.\nShapesXR was born with the mission to democratize 3D content creation allowing  product owners, business leaders, and designers to finally start thinking and creating spatially together.\n\nIn ShapesXR you can pick a premade scene as a canvas for your creation or start from scratch and build the lobby of a VR fitness game. Designers can introduce and manipulate simple shapes at scale, change color and materials, research user flows and pitch scenes in motion with a simple to use staging system (everything stays in low fidelity so that people don\u2019t hang up on details too early in the process).", "short_description": "ShapesXR is a creation and collaboration platform for remote teams.\n\nIn ShapesXR you start creating in 3D within minutes without prior experience. You can create immersive storyboards to show your design in function and easily invite team members to ideate, iterate and run design reviews."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.shapesxr.com/privacy", "developer_terms_of_service_url": "https://www.shapesxr.com/terms", "publisher_name": "Tvori Inc.", "support_website_url": null, "website_url": "https://www.shapesxr.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "A