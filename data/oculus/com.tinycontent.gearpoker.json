t64.5771-25/12386356_165630047457832_3733909645039763456_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wx-9t1IC5DcQ7kNvgGNV2NA&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyEX8nbLtKAtNuTyJJ0oqVq&oh=00_AYAZ7cCfsfCBk2vmkzeRDHei9E5VJDtBDn4_Rb_Tvshbzg&oe=66E82CCC"}, {"file_name": "migrated_image.png", "id": "209007576853962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_190603405083887_1986441023147999232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dw32SQYlGcMQ7kNvgGQWR9Q&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyEX8nbLtKAtNuTyJJ0oqVq&oh=00_AYD6sCEO_7cK7tiMP-_-5tvzNqEFtJwAxLiHkpQccZKAyA&oe=66E80EB9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SS6.png", "id": "2044551719096029", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_2044551722429362_8817000776976039936_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PPb3w_toM70Q7kNvgGBjvyB&_nc_ht=scontent.oculuscdn.com&_nc_gid=AyEX8nbLtKAtNuTyJJ0oqVq&oh=00_AYAmoBy_G1j9NsTv5MuxTkgx4X4YKsvffuXi_H17wMdyzw&oe=66E808C1"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Compete against your friends and other Gear, Go and Oculus players in 4 unique environments.\n\nAs the first platform to offer private tables for rent by the hour, MetaTable Poker allows you create a game and invite your friends to play by providing them with a unique PIN number. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nAnd what\u2019s a poker game without food, drink, funny hats and other objects to play with? MetaTable Poker allows you to spend your hard-earned chips on 32 unique objects. You can share these objects with your friends at the table.\n\nSome of MetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- Oculus Avatar support\n- Voice chat\n- Private table rental