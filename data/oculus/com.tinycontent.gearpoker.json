w4VQsT66njU2A&oe=6733524C"}, {"file_name": "migrated_image.png", "id": "209007576853962", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138999_190603405083887_1986441023147999232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9P-S3jVTS0Q7kNvgFIT4-O&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDXS0DCEKXq1jVaMK7Dnga7uViszINO3PCXJnickUtzFg&oe=67333439"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SS6.png", "id": "2044551719096029", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138999_2044551722429362_8817000776976039936_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cqjTgljfv3wQ7kNvgEcRAoA&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDu_4z43HPmTq3E4ywW4PhFsRvbSfg3dFePLz_huhCfMg&oe=67332E41"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Compete against your friends and other Gear, Go and Oculus players in 4 unique environments.\n\nAs the first platform to offer private tables for rent by the hour, MetaTable Poker allows you create a game and invite your friends to play by providing them with a unique PIN number. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nAnd what\u2019s a poker game without food, drink, funny hats and other objects to play with? MetaTable Poker allows you to spend your hard-earned chips on 32 unique objects. You can share these objects with your friends at the table.\n\nSome of MetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- Oculus Avatar support\n- Voice chat\n- Private table rental\n- Objects to purchase with your chips\n- 4 unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "h