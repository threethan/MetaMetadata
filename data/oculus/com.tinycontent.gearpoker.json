ile_name": "Cover-Art-Landscape.png", "id": "1343171842862659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035383_1343171846195992_8932016081078023285_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUarc8kVyTEQ7kNvgEhtR3W&_nc_ht=scontent.oculuscdn.com&oh=00_AYDrdMvztF6LM8vW76qst4e_ISbZjGufybr7riOG_q_vGg&oe=66F92F3F"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Complete cross-platform with Rift, Go, Quest, and iOS.\n\nBATTLE tables, now in beta, allow you to teleport within the level and acquire weapons. Shoot your opponents out of the hand and avoid getting hit. \n\nCreate a private game and invite your friends to play with a unique PIN. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nFood, drink, funny hats and other objects are available for purchase. MetaTable Poker allows you to spend your hard-earned chips on unique objects. You can share these objects with your friends at the table.\n\nMetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- BATTLE tables blend poker and arena play\n- Voice chat\n- Private table rental\n- Cross-platform play with Oculus and iOS\n- Unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Our BATTLE tables are in beta and blend poker and combat arena style play - a truly unique twist on poker."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "https://www.metatable.co/privacy-policy-2021", "developer_terms_of_service_url": "https://www.metatable.co/terms-of-service", "publisher_name": "Tiny Content", "support_website_url": null, "website_url": "https://metatable.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_t