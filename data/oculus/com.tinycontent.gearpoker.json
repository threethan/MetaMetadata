sid=6e7a0a&_nc_ohc=tMeHlxdYVK0Q7kNvgE-HskT&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBoyK0MsnJSZ8CwwaG3KPun0lh-kHtN3i8BBIny6RVvoA&oe=670A55B9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SS6.png", "id": "2044551719096029", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138999_2044551722429362_8817000776976039936_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=818_f7K37wMQ7kNvgEUlXtJ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKsWoZaBeMrVqajlc_79EH9Pa78u71D1MHDFJhCZjVow&oe=670A4FC1"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Compete against your friends and other Gear, Go and Oculus players in 4 unique environments.\n\nAs the first platform to offer private tables for rent by the hour, MetaTable Poker allows you create a game and invite your friends to play by providing them with a unique PIN number. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nAnd what\u2019s a poker game without food, drink, funny hats and other objects to play with? MetaTable Poker allows you to spend your hard-earned chips on 32 unique objects. You can share these objects with your friends at the table.\n\nSome of MetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- Oculus Avatar support\n- Voice chat\n- Private table rental\n- Objects to purchase with your chips\n- 4 unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "https://www.metatable.co/privacy-policy", "developer_terms_of_service_url": "https://www.metatable.co/terms-of-service", "publisher_name": "Tiny Content", "support_website_url": null, "website_url": "https://metatable.co/", "category": "GAMES",