m&oh=00_AYDEall1AnDte7BW2wrKedbdZk014yV19sdsxSJd-MRkXg&oe=66F941DF"}]}, "id": "2353115698121545", "locale": "en_US", "screenshots": [{"file_name": "migrated_image.png", "id": "2793785437376160", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12482172_321677698360019_6770873868920815616_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Fmg_PkNxlgUQ7kNvgGbOZj1&_nc_ht=scontent.oculuscdn.com&oh=00_AYDXpMRTrqnvtEfOj6z5yUNhh569SyjrFezkOEGYIWEJ8A&oe=66F94D9F"}, {"file_name": "migrated_image.png", "id": "859320967876377", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12331069_621627894847676_4360016800490979328_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BizUeV05sawQ7kNvgEDNka1&_nc_ht=scontent.oculuscdn.com&oh=00_AYBAuezNj42r1qnNqkDsAFPDXCuf7du9XMPdrB00PWNqlA&oe=66F93B77"}, {"file_name": "migrated_image.png", "id": "296718951290141", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386401_326793387848091_8801435330164031488_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-sAqoK2vygQ7kNvgED6PvP&_nc_ht=scontent.oculuscdn.com&oh=00_AYAAHeazPvFg0VvwOku7EwAdy1gvimQHiChi8b3Ac_DwxA&oe=66F93F5C"}, {"file_name": "migrated_image.png", "id": "236849207469816", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12386356_165630047457832_3733909645039763456_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y1f-D1lsrgUQ7kNvgFdpj-T&_nc_ht=scontent.oculuscdn.com&oh=00_AYAyoSFJe3TdDknjgrArjwta_1kkAVGAR6blhgfcffm9dA&oe=66F9504C"}, {"file_name": "migrated_image.png", "id": "209007576853962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_190603405083887_1986441023147999232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3AWfF1XQMFsQ7kNvgGuoGLV&_nc_ht=scontent.oculuscdn.com&oh=00_AYADPGqqmM9AeQO8LAsa2DkeI8zBu4D8C_EjegLfyys6Tw&oe=66F93239"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SS6.png", "id": "2044551719096029", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_2044551722429362_8817000776976039936_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BvJfk3c5rzgQ7kNvgHg6nst&_nc_ht=scontent.oculuscdn.com&oh=00_AYDnaFz1kbaVpEWZnPZ9oaJexCJfbX7KjtblQGjCWZRB5g&oe=66F92C41"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Compete against your friends and other Gear, Go and Oculus players in 4 unique environments.\n\nAs the first platform to offer private tables for rent by the hour, MetaTable Poker allows you create a game and invite your friends to play by providing them with a unique PIN number. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nAnd what\u2019s a poker game without food, drink, funny hats and other objects to play with? MetaTable Poker allows you to spend your hard-earned chips on 32 unique objects. You can share these objects with your friends at the table.\n\nSome of MetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- Oculus Avatar support\n- Voice chat\n- Private table rental\n- Objects to purchase with your chips\n- 4 unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "https://www.metatable.co/privacy-policy", "developer_terms_of_service_url": "https://www.metatable.co/terms-of-service", "publisher_name": "Tiny Content", "support_website_url": null, "website_url": "https://metatable.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "CASUAL", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "suppo