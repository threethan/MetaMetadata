.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYDpNRQVMsP3R5P5U-NdLHNktNb-F8efrZ7lDHUeSkuLOg&oe=66E6D9AD"}, {"file_name": "Cover-Art-Landscape-Tiny.png", "id": "289248206750240", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974460_289248210083573_7166818702470469519_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5VDnUbngkgQ7kNvgEm0hV4&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYBQPsGp0lPPIs4AymuwlWJSyKEBM-5p9h7xPQdyLK_dIQ&oe=66E6B362"}]}, "id": "333128522287676", "locale": "en_US", "screenshots": [{"file_name": "SS3.png", "id": "4634905453291286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982650_4634905459957952_6873390494386264117_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HVuNEQWdT_gQ7kNvgEltnxK&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYAq9zTlnizzMizn1vWMfQr4MDShHm0Vu3QQYuj5Eh0MxQ&oe=66E6C416"}, {"file_name": "SS5.png", "id": "703389281004380", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982700_703389284337713_5826611145834820161_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sL0RW4uoMSkQ7kNvgHkZWPr&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYAYhw2QdKuT81ogjI1WXmfqARcCuKH00rgt2DJIRbubdg&oe=66E6BBCB"}, {"file_name": "SS1.png", "id": "567064968072454", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982721_567064971405787_4672036885606849560_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KwUwISp8Oc4Q7kNvgGhEwlB&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYADJjeFGS3ZiKmLvsbz4rVetJjyg58gAWuS9f-KrnxjaQ&oe=66E6DCEF"}, {"file_name": "SS4.png", "id": "416647226572748", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75356792_416647229906081_8768521853214104008_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ld4cfc5DqYkQ7kNvgGSGS9L&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYDEV03kAtHKuBWUZgnFiVf1gDMZnUlEdsv-uSgDVvfRTQ&oe=66E6A8E2"}, {"file_name": "SS2.png", "id": "297878989208045", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031375_297878992541378_183972035221925865_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3DZxQyXqyngQ7kNvgEkpuDv&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYCihlLNt4JBAIHWSMy6EoVX3yHK_5LGnSntonREscdFCQ&oe=66E6D6DA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Cover-Art-Landscape.png", "id": "1343171842862659", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035383_1343171846195992_8932016081078023285_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRi4c4axVaIQ7kNvgE1dzGN&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYAD_mwdlHa5lGR667JZIpgPqlYCkcEaRIRrJ6nRZAtRTQ&oe=66E6BA3F"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Complete cross-platform with Rift, Go, Quest, and iOS.\n\nBATTLE tables, now in beta, allow you to teleport within the level and acquire weapons. Shoot your opponents out of the hand and avoid getting hit. \n\nCreate a private game and invite your friends to play with a unique PIN. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nFood, drink, funny hats and other objects are available for purchase. MetaTable Poker allows you to spend your hard-earned chips on unique objects. You can share these objects with your friends at the table.\n\nMetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- BATTLE tables blend poker and arena play\n- Voice chat\n- Private table rental\n- Cross-platform play with Oculus and iOS\n- Unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Our BATTLE tables are in beta and blend poker and combat arena style play - a truly unique twist on poker."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "https://www.metatable.co/privacy-policy-2021", "developer_terms_of_service_url": "https://www.metatable.co/terms-of-service", "publisher_name": "Tiny Content", "support_website_url": null, "website_url": "https://metatable.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SOCIAL", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "538055247693393"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982700_544722633940406_5083385246360528834_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4vYECjbdDxsQ7kNvgHPIsEW&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYDBdJqi7DuE_lcyvUmMgjzb1raVwUlHurPpe4btMoXccA&oe=66E6D9AD"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MetaTable Poker", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1529514000, "lastRevision": {"nodes": [{"id": "1551236588294170", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "1507202936002141", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID"}, "iarc_cert": {"id": "477117179357978"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "migrated_image.png", "id": "25024556933