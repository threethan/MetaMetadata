t64.5771-25/12386356_165630047457832_3733909645039763456_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wx-9t1IC5DcQ7kNvgHPYHDH&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYDlidc2UT2GUbwzRPsSec-04FEj3_FRCjfKRyGMd9Ad9Q&oe=66E6DB4C"}, {"file_name": "migrated_image.png", "id": "209007576853962", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_190603405083887_1986441023147999232_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dw32SQYlGcMQ7kNvgEXp5bZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYCGGjTS1_i5ISc4UDntMzPCKk4t1VkRjV1P-6G08RGMnA&oe=66E6BD39"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SS6.png", "id": "2044551719096029", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138999_2044551722429362_8817000776976039936_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hHu7ybcYEiEQ7kNvgFTrwDK&_nc_ht=scontent.oculuscdn.com&_nc_gid=And5WRc13i-s0a-vDm39oJw&oh=00_AYBer-TPBa2-25fejWsRTEHBGQ7qj_i8cuowBeTKt0WjWg&oe=66E6B741"}, "display_name": "MetaTable Poker", "keywords": ["Poker", "Casino", "MetaTable", "Card", "Social"], "long_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR. Compete against your friends and other Gear, Go and Oculus players in 4 unique environments.\n\nAs the first platform to offer private tables for rent by the hour, MetaTable Poker allows you create a game and invite your friends to play by providing them with a unique PIN number. You can use private tables to test your friends\u2019 poker skills or just hang out and chat in VR.\n\nAnd what\u2019s a poker game without food, drink, funny hats and other objects to play with? MetaTable Poker allows you to spend your hard-earned chips on 32 unique objects. You can share these objects with your friends at the table.\n\nSome of MetaTable Poker\u2019s features:\n\n- Realistic Texas Hold\u2019em gameplay\n- Oculus Avatar support\n- Voice chat\n- Private table rental\n- Objects to purchase with your chips\n- 4 unique environments", "short_description": "MetaTable Poker is the ultimate social card platform to play Texas Hold\u2019em in VR."}]}, "developer_name": "Tiny Content", "developer_privacy_policy_url": "https://www.metatable.co/privacy-policy", "developer_terms_of_service_url": "https://www.metatable.co/terms-of-service", "publisher_name": "Tiny Content", "support_website_url": null, "website_url": "https://metatable.co/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SOCIAL", "CASUAL", "STRATEGY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["TOUCHPAD", "GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "2845095985788652"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "193288384719068"}]}, "baseline_offer": {"id": "193288384719068"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1529514000, "status": "PUBLISHED", "id": "193288384719068"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2611133632275727", "version": "1.0.2"}, "id": "922617024570710", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1507202936002141", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "2611133632275727"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name"