/v/t64.5771-25/39035422_617153453816929_8197618131681588935_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o_yRWZ7rzkgQ7kNvgHYptJQ&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCEkKPs6TUZ5qGInWqMbR5TFn3TfmUmMRAaMSHptBehTg&oe=67584329"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TBC_Landscape.png", "id": "1933231860214727", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/39036614_1933231863548060_6384280158781549633_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6n2AgHt5y7cQ7kNvgGflXFw&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYByTPJX9nxL4DX2seUNm5LqCeNOb3LG9pY0NdXm_eVbow&oe=67581FCB"}, "display_name": "Tube Be Continued", "keywords": ["puzzle", "funny", "cute", "story", "pet"], "long_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels! \u2b50\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nTUBE-Based Benefits:\n\u2022 60 levels across 3 themed floors: Hamster Hangout, Smart Home Slide & Bakery Blitz!\n\u2022 Customize your hamster\u2019s appearance!\n\u2022 Classic and slide-based tube puzzles!\n\u2022 Numerous Mini-Puzzles including our new hamster cannon!\n\u2022 Chat with the BOSS and help him deal with important \u201cbusiness decisions\u201d!\n\u2022 Relaxed-pace gameplay with no time pressure.\n\u2022 Supports seated, standing, or room scale play.\n\nYour destination for TUBE-Based entertainment awaits!\n\nSincerely,\nThe BOSS", "short_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels! \u2b50\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nSincerely,\nThe BOSS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bluemonttechnology.com/game%20privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bluemont Technology & Research, Inc.", "support_website_url": null, "website_url": "https://tubebecontinued.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8077335482357240"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75282159_528809865418007_1389408569423651087_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zNBnuQ4Ch8kQ7kNvgHZX8wN&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDO8XRI0frVnBJ6aiuBhE98WvK5CkuetYBlb8psQdTQjQ&oe=67584280"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Be Continued", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1669842000, "lastRevision": {"nodes": [{"id": "5556606084430205", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "5556605911096889", "is_first