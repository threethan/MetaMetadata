36 hamster-approved puzzles across 60 levels! \u2b50\n\nTry the Free Demo: https://www.oculus.com/experiences/quest/4157274414400932/\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nSincerely,\nThe BOSS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bluemonttechnology.com/game%20privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bluemont Technology & Research, Inc.", "support_website_url": null, "website_url": "https://tubebecontinued.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6984554818301984"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282159_528809865418007_1389408569423651087_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pyv-obWCWtcQ7kNvgEeT_tq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AU7lw6CYHoMcQ26kBDZF16H&oh=00_AYDJPcWeDvOwhD_AXV39A3I2_8y_mfrpjMRd6fI4xOmekg&oe=66CD9CC0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Be Continued", "platform":