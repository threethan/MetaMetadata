e_name": "TBC_BB_Screenshot2.png", "id": "617153450483596", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035422_617153453816929_8197618131681588935_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k3APtgb9whkQ7kNvgERNanh&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVwuJWjrTdBTh_bQNpr7B1V&oh=00_AYBgEcYzYZE2ZYWtWfafxr9bw8uFK3M5UNWJSKBkL8i1cQ&oe=66E406E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TBC_Landscape.png", "id": "1933231860214727", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036614_1933231863548060_6384280158781549633_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I3AMrZrzN_0Q7kNvgH3mpA3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVwuJWjrTdBTh_bQNpr7B1V&oh=00_AYB2rEJhE9k-BjoAUjLW5IumAQagqyyqJ60RRXxxAYZKLg&oe=66E41BCB"}, "display_name": "Tube Be Continued", "keywords": ["puzzle", "funny", "cute", "story", "pet"], "long_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels! \u2b50\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nTUBE-Based Benefits:\n\u2022 60 levels across 3 themed floors: Hamster Hangout, Smart Home Slide & Bakery Blitz!\n\u2022 Customize your hamster\u2019s appearance!\n\u2022 Classic and slide-based tube puzzles!\n\u2022 Numerous Mini-Puzzles including our new hamster cannon!\n\u2022 Chat with the BOSS and help him deal with important \u201cbusiness decisions\u201d!\n\u2022 Relaxed-pace gameplay with no time pressure.\n\u2022 Supports seated, standing, or room scale play.\n\nYour destination for TUBE-Based entertainment awaits!\n\nSincerely,\nThe BOSS", "short_description": "\u2b50 Play 136 hamster-approved puzzles across 60 levels! \u2b50\n\nHello! Welcome to TUBE Industries: a hamster owned and operated tube puzzle emporium! \n\nPrepare for a tube-based, puzzle-filled, HAM-PACKED adventure with our charismatic leader: The BOSS. Here at TUBE Industries we provide the puzzles and you provide\u2026 the brains. No shady business here!\n\nSincerely,\nThe BOSS"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bluemonttechnology.com/game%20privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Bluemont Technology & Research, Inc.", "support_website_url": null, "website_url": "https://tubebecontinued.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "394813081514456"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["PUZZLE", "CASUAL"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8077335482357240"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75282159_528809865418007_1389408569423651087_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1R49-fmrc7MQ7kNvgGVttCM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AVwuJWjrTdBTh_bQNpr7B1V&oh=00_AYA6TMdByEJ9o6mU2Qo53A3_f2lcG-irEWakHCTXBAp-pg&oe=66E43E80"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Tube Be Continued", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Interactive Story", "id": "3771364559549515"}, {"topic_name": "Casual", "id": "3948130815144