aMOWvZXEYIQ&oe=67347D8B"}, {"file_name": "migrated_image.png", "id": "139314820819180", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982690_2275901685763033_2134455083750916096_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mngk7gx9ykgQ7kNvgGKmfuO&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAuykTaQrVFnBFLIzBlufIRjnZmObNaKnQ8ZEzlUkwk3Q&oe=673495B6"}, {"file_name": "migrated_image.png", "id": "205740824070377", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003279_525830377914634_4213073299141296128_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OAfZHAlkp0cQ7kNvgF9nox8&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYANC1GZL6UwqJlhM0CEglzsxghdTwwh4JU1YD8NtbrPAA&oe=67349662"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/jtgTT4", "id": "227622721458821", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974657_227622724792154_1333951219332284416_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U9kcBE7wTJIQ7kNvgHmOrZ4&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA0IGOm0oNOAWYJ-YuSKbX9eN90R2AvfF-NalPwYNofWA&oe=673476FB"}, "display_name": "EQQO", "keywords": ["Adventure", "Narrative", "Story", "Poetic", "Puzzle"], "long_description": "Inspired by ancient Ethiopian legends, Eqqo is a poetic narrative puzzle game, an initiatory adventure, and a love song to nature. It\u2019s the improbable epic of two foreign creatures one to the other... A child who can't see, and an Egg, as fragile as it is vital.\n\nLook at Eqqo's world through the eyes of his mother, who will guide him while telling his story. Help him use the powers of the Egg to advance through mysterious rooms and awaken the Temple's sleeping mechanisms... Foil ancient traps... And repel the dark forces that want to seize the Egg!\n\nEqqo\u2019s walkthrough represents more than five hours of gameplay, a compelling story, original musics recorded with philharmonic orchestra and complete voice acting.", "short_description": "A new poetic adventure in virtual reality from the creators of Dark Days.\n\nEqqo\u2019s walkthrough represents more than five hours of gameplay, a compelling story, original musics recorded with philharmonic orchestra and complete voice acting."}]}, "developer_name": "Parallel Studio", "developer_privacy_policy_url": "http://www.parallel-studio.com/PrivacyPolicy_EQQO.html", "developer_terms_of_service_url": "http://parallel-studio.com/", "publisher_name": "Parallel Studio", "support_website_url": null, "website_url": "http://parallel-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ja", "ko", "zh_CN", "it", "de", "es_AR"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "227716692803268"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974660_837407889787045_7677819005893083136_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XseVCQXqhrEQ7kNvgFny-ms&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCarOfoUE6qJRmjVjDbtJhLY4-PQVi79UoGNuWBASyqlg&oe=6734A4BC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "EQQO", "platform": "ANDROID", "context_category": null, "context_topics": [], "release_date": 1548784800, "lastRevision": {"nodes": [{"id": "2088662884547632", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "2461352513879642",