tra and complete voice acting.", "short_description": "A new poetic adventure in virtual reality from the creators of Dark Days.\n\nEqqo\u2019s walkthrough represents more than five hours of gameplay, a compelling story, original musics recorded with philharmonic orchestra and complete voice acting."}]}, "developer_name": "Parallel Studio", "developer_privacy_policy_url": "http://www.parallel-studio.com/PrivacyPolicy_EQQO.html", "developer_terms_of_service_url": "http://parallel-studio.com/", "publisher_name": "Parallel Studio", "support_website_url": null, "website_url": "http://parallel-studio.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE", "NARRATIVE", "PUZZLE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ja", "ko", "zh_CN", "it", "de", "es_AR"], "supported_input_devices": ["GEAR_VR_CONTROLLER"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "227716692803268"}}]}, "scheduled_offers": {"count": 25, "nodes": [{"status": "PUBLISHED", "id": "649590475452947"}, {"status": "PUBLISHED", "id": "2434595786803326"}, {"status": "PUBLISHED", "id": "303977487634490"}, {"status": "PUBLISHED", "id": "318690505417286"}, {"status": "PUBLISHED", "id": "2470557169847914"}, {"status": "PUBLISHED", "id": "298840170774527"}, {"status": "PUBLISHED", "id": "668351563616539"}, {"status": "PUBLISHED", "id": "2242189846085876"}, {"status": "PUBLISHED", "id": "2054314144864572"}, {"status": "PENDING", "id": "1459979494792117"}, {"status": "PUBLISHED", "id": "490193278436356"}, {"status": "PUBLISHED", "id": "491296764737023"}, {"status": "PUBLISHED", "id": "408618513038891"}, {"status": "PUBLISHED"