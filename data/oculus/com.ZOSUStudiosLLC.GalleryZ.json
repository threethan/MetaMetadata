404", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031423_460976045916737_8426282240400093759_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=O9DUghMkvCEQ7kNvgHq-ZPE&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB6NEx1QNHal1UDpbs0X5YN0R-avkZ28T4JEsL9QPoFBQ&oe=670A6685"}, {"file_name": "darkscreen3.png", "id": "777010026967806", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75411997_777010030301139_1357740700211826645_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b_5AszNeZNMQ7kNvgEA6xx6&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA57KzTw-q4RDxroDa1vhtnE0nl1riiz0Fu6bj6L4TmzA&oe=670A477A"}, {"file_name": "darkscreen5.png", "id": "1077654623115403", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75234367_1077654626448736_8852792745791337255_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-LlRIeYdHI8Q7kNvgEsM37Q&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOsPTy0Yovk_pseMAj4xWY0zrL-7gAlipU5uy6guYn9A&oe=670A52F5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "darkscreen4.png", "id": "485229493065555", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974867_485229496398888_8175609707286513413_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yHneTD_kL2gQ7kNvgGpHzbg&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDD2e6DTTTFzZ_k6DZHLs1Vey-RYw-VX4Vo_pmxZOn4xg&oe=670A59D4"}, "display_name": "ZOSU Castle Morgue Escape", "keywords": ["Horror", "puzzle", "escape", "castle"], "long_description": "VR ZOSU Castle Morgue Escape\n- You awaken in a dark and scary abandoned castle that was being used as morgue. It is dark but fortunately you have a flashlight, you must find your way out through a series of simple puzzles and mechanics. \n- This is a casual and somewhat spooky escape-room/area type of game\n- Mostly search and explore with a few cryptic clues to help you along\n- Casually playing it should not take more than 60 minutes\n- Escape the castle quickly for a highscore\n- The last completed round score and highest all time scores are saved\n- Many mysteries, skeletons, and castle areas await you!\n- Some events are slightly randomized for replay ability\n- 3 game modes:\n1) standard in the dark with extra visual hints every few minutes\n2) hard in the dark with no extra timed hints\n3) explore in the light with no puzzles or scoring\n", "short_description": "- You awaken in a dark and scary abandoned castle that was being used as morgue. It is dark but you have a flashlight, you must find your way out through a series of simple puzzles and mechanics. \n- This is a casual and somewhat spooky escape-room/area type of game\n- Escape the castle quickly for a highscore\n- 3 game modes:\n1) standard in the dark with extra visual hints every few minutes\n2) hard in the dark with no extra timed hints\n3) explore in the light with no puzzles/time\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "PUZZLE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8144099342365553"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://sconten