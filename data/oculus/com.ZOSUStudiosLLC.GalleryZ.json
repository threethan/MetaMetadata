vgGSExgC&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9LOzO5d5qEx1V6l_uBV74Zd60NCBISKyPecijWNrBCg&oe=66CAFF7A"}, {"file_name": "darkscreen5.png", "id": "1077654623115403", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234367_1077654626448736_8852792745791337255_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oMJF5-1irWgQ7kNvgGbEFkB&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8FM7hEDV5wdO8Kvywui-hYTM_lzaLXbphywe6GGnVag&oe=66CB0AF5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "darkscreen4.png", "id": "485229493065555", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974867_485229496398888_8175609707286513413_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yJ8X7Atg8QsQ7kNvgF4MxGt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBfQ1WKdkSm3Yvj-MrQvScWtr6pjJarJVkyd15BTm02Vg&oe=66CB11D4"}, "display_name": "ZOSU Castle Morgue Escape", "keywords": ["Horror", "puzzle", "escape", "castle"], "long_description": "VR ZOSU Castle Morgue Escape\n- You awaken in a dark and scary abandoned castle that was being used as morgue. It is dark but fortunately you have a flashlight, you must find your way out through a series of simple puzzles and mechanics. \n- This is a casual and somewhat spooky escape-room/area type of game\n- Mostly search and explore with a few cryptic clues to help you along\n- Casually playing it should not take more than 60 minutes\n- Escape the castle quickly for a highscore\n- The last completed round score and highest all time scores are saved\n- Many mysteries, skeletons, and castle areas await you!\n- Some events are slightly randomized for replay ability\n- 3 game modes:\n1) standard in the dark with extra visual hints every few minutes\n2) hard in the dark with no extra timed hints\n3) explore in the light with no puzzles or scoring\n", "short_description": "- You awaken in a dark and scary abandoned castle that was being used as morgue. It is dark but you have a flashlight, you must find your way out through a series of simple puzzles and mechanics. \n- This is a casual and somewhat spooky escape-room/area type of game\n- Escape the castle quickly for a highscore\n- 3 game modes:\n1) standard in the dark with extra visual hints every few minutes\n2) hard in the dark with no extra timed hints\n3) explore in the light with no puzzles/time\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "PUZZLE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7779288582179966"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57575349_838513140652404_8602856287160708788_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XadbkQQIVh4Q7kNvgEnpAvx&_nc_ht=scontent.oculuscdn.com&oh=00_AYByoNx18Ohb0RzpYZhBPLv_MG9K6fony1CjO3sqaXwcfQ&oe=66CB00DB"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "ZOSU Castle Morgue Escape", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Adventure", "id": "2691890164