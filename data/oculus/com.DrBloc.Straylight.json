5GXxg-wLiTowUGQ&oe=66E6B88E"}, {"file_name": "Straylight Screenshot 05.png", "id": "306461414530100", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974454_306461417863433_2013603082060758168_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fTQp_YpU-OUQ7kNvgEV39Ru&_nc_ht=scontent.oculuscdn.com&oh=00_AYDiVwLfBnGGG4AoIFSXB_xk1mGQTotPTOp9jkMQveY5Jg&oe=66E6E0CD"}, {"file_name": "Straylight Screenshot 08.png", "id": "330324378700085", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974800_330324382033418_8613667374889529408_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZtSXmo7ppmoQ7kNvgFzi4iH&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBqIEeQoKX6yZ_GBOh9EvzTPxuwQa4lZFN8KDZ4bzaYQ&oe=66E6D7DC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCover.png", "id": "334272634986723", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974602_334272638320056_1646791582313961751_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XJG-Wv4l4hsQ7kNvgFneXVt&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfurj2F2HwDX72UV1jzkskZhjG83fi0Ab38NJfNNI38w&oe=66E6E0E1"}, "display_name": "Straylight", "keywords": [], "long_description": "Have you ever wanted to fly? In STRAYLIGHT, you will soar through beautiful and deadly obstacle courses meant to evoke the simplicity, difficulty, and fun of old-school platforming games, but in a way that can only be experienced in VR. You will swing, fly, and fling yourself through beautiful and deadly cosmic playgrounds. It isn\u2019t all freedom, however; you will need to navigate increasingly diabolical obstacles to reach the end of each challenge. Though the gameplay is simple at its core, it is endlessly replayable as you try to nail that one, perfect, beautiful run.\n\nPlaying STRAYLIGHT is a simultaneously nail-biting and zen experience; each level is crafted to provide moments of exhilaration and wonder while \nchallenging the player to navigate through the flowing obstacle courses. The score, composed specifically for the game, is tailored to heighten and magnify both sensations.\n\nWe developed STRAYLIGHT to be an experience that anyone can enjoy, even those brand new to VR.", "short_description": "Fly, swing, and soar through a beautiful and deadly universe in a new kind of VR platforming experience. Using the Fling Engine - a propulsion mechanic designed for totally comfortable movement in VR - you will soar too high, fly too fast, and die way too much. Can you master the STRAYLIGHT?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.drbloc.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "Dr. Bloc", "support_website_url": null, "website_url": "https://www.drbloc.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "FLYING", "RACING"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "455727353053945"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2164483573747877"}]}, "baseline_offer": {"id": "2164483573747877"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1675157400, "status": "PUBLISHED", "id": "2164483573747877"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6190930700941477", "version": "1.0"}, "id": "506328637444046", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typena