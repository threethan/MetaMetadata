file_name": "image_2024-05-26_001831763.png", "id": "1164866334583210", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/43997716_1164866337916543_3509890935369151886_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Tf4QpiaCsfYQ7kNvgFUegYu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDM0B-7z1taFurjbiY6pAu_-iKi0wygxq0R2Wi6s1kb6A&oe=673C5EB7"}, {"file_name": "image_2024-05-26_001840281.png", "id": "7564926693626297", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974887_7564926696959630_3060361769582008323_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D1XHgbPDQgUQ7kNvgGWVYoz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD0ffLYTUxp4KO_MR7Oi_pVwBS79ZgWnATr-CIqUSpZ6Q&oe=673C8D63"}, {"file_name": "image_2024-05-26_001845812.png", "id": "1643454329804339", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86610703_1643454336471005_6043412212073075318_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UQmO7I-icFMQ7kNvgFQtES5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDhFLlqlygpSavTtKzClBYfs33A3mJOoGsZlVoU7HOwwg&oe=673C688E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Volcano Runners", "keywords": [], "long_description": "Volcano Runners is an action-packed Gorilla Tag fangame that thrusts players into a thrilling volcanic landscape where agility and quick reflexes are key to survival. Set amidst the backdrop of an erupting volcano, this game offers an intense, immersive experience where every leap, swing, and climb could be the difference between victory and a fiery demise.\n\nIn Volcano Runners, players take on the role of agile runners navigating a hazardous terrain filled with bubbling lava flows, erupting geysers, and crumbling rock formations. The game's dynamic environment is ever-changing, with molten lava rising and falling, creating new challenges and paths. Players must stay on their toes, using their parkour skills to jump between platforms, scale vertical cliffs, and swing across dangerous chasms.", "short_description": "### Volcano Runners\n\n**Volcano Runners** is an exhilarating Gorilla Tag fangame that plunges players into a molten adventure! Set in a perilous volcanic landscape, players must navigate treacherous lava flows, dodge erupting geysers, and climb unstable rock formations using only their wits and agility. Race against friends or foes, leaping from platform to platform, scaling vertical cliffs, and swinging across fiery chasms to reach the summit. With its dynamic environment and heart-pounding game"}]}, "developer_name": null, "developer_privacy_policy_url": "https://sites.google.com/view/volcanorunners/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Volcano Runners Studios", "support_website_url": null, "website_url": "https://sites.google.com/view/volcanorunners", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "7552483468165262"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1828999557620392"}]}, "baseline_offer": {"id": "1828999557620392"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1718146800, "status": "PUBLISHED", "id": "1828999557620392"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7650465681700373", "version": "12.0"}, "id": "806179734802011", "channel_name"