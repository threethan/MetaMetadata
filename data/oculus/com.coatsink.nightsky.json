_279984355777994_6220177160842248192_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T8r9tSigiL8Q7kNvgEM9xsk&_nc_ht=scontent.oculuscdn.com&oh=00_AYDshVrHh6yIqd7rWyekGbEmSsgalF6sBGRlRevBxEy6DA&oe=66E42388"}, {"file_name": "migrated_image.png", "id": "565763104015125", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162771_155781144947442_6179205208652906496_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tlPF8860Sl4Q7kNvgGBjFUX&_nc_ht=scontent.oculuscdn.com&oh=00_AYB0T3KP2OGMj4qoKk7ouwWKfpu-SvtTtgYlXHoWrVdVnw&oe=66E425D5"}, {"file_name": "migrated_image.png", "id": "216627796061106", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162707_520911398250041_5078287438648967168_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E4Z36eg2cssQ7kNvgGELE04&_nc_ht=scontent.oculuscdn.com&oh=00_AYBilimhl9PRM_8kizqnWxc5-TzniOn9mOJa5uRpohgxxw&oe=66E4256C"}, {"file_name": "migrated_image.png", "id": "207986917088966", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12533831_123389915014973_7783019969201045504_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p89ZIX1cPN8Q7kNvgHWYeAA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBKzC56cRH6wBPHkSjJxxALTZi4Z3t-xzXmRnpd1OinXQ&oe=66E43C8A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "a-night-sky-thumb.png", "id": "195532387724292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12504684_195532391057625_4101844924759015424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L-Q6co_jsW4Q7kNvgEdvxWv&_nc_ht=scontent.oculuscdn.com&oh=00_AYB9kjiaulGWlQMUcimRaUVq_L05QpgbBEvZWKvg6zodMw&oe=66E413A5"}, "display_name": "A Night Sky", "keywords": ["Night", "Sky", "Controller", "Free", "Beautiful"], "long_description": "Come hang out under the stars this holiday with all of your favorite characters in A Night Sky.\n\nYou are invited to relax on the edge of a peaceful vale, beside a crackling campfire, and beneath the open night sky - Connect the constellations to form patterns among the stars. As the different shapes are revealed, strange and wonderful creatures are brought to life. Watch and enjoy as your new discoveries stride, bound or glide around the hillside in an immersive and charming spectacle.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more.", "short_description": "Relax beneath the open sky and connect the constellations above using simple point and touch controls. With each new pattern discovered, a charming and wonderful creature is brought to life.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more."}]}, "developer_name": "Coatsink Software", "developer_privacy_policy_url": "http://coatsink.com/privacy-policy/", "developer_terms_of_service_url": "http://coatsink.com/terms/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://coatsink.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "992578931363341"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162766_171067100053714_8168250730033971200_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dsy32-yni1AQ7kNvgEadavC&_nc_ht=scontent.oculuscdn.com&oh=00_AYD2ANweXlVeCblo1QPhHezUmzOrpHkcyPR-iiSmV8R77A&oe=66E439A8"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false,