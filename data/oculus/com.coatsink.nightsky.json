_name": "A Night Sky", "keywords": ["Night", "Sky", "Controller", "Free", "Beautiful"], "long_description": "Come hang out under the stars this holiday with all of your favorite characters in A Night Sky.\n\nYou are invited to relax on the edge of a peaceful vale, beside a crackling campfire, and beneath the open night sky - Connect the constellations to form patterns among the stars. As the different shapes are revealed, strange and wonderful creatures are brought to life. Watch and enjoy as your new discoveries stride, bound or glide around the hillside in an immersive and charming spectacle.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more.", "short_description": "Relax beneath the open sky and connect the constellations above using simple point and touch controls. With each new pattern discovered, a charming and wonderful creature is brought to life.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more."}]}, "developer_name": "Coatsink Software", "developer_privacy_policy_url": "http://coatsink.com/privacy-policy/", "developer_terms_of_service_url": "http://coatsink.com/terms/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://coatsink.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "992578931363341"}, "rev