_279984355777994_6220177160842248192_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gC0Bb03U8BgQ7kNvgEkfEdF&_nc_ht=scontent.oculuscdn.com&oh=00_AYDkjtbQgeK7WbcvP4inDPuhgSmCdIGK2Kqy-DKOVCUriQ&oe=66DD8C08"}, {"file_name": "migrated_image.png", "id": "565763104015125", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162771_155781144947442_6179205208652906496_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9GcncSwa-MQQ7kNvgEBLCBO&_nc_ht=scontent.oculuscdn.com&oh=00_AYDDpp4VkwNkokFmKH2SBy6u0JydNWn1NPttFNFSfiEnPg&oe=66DD8E55"}, {"file_name": "migrated_image.png", "id": "216627796061106", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162707_520911398250041_5078287438648967168_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9qD91y662oMQ7kNvgHadSrV&_nc_ht=scontent.oculuscdn.com&oh=00_AYAwUJ25GuDcnY7KBWf3TTgrpPi2H7Vyo7AldL8HL287LQ&oe=66DD8DEC"}, {"file_name": "migrated_image.png", "id": "207986917088966", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12533831_123389915014973_7783019969201045504_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRRNWB_7tpwQ7kNvgFXRm_V&_nc_ht=scontent.oculuscdn.com&oh=00_AYAFSJMZqRs1_7oMw5IQUJtvJmVMYv58KneEZ4TTNYLlBw&oe=66DDA50A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "a-night-sky-thumb.png", "id": "195532387724292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12504684_195532391057625_4101844924759015424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZKQHpKuUojgQ7kNvgFtOkhQ&_nc_ht=scontent.oculuscdn.com&oh=00_AYATmpX3hhJRNyBWjjpM-pzUGdHHIhcvDEzMvYjnIBKA1g&oe=66DD7C25"}, "display_name": "A Night Sky", "keywords": ["Night", "Sky", "Controller", "Free", "Beautiful"], "long_description": "Come hang out under the stars this holiday with all of your favorite characters in A Night Sky.\n\nYou are invited to relax on the edge of a peaceful vale, beside a crackling campfire, and beneath the open night sky - Connect the constellations to form patterns among the stars. As the different shapes are revealed, strange and wonderful creatures are brought to life. Watch and enjoy as your new discoveries stride, bound or glide around the hillside in an immersive and charming spectacle.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more.", "short_description": "Relax beneath the open sky and connect the constellations above using simple point and touch controls. With each new pattern discovered, a charming and wonderful creature is brought to life.\n\nExpand your experience by opening DLC Chests in game to come face to face with a Kraken, Phoenix, Baby Golem and more."}]}, "developer_name": "Coatsink Software", "developer_privacy_policy_url": "http://coatsink.com/privacy-policy/", "developer_terms_of_service_url": "http://coatsink.com/terms/", "publisher_name": "Oculus Studios", "support_website_url": null, "website_url": "http://coatsink.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ADVENTURE", "CASUAL", "EXPLORATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "992578931363341"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/11162766_171067100053714_8168250730033971200_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q66WOAS9E-sQ7kNvgGoQST0&_nc_ht=scontent.oculuscdn.com&oh=00_AYBnVJO_gw5tlKjrxr3zc0PFVIzyMXlj2fv6mrVXyoQbcQ&oe=66DDA228"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false,