mMowBg&oe=66E4268C"}, {"file_name": "ScreenShot04_2560x1440.png", "id": "1270074803649292", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974514_1270074806982625_5335865005242226290_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=99yt5petNjsQ7kNvgE82i8x&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvK56P_EYdAu2842SoPR__X&oh=00_AYBLaqYt1rmmvN1Tlwv_DfnYg4VMXc0DDPri4E3a3n4ktQ&oe=66E412D1"}, {"file_name": "ScreenShot02_2560x1440.png", "id": "813144287027038", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036623_813144293693704_3049302096086576569_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k9em6DuxxkIQ7kNvgH8o3kd&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvK56P_EYdAu2842SoPR__X&oh=00_AYCgWuGgawhowBqwpBnn8SDOxhU7awyihJ-YIqupwTbjow&oe=66E42199"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Movie2560x1440.png", "id": "230455106575015", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974884_230455109908348_2198088300040870805_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3IHrnsoHQvIQ7kNvgFuQCcL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvK56P_EYdAu2842SoPR__X&oh=00_AYCSI260JbbuhkfuEeId96uft6SPfMbZwDe5HMbfqQphWA&oe=66E43225"}, "display_name": "Angry Maze VR", "keywords": [], "long_description": "The maze is angry. While playthings have evolved from paper and pencils to VR, maze gameplay has remained unchanged. Mazes have been underestimated and labeled as old-fashioned because their play methods haven't evolved. It's not that mazes themselves are outdated, but rather that their gameplay hasn't been updated. Could this be the reason why mazes are no longer played as much? That's where \"Angry Maze VR\" comes in, aiming to evolve mazes in sync with VR. Give it a go and experience the evolved maze in VR.", "short_description": "The maze is angry. You know what? It's not the maze that's old, it's us humans who can't evolve it. But fear not, because the maze is evolving with VR. Can you play in the evolved maze? Or are you stuck with the same old maze?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr/post/privacy-policy", "developer_terms_of_service_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr/post/terms-of-service", "publisher_name": "https://twitter.com/3DMazeXR", "support_website_url": null, "website_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8014952225292792"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031481_1012905860031105_6861378441154626568_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0jUd-MrSyQwQ7kNvgEczpZJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AvK56P_EYdAu2842SoPR__X&oh=00_AYABm97tT2Aued0-7MM1buzYlNW6_3exKEuPkByqdpRYEQ&oe=66E40C8B"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Angry Maze VR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1689622320, "lastRevision": {"nodes": [{"id": "6050907311697303", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "6050907288363972", "is_first_party": false, "enables_in_app_ads": false, "is_concept": f