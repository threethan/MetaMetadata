5fJ161EozZ-bJs_kBBExx_5kEw&oe=66CEFAD1"}, {"file_name": "ScreenShot02_2560x1440.png", "id": "813144287027038", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036623_813144293693704_3049302096086576569_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=B89hrFOh87oQ7kNvgFto04-&_nc_ht=scontent.oculuscdn.com&oh=00_AYDauAeLUpJiBNBPW49Y7UOh7GrYpkVWer8P86HamQrzKw&oe=66CF0999"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Movie2560x1440.png", "id": "230455106575015", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974884_230455109908348_2198088300040870805_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kllBFMqHq3YQ7kNvgE4rhYF&_nc_ht=scontent.oculuscdn.com&oh=00_AYD8UDLYov2C-dDMLhOSn4BQaOgTeu6OQ8xdHA-N-hkR3Q&oe=66CF1A25"}, "display_name": "Angry Maze VR", "keywords": [], "long_description": "The maze is angry. While playthings have evolved from paper and pencils to VR, maze gameplay has remained unchanged. Mazes have been underestimated and labeled as old-fashioned because their play methods haven't evolved. It's not that mazes themselves are outdated, but rather that their gameplay hasn't been updated. Could this be the reason why mazes are no longer played as much? That's where \"Angry Maze VR\" comes in, aiming to evolve mazes in sync with VR. Give it a go and experience the evolved maze in VR.", "short_description": "The maze is angry. You know what? It's not the maze that's old, it's us humans who can't evolve it. But fear not, because the maze is evolving with VR. Can you play in the evolved maze? Or are you stuck with the same old maze?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr/post/privacy-policy", "developer_terms_of_service_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr/post/terms-of-service", "publisher_name": "https://twitter.com/3DMazeXR", "support_website_url": null, "website_url": "https://3dmaze2020.wixsite.com/angry-mazes-vr", "category": null, "comfo