16B"}]}, "id": "814510050249699", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "221025937503459", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982519_221025940836792_1269083278177186502_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5WjeJ8ZBWIwQ7kNvgGHYOyL&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAc7RAsnGJOYD9fzAkGj-eJ0RXVTjLwEe5vGJQWlpUk-g&oe=67307FDD"}, {"file_name": "2.png", "id": "232910699541742", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001723_232910702875075_1489031726631562923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mc60m1Z-1qAQ7kNvgE0ReVf&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAicQatjZxgxvmTzwsW-tZ1-RKRDi2fVse9m1pV3SJMsQ&oe=6730A05C"}, {"file_name": "3.png", "id": "1230835514288480", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982544_1230835517621813_3119162884707279355_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iyD_wQzMwBAQ7kNvgEia1t6&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA6z82cEU8KomJram-p1mWHi9bxfRcCIvupfaWAY05zXQ&oe=6730A824"}, {"file_name": "5.png", "id": "809279907169207", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035353_809279910502540_1269059870080986797_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XkOPrrnl7s4Q7kNvgFGvLv_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBdywhV2RsK9pRf-tp8GYMwZZR-KqyVlKSQ46P4TaNNhw&oe=6730B05F"}, {"file_name": "4.png", "id": "990956528995853", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031452_990956532329186_7210068973129628967_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9ygDcdN1wjkQ7kNvgHIiyfn&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDbAtON9YaVBAvkdnGQUd4hkoCdJtGVIdUvXdHChCokvA&oe=6730B136"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560-1440.png", "id": "804447234337878", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974552_804447237671211_7269954362785864672_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dtqE2fHEV2MQ7kNvgH3sVTP&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAwRPx_hMd3l5_fZfzoWzrEJFFSjrB9VFyLaQ_PGLVz7A&oe=6730B4C5"}, "display_name": "Drakheir\uff08Alpha\uff09", "keywords": [], "long_description": "Gesture Magic, a Unique Game Experience!\nOver 10 magic gestures to combine freely. Cast magic with one or both hands, and master the elements of Cryo, Pyro, and Electro at will!\n\nUnique Elemental Activation gameplay, with just a snap of your fingers, trigger reactions instantly; explore the fascinating Elements Fusion, what sparks will fly when Pyro and Electro collide? Create your own combination skills!\n\nAn Adventure of Redemption and Salvation\uff01\nYou are troubled by a mysterious situation: while gaining powerful magic, it also consumes your life. It is the only method to go to the floating city and seek the help of the Sage. However, your journey is hindered by elves, who were instigated by the beautiful and mysterious Elf Princess. Is she an enemy or a friend? What kind of story will start?\n\nRogue Gameplay and Intense Boss Battles, Break Your Limits!\nGet random magic when you defeated all the enemies in this level. Different choices bring you different game experiences!\n\nThere are even more thrilling Boss battles waiting for you! An inspiring battle with the immense projection within the Mind Forest of the Elf Princess, rescue her from the shadows of the past!", "short_description": "Drakheir, a Roguelite-RPG VR game, the magical fantasy adventure base on the hand-tracking technology."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.5151vr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Shambala", "support_website_url": null, "website_url": "https://sidequestvr.com/app/16026/drakheiralpha", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_t