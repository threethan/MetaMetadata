186502_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-9fHvBiChd8Q7kNvgEsA0ez&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD6RtlXq2skFRAFZEi_eKHvw4pubPPMsR9Xg6ZfaRpT_g&oe=670CE75D"}, {"file_name": "2.png", "id": "232910699541742", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001723_232910702875075_1489031726631562923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SC148x6Dfg4Q7kNvgEFvP49&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDeVT6PlNKRMBt-_LF-bPmIPrTQpvs1bqwE2KQPfrHqg&oe=670D07DC"}, {"file_name": "3.png", "id": "1230835514288480", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982544_1230835517621813_3119162884707279355_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4cHmIXnbUiAQ7kNvgEx6YBo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDapTsspYlyArKJz9AudCrx5ls6_gK-kDLGqTMizG6Lmg&oe=670D0FA4"}, {"file_name": "5.png", "id": "809279907169207", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035353_809279910502540_1269059870080986797_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hWmgYNNOg-YQ7kNvgH0zYJ8&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhdrSeWXfZORtyFluJxYVGyoynPA3sW3tw0vOqaaMmrQ&oe=670D17DF"}, {"file_name": "4.png", "id": "990956528995853", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031452_990956532329186_7210068973129628967_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cm3PWfT_cSEQ7kNvgFEErdu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBL6_GNFhKZwqVNcY-GXbIL8bBv7CK_8iByTdc_BpC2Dg&oe=670D18B6"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560-1440.png", "id": "804447234337878", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974552_804447237671211_7269954362785864672_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TrFUM2y_c_4Q7kNvgFunRtp&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVIg6RN90kUtpwo2kjD8Nrul05gn7FJAi4aHm0IfEZbg&oe=670D1C45"}, "display_name": "Drakheir\uff08Alpha\uff09", "keywords": [], "long_description": "Gesture Magic, a Unique Game Experience!\nOver 10 magic gestures to combine freely. Cast magic with one or both hands, and master the elements of Cryo, Pyro, and Electro at will!\n\nUnique Elemental Activation gameplay, with just a snap of your fingers, trigger reactions instantly; explore the fascinating Elements Fusion, what sparks will fly when Pyro and Electro collide? Create your own combination skills!\n\nAn Adventure of Redemption and Salvation\uff01\nYou are troubled by a mysterious situation: while gaining powerful magic, it also consumes your life. It is the only method to go to the floating city and seek the help of the Sage. However, your journey is hindered by elves, who were instigated by the beautiful and mysterious Elf Princess. Is she an enemy or a friend? What kind of story will start?\n\nRogue Gameplay and Intense Boss Battles, Break Your Limits!\nGet random magic when you defeated all the enemies in this level. Different choices bring you different game experiences!\n\nThere are even more thrilling Boss battles waiting for you! An inspiring battle with the immense projection within the Mind Forest of the Elf Princess, rescue her from the shadows of the past!", "short_description": "Drakheir, a Roguelite-RPG VR game, the magical fantasy adventure base on the hand-tracking technology."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.5151vr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Shambala", "support_website_url": null, "website_url": "https://sidequestvr.com/app/16026/drakheiralpha", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": n