186502_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-9fHvBiChd8Q7kNvgHsdKmi&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYD1SwYo4cSAkST6rTCYvbsWZlHzvx82KDIEIRpKpx1a-g&oe=670B95DD"}, {"file_name": "2.png", "id": "232910699541742", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39001723_232910702875075_1489031726631562923_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SC148x6Dfg4Q7kNvgGWhBpl&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYD7QpEXzlcrSm5Z6UvEs57ikvhq9hPyhdZVAdobMQZosA&oe=670BB65C"}, {"file_name": "3.png", "id": "1230835514288480", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38982544_1230835517621813_3119162884707279355_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XACpoD1WEQcQ7kNvgGr3qqC&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBAeHyzm55UNYQDiO-x_vb_6Lx-OWf1vdT19Jw_-3-biA&oe=670BBE24"}, {"file_name": "5.png", "id": "809279907169207", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39035353_809279910502540_1269059870080986797_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IdVXybhMRGkQ7kNvgFQlRO9&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBfNsIhYmYG20bii3ak2QsDbbJ4Y-lFsoejWA40cIPdgw&oe=670BC65F"}, {"file_name": "4.png", "id": "990956528995853", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031452_990956532329186_7210068973129628967_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Cm3PWfT_cSEQ7kNvgGdTLcO&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBTErdwOyxnVRBUvT_fxW1mGUrwDgKU86Kdi3qY0Nn8IA&oe=670BC736"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560-1440.png", "id": "804447234337878", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974552_804447237671211_7269954362785864672_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TrFUM2y_c_4Q7kNvgECxqvu&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDwedg3-e6p9Mzz9z-EzFxZQ-H_HMEEbzOvgmz1Xexf5A&oe=670BCAC5"}, "display_name": "Drakheir\uff08Alpha\uff09", "keywords": [], "long_description": "Gesture Magic, a Unique Game Experience!\nOver 10 magic gestures to combine freely. Cast magic with one or both hands, and master the elements of Cryo, Pyro, and Electro at will!\n\nUnique Elemental Activation gameplay, with just a snap of your fingers, trigger reactions instantly; explore the fascinating Elements Fusion, what sparks will fly when Pyro and Electro collide? Create your own combination skills!\n\nAn Adventure of Redemption and Salvation\uff01\nYou are troubled by a mysterious situation: while gaining powerful magic, it also consumes your life. It is the only method to go to the floating city and seek the help of the Sage. However, your journey is hindered by elves, who were instigated by the beautiful and mysterious Elf Princess. Is she an enemy or a friend? What kind of story will start?\n\nRogue Gameplay and Intense Boss Battles, Break Your Limits!\nGet random magic when you defeated all the enemies in this level. Different choices bring you different game experiences!\n\nThere are even more thrilling Boss battles waiting for you! An inspiring battle with the immense projection within the Mind Forest of the Elf Princess, rescue her from the shadows of the past!", "short_description": "Drakheir, a Roguelite-RPG VR game, the magical fantasy adventure base on the hand-tracking technology."}]}, "developer_name": null, "developer_privacy_policy_url": "http://privacy.5151vr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Shambala", "support_website_url": null, "website_url": "https://sidequestvr.com/app/16026/drakheiralpha", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "961172191044986"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": null, "recommended_graphics": n