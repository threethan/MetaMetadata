c_ht=scontent.oculuscdn.com&oh=00_AYAd9yWF80ZqBhRvK_DV3e2FebmkmXZJxy9CMl8qZ-HqRQ&oe=66D98DCA"}, {"file_name": "migrated_image.png", "id": "890739608032486", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003249_2181001278783157_2434954850027438080_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TFOUvZDGi8cQ7kNvgHdDJBR&_nc_ht=scontent.oculuscdn.com&oh=00_AYD7hbyFDInCp-bIFgWTuL4pxWB3wqyyLhe-zYyDrL8W8w&oe=66D986A4"}, {"file_name": "migrated_image.png", "id": "874604876303169", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974511_141503626767263_6500919738254753792_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m-Qqq-DNqSYQ7kNvgHfMVsv&_nc_ht=scontent.oculuscdn.com&oh=00_AYDf98h59srvkvqpL0iDWNt3rbDK3oXMQ2P8vmq0LR13hQ&oe=66D9B3E7"}, {"file_name": "migrated_image.png", "id": "199646688035908", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_273999916617177_8847344918490775552_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TFpHyuPuIrEQ7kNvgFslBTz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCahfWxOqAcXhZ8amfVmD2XkjwOxp1AcJmJ7VsfCHuSTA&oe=66D98C4B"}, {"file_name": "migrated_image.png", "id": "197110371576830", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974629_285356768848572_5082100343110631424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H39fVWtog5oQ7kNvgGa2tbm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQIkus6a0YwrNl05s0QXVZYAWA2QyOpCRRa90CkBxnJg&oe=66D9A042"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Traveling While Black", "keywords": ["Travel", "Freedom", "Sundance", "Felix", "Movie"], "long_description": "Traveling While Black is a cinematic VR experience that immerses the viewer in the long history of restriction of movement for black Americans and the creation of safe spaces in our communities.\n\nAcademy Award winner Roger Ross Williams and Emmy Award-winning Felix & Paul Studios' film transports you to historic Ben's Chili Bowl in Washington DC. The viewer shares an intimate series of moments with several of the patrons of Ben's as they reflect on their experiences of restricted movement and race relations in the U.S. \n\nConfronting the way we understand and talk about race in America, Traveling While Black highlights the urgent need to not only remember the past but to learn from it, and facilitate a dialogue about the challenges minority travelers still face today.", "short_description": "Traveling While Black is a cinematic VR experience that immerses the viewer in the long history of restriction of movement for black Americans and the creation of safe spaces in our communities. Visit historic Ben's Chili Bowl and join patrons as they share and reflect on their experiences. Confronting the way we understand and talk about race in America, Traveling While Black highlights the urgent need to facilitate a dialogue about the challenges minority travelers still face today."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "https://www.felixandpaul.com/privacy", "developer_terms_of_service_url": "https://www.felixandpaul.com/license", "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "MOVIE", "DOCUMENTARY_HISTORY"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "630758034681370"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "CANCELLED", "id": "2355390624481614"}, {"status": "CANCELLED", "id": "298040887569360"},