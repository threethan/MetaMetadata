oculuscdn.com&oh=00_AYDf98h59srvkvqpL0iDWNt3rbDK3oXMQ2P8vmq0LR13hQ&oe=66D9B3E7"}, {"file_name": "migrated_image.png", "id": "605147137007614", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974629_285356768848572_5082100343110631424_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H39fVWtog5oQ7kNvgGa2tbm&_nc_ht=scontent.oculuscdn.com&oh=00_AYAQIkus6a0YwrNl05s0QXVZYAWA2QyOpCRRa90CkBxnJg&oe=66D9A042"}, {"file_name": "migrated_image.png", "id": "549885342552314", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974594_273999916617177_8847344918490775552_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TFpHyuPuIrEQ7kNvgFslBTz&_nc_ht=scontent.oculuscdn.com&oh=00_AYCahfWxOqAcXhZ8amfVmD2XkjwOxp1AcJmJ7VsfCHuSTA&oe=66D98C4B"}, {"file_name": "migrated_image.png", "id": "548259012475995", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982661_291455104904289_1982556500106674176_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_Cd_gjGR6VsQ7kNvgGwWYHu&_nc_ht=scontent.oculuscdn.com&oh=00_AYAd9yWF80ZqBhRvK_DV3e2FebmkmXZJxy9CMl8qZ-HqRQ&oe=66D98DCA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "/tmp/w17Ljp", "id": "548979745613798", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974860_548979748947131_901371776955580416_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CdnBhEYMPEgQ7kNvgHyWVDJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYCj_U2mnO8CBhk04t50MvTTuMRNpvSVQ9GVJXtL9OTQQg&oe=66D983E6"}, "display_name": "Traveling While Black", "keywords": ["Travel", "Freedom", "Sundance", "Felix", "Movie"], "long_description": "Traveling While Black is a cinematic VR experience that immerses the viewer in the long history of restriction of movement for black Americans and the creation of safe spaces in our communities.\n\nAcademy Award winner Roger Ross Williams and Emmy Award-winning Felix & Paul Studios' film transports you to historic Ben's Chili Bowl in Washington DC. The viewer shares an intimate series of moments with several of the patrons of Ben's as they reflect on their experiences of restricted movement and race relations in the U.S. \n\nConfronting the way we understand and talk about race in America, Traveling While Black highlights the urgent need to not only remember the past but to learn from it, and facilitate a dialogue about the challenges minority travelers still face today.", "short_description": "Traveling While Black is a cinematic VR experience that immerses the viewer in the long history of restriction of movement for black Americans and the creation of safe spaces in our communities. Visit historic Ben's Chili Bowl and join patrons as they share and reflect on their experiences. Confronting the way we understand and talk about race in America, Traveling While Black highlights the urgent need to facilitate a dialogue about the challenges minority travelers still face today."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "http://privacy.felixandpaul.com/", "developer_terms_of_service_url": null, "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2837265163266059", "context_category": "ENTERTAINMENT"}, "context_topics": [{"id": "2777382702530830"}, {"id": "1283811691952063"}, {"id": "439804597133915"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["DOCUMENTARY_HISTORY", "MOVIE", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GEAR_VR_CONTROLLER", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6705593606188739"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scont