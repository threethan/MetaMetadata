2_0.png", "id": "1009776593911585", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572953_1009776603911584_4024646650142680318_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tOp8wNzDIqsQ7kNvgEKSqqY&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCsDJFVWYX2WSYbEr7qeW8GX0GarOfYz12vvgPXuOCPdw&oe=675D628D"}, {"file_name": "CoverArt_Screenshot_04_0.png", "id": "1482008166083897", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75411992_1482008169417230_1382339419194635181_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EC_49A2_UnoQ7kNvgEs-HgB&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBwT-4o5fBSshAbb_U5-Jl3yZDSXTc0jBHPqidqv8xKXQ&oe=675D7342"}, {"file_name": "CoverArt_Screenshot_03_0.png", "id": "466465192573352", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001725_466465195906685_6524410999576019529_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YZkt94x0oqQQ7kNvgFnB4_M&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCUC_hlW_X6GIJ1ZzAHKV7DbizeGD0GEn4KjxXGDCpclQ&oe=675D63D3"}, {"file_name": "CoverArt_Screenshot_01_0.png", "id": "1779171239273279", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39003224_1779171242606612_2456133946134135166_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=S1zDfj2uo2sQ7kNvgG-ebha&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBj7b6DxzIF1gvKafFGCLGjvuwAh8b2-V5BhbzJCVow9A&oe=675D8998"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_0.png", "id": "1502591547345462", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75416835_1502591550678795_714131516175272875_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=75-mUWl5hdAQ7kNvgEMVq6m&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCll5yDVJjutz36YYF7_Fcoghk99mDwrf7HmaNp_gPcvA&oe=675D7503"}, "display_name": "Swivel Gun XR: Treasure Hunt", "keywords": [], "long_description": "Gather 'round, for I've got a tale to tell ye that'll shiver yer timbers and set yer souls ablaze with the spirit of adventure! \n\nWelcome to Swivel Gun XR: Treasure Hunt, the game that'll have ye plunderin' riches beyond yer wildest dreams right from the comfort of yer own home! \n\nAye, ye heard me right, me hearties! No need to brave the perils of the open sea when the treasure's waitin' right at yer doorstep! But beware, me mateys, for the hunt won't be easy! Ye'll need yer wits about ye as ye navigate treacherous waters, battle bloodthirsty scallywags, and unravel the mysteries of the deep! \n\nSo weigh anchor, me hearties, and set sail for adventure like never before! With Swivel Gun XR: Treasure Hunt, the world be yer oyster, and the plunder be ripe for the takin'! \n\nSo tell me, me hearties: where will ye hunt next?", "short_description": "Ahoy, me hearties! Dive into Swivel Gun XR: Treasure Hunt, the game where ye plunder riches from home! Navigate treacherous waters, battle scallywags, and unravel deep mysteries. Set sail for adventure and claim the treasure that awaits! \n\nWhere will ye hunt next?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelsofeight.wixsite.com/lander/sgth-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Pixels of Eight LLC", "support_website_url": null, "website_url": "https://pixelsofeight.wixsite.com/lander", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7574005185956