FdWwQ7kNvgHUPYIl&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYASmeuC7GGJGe3hkAFZ1X8KBh_brRk3EZglp2iKy7h72A&oe=66EC2019"}, {"file_name": "CoverArt_Screenshot_02_0.png", "id": "1009776593911585", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572953_1009776603911584_4024646650142680318_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YIHlzKDERVMQ7kNvgFt1lk0&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYCWXaHNel2q08mRiX9hf0XrjN_Isv9ZYEYMUbs-UWSmbA&oe=66EC018D"}, {"file_name": "CoverArt_Screenshot_04_0.png", "id": "1482008166083897", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75411992_1482008169417230_1382339419194635181_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6EUxuxUYHMsQ7kNvgFLE2mV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYAaJi9PwaDqnd1VAzgGKTf4J-j26NZcDroBg7NpEwO4-Q&oe=66EC1242"}, {"file_name": "CoverArt_Screenshot_03_0.png", "id": "466465192573352", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001725_466465195906685_6524410999576019529_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mjsoWBP8NsQQ7kNvgGQeZ0r&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYAh_5Ng3o7F-d63O1lnroq_a2RMg5uG7OsCiEQJvIWlSQ&oe=66EC02D3"}, {"file_name": "CoverArt_Screenshot_01_0.png", "id": "1779171239273279", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003224_1779171242606612_2456133946134135166_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WWs6sTjSuPQQ7kNvgH-bReP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYC8POoIHi5F330v38OgBVyMg3MioucRykdTVQ5FVIkAqA&oe=66EC2898"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverArt_Landscape_0.png", "id": "1502591547345462", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75416835_1502591550678795_714131516175272875_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4kFLHfg1UZMQ7kNvgGb52dq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AUlAvERfCMFEqVhgCkH7DpN&oh=00_AYCPYPNB3L-MJPfgJDmZCGJ9T4Qx3VHEt9hhFOek4d4T2w&oe=66EC1403"}, "display_name": "Swivel Gun XR: Treasure Hunt", "keywords": [], "long_description": "Gather 'round, for I've got a tale to tell ye that'll shiver yer timbers and set yer souls ablaze with the spirit of adventure! \n\nWelcome to Swivel Gun XR: Treasure Hunt, the game that'll have ye plunderin' riches beyond yer wildest dreams right from the comfort of yer own home! \n\nAye, ye heard me right, me hearties! No need to brave the perils of the open sea when the treasure's waitin' right at yer doorstep! But beware, me mateys, for the hunt won't be easy! Ye'll need yer wits about ye as ye navigate treacherous waters, battle bloodthirsty scallywags, and unravel the mysteries of the deep! \n\nSo weigh anchor, me hearties, and set sail for adventure like never before! With Swivel Gun XR: Treasure Hunt, the world be yer oyster, and the plunder be ripe for the takin'! \n\nSo tell me, me hearties: where will ye hunt next?", "short_description": "Ahoy, me hearties! Dive into Swivel Gun XR: Treasure Hunt, the game where ye plunder riches from home! Navigate treacherous waters, battle scallywags, and unravel deep mysteries. Set sail for adventure and claim the treasure that awaits! \n\nWhere will ye hunt next?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://pixelsofeight.wixsite.com/lander/sgth-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Pixels of Eight LLC", "support_website_url": null, "website_url": "https://pixelsofeight.wixsite.com/lander", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "1592192974313489"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommend