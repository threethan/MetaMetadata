content.oculuscdn.com/v/t64.5771-25/38974735_277067237398133_5801766461525080614_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I3jk5x8JX3gQ7kNvgERgU9x&_nc_ht=scontent.oculuscdn.com&oh=00_AYA275ZcvIlVS5wo2C9PIwRGKW9oO-GF24hoMdS4f4ZimA&oe=66D2EE2C"}, {"file_name": "screenshot5.png", "id": "368575211162224", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974604_368575214495557_6761032703570560811_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SrVGplAbaUMQ7kNvgGvgr6e&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtoBArXZ_-Fk3ZwJvm4pKxzD67I5yDc9Pz9ccq7yTm2w&oe=66D2EB9B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video cover.png", "id": "140862334676181", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984465_140862338009514_8105447240219103647_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7u4Ci2ZYtkEQ7kNvgHQMSs6&_nc_ht=scontent.oculuscdn.com&oh=00_AYAtGekELSY_XIPXCVd8XD-UxpUtUwz18G8aJXWKTglkWg&oe=66D2EB3B"}, "display_name": "MageVR", "keywords": [], "long_description": "Our products use real-time speech recognition as the core interactive method, creating a relaxing and natural environment for you. In this world, we encourage you to explore freely. At the same time, you will meet a group of virtual partners with different skin colors, different personalities, and different images. They will accompany you and help you learn. Here you can see:\n\n-Learning content on multiple topics\n-Gamified learning interactive experience,\n-A group of learning partners with different personalities will accompany you on your exploration journey\n-Complete learning, feedback and progress system\n-This function of wrong questions strengthens the learning effect\n-Score challenge and hit the excellent learning record of this course!\n\nCome join MageVR!", "short_description": "MageVR-Knowledge and connection are everywhere!\n\nMageVR is a virtual learning platform. We integrate different subjects and knowledge into our content design. Both native speakers and non-native speakers can use MageVR To find interesting and rich learning content, we hope to use VR to redefine the way you acquire knowledge from this world, and at the same time bring you a unique learning experience!"}]}, "developer_name": "Haopeng Yang", "developer_privacy_policy_url": "https://www.yumpu.com/s/B2f6jvgKUqeyXYcI", "developer_terms_of_service_url": null, "publisher_name": "Haopeng Yang", "support_website_url": null, "website_url": "https://www.dengxianvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "322787426528287"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974864_832472680682260_3128598979071795485_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZZTve1PZb3QQ7kNvgFZhgz-&_nc_ht=scontent.oculuscdn.com&oh=00_AYBzrozb-9TVhiuw7jGgMqvP0sVUS2e6OGPPN-Jv9YgwXg&oe=66D2EDFF"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "MageVR", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [], "release_date": 1623783986, "lastRevision": {"nodes": [{"id": "281420550007721", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3701130973267562"