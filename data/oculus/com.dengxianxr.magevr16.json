067237398133_5801766461525080614_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ichd94NUBfAQ7kNvgGn6QWV&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCz5W0au6BE5Uvi0RO6V5Pmsi-jUuO2RaskssXe6y6ttA&oe=6754212C"}, {"file_name": "screenshot5.png", "id": "368575211162224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974604_368575214495557_6761032703570560811_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=T4ekmG2cCgUQ7kNvgGcifp_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmmUnR5b4NeRdYxmhICseTX6PkHJdzJudmpgClacYaCg&oe=67541E9B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video cover.png", "id": "140862334676181", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984465_140862338009514_8105447240219103647_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nD8uDN-6pGIQ7kNvgHFlQcJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhM2S46NwkxcTaykJnAqhzURfHkVZqGN5I8c1UYGq8xA&oe=67541E3B"}, "display_name": "MageVR", "keywords": [], "long_description": "Our products use real-time speech recognition as the core interactive method, creating a relaxing and natural environment for you. In this world, we encourage you to explore freely. At the same time, you will meet a group of virtual partners with different skin colors, different personalities, and different images. They will accompany you and help you learn. Here you can see:\n\n-Learning content on multiple topics\n-Gamified learning interactive experience,\n-A group of learning partners with different personalities will accompany you on your exploration journey\n-Complete learning, feedback and progress system\n-This function of wrong questions strengthens the learning effect\n-Score challenge and hit the excellent learning record of this course!\n\nCome join MageVR!", "short_description": "MageVR-Knowledge and connection are everywhere!\n\nMageVR is a virtual learning platform. We integrate different subjects and knowledge into our content design. B