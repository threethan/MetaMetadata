x7GNevsd2m0Q7kNvgEGA2xm&_nc_ht=scontent.oculuscdn.com&oh=00_AYBttAtp_Wx0i7_SZPq8wEph2_utV5RZuurRzgehJCFWhw&oe=66D1BD91"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video cover.png", "id": "278739560382041", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974560_278739563715374_844257912761203850_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cAcQAMhDnkkQ7kNvgGYlkMl&_nc_ht=scontent.oculuscdn.com&oh=00_AYAfUkcUxiXBOoZAZlT-Y9K9SS-9bsA-P_XTpfGjX4wedQ&oe=66D1BE15"}, "display_name": "MageVR", "keywords": [], "long_description": "\u6211\u4eec\u7684\u4ea7\u54c1\u91c7\u7528\u4ee5\u5b9e\u65f6\u8bed\u97f3\u8bc6\u522b\u4e3a\u6838\u5fc3\u7684\u4ea4\u4e92\u65b9\u5f0f\uff0c\u4e3a\u4f60\u521b\u9020\u4e86\u4e00\u4e2a\u8f7b\u677e\u81ea\u7136\u7684\u73af\u5883\uff0c\u5728\u8fd9\u4e2a\u4e16\u754c\u4e2d\uff0c\u6211\u4eec\u9f13\u52b1\u4f60\u81ea\u7531\u7684\u63a2\u7d22\u3002\u540c\u65f6\uff0c\u4f60\u4f1a\u9047\u5230\u4e00\u7fa4\u4e0d\u540c\u80a4\u8272\u3001\u4e0d\u540c\u6027\u683c\u3001\u4e0d\u540c\u5f62\u8c61\u7684\u865a\u62df\u4f19\u4f34\uff0c\u4ed6\u4eec\u5c06\u966a\u4f34\u7740\u4f60\uff0c\u5e2e\u52a9\u4f60\u5b66\u4e60\uff0c\u5728\u8fd9\u91cc\u4f60\u53ef\u4ee5\u770b\u5230\uff1a\n\n-\t\u591a\u4e2a\u4e3b\u9898\u7684\u5b66\u4e60\u5185\u5bb9\n-\t\u6e38\u620f\u5316\u7684\u5b66\u4e60\u4e92\u52a8\u4f53\u9a8c\u3001\n-\t\u4e00\u7fa4\u4e2a\u6027\u4e0d\u540c\u7684\u5b66\u4e60\u4f19\u4f34\uff0c\u966a\u4f34\u4f60\u7684\u63a2\u7d22\u4e4b\u8def\n-\t\u5b8c\u6574\u7684\u5b66\u4e60\u3001\u53cd\u9988\u3001\u8fdb\u6b65\u7cfb\u7edf\n-\t\u9519\u9898\u672c\u529f\u80fd\uff0c\u5f3a\u5316\u5b66\u4e60\u6548\u679c\n-\t\u5206\u6570\u6311\u6218\uff0c\u51b2\u51fb\u672c\u8bfe\u7a0b\u7684\u4f18\u79c0\u5b66\u4e60\u7eaa\u5f55\u5427\uff01\n\n\u5feb\u6765\u52a0\u5165MageVR\u5427\uff01", "short_description": "MageVR \u2013 \u77e5\u8bc6\u548c\u8fde\u63a5\u65e0\u5904\u4e0d\u5728\uff01\n\nMageVR\u662f\u4e00\u4e2a\u865a\u62df\u5b66\u4e60\u5e73\u53f0\uff0c\u6211\u4eec\u5c06\u4e0d\u540c\u7684\u5