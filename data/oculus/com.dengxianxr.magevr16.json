67237398133_5801766461525080614_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UHzRdMsjT_gQ7kNvgF150QF&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDvTx4RyqhAfR316gKKr5B310v4_ZbIQ4fPnTv2trwdjQ&oe=676D2DAC"}, {"file_name": "screenshot5.png", "id": "368575211162224", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974604_368575214495557_6761032703570560811_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y5Rjxmdnp4wQ7kNvgGqdOD8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDK3YiFl3Sstncq0X741SYL3TH6eA7DaL5x7UvVfKK66Q&oe=676D2B1B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video cover.png", "id": "140862334676181", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984465_140862338009514_8105447240219103647_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dxJPok947yYQ7kNvgEHkOxp&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBKfn8OxLuV2ba9N2n9ahooLuEwFGRyVRuquwkgfCzPOQ&oe=676D2ABB"}, "display_name": "MageVR", "keywords": [], "long_description": "Our products use real-time speech recognition as the core interactive method, creating a relaxing and natural environment for you. In this world, we encourage you to explore freely. At the same time, you will meet a group of virtual partners with different skin colors, different personalities, and different images. They will accompany you and help you learn. Here you can see:\n\n-Learning content on multiple topics\n-Gamified learning interactive experience,\n-A group of learning partners with different personalities will accompany you on your exploration journey\n-Complete learning, feedback and progress system\n-This function of wrong questions strengthens the learning effect\n-Score challenge and hit the excellent learning record of this course!\n\nCome join MageVR!", "short_description": "MageVR-Knowledge and connection are everywhere!\n\nMageVR is a virtual learning platform. We integrate different subjects and knowledge into our content design. Bo