_AYBt1yUFibHu-dt9d1jD0DgT8KuKvrhmM2e5MaEAHJhdew&oe=670274FD"}, {"file_name": "screenshots-3.png", "id": "3218780311558530", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974560_3218780314891863_344226442517322661_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZeLimiNhpDMQ7kNvgGyQOzD&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCv7fCFCb-OmsDtaLduXxXJ9SOoKJdTsXs7kRjVyc80gQ&oe=67027CE7"}, {"file_name": "screenshots-4.png", "id": "277067234064800", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974735_277067237398133_5801766461525080614_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HF3J9VZnUc4Q7kNvgF_kBi5&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCXggqTwjzSzF6QUcMw920_fMcAZV0nMdXK2y2eg_fL2g&oe=6702642C"}, {"file_name": "screenshot5.png", "id": "368575211162224", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974604_368575214495557_6761032703570560811_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dcwPaqkZ-usQ7kNvgG-EBXh&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCeKlilHHIFXs7ooI8S9EvGPEYKUd-CwvPI4q7Mnf30gA&oe=6702619B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "video cover.png", "id": "140862334676181", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38984465_140862338009514_8105447240219103647_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V9VTPvYyA3EQ7kNvgG31E9e&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBlMdMMuxiHmf4pJI_c9KI0BATcKttAwxwNiZjAsAC3pA&oe=6702613B"}, "display_name": "MageVR", "keywords": [], "long_description": "Our products use real-time speech recognition as the core interactive method, creating a relaxing and natural environment for you. In this world, we encourage you to explore freely. At the same time, you will meet a group of virtual partners with different skin colors, different personalities, and different images. They will accompany you and help you learn. Here you can see:\n\n-Learning content on multiple topics\n-Gamified learning interactive experience,\n-A group of learning partners with different personalities will accompany you on your exploration journey\n-Complete learning, feedback and progress system\n-This function of wrong questions strengthens the learning effect\n-Score challenge and hit the excellent learning record of this course!\n\nCome join MageVR!", "short_description": "MageVR-Knowledge and connection are everywhere!\n\nMageVR is a virtual learning platform. We integrate different subjects and knowledge into our content design. Both native speakers and non-native speakers can use MageVR To find interesting and rich learning content, we hope to use VR to redefine the way you acquire knowledge from this world, and at the same time bring you a unique learning experience!"}]}, "developer_name": "Haopeng Yang", "developer_privacy_policy_url": "https://www.yumpu.com/s/B2f6jvgKUqeyXYcI", "developer_terms_of_service_url": null, "publisher_name": "Haopeng Yang", "support_website_url": null, "website_url": "https://www.dengxianvr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EXPLORATION", "EDUCATIONAL", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "322787426528287"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974864_832472680682260_3128598979071795485_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XGAZ5a-sayEQ7kNvgFftjwx&_nc_ht=scontent