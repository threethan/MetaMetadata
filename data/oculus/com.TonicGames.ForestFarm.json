sfKVIfVJiafCyG1dvG7Yw&oe=66CEFCA6"}, "display_name": "Forest Farm", "keywords": [], "long_description": "Forest Farm is a farming game that seeks to be different.\n\nThe farming mechanics are based on regenerative agriculture and will encourage players to manage their farm intelligently. Cut down all the trees? Now you'll have to regrow them. Need more vegetable plots? Then get to making soil. Get ready to bring life to the Forest Farm and make it a thriving ecosystem.\n\nThere will be multiple activities to master, from growing vegetables, to logging and clearing the forest, to fishing at the river. Each of these will mimic the activities on an actual Forest Farm and I hope it is something different for the gaming community.", "short_description": "The definitive VR farming sim. Learn to manage your land and grow all plants from seed to harvest, including trees!"}]}, "developer_name": "Nic Schubert", "developer_privacy_policy_url": "http://tonicgamesaustralia.com/ForestFarm-privacypolicy.html", "developer_terms_of_service_url": "http://tonicgamesaustralia.com/ForestFarm-termsandconditions.html", "publisher_name": "Tonic Games Australia", "support_website_url": null, "website_url": "https://tonicgamesaustralia.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "SIMULATION", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1426268414496088"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "516180460967079"}, {"status": "PUBLISHED