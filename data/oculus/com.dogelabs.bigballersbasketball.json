47486193790_151222580142976334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H2nrZ9J6uRcQ7kNvgGBui6y&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2u7Zho24tlE-o2IqQKa4fhJTSPvGOLnANY2NYsxTDmw&oe=67850558"}, {"file_name": "dribbling.png", "id": "565302594470834", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57568668_565302597804167_2403830162561096493_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y4bIXdXkToYQ7kNvgGcrM9I&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCI8Zrlw1FXs6u2BU_Cbr24WNa3dapwdpl9nxs3Np5CAw&oe=67850D67"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "dunk_screenshot.png", "id": "854696385153934", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003271_854696388487267_8661722327325916084_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uRLQZKw2fRUQ7kNvgGyCUdS&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB7ykuigY3pf01flxbXwMhyQjU-Ycp2qH9GNOhEUZe89A&oe=67851121"}, "display_name": "Big Ballers Basketball", "keywords": [], "long_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot or even your sky hook! Use a natural basketball stroke and Big Ballers Basketball's realistic physics engine will do the rest. Make sure to hold the grip button until the top of your release. Try the 1 minute drill minigame or experiment with reduced gravity. The court is yours! Dribbling, multiplayer and even Shaq mode. It's the easiest way to have fun, socialize and exercise at the same time.\n\nAs you shoot enjoy the music from your very own Boom Box. Feeling a little tired? Big Baller's has got you covered you can play seated or standing. ", "short_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot, sky hook and your DUNK! Oh yeah, there's multiplayer too. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://do