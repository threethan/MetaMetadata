47486193790_151222580142976334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rPmUM-0O4kUQ7kNvgFtseN_&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAWesd8UptDvECkkHnHT6cEbz9gKA0-f0UEIgV8c2BE3A&oe=6787A858"}, {"file_name": "dribbling.png", "id": "565302594470834", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/57568668_565302597804167_2403830162561096493_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y4bIXdXkToYQ7kNvgEph7Or&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYDuGeAb-r8Z7oh65MevRSc-tabOKsu86JOibY_Vlso5hQ&oe=6787B067"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "dunk_screenshot.png", "id": "854696385153934", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39003271_854696388487267_8661722327325916084_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gAVkC8l-KxAQ7kNvgFbc4hb&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC2p1jdCcyTKsF-dSMY4XT-OW6JWWs6b5b2b8__ejlz_w&oe=6787B421"}, "display_name": "Big Ballers Basketball", "keywords": [], "long_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot or even your sky hook! Use a natural basketball stroke and Big Ballers Basketball's realistic physics engine will do the rest. Make sure to hold the grip button until the top of your release. Try the 1 minute drill minigame or experiment with reduced gravity. The court is yours! Dribbling, multiplayer and even Shaq mode. It's the easiest way to have fun, socialize and exercise at the same time.\n\nAs you shoot enjoy the music from your very own Boom Box. Feeling a little tired? Big Baller's has got you covered you can play seated or standing. ", "short_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot, sky hook and your DUNK! Oh yeah, there's multiplayer too. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://do