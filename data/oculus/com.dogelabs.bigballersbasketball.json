vered you can play seated or standing. ", "short_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot, sky hook and your DUNK! Oh yeah, there's multiplayer too. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1OJOSmAlYAxfsAdHu14Js2SWAe8pkr3AuREebGQ4Dh2g", "developer_terms_of_service_url": null, "publisher_name": "Doge Labs", "support_website_url": null, "website_url": "https://linktr.ee/bigballersbasketballvr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ACTION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5071989819487711"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PENDING", "id": "694848165533347"}, {"status": "PUBLISHED", "id": "322898349536340"}, {"status": "PUBLISHED", "id": "428686062201362"}, {"status": "PUBLISHED", "id": "1349335335520112"}, {"status": "PUBLISHED", "id": "452680853106758"}, {"status": "PUBLISHED", "id": "356469582521060"}, {"status": "PUBLISHED", "id": "610104747353581"}, {"status": "CANCELLED", "id": "595992122730972"}, {"status": "PUBLISHED", "id": "796486178156150"}, {"status": "PUBLISHED", "id": "2320557041442548"}, {"status": "PUBLISHED", "id": "169864212872588"}, {"status": "PUBLISHED", "id": "611948160010088"}, {"status": "PUBLISHED", "id": "1020295572169559"}]}, "baseline_offer": {"id": "169864212872588"}, "is_approved": true, "firstOffer": {"nodes": [