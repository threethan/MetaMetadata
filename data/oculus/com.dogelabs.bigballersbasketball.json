271547486193790_151222580142976334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rPmUM-0O4kUQ7kNvgHaeqkA&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCWLPQ316FTDtBC9QLWZ9M98rP48BV-IG7xWanpDU5KLQ&oe=678656D8"}, {"file_name": "dribbling.png", "id": "565302594470834", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57568668_565302597804167_2403830162561096493_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y4bIXdXkToYQ7kNvgEIv0qZ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC7h5h-ypd4Vtwq6yiNactAEDx9OP2ZRQC76Pf4jhZ2Pw&oe=67865EE7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "dunk_screenshot.png", "id": "854696385153934", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39003271_854696388487267_8661722327325916084_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uRLQZKw2fRUQ7kNvgG2afUY&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCIbZJKe9LC7bYGirjXBeCtV6v4hsqq73gMpXxn2uAhMA&oe=678662A1"}, "display_name": "Big Ballers Basketball", "keywords": [], "long_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot or even your sky hook! Use a natural basketball stroke and Big Ballers Basketball's realistic physics engine will do the rest. Make sure to hold the grip button until the top of your release. Try the 1 minute drill minigame or experiment with reduced gravity. The court is yours! Dribbling, multiplayer and even Shaq mode. It's the easiest way to have fun, socialize and exercise at the same time.\n\nAs you shoot enjoy the music from your very own Boom Box. Feeling a little tired? Big Baller's has got you covered you can play seated or standing. ", "short_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot, sky hook and your DUNK! Oh yeah, there's multiplayer too. "}]}, "developer_name": null, "developer_privacy_policy_url": "https: