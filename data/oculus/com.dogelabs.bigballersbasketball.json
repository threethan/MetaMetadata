=67407A09"}, {"file_name": "03.png", "id": "421465910493729", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982469_421465913827062_5336444835991613147_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_7Qw6rkoL0IQ7kNvgHQyunH&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAf1-WMICxqlij6bPq88hI6ULsAoTUVY7JH31PeyFCbtA&oe=674067F8"}, {"file_name": "ASSET-temp.png", "id": "7036838179709959", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75443238_7036838183043292_4028150758810939956_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=L2sz5fyIX10Q7kNvgEcjisp&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCqh3SghwDEA1kj0By2TS37c7DmKKhoVWrw2Kx_tJKGTQ&oe=6740743F"}, {"file_name": "ballers-arena.png", "id": "1393923774644849", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031627_1393923777978182_8033474185708069791_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XYWWYoSFmfUQ7kNvgF2A337&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBLjq4IBl7WEUiJaFOQpavGh5Lf15mY6DFN9dkG0YaaiQ&oe=67405832"}, {"file_name": "render6 (2).png", "id": "743056764091566", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982585_743056767424899_6555961347991160068_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WjDA0Q83ukwQ7kNvgGDqed-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDs0gmw0ehjVMoQMRwWHlHBDbKFOPzIk_PvwvKOcsTLLA&oe=674073AA"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "bbvr-Cover Art Landscape (1).png", "id": "1184208302971120", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031420_1184208306304453_962545794958547069_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=h-oxovq3FIwQ7kNvgEIcnz_&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDlNdBpN4aKXzuTHwNRBva2SrxakLC9rUjVSX-ctL1Sfg&oe=67407DAF"}, "display_name": "BIG BALLERS - VR SPORTS", "keywords": ["basketball", "football", "baseball", "sports", "fitness"], "long_description": "\ud83c\udfc6 The #1 all-in-one VR Sports Game. \n\n\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10\n\n\ud83c\udf96\ufe0f Begin your legacy in BIG BALLERS VR. It's a fully multiplayer game where you can play with up to 10 players per Park and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches. There's even an MR mini-hoop mode and a Blade Ball inspired game mode.\n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\udde3\ufe0f COMMUNITY RUNS DEEP \ud83d\udde3\ufe0f\n\nWe strongly believe in respect. Earn reputation by playing with good sportsmanship.\n\n\ud83d\udcaa FLEX ON YOUR OPPS \ud83d\udcaa\n\nWith 100s of cosmetics available in our shop, you can make plays in style. Customize with the drippiest hats, jackets, kicks, and accessories.\n\n\ud83e\udd56 FRESH UPDATES MONTHLY \ud83e\udd56\n\nExpect new content and enhancements every month, tailored to our community's feedback \u2013 that includes you \ud83e\udef5.\n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE? \ud83d\ude24\n\nGo big or go home. Play for free now!", "short_description": "\ud83c\udfc6 The #1 all-in-one VR Sports Game. \n\n\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10\n\n\ud83c\udf96\ufe0f Begin your legacy in BIG BALLERS VR. Play with up to 10 players and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches.\n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE? \ud83d\ude24"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bigballersvr.com/privacy", "developer_terms_of_service_url": "https://bigballersvr.com/terms", "publisher_name": "Doge Labs Inc", "support_website_url": "https://bigballersvr.com/discord", "website_url": "https://bigballersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ACTION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8350144288387150"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031441_881937013477453_7013475375849736954_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yLBwET0CMnIQ7kNvgExwVhA&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDpKeyBeCyoYQk_DetzAo1u9eCWTCcjJWNFtn1qxACWcw&oe=6740702A"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BIG BALLERS - VR SPORTS", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1700589600, "lastRevision": {"nodes": [{"id": "189963473024939", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3947713001963656", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "3074012062818431"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [