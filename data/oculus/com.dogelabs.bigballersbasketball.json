uaR3Ntuhs4YQ7kNvgFhJ2iE&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEnFPnIgqqOGlAVuH_wB5eG&oh=00_AYBTJIRj0PCKpSHCO5Ea1yjs3BARybr3aM8Z8_kbfRmFbA&oe=66DC36A1"}, {"file_name": "dunk_screenshot.png", "id": "5271547479527124", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974794_5271547486193790_151222580142976334_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nxxs0WxHkjgQ7kNvgH2E2JM&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEnFPnIgqqOGlAVuH_wB5eG&oh=00_AYCV4ErlrYfeB67iV3GbiNKtOb4Cp0et0M0bzkyr2Axs3w&oe=66DC4558"}, {"file_name": "dribbling.png", "id": "565302594470834", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568668_565302597804167_2403830162561096493_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UMBdCgq5qcIQ7kNvgFjwhX5&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEnFPnIgqqOGlAVuH_wB5eG&oh=00_AYBe4OCRIEYEIYqijZb_btNtvup8JYtr-iYO7a9yq4v8BQ&oe=66DC4D67"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "dunk_screenshot.png", "id": "854696385153934", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003271_854696388487267_8661722327325916084_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IKQFuTZRI8cQ7kNvgG_lN3A&_nc_ht=scontent.oculuscdn.com&_nc_gid=AEnFPnIgqqOGlAVuH_wB5eG&oh=00_AYCEPBELlHM3QTpqotFL8dK5fpqQAtdFhdqp4n9bgXl4Bg&oe=66DC5121"}, "display_name": "Big Ballers Basketball", "keywords": [], "long_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot or even your sky hook! Use a natural basketball stroke and Big Ballers Basketball's realistic physics engine will do the rest. Make sure to hold the grip button until the top of your release. Try the 1 minute drill minigame or experiment with reduced gravity. The court is yours! Dribbling, multiplayer and even Shaq mode. It's the easiest way to have fun, socialize and exercise at the same time.\n\nAs you shoot enjoy the music from your very own Boom Box. Feeling a little tired? Big Baller's has got you covered you can play seated or standing. ", "short_description": "Big Ballers Basketball is the ultimate basketball simulator. Enter a virtual basketball court and practice your jump shot, sky hook and your DUNK! Oh yeah, there's multiplayer too. "}]}, "developer_name": null, "developer_privacy_policy_url": "https://docs.google.com/document/d/1OJOSmAlYAxfsAdHu14Js2SWAe8pkr3AuREebGQ4Dh2g", "developer_terms_of_service_url": null, "publisher_name": "Doge Labs", "support_website_url": null, "website_url": "https://linktr.ee/bigballersbasketballvr", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ACTION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "5071989819487711"}}]}, "scheduled_offers": {"count": 13, "nodes": [{"status": "PENDING", "id": "694848165533347"}, {"status": "PUBLISHED", "id": "322898349536340"}, {"status": "PUBLISHED", "id": "428686062201362"}, {"status": "PUBLISHED", "id": "1349335335520112"}, {"status": "PUBLISHED", "id": "452680853106758"}, {"status": "PUBLISHED", "id": "356469582521060"}, {"status": "PUBLISHED", "id": "610104747353581"}, {"status": "CANCELLED", "id": "595992122730972"}, {"status": "PUBLISHED", "id": "796486178156150"}, {"status": "PUBLISHED", "id": "2320557041442548"}, {"status": "PUBLISHED", "id": "169864212872588"}, {"status": "PUBLISHED", "id": "611948160010088"}, {"status": "PUBLISHED", "id": "1020295572169559"}]}, "baseline_offer": {"id": "169864212872588"}, "is_approved": true, "firstOffer": {"nodes": [