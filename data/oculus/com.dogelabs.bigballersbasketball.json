": "03.png", "id": "421465910493729", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982469_421465913827062_5336444835991613147_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=580daPKM_2MQ7kNvgH0X77I&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYABFAQh7bT1I23rAXvbs2Lv6ARLw25IV6OudwfIrju6nw&oe=67864778"}, {"file_name": "ASSET-temp.png", "id": "7036838179709959", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75443238_7036838183043292_4028150758810939956_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fblPy_rwKdwQ7kNvgHUibHv&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDg83h_kCHR-OHseWqijxfJ1tqQsE7kZq_vJIW3rwzEJg&oe=678653BF"}, {"file_name": "ballers-arena.png", "id": "1393923774644849", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031627_1393923777978182_8033474185708069791_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HErvL1mpj6cQ7kNvgFxZQzU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB8NvxbC6bciqPAwPR_ULCNQDyigNuw9AW6K_clpOQ8gg&oe=678637B2"}, {"file_name": "render6 (2).png", "id": "743056764091566", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982585_743056767424899_6555961347991160068_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D0IsFUWXG9oQ7kNvgHChgm-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA7JStG-Mo7gj-jzjLC25KfWdL4BKn6lbiooKqoHO3HQg&oe=6786532A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "bb-all-in-one.png", "id": "639440422121216", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/468712937_639440425454549_4294223579813546153_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V6sKL8VSGJ4Q7kNvgGwA5yW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDZruIwkZcDTj5GYNm_D3sh3A0q5VqZ-giYyxDBgdOLig&oe=678638E2"}, "display_name": "BIG BALLERS - VR SPORTS", "keywords": ["basketball", "football", "baseball", "sports", "fitness"], "long_description": "# \ud83c\udfc6 The #1 fully multiplayer all-in-one VR Sports Game.\n\n\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10\n\n\ud83c\udf96\ufe0f Begin your legacy in BIG BALLERS VR. It's a fully multiplayer game where you can play with up to 10 players per Park and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches. There's even an MR mini-hoop mode and a Blade Ball inspired game mode.\n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\udde3\ufe0f COMMUNITY RUNS DEEP \ud83d\udde3\ufe0f\n\nWe strongly believe in respect. Earn reputation by playing with good sportsmanship.\n\n\ud83d\udcaa FLEX ON YOUR OPPS \ud83d\udcaa\n\nWith 100s of cosmetics available in our shop, you can make plays in style. Customize with the drippiest hats, jackets, kicks, and accessories.\n\n\ud83e\udd56 FRESH UPDATES MONTHLY \ud83e\udd56\n\nExpect new content and enhancements every month, tailored to our community's feedback \u2013 that includes you \ud83e\udef5.\n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE? \ud83d\ude24\n\nGo big or go home. Play for free now!", "short_description": "\ud83c\udfc6 The #1 all-in-one VR Sports Game.\n\n\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10\n\n\ud83c\udf96\ufe0f Begin your legacy in BIG BALLERS VR. Play with up to 10 players and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches.\n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE? \ud83d\ude24"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bigballersvr.com/privacy", "developer_terms_of_service_url": "https://bigballersvr.com/terms", "publisher_name": "Doge Labs Inc", "support_website_url": "https://bigballersvr.com/discord", "website_url": "https://bigballersvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPORTS", "ACTION", "SIMULATION"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8803344676400440"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974774_1620009922728022_8049523631773756806_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H5dajK7rmjwQ7kNvgEglmlV&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCC8PDSiGAplSuVQ_uO6y2jxe75jT7XkFEYAMBe7rn5tQ&oe=678652C5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "BIG BALLERS - VR SPORTS", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Sports", "id": "2776542286000603"}], "release_date": 1700589600, "lastRevision": {"nodes": [{"id": "189963473024939", "release_type": "MANAGED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "3947713001963656", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "3074012062818431"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": 