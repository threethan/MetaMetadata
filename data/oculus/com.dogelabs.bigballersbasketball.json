t.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYBxjX4h-Vid6_5ik7ScEvpQRTfoowwxcUV33xszrwPWnA&oe=66E2DF89"}, {"file_name": "03.png", "id": "421465910493729", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982469_421465913827062_5336444835991613147_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WRHP45nNHmcQ7kNvgFvNTEX&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYA-K65ZZFTG072s6dhFdVi3p5dqgyhc3XiX2oRVyMnChg&oe=66E2CD78"}, {"file_name": "ASSET-temp.png", "id": "7036838179709959", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75443238_7036838183043292_4028150758810939956_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ok_cHIg1g1wQ7kNvgHlHwbR&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYAZtTVRnb6zBcoVeCYaLHovCNpoJug1n5C_ZolBqbEddg&oe=66E2D9BF"}, {"file_name": "ballers-arena.png", "id": "1393923774644849", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031627_1393923777978182_8033474185708069791_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xe1MY8Cb4bgQ7kNvgFaZYdM&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYBb4qiKJXyv9lJHDRDSlurvjWLparZ1G6cv_EgK3gylRw&oe=66E2BDB2"}, {"file_name": "render6 (2).png", "id": "743056764091566", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982585_743056767424899_6555961347991160068_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MEY1vDm_9GwQ7kNvgHTCruO&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYCb0xVri4GONYgrdQQ843yUTJK6cw_3S4ts2uCIWYzKzw&oe=66E2D92A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "bbvr-Cover Art Landscape (1).png", "id": "1184208302971120", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031420_1184208306304453_962545794958547069_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=piWCVWvJDloQ7kNvgEVXNXu&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-yiey0clG9idQyaKEXXUBX&oh=00_AYAhOfKVGiXGiIadAPkUQ61W1JTDyp9XRYvQUJJDO56Mbw&oe=66E2E32F"}, "display_name": "BIG BALLERS VR", "keywords": ["basketball", "football", "baseball", "sports", "fitness"], "long_description": "\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10 \n\nRank up in the fastest growing VR sports game, BIG BALLERS VR. Play with up to 12 players and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches. Try our MR Fitness mode too.  \n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\udde3\ufe0f COMMUNITY RUNS DEEP \ud83d\udde3\ufe0f\n\nWe strongly believe in respect. Earn reputation by playing with good sportsmanship. \n\n\ud83d\udcaa FLEX ON YOUR OPPS \ud83d\udcaa\n\nWith 100s of cosmetics available in our shop, you can make plays in style. Customize with the drippiest hats, jackets, kicks, and accessories.  \n\n\ud83e\udd56 FRESH UPDATES MONTHLY \ud83e\udd56\n\nExpect new content and enhancements every month, tailored to our community's feedback \u2013 that includes you \ud83e\udef5. \n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE? \ud83d\ude24\n\nGo big or go home. Play for free now!", "short_description": "\ud83d\udc10 BECOME THE G.O.A.T \ud83d\udc10 \n\nRank up in the fastest growing VR sports game, BIG BALLERS VR. Play with up to 12 players and perform crazy windmill contact dunks in basketball, slug dingers in baseball, and clutch it with game-winning touchdown catches. Try our MR Fitness mode too.  \n\n\ud83c\udfc8 EASY TO LEARN \u2013 HARD TO MASTER \u26be\ufe0f\ud83c\udfc0\ud83c\udfd0\n\nOur world-class physics engine gives you realistic natural gameplay while being easy to grasp yet challenging to master.\n\n\ud83d\ude24 WILL YOU RISE TO THE CHALLENGE \ud83d\ude24\n\nPlay free now!\n\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://bigballersvr.com/privacy", "developer_terms_of_service_url": "