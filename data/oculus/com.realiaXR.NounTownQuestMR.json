anguage Learning, you don\u2019t need to grab this one as it contains the same Mixed Reality gameplay.**\n\n{1108665530823608}\n\n# Your Home, Your Learning\n\n\u2714 Learn 800+ words and phrases\n\n\u2714 Choose to learn: English, Japanese, Korean, Chinese, Spanish, German, French, Italian, Ukrainian, Russian, Greek and Arabic\n\n\n\u2714 Stay motivated with \"Daily Goals\" and \"Learning Streaks\"\n\n\u2714 Play the Superseeker and Alpha-Bash mini-games and use the auto-revision system to lock in your learning\n\n\u2714 Customize your room, label household items, and create your own memory palace to help you remember\n\n\u2714 Practice speaking with 16 NPCs using speech recognition, preparing you for real conversations\n\n{1302404137427276}", "short_description": "Improve your language skills by listening, reading, and speaking your chosen language at home with Mixed Reality! Test yourself with mini-games and chat with characters. Learn Japanese, Spanish, and 11 other languages..."}]}, "developer_name": "SUPER HYPER MEGA", "developer_privacy_policy_url": "https://noun.town/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "SUPER HYPER MEGA", "support_website_url": "https://nountown.freshdesk.com/support/home", "website_url": "https://noun.town/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1990104051447093"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interacti