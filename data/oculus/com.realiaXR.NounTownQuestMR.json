1.oculuscdn.com&oh=00_AYDikt5a7mvj3I-b7grVvEqISaSpyOhf-y7HYxMSEQpZvQ&oe=67864A1C"}, {"file_name": "Screenshot_4.png", "id": "1119767196158985", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75245820_1119767199492318_3798500756352791956_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mXXwrdrzCAAQ7kNvgGup_GP&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAQNXRxc50XyGaCWenNVq32KnVtuqDYvzopKIAsIRy5dQ&oe=67865C92"}, {"file_name": "Screenshot_5.png", "id": "1495580497764393", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031491_1495580501097726_1196866140773167282_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G6RNhA7k2J0Q7kNvgEwCiaJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAWyYphG7F2Z9KCQSIgsKFPmKVCRqk-EmFPljF2t9ojbg&oe=67864F1A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "MR_NounTown_Landscape.png", "id": "1229003341643815", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75476754_1229003344977148_2909509994452516837_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4_UKw_YkA9MQ7kNvgETwOvk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDxOH7c39cAmNfZBf5hOifGM0nYbIDu6_cewtq8UPrBhw&oe=6786410A"}, "display_name": "Noun Town: Home", "keywords": ["education", "language", "MR", "fun"], "long_description": "**Noun Town: Home is a standalone Mixed Reality version of the award-winning Noun Town Language Learning game. If you already own Noun Town Language Learning, you don\u2019t need to grab this one as it contains the same Mixed Reality gameplay.**\n\n{1108665530823608}\n\n# Your Home, Your Learning\n\n\u2714 Learn 800+ words and phrases\n\n\u2714 Choose to learn: English, Japanese, Korean, Chinese, Spanish, German, French, Italian, Ukrainian, Russian, Greek and Arabic\n\n\n\u2714 Stay motivated with \"Daily Goals\" and \"Learning Streaks\"\n\n\u2714 Play the Superseeker and Alpha-Bash mini-games and use the auto-revision system to lock in your learning\n\n\u2714 Customize your room, label household items, and create your own memory palace to help you remember\n\n\u2714 Practice speaking with 16 NPCs using speech recognition, preparing you for real conversations\n\n{1302404137427276}", "short_description": "Improve your language skills by listening, reading, and speaking your chosen language at home with Mixed Reality! Test yourself with mini-games and chat with characters. Learn Japanese, Spanish, and 11 other languages..."}]}, "developer_name": "SUPER HYPER MEGA", "developer_privacy_policy_url": "https://noun.town/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "SUPER HYPER MEGA", "support_website_url": "https://nountown.freshdesk.com/support/home", "website_url": "https://noun.town/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}, {"id": "1990104051447093"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8786024564812824"}, "review_messages": ["", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75375081_1089780225949372_949075827650043857_n.png?stp=dst-png_s360x360&_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9dMJvYB5TkgQ7kNvgGBki4w&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAHCnyPaq7YYbAF9_qhtQdfHcXfCzx4CMzC3qsZuEiwbQ&oe=67864FA5"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Noun Town: Home", "platform": "ANDROID_6DOF",