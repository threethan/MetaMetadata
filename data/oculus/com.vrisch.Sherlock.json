3kVcZg&oe=66E6C483"}, {"file_name": "Screenshot_3_00.png", "id": "588608545763309", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982535_588608549096642_7640218666333570115_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dCXBhb7UhBoQ7kNvgHnq5jh&_nc_ht=scontent.oculuscdn.com&_nc_gid=APHkvUT0ai6tOhSRAMQ56sV&oh=00_AYAUr_6HTVFJgkP3HwMIK7RM9V4kBdEbYn7wVp1j8LbfUA&oe=66E6C737"}, {"file_name": "Screenshot_5_00.png", "id": "1225775251164793", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1225775254498126_4839131565103206938_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y0C8Jw_G8vkQ7kNvgGzsJ-f&_nc_ht=scontent.oculuscdn.com&_nc_gid=APHkvUT0ai6tOhSRAMQ56sV&oh=00_AYDfiAtoRD2XTh2SltzAgLkrmE3BaTYPbGivrHEObHMXEg&oe=66E6C8FC"}, {"file_name": "Screenshot_4_00.png", "id": "662214628493829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_662214631827162_1631739407993477234_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eIL4DLc2xYIQ7kNvgFA6fVs&_nc_ht=scontent.oculuscdn.com&_nc_gid=APHkvUT0ai6tOhSRAMQ56sV&oh=00_AYA1szEaAnanZC7fhdqAqhRIYIU6EAxdNwV18U5uMeiATQ&oe=66E6D5FB"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Sherlock Holmes: The Case of the Hung Parliament", "keywords": [], "long_description": "Sherlock Holmes: The Case of the Hung Parliament is a story-driven VR detective adventure that combines game, film, and performing arts to put your analytical and intellectual skills to the test. Play from your living room, alone or with friends, from anywhere in the world.\n\nEnjoy live-action performances by professional theatre actors and scour crime scenes shoulder to shoulder with Dr. Watson to solve the case of the Hung Parliament. Sherlock Holmes VR is great for first-time VR users and perfect for those with limited space or reduced mobility.\n\nThe Home Secretary, The Foreign Secretary, and the Lord Chancellor have all been found hanging in their own chambers. Each victim died on their birthday. On that day, they received a card with a mysterious quote written in it, but what does this mean? Where's Sherlock? And will you be able to solve the case before the murderer strikes again?", "short_description": "Sherlock Holmes: The Case of the Hung Parliament is a story-driven VR detective adventure that combines game, film, and performing arts to put your analytical and intellectual skills to the test. Play from your living room, alone or with friends, from anywhere in the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrisch.com/sherlock-vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "vrisch multimediaproduction GmbH", "support_website_url": null, "website_url": "https://www.vrisch.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "PUZZLE", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER", "SINGLE_USER"], "id": "461647882301465"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "795752747982075"}]}, "baseline_offer": {"id": "795752747982075"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677816000, "status": "PUBLISHED", "id": "795752747982075"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8084769018217437", "version": "1.4"}, "id": "578649040208134", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typ