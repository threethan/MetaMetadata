FW8A6CwqRF4hXd0VA&oe=66DAE9B7"}, {"file_name": "Screenshot_5_00.png", "id": "1225775251164793", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031326_1225775254498126_4839131565103206938_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gU_4sOOTSooQ7kNvgF4mJQA&_nc_ht=scontent.oculuscdn.com&oh=00_AYBMzpitYxjp5yezRTc4ZknznnrHhCxD9pCuaBNF5QlhCQ&oe=66DAEB7C"}, {"file_name": "Screenshot_4_00.png", "id": "662214628493829", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57569471_662214631827162_1631739407993477234_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=A6VQQ9Ax7EkQ7kNvgGw8Ruf&_nc_ht=scontent.oculuscdn.com&oh=00_AYDA2OtwbXYF7cwky6xxQuTpH3_NaFRSIJbclfDMZ8NoQw&oe=66DAF87B"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Sherlock Holmes: The Case of the Hung Parliament", "keywords": [], "long_description": "Sherlock Holmes: The Case of the Hung Parliament is a story-driven VR detective adventure that combines game, film, and performing arts to put your analytical and intellectual skills to the test. Play from your living room, alone or with friends, from anywhere in the world.\n\nEnjoy live-action performances by professional theatre actors and scour crime scenes shoulder to shoulder with Dr. Watson to solve the case of the Hung Parliament. Sherlock Holmes VR is great for first-time VR users and perfect for those with limited space or reduced mobility.\n\nThe Home Secretary, The Foreign Secretary, and the Lord Chancellor have all been found hanging in their own chambers. Each victim died on their birthday. On that day, they received a card with a mysterious quote written in it, but what does this mean? Where's Sherlock? And will you be able to solve the case before the murderer strikes again?", "short_description": "Sherlock Holmes: The Case of the Hung Parliament is a story-driven VR detective adventure that combines game, film, and performing arts to put your analytical and intellectual skills to the test. Play from your living room, alone or with friends, from anywhere in the world."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.vrisch.com/sherlock-vr-privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "vrisch multimediaproduction GmbH", "support_website_url": null, "website_url": "https://www.vrisch.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["NARRATIVE", "PUZZLE", "ADVENTURE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["CO_OP", "MULTI_USER", "SINGLE_USER"], "id": "461647882301465"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "795752747982075"}]}, "baseline_offer": {"id": "795752747982075"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1677816000, "status": "PUBLISHED", "id": "795752747982075"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8084769018217437", "version": "1.4"}, "id": "578649040208134", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4624529214241452", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8084769018217437"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "578649040208134"}]}, "change_log": "Fixed video display bug and added bu