71001695_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4VTpi1jo4wgQ7kNvgFzy__d&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA2onfwl3_HowTbIf03hssyYGqhhi162SY9ubpool-tLQ&oe=675AE810"}, {"file_name": "Screenshot4.png", "id": "425267655428643", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982678_425267662095309_828575248451170489_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DmTPCk3_cUIQ7kNvgH-7CeE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC661D08A7Da7Jm_oWCBBiO1IDep87AvcIFfSugTdwtIg&oe=675AE7A2"}, {"file_name": "Screenshot6.png", "id": "174126930945943", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982564_174126934279276_2396599257823916983_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZS4mRvMojb4Q7kNvgFInzB6&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCMSZgwGDIHLog83j3PS8NAbdTvW4-CZy2vvdIaCgQC3w&oe=675ACB9E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoThumbnail.png", "id": "435412957782025", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982545_435412961115358_1195377053426836600_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qvOSTDwdsY0Q7kNvgEPRG7Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD4ruxEpR0x4i0MtkdtEtGg_LX7Lt7eGpp4BLwFQ48IvQ&oe=675AE719"}, "display_name": "Crashland", "keywords": ["Action", "Horror", "Shooter", "Aliens", "Dinosaurs"], "long_description": "CRASHLAND is a VR action horror game set on a hostile alien planet. You play as an intergalactic gladiator who is crashlanding and trying to survive until rescue. Combat in CRASHLAND is fast, vicious, and brutal. You will fight giant hellworms in the desert, terror birds in the forest, scorpions in the mist and spiders in the dark. There is nowhere to hide.\n\nYou will need to master your pistol, boomstick, scanner and teleporter to survive. New firing modes and powerups will drop during missions. By gaining XP you can level up, unlock perks, and radically alter how the game plays. \n\nFeatures:\n- Fast visceral combat against over 50 vicious and deadly creatures. \n- 24 unique missions across desert, forest, and mountain biomes.\n- Advanced procedural animation technology that helps bring the virtual creatures to life.\n- Weather effects like howling winds, rain, thunder and snow.\n- 30 perks to unlock including teleport punch, slow time, and turrets.\n- Local, friend and galactic leaderboards.", "short_description": "CRASHLAND is a VR action horror game set on a hostile alien planet. You play as an intergalactic gladiator who is crashlanding and trying to survive until rescue. Combat in CRASHLAND is fast, vicious, and brutal. You will fight giant hellworms in the desert, terror birds in the forest, scorpions in the mist and spiders in the dark. There is nowhere to hide."}]}, "developer_name": "Llyr ap Cenydd", "developer_privacy_policy_url": "https://www.crashlandvr.com/privacy", "developer_terms_of_service_url": null, "publisher_name": "LAC Games Ltd", "support_website_url": "http://www.crashlandvr.com/", "website_url": "http://www.crashlandvr.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "HORROR"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "453563322980154"}}]}, "scheduled_offers": {"count": 19, "nodes": [{"status": "PUBLISHED", "id": "1299919631023939"}, {"status": "PUBLISHED", "id": "445726328478989"}, {"status": "PUBLISHED", "id"