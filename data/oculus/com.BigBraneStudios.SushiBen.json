/v/t64.5771-25/38974497_931997718103607_6006284244228210301_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AGXS83eSZeYQ7kNvgE1IuBL&_nc_ht=scontent.oculuscdn.com&oh=00_AYCxdNCyiRsEqbXkjl-fhPSfPgF3gd1_r4Tz91m4ot7PXg&oe=66DAE841"}, {"file_name": "SushiBen_ScreenShot_4.png", "id": "1307238116875009", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974917_1307238120208342_3910000765290985600_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yOIjJHBWrw8Q7kNvgHdXjYq&_nc_ht=scontent.oculuscdn.com&oh=00_AYBO9QXSmbpfcSVP19wKzia4EAnKZvm7YORRPv4ZiKO5eA&oe=66DACBBC"}, {"file_name": "SushiBen_ScreenShot_1.png", "id": "1189489951730164", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57574717_1189489955063497_6029107559823454791_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=r-4vubBsexwQ7kNvgG74ndj&_nc_ht=scontent.oculuscdn.com&oh=00_AYDhUjX9xb7qQki8Nvf7oui5K7w-M7Ghi9ALOrc0iW-l1w&oe=66DAD6B4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SBVR_CoverLandScape_highres 2.png", "id": "1140865846870016", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974551_1140865850203349_4685788634542620045_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0XH2CeHfWzgQ7kNvgHRZ_Ye&_nc_ht=scontent.oculuscdn.com&oh=00_AYB5I2-S0wGahvuizEAFJPxnu_LX3C1Xeye3qcLbGvX73Q&oe=66DAFA3E"}, "display_name": "Sushi Ben", "keywords": ["manga", "anime", "Japan", "fishing", "comedy"], "long_description": "Featuring exciting 3D manga panels, Sushi Ben is a narrative adventure game written by the creator of Hatoful Boyfriend. You\u2019ll fish, catch bugs, snap photos and more, all to save a beloved local sushi bar from some dastardly landsharks!\n\nMeet the colorful cast of Sushi Ben, the residents of Kotobuki town. From your friendly neighborhood landlady, to the mysterious shrine janitor, you\u2019ll have to complete quests to get them to dine with you!\n\nUtilizing 3D manga panels for powerful visual storytelling, players will be transported to the colorful port town of Kotobuki. Sushi Ben\u2019s lively cast of characters lead you through fun quests that\u2019ll leave you excited to meet the next townsperson.\n\nSushi Ben feels like playing an age-old classic, with a twist!\n\nWe'd love to help out! For additional support, please email us at support@bigbranestudios.com or join our Discord server! (https://discord.gg/Jj3AUAAP8D)", "short_description": "Featuring exciting 3D manga panels, Sushi Ben is a narrative adventure game written by the creator of Hatoful Boyfriend. You\u2019ll fish, catch bugs, snap photos and more, all to save a beloved local sushi bar from some dastardly landsharks!\n\nMeet the colorful cast of Sushi Ben, the residents of Kotobuki town. From your friendly neighborhood landlady, to the mysterious shrine janitor, you\u2019ll have to complete quests to get them to dine with you!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.sushiben.com/privacy", "developer_terms_of_service_url": "https://www.sushiben.com/eula", "publisher_name": "Big Brane Studios Inc", "support_website_url": "https://www.sushiben.com/contact", "website_url": "https://www.sushiben.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ADVENTURE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ja"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8189480391068678"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/