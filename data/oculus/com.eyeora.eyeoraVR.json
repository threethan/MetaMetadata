yEIBeJAQ7kNvgHZ6fBR&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBIuV1Hy2NAGjb2C7ucMs1-OGYIc_6fQS7bgHRCWpdHZA&oe=673DCBF3"}, {"file_name": "CoverLandscape1.png", "id": "454315255700299", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75556798_454315259033632_4109156937198967114_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YAR28DjW3P0Q7kNvgH6ibox&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDPmGybwIpFbD-eML5TvJedcR6-T2ytTMSPP7vUS46Rmg&oe=673DC152"}, {"file_name": "CoverLandscape2.png", "id": "922931651849482", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75262744_922931655182815_5099644515480678808_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5dxm36BtQ60Q7kNvgHgFXCc&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBdBkqMyTLqzHbwYQU7e7-i8a3xn2_GS893AHhlyRejgw&oe=673DBBF5"}, {"file_name": "image_2020-10-23_08-51-07.png", "id": "425436815347670", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57570299_425436818681003_4578662778477016696_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gl7Te_ng7QYQ7kNvgHnprJm&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBUCNniifgtZzcS5WAYaETdZd9k_qOTW6tcJ2wADWnSEw&oe=673DDE4E"}, {"file_name": "image_2020-10-22_12-28-22.png", "id": "1341197996265739", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982678_1341198006265738_1756902884262449121_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ABnmcX3OTq4Q7kNvgHOBCZZ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDb9Xr2bgRLG4eQ46HxuCeHFIWHdM3fshRhfB3L5k1Kw&oe=673DD8B0"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "eyeora VR", "keywords": [], "long_description": "CREATE\nThe eyeora VR studio offers a user friendly drag n drop tool, creates 360 scenes with real-time gaze control hotspots and  auto-sync's multiple camera angles in main scene feature, making anyone a PRO VR content creator.\n\nCUSTOMISE\nVia the VR studio create your own customised 3D VR Room. It can be fully branded, with banners, logos and URL links or PRO 360 content with hotspots, real-time editor allowing other VR explorers a social VR space. \n\nCONNECT\nSocial VR events can be scheduled via the eyeora VR studio. Free or Paid plan can invite private groups to explore into your VR room, assign content to view in event or leave open entry via a public VR event, build your network.", "short_description": "A VR studio and VR app for 360 content management, 3D VR room customisation, social interaction and monetisation"}]}, "developer_name": "eyeora ltd", "developer_privacy_policy_url": "https://www.eyeora-vr.com/privacy-policy", "developer_terms_of_service_url": "https://www.eyeora-vr.com/T&C", "publisher_name": "eyeora VR", "support_website_url": "https://www.eyeora-vr.com/contact-us", "website_url": "https://www.eyeora-vr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1228796255027646"}], "external_subscription_type": "REQUIRED", "genres": ["EXPLORATION", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "306829021419429"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "474844503859008"}]}, "baseline_offer": {"id": "474844503859008"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1619470620, "status": "PUBLISHED", "id": "474844503859008"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6