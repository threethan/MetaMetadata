n be fully branded, with banners, logos and URL links or PRO 360 content with hotspots, real-time editor allowing other VR explorers a social VR space. \n\nCONNECT\nSocial VR events can be scheduled via the eyeora VR studio. Free or Paid plan can invite private groups to explore into your VR room, assign content to view in event or leave open entry via a public VR event, build your network.", "short_description": "A VR studio and VR app for 360 content management, 3D VR room customisation, social interaction and monetisation"}]}, "developer_name": "eyeora ltd", "developer_privacy_policy_url": "https://www.eyeora-vr.com/privacy-policy", "developer_terms_of_service_url": "https://www.eyeora-vr.com/T&C", "publisher_name": "eyeora VR", "support_website_url": "https://www.eyeora-vr.com/contact-us", "website_url": "https://www.eyeora-vr.com/", "category": "ENTERTAINMENT", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1819021644882647"}, {"id": "1228796255027646"}], "external_subscription_type": "REQUIRED", "genres": ["EXPLORATION", "CASUAL", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "306829021419429"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "474844503859008"}]}, "baseline_offer": {"id": "474844503859008"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1619470620, "status": "PUBLISHED", "id": "474844503859008"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6