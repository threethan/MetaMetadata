25/38982687_1563254040745795_671993254825275152_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5kMZ918QfXoQ7kNvgFjBrb5&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAsXOb5HM3himRImjqpTxEYni2UtGJmCToIEL8q40KfpQ&oe=670273A2"}, {"file_name": "Maya3.png", "id": "706623481566100", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/38974682_706623484899433_7441758451951157034_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=voa4TbKeu2oQ7kNvgHWAibO&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYC6F7dwa-sxiuGO4YFLkOlHj0IOuxpBmF6L0RollECntg&oe=67028638"}, {"file_name": "Snipe2.png", "id": "1532765054209702", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974593_1532765057543035_618341148461529467_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IjebHj60C-EQ7kNvgHs7vvI&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYD0_1H9RuZDMonbHYPGrTo7OTm-QqqG1VYPUPyyDCJTOg&oe=6702699C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Affiche_v5_landscape.png", "id": "393807306316025", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031597_393807309649358_767017438018739195_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K5wBa9UIE1UQ7kNvgHMhuQy&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAanN0P_goFaQ6ZaviJsT4booojeNHrCSkdNEACmJHDng&oe=67028B8E"}, "display_name": "MASTERS OF LIGHT", "keywords": ["fight", "adventure", "fitness", "action", "handtracking"], "long_description": "Shadows are threatening the galaxy and it\u2019s up to you to join the fight! \n\nMASTERS OF LIGHT is a fun HAND TRACKING action adventure game that will take your breath away. Harness the might of your superpowers and delve into the mysteries of the fallen Constellations. Unlock new abilities, boost your skills, and evolve into the ultimate Master of Light. \n\nThe fate of your sisters in arms rests on your shoulders. Will you be strong enough to face what awaits you at the heart of the Black Hole?\n\nKey features : \n- 2 ways to play : hand-tracking (preferred) or controllers\n- 3 difficulty modes : easy / normal / survivor\n- 5 superpowers to master and upgrade \n- 6 types of enemies \n- 20 trophies to unlock\n- 36 levels\nand unlimited replay to improve your score!\n\nAvailable in English, Spanish, French, German, Simplified Chinese, Japanese.\n", "short_description": "Shadows are threatening the galaxy and it\u2019s up to you to join the fight! \n\nMASTERS OF LIGHT is a fun HAND TRACKING action adventure game that will take your breath away. Harness the might of your superpowers and delve into the mysteries of the fallen Constellations. Unlock new abilities, boost your skills, and evolve into the ultimate Master of Light. \n\nThe fate of your sisters in arms rests on your shoulders. Will you be strong enough to face what awaits you at the heart of the Black Hole?"}]}, "developer_name": "COVEN", "developer_privacy_policy_url": "https://wearecoven.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "COVEN ", "support_website_url": null, "website_url": "http://www.wearecoven.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr", "ja", "es", "zh_CN", "de"], "supported_input_devices": ["HAND_TRACKING", "GAMEPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7267867979941631"}}]}, "scheduled_offers": {"count": 7, "nodes": [{"status": "PUBLISHED", "id": "389144417356785"}, {"status": "PUBLISHED", "id": "1705438963555757"}, {"status": "PUBLISHED", "id": "