_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAlJMA2rxsWhT4phlWdBPm3Z9KI7559hKsmptXO2dsYyw&oe=675D8548"}, {"file_name": "pirate ship.png", "id": "1270838327379013", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974448_1270838330712346_483726301639150244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JFD1_p_Ti1sQ7kNvgF1VISG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBR4lGVqC0tgJcx8MwqxJPd3i3XQnSAG5-iXElbwMohaA&oe=675D87D5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39035341_210173948412680_4740011655580331961_n.png", "id": "808149744570534", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38982626_808149747903867_5100784820136452062_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tSIewPYJ6UgQ7kNvgGxOPww&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA4uRCXLmGNl_Hf3AzkFJvPjtB2Pom8Ab1sYHWFm2uV6g&oe=675D6B9F"}, "display_name": "Chimp Chase PVP", "keywords": [], "long_description": "Chimp Chase is a thrilling PVP game that redefines the excitement of the Gorilla Locomotion movement system. Immerse yourself in a one of a kind experience as you choose from an arsenal of primary and secondary weapons. Then, dive straight into the battle zone for intense online PVP battles with other players.\n\nComplete quests to earn ores, which you can then use to purchase a wide variety of stylish cosmetics, allowing you to pimp your chimp's appearance and express yourself on the battlefield.\n\nEnter the world of Chimp Chase and take part in awesome battles that combine skill, style, and fun to provide the best possible experience.", "short_description": "Welcome to Chimp Chase, hop straight into the battle zone with your favorite weapons and compete against other players in some good old fashioned PVP!"}]}, "developer_name": "GetaGames Limited", "developer_privacy_policy_url": "https://www.termsfeed.com/live/ffb76398-19d9-4068-8752-7b21003b1274", "developer_terms_of_service_url": "https://getagamesbusines