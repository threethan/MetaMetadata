115256343143928", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/38982576_1115256346477261_7940274428983720617_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iyIb9CnKKRkQ7kNvgEEuCpT&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYC8pEaF746kxe4KQKSTU6hZIt21fF4coYYsPKB8Rn-GDw&oe=671A49E6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Chimp Chase PVP", "keywords": [], "long_description": "Welcome to Chimp Chase, a thrilling PvP VR gorilla locomoted game that puts you in the heart of intense battles across many maps, from calm forests to scorching deserts. Take control of powerful weaponry including the AK47, pistol, RPG, and sniper rifles as you compete for dominance in adrenaline-fueled matches. Previously owned by Henwy, Chimp Chase is now under the ownership of Edivence, promising a revamped experience filled with action, strategy, and heart-pounding excitement. Are you ready to unleash your primal instincts and conquer the competition?", "short_description": "\nStep into Chimp Chase, a PvP VR game with fierce gorilla battles in diverse landscapes. Arm yourself with AK47s, pistols, RPGs, and sniper rifles for adrenaline-fueled matches. Formerly Henwy's, now Edivence promises an action-packed, strategic experience. Ready to dominate?"}]}, "developer_name": "GetaGames", "developer_privacy_policy_url": "https://www.termsfeed.com/live/1b812005-5f34-4430-b5f9-16c9ae75121b", "developer_terms_of_service_url": null, "publisher_name": "GetaGames", "support_website_url": null, "website_url": "https://finx10.wixsite.com/chimpchase/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_pro