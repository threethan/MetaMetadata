amesbusiness.wixsite.com/chimp-chase-pvp", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8106007602771862"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/43931330_450790150628542_1257595952492593456_n.png?stp=dst-png_s360x360&_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CPDO7lysdPQQ7kNvgEjUVlK&_nc_ht=scontent-xsp1-3.oculuscdn.com&oh=00_AYDehYoTX-Mz60C6EerGTCKfZwSx0FYmhVTuFuy1Ka528Q&oe=671A4339"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Chimp Chase PVP", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Fighting", "id": "2710427532541308"}], "release_date": 1712784480, "lastRevision": {"nodes": [{"id": "7534476213258340", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "7534476186591676", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1151833892899452"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"images": {"nodes": [{"file_name": "owner armyt soldie picyure.png", "id": "1896876957397785", "image_type": "APP_IMG_ICON", "uri": "https://scontent-xsp1-3.oculuscdn.com/v/t64.5771-25/75429290_1896876960731118_462