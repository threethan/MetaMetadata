c_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCm9dO3yMPmE0DtA0HgpSXHa9hYWlepgUhwbt7gEVnsVw&oe=675C33C8"}, {"file_name": "pirate ship.png", "id": "1270838327379013", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974448_1270838330712346_483726301639150244_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nf5nvjwp2fIQ7kNvgHJUDCk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCCJSIxdLyyymw10rYlWf9FKZGxAb1PJsX_g-Yxust7EA&oe=675C3655"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "39035341_210173948412680_4740011655580331961_n.png", "id": "808149744570534", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982626_808149747903867_5100784820136452062_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CIzVKLoVs0kQ7kNvgEb2uTz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD3YK9Otu57lFHyVJg3RvIFKap0totzNfBtd2sJ2oGZgg&oe=675C1A1F"}, "display_name": "Chimp Chase PVP", "keywords": [], "long_description": "Chimp Chase is a thrilling PVP game that redefines the excitement of the Gorilla Locomotion movement system. Immerse yourself in a one of a kind experience as you choose from an arsenal of primary and secondary weapons. Then, dive straight into the battle zone for intense online PVP battles with other players.\n\nComplete quests to earn ores, which you can then use to purchase a wide variety of stylish cosmetics, allowing you to pimp your chimp's appearance and express yourself on the battlefield.\n\nEnter the world of Chimp Chase and take part in awesome battles that combine skill, style, and fun to provide the best possible experience.", "short_description": "Welcome to Chimp Chase, hop straight into the battle zone with your favorite weapons and compete against other players in some good old fashioned PVP!"}]}, "developer_name": "GetaGames Limited", "developer_privacy_policy_url": "https://www.termsfeed.com/live/ffb76398-19d9-4068-8752-7b21003b1274", "developer_terms_of_service_url": "https://getagamesbusiness.