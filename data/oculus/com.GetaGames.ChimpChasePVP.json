tles in diverse landscapes. Arm yourself with AK47s, pistols, RPGs, and sniper rifles for adrenaline-fueled matches. Formerly Henwy's, now Edivence promises an action-packed, strategic experience. Ready to dominate?"}]}, "developer_name": "GetaGames", "developer_privacy_policy_url": "https://www.termsfeed.com/live/1b812005-5f34-4430-b5f9-16c9ae75121b", "developer_terms_of_service_url": null, "publisher_name": "GetaGames", "support_website_url": null, "website_url": "https://finx10.wixsite.com/chimpchase/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7534476196591675"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2726783744145028"}]}, "baseline_offer": {"id": "2726783744145028"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1712784480, "status": "PUBLISHED", "id": "2726783744145028"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "8678216445550972", "version": "1.10.20"}, "id": "1491821024735382", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "7534476186591676", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8678216445550972"}, "release_statu