86843395_6414908525109761637_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=twJhhQp5F1AQ7kNvgFZ8umO&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCjKYrlCf7kW_sUX4NBGvM3ebnpv8LBFCOb6meHbYSA9g&oe=6787B6EB"}, "display_name": "VR Mummy Girl", "keywords": [], "long_description": "A mummy girl who has been asleep deep inside a pyramid for more than 1000 years wakes up.\nShe doesn\u2019t know what era is it is, who she is, or the reason she's there.\nShe keeps walking, trying to find the exit.\n\nSwing your arms down to stretch the bandage, grab the gimmick with the bandage and jump.\nThe realistic VR and high-speed movement are exhilarating and it feels good.\nOnce you get the hang of it, you will come to know the fun of the game.\n\n* Stretching bandage\n* High speed jump movement\n* Climbing the wall / Trapeze\n* Trap that blocks the way\n* Various game stages\n* The rank of clearing the stage\n\nThe video and screenshots were taken with Quest2.", "short_description": "A mummy girl who has been asleep deep inside a pyramid for more than 1000 years wakes up.\nShe doesn\u2019t know what era is it is, who she is, or the reason she's there.\nShe keeps walking, trying to find the exit."}]}, "developer_name": "\u307e\u3053\u3061\u3083\u3093\u3068\u3044\u3063\u3057\u3087", "developer_privacy_policy_url": "https://www.withmako.com/VRMummyGirl_PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "\u307e\u3053\u3061\u3083\u3093\u3068\u3044\u3063\u3057\u3087", "support_website_url": null, "website_url": "http://www.withmako.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommen