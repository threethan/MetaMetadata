.com/v/t64.5771-25/38974835_508321905442260_1779725050188987969_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BpHnAisOohEQ7kNvgHPhFl-&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBXn5enVE_5mufKEh510NwHRpY0LsMzIcDAh3AosgpsoA&oe=6786554F"}, {"file_name": "Steam_Screenshot_02.png", "id": "2519556348434748", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035447_2519556351768081_2234390948281231888_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WNEdFgu7A-kQ7kNvgGfVC_U&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCdr3fRzgl7Zbj3rnlKJ3zH0rPTOfv7mik2yi5QG8BQLQ&oe=67863E5E"}, {"file_name": "Steam_Screenshot_03.png", "id": "1548440872700104", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982608_1548440876033437_3846505249450171897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PBwSd1ct8oYQ7kNvgGhhfXm&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAaQHsgDkcm6ZQsqobxxiBjdGlO_4fSG2Rahjz8TmLlzA&oe=67866892"}, {"file_name": "Steam_Screenshot_04.png", "id": "1285291335801131", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035456_1285291339134464_3340480892359411112_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XG2d490Rd1cQ7kNvgG_vG7c&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBMlGk0LEGg10XVinhpCwN9InDNsHCQjyPTYeLIEiJvRw&oe=678639A5"}, {"file_name": "Steam_Screenshot_05.png", "id": "1103813564447820", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974842_1103813567781153_4416741342714344124_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lVy2qNm5Gf4Q7kNvgEnh0e_&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB6NSWTY12-bPQQMJUpJZP923Rww40XyxbiHZEJamLC2w&oe=67863C87"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "461453252991834", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974613_461453256325167_5103001946371630376_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=daQEPZQQPEoQ7kNvgEIdzPi&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCiAb3wD5lWtqRuTKgTIxtFs6WXbxqxsGX4pQQJtS333Q&oe=678656C3"}, "display_name": "Crowbar Climber.", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?"}, {"images": {"nodes": [{"file_name": "\u30d2\u30fc\u30ed\u30fc\u30ab\u30cf\u3099\u30fc_3000\u00d7900px.png", "id": "2199490983740498", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001705_2199490987073831_2924059073434962003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o_cjP_OxOCYQ7kNvgFk4t46&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCadzGkn6mAHt-_2BRVNEaC65BAI2HiRIgv_SQ6jGGlTg&oe=6786554F"}, {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "1