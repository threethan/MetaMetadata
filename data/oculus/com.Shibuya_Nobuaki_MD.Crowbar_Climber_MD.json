9303010560712_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k0nSaHTPEyYQ7kNvgHkS4sd&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC8Kw4uiUwR56nysjieNExsfgQ1xVGXDlkFEoprEuB4xw&oe=6734849C"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 3.png", "id": "528808273312513", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982480_528808276645846_650673609639349305_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=giObf12tLz8Q7kNvgH-k1Lu&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBYTa7Zge93cIAMKeG8pglkxevk-gUqUv2CYIOgkeVvHA&oe=6734A273"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 4.png", "id": "1086844642814416", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75254872_1086844649481082_2280050323974735942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DgjdwD-PMZMQ7kNvgH0VwZb&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBrwPjN-XMi5TkXl-JwAUEuBVWLUYgOOTWf7c9BjUCMew&oe=6734868F"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 5.png", "id": "469226992216167", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75404388_469226995549500_1835890897211470351_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gOB6Lr98mOQQ7kNvgFvvpSo&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBfIaJbPlzJWaIuTulCckdwKo__LI4eo4JWiwhB8rgzqw&oe=673498E5"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px_en.png", "id": "2322376778126421", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035311_2322376781459754_3321103345899218788_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MEpr0lNBzKkQ7kNvgFyYWTt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC3de9weso_ecb-iw0w2BMZCTnp2x504pgN-IhYjau-NA&oe=67349D48"}, "display_name": "Crowbar Climber", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?"}]}, "developer_name": "Bazooka Studio", "developer_privacy_policy_url": "https://mydearestvr.com/en/privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "MyDearest Inc.", "support_website_url": null, "website_url": "https://mydearestvr.com/en/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_pl