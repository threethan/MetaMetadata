-iad3-2.oculuscdn.com/v/t64.5771-25/39035447_2519556351768081_2234390948281231888_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J9FJ6zvMzjMQ7kNvgEeRr9F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQH29vdfHmGAeLZhctEbqYrgHnofiFaJVDJ0i7Kjx4QQ&oe=6761545E"}, {"file_name": "Steam_Screenshot_03.png", "id": "1548440872700104", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982608_1548440876033437_3846505249450171897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_LSvAzPJaS0Q7kNvgEz41LN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCl9MCe-rTn6tMDBguWORL1wDWyKhtmA6JUAgmG4FdjfQ&oe=67617E92"}, {"file_name": "Steam_Screenshot_04.png", "id": "1285291335801131", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035456_1285291339134464_3340480892359411112_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=STN8O7nf5SUQ7kNvgHagdLb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1vWiZxH0rUViGOKxiP0_On3ZPn5MgIDRQbFkgbdYUww&oe=67614FA5"}, {"file_name": "Steam_Screenshot_05.png", "id": "1103813564447820", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974842_1103813567781153_4416741342714344124_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=I8HZ1YwFFRQQ7kNvgH-sxDJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPEOaYD9jPeiUv34lhvOdRT7vEQYAs5WLhVJ5y5lsJfg&oe=67615287"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "461453252991834", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974613_461453256325167_5103001946371630376_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aO5CiALdE9AQ7kNvgEg5AvN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDRPRLlGMdQgdBGJNu9mPLlHIduSlIYKWcJLAVU8zPpxQ&oe=67616CC3"}, "display_name": "Crowbar Climber.", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?"}, {"images": {"nodes": [{"file_name": "\u30d2\u30fc\u30ed\u30fc\u30ab\u30cf\u3099\u30fc_3000\u00d7900px.png", "id": "2199490983740498", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001705_2199490987073831_2924059073434962003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Jx562ZdEkHwQ7kNvgFdxOFz&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAW6_tGXSS9tHT2VQ8aW_HJ82DM9OS80munWkhTaqweHg&oe=67616B4F"}, {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "1600193200920430", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035422_1600193204253763_2888175221652773853_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZY9SHITb7K0Q7kNvgFOTI2h&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq-7dkMhWW1dqNiKH7V9003weMM4EQrBmpwiSa6gcO9A&oe=67