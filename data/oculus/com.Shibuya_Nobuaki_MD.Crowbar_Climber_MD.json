680_1213459303010560712_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NSOW_rPSa60Q7kNvgHG0vl_&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCyRAA2jHOCA5W20F0Y0ZUKu4-fM7DMw680egTKi0X1bw&oe=675AC01C"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 4.png", "id": "1086844642814416", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1086844649481082_2280050323974735942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aQJYuiIt038Q7kNvgHjimhv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBDnYBu1vxmHjpEW4grJl1fJsy3uRuGNfwWMY44wBhDdw&oe=675AC20F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "389280947512640", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974895_389280950845973_8381892681958163639_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W-3gE2GurIkQ7kNvgER7OZW&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBTIeDkLd6vMnhaYnkNd3b6W9G3lmEQfzG4D07YhVXcRw&oe=675AC1E8"}, "display_name": "Crowbar Climber", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "It\u2019s Finally Here! Multiplayer Mode Unlocked!\nGrab Your Crowbars and Climb to the Top \u2013 Together!\n\n**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n{3901836126764594}\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\nIt\u2019s Finally Here! Multiplayer Mode Unlocked!\nGrab Your Crowbars and Climb to the Top \u2013 Together!"}, {"images": {"nodes": [{"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "3844019052521073", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75439595_3844019055854406_1057074479581238385_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YJPGJAQM3JkQ7kNvgHpV8ha&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDD2lP9RaEIAXi4Z6mt-DanY8M4HyS7T_2qzgHkeb-7ow&oe=675ABBE5"}, {"file_name": "CrowbarClimber_Logo_JP.png", "id": "1488048641876518", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974860_1488048645209851_2609652950305837539_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tsb1uBlEx8QQ7kNvgFfOO8F&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCfXywkDS9ASWv6PIdF12WWiYVjy5w_h_kjsQPn-Fc21w&oe=675AE0A5"}, {"file_name": "\u30d2\u30fc\u30ed\u30fc\u30ab\u30cf\u3099\u30fc_3000\u00d7900px.png", "id": "1154697392950600", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57570311_1154697399617266_7889389639807948105_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=krvpvhoPtBIQ7kNvgHduwHO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDVbvLIjGZMgku5aJ6jBgxMTk32zh_P16EZJMmvkNRebg&oe=675AC3CA"}, {"file_name": "\u6b63\u65b9\u5f62\u306e\u30ab\u30cf\u3099\u30fc_1440\u00d71440px.png", "id"