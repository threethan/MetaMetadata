.5771-25/39031509_1593466838189680_1213459303010560712_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m9R2mNsC7rMQ7kNvgECE9Hg&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAkuCtbEXmgkFLnZY-p4dzaVHLrCb6QoHpqMjHgJt2nfQ&oe=6780FB9C"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 4.png", "id": "1086844642814416", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75254872_1086844649481082_2280050323974735942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TP8HSA9ITCMQ7kNvgF_I8KU&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAu2gebqBtfUzaC9pOKbRbVJzaorwlt6rdy-Q4nwtCkYA&oe=6780FD8F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px_TSUBO8SHOTA.0828@SOFTBANK.NE.JP3.png", "id": "1962996097542460", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974471_1962996104209126_4483567313594403949_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q9R6oGgpm88Q7kNvgGzytQb&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYA9Qt6S_MtYtD2_VhF6_yoXdpXF_oN5IOJxyJq_VIVnEg&oe=67810E96"}, "display_name": "Crowbar Climber", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "It\u2019s Finally Here! Multiplayer Mode Unlocked!\nA Brand-New Stage Has Arrived!\n\n**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n{3901836126764594}\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\nIt\u2019s Finally Here! Multiplayer Mode Unlocked!\nGrab Your Crowbars and Climb to the Top \u2013 Together!"}, {"images": {"nodes": [{"file_name": "\u7e26\u9577\u306e\u30ab\u30cf\u3099\u30fc_1008\u00d71440px.png", "id": "2318984705129862", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/468828100_2318984708463195_6363561151669379213_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3abu0kf0Q1IQ7kNvgHWNtuw&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDv07d8X5LuYu5dQd_PIq8_tfioIJCo1xSvbv55hTbmqw&oe=6780FCD1"}, {"file_name": "\u30a2\u30a4\u30b3\u30f3_512\u00d7512px.png", "id": "1993329574475945", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974877_1993329577809278_2209380163099589438_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TbClhg_SQGsQ7kNvgHajxTj&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBGSAD_chfdLlDoDZTBS4F7hhiwjWscahKrClFiCh96JA&oe=67810CA8"}, {"file_name": "CrowbarClimber_Logo_JP.png", "id": "1488048641876518", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974860_1488048645209851_2609652950305837539_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EpigQcymRYkQ7kNvgFbwpha&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCSCGv8p9RWAceKP6ZPkPzX5lfM79sPVFDoCosDiYAerA&oe=67811C25"}, {"file_name": "\u6b63\u65b9\u5f62\u306e\u30ab\u30cf\u3099\u30fc_1440\u