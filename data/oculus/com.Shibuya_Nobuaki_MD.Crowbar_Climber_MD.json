459303010560712_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kfuGEqQLoPkQ7kNvgEdJwfq&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCOhPtqQy-wW4TCPMsyxd4NLxVP6Ou2fubgy7rdKTbjIQ&oe=67484B1C"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 3.png", "id": "528808273312513", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982480_528808276645846_650673609639349305_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MgJA0P0wrhgQ7kNvgGFmc6o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCFO3wCtAKkTPvASLUoo1DHOPyqID2yTL09_7E-aEmCxw&oe=674868F3"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 4.png", "id": "1086844642814416", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254872_1086844649481082_2280050323974735942_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uzc_x2q0bOoQ7kNvgGkOHgN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDj1NjmO0rHepII_7FQ_7_nlCF-ho1Uae5Gif7o4nr4ig&oe=67484D0F"}, {"file_name": "\u30a2\u30fc\u30c8\u30db\u3099\u30fc\u30c8\u3099 5.png", "id": "469226992216167", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75404388_469226995549500_1835890897211470351_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FMHxgT_dMAQQ7kNvgFSdF49&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAb4iCa2qWDnVIsIfG5w-f_atNArtkueGt_9xBOzsfRwQ&oe=67485F65"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px_en.png", "id": "2322376778126421", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39035311_2322376781459754_3321103345899218788_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n1b3ECOAqm0Q7kNvgHR0Fcw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCELywm_fLJ09j6lYTVTT75tzYWKaGbRaXQWrfd1urqrA&oe=674863C8"}, "display_name": "Crowbar Climber", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?"}]}, "developer_name": "Bazooka Studio", "developer_privacy_policy_url": "https://mydearestvr.com/en/privacypolicy/", "developer_terms_of_service_url": null, "publisher_name": "MyDearest Inc.", "support_website_url": null, "website_url": "https://mydearestvr.com/en/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "459781504968480"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_