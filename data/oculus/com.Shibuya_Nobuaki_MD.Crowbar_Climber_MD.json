-ams2-1.oculuscdn.com/v/t64.5771-25/39035447_2519556351768081_2234390948281231888_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iBU7NwArTHcQ7kNvgFMwdhp&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCMtt5tyiG-VF5J6TA1i1dz7b67Kita_iNM4_MdXjm6qw&oe=675D5FDE"}, {"file_name": "Steam_Screenshot_03.png", "id": "1548440872700104", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982608_1548440876033437_3846505249450171897_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPY4jJNusmkQ7kNvgFjti2k&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD5pLL6xachoY8FpIqoX6AHL9-qohlfm9ecKKVyOMdRlg&oe=675D8A12"}, {"file_name": "Steam_Screenshot_04.png", "id": "1285291335801131", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39035456_1285291339134464_3340480892359411112_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=x_VJyfKi78gQ7kNvgF6SW0T&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDIqgrdADQj73ClhqN4fzbrxig-bSMNchg9Ra1MVlrGeQ&oe=675D5B25"}, {"file_name": "Steam_Screenshot_05.png", "id": "1103813564447820", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974842_1103813567781153_4416741342714344124_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8yvWTY-Q7jkQ7kNvgHzQ963&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDH0X4MeoIzgLlw5Hy9Uv1CZxdwpYsbQeBzRXEOGen7Tw&oe=675D5E07"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "461453252991834", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974613_461453256325167_5103001946371630376_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J53kJOJzxrkQ7kNvgH38ejP&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBqZFT1xO89Rbm6IQofLMleizvYXXLukA0th4ylk_ZDcQ&oe=675D7843"}, "display_name": "Crowbar Climber.", "keywords": ["Physics", "Crowbar", "Climber", "Climb", "Action"], "long_description": "**This game is a challenge for all VR gamers who love physics and brain teasers.**\nFor VR gamers who are strong in both mind and arm... see you at the top!\n\n\n# \ud83d\udcaaYour hands are crowbars\u2014ready to start climbing\ud83d\udcaa\n\nIn Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?\n\n{1245640926757649}\n\n# \ud83e\uddd7\u200d\u2642\ufe0fMaster the art of climbing through physics!\ud83e\uddd7\u200d\u2640\ufe0f\n\nControl your environment and body using a crowbar that reacts to every move.\nGrab hooks at the last second, launch yourself with powerful swings, and cling to ledges in creative ways.\n\n{1284515982538891}\n\n# \ud83d\udcf8Share your gameplay videos with friends!\ud83c\udfa5\n\nRecord both first-person and third-person perspectives, just like in the promo video.\n\nShow off your crowbar-climbing skills to friends or share on social media.\n\n\n{1761655857997683}", "short_description": "In Crowbar Climber, use your crowbars to make your way up!\nFace hooks, planks, and gears using only your arms.\nCan you beat the game before you run out of energy?"}, {"images": {"nodes": [{"file_name": "\u30d2\u30fc\u30ed\u30fc\u30ab\u30cf\u3099\u30fc_3000\u00d7900px.png", "id": "2199490983740498", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39001705_2199490987073831_2924059073434962003_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ez7d7Awg-IQ7kNvgEv0eMz&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDZb93nBIDNODXCyatlIrctn6QZdnkgFH2OT_Yz7AXQcQ&oe=675D76CF"}, {"file_name": "\u6a2a\u9577\u30ab\u30cf\u3099\u30fc_2560\u00d71440px.png", "id": "1600193200920430", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39035422_1600193204253763_2888175221652773853_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0A6lFnFLsxcQ7kNvgFagH4-&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCDAgmA1J2yylzo6yTnThp2uagrCMQz5zkJwg1PRgGoYQ&oe=67