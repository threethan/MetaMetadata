027783_1805333262688870103_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EN3TtCf37LsQ7kNvgFZBinD&_nc_ht=scontent.oculuscdn.com&oh=00_AYDX7W9r1CGO_jTvnzGtjK2Ou9tIBIyOUPCTD56Ka6CWtQ&oe=66D59FAD"}]}, "id": "1456690718363883", "locale": "en_US", "screenshots": [{"file_name": "1.png", "id": "3701180483437010", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974836_3701180490103676_4874609080683365939_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TPLr4dQ0wRcQ7kNvgHtfWDt&_nc_ht=scontent.oculuscdn.com&oh=00_AYBBQf24GZvYPplS-joVMdBvZkYDih1wTAOrrZVgFK3hJw&oe=66D59610"}, {"file_name": "2.png", "id": "503829585569290", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_503829588902623_8699603110406119408_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6De60ws4MXgQ7kNvgHFH8X2&_nc_ht=scontent.oculuscdn.com&oh=00_AYCgrOQDMSYcbFx9kBDR2HIPIb14xYM9rmFlD4FBytXY9Q&oe=66D5A1C3"}, {"file_name": "3.png", "id": "1057237765993092", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031554_1057237769326425_2363224287171852583_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6BFDmfGqr7YQ7kNvgGFxzAx&_nc_ht=scontent.oculuscdn.com&oh=00_AYCdhU8tqjYjtQu5BziO2lcmEB5Phbadc3co5Z8RSMGhzg&oe=66D5AEE6"}, {"file_name": "4.png", "id": "1488377815132033", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001670_1488377818465366_4369730771137685134_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hTFDnN8IEGkQ7kNvgHw6FQ3&_nc_ht=scontent.oculuscdn.com&oh=00_AYBJuEyLPBjRh3AVcJXNDloNuVnPbd3qJm1zjtqxtmEROg&oe=66D5AB44"}, {"file_name": "5.png", "id": "414882827722865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982480_414882831056198_2207792374391745331_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0ZBv-fkLOcwQ7kNvgHU1wtC&_nc_ht=scontent.oculuscdn.com&oh=00_AYAMWpH5dZiUY5cP1pla1vtRMHze0r22sAdS21DSsvfV5A&oe=66D59E7D"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "16x9-2.png", "id": "811607170639171", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86609236_811607173972504_8101196321901847264_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zLyalk0fkAgQ7kNvgFyp861&_nc_ht=scontent.oculuscdn.com&oh=00_AYBuXZVeT_qUJP5E__eAc5qXoTnzd98YhQONvouqLhqMsw&oe=66D59341"}, "display_name": "Void Ninja Demo", "keywords": ["action", "platformer", "ninja", "void", "runner"], "long_description": "Void Ninja is an **action platformer** game that blends runner elements with a unique **\u201cJinba Ittai\u201d locomotion**.  \n\n\ud83d\udc49Gameplay: You're **always on the move and can't stop**. Use your hips and shoulders to steer on the path. Overcome obstacles and clear out enemies.   \n\n\ud83d\udc49**Just one button \u2014 let your body do the rest!*** \nYou don't need to remember million of combinations, or press something to move  - run with the flow.  \n\n\ud83e\udd77\ud83e\udd77\ud83e\udd77  \n\n# Key Features:\n\n- **Unique natural flow locomotion:**   \nInspired by the \"Jinba Ittai\" philosophy, this system ensures perfect unity between player and the game - you simply act as you would in real life  \n\u2796  \n- **Comfort / Motion sickness tested:**  \n 85% of players experienced no symptoms, 10% adapted after 30 minutes, and 5% did not adjust and we prefer not to talk about them  \n\u2796 \n- **Platformer / runner:**   \nFirst-person platforming adventure inspired by a certain blue hedgehog. Intense combats,  adrenaline-pumping jumps and jet-powered flights - this game will keep your heart racing   \n \u2796 \n- **Combat dance:**   \nAs you progress, you'll develop your own unique moves and combos crafted by your skill, not pre-made by the developers  \n \u2796\n- **Level reassembly:**   \nEach time you load a level, it\u2019s generated in a new and unique way   \n\n\n\n\ud83e\udea7**4 demo levels**   \n\u279517 extra levesl available in the paid supporter version\n\n\ud83e\udd77\ud83e\udd77\ud83e\udd77 \n\nThis is work in progress version.\n**Share your thoughts, ideas and feedback with us** - let's make the game together.\n\n*rarely its 2 buttons, but you won't confuse them. Only 1 sounds better, right?\n", "short_description": "Action platformer with gesture based controls and unique locomotion."}]}, "developer_name": "Roman Yakimenko", "developer_privacy_policy_url": "https://void-ninja.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Magic Web Solutions", "support_website_url": null, "website_url": "https://void-ninja.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8167510589981576"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031591_1521482289248109_5284890786061878415_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SAGgPvExMdYQ7kNvgE93s0c&_nc_ht=scontent.oculuscdn.com&oh=00_AYCEYGW7tY8W9bBJ1SR-wJwA6UdEnBedPuaPvOPMd8pfkw&oe=66D59CED"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Void Ninja Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}], "release_date": 1644446170, "lastRevision": {"nodes": [{"id": "409081810701093", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "45