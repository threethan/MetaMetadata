orYBORSpV8xVbt3aAENaUlXqFQ&oe=67178C50"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SchooVR - Cover Art Landscape.png", "id": "1199424668034919", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86604447_1199424671368252_6882837374507473771_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MUmwoDL1ca0Q7kNvgGG_Mz5&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWX-gAJdJrXq1SrDZYzs-putsHAPzwRm2JwNkx5TMZ_Q&oe=6717794F"}, "display_name": "SchooVR", "keywords": [], "long_description": "** This is a student XR viewer application which has been created specifically for the SchooVR platform - www.schoovr.com. You will need a SchooVR Pro subscription to use with more than three headsets.** \n\nSchooVR features include\n\ud83c\udf0e Teachers/instructors can create a free account on the SchooVR platform and access 1000s of immersive resources.\n\ud83c\udf93 Students can join a lesson using a unique lesson code.\n\ud83d\ude80 Launch and guide in real-time or let students go on interactive learning journeys.\n\ud83d\udcc1 Teachers/instructors can use our Tour Creator to upload and share their own resources including PowerPoint slides, PDFs, diagrams, 360 panoramas and videos.\n\ud83c\udfeb School/districts get a discount on SchooVR Pro School licenses\n\nUtilizing the latest WebXR technology, SchooVR supports both AR and VR in the browser, making it accessible on a wide range of devices including Chromebooks, laptops, tablets, and virtual reality goggles.\n\nSchooVR enhances classroom engagement, reduces teacher planning time, and provides an interactive and fun learning environment for students\u200b\u200b\u200b\u200b\u200b\u200b\u200b\u200b. Contact us at: admin@schoovr.com for school/district discounts.\n\n*** This application does not include saved learning material or modules - its is designed to offer an immersive experience with the SchooVR platform. ***", "short_description": "This is a student viewer application which has been created specifically for the SchooVR platform - www.schoovr.com. Students can join a lesson using a unique lesson code.\n\nWhether you\u2019re visiting the Himalayas or investigating Roman and Greek Civilizations, there\u2019s something amazing to explore for every subject. Help students review key learning concepts by interacting with 360\u00b0 learning environments, reviewing differentiated content, or completing personalized learning tasks."}]}, "developer_name": null, "developer_privacy_policy_url": "https://support.schoovr.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "SchooVR", "support_website_url": "https://support.schoovr.com/", "website_url": "https://www.schoovr.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "5108963129124071"}, {"id": "1063584910766706"}, {"id": "879473995923081"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8216322138417488"}, "review_messages": ["", "", "", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036644_1205906980619912_6171891242792638637_n.png?stp=dst-png_s360x360&_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ix5NbrNkoJcQ7kNvgFVyQFC&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBnupkIiypx9ORBkah8zU0VNoeR1_FtWIJWVdrj9BrrRQ&oe=67178509"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "SchooVR", "platform": "ANDROID_6DOF", "contex