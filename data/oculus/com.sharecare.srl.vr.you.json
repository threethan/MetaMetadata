com/v/t64.5771-25/38974444_577377736778626_3922665700723868325_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eMvR5-khZH0Q7kNvgEM89bu&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA7hWAzvOTTRV8k01aYjiaAFTb-ekIU-E6pr9R8WJyBKg&oe=6756E5B3"}, {"file_name": "SCR_02.png", "id": "302615291322463", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974672_302615294655796_4980498534043519650_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-MKM94FjI20Q7kNvgHRd2iO&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBIbewgpRFUvaer0JkvGoMz16S38hKqzdFNuTiLcCkrAw&oe=6756CE9C"}, {"file_name": "SCR_04.png", "id": "1313612032392372", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974689_1313612035725705_1535331535645226958_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v1SiDg9vkWcQ7kNvgFbLG0W&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAzJxkon0ZQA6wB8OtzhBER6mVNygoEItTKe_VOpVDP1w&oe=6756CB0F"}, {"file_name": "SCR_05.png", "id": "375081281030123", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/57566696_375081284363456_7437279212040296529_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y1UwFzYzLdgQ7kNvgF2t_ZD&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAX_FSUNsZVTNCyoOQq-7kI5XfeFkartGnv7sqt3fsvNA&oe=6756F27B"}, {"file_name": "SCR_06.png", "id": "554749035589554", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974844_554749038922887_236452003771609994_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lwLByZKYUz4Q7kNvgEsS0es&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAasefyRYoNLieQxzF2uGSkXEYgl_pnn0cRfI-fthzVLg&oe=6756C55B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "OculusCoverSCLandscape_3.png", "id": "3049274152057958", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974672_3049274155391291_5102070444868881242_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fnRWt4M0VA8Q7kNvgFj4XdT&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYC0qnrYYdpj6R-AX368JauPLbQWlmBEvmfNLwNnb1RV7A&oe=6756C60F"}, "display_name": "Sharecare YOU Anatomy", "keywords": [], "long_description": "Experience the human body like never before!\n\nSharecare YOU Anatomy is a larger-than-life exploration of the Human Body that allows viewers to visualize, understand and interact with their organs. This is not a boring anatomy app, nor simple 2D video demonstration\u2013it is a fully immersive and interactive 360-degree experience you have to try for yourself!\n\nSharecare YOU Anatomy is the latest in the award-winning VR series from Sharecare, giving you an anatomical adventure like no other! It includes:\n\n\u25cf Over a dozen organs to explore from all angles, both inside and out\n\u25cf Informative labels and contextual information with voice-over pronunciations\n\u25cf High quality textures and animations, showcasing the organs' functions in full detail\n\u25cf Challenging self-quiz so you can test your knowledge\n\u25cf Enhanced visual quality on Oculus Quest 2\n\nInterested in more Sharecare products, including deeper looks into physiology, disease conditions and treatments? Find them here: https://www.sharecareyou.com", "short_description": "Sharecare YOU Anatomy lets viewers experience the Human Body like never before! Visualize, understand, and interact with their organs in this a larger-than-life VR adventure. The winner of the 2019 Appy Best VR App is now optimized for Oculus Quest, with even more content, bolder graphics, and enhanced features! Oculus Quest 2 users will especially love the enhanced visual quality!\n\nEnjoy breath-taking views of the brain, eye, heart, lungs, stomach, kidney, liver, bladder, ear, and more!"}, {"images": {"nodes": []}, "id": "180604290897412", "locale": "ru_RU", "screenshots": [], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Sharecare YOU \u0410\u043d\u0430\u0442\u043e\u043c\u0438\u044f", "keywords": [], "long_description": "Sharecare YOU \u0410\u043d\u0430\u0442\u043e\u043c\u0438\u044f \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0435\u0442 \u043f\u043e-\u043d\u043e\u0432\u043e\u043c\u0443 \u0432\u0437\u0433\u043b\u044f\u043d\u0443\u0442\u044c \u043d\u0430 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0435 \u0442\u0435\u043b\u043e! \u0420\u0430\u0441\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0439\u0442\u0435, \u0438\u0437\u0443\u0447\u0430\u0439\u0442\u0435 \u0438 \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0439\u0442\u0435 \u0441 \u0436\u0438\u0432\u044b\u043c\u0438, \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0449\u0438\u043c\u0438 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u043c\u0438 \u043e\u0440\u0433\u0430\u043d\u0430\u043c\u0438 \u043d\u0430 \u043d\u0435\u0432\u0438\u0434\u0430\u043d\u043d\u043e\u043c \u0440\u0430\u043d\u0435\u0435 \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u0443\u0440\u043e\u0432\u043d\u0435. \u0411\u043e\u043b\u0435\u0435 \u043d\u0435 \u043d\u0443\u0436\u043d\u044b \u0443\u0442\u043e\u043c\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0438 \u0441\u0445\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0430\u0442\u043b\u0430\u0441\u044b, \u0412\u0430\u0441 \u0436\u0434\u0435\u0442 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0435 \u0438\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432\u043d\u0443\u0442\u0440\u044c \u0432\u0430\u0441 \u0441\u0430\u043c\u0438\u0445!\n\n\u0414\u0435\u0441\u044f\u0442\u043a\u0438 \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0441\u0446\u0435\u043d \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0442 \u0412\u0430\u043c \u043f\u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u0441 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0430\u043c\u0438, \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0449\u0438\u043c\u0438 \u0432\u043d\u0443\u0442\u0440\u0438 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0435\u043b\u0430 - \u043e\u0434\u043d\u043e\u0433\u043e \u0438\u0437 \u0441\u0430\u043c\u044b\u0445 \u0441\u043b\u043e\u0436\u043d\u044b\u0445 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043c\u043e\u0432 \u043d\u0430 \u0417\u0435\u043c\u043b\u0435. \u0414\u043b\u044f \u0432\u0430\u0441 \u043c\u044b \u0442\u0430\u043a\u0436\u0435 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u0438\u043b\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u0432\u043d\u044b\u0435 \u043c\u0435\u0442\u043a\u0438, \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u044b\u0435 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u0438 \u0442\u0435\u0441\u0442-\u043e\u043f\u0440\u043e\u0441\u044b, \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u0431\u043e\u043b\u0435\u0435 \u0434\u0435\u0442\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u044e \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0438 \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430. \u0418 \u0432\u0441\u0435 \u044d\u0442\u043e \u043d\u0430 \u0444\u043e\u043d\u0435 \u0444\u043e\u0442\u043e\u0440\u0435\u0430\u043b\u0438\u0441\u0442\u0438\u0447\u043d\u043e\u0439 \u0433\u0440\u0430\u0444\u0438\u043a\u0438 \u0438 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0439\u0448\u0438\u0445 \u0430\u043d\u0438\u043c\u0430\u0446\u0438\u0439, \u0434\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0438\u0440\u0443\u044e\u0449\u0438\u0445 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u044e \u0440\u0430\u0431\u043e\u0442\u044b \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0438 \u0441\u0438\u0441\u0442\u0435\u043c.\n\n\u0417\u0430\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043e\u0432\u0430\u043d\u044b \u0432 \u0435\u0449\u0435 \u0431\u043e\u043b\u0435\u0435 \u0433\u043b\u0443\u0431\u043e\u043a\u043e\u043c \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0438 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u0438, \u0437\u0430\u0431\u043e\u043b\u0435\u0432\u0430\u043d\u0438\u0439, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0438\u0445 \u043b\u0435\u0447\u0435\u043d\u0438\u044f? \u041f\u043e\u0441\u0435\u0442\u0438\u0442\u0435 \u043d\u0430\u0448 \u0441\u0430\u0439\u0442 (https://www.sharecareyou.com/), \u0447\u0442\u043e\u0431\u044b \u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u0441 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430\u043c\u0438 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0434\u043b\u044f \u0434\u0440\u0443\u0433\u0438\u0445 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c.", "short_description": "Sharecare YOU \u0410\u043d\u0430\u0442\u043e\u043c\u0438\u044f - \u044d\u0442\u043e \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u043d\u043e \u043d\u043e\u0432\u044b\u0439 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u0434\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0430\u0446\u0438\u044e \u0438 \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0435 \u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0435\u043b\u0430! \u041f\u043e\u043b\u043d\u043e\u0446\u0435\u043d\u043d\u043e\u0435 VR \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432\u043d\u0443\u0442\u0440\u044c \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0438 \u0441\u0438\u0441\u0442\u0435\u043c \u0441 \u0434\u0435\u0442\u0430\u043b\u044c\u043d\u044b\u043c \u0432\u043e\u0441\u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u0435\u043c \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0438 \u0438 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u0438. \u041b\u0443\u0447\u0448\u0435\u0435 VR \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 2019 \u0433\u043e\u0434\u0430 \u043f\u043e \u0432\u0435\u0440\u0441\u0438\u0438 Appy (\u0410\u043f\u043f\u0438) \u0442\u0435\u043f\u0435\u0440\u044c \u0430\u0434\u0430\u043f\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043e \u0434\u043b\u044f Quest 2, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u043e \u0438 \u0434\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u043e, \u043a\u0430\u043a \u043f\u043e \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e, \u0442\u0430\u043a \u0438 \u0432 \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u043f\u043b\u0430\u043d\u0435. \u0412\u0430\u0441 \u0436\u0434\u0443\u0442 \u0437\u0430\u0432\u043e\u0440\u0430\u0436\u0438\u0432\u0430\u044e\u0449\u0438\u0435 \u0432\u0438\u0434\u044b \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u043c\u043e\u0437\u0433\u0430, \u0433\u043b\u0430\u0437, \u0441\u0435\u0440\u0434\u0446\u0430, \u043b\u0435\u0433\u043a\u0438\u0445, \u0436\u0435\u043b\u0443\u0434\u043a\u0430, \u043f\u043e\u0447\u0435\u043a, \u043f\u0435\u0447\u0435\u043d\u0438, \u0443\u0445\u0430 \u0438 \u043c\u043d\u043e\u0433\u043e\u0435 \u0434\u0440\u0443\u0433\u043e\u0435!"}]}, "developer_name": "Sharecare Reality Lab", "developer_privacy_policy_url": "https://www.sharecareyou.com/privacy-policy/", "developer_terms_of_service_url": "https://www.sharecareyou.com/legal/SC-YOU-ANATOMY-EULA.html", "publisher_name": "Sharecare, Inc.", "support_website_url": null, "website_url": "https://www.sharecareyou.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "MEDICINE", "SIMULATION"], "has_in