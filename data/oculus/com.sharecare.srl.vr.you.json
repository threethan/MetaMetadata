=00_AYC0qnrYYdpj6R-AX368JauPLbQWlmBEvmfNLwNnb1RV7A&oe=6756C60F"}, "display_name": "Sharecare YOU Anatomy", "keywords": [], "long_description": "THE SHARECARE YOU ANATOMY APP IS AVAILABLE ONLY THROUGH THE END OF MAY AT DISCOUNTED, \u201cAS IS,\u201d NO LONGER SUPPORTED RATE OF $5.99 PER DEVICE. THEREAFTER, IT WILL BE DISCONTINUED ALTOGETHER.\n\nExperience the human body like never before!\n\nSharecare YOU Anatomy is a larger-than-life exploration of the Human Body that allows viewers to visualize, understand and interact with their organs. This is not a boring anatomy app, nor simple 2D video demonstration\u2013it is a fully immersive and interactive 360-degree experience you have to try for yourself!", "short_description": "THE SHARECARE YOU ANATOMY APP IS AVAILABLE ONLY THROUGH THE END OF MAY AT DISCOUNTED, \u201cAS IS,\u201d NO LONGER SUPPORTED RATE OF $5.99 PER DEVICE. THEREAFTER, IT WILL BE DISCONTINUED ALTOGETHER.\n\nExperience the human body like never before!\nSharecare YOU Anatomy is a larger-than-life exploration of the Human Body that allows viewers to visualize, understand and interact with their organs."}]}, "developer_name": "Sharecare Reality Lab", "developer_privacy_policy_url": "https://www.sharecareyou.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Sharecare, Inc.", "support_website_url": null, "website_url": "https://www.sharecareyou.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "MEDICINE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction