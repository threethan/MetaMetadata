0438\u0437\u0443\u0447\u0430\u0439\u0442\u0435 \u0438 \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0439\u0442\u0435 \u0441 \u0436\u0438\u0432\u044b\u043c\u0438, \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0449\u0438\u043c\u0438 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u043c\u0438 \u043e\u0440\u0433\u0430\u043d\u0430\u043c\u0438 \u043d\u0430 \u043d\u0435\u0432\u0438\u0434\u0430\u043d\u043d\u043e\u043c \u0440\u0430\u043d\u0435\u0435 \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u0443\u0440\u043e\u0432\u043d\u0435. \u0411\u043e\u043b\u0435\u0435 \u043d\u0435 \u043d\u0443\u0436\u043d\u044b \u0443\u0442\u043e\u043c\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0438 \u0441\u0445\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u0430\u0442\u043b\u0430\u0441\u044b, \u0412\u0430\u0441 \u0436\u0434\u0435\u0442 \u0437\u0430\u0445\u0432\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0435 \u0438\u043d\u0442\u0435\u0440\u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0435 \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432\u043d\u0443\u0442\u0440\u044c \u0432\u0430\u0441 \u0441\u0430\u043c\u0438\u0445!\n\n\u0414\u0435\u0441\u044f\u0442\u043a\u0438 \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0441\u0446\u0435\u043d \u043f\u043e\u0437\u0432\u043e\u043b\u044f\u0442 \u0412\u0430\u043c \u043f\u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u0441 \u043f\u0440\u043e\u0446\u0435\u0441\u0441\u0430\u043c\u0438, \u043f\u0440\u043e\u0445\u043e\u0434\u044f\u0449\u0438\u043c\u0438 \u0432\u043d\u0443\u0442\u0440\u0438 \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0435\u043b\u0430 - \u043e\u0434\u043d\u043e\u0433\u043e \u0438\u0437 \u0441\u0430\u043c\u044b\u0445 \u0441\u043b\u043e\u0436\u043d\u044b\u0445 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u043c\u043e\u0432 \u043d\u0430 \u0417\u0435\u043c\u043b\u0435. \u0414\u043b\u044f \u0432\u0430\u0441 \u043c\u044b \u0442\u0430\u043a\u0436\u0435 \u043f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u0438\u043b\u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0442\u0438\u0432\u043d\u044b\u0435 \u043c\u0435\u0442\u043a\u0438, \u0442\u0435\u043a\u0441\u0442\u043e\u0432\u044b\u0435 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u0438 \u0442\u0435\u0441\u0442-\u043e\u043f\u0440\u043e\u0441\u044b, \u0441\u043f\u043e\u0441\u043e\u0431\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0435 \u0431\u043e\u043b\u0435\u0435 \u0434\u0435\u0442\u0430\u043b\u044c\u043d\u043e\u043c\u0443 \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u044e \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0438 \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430. \u0418 \u0432\u0441\u0435 \u044d\u0442\u043e \u043d\u0430 \u0444\u043e\u043d\u0435 \u0444\u043e\u0442\u043e\u0440\u0435\u0430\u043b\u0438\u0441\u0442\u0438\u0447\u043d\u043e\u0439 \u0433\u0440\u0430\u0444\u0438\u043a\u0438 \u0438 \u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0439\u0448\u0438\u0445 \u0430\u043d\u0438\u043c\u0430\u0446\u0438\u0439, \u0434\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0438\u0440\u0443\u044e\u0449\u0438\u0445 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u044e \u0440\u0430\u0431\u043e\u0442\u044b \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0438 \u0441\u0438\u0441\u0442\u0435\u043c.\n\n\u0417\u0430\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043e\u0432\u0430\u043d\u044b \u0432 \u0435\u0449\u0435 \u0431\u043e\u043b\u0435\u0435 \u0433\u043b\u0443\u0431\u043e\u043a\u043e\u043c \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0438 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u0438, \u0437\u0430\u0431\u043e\u043b\u0435\u0432\u0430\u043d\u0438\u0439, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0438\u0445 \u043b\u0435\u0447\u0435\u043d\u0438\u044f? \u041f\u043e\u0441\u0435\u0442\u0438\u0442\u0435 \u043d\u0430\u0448 \u0441\u0430\u0439\u0442 (https://www.sharecareyou.com/), \u0447\u0442\u043e\u0431\u044b \u043e\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0442\u044c\u0441\u044f \u0441 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u044b\u043c\u0438 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430\u043c\u0438 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438 \u0434\u043b\u044f \u0434\u0440\u0443\u0433\u0438\u0445 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c.", "short_description": "Sharecare YOU \u0410\u043d\u0430\u0442\u043e\u043c\u0438\u044f - \u044d\u0442\u043e \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u043d\u043e \u043d\u043e\u0432\u044b\u0439 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u0434\u0435\u043c\u043e\u043d\u0441\u0442\u0440\u0430\u0446\u0438\u044e \u0438 \u0438\u0437\u0443\u0447\u0435\u043d\u0438\u0435 \u0441\u0442\u0440\u043e\u0435\u043d\u0438\u044f \u0447\u0435\u043b\u043e\u0432\u0435\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0442\u0435\u043b\u0430! \u041f\u043e\u043b\u043d\u043e\u0446\u0435\u043d\u043d\u043e\u0435 VR \u043f\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432\u043d\u0443\u0442\u0440\u044c \u043e\u0440\u0433\u0430\u043d\u043e\u0432 \u0438 \u0441\u0438\u0441\u0442\u0435\u043c \u0441 \u0434\u0435\u0442\u0430\u043b\u044c\u043d\u044b\u043c \u0432\u043e\u0441\u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u0438\u0435\u043c \u0430\u043d\u0430\u0442\u043e\u043c\u0438\u0438 \u0438 \u0444\u0438\u0437\u0438\u043e\u043b\u043e\u0433\u0438\u0438. \u041b\u0443\u0447\u0448\u0435\u0435 VR \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0435 2019 \u0433\u043e\u0434\u0430 \u043f\u043e \u0432\u0435\u0440\u0441\u0438\u0438 Appy (\u0410\u043f\u043f\u0438) \u0442\u0435\u043f\u0435\u0440\u044c \u0430\u0434\u0430\u043f\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u043e \u0434\u043b\u044f Quest 2, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043d\u043e \u0438 \u0434\u043e\u043f\u043e\u043b\u043d\u0435\u043d\u043e, \u043a\u0430\u043a \u043f\u043e \u0441\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u044e, \u0442\u0430\u043a \u0438 \u0432 \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u043c \u043f\u043b\u0430\u043d\u0435. \u0412\u0430\u0441 \u0436\u0434\u0443\u0442 \u0437\u0430\u0432\u043e\u0440\u0430\u0436\u0438\u0432\u0430\u044e\u0449\u0438\u0435 \u0432\u0438\u0434\u044b \u0444\u0443\u043d\u043a\u0446\u0438\u043e\u043d\u0438\u0440\u0443\u044e\u0449\u0435\u0433\u043e \u043c\u043e\u0437\u0433\u0430, \u0433\u043b\u0430\u0437, \u0441\u0435\u0440\u0434\u0446\u0430, \u043b\u0435\u0433\u043a\u0438\u0445, \u0436\u0435\u043b\u0443\u0434\u043a\u0430, \u043f\u043e\u0447\u0435\u043a, \u043f\u0435\u0447\u0435\u043d\u0438, \u0443\u0445\u0430 \u0438 \u043c\u043d\u043e\u0433\u043e\u0435 \u0434\u0440\u0443\u0433\u043e\u0435!"}, {"images": {"nodes": [{"file_name": "OculusCoverSCSquare_1.png", "id": "3000083076881999", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982492_3000083080215332_6218957280591871939_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MRx9e68yhdoQ7kNvgG4n3cw&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD6kyclm-DEmu8ZaLWh6fNK5FXQskoooM3jFG2CVmjxXw&oe=6756C69A"}, {"file_name": "OculusHero_01.png", "id": "2959308444319280", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39036672_2959308447652613_436175383779776204_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SQ8VcFjA2AAQ7kNvgFR4ovR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCvEpNipEVUgUTSU1rrWADxgqV_GK360n00LipHbkr2mw&oe=6756DC2B"}, {"file_name": "SC_Icon.png", "id": "568626401074042", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t