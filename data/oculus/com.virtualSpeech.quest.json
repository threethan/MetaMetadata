k&oh=00_AYD7KMwwMbuKUZXy4-12tLVwnzm34jbZB_9Rno5xaUT8YQ&oe=66CDCF0F"}, {"file_name": "speech-analysis-feedback.png", "id": "334388028943301", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974602_334388035609967_2439382865423790604_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8B2PVjkGPb4Q7kNvgEYPs7N&_nc_ht=scontent.oculuscdn.com&_nc_gid=Artt4nUPwK11dmrGKY_4RVk&oh=00_AYBK595UEaDFOJCIKTEtrqiapXcfhXgbvP-YxhsUrhfyug&oe=66CD9C72"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "virtualspeech-video-thumbnail.png", "id": "3702423459989865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982528_3702423466656531_7177446497185365535_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5k89lvyHN2MQ7kNvgG1Mtd0&_nc_ht=scontent.oculuscdn.com&_nc_gid=Artt4nUPwK11dmrGKY_4RVk&oh=00_AYBpD4JfMnP3bQded5LvgBT4d_D3Asb0G_qL6VD6iY35jg&oe=66CDA2C6"}, "display_name": "VirtualSpeech", "keywords": ["training", "presentations", "speech", "skills", "interview"], "long_description": "VirtualSpeech is the ultimate training tool for improving your soft skills. With AI-powered avatars, real-time feedback, and realistic environments, you\u2019ll improve your workplace skills in areas such as presentations, leadership, sales, difficult conversations, and more.\n\nPractice in over 50 environments where you\u2019re safe to learn from mistakes with no real-life consequences.\n\nFeatures include:\n\u2605 AI-powered roleplay conversations\n\u2605 Real-time feedback on performance\n\u2605 Record your presentations and body language\n\u2605 25+ training modules\n\u2605 Add your slides, notes, and questions\n\u2605 Wide range of supported courses\n\nApp Guide and how to use the features: https://virtualspeech.com/app-guide\n\nBuild soft skills and confidence in VR, track your progress, and improve your career opportunities. Join over 550,000 learners worldwide.", "short_description": "Improve your communication skills with AI-powered avatars, real-time feedback, and realistic environments. Training on presentation skills, leadership, sales, difficult conversations, and other workplace skills.\n\nFeatures include:\n\u2605 AI-powered roleplay conversations\n\u2605 Real-time feedback on performance\n\u2605 Record your presentations and body language\n\u2605 25+ training modules\n\u2605 Add your slides, notes, and questions\n\u2605 Wide range of supported courses"}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtualspeech.com/privacy", "developer_terms_of_service_url": "https://virtualspeech.com/terms-and-conditions", "publisher_name": "VirtualSpeech", "support_website_url": "https://virtualspeech.com/contact", "website_url": "https://virtualspeech.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "421923165850360"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "7748932908472259"}, "review_messages": ["", "VRC.Quest.Asset.2 - Please remove extraneous text in Trailer Cover image."]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982724_851000743461245_2092827140860241856_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KUfjXHkCJ7wQ7kNvgGh7LEq&_nc_ht=scontent.oculuscdn.com&_nc_gid=Artt4nUPwK11dmrGKY_4RVk&oh=00_AYBAGGthOZ_Sk6ofEH0SIck6eBoVjd0CO1sTE7Ec8clieg&oe=66CDB172"}, "is_concept": false, "is_test":