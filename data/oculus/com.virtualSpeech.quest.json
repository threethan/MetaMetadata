974693_1423675061905379_342661536269244613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z4nYmrSq4UgQ7kNvgFuXhyU&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDAO3ROOA_kxjTCQSIM6wSST_FDxPzmKeo2Omngwv82hw&oe=67067FC9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "virtualspeech-video-thumbnail.png", "id": "3702423459989865", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982528_3702423466656531_7177446497185365535_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mmm3BTEKHrEQ7kNvgEdteK-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAT--DwrE2SKul388d_cRTmTTo-C3OZcUn4PRCiTvKekg&oe=67065346"}, "display_name": "VirtualSpeech", "keywords": ["training", "presentations", "speech", "skills", "interview"], "long_description": "VirtualSpeech is the ultimate training tool for improving your soft skills. With AI-powered avatars, real-time feedback, and realistic environments, you\u2019ll improve your workplace skills in areas such as presentations, leadership, sales, difficult conversations, and more.\n\nPractice in over 50 environments where you\u2019re safe to learn from mistakes with no real-life consequences.\n\nFeatures include:\n\u2605 AI-powered roleplay conversations\n\u2605 Real-time feedback on performance\n\u2605 Record your presentations and body language\n\u2605 Practice in augmented and mixed reality (MR/AR)\n\u2605 30+ training modules\n\u2605 Add your slides, notes, and questions\n\u2605 Wide range of supported courses\n\nApp Guide and how to use the features: https://virtualspeech.com/app-guide\n\nBuild soft skills and confidence in VR, track your progress, and improve your career opportunities. Join over half a million learners worldwide.", "short_description": "Improve your communication skills with AI-powered avatars, real-time feedback, and realistic environments. Training on presentation skills, leadership, sales, difficult conversations, and other workplace skills.\n\nFeatures include:\n\u2605 AI-powered roleplay conversations\n\u2605 Real-time feedback on performance\n\u2605 Record your presentations and body language\n\u2605 Practice in augmented and mixed reality (MR/AR)\n\u2605 30+ training modules\n\u2605 Add your slides, notes, and questions\n\u2605 Wide range of supported courses"}]}, "developer_name": null, "developer_privacy_policy_url": "https://virtualspeech.com/privacy", "developer_terms_of_service_url": "https://virtualspeech.com/terms-and-conditions", "publisher_name": "VirtualSpeech", "support_website_url": "https://virtualspeech.com/contact", "website_url": "https://virtualspeech.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1063584910766706"}, {"id": "879473995923081"}, {"id": "421923165850360"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["EDUCATIONAL", "PRODUCTIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8501425946556281"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982724_851000743461245_2092827140860241856_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7g3DedREiBIQ7kNvgGXhmG_&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDodZjqdHJKPf6VBZMuoSaWZpIxliydEgZLD0SB3uwZOA&oe=670661F2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VirtualSpeech", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topi