Vy-N3W&oh=00_AYDJKo7Jl5NcPxMMxk5_d9kEFSVn5JqQITuDVcjmhsykNg&oe=66F55C0F"}, {"file_name": "debating-room.png", "id": "1423675055238713", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974693_1423675061905379_342661536269244613_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0QW-Ao4fdcMQ7kNvgF9GS6x&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGWm1VtApniPcvpumVy-N3W&oh=00_AYD4yirDEy1mHQvmaujY7ttx_2UWv9cpWJGpaERwtcF-uQ&oe=66F55C49"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "virtualspeech-video-thumbnail.png", "id": "3702423459989865", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982528_3702423466656531_7177446497185365535_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bLFWl86NQ2MQ7kNvgFY_Xji&_nc_ht=scontent.oculuscdn.com&_nc_gid=AGWm1VtApniPcvpumVy-N3W&oh=00_AYCd9glW8GsHV444bqOOva4u3obSGGr0sxTKiehfTfQApQ&oe=66F52FC6"}, "display_name": "VirtualSpeech", "keywords": ["training", "presentations", "speech", "skills", "interview"], "long_description": "VirtualSpeech is the ultimate training tool for improving your soft skills. With AI-powered avatars, real-time feedback, and realistic environments, you\u2019ll improve your workplace skills in areas such as presentations, leadership, sales, difficult conversations, and more.\n\nPractice in over 50 environments where you\u2019re safe to learn from mistakes with no real-life consequences.\n\nFeatures include:\n\u2605 AI-powered roleplay conversations\n\u2605 Real-time feedback on performance\n\u2605 Record your presentations and body language\n\u2605 Practice in augmented and mixed reality (MR/AR)\n\u2605 30+ training modules\n\u2605 Add your slides, notes, and questions\n\u2605 Wide range of supported courses\n\nApp Guide and how to use the features: https://virtualspeech.com/app-guide\n\nBuild soft skills and confidence in VR, track your progress, and improve your career opportunities. Join over half a million learners worldwide.", "short_description": "Improve your communication skills 