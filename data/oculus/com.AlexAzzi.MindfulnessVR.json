uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031410_316602817837467_5758807586983106930_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8ifCkB3UqJIQ7kNvgFGybx1&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYBFQchGAW2oswphML1DjmU9Xv_0xbB-evS7J4kM1Mzz2w&oe=66F1585C"}]}, "id": "443731991737203", "locale": "en_US", "screenshots": [{"file_name": "Screenshot1.png", "id": "456232713618318", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572934_456232720284984_8331080731985449608_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=76ZLcysWIx8Q7kNvgGpdTVv&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYCcPF2o9LRNRzH6TgCB3N70cLe16WhqbVbQbQIyYwBQKQ&oe=66F138DB"}, {"file_name": "Screenshot2.png", "id": "986813126110285", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003254_986813129443618_2714275746178866392_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfvICkG09-sQ7kNvgFrmb_c&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYBSImHm2Bkd2w6Re1i3CF9Lb1sh2-Ddy2BYodfY2DzYIg&oe=66F139DE"}, {"file_name": "Screenshot3.png", "id": "1110989773499185", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39035446_1110989776832518_5339527034493652621_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H_VIdv-LvscQ7kNvgGA7I7G&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYCCphsrFgrjpa4NPgCYmmFKOxgjFAS6HYKZbcHdRRzKYg&oe=66F14B59"}, {"file_name": "Screenshot4.png", "id": "436836875710618", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001665_436836879043951_9113424110473311052_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-mTDktJbhOQQ7kNvgERX0RP&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYDofk92RJ4FNNgq6Ykk2yn02sC-QTt2twqEWqYk0br6MA&oe=66F15ED4"}, {"file_name": "Screenshot5.png", "id": "777313314371286", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75269587_777313317704619_4587312040166987246_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fl-Mw_BwBigQ7kNvgG5yeFy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYBJr92FmqkA84yx-KdisrUeGsvoG25axo0BwKDTiewdzQ&oe=66F13809"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meditation XR - Mindfulness", "keywords": [], "long_description": "Mindfulness Meditation XR is the #1 app for mindfulness practice in XR. Discover a happier, more mindful life through our meditation courses set in 360 visualizations of nature, space and art.\n\nOur meditation app is for anyone, whether you\u2019re brand new to meditation or a seasoned expert. It\u2019s also for anyone who needs a mental break, a soothing sound, or a peaceful night\u2019s rest. Our guided meditations are divided into courses, the first one being completely free and the pro courses having free previews. Many of our meditations are also available on YouTube VR.\n\nOur Masterclasses are taught by world-renowned experts in the field of mindfulness, and we have breathing timers in both visual and audio form to soothe you into a relaxed state. You can choose whether to meditate with music or without.\n\nWe\u2019re having a positive effect on more and more people each day. Take a moment to prioritize yourself today, and enjoy the app. ", "short_description": "Mindfulness Meditation XR is the #1 app for mindfulness practice in XR. Discover a happier, more mindful life through our meditation courses set in 360 visualizations of nature, space and art."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/e31ce554-cc73-4454-affe-71b6b54631e1", "developer_terms_of_service_url": null, "publisher_name": "Alex Azzi", "support_website_url": null, "website_url": "https://alexazzi.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}, {"id": "384928226018505"}], "external_s