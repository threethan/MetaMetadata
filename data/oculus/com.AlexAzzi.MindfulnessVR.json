_4231188847658352160_n.png", "id": "3697362113815693", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39001719_3697362117149026_9130148849042568281_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TKxX6ew3RRMQ7kNvgHc6sOk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC69E7pCOx1zzLm2R4tCn5kycaXYgTq4tcbzKuu2RIS7g&oe=6739EE7F"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mindfulness Meditation XR", "keywords": [], "long_description": "Immerse yourself in Mindfulness VR, a transformative meditation experience. Escape to serene landscapes, from mountains to beaches, crafted for peace. Let nature's sounds guide you: leaves rustle, waves lap. Customize sessions for your needs, whether a quick break or deep practice. With a user-friendly interface, Mindfulness VR welcomes beginners and experts alike. Rediscover peace, clarity, and balance within yourself.", "short_description": "Dive into a tranquil oasis with Mindfulness VR, your gateway to inner peace and serenity. Immerse yourself in breathtaking landscapes and soothing sounds as you embark on a journey of mindfulness and relaxation. Escape the chaos of everyday life and discover a new realm of calmness within."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/e31ce554-cc73-4454-affe-71b6b54631e1", "developer_terms_of_service_url": null, "publisher_name": "Alex Azzi", "support_website_url": null, "website_url": "https://alexazzi.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "810139357995560"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": 