0a&_nc_ohc=v2R0OogmopoQ7kNvgEpynx_&_nc_ht=scontent.oculuscdn.com&_nc_gid=A4dmo-aJh-wEjM1I7N2g3XY&oh=00_AYBh0RQMb7axFh1c6lhFsw98LwU5jYPxeXZ_mzkcuA4SGg&oe=66E6AC09"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Meditation XR - Mindfulness", "keywords": [], "long_description": "Mindfulness Meditation XR is the #1 app for mindfulness practice in XR. Discover a happier, more mindful life through our meditation courses set in 360 visualizations of nature, space and art.\n\nOur meditation app is for anyone, whether you\u2019re brand new to meditation or a seasoned expert. It\u2019s also for anyone who needs a mental break, a soothing sound, or a peaceful night\u2019s rest. Our guided meditations are divided into courses, the first one being completely free and the pro courses having free previews. Many of our meditations are also available on YouTube VR.\n\nOur Masterclasses are taught by world-renowned experts in the field of mindfulness, and we have breathing timers in both visual and audio form to soothe you into a relaxed state. You can choose whether to meditate with music or without.\n\nWe\u2019re having a positive effect on more and more people each day. Take a moment to prioritize yourself today, and enjoy the app. ", "short_description": "Mindfulness Meditation XR is the #1 app for mindfulness practice in XR. Discover a happier, more mindful life through our meditation courses set in 360 visualizations of nature, space and art."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/e31ce554-cc73-4454-affe-71b6b54631e1", "developer_terms_of_service_url": null, "publisher_name": "Alex Azzi", "support_website_url": null, "website_url": "https://alexazzi.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "1067126693731825"}, {"id": "619566195371476"}, {"id": "384928226018505"}], "exte