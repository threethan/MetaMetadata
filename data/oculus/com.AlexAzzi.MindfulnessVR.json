809447_7907415102957947053_n.png", "id": "409948208409573", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036671_409948211742906_1042359712019602992_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DOM4NTHdzRsQ7kNvgGtBstV&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYDGM00u8aa9YVjLOMopeZfGarWpMhW6uWT8VT3_J3Z0sA&oe=66F162C4"}, {"file_name": "38982700_421772567201545_4231188847658352160_n.png", "id": "3697362113815693", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001719_3697362117149026_9130148849042568281_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mf1ZMs8lu0UQ7kNvgGPrnVX&_nc_ht=scontent.oculuscdn.com&_nc_gid=AcBxvr95gMY19QNqvq5MhzZ&oh=00_AYDVVQChQbqvUeCK3vJz0jmFqQZFJP7rm-Vt_Zyct44QPQ&oe=66F16BFF"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Mindfulness Meditation XR", "keywords": [], "long_description": "Immerse yourself in Mindfulness VR, a transformative meditation experience. Escape to serene landscapes, from mountains to beaches, crafted for peace. Let nature's sounds guide you: leaves rustle, waves lap. Customize sessions for your needs, whether a quick break or deep practice. With a user-friendly interface, Mindfulness VR welcomes beginners and experts alike. Rediscover peace, clarity, and balance within yourself.", "short_description": "Dive into a tranquil oasis with Mindfulness VR, your gateway to inner peace and serenity. Immerse yourself in breathtaking landscapes and soothing sounds as you embark on a journey of mindfulness and relaxation. Escape the chaos of everyday life and discover a new realm of calmness within."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.termsfeed.com/live/e31ce554-cc73-4454-affe-71b6b54631e1", "developer_terms_of_service_url": null, "publisher_name": "Alex Azzi", "support_website_url": null, "website_url": "https://alexazzi.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362