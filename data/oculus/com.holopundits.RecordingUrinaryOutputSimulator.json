1303386284176591", "locale": "en_US", "screenshots": [{"file_name": "Recording_urinary_output_SS_01.png", "id": "1641459290060731", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974842_1641459293394064_4849429906082056127_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dpGevcnaqDEQ7kNvgE4PV6G&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBfZhAW9WXvCnipWnnHxOO2q2-nEPUSxL_yKW1ULfSwuw&oe=6773C5A0"}, {"file_name": "Recording_urinary_output_SS_02.png", "id": "2064775120637563", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036688_2064775123970896_2823803603300518747_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bRRWTLSye3oQ7kNvgH71zsP&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBvfX0xSQxmur1K5xJ1P3gwYC9N3u17S9gKafqRZRCPuw&oe=6773DF65"}, {"file_name": "Recording_urinary_output_SS_03.png", "id": "10003901396292503", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39036706_10003901399625836_7481725541577107264_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=prvKr86EKIoQ7kNvgHkSu-8&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA_jON1sJhf-QLlBQg7RmxqfeWCfL1L8tDsawZB9nfBKA&oe=6773C51E"}, {"file_name": "Recording_urinary_output_SS_04.png", "id": "1118747276306028", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974567_1118747279639361_2630598639698941212_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eZnjXw_OcuwQ7kNvgHbKzVL&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYALsALLYooc1PbtcKQ61zZybpFmJw5U5D2qTPP7luwdzQ&oe=6773C8C9"}, {"file_name": "Recording_urinary_output_SS_05.png", "id": "1112731786543003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75462205_1112731789876336_7874361370153734845_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pzCOiCaNq6UQ7kNvgHPurPy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBPn8kULvdk08KcBqssmzsBnIP65EPnLjPq2DFY2q1uKQ&oe=6773CECF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Recording_urinary_output_SS_02.png", "id": "595629112986504", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974582_595629116319837_3672331500502065539_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CRajjl9Y-kAQ7kNvgHebPGS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCJGR0TUW6r-w2FPidTDPIl6CZqbV4H1C-ISIrTZXI22A&oe=6773E225"}, "display_name": "Recording Urinary Output Simulator", "keywords": ["CNA", "nurse", "nursing", "urinary", "Healthcare"], "long_description": "In this tutorial, learners will engage in a VR simulation to measure and record urinary output. The process includes preparation, patient communication, measurement, and documentation.\n\nWith multi-language support (English, Spanish, French, and Arabic), this simulator ensures inclusivity and accessibility for a global audience.  \n\nThe experience is enhanced by an AI companion, acting as a virtual mentor, to answer questions to reinforce learning.\n \n# Key Features: \n- Multi-Language Support: Tailored instructions and narrations in four major languages to cater to diverse learners. \n- AI Companion: An interactive assistant that responds to user queries, and provides clarifications to meet learning needs.(NOTE: Generative AI is still experimental)\n\n By the end of this tutorial, participants will be able to: \n- Remember the steps for measuring and recording urinary output. \n- Understand the importance of accurate measurements in patient care. \n- Apply the procedures in a clinical setting to ensure patient safety and data accuracy. \n- Analyze and identify potential issues or abnormalities in urinary output. \n- Evaluate their techniques and make necessary adjustments for improvement. \n- Create accurate and comprehensive records of urinary output for further clinical evaluation. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn how to accurately measure and record urinary output to ensure precise patient care with AI guidance and multilingual support for better learning."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "478089301798119"}, {"id": "514087707868786"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "ar", "fr", "es_MX"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "28764512229814211"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031488_590431616707729_1706102422992719348_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9JZzJWr1b4QQ7kNvgGSdnKA&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASdSaf2xt_osA2ofcnEn81_-UiVugKKjZRCq5xVhs7nQ&oe=6773C469"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Recording Urinary Output Simulator", "platform": "ANDROID_6DOF", "context_category": {"context_category": "APPS", "id": "362692211442873"}, "context_topics": [{"topic_name": "Medical", "id": "478089301798119"}, {"topic_name": "Hands-On Training", "id": "514087707868786"}, {"topic_name": "Learning", "id": "1043107547362485"}], "release_date": 1722615305, "lastRevision": {"nodes": [{"id": "27067585739506877", "r