729975742", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974746_3469363733309075_489250372346912921_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ze_pqpDzpKIQ7kNvgFty1yu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA2EmWv1zFPuk8vdNpk3qoh5USZJs8BbhvF0Xqg3i5Hvw&oe=673F07E9"}, {"file_name": "Recording_urinary_output_SS_03.png", "id": "1859679364527166", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974732_1859679367860499_3719705938310895382_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tfyhwXEur5IQ7kNvgFUTALl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAc91GJgdyg9X3YFCW6dDCKTwoboQ-CwbHWISEJJ__9TA&oe=673F2F24"}, {"file_name": "Recording_urinary_output_SS_04.png", "id": "459450583523429", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974792_459450586856762_3358244016603382828_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c7TloOmmzLwQ7kNvgEcKfk3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDQUdlto4CqE3NciDtADR7hPmeDZXD5u21Trcw7J-cV9A&oe=673F07B9"}, {"file_name": "Recording_urinary_output_SS_05.png", "id": "480460224578456", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982699_480460227911789_6803552178662113930_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0nbqBiOOEWYQ7kNvgGM4gJL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDUWp95UFqH_PhHopMBNGK1PPnzMIF2gXQZj5S5xk6nDw&oe=673F2F97"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560X1440.png", "id": "458101067138615", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974686_458101070471948_3126529237587478707_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=paxIGHWWqgsQ7kNvgFGqQzk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCUofp0bhSkj5iU4--7e3I-W3icaXXGt5hROR_rR1ig0A&oe=673F040B"}, "display_name": "Recording Urinary Output Simulator", "keywords": [], "long_description": "In this tutorial, learners will engage in a VR simulation to measure and record urinary output. The process includes preparation, patient communication, measurement, and documentation. By the end of this tutorial, participants will be able to: \n- Remember the steps for measuring and recording urinary output. \n- Understand the importance of accurate measurements in patient care. \n- Apply the procedures in a clinical setting to ensure patient safety and data accuracy. \n- Analyze and identify potential issues or abnormalities in urinary output. \n- Evaluate their techniques and make necessary adjustments for improvement. \n- Create accurate and comprehensive records of urinary output for further clinical evaluation. \n\nThis comprehensive approach ensures CNAs are well-prepared to assist patients with feeding efficiently and compassionately in real-world clinical settings. ", "short_description": "Learn how to accurately measure and record urinary output to ensure precise patient care."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.holopundits.com/privacy-policy.html", "developer_terms_of_service_url": null, "publisher_name": "Holo Pundits", "support_website_url": null, "website_url": "https://www.holopundits.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "514087707868786"}, {"id": "478089301798119"}, {"id": "1043107547362485"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "27067585719506879"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/