ition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7297278980375793"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974512_1158801682013789_8239791124666698860_n.png?stp=dst-png_s360x360&_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=n3RpVbcxyc4Q7kNvgG8O5UK&_nc_ht=scontent.oculuscdn.com&_nc_gid=A-lHExULvGiFFS2FpMh-C2d&oh=00_AYDwxdjXdsj8EX5x9myMA9f1COcxBQq17X8d-mOvaAtzOg&oe=66CC75F2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Battle of Nowhere - Free Demo", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Shooting", "id": "1436351953220286"}], "release_date": 1717447440, "lastRevision": {"nodes": [{"id": "6411035112333522", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"applicatio