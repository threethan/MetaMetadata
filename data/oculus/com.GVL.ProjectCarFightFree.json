c_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB8hGvnZfeuDh30zxfAWKySJg27Gjfc9D6tRqxVtDxX2w&oe=675D6605"}, {"file_name": "GamePhoto-(Xavier-Grubb)_Photo4.png", "id": "1487436081961738", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75388619_1487436085295071_7484513078476327408_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=97sfg2_Uwq0Q7kNvgFhiuwk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCC4owBosl5NRNNNj-KO5LHNZQnktIixkvIGLxamwvEdQ&oe=675D7FFA"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Battle of Nowhere - Free Demo", "keywords": [], "long_description": "Purchase the ea version to unlock the full game: https://www.meta.com/experiences/6448853188462469/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOS