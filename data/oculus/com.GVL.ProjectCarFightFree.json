ps. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "You are guarding a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down."}]}, "developer_name": null, "developer_privacy_policy_url": "https://greatvictorylegends.notion.site/Privacy-Policy-80c4a267b20643cf9550850f5402e418", "developer_terms_of_service_url": null, "publisher_name": "Great Victory Legends, Inc.", "support_website_url": null, "website_url": "https://www.greatvictorylegends.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1436351953220286"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6411035099000190"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "3324584404498520"}]}, "baseline_offer": {"id": "3324584404498520"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1717447440, "status": "PUBLISHED", "id": "3324584404498520"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7236750483095310", "version": "0.5.14 free"}, "id": "2100926610299749", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_