4SlbVVaPRHjjONGrR5IPeGLM4MSFImzP78nt5LnfQ&oe=671CB9CF"}, {"file_name": "Screenshot 2024-06-17 200744.png", "id": "1680165882806800", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031499_1680165886140133_6748548161290295297_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tnxf55hI9b8Q7kNvgFEuuVd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDm8FaMrKRs7IiOwZwQtCEcvPgJx7vCJz9VAUpnovXCNw&oe=671CC44F"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "BoNCoverArt(Landscape)8-24 Carlin Jasper.png", "id": "516982287564713", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974759_516982290898046_8713658857916940054_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WmlVrNVDb_YQ7kNvgHeu-jg&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAugY-DADdndFWqMm7_omHuoPiJ2VvMFuubVpHKcAPTVw&oe=671CDF39"}, "display_name": "Battle of Nowhere - Free Demo", "keywords": [], "long_description": "Purchase the ea version to unlock the full game: https://www.meta.com/experiences/6448853188462469/\n\nYou guard a base in the middle of nowhere against waves of weird enemies. Shoot them before they take you down.\n\nFeatures:\n\n- An immersive and addictive VR arcade shooting game.\n- A variety of weapons. Different properties, upgrades, scatter rates, and recoil. It has an excellent shooting feel.\n- A variety of support props. Provides various tactical combinations for the ever-changing battlefield.\n- Unique art style and changeable weather and day and night systems.\n- Mild roguelike. Replayability.\n\nJoin our discord at https://discord.gg/2UqhEjfEAj to tell us what you like/dislike about our game, and what you want us to add.", "short_description": "In our Post Apocalyptic VR shooter, you will protect your ride out of town against the hordes of enemies coming to end you.\n\nUnleash mayhem as you decimate the opposition with a plethora of weapons, upgrades, and explosives today!"}]}, "developer_name": null, "developer_privacy_policy_ur