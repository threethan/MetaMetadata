t64.5771-25/38974499_233739879601498_8650799063942384670_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=oY9f4YemxOMQ7kNvgEe8A9e&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBu2qdOzmg1cc3cGv04ylJ2yxAE2oexCx4QVgRXNj8-qQ&oe=6749968E"}, {"file_name": "Gameplay_META_Shed_02.png", "id": "1046836919771903", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57566690_1046836923105236_2934846127604306607_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=R5CH6DCdtNkQ7kNvgHyXZtQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAC4qexCAbkA0e_1PXwFpQ8_G0XVfsCBdGlJxZmniBmgA&oe=6749B72B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "VideoCover.png", "id": "1293509128018260", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982626_1293509131351593_1906963968364817964_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ItQxcOziGwUQ7kNvgFGOzD-&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCaEhjTrWdeGL8_cWdHQ9d5CbQFiFUqAqDdV14aZg-ANQ&oe=6749B45D"}, "display_name": "Taskmaster VR", "keywords": [], "long_description": "Submit to the judgement of The Taskmaster in glorious virtual reality! The hit TV show comes to VR and YOU are the contestant. Step into the world of Taskmaster, endeavour to complete a menagerie of weird and wonderful tasks and get creative in how you solve them! \nThe premise of Taskmaster VR is simple - complete tasks and impress The Taskmaster. Sounds easy? Well, it never, ever is. There are many ways to succeed and even more ways to fail.\n\n\nYOU VS THE TASK\nMastering tasks requires skill, patience, precision and grace. And if that fails, just throw things around and hope for the best! Grab, smash, balance, magnetise, fry, pierce - do whatever you need to do.\n\nWIELD HEAPS OF ODDBALL OBJECTS\nTaskmaster VR features more weird items than you can shake a rubber duck at. Eggs will be cracked, melons smashed and toy swords brandished. Don\u2019t worry about making a mess, Alex will clear it up.\n\nEXPLORE THE TASKMASTER HOUSE\nStep into the Taskmaster House and studio where many talented comedians have wilted; will you be praised or patronised?\n\nFEATURING THE TASKMASTER AND HIS ASSISTANT\nThe Taskmaster himself, Greg Davies, and his long suffering assistant Alex Horne will have more than a few things to say about your efforts in a fully voice acted performance from the deadpan duo.\n\nWIN THE TROPHY, LOSE YOUR DIGNITY\nBecome the series champion and be bestowed with a tremendous trophy depicting The Taskmaster in a fetching shade of not-quite-gold. Losers get nothing - not even pity.\n", "short_description": "Submit yourself to the judgement of The Taskmaster in glorious virtual reality! The hit TV game show comes to VR and YOU are the contestant. Step into the world of Taskmaster, endeavour to complete a menagerie of weird and wonderful physics-based tasks and get creative in how you solve them! "}]}, "developer_name": "Scallywag Arcade", "developer_privacy_policy_url": "https://drawandcode.com/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Draw & Code", "support_website_url": null, "website_url": "https://scallywagarcade.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de", "es", "fr", "it", "ja", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "6997166970305739"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PUBLISHED", "id": "123062982