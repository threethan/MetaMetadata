-sea1-1.oculuscdn.com/v/t64.5771-25/75272208_1237961154158395_5005644889778871895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cY58uhG37MkQ7kNvgGPYNMk&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDqNm5dIrIgXa4WxBHLzAsPLDXESzKlO7hs1cYRcgY3gg&oe=6777BBD0"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q1eZTUphpjMQ7kNvgFESyoP&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYC1XtqTdRMktbWp45S9spF2YTNtawn-UpvaAaJh-jbZcg&oe=6777E9F2"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DsKVHNoiox0Q7kNvgG3nde6&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCVbDRN2DGjN2ANhRZmsoYG8QF8IwBfSr8LXTLAA3n18A&oe=6777D129"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QJ6ulDENy8oQ7kNvgGNdazE&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDI0wFgB8cE3uYVfxDEhdV0V7O4nobQx-Mw662umqIolg&oe=6777C09C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yfaSCKjQgkoQ7kNvgH220HB&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCHPMKdZhdNxjus-dgwdNUBSpXKZXKWtapBPEoM5HzrTA&oe=6777B947"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_theme_coverlandscape_[2560x1440px_002.png", "id": "770524935205836", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031341_770524938539169_6889252562189588358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zU9dpa_tn3oQ7kNvgFUGD2D&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYDlUDFFHQ_lCzOsp2jHd7wLk0uespv0TPk-m6BblAffXw&oe=6777E643"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorv