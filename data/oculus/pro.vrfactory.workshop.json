GexnyO8QQ7kNvgGpH0lO&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDneetSMPvU3hZcHG-qg5GqmXozeVNBzaZLYNfk9nNLxQ&oe=675EAF50"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=us85MXgjL6kQ7kNvgFSaMBd&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYAHiYeEZx-LysV887PfQZfOl4M626FY--3h6TBXeoMIBA&oe=675EDD72"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UIqIyRzD1FEQ7kNvgHPp3l1&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYARtK2B-CkSL5Ol_EMxBErBE3cY_r8xJw9W0Xo-lHDwQA&oe=675EC4A9"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=kYQW-v5f_XkQ7kNvgGiLraE&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYD1PnQbjOqiETJZ1Gkj3GTZc8FDuEQQIV5jV__nhKxqeQ&oe=675EB41C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t5QShzpVIbYQ7kNvgE7VLsb&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYByjlmNg-NkhlPx93Z2Q67elL4VX8JijzRMW8Q2_-cC2g&oe=675EACC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_Haptic_Feedback__coverlandscape_[2560x1440px]_002.png", "id": "591309303456360", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39001694_591309310123026_5573451597278605590_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pN2VcMJlRDgQ7kNvgFJecJm&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYCUB8yEJGtC60bBj21PUET5NEyXIzHntYKa41JJVkymGQ&oe=675ED5AD"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VR Factory Games S.A.", "support_website