=1-7&_nc_sid=6e7a0a&_nc_ohc=yTBIKRmRqRoQ7kNvgH0mfek&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAfCvUgS1tiVVTyeIUTzSxT4Tfcbe7Iqe3v7VURiNdRDw&oe=677275D0"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QgsPdoGR54YQ7kNvgH_toIu&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCrskiaSKHhpYhbwJAxeUgAfKD_n_sHg0RGkOpny1phfw&oe=67726BB2"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iOeBaz2pJEEQ7kNvgGBS9hF&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBYrzyaOlcVp_GTUy91GyHJ1AhfjTHwNmffUzx-mCir_Q&oe=67728B29"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_1kA_U8TCn0Q7kNvgESxtH1&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBYZGUlEEwoZdOYB0zYjj4HcoCcKAFNXNtcoPeSLTrmYA&oe=67727A9C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=29Ky3EvRisQQ7kNvgH67Cc3&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCR5LD6DpM7pMwIKO87t_fNS-HhCCkTZ5IvT6UZQ2Zf2w&oe=67727347"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_sound_effects_update_coverlandscape_[2560x1440px]_001.png", "id": "1103584494350759", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/44000512_1103584497684092_8604947933276651617_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X2gjEkmeQDUQ7kNvgEc0s4Y&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCkCSgqDozMgloLubYq85wbk_A1oB48EltKc6rkgk7eqQ&oe=67729502"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VR 