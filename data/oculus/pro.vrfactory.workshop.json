-fra3-1.oculuscdn.com/v/t64.5771-25/75272208_1237961154158395_5005644889778871895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Soe_4CJ_SwgQ7kNvgGOccCV&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD28Mzk__vcHhzQNLo-NksjertspAbSsMeJYGB6SjALfA&oe=67878DD0"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4VGcCky7nRoQ7kNvgGEnA-D&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCCs44NSZNhjLT1BOwZ2RWKhRPT3p2Gbo9bNVAYFLGgsg&oe=678783B2"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wg4AikbguuEQ7kNvgHX-K8J&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYBKkI5O_kqD_M_WK4rpsZJLHIvThjQswr2r5ZccfYipNw&oe=6787A329"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K1t1hL0qhVgQ7kNvgGVP1J8&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCJMN9jo5VZAZMil99joBJYzG9vvcCpZqgUjmxqu2TOwg&oe=6787929C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=caby42HiTqUQ7kNvgFQNKGf&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYAq-lL-QY5dmaikw96YAtZ9dfJqlkBbULuTQ6wl8O2WEg&oe=67878B47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_theme_coverlandscape_[2560x1440px_002.png", "id": "770524935205836", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031341_770524938539169_6889252562189588358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-WRRbH62C0sQ7kNvgH4yWnd&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCsfMAatcYbLW1tqD-Wwo6m9Ha0Q0zICgBOgf04-_Vbjg&oe=6787B843"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorv