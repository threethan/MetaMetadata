-ams4-1.oculuscdn.com/v/t64.5771-25/75272208_1237961154158395_5005644889778871895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JQ27Vkm_gwkQ7kNvgEjoA9o&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDTCTFgpgkWjlUIom_N_9FGw3-eumQ1Uyu-LqC7BovuNg&oe=677BB050"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UsBL_VY61VYQ7kNvgGZSJlt&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA8gimERS5zwDF4YoCU6fLF8q1SzjhkonFOD4gYf4xrGQ&oe=677BDE72"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-aP9fbhuilkQ7kNvgF5VqVy&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD5LdjR3luuroi2jt7NF7LUCoA2ZJrqxkI8Mi2_TDCTVw&oe=677BC5A9"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Pn1YYAG9cC0Q7kNvgF0x5S2&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD40foHnV-vdV6Y0S0cuOWQypSKFPc6oiC79w27WmFW1w&oe=677BB51C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xq6guw1BowAQ7kNvgEIEsUR&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCaaIUG7w-SZK6DUb-8SrDHwUxxx4UGnG8uBGRLe2EXNA&oe=677BADC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_theme_coverlandscape_[2560x1440px_002.png", "id": "770524935205836", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031341_770524938539169_6889252562189588358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=H2GhzBUG1GIQ7kNvgG88yP0&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBZnORzE1FOn61JopN97k0j2TDzhdlW-UnXTIuJtRpHvw&oe=677BDAC3"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorv