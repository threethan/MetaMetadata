=1-7&_nc_sid=6e7a0a&_nc_ohc=XymkVDWFokgQ7kNvgEIlokP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAMZgtuFCAsRKJRsN3KeL1u3OrsvEp9svRuc9okjPF69g&oe=676A8CD0"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MhpPNLsAJzsQ7kNvgF7gcLb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2lpNkRUtQwYuOXIkKXu9pshIu24jZNxIKAaNMATza2A&oe=676A82B2"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wJRBQf8iC2EQ7kNvgFGOoTR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD1dOP5qq-4khkd4QF5DezhIFLOMrovn2IqdQ6YmLzpLg&oe=676AA229"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yahHBzzAwOQQ7kNvgFwVTPb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBYjFo0sANcaETZA-zrC5Yk_al9JxAMBUBgHqiQxvYsqA&oe=676A919C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FA76Xd1pH-IQ7kNvgGxamgK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPAZgllRKftsezY75zDzYjrEpOQ5MdP6FdlyqG6LfjxA&oe=676A8A47"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_sound_effects_update_coverlandscape_[2560x1440px]_001.png", "id": "1103584494350759", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/44000512_1103584497684092_8604947933276651617_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sGUQkPMUTTYQ7kNvgF1Eo3N&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbA_nOtYVvS7g8N3EMP8ydyPTxW631Ust22FPHxqIyXw&oe=676AAC02"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorvr.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "VR 