-iad3-1.oculuscdn.com/v/t64.5771-25/75272208_1237961154158395_5005644889778871895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AXqHm0EjY8YQ7kNvgHJuX0Z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq3QmqWPTB09lCo_1DfmCHiLvyYe1eBzsuAqVEsUwFlQ&oe=67839950"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JtPXHqK4ulQQ7kNvgFPpWYQ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCGgktPqul1wk0IBXbPj31AaIaS4l91xZB1OKug_IsFCg&oe=67838F32"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lEzBJoafpw8Q7kNvgHfMIID&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAMzDEzCwUL7lfXuNBtAQyjJHPz3598aCAbxJgWaJiF8w&oe=6783AEA9"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wzKvik9kB-4Q7kNvgFveiPM&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBw90RfFxFUkJbFlSlr1k8x3uq6xe70wGcqFrSiywiXmQ&oe=67839E1C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6qCg3Ar0560Q7kNvgFVNRNL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAWjF4kPmyjWnZ2aY94lIgLhaUrVaUTXWepczvfYwj6bQ&oe=678396C7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_theme_coverlandscape_[2560x1440px_002.png", "id": "770524935205836", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031341_770524938539169_6889252562189588358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=88Ob60eQu-4Q7kNvgED13yu&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCPmEJrpaSmwWK5E6m3EaStwu9dd65cBUvlahk1pT6Spg&oe=6783C3C3"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorv