-iad3-1.oculuscdn.com/v/t64.5771-25/75272208_1237961154158395_5005644889778871895_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cY58uhG37MkQ7kNvgGrz-EU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCx3TWMZGwC5FNj5GpJHugqazVZOJDMC1K9Wn8gl9kwZw&oe=67790D50"}, {"file_name": "10.png", "id": "1490606904974164", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210891_1490606908307497_6798544285335966650_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Q1eZTUphpjMQ7kNvgEAdvpO&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC97MfhU1R_t1b0Wq_N5xjz4bSAGBRNz6xbf_7XHJKA0g&oe=67790332"}, {"file_name": "2.png", "id": "2001218930391803", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974893_2001218933725136_9161596949914938310_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-aP9fbhuilkQ7kNvgHq1y6Z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCp4_mnkhqzkXC8jdk695iVIHIkoNFwJYix3qVjUAW7iA&oe=677922A9"}, {"file_name": "7.png", "id": "9404516012898764", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031588_9404516022898763_8012595287728672818_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QJ6ulDENy8oQ7kNvgFPjns1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAkvZNdaXUQ9gUcz5wTEopXF8p-hGqGw6VoPBCT9ma2SA&oe=6779121C"}, {"file_name": "3.png", "id": "1262456198515726", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031588_1262456201849059_7740034526890360408_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yfaSCKjQgkoQ7kNvgEyHKKy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBcDCaIQVlzv7r8Hq6T_EbbI3TY3j85qItCM030JTCrxQ&oe=67790AC7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "workshop_theme_coverlandscape_[2560x1440px_002.png", "id": "770524935205836", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031341_770524938539169_6889252562189588358_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zU9dpa_tn3oQ7kNvgFDQ65s&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvF7Nkta-Xwl09OHlkgq9Ec1DcPqT-b5LayGiWdiDv5A&oe=677937C3"}, "display_name": "WORKSHOP SIMULATOR VR", "keywords": ["renovation", "relax", "casual", "cozy", "paint"], "long_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop.\n\n# \ud83d\udd27 Disassemble & Assemble: \n\nUse a special arm, manual, and mechanical tools to unscrew and screw bolts, remove and hammer nails, and take apart the most intricate structures. Reassemble items to restore them to their original glory.\n\n{1124376772351607}\n\n# \ud83e\uddfc Cleaning:\n\nCarefully wash all surfaces with a special cleaning solution, sponge, or pressure washer. Then, clean and polish every crevice of each item with a wire brush, grinder, or sandblaster. Your earnings and reputation depend entirely on the quality of your work.\n\n{1222923442095773}\n\n# \ud83c\udfa8 Make it beautiful:\n\nUse brushes, colorful sprays, or an airbrush. Unleash your creativity by choosing colors and techniques to breathe new life into every item, transforming it into a unique piece of art.\n\n{1744297086322860}\n\n# Key features:\n\n- Play as the owner of the Workshop\n- Variety of tools and workshop techniques\n- Diverse tasks to complete\n- Interactive, physics-based objects\n- Expand and develop your workshop", "short_description": "**Workshop Simulator VR** is a simulation game where you take on the role of a workshop owner, equipped with a range of specialized tools. Become a master of restoring various items, take on increasingly complex tasks, earn money, build your reputation, buy new tools, replenish resources, and expand your workshop. "}]}, "developer_name": "VR Factory Games S.A.", "developer_privacy_policy_url": "https://workshopsimulatorv