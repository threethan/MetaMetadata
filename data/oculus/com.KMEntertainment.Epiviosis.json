2-1.oculuscdn.com&oh=00_AYAyfjWylcmBWChyi974U-a98vI-owhksvS-c43yY1TqUA&oe=6780FE87"}, {"file_name": "screen04.png", "id": "1194826387632547", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38984464_1194826390965880_6614854191027359345_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CwvMzQqlyGMQ7kNvgF4ERbg&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBnX2dNESzAVhBRGK5PCLtH-_lKqrn1RfORrnhkzbyIcA&oe=6780FB65"}, {"file_name": "screen05.png", "id": "336610621290058", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974538_336610624623391_6519872809688220140_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KyC-6J_LXT8Q7kNvgEiGgWW&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDtWhHZDsoC0C3C24-GCgo8_GEEcvy2Yjw-EnYdVJjKPA&oe=67811415"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_horizontal_2560x1440.png", "id": "4509630855747264", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974499_4509630862413930_2627979156702783130_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCyqR-fdWh0Q7kNvgElCMFp&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB5-XcjG3T102jEItwgvq1T79ralm34yiJBpxHqs5DQ6w&oe=678116B0"}, "display_name": "Epiviosis", "keywords": [], "long_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy. Benefit from various power-ups that fall from the sky.\n\nThere are two play modes in Epiviosis:\n\n1. Story Mode\nEarth, as we know it, is coming to an end. Try to get to the escape vehicle that leaves Earth for another habitable planet! Make your way through waves of enemies and reach your final destination.\n\n2. Epiviosis Mode\nAs you complete Story mode levels, Epiviosis mode unlocks the same levels. But, now, you have to survive against time! The longer you stay alive, the better your score!\n\n", "short_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy.\n\nTwo play modes: \n1. Story Mode \n2. Epiviosis Mode"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.km-entertainment.com/epiviosis/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "KM Entertainment", "support_website_url": null, "website_url": "https://www.km-entertainment.com/epiviosis/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3744040075834813"}, {"id": "644354873106712"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "906799163239334"}}]}, "scheduled_offers": {"count": 0, "nodes": []}, "baseline_offer": null, "is_approved": true, "firstOffer": {"nodes": []}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "4135188569879911", "version": "1"}, "id": "298751275280799", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "4131294590269309", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "4135188569879911"}, "release_status": "RELEASED"}, "bi