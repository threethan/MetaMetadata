984464_1194826390965880_6614854191027359345_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=j0FYJ5LvCt8Q7kNvgHdbmj2&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANtw7guFhDNYVJYarsAxHlM&oh=00_AYB3vdBJbR2MfgSytK4NcZsGgoe8eOmA3ADYwW7bNMXa8w&oe=66E80D65"}, {"file_name": "screen05.png", "id": "336610621290058", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974538_336610624623391_6519872809688220140_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BUEihzQybS8Q7kNvgF5JHvw&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANtw7guFhDNYVJYarsAxHlM&oh=00_AYAb0ly6vwKdpj72l3fsJ1UN2JlA-lcPC6Xs4b0W63lnAg&oe=66E82615"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_horizontal_2560x1440.png", "id": "4509630855747264", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974499_4509630862413930_2627979156702783130_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XhQebtVleOkQ7kNvgF1arA7&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANtw7guFhDNYVJYarsAxHlM&oh=00_AYAnAjxaVHD2w_0-yTpX16HrOjsi2kE7_v1RCos6-bWMBQ&oe=66E828B0"}, "display_name": "Epiviosis", "keywords": [], "long_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy. Benefit from various power-ups that fall from the sky.\n\nThere are two play modes in Epiviosis:\n\n1. Story Mode\nEarth, as we know it, is coming to an end. Try to get to the escape vehicle that leaves Earth for another habitable planet! Make your way through waves of enemies and reach your final destination.\n\n2. Epiviosis Mode\nAs you complete Story mode levels, Epiviosis mode unlocks the same levels. But, now, you have to survive against time! The longer you stay alive, the better your score!\n\n", "short_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy.\n\nTwo play modes: \n1. Story Mode \n2. Epiviosis Mode"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.km-entertainment.com/epiviosis/privacy_policy.html", "developer_terms_of_service_url": null, "publisher_name": "KM Entertainment", "support_website_url": null, "website_url": "https://www.km-entertainment.com/epiviosis/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "906799163239334"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974848_387748599260069_6673653473802838069_n.png?stp=dst-png_s360x360&_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W1QTKUgC_PIQ7kNvgFAEQ-x&_nc_ht=scontent.oculuscdn.com&_nc_gid=ANtw7guFhDNYVJYarsAxHlM&oh=00_AYB4aBoCLboHaLN7njP_DbV4Q0xggzVAuarR5hKnbvxoHQ&oe=66E818AA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Epiviosis", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [], "release_date": 1625702038, "lastRevision": {"nodes": [{"id": "580672342905094", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"application": {"default_locale": "en_US", "id": "4131294590269309", "is_first_party": false, "enables_in_app_ads": false, "is_concept": false, "platform": "ANDROID_6DOF"}, "iarc_cert": {"id": "1003946950375629"}, "iarc_email": null, "msrp": null, "translations": {"nodes": [{"ima