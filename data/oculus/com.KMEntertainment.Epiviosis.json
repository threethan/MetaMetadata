c3-1.oculuscdn.com&oh=00_AYAp2TfcU6-sBQYVp5BM7FN8mDeSbM0eqyS1I1pyFUgUdA&oe=6724B587"}, {"file_name": "screen04.png", "id": "1194826387632547", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984464_1194826390965880_6614854191027359345_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8noxdwyMMG4Q7kNvgEMnjah&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBdr-40rnrWR98iD5_xfIzukwyBQ1--dxS8XtO9_3gAMQ&oe=6724B265"}, {"file_name": "screen05.png", "id": "336610621290058", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974538_336610624623391_6519872809688220140_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rSU6BM8eK7gQ7kNvgHWXsAT&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCg_1qwgJLHiuZRao0-BcBvRvnUpLyVl5bvtzVDZXIfHQ&oe=6724CB15"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_horizontal_2560x1440.png", "id": "4509630855747264", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974499_4509630862413930_2627979156702783130_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OG8Es7rWWUwQ7kNvgFCAoc-&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAAxup-M_t88ISHS0krGesJFudN3EMAJjMZUsPqqOXNDw&oe=6724CDB0"}, "display_name": "Epiviosis", "keywords": [], "long_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy. Benefit from various power-ups that fall from the sky.\n\nThere are two play modes in Epiviosis:\n\n1. Story Mode\nEarth, as we know it, is coming to an end. Try to get to the escape vehicle that leaves Earth for another habitable planet! Make your way through waves of enemies and reach your final destination.\n\n2. Epiviosis Mode\nAs you complete Story mode levels, Epiviosis mode unlocks the same levels. But, now, you have to survive against time! The longer you stay alive, the better your score!\n\n", "short_descriptio