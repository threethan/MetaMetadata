d3-2.oculuscdn.com&oh=00_AYAzCLC4umy7BdDIzQU1UX2hNOnV8CfW9MukNVuUbXGoCw&oe=67372A87"}, {"file_name": "screen04.png", "id": "1194826387632547", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984464_1194826390965880_6614854191027359345_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sEftC4Qu4FAQ7kNvgHIS561&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRmmDhyyROUuT1CHk1iymT49S_CYjo-LB6OYs48oZZ8g&oe=67372765"}, {"file_name": "screen05.png", "id": "336610621290058", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974538_336610624623391_6519872809688220140_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K9dRflWioXIQ7kNvgEAZ6tT&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCerHAGWuA8ewGKqaqo_9P1fCow25gtXLhDys919baN-A&oe=67374015"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "cover_horizontal_2560x1440.png", "id": "4509630855747264", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974499_4509630862413930_2627979156702783130_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iO0gyxmPc1EQ7kNvgEcvPBi&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDLTN0-CKvveQG1JpLIOlEeQ9PS3ErbNE2FMTfvTkBjA&oe=673742B0"}, "display_name": "Epiviosis", "keywords": [], "long_description": "Epiviosis is a VR FPS game created for the Oculus Quest 1 and 2. \"Epiviosis\" is the greek word for \"Survival\".\n\nFast action, destructible environment, various kinds of enemies and vehicles to destroy. Benefit from various power-ups that fall from the sky.\n\nThere are two play modes in Epiviosis:\n\n1. Story Mode\nEarth, as we know it, is coming to an end. Try to get to the escape vehicle that leaves Earth for another habitable planet! Make your way through waves of enemies and reach your final destination.\n\n2. Epiviosis Mode\nAs you complete Story mode levels, Epiviosis mode unlocks the same levels. But, now, you have to survive against time! The longer you stay alive, the better your score!\n\n", "short_descriptio