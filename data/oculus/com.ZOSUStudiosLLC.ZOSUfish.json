Q7kNvgHb-Qjx&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYAiS0ud8EwmOoOPXThNSS7bSuVzQyp2Pl8-maoyYifSYQ&oe=6728A28C"}, {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w0012  cob.png", "id": "1559235387862587", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982440_1559235391195920_6496480092832263949_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yLRuYp23ZSUQ7kNvgFun2Dy&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYChHLDQ-nkIQxq38xxnhISDrU_pBWzJbln9-BbXi17kTg&oe=6728B601"}, {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w0012b.png", "id": "501823938670509", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974783_501823942003842_5107915751943572088_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lJ51ek-t4AkQ7kNvgGt93hI&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYCcPIZbg3DT8YP2d0xY-LjhMVf_uy9qyNybt1Pp8udFaw&oe=672898F4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape ocean.png", "id": "426732919647217", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974740_426732922980550_2042688344430875991_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xBD2Kissu_YQ7kNvgH5OpH2&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYA11deM04uXWFkIQ91Q_l7MmqT7oRY3eA_-N8vO88jv4Q&oe=6728C8DD"}, "display_name": "Ocean Passthrough", "keywords": [], "long_description": "Experience an ocean in your home!\n- over 100 hundred sea creatures and (updated) bonus level 50+ toy sized land animals/dinosaurs\n- August 2024 update: added object s position save state and custom mixed reality visual boundary to various areas and added a bonus jungle area\n- full Passthrough / Mixed Reality, Handtracking\n- move, delete, spawn animals to create your own ocean home! \n- turtles, sharks, whales, dolphins, clown fish, starfish, crocodiles, octopus, extinct dinosaur fish, piranha, and a wide variety of exotic and common sea creatures! + much more!\n-  bonus toy / table top land animals include:  rhino, elephant, t-rex, deer, crocodile, tiger, leopard, hippo, zebra, dogs, cats, various farms animals and dinosaurs, and more!\n- 10 scenes to explore, all with ability to spawn & delete fish and to move stationary fish:\n\u2014 feed swimming fish to a shark, feed fish to swimming sharks\n\u2014 swimming fish on random spawn\n\u2014 varying pre-made fish scenes\n\u2014 2 scenes full of turtles\n\u2014 empty scene to spawn fish\n\u2014 mammals only", "short_description": "Experience an ocean in your home!\n- 100+ hundred sea creatures, bonus level 50+ toy sized land animals/dinosaurs, bonus jungle \n- Passthrough, Handtracking\n- move, delete, spawn animals to create your own ocean home\n- turtles, sharks, whales, dolphins, octopus, extinct dinosaur fish, & a wide variety of exotic & common sea creatures +much more\n- 10 scenes to explore, all with ability to spawn and delete fish, including:\n\u2014 feed sharks\n\u2014 swimming fish on random spawn\n\u2014 varying pre-made fish scenes"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "CASUAL", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_