kNvgF1moJr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAak5Pnp-xXy3uqf7dKgayMzAYzuIC3bdCC6nMThUgL6A&oe=673F0C0C"}, {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w0012  cob.png", "id": "1559235387862587", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982440_1559235391195920_6496480092832263949_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WKpHHvriYjYQ7kNvgEmTHxa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBmzICueducuPZaSDCXqoXQ-Zotw_T9ywCovU9jGxQv2w&oe=673F1F81"}, {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape w0012b.png", "id": "501823938670509", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974783_501823942003842_5107915751943572088_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ufw8tWWETvEQ7kNvgEs5Azx&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvkWmN3ZWyC--zNXmPI61h-9inB_XSDj9rqbH-SiY-EA&oe=673F0274"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImageSafeAreaTemplate not t miniLandscape ocean.png", "id": "426732919647217", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974740_426732922980550_2042688344430875991_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=aFEXORqeAJMQ7kNvgFIH0_J&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCwwoR-ooghBx_Lfed9ryBOIOYzmVm4mYKzXji7avQwOA&oe=673F325D"}, "display_name": "Ocean Passthrough", "keywords": [], "long_description": "Experience an ocean in your home!\n- over 100 hundred sea creatures and (updated) bonus level 50+ toy sized land animals/dinosaurs\n- August 2024 update: added object s position save state and custom mixed reality visual boundary to various areas and added a bonus jungle area\n- full Passthrough / Mixed Reality, Handtracking\n- move, delete, spawn animals to create your own ocean home! \n- turtles, sharks, whales, dolphins, clown fish, starfish, crocodiles, octopus, extinct dinosaur fish, piranha, and a wide variety of exotic and common sea creatures! + much more!\n-  bonus toy / table top land animals include:  rhino, elephant, t-rex, deer, crocodile, tiger, leopard, hippo, zebra, dogs, cats, various farms animals and dinosaurs, and more!\n- 10 scenes to explore, all with ability to spawn & delete fish and to move stationary fish:\n\u2014 feed swimming fish to a shark, feed fish to swimming sharks\n\u2014 swimming fish on random spawn\n\u2014 varying pre-made fish scenes\n\u2014 2 scenes full of turtles\n\u2014 empty scene to spawn fish\n\u2014 mammals only", "short_description": "Experience an ocean in your home!\n- 100+ hundred sea creatures, bonus level 50+ toy sized land animals/dinosaurs, bonus jungle \n- Passthrough, Handtracking\n- move, delete, spawn animals to create your own ocean home\n- turtles, sharks, whales, dolphins, octopus, extinct dinosaur fish, & a wide variety of exotic & common sea creatures +much more\n- 10 scenes to explore, all with ability to spawn and delete fish, including:\n\u2014 feed sharks\n\u2014 swimming fish on random spawn\n\u2014 varying pre-made fish scenes"}]}, "developer_name": null, "developer_privacy_policy_url": "https://zosustudios.wixsite.com/website/about", "developer_terms_of_service_url": "https://zosustudios.wixsite.com/website/about", "publisher_name": "ZOSU Studios LLC", "support_website_url": null, "website_url": "http://www.zosustudios.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "CASUAL", "DINOSAURS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING"], "supported_tracking_mo