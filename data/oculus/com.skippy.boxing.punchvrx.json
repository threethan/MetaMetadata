itness", "health", "sports", "fighting"], "long_description": "Live your dream of a boxing champion and conquer the ring. Push attack and defend to fully surprise your opponent. Amazing gameplay with outclass environment will make you feel the real experience of what it looks like to be a boxing master.\n\nFor fitness, use the training equipment in the Gym and play with your real friends in Multiplayer mode. The game is still in development and check frequent updates as we improve the opponent AI for achieve professional fighting and more interested training and other fighting features.", "short_description": "Get into the boxing ring and show your boxing skills. Defend and block the opponent and attack when ready. Play with real friends in Multiplayer mode."}]}, "developer_name": "XZ Solutions", "developer_privacy_policy_url": "https://skippyapps.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Skippy Apps PTY LTD.", "support_website_url": null, "website_url": "https://skippyapps.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "331529188132278"}, {"id": "2710427532541308"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FIGHTING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "OCULUS_TOUCH", "HAND_TRACKING"], "supported_player_modes": ["STANDING", "ROOM_SCALE", "SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER", "SINGLE_USER"], "id": "8754922484525924"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/75556792_1012465920362338_7884146082576397602_n.png?