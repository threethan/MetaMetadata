&_nc_ohc=UWiJ2bTYA8QQ7kNvgEYDA8P&_nc_ht=scontent.oculuscdn.com&oh=00_AYDZY6Q5qepsmI44fk3sMsA7mFakIRFz5pvPBgaErx5BjA&oe=66D2F9AE"}, "display_name": "Dragon Fist: VR Kung Fu", "keywords": [], "long_description": "Step into your own kung fu movie with colourful characters inspired by Chinese and Hong Kong martial arts movies across the decades. Whether you fancy playing as an old wise master, or a young gifted female kung fu student, or a shaolin monk, Bruce Lee inspired character, samurai or a ninja there's bound to be someone for you...\n\nBlock attacks with your hands or forearms, or bob and weave, push their arms out the way, or move about, how you fight is up to you. But your opponents might use different strategies also, so you must learn how to foresee their attacks and how best to attack them.\n\nYou opponents all have the same controls as you, no advantage, no disadvantage. Except on easier levels they will have less strength - they will also have their speed and intelligence reduced.\n\n40 different characters that have various colourful costumes and have their own special moves to learn and use. Each character has their own fighting style to fight against as well as a perk and a weakness.", "short_description": "First person VR Kung Fu combat against a variety of different opponents, with a variety of different fighting styles, special moves and back stories. Unlock over 40 different characters, multiple stages, and take on the masters! "}]}, "developer_name": "Ben Olding Games", "developer_privacy_policy_url": "http://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": "http://www.benoldinggames.co.uk/Contact-Me.htm", "website_url": "http://clique.games/dragonfist", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ARCADE", "FIGHTING"], "has_in_app_ads": 