&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HEC3s0__eDwQ7kNvgEgjyz8&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYD9fdNjcfI_4fYufLbmi3KbhiV5BBhiW__UeFxsgEUqiQ&oe=670BB178"}]}, "id": "419950596624200", "locale": "en_US", "screenshots": [{"file_name": "aplb - ss4.png", "id": "1328030287697077", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/39031379_1328030294363743_5627255058065069341_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z5ytaFv_0IgQ7kNvgFy8R4I&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYDmpSWvZTTYk4mMuaD0hmKidr3T-btpAWw0jR6bDZBWNQ&oe=670BA75A"}, {"file_name": "aplb - ss3.png", "id": "543789407313553", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974798_543789410646886_5915502377252837958_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9FvJLNBC4NYQ7kNvgEc5Ah2&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBl_7aAmHl0UobdyMTGtxsYcsRT_o06YvTfvyXqqGMcAg&oe=670BB13A"}, {"file_name": "aplb - ss1.png", "id": "288797220100520", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/39031486_288797223433853_2396487777045212145_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nInjFhV725UQ7kNvgGp0UcH&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYClLKCt3W2tioIkUcQDR6Vov_CF6vAZCfxT6EmSevBL3w&oe=670BCDD4"}, {"file_name": "aplb - ss5.png", "id": "1450180905413928", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39035331_1450180908747261_2060207280339599727_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ivPEs5rt52sQ7kNvgHL9hx4&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAp_nAOvj-K9EpHTU-mHOTaQTRWjoUNOhTjaa6v3PTAzQ&oe=670BC513"}, {"file_name": "aplb - ss2.png", "id": "521091429664417", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/38974593_521091432997750_8207741959667719255_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X2uyKJ6JPKwQ7kNvgF0c_V5&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBr4M41ofiKQn8Zp1YX8SpZw4Ot1fsPtKGkajNa7zMlmw&oe=670BA636"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "aplb - cover land.png", "id": "3206338996273601", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974798_3206339009606933_3068407365452566861_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jpi3ranjnxwQ7kNvgH7dSve&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAlq2tcojzl0f2kArFNhIxE79CkTzZV9bXFItsd-RsfrA&oe=670BAA2E"}, "display_name": "Dragon Fist: VR Kung Fu", "keywords": [], "long_description": "Step into your own kung fu movie with colourful characters inspired by Chinese and Hong Kong martial arts movies across the decades. Whether you fancy playing as an old wise master, or a young gifted female kung fu student, or a shaolin monk, Bruce Lee inspired character, samurai or a ninja there's bound to be someone for you...\n\nBlock attacks with your hands or forearms, or bob and weave, push their arms out the way, or move about, how you fight is up to you. But your opponents might use different strategies also, so you must learn how to foresee their attacks and how best to attack them.\n\nYou opponents all have the same controls as you, no advantage, no disadvantage. Except on easier levels they will have less strength - they will also have their speed and intelligence reduced.\n\n40 different characters that have various colourful costumes and have their own special moves to learn and use. Each character has their own fighting style to fight against as well as a perk and a weakness.", "short_description": "First person VR Kung Fu combat against a variety of different opponents, with a variety of different fighting styles, special moves and back stories. Unlock over 40 different characters, multiple stages, and take on the masters! "}]}, "developer_name": "Ben Olding Games", "developer_privacy_policy_url": "http://clique.games/privacy", "developer_terms_of_service_url": null, "publisher_name": "Clique Games", "support_website_url": "http://www.benoldinggames.co.uk/Contact-Me.htm", "website_url": "http://clique.games/dragonfist", "category": "GAMES", "comfort_ra