2.oculuscdn.com/v/t64.5771-25/39031629_372666094470535_3307308553942750494_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IN0TYYaFrUgQ7kNvgFl8ogD&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAZQDku-YV0rk2JE4ZPM5ZZ0mF_0phFlt2nWcil4biqGw&oe=671E2D2B"}, {"file_name": "Untitled-1Artboard-1.png", "id": "1051401865415975", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572957_1051401868749308_5367370891318206744_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KexzD441rZcQ7kNvgGkjWjq&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA6_Y-mD3T447xUGkbuaZWq_SLPcOenbg4kEeBTTwFVQw&oe=671E2233"}, {"file_name": "Untitled-1Artboard-2.png", "id": "726310185043466", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86796156_726310188376799_8716500588093256576_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XB6gkXqQ5z0Q7kNvgFMBf3q&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCS0Pr5A94PitloyWCg05D5V5W0T2NuiKUq3pevDyuK0Q&oe=671E247C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "jousting-oculuszdjecie-w-tle.png", "id": "1101975417031636", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982658_1101975420364969_4891128562063501818_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gWMpmI-5bH0Q7kNvgFBLEC0&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDxxC6_zNMdMLIoWD8E0vTwij87qvllcXjmB0V7s8A7gQ&oe=671E3D84"}, "display_name": "Jousting VR", "keywords": [], "long_description": "XIII century, Europe, royal market courtyard. You are a knight who joined the medieval tournament. Your task is \"simple\". Jump on your trusty steed, grab your lance & defeat the enemy. Take into consideration speed, accuracy, strength. Equipment is also important. The better gear the easier the task.  Oh, and other knights - they want to win as much as you do.\n\nYou beat them the king's greatest treasure is yours. And I didn't mean gold.\n\nJOUSTING VR FEATURES\n\n- Physics - experience Exciting fights based on true lance fighting physics.\n- Progression -  Knightly tournaments in which only the best advance to the next stages.\n- Challenge mode -  Smash hanging items. An exceptional aim helps you hit the target.", "short_description": "Welcome to medieval times. Times of Jousting.\nYou take part in a grand tournament competing with other knights, for fame, glory, wealth and to win the king's niece's heart.\n\u201cTo risk life to save a smile on a face of a woman or a child is the secret of chivalry.\u201d"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vraar.pl/privacy_policy/", "developer_terms_of_service_url": null, "publisher_name": "Vraar S.A.", "support_website_url": null, "website_url": "https://vraar.pl/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "743056196616504"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982464_635337867574311_9085566696798040684_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=K7Tz6Y3244QQ7kNvgE5pULa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDj5nkYMdrCCKmPBDW0OIEwJ-wnA-k5fnPuc_pZZ8HY9A&oe=671E3CC7"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Jousting VR", "platform": "ANDROID_6DOF", "context_category": null, "cont