ntitled-1Artboard-3.png", "id": "372666091137202", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031629_372666094470535_3307308553942750494_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SfsRkfOMJ8MQ7kNvgHs3FkG&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkvQ8qnHiOLNrooT6qKgr-d&oh=00_AYCxR9957PxqDXVKWjAe-WRBLbbxuXkXgkf8zc5zhgOuYw&oe=66EAC2AB"}, {"file_name": "Untitled-1Artboard-1.png", "id": "1051401865415975", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572957_1051401868749308_5367370891318206744_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Mq6LXyNI__8Q7kNvgH_zkll&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkvQ8qnHiOLNrooT6qKgr-d&oh=00_AYDLswNHdRPwg2ChPHZVf6rY1xrjjkRzaewL2_JwJ-CjSw&oe=66EAB7B3"}, {"file_name": "Untitled-1Artboard-2.png", "id": "726310185043466", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/86796156_726310188376799_8716500588093256576_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fxPLcMIr9UMQ7kNvgGUW8qc&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkvQ8qnHiOLNrooT6qKgr-d&oh=00_AYABUB2qBsh7SXG47QitPcN9o2mLDzyK9k48j3xWqwSpLw&oe=66EAB9FC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "jousting-oculuszdjecie-w-tle.png", "id": "1101975417031636", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982658_1101975420364969_4891128562063501818_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bNDgAH7D5N8Q7kNvgGI-ZhQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkvQ8qnHiOLNrooT6qKgr-d&oh=00_AYAxMvMWwdZG1F2qlnGk1g17Emw57FdBcyttnobnH38_Qg&oe=66EAD304"}, "display_name": "Jousting VR", "keywords": [], "long_description": "XIII century, Europe, royal market courtyard. You are a knight who joined the medieval tournament. Your task is \"simple\". Jump on your trusty steed, grab your lance & defeat the enemy. Take into consideration speed, accuracy, strength. Equipment is also important. The better gear the easier the task.  Oh, and other knights - they want to win as much as you do.\n\nYou beat them the king's greatest treasure is yours. And I didn't mean gold.\n\nJOUSTING VR FEATURES\n\n- Physics - experience Exciting fights based on true lance fighting physics.\n- Progression -  Knightly tournaments in which only the best advance to the next stages.\n- Challenge mode -  Smash hanging items. An exceptional aim helps you hit the target.", "short_description": "Welcome to medieval times. Times of Jousting.\nYou take part in a grand tournament competing with other knights, for fame, glory, wealth and to win the king's niece's heart.\n\u201cTo risk life to save a smile on a face of a woman or a child is the secret of chivalry.\u201d"}]}, "developer_name": null, "developer_privacy_policy_url": "https://vraar.pl/privacy_policy/", "developer_terms_of_service_url": null, "publisher_name": "Vraar S.A.", "support_website_url": null, "website_url": "https://vraar.pl/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1592192974313489"}, {"id": "394813081514456"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "743056196616504"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982464_635337867574311_9085566696798040684_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LzW6TXzj4kYQ7kNvgEErfDn&_nc_ht=scontent.oculuscdn.com&_nc_gid=AkvQ8qnHiOLNrooT6qKgr-d&oh=00_AYAZO4LYRVbXngsIe4OOiM15T26RjXcoH8NoE0IEAvwGSg&oe=66EAD247"}, "is_concept": false, "is_test": fa