_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCs3rkKyuGjG5_5EZ-PX6hf_H5xCbaHwM1FTW9D7BpGqw&oe=6756D1C5"}, {"file_name": "Keyarte_1080x360.png", "id": "504344522344547", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974751_504344525677880_8757980474147716254_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PCL7fTtczaEQ7kNvgFQnmtS&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCnE8hmULklNoYqSpnuYhSO-3lUgQNGOt_9h_Qq4HxTxQ&oe=6756DD2B"}]}, "id": "1238928606731869", "locale": "en_US", "screenshots": [{"file_name": "image1.png", "id": "1057387732496751", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75540501_1057387735830084_2190979014283040881_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VW5HflAZOOoQ7kNvgHR8pJR&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYByOlGJv9HGU0vvofJ3fieWtqoTqaa7RSRqMCB4xIB4GA&oe=6756EBF3"}, {"file_name": "image2.png", "id": "410575135384874", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974821_410575138718207_8230945586108737660_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gjs_SFaNFgYQ7kNvgEIB5S2&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBs55APe2BZZXINnnRGCgAj1pQoPD32uj4R2TbD1TSePA&oe=6756E0D8"}, {"file_name": "image5.png", "id": "27882995044633476", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974864_27882995047966809_2560160188894003364_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=9DT9aHLsrz4Q7kNvgEXCD0W&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYB8Gmu4Q-Xwbe2T1lhxK62ZakMTICTmT6YUBEL7VdeR1w&oe=6756C2F9"}, {"file_name": "image3.png", "id": "1012617210657646", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75280177_1012617213990979_1732549949916101256_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3wptSOn6yFYQ7kNvgFkTRMV&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAAKPYbZ2jMC9BnuNUPraRni2jswBZJolJC3hZADm-G0Q&oe=6756C4B8"}, {"file_name": "image4.png", "id": "1151089155995496", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974848_1151089159328829_2039739925044486928_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u9y3fuRI_aYQ7kNvgFq_NEh&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYD3-bXycUBDBmKlR1YuADVxVzW02K1pGTneFKERW_HflA&oe=6756BDAF"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Keyart_2560x1440.png", "id": "1984373528679847", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974591_1984373532013180_122028893976097645_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HMrgligt9FkQ7kNvgH0fDHD&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYAzG0zGVZ_hYo6_q_oZXQVtCT4JD4384HH24AMNU-BfDw&oe=6756D0BB"}, "display_name": "My Monsters - Demo", "keywords": ["Third", "Action", "Adventure", "Indie", "Fanstasy"], "long_description": "My Monsters is an action-adventure VR game that with a *100% hand-painted art*, creating a visually stunning *world full of fantasy and surrealism*. At the heart of the game is a deep narrative that explores humanity's greatest inner struggles\u2014anxiety, fear, and loneliness. As a player, you are transported to Onirium, a *dream-like realm* where you meet Moti, a frightened little monster with no memory.\n\nIn My Monsters, you\u2019re never alone. *Team up with your inner monster*, Moti, to face a variety of enemies, solve intricate puzzles, and overcome challenges in a shared journey. This partnership mechanic fosters a powerful connection with Moti, requiring empathy and courage to navigate obstacles and reveal fragments of a *meaningful dreamlike tale*. Every stage introduces new aspects of this bond, allowing players to experience moments of self-discovery and emotional depth.\n\nKey Features on Demo:\n\n\n\u2694\ufe0f  Combat Enemies: Engage in dynamic battles with your enemies.\n\n\ud83e\udde9  Solve Puzzles: Test your critical thinking and problem-solving skills.\n\n\ud83c\udf19  A Dream-like Tale: Uncover a touching, emotional narrative that delves into themes of self-reflection and growth. \n\n\ud83c\udfa8  100% Hand-Painted Art: Every visual element in the game is carefully crafted by hand, creating a beautiful, one-of-a-kind experience. \n\n\ud83e\udd1d  Team Up with Your Inner Monster: Build a meaningful relationship with Moti, using teamwork, empathy, and courage to overcome every challenge.\n\n*THE GAME IS CURRENTLY IN DEVELOPMENT, AND ITS CONTENT MAY CHANGE.*", "short_description": "My Monsters is a VR action-adventure game featuring stunning 100% hand-painted art. In this demo, you\u2019ll explore Onirium, a dream-like world filled with emotional depth, as you face humanity's greatest inner monsters like anxiety and fear. Meet Moti, a scared little monster with no memory, and team up to battle enemies, solve puzzles, and overcome challenges. Unravel fragments of a dreamlike narrative as you journey together. The game is currently in development, and its content may change."}]}, "developer_name": null, "developer_privacy_policy_url": "https://mymonsters.ludact.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Ludact", "support_website_url": null, "website_url": "https://mymonsters.ludact.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1512904879196773"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "4272862