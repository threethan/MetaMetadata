/t64.5771-25/57575362_363848013452045_996116340368343728_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cHE3Foie8VoQ7kNvgHz_8U_&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBs-X4XBoFnWZT8k-LBdh-6-GoRHwiEZ7uVrgZYjbI6MQ&oe=67727994"}, {"file_name": "TARGETPRACTICE2.png", "id": "896277519257305", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75356790_896277522590638_8357593418870556152_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ph4qbqaP38YQ7kNvgHekP9X&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCdeR0pK7bhAU6Wbc0NNzn3oJ6M7KJryOvk6z-xX7__Vg&oe=67729879"}, {"file_name": "Kaiju Fight.png", "id": "544081348242438", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031376_544081351575771_3551761510044050173_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6xG3LMc3XEgQ7kNvgElQkC4&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCCEShsYDpcmU2p4TRdJSudZijLucv5Ue1EqehG0I742A&oe=6772A245"}, {"file_name": "FighterJet_Edit01.png", "id": "533101222524018", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031346_533101225857351_1265597128783584983_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uK9H6KUiVBUQ7kNvgF7KeYV&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYDDKEdlVgvslTO7LenmWN8P5_ZRuLekSnzAEMpoBWApCA&oe=67728FE0"}, {"file_name": "Asylum01.png", "id": "1068438351639826", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031633_1068438354973159_3945996795730057558_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M_x8FVtPtAUQ7kNvgG1_7ie&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCxi4iqjkxGSCNOvJTDfm1tmLEkYjNtABuXnGWLqYKEFA&oe=677279FC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Digigods_multiverse_Landscape.png", "id": "1116662343418896", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39036675_1116662346752229_266256118318289132_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LAEw94AcTs0Q7kNvgGUivDT&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYB0WG2JNm7-DUyK5O-T8kI7AcQTwCSIO5j64wp-RZoVAQ&oe=67726DB9"}, "display_name": "DigiGods: Build and Battle", "keywords": ["social", "action", "multiplayer", "casual", "sandbox"], "long_description": "..                                                                                                                                                            \n                                                                                                                                                     \n\n{1133812691416110}\n{1387318419176417}\n{1500012183996320}\n{486890043802420}\n\n# CREATE, PLAY, & SHARE in a physics-based sandbox environment where you can shoot, parkour, or simulate any type of gameplay you desire, taking the best of VR goofiness. \n\n**NEW!** Medieval Madness is here! Travel back in time and experience epic sword fights and exhilerating archery. Finish off your foes by raining fire from the skies atop your very own dragon!\n\n**Movement Freedom:** Move using  your hands like Gorilla Tag and No More Rainbows, or Joystick, or both!\n\n**Drag-and-Drop System:** Intuitive and user-friendly, making the creation process accessible to everyone.\n\n**Real-Time Multiplayer Physics:** Engage with friends and other creators in a dynamic, physics-driven world.\n\n**Limitless Possibilities:** From gravity-defying shooters to complex puzzles! Create anything you can dream of and publish your creations!\n\n**Instant Action:** Jump into the game with no loading times, keeping your creative flow uninterrupted.\n\n**Social and Interactive:** Share your creations with a community of players and creators, fostering an environment of endless inspiration. \n\n**Innovative VR/MR Sandbox:** A unique blend of virtual and mixed reality that offers an unparalleled sandbox experience.", "short_description": "CREATE, PLAY, & SHARE in a physics-based sandbox environment where you can shoot, parkour, or simulate any type of gameplay you desire, taking the best of VR goofiness. \n\nNEW! Medieval Madness is here! Travel back in time and experience epic sword fights and exhilerating archery. Finish off your foes by raining fire from the skies atop your very own dragon!\n\nDigiGods is free and always will be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.digigods.gg/privacy-policy", "developer_terms_of_service_url": "https://www.digigods.gg/terms-of-service", "publisher_name": "Squido Studio", "support_website_url": "https://www.digigods.gg/", "website_url": "https://www.digigods.gg/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "1990104051447093"}, {"id": "1023770785722696"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr_CA"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "8965093333552474"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39031396_1704151246833638_2069627282068224908_n.png?stp=dst-png_s360x360&_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=10UC_83Mn8AQ7kNvgFZuxCx&_nc_zt=3&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAmc2Idstyi9Ib-726grZAQidqFkj541OLjcFwoXhLvsg&oe=677288AA"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "DigiGods: Build and Battle", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Action", "id": "459781504968480"}, {"topic_name"