5R6O4kT97vQck7qd3IfYB8aLOHoA&oe=672E049C"}, {"file_name": "12534042_371680596569289_1291321706119430144_n.png", "id": "839545973241195", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75298470_839545976574528_4517500296023815162_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bj1aPxWlR34Q7kNvgFqq8gJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAukgYllP4ZGO2uSFTH5JCI03nJieYauKonpK02Tj6stw&oe=672DF011"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "nasa_screenshot_2560x1440.png", "id": "627392187909930", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57575365_627392191243263_1129176125444413530_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8YtAcjs5uAQQ7kNvgH8_nxs&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBrmKqQQtAz2HVhmVBUdb5VB-pFuyY3US7YNRtq3McLiA&oe=672DE1C4"}, "display_name": "Space Explorers Portal", "keywords": ["Space", "Explorers", "Nasa", "Astronaut", "Felix"], "long_description": "Includes In-App Purchases (USD $2,99 per episode)\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness firsthand the lives of veteran and novice NASA astronauts alike as they navigate the trials and sacrifices of their training and missions. Explore the dynamics and camaraderie of space programs around the world and the collaboration between the public and private space agencies, and discover the latest advancements and plans for deep space exploration. Space Explorers will shine a light on mankind\u2019s most ambitious journey to understand our planet, our galaxy, our universe and our origins. Narrated by Brie Larson. \n\nSeason 1 available now. Season 2 releases beginning Fall 2020 with Episode 1, Winter 2020/2021 with Episode 2, Spring 2021 with Episode 3 and Summer 2022 with final Episode 4. ", "short_description": "Includes In-App Purchases (USD $2,99 per episode)\n\nSpace Explorers is a cinematic VR series about the new age of space exploration. Witness the lives of NASA astronauts as they navigate the trials and sacrifices of their training and missions. Explore the camaraderie of space programs around the world, and discover the latest advancements and plans for deep space exploration. Season 1 available now, with more episodes beginning Fall 2020."}]}, "developer_name": "Felix & Paul Studios", "developer_privacy_policy_url": "https://www.felixandpaul.com/privacy", "developer_terms_of_service_url": "https://www.felixandpaul.com/license", "publisher_name": "Felix & Paul Studios", "support_website_url": null, "website_url": "https://www.felixandpaul.com/", "category": "ENTERTAINMENT", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "EXPLORATION", "NARRATIVE"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1651548808523212"}}]}, "scheduled_offers": {"count": 4, "nodes": [{"status": "PENDING", "id": "917624953035485"}, {"status": "PUBLISHED", "id": "352347952772564"}, {"status": "PUBLISHED", "id": "684413195765556"}, {"status": "PUBLISHED", "id": "2687443954832577"}]}, "baseline_offer": {"id": "352347952772564"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "917624953035485"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6316165065140492", "version": "1.08.0"}, "id": "269856287692062", "channel_name": "LIVE"}]}, "is_for_oculus_keys_onl