5hg&oe=6728989B"}, {"file_name": "pd-1-1-updatedtext.png", "id": "221613087438274", "image_type": "APP_IMG_COVER_SQUARE", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982551_221613090771607_8620078170120975747_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BN9Xr4aVGrUQ7kNvgGp_fIl&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYACE1QV7y8jJ2Qj_Ivfy0J0KzsFWjOXb10ryVuanmhH8g&oe=6728C4A8"}]}, "id": "1063156431571549", "locale": "en_US", "screenshots": [{"file_name": "pd-screen-4.png", "id": "452755380055036", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75223479_452755383388369_7916189931699766309_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bLjn3eZo6bYQ7kNvgHsMQNF&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYAtlDwp-UrZTVv7Klpt4I1Mh_x5p7kfJr9tbNmF2NfJZQ&oe=6728CEE9"}, {"file_name": "pd-screen-3.png", "id": "1062325254420235", "uri": "https://scontent-sin11-2.oculuscdn.com/v/t64.5771-25/75593950_1062325261086901_104825397019691373_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ghxi8K9MIXcQ7kNvgGTbdIt&_nc_zt=3&_nc_ht=scontent-sin11-2.oculuscdn.com&oh=00_AYA9twE0_LNt8gCbOd8fEYSfeW6DwcXHUVTsbzdObKSiRA&oe=6728C872"}, {"file_name": "pd-screen-1.png", "id": "1148192932456664", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38974625_1148192935789997_1416656799652225989_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bW4GYG6u8b8Q7kNvgG0xfwo&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYD3KSUaDJBJhPZkuz-ne17E9liBW6cMTbOFckjQUAc54Q&oe=6728CF36"}, {"file_name": "pd-screen-2.png", "id": "2332569856899945", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974820_2332569860233278_8835659424562109361_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Kqb_V822CqUQ7kNvgGs576n&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDhXoISQvVNgc9kvqhdPfxCdTItNmoUzUcx5bnfCceY9g&oe=6728A6B6"}, {"file_name": "pd-screen-5.png", "id": "430728135872291", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39003247_430728139205624_5946641524650245644_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BhDZonbvp_UQ7kNvgE0WVpX&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCHoDtxO83cRKqqbCTyWWvMzpg7drdb0n7Gnzs_-GR3Dg&oe=6728A8E2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videoscreen.png", "id": "986130542781323", "uri": "https://scontent-sin6-2.oculuscdn.com/v/t64.5771-25/38974594_986130546114656_4585000279316381076_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=AHAruQ7maMkQ7kNvgFaFX2O&_nc_zt=3&_nc_ht=scontent-sin6-2.oculuscdn.com&oh=00_AYAQPay9MqRfOWqj9Q2W6qLQ8RrDXIiAh7f7CBaPVqOdTQ&oe=67289A6E"}, "display_name": "Paradiddle", "keywords": ["drum", "beat", "music", "piano", "instrument"], "long_description": "So much more than a VR drum kit. Learn to drum with step by step lessons, flex your skills with the built-in rhythm game, and build your own custom kit from a library of 60+ percussive instruments without the limitations of money or physical space. Fun, intuitive drumming for pros and newcomers alike!\n\nKey Features:\n- Flex your skills in the built-in rhythm game mode: adjustable difficulty for 30 different songs, plus custom song support and cross-platform leaderboards.\n- Create your custom drum kit from a library of 60+ percussive instruments, from mallet instruments like the xylophone and steel drum, to auxiliary percussion such as bongos, tambourines and timpanis.\n- Pick up the basics with 10 beginner-friendly lessons, perfect for drumming newcomers.\n- Use the new multiplayer mode to perform for your friends in free play, or compete to get the high score playing the built-in songs.\n- MR passthrough support empowers you to play virtual drums in the real world. You can even connect and augment your physical kit with the rhythm game mode and lessons.\n- MIDI input/output support provides a powerful tool for composers, and also lets you augment your own electronic drum kit.\n- Set the mood with 4 different environments: Dojo, Jazz Club, Galaxy, Void.\n- USB and Bluetooth pedal support for kick and hi-hat.\n- Load your own songs, audio files and sheet music.\n- Easily save/load different kits and record your jam sessions.", "short_description": "Play drums without the limitations of the real world.\n\nSo much more than a VR drum kit. Learn to drum with step by step lessons, flex your skills with the built-in rhythm game, and build your own custom kit from a library of 60+ percussive instruments without the limitations of money or physical space. Fun, intuitive drumming for pros and newcomers alike!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://paradiddleapp.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Emre Tanirgan", "support_website_url": "http://paradiddleapp.com/faq", "website_url": "http://paradiddleapp.com/", "category": "APPS", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1672577396871977"}, {"id": "1043107547362485"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "7056409527730786"}, "review_messages": ["approved for release on Nov 16th at 10:00am PT"]}]}, "cover_square_image": {"uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/38982551_221613090771607_8620078170120975747_n.png?stp=dst-png_s360x360&_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BN9Xr4aVGrUQ7kNvgGp_fIl&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYBTG