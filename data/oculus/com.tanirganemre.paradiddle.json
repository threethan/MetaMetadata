8192935789997_1416656799652225989_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qyD9jXM1tBkQ7kNvgGOai0P&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDkvLYxiiu1yGOWjzM3j2GUvRcjY4kXXqjQAcNceAvT7Q&oe=671CF1B6"}, {"file_name": "pd-screen-4.png", "id": "452755380055036", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75223479_452755383388369_7916189931699766309_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nWhyJ-BOTVoQ7kNvgF7tgUq&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3exC1ySgjXzSxXYq0uwpGyBw30zbKUbBq8tJp8Fouow&oe=671CF169"}, {"file_name": "pd-screen-5.png", "id": "430728135872291", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39003247_430728139205624_5946641524650245644_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1nVdIeWzS_0Q7kNvgGbiRkm&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDMlP-xQuwYSN8VJlS0A39GOD9vETWhUjkgKSRRZ1JTjA&oe=671CCB62"}, {"file_name": "pd-screen-3.png", "id": "1062325254420235", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75593950_1062325261086901_104825397019691373_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eaitu4EXCeIQ7kNvgFJGFjL&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBfCL7-nPkH80E6pUXTuLu0OlD_OE0V8cF2LLhG9W_L_A&oe=671CEAF2"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "videoscreen.png", "id": "986130542781323", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974594_986130546114656_4585000279316381076_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vPTCe3a6sO4Q7kNvgE60gbu&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAalegZK1ygLFW1r0TaaIpfnGxbuG1ZbOIw_FY37DTiTg&oe=671CBCEE"}, "display_name": "Paradiddle", "keywords": [], "long_description": "Play drums without the limitations of the real world. Paradiddle lets you play 50+ realistic percussion instruments without worrying about making noise, buying expensive equipment or needing physical space. With our built-in rhythm game mode and lineup of lessons, it's easier and more fun than ever to learn how to drum.\n\nKey Features:\n- Rhythm game mode with custom song support and cross-platform leaderboards.\n- 50+ realistic percussion instruments including 5 full drum kits, mallet instruments like the xylophone, marimba and glockenspiel, and auxiliary percussion such as bongos, tambourines and timpanis.\n- 10 beginner-friendly lessons that take you through drumming basics.\n- 4 different environments to play in: Dojo, Jazz Club, Galaxy, Void.\n- USB and Bluetooth pedal support for kick and hi-hat.\n- Passthrough AR support to play in the real world along other musicians.\n- Load your own songs, audio files and sheet music.\n- Easily save/load different kits and record your jam sessions.", "short_description": "Play drums without the limitations of the real world.\n\nParadiddle lets you play 50+ realistic and responsive percussion instruments without worrying about making noise, buying expensive equipment, or needing physical space. With our built-in rhythm game mode and lineup of lessons, it's easier and more fun than ever to learn how to drum. The app even supports a variety of pedals and peripherals for those looking to bring their VR drumming journey to the next level."}]}, "developer_name": null, "developer_privacy_policy_url": "http://paradiddleapp.com/privacy-policy", "developer_terms_of_service_url": null, "publisher_name": "Emre Tanirgan", "support_website_url": "http://paradiddleapp.com/faq", "website_url": "http://paradiddleapp.com/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "393222478507326"}, {"id": "384928226018505"}, {"id": "323450648956687"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "MUSIC", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor"