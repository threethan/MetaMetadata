=scontent-iad3-1.oculuscdn.com&oh=00_AYC_5yC7ChfanWJi3oYFMpDmypVcYY4BxDA8100y_kCKVg&oe=675057A1"}, {"file_name": "Photo5.png", "id": "1311981289289141", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974680_1311981292622474_1658139110581680933_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iwIiP3q4VRUQ7kNvgEm_wBY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3g4GSEyNOzS7Fy2o7K9AZzOaFy1VcSeIz7Vfz7ybR9g&oe=6750320E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "TrailerCoverImage.png", "id": "2457356644405354", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75295751_2457356647738687_1041278583473976247_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LgUhtIUlhxsQ7kNvgEIFZrl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAwnD0LxLIEV7M8tZrT0hDWvhd7DfpKUVLsrSIwVXZCzA&oe=6750528B"}, "display_name": "Good Music", "keywords": [], "long_description": "Good Music allows you to bring your real world music listening experience into VR whilst enjoying colourful visualisations. The experience transports you to a magical universe where you can discover new life forms that use the energy from your music to grow, multiply, move around and thrive. You can take photos of the artificial wildlife you discover amongst the mesmerising vistas, and share with friends.\n\nRecording Audio.\nThe app requires permission to record ambient audio in order to function. For your privacy and peace of mind, this ambient sound information is immediately discarded milliseconds after it is read and the app does not not store, transmit or reproduce ambient audio information to deliver this experience.\n\n", "short_description": "Enjoy your favourite music whilst exploring a breath-taking universe of colour and sound. Discover new life forms that use the energy from your music to grow, multiply, move around and thrive. Take photos of the artificial wildlife you discover amongst the mesmerising vistas, and share with friends."}]}, "developer