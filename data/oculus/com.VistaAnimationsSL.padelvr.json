&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=o5BAy_Kqav8Q7kNvgFpOsiF&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDttlDRwFGjmO2wUm2A5hpvlMChaPbxCJzXd276_FLFXA&oe=67150033"}, {"file_name": "SettingsFlag.png", "id": "921290958961621", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982487_921290962294954_3030793479275660074_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WaONS5ClAqQQ7kNvgF2vYk4&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB1_2tEyX7Aw0qHGve77Huzoyt2oH4L71siK2KbYtYnlQ&oe=6714ED0B"}, {"file_name": "PlayFlag.png", "id": "1435465923663082", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75593947_1435465926996415_954103576993442317_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m754oHW13DgQ7kNvgFlFlvf&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDBcSOZpecUBo8MHZslN_tZ0Y43Qdy8mUlysOJbOjt2JQ&oe=67150A46"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Portada.png", "id": "1156571041706149", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974515_1156571048372815_3648241606647433123_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=nwOPMZTA7g0Q7kNvgHUUpLS&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD2FtrZAsYe68AjenXxxxS6827JvbX5t5dV9xx5zFOvJw&oe=671501F8"}, "display_name": "PadelVR Alpha", "keywords": [], "long_description": "PadelVR is a Padel sport simulator in which you'll be able to learn, train and play Padel.\n\nThis is an early version with just basic features and with an early physics engine that we are working on.\n\nWhat you will find in the first Alpha:\n\n\u25aa Freeplay mode: try serving and hitting the ball alone on the court.\n\n\u25aa Introduction: a sequence of shots with progressive difficulty from back and net positions. Ideal for getting started.\n\n\u25aa Warm Up: a coach will throw random types of balls at you based on your position.\n\n\u25aa Minigames: two short minigames to test your skills.\n\n\u25aa What you should expect: Physics may not be as solid as desired.\n\nNote you have a physics tab where you can edit in game physics to tune your preferences like Bounciness, air friction, etc!\n\nDue to the lack of an adapter for your VR device, the hand movements and sensations may not feel realistic.\n\nWe are working on a haptic adapter that will simulate the weight and the air friction of a real padel racket. You can also use your own custom 3D printed handle.\n\nGame modes have been reduced for the first alpha in order to get more streamlined feedback.\nSoon we will update it with extra features!\n\nJoin our Discord Channel and give us your feedback! \n\nThis is a testing version and should be used only for personal use. There is time limitation", "short_description": "VR Padel Simulator. Train your skills or play a match with friends!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.padelvrgame.com/privacy-policy/", "developer_terms_of_service_url": "http://www.padelvrgame.com/terms-of-service/", "publisher_name": "Vista Animations SL", "support_website_url": null, "website_url": "https://www.padelvrgame.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1573854509480616"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER", "CO_OP"], "id": "1014888832834569"}}]}, "scheduled_offers": {"count": 2, "nodes": [{"status": "PUBLISHED", "id": "1217012329490867"}, {"status": "PUBLISHED", "id": "675703197654175"}]}, "baseline_offer": {"id": "1