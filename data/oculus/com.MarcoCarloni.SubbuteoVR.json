8_739331486434940057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E7UpX8ewI1kQ7kNvgFtpTIo&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYBYL3qRW8JdWqhxy0yaUhLoEgu_d5HHlQEOnIz41WyUZA&oe=67013B7E"}, {"file_name": "512.png", "id": "626459722472930", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/39035336_626459729139596_8012469447108701207_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lgh9qObyEkwQ7kNvgEG-52C&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD6nHAp6u-jwkEQJO5xwJLnPVacwJ31F_x4aXODFvaknA&oe=67011482"}]}, "id": "833930024500805", "locale": "en_US", "screenshots": [{"file_name": "screenshott - Copy.png", "id": "414741640813310", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75630185_414741644146643_8100796172463660395_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rJEUcKpp3BEQ7kNvgH04bMC&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYA4UBPliHP9lKr17hEHB8eHTcp6U7OLwF5FHJUGw7rIfA&oe=67010F18"}, {"file_name": "vlcsnap-2022-07-09-22h56m23s079.png", "id": "713956126569270", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974676_713956129902603_5229200638473249164_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DCu3EscXqqgQ7kNvgGQ5HNB&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAb9qyAM0769kn5sH-XT-w1bf36XYJS8-BCEsxapmQlRw&oe=670115CF"}, {"file_name": "vlcsnap-2022-02-20-19h18m07s992.png", "id": "619769799118668", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974497_619769802452001_2094890422274419360_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ylEn_JcMxQsQ7kNvgECIKxW&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYC0QtMdixLkGslu6jcXGXdlK8o2XKQmwoO3foYq70qJuA&oe=67013674"}, {"file_name": "vlcsnap-2022-02-20-19h23m03s509.png", "id": "1418043768631519", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/75295892_1418043771964852_9176465051160710845_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Bae27mOcG5oQ7kNvgGHZ4Ik&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYD0bafP4KUhaO5dCNxjCTokrr3cS2bGybHm5f46qduyDQ&oe=67011E5B"}, {"file_name": "vlcsnap-2022-02-20-19h15m28s471.png", "id": "369786517987108", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38974497_369786521320441_3179288813000259038_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=suJiWUGkuyIQ7kNvgECS0BY&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYCoggm823q1pjrmXuiW-9eOSs6grW6YM596FmR2pr7NOA&oe=6701293B"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Finger_Soccer_copy - Copy.png", "id": "1011446596918089", "uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/38984468_1011446600251422_713221081973221875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qfTYVJEfdrEQ7kNvgG0JpZo&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAYtw8GFpuDOFukCcYQ2BJ4KCB3wP99mc8pXwUvR70_0A&oe=67010FC1"}, "display_name": "Finger Soccer VR ", "keywords": [], "long_description": "Inspired by tabletop games, this game offers a unique blend of nostalgia and modern gameplay.\n\nTo get started, simply choose your teams, formations and options.\n\n You'll then be matched with another player online, and the game will begin. The goal is simple: outscore your opponent to be the ultimate winner.\n\nYou have the ability to tailor the gameplay to your liking by adjusting features like teams, formations, player size, game time, arena, ball properties which can affect the gameplay in various ways.\n\nAnd when it comes to controlling the action, you have options.\n You can play with your real hands using hand tracking technology, or you can use controllers for a more relaxed arcade experience. The choice is yours.\n\nJust be careful - hitting the ball into the net with your hands isn't as easy as it looks. You'll need to be precise and strategic in your movements to succeed.\n\nSo if you're ready to join the action, start playing now and experience the thrill of online soccer! ", "short_description": "Join the action with our turn-based soccer game inspired by tabletop games.\n\nChoose your teams, settings, and formations and start scoring goals to be the winner offline or in the online matchmaking. \n\nYou can even customize a variety of features like players size, time, arena, ball and a lot more!\n\nAnd the best part? You can play with your real hands or with controllers - the choice is yours! \n\nJust be careful, because hitting the ball into the net with your hands isn't as easy as it looks!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3digitalinnovation.com/Documentation/FingerSoccerVR/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Myself", "support_website_url": null, "website_url": "https://www.3digitalinnovation.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3336336846622176"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-sjc3-1.oculuscdn.com/v/t64.5771-25/57568677_778338473395005_7334299336877103581_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y4t6rAnAo1wQ7kNvgEcv8Qh&_nc_ht=scontent-sjc3-1.oculuscdn.com&oh=00_AYAFXD94VL39WqtaGvkJ7-3TKd-u8rY3pQpWZ_OS_Sdv_g&oe=670143A9"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Finger Soccer VR ", "platform": "ANDROID_6DOF", "context_category": null, "context_topics": [],