cdn.com/v/t64.5771-25/75230047_639331624533108_739331486434940057_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=456Pt3tjvRsQ7kNvgGGIQWr&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBABbtL8zEUQbVi2EDIqTCvLKogdN6loseuT5vV7OLjxw&oe=671CEAFE"}, {"file_name": "512.png", "id": "626459722472930", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035336_626459729139596_8012469447108701207_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=-2B1dglLsM8Q7kNvgFFC94V&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCV7cLUBTeFIAc9BIdcn490T2r4rTO06Q6Uz_BA2oB2EQ&oe=671CC402"}]}, "id": "833930024500805", "locale": "en_US", "screenshots": [{"file_name": "screenshott - Copy.png", "id": "414741640813310", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75630185_414741644146643_8100796172463660395_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mN1IezOgBDQQ7kNvgEANZ8l&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCynymwU0kFrSAtByrFpbGgtBrgeKvsRg5bSZOlREQfxg&oe=671CBE98"}, {"file_name": "vlcsnap-2022-07-09-22h56m23s079.png", "id": "713956126569270", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974676_713956129902603_5229200638473249164_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=IJUVHkqiocQQ7kNvgEO83oS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBC-DR6UJr4gBUC4CXk1CQ3Dk4D2h24Ey845KlPZAO1_w&oe=671CC54F"}, {"file_name": "vlcsnap-2022-02-20-19h18m07s992.png", "id": "619769799118668", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974497_619769802452001_2094890422274419360_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZmnJhj3SGDMQ7kNvgEX_S5H&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC_qufWJp52MElZrLerLchM6_rNMSZYVPDPeQR7JIL0wQ&oe=671CE5F4"}, {"file_name": "vlcsnap-2022-02-20-19h23m03s509.png", "id": "1418043768631519", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75295892_1418043771964852_9176465051160710845_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tbVlNtrxrIIQ7kNvgGidcPJ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBjILGn82nR84A19YkRpOe_Qn8KZoQlKu9b1af_Np8AIQ&oe=671CCDDB"}, {"file_name": "vlcsnap-2022-02-20-19h15m28s471.png", "id": "369786517987108", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974497_369786521320441_3179288813000259038_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pkyM54Qy4iMQ7kNvgHQoVOI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBDZBgfCUqGzoA_leMVsLsMg9CPEOzyEvghWFt_Y5L6OA&oe=671CD8BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Finger_Soccer_copy - Copy.png", "id": "1011446596918089", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984468_1011446600251422_713221081973221875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=u3ud_QMMHZAQ7kNvgE4J21u&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCzfyELUlhcFBkEwQcJ0tgUyiXtvAc6pJ6dAJd5IbZVuQ&oe=671CBF41"}, "display_name": "Finger Soccer VR ", "keywords": [], "long_description": "Inspired by tabletop games, this game offers a unique blend of nostalgia and modern gameplay.\n\nTo get started, simply choose your teams, formations and options.\n\n You'll then be matched with another player online, and the game will begin. The goal is simple: outscore your opponent to be the ultimate winner.\n\nYou have the ability to tailor the gameplay to your liking by adjusting features like teams, formations, player size, game time, arena, ball properties which can affect the gameplay in various ways.\n\nAnd when it comes to controlling the action, you have options.\n You can play with your real hands using hand tracking technology, or you can use controllers for a more relaxed arcade experience. The choice is yours.\n\nJust be careful - hitting the ball into the net with your hands isn't as easy as it looks. You'll need to be precise and strategic in your movements to succeed.\n\nSo if you're ready to join the action, start playing now and experience the thrill of online soccer! ", "short_description": "Join the action with our turn-based soccer game inspired by tabletop games.\n\nChoose your teams, settings, and formations and start scoring goals to be the winner offline or in the online matchmaking. \n\nYou can even customize a variety of features like players size, time, arena, ball and a lot more!\n\nAnd the best part? You can play with your real hands or with controllers - the choice is yours! \n\nJust be careful, because hitting the ball into the net with your hands isn't as easy as it looks!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3digitalinnovation.com/Documentation/FingerSoccerVR/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Myself", "support_website_url": null, "website_url": "https://www.3digitalinnovation.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3336336846622176"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57568677_778338473395005_7334299336877103581_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MkDKf6MOVHEQ7kNvgEc_ypb&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD_qO6oPGjzAXWODQeBf7tHH8Yo2_04ItDsPSQJhlIJ4Q&oe=671CBAE9"}, "is_concept": false, "is_test": false, "is_trial_offer_v