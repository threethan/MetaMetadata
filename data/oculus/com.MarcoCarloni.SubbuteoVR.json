id=6e7a0a&_nc_ohc=4XQo2hqR5vQQ7kNvgE0E-be&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAcrqjICAY15Poronoyoeez9eQ9DDBLghATap37IS69jQ&oe=675EB8DB"}, {"file_name": "vlcsnap-2022-02-20-19h15m28s471.png", "id": "369786517987108", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/38974497_369786521320441_3179288813000259038_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y6CC9NwyBmUQ7kNvgF9jKhU&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYDq10QrAd2eO281m27QJy6D7N7a1MRZl4IjvxE5hnURSg&oe=675EC3BB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Finger_Soccer_copy - Copy.png", "id": "1011446596918089", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/38984468_1011446600251422_713221081973221875_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=54rBoOJn5RsQ7kNvgFBWR3r&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYDxzt0s9gnkZ4LGPxMLImx2zeV6j4ajKOHUwwZfKZY10A&oe=675EAA41"}, "display_name": "Finger Soccer VR ", "keywords": [], "long_description": "Inspired by tabletop games, this game offers a unique blend of nostalgia and modern gameplay.\n\nTo get started, simply choose your teams, formations and options.\n\n You'll then be matched with another player online, and the game will begin. The goal is simple: outscore your opponent to be the ultimate winner.\n\nYou have the ability to tailor the gameplay to your liking by adjusting features like teams, formations, player size, game time, arena, ball properties which can affect the gameplay in various ways.\n\nAnd when it comes to controlling the action, you have options.\n You can play with your real hands using hand tracking technology, or you can use controllers for a more relaxed arcade experience. The choice is yours.\n\nJust be careful - hitting the ball into the net with your hands isn't as easy as it looks. You'll need to be precise and strategic in your movements to succeed.\n\nSo if you're ready to join the action, start playing now and experience the thrill of online soccer! ", "short_description": "Join the action with our turn-based soccer game inspired by tabletop games.\n\nChoose your teams, settings, and formations and start scoring goals to be the winner offline or in the online matchmaking. \n\nYou can even customize a variety of features like players size, time, arena, ball and a lot more!\n\nAnd the best part? You can play with your real hands or with controllers - the choice is yours! \n\nJust be careful, because hitting the ball into the net with your hands isn't as easy as it looks!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.3digitalinnovation.com/Documentation/FingerSoccerVR/PrivacyPolicy.html", "developer_terms_of_service_url": null, "publisher_name": "Myself", "support_website_url": null, "website_url": "https://www.3digitalinnovation.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2776542286000603"}, {"id": "1676485315806614"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "CASUAL", "SPORTS"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["HAND_TRACKING", "OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "SITTING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "3336336846622176"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/57568677_778338473395005_7334299336877103581_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ed0rNzkj8SgQ7kNvgG7pq47&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYAUt8MvL24ROMXcL8RhHDQrVEPNyfcDjXBqaXC5tDDCuA&oe=675EDE29"}, "is_concept": false, "is_test