720424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572954_975509374053757_7256813517372894606_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OUU_r2w6aiEQ7kNvgEoy-Zh&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_fDtiIKiwWKt9llulYH7z3AbLoTFf4Kn_6r93lMdrtA&oe=678248C7"}, {"file_name": "image_005_0002.png", "id": "1131555677903551", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572954_1131555681236884_3987358627319176982_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=d6RNAu4YiCAQ7kNvgGAdK11&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAJSZbdUgpmeAywc_n2DHKJyLQvyefOnhsNdzeFgNNVUw&oe=67825CEB"}, {"file_name": "image_006_0012.png", "id": "468535432489414", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250458_468535435822747_1230677552996745658_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pN7pNypHDCUQ7kNvgG0__Vm&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB0njo5ls0rdVjDWQF6j8ou5dUd9tyPkOuu0McvMSMNbA&oe=67826E34"}, {"file_name": "image_007_0005.png", "id": "477550874827704", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982595_477550878161037_7113671620325822889_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3Rr25VzW7BcQ7kNvgFonZhb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB_vVAy4a7CmdBvDZccRKv5O6qV1EO4i-IXvU5phtFYhg&oe=67825FA6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Spunky Monkey VR", "keywords": [], "long_description": "Welcome to this artificial facade of a reality where the leading species are monkeys who can transform into different species and move with their arms because they lack legs. Sounds pretty sick, doesn't it? Well, welcome to Spunky Monkey VR! A cartoony styled game based off of the widely popular game Gorilla Tag. In this game, you can explore the massive forest map the monkeys claimed as their natural habitat, a canyons where monkeys can swing and glide through the beautiful terraforming of the sandstone, a shop built by the monkeys where other monkeys can get in style, a deep cave found by the monkeys, but don't go there, reports have come that few monkeys came back alive, and an alternate reality where you can test and experience all of the things not yet added to the main thing.", "short_description": "Spunky Monkey VR is a hand-based locomotion game, and it's based around the popular virtual reality game, Gorilla Tag. Walk around in forest, climb in canyons, buy stuff in shop, and get jump scared in horror!"}]}, "developer_name": "OxidizingStudios", "developer_privacy_policy_url": "https://sites.google.com/view/oxidizingstudios/privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Isaac Tinoco", "support_website_url": null, "website_url": "https://sites.google.com/view/oxidizingstudios/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "8990758664273408"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "1866215280458176"}]}, "baseline_offer": {"id": "1866215280458176"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1720572050, "status": "PUBLISHED", "id": "1866215280458176"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "9760278273988106", "version": "1.0.36"}, "id": "367681322821173", "channel_name": "LIVE"}]}, "is_for_oculus_key