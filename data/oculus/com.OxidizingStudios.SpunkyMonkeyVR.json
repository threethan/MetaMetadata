/t64.5771-25/38984468_381133995010325_3545020389693658215_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KbEUmTqYZQ4Q7kNvgG23xGJ&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAp1-Ph9suL9Xgx6QjY9mzbMJswxSuGCi3KOKJ9U56r_A&oe=67091C60"}]}, "id": "867759355287049", "locale": "en_US", "screenshots": [{"file_name": "image_002_0011.png", "id": "492274156694183", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982501_492274160027516_429952017365222734_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SfLUnrybgwQQ7kNvgEXOTpv&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD3_nx3KHZ0vemUs57-OH6ukC0eKYxjMqIYkRNcyPUJ5Q&oe=67092AA9"}, {"file_name": "image_004_0006.png", "id": "975509370720424", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572954_975509374053757_7256813517372894606_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s9SGy-i4QVYQ7kNvgHCJCGo&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9oNzVXRTHXaNw-co6qZZHQ33HZxvwa19ndDK5WE8sag&oe=6708FEC7"}, {"file_name": "image_005_0002.png", "id": "1131555677903551", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572954_1131555681236884_3987358627319176982_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rHr9U8jS1fwQ7kNvgFFU3M7&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBjMbDWycAnzy7kgQX054RRjQICNdY-_EAqU_VelzWmTQ&oe=670912EB"}, {"file_name": "image_006_0012.png", "id": "468535432489414", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75250458_468535435822747_1230677552996745658_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=81Et9u95oFcQ7kNvgGJBppA&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDi6JbKGBlBzNxV8kPM58Y1-G6_ks-zKNSXD3o_fDEaZw&oe=67092434"}, {"file_name": "image_007_0005.png", "id": "477550874827704", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982595_477550878161037_7113671620325822889_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DZujvPfZ4C8Q7kNvgGK_HfH&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB38AH1lp36EHZfnF06QLO-1-XX5M3Q2RqJ4M_XAhY5Mw&oe=670915A6"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Spunky Monkey VR", "keywords": [], "long_description": "Welcome to this artificial facade of a reality where the leading species are monkeys who can transform into different species and move with their arms because they lack legs. Sounds pretty sick, doesn't it? Well, welcome to Spunky Monkey VR! A cartoony styled game based off of the widely popular game Gorilla Tag. In this game, you can explore the massive forest map the monkeys claimed as their natural habitat, a canyons where monkeys can swing and glide through the beautiful terraforming of the sandstone, a shop built by the monkeys where other monkeys can get in style, a deep cave found by the monkeys, but don't go there, reports have come that few monkeys came back alive, and an alternate reality where you can test and experience all of the things not yet added to the main thing.", "short_description": "Spunky Monkey VR is a hand-based locomotion game, and it's based around the popular virtual reality game, Gorilla Tag. Walk around in forest, climb in canyons, buy stuff in shop, and get jump scared in horror!"}]}, "developer_name": "OxidizingStudios", "developer_privacy_policy_url": "https://sites.google.com/view/oxidizingstudios/privacy-notice", "developer_terms_of_service_url": null, "publisher_name": "Isaac Tinoco", "support_website_url": null, "website_url": "https://sites.google.com/view/oxidizingstudios/", "category": null, "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "411892083130028"}, {"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_la