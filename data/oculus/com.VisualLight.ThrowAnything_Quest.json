8011400859_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5ihDQNYPyAQQ7kNvgEOsoCr&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCz7QGjqG7V8Iyrs6We-h8nONtB-WM9PsVzbAuSiY_8SQ&oe=6707D723"}, {"file_name": "\uc2a4\ud14c\uc774\uc9c01_2-(1).png", "id": "1059585604811572", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75262742_1059585608144905_8719659089028722111_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EDjoPtdtJBgQ7kNvgFLpIy5&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBm_CSydyaV1WSfZmhvC2ZGB7WlO6wBM6Njwpch3DVBMg&oe=6707BB72"}, {"file_name": "\uc2a4\ud14c\uc774\uc9c04-(1).png", "id": "2845180175750112", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39035331_2845180182416778_6148255268265946760_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p1YPuPS6wHMQ7kNvgE3am_D&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCzvM81bX_rhnYkFh1dq6JvHyGMp8AAbQLJ50Qc4Gw--w&oe=6707DBAA"}, {"file_name": "\uc2a4\ud14c\uc774\uc9c06-(1).png", "id": "940705000094340", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982668_940705003427673_3899426170847427188_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m0JjfteoTaQQ7kNvgEmZVVR&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCqqugQ80UvHsnQlhOP2wiTE3pDq_x_g6ykzwP9tpZWjw&oe=6707D7A4"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "2560x1440_32bit.png", "id": "170020154803939", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982663_170020158137272_7980502875436620937_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pbDHl_kW28cQ7kNvgE3QS2Q&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDvtsc0bT8jFYr-A170OZ8lrbpsM8e9PPc3uZJZJcCqGg&oe=6707DAA9"}, "display_name": "Throw Anything", "keywords": [], "long_description": "There is nowhere to run... and nowhere to hide as zombies climb up the walls hoping to satisfy their appetite for brains. The only way to survive: reload your guns, destroy all furniture in the room, grab them all, and throw anything you can find to take them down.. and we mean ANYTHING.\nFace off against starving zombies in high-rise buildings across the globe in the VR action defense game, Throw Anything!\n\n\u25cf Key Features\n\u318dEnjoy laying waste to fully destructible environments!\n\n\u318dThrow any object within reach \u2013 humans included!\n\n\u318dTake on 6 challenging stages about to be overrun by the zombie horde!\n\n\u318dDefeat 5 mid-bosses and 6 powerful \u201cmain\u201d bosses!\n\n\u318dCollect ancient relics to save the world!\n\n\u318dDefeat zombies and get powerful weapons as rewards!\n\n\u318dTest your limits at various difficulty levels!", "short_description": "Get secret missions from Secret Delivery Agency (SDA) and save the world from zombie hordes in the VR action game, Throw Anything!"}]}, "developer_name": null, "developer_privacy_policy_url": "http://visuallight.kr/notice/?vid=6", "developer_terms_of_service_url": null, "publisher_name": "VisualLight Co., Ltd.", "support_website_url": null, "website_url": "http://visuallight.kr/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ACTION", "ADVENTURE", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["de", "ru", "ko", "en", "fr", "es", "zh_TW", "th", "ja", "id", "zh_CN"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "358265959171405"}, "review_messages": ["", "Hello!\n\nThank you for submitting to App Lab. Please provide a valid Privacy Policy URL that outlines how you collect and share user information, even if you are not collecting anything, 