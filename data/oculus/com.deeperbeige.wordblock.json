_Screenshot__0001_Layer-10.png", "id": "730877722445491", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38982724_730877729112157_3368435981660093747_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3TxisHy1qzcQ7kNvgF8fvTz&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYAoLFhUCessAtMYNcYP57Kcj0SsZ1wMnd6Xs8Rp-qPIzQ&oe=670BC725"}, {"file_name": "AOWB_Screenshot__0000_Layer-11.png", "id": "2132171110471297", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/57566685_2132171113804630_6020297435780050098_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NOzWFArNn_8Q7kNvgH5LkzK&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYCNon4Ua0akP_77SpTaAyJlaxBdfjSoDy8MILbZe8X6nQ&oe=670BBDCC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Word-Block-Trailer-Image-2560x1440.png", "id": "1613346342808754", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/39003253_1613346346142087_2107283030342275446_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rFH9snr1-eYQ7kNvgFz9edI&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYA_X6ZRccY57c4GqCLkcEUDQ7_S4UPcllXlGc-0VRycIA&oe=670BB98D"}, "display_name": "Arthur Owl's Word Block", "keywords": [], "long_description": "Let Arthur Owl guide you through this blend between a 3D crossword and a category quiz. He's on hand to help you learn the ropes and give you hints when your vocabulary fails you. He'll even teach you how to make your own puzzles.\n\nIncludes around 200 free puzzles and a fully featured editor to make your own. Submit them for inclusion in future user packs!\n\nThere are six premium-themed puzzle packs available to purchase for a total of over 300 puzzles.\n\nFeatures\n - 300+ puzzles, ranging from trivial to taxing\n - Hints for when you get stuck\n - Fully featured puzzle creator mode\n - 7 visual themes to suit all tastes\n - Fully adjustable settings\n - Personal puzzle statistics\n - Around 30 achievements\n - Meta leaderboards for each puzzle\n - In-game store for extra packs and hints  \n\nJoin the Discord!\nhttps://discord.gg/VmA5fWPryw\n", "short_description": "Meet Arthur Owl and his clever game Word Block. With around 200 included puzzles and even more in downloadable packs, you'll have plenty to do!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deeperbeige.com/privacy-policy-terms-of-service/", "developer_terms_of_service_url": null, "publisher_name": "Deeperbeige Games", "support_website_url": null, "website_url": "https://deeperbeige.com/", "category": null, "comfort_rating": null, "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7865695683516503"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75367591_434597172336400_5905407334416560266_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HdFoqOQChioQ7kNvgH048or&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYCfg2bJcPPJa5KOETegny1gGI9QhGh3h4_h_zA6bUdiyQ&oe=670BC0FC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Arthur Owl's Word Block", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490"}], "release_date": 1710365280, "lastRevision": {"nodes": [{"id": "5821234761295949", "release_type": "SCHEDULED", "administration_status": "APPROVED", "pdp_metadata": {"ap