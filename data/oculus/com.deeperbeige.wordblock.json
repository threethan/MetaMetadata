statistics\n - Over 25 achievements\n - Meta leaderboards for each puzzle\n - In-game store for extra packs and hints\n - NEW: Unlimited Hints DLC!\n\nJoin the Discord!\nhttps://discord.gg/VmA5fWPryw\n", "short_description": "Meet Arthur Owl and his clever game Word Block. With around 300 included puzzles and even more in downloadable packs, you'll have plenty to do!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://deeperbeige.com/privacy-policy-terms-of-service/", "developer_terms_of_service_url": null, "publisher_name": "Deeperbeige Games", "support_website_url": null, "website_url": "https://deeperbeige.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "8731717183581011"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75367591_434597172336400_5905407334416560266_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DMtvTsik34wQ7kNvgG3DJ2r&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCG3M0kpbJFXa5BaRFTdz7RtbLHkE4dmWWSGwdUDAoysQ&oe=676566FC"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Arthur Owl's Word Block", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Puzzle", "id": "377978390272490