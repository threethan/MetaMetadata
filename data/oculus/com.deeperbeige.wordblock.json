435981660093747_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y5Bo6NxlHtgQ7kNvgF3ZXpJ&_nc_ht=scontent.oculuscdn.com&oh=00_AYDqQ4NI6BIYNPIPhC_TY49nWOqtEsAmGDKeNamRS__v7g&oe=66FBF525"}, {"file_name": "AOWB_Screenshot__0000_Layer-11.png", "id": "2132171110471297", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57566685_2132171113804630_6020297435780050098_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Eg77enETCS8Q7kNvgHd9WX-&_nc_ht=scontent.oculuscdn.com&oh=00_AYAzCfguJ9BHMQX1iAxY3TTCP5JVsaW6ZlL-fz1pMQxgOA&oe=66FBEBCC"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Word-Block-Trailer-Image-2560x1440.png", "id": "1613346342808754", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39003253_1613346346142087_2107283030342275446_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SFh_bXuEQ6QQ7kNvgHMXn3k&_nc_ht=scontent.oculuscdn.com&oh=00_AYBtEL16zas10qUDXTcE-VbC4Vrhyp8Knb1E6ildIDEtwQ&oe=66FBE78D"}, "display_name": "Arthur Owl's Word Block", "keywords": [], "long_description": "Let Arthur Owl guide you through this blend between a 3D crossword and a category quiz. He's on hand to help you learn the ropes and give you hints when your vocabulary fails you. He'll even teach you how to make your own puzzles.\n\nIncludes around 200 free puzzles and a fully featured editor to make your own. Submit them for inclusion in future user packs!\n\nThere are six premium-themed puzzle packs available to purchase for a total of over 300 puzzles.\n\nFeatures\n - 300+ puzzles, ranging from trivial to taxing\n - Hints for when you get stuck\n - Fully featured puzzle creator mode\n - 7 visual themes to suit all tastes\n - Fully adjustable settings\n - Personal puzzle statistics\n - Around 30 achievements\n - Meta leaderboards for each puzzle\n - In-game store for extra packs and hints  \n\nJoin the Discord!\nhttps://discord.gg/VmA5fWPryw\n", "short_description": "Meet Arthur Owl and his clever game Word Block. With around 200 included puzzles and even more in d