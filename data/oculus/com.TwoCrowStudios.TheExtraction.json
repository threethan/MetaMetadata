=1-7&_nc_sid=6e7a0a&_nc_ohc=eyrssCWRFu4Q7kNvgGBksQJ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auga3-NTP5z9uuL4PYlId_O&oh=00_AYBXTJdkOnrtcDxUuo3BLECCkV3qqsooW1IjRUuDoGJwsw&oe=66D2EECE"}, {"file_name": "THE RETRIEVAL (2).png", "id": "532893648578056", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036657_532893655244722_8704198540069561814_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t7tkPg6DWPMQ7kNvgEff6MZ&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auga3-NTP5z9uuL4PYlId_O&oh=00_AYA10PYCEACxkaexPeEA8r6nHzDq-hHyG2pkVVGaqJ5q5g&oe=66D301E9"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "THE RETRIEVAL (2).png", "id": "1059497764697325", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982500_1059497768030658_269254459267951193_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mmpCZqz86gAQ7kNvgGEER-r&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auga3-NTP5z9uuL4PYlId_O&oh=00_AYDKruh32OOoL5BwWb-nAHVUp6YmT39S2yJoJ9XXdL3OJw&oe=66D31093"}, "display_name": "The Retrieval", "keywords": [], "long_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew.\n\n If you enjoy puzzles games and mind bending horror environments - this game is for you. And remember, the deep space can play tricks to the mind..\n\nWarning: this game contains sudden horrifying moments.\n\nThis game will receive regular updates.", "short_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew. If you enjoy puzzles games and mind bending horror environments - this game is for you.\n\n"}]}, "developer_name": "Two Crow Studios", "developer_privacy_policy_url": "https://twocrowstudios.godaddysites.com/the-retrieval", "developer_terms_of_service_url": null, "publisher_name": "Two Crow Studios", "support_website_url": null, "website_url": "https://twocrowstudios.godaddysites.com/the-retrieval", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "3771364559549515"}, {"id": "411892083130028"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "562746972632369"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974469_541611217420546_3438748509542675725_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zHi6tirl1BIQ7kNvgHTPs_J&_nc_ht=scontent.oculuscdn.com&_nc_gid=Auga3-NTP5z9uuL4PYlId_O&oh=00_AYDK75jeEHoQPGabc3-D2dvB0xtFNeZFvlUWSEqLC05KAQ&oe=66D2F1D0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "The Retrieval", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Interactive Story", "id": "3771364559549515"}, {"topic_name": "Horror", "id": "41189