scdn.com&oh=00_AYAU-0hv004DCWFm6bhyHH4k4S7JIXBnh_bDdt7hc-OnnA&oe=6752D04E"}, {"file_name": "THE RETRIEVAL (2).png", "id": "532893648578056", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39036657_532893655244722_8704198540069561814_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=wbPcV2U0Jx4Q7kNvgFU7pYB&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDtdaAlBNTnWrSwkKxx7qd3cXOvjL_HJoN97RWD0e6gOg&oe=6752E369"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "THE RETRIEVAL (2).png", "id": "1059497764697325", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38982500_1059497768030658_269254459267951193_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=y67t0dlouboQ7kNvgEoExaR&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC99eherAW6Ac7PR5gLdmjCsVsfrNYui41tKpRbSaTyPg&oe=6752F213"}, "display_name": "The Retrieval", "keywords": [], "long_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew.\n\n If you enjoy puzzles games and mind bending horror environments - this game is for you. And remember, the deep space can play tricks to the mind..\n\nWarning: this game contains sudden horrifying moments.\n\nThis game will receive regular updates.", "short_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to t