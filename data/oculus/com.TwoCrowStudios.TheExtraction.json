 signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew. If you enjoy puzzles games and mind bending horror environments - this game is for you.\n\n"}]}, "developer_name": "Two Crow Studios", "developer_privacy_policy_url": "https://www.twocrowstudios.com/privacy-policy-the-extraction", "developer_terms_of_service_url": null, "publisher_name": "Two Crow Studios", "support_website_url": null, "website_url": "http://www.twocrowstudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE", "SPACE_UNIVERSE"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "387580136682134"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "738425604482500"}, {"status": "PUBLISHED", "id": "561271025676333"}, {"status": "PUBLISHED", "id": "488318566101696"}]}, "baseline_offer": {"id": "738425604482500"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1679695740, "status": "PUBLISHED", "id": "738425604482500"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7610951755644777", "version": "1.2"}, "id": "1308700646321976", "channel_name": "LIVE"}]}, "is_f