25/38984446_348656964077061_4074936968419848118_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=KBwfcitWePYQ7kNvgEcUHAl&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYBqPdg2YoEynMj7ZzGHsc0QrIgk_jKmyrlHU_cPIm7mqQ&oe=67600E37"}, {"file_name": "Untitled design (6).png", "id": "392575969577349", "uri": "https://scontent-lga3-2.oculuscdn.com/v/t64.5771-25/39035315_392575972910682_4464738960571623405_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vEvLibL6JyMQ7kNvgE0d6Cs&_nc_zt=3&_nc_ht=scontent-lga3-2.oculuscdn.com&oh=00_AYBqatdA68n943di4cKu4wNQCRrtbeOGCFeHVJkE8O9exQ&oe=6760257E"}, {"file_name": "Untitled design (7).png", "id": "760533521614935", "uri": "https://scontent-lga3-1.oculuscdn.com/v/t64.5771-25/39001703_760533524948268_5929132528678025364_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SfEkBWfcQUIQ7kNvgE15CdH&_nc_zt=3&_nc_ht=scontent-lga3-1.oculuscdn.com&oh=00_AYA32uYWDSVDU8Kq4inW8hfW9FrWwAOb2eIZHU69vdjmDg&oe=675FFF4E"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "THE RETRIEVAL (2).png", "id": "1059497764697325", "uri": "https://scontent-lga3-3.oculuscdn.com/v/t64.5771-25/38982500_1059497768030658_269254459267951193_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VYw97N8MRkcQ7kNvgGNnuCF&_nc_zt=3&_nc_ht=scontent-lga3-3.oculuscdn.com&oh=00_AYDOYOAqMlNSP1d3ZfGzOUSsfSmbwkHpX5xl5Ux6J8fK-w&oe=67602113"}, "display_name": "The Retrieval", "keywords": [], "long_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew.\n\n If you enjoy puzzles games and mind bending horror environments - this game is for you. And remember, the deep space can play tricks to the mind..\n\nWarning: this game contains sudden horrifying moments.\n\nThis game will receive regular updates.", "short_description": "THE spaceship Prometheus has re-emerged after being lost for over 200 years. It's not responding to our calls or emitting any signals. The mission is simple: dock in, try to make contact with the crew and if not possible, learn what happened and leave.\n\nThe Retrieval is a sci-fi horror puzzle taking place in the far future. Navigate your way through abandoned spaceship learning what happened to the crew. If you enjoy puzzles games and mind bending horror environments - this game is for you.\n\n"}]}, "developer_name": "Two Crow Studios", "developer_privacy_policy_url": "https://www.twocrowstudios.com/privacy-policy-the-extraction", "developer_terms_of_service_url": null, "publisher_name": "Two Crow Studios", "support_website_url": null, "website_url": "http://www.twocrowstudios.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["HORROR", "PUZZLE", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "387580136682134"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "738425604482500"}, {"status": "PUBLISHED", "id": "561271025676333"}, {"status": "PUBLISHED", "id": "488318566101696"}]}, "baseline_offer": {"id": "738425604482500"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1679695740, "status": "PUBLISHED", "id": "7384256