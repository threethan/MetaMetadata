creenshot-1.png", "id": "832532242169712", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031457_832532248836378_3663210356497322076_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ycY8_Q4GjMMQ7kNvgH158-Y&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCNhlXSR_rTuPe5BNX-uZAC2KTp4yOe0AmZkXuRF13Zsw&oe=677BDC11"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "Landscape.png", "id": "1118375069235788", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974458_1118375072569121_2864568641225082773_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W4t3CavcVZAQ7kNvgHTJbeu&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDzbZXF6BexR5qjvuUSCp1CgSFRtx7inQKXqqvwPE_n-A&oe=677BA5B0"}, "display_name": "No Games - Drum & Bass Music Studio", "keywords": [], "long_description": "This app was created with PatchWorld - a modular metaverse where you can build experiences like this from scratch, we intend to take over cyberspace.\n\nAbout No Games - this is our collaboration with UK rapper Harry Shotta and acclaimed producer Erb n Dub. \n\nMix and match hard-hitting drum sounds to generate the perfect DNB beat. Compose wicked and wild bass lines by moving the controllers around, adding hair-raising effects, all on top of Harry Shotta's classic jump-up style rap virtuosity.\n\nPlay solo or with up to 15 friends to have your own virtual DNB rave in VR!", "short_description": "Play incredible Drum & Bass live in multiplayer, with the sounds of UK rapper Harry Shotta and acclaimed producer Erb n Dub. \n\nMix and match hard-hitting drum sounds to generate the perfect DNB beat. Compose wicked and wild bass lines by moving the controllers around, adding hair-raising effects, all on top of Harry Shotta's classic jump-up style rap virtuosity.\n\nPlay solo or with up to 15 friends to have your own virtual DNB rave in VR!\n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://wiki.patchxr.com/privacy-policy-201", "developer_te