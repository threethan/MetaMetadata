688515", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75210393_1266808544021848_5881271589942806823_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=OgPtyN24OacQ7kNvgFS54qn&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYAj523zb1S6YmegqMAgw8_5pwyt4v83oXiviZVR564CpA&oe=67122F0E"}, "display_name": "Partopia", "keywords": [], "long_description": "This is the Alpha test of our studio's first multi-player PVP game partopia. \nThis alpha test includes 3 basic game mode:\nCreazythrow: 10 people fighting against everyone and try to gain more points by eliminating other players.\nJelly Wars: 4v4 team fight by using your jelly gun hit your opponent. Save your teammate from huge jelly before out of breath by using your jelly spoon.\nBio Cube: Up to 16 player infection game. Random players becomes zombie to infect all human to win while human resist or kill zombie by using weapons.", "short_description": "Multiplayer party game Partopia, your party utopia! Now available on Meta Quest App Lab!\nJoin in game for free at our alpha test, try 3 game different mode!\nCreazy Throw: You throw burger bomb, they throw apples.\nJelly Wars: Turn your enemy to JELLY!!!!\nBio Cube: Be the zombie, infect all human! Or kill the zombie with your gun! In low-poly world!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.fountainmeta.com/privacy-policy-en.html", "developer_terms_of_service_url": null, "publisher_name": "Fountain Games Studio", "support_website_url": null, "website_url": "https://www.fountainmeta.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}, {"id": "1436351953220286"}, {"id": "459781504968480"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": [], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_m