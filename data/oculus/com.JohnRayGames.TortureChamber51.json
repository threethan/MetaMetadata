-7&_nc_sid=6e7a0a&_nc_ohc=gADG4Xp_0aIQ7kNvgGg33Bh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDZtA8VkOCWSbtL8i30IUjJ5zuRh4Ca0oZH4wGmgNviIg&oe=674B0692"}, "display_name": "Space Station 51", "keywords": ["space", "robot", "alien", "shooting", "asteroid"], "long_description": "Welcome to Space Station 51, your private space station where innovation meets action. Assigned to this high-tech lab, you\u2019re equipped with an arsenal of new weapons to test on your Robotic Dummy. From guns and blades to anything you can get your hands on, unleash your creativity and precision.\n\nTest Your Arsenal: Use a variety of weapons to inflict damage and earn credits.\n\nUnlock Premium Gear: Spend your hard-earned credits to unlock top-tier weapons and exciting mini-games.\n\nInteractive Environment: Discover and test interactable items around the station.\n\nDual-Wield Freedom: Equip and use weapons in both hands for maximum impact.\n\nStep into Space Station 51 and start your weapon testing adventure today!", "short_description": "You have been assigned to Space Station 51.  Backed by an arsenal of new weapons, you must test them on your Robotic Dummy.  Use  guns, blades and anything you can get your hands on. Test the weapon- get rewarded.  Simulated stress relief is guaranteed!"}]}, "developer_name": "John Ray", "developer_privacy_policy_url": "https://johnray32875.wixsite.com/johnraygames/space-station-51-privacy", "developer_terms_of_service_url": null, "publisher_name": "John Ray Games", "support_website_url": null, "website_url": "https://johnray32875.wixsite.com/johnraygames", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "331529188132278"}, {"id": "3744040075834813"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["CASUAL", "ARCADE", "SHOOTER"], "has_in_app_ads": false, "internet_connecti