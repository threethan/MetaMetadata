aCOCA&oe=66EC2165"}, {"file_name": "pdpscreenshot2_2560x1440.png", "id": "189575319607362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984462_189575322940695_2245710134253276400_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QG6VMDARg6cQ7kNvgGBWyP2&_nc_ht=scontent.oculuscdn.com&_nc_gid=AehKsEgIhdHOmHyAamAsTUT&oh=00_AYC4hDUhdroxtlc5f7eiScVod_KfuoKAvVCTl_HYlCYdIQ&oe=66EC111F"}, {"file_name": "pdpscreenshot5_2560x1440.png", "id": "428753815051356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001711_428753818384689_1522422253164281646_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VJHV4NyB0qAQ7kNvgE2nd6B&_nc_ht=scontent.oculuscdn.com&_nc_gid=AehKsEgIhdHOmHyAamAsTUT&oh=00_AYAmQhUNY7vwucm08foGg7liaPBy3gqZXVBuPSapUK9RuA&oe=66EC05D7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YpU8uO8kF_sQ7kNvgEq5tA4&_nc_ht=scontent.oculuscdn.com&_nc_gid=AehKsEgIhdHOmHyAamAsTUT&oh=00_AYAK7dkE58OEzXc8Z-CpaZYzev7TwUxbthwOgczleSIPKg&oe=66EC0514"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", "