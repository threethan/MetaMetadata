5c8DA&oe=66F015E5"}, {"file_name": "pdpscreenshot2_2560x1440.png", "id": "189575319607362", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38984462_189575322940695_2245710134253276400_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=CGHznmMZ-UwQ7kNvgF0lUZH&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5Nl74Jm5LEHKgn2wpIY3CB&oh=00_AYAry8eEsMlrH2JF5Gfj3evJQNST0mV67ngm-wlPdG1H6Q&oe=66F0059F"}, {"file_name": "pdpscreenshot5_2560x1440.png", "id": "428753815051356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001711_428753818384689_1522422253164281646_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cSFBvYHldeAQ7kNvgHmLSfn&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5Nl74Jm5LEHKgn2wpIY3CB&oh=00_AYAC4PpbYzT6ebuG5li7835aThSXpZls8df6Begictw1PQ&oe=66EFFA57"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XHLpB6vnebQQ7kNvgHQNxH6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A5Nl74Jm5LEHKgn2wpIY3CB&oh=00_AYDMRxQVM-IVtg1DIctaZ3Qn_U7pWn-h4Y1EXzalI_h1oQ&oe=66EFF994"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", "