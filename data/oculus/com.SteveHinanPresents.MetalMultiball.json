video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BE4VqNk1AlQQ7kNvgFLyXDA&_nc_ht=scontent.oculuscdn.com&oh=00_AYA8PGtg0YpEQ2NO4BnOKDeF_YjC_jPBOSS-G99hBDtuYQ&oe=66E56D94"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", "short_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music.\n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://stevehinanpresents.com/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Steve Hinan", "support_website_url": "https://stevehinanpresents.com/", "website_url": "https://stevehinanpresents.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfo