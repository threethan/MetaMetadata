Ian_C4RROl&oh=00_AYDE-fPZ7LFxBB4Shyad974FP3QIUKhAUmJ6cnAg2dQo0w&oe=66E0339F"}, {"file_name": "pdpscreenshot5_2560x1440.png", "id": "428753815051356", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001711_428753818384689_1522422253164281646_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8FOfhNGYj58Q7kNvgFbq9lL&_nc_ht=scontent.oculuscdn.com&_nc_gid=APIKzzI9OKDvLIan_C4RROl&oh=00_AYD6WFlyO-bk1XKr7KVPN0ADFoWeB3ijVuVpyyweanvJ8Q&oe=66E02857"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7fCA29hmRxsQ7kNvgHlR3aU&_nc_ht=scontent.oculuscdn.com&_nc_gid=APIKzzI9OKDvLIan_C4RROl&oh=00_AYADt5Ty6sZsTmfan44MubJoDNym1oDQ0ozXPbu-rWhhEA&oe=66E02794"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", "short_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music.\n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to lear