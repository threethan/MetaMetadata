AqH&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYACC2zJUwMcoTvl3LqeDRBzqwUbjaCfHKS6foqq1WJmeA&oe=6729FB98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "hexapuss_storecoverart_hexagon_2560x1440.png", "id": "452429410670929", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75630188_452429417337595_538857478969487480_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=z7e2ovbixH8Q7kNvgHeJtCh&_nc_zt=3&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYCWwrXjdr-GdJKtG_KatZrR8ka919IJnSz8VwUCJcJJOw&oe=6729F581"}, "display_name": "Hexapuss", "keywords": ["cat", "metal", "pinball", "music", "story"], "long_description": "I need your help to send Hexapuss back to the Sixth Dimension.\n\nHigh above Honolulu, a wormhole opened, connecting to the mysterious Sixth Dimension, and out came Hexapuss\u2014a colossal cat's head with six powerful tentacles. But then, something went wrong. The wormhole vanished, leaving Hexapuss stranded.\n\nNow, the military is in a frantic battle to destroy Hexapuss, who\u2019s terrified and just wants to return home to the Sixth Dimension.\n\nI've discovered a way to help Hexapuss return home. By re-opening the wormhole, we can save Hexapuss. But I can't do it alone\u2014I need you.\n\nJoin the adventure by playing my pinball game, and I\u2019ll guide you through each step.\n\nTime is running out. Play now and help save Hexapuss!\n\nHexapuss is:\n\nA virtual reality game.\nAn album by Hexapuss.\nStreaming music available now.\nA future summer blockbuster movie.\nMerch available at Hexapuss.com.", "short_description": "I need your help to send Hexapuss back to the Sixth Dimension.\n\nI've discovered a way to help Hexapuss return home. By re-opening a wormhole, we can save Hexapuss. But I can't do it alone\u2014I need you.\n\nJoin the adventure by playing my pinball game, and I\u2019ll guide you through each step.\n\nTime is running out. Play now and help save Hexapuss!\n\nHexapuss is:\n\nA virtual reality game.\nAn album by Hexapuss.\nStreaming music available now.\nA future summer blockbuster movie.\nMerch available at Hexapuss.com."}]}, "developer_name": null, "developer_privacy_policy_url": "https://stevehinanpresents.com/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Steve Hinan", "support_website_url": "https://stevehinanpresents.com/support.html", "website_url": "https://stevehinanpresents.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1672577396871977"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "9383712114979500"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75196228_1099440128485936_1466932949221852375_n.png?stp=dst-png_s360x360&_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=J6IxJXbHISgQ7kNvgEY9I1h&_nc_zt=3&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCsBGVPJoUUVYSsffNe-HGiU44lTaQNZ3j2Io5iGb1H6Q&oe=672A0AC0"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Hexapuss", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Arcade", "id": "1592192974313489"}, {"topic_name": "Rhythm", "id": "1672577396871977"}], "release_date": 1618440375, "lastRevision": {"nodes": [{"id": "3435699516558792", "release_type": "SCHEDULED", "administrati