: "280832060130982", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75210887_280832063464315_385758176981127118_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=U6p7F_bbSHMQ7kNvgEAJjG2&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAAHigyuX0n5DVcVZjVYTktff9Q4djfQO3T7IHXqWoRJA&oe=6714FFE5"}, {"file_name": "pdpscreenshot2_2560x1440.png", "id": "189575319607362", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38984462_189575322940695_2245710134253276400_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=chuyLl33q1QQ7kNvgEoY5jJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC9Iym0kZINrZV4FKZxsu1zE2JeiH4VI8dDb_3BzIRCjw&oe=6714EF9F"}, {"file_name": "pdpscreenshot5_2560x1440.png", "id": "428753815051356", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001711_428753818384689_1522422253164281646_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7lL4mNWAH0MQ7kNvgGvCYqE&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDG6FtAn_pLp1vpFUsymhNVYTl9SEwKL-Sx5nXcVvwnBQ&oe=6714E457"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yUKAqbgbQ-YQ7kNvgEcSthO&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC1YsOjwoLO0fAAcxfKIMqm20g5-dk2xxI9o9FEEh9gzA&oe=6714E394"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", "short_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music.\n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://stevehinanpresents.com/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Steve Hinan", "support_website_url": "https://stevehinanpresents.com/", "website_url": "https://stevehinanpresents.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "ACTION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "476811183967333"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "903403624943770"}, {"status": "PUBLISHED", "id": "3325582784328681"}, {"status": "PUBLISHED", "id": "3671917966397006"}, {"status": "CANCELLED", "id": "1182959735497268"}, {"status": "PUBLISHED", "id": "5