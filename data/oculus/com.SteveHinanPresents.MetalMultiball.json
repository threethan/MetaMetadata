&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rFvKGKmbwQoQ7kNvgGlQvOS&_nc_ht=scontent.oculuscdn.com&oh=00_AYCHFf-UH2w0eeicrwkq0MC4ciBZ4JG9p7RtDCfCOhw8Lw&oe=66E55FD3"}, "display_name": "Hexapuss", "keywords": ["cat", "metal", "pinball", "music", "scifi"], "long_description": "Imagine a pinball machine designed by Hexapuss, that teleports you into music venues to hear songs created by Hexapuss itself. Do you have what it takes to prevent Hexapuss from opening a quantum chromodynamic wormhole into another dimension?  Play Hexapuss and find out.\n\nHexapuss is:\nA virtual reality game.\nA full album soundtrack created by Hexapuss.\nA six tentacled cat trying to open another dimension.\nMusic to be streamed now on your favorite streaming sites.\nTo become a summer blockbuster movie at a theater near you.\nA merch store at hexapuss.com\n\nPlay Hexapuss now!", "short_description": "Imagine a pinball machine designed by Hexapuss, that teleports you into music venues to hear songs created by Hexapuss itself. Do you have what it takes to prevent Hexapuss from opening a quantum chromodynamic wormhole into another dimension?  Play Hexapuss and find out.\n\nHexapuss is:\nA virtual reality game.\nA full album soundtrack created by Hexapuss.\nA six tentacled cat trying to open another dimension.\nA merch store at hexapuss.com\n\nPlay Hexapuss now!"}]}, "developer_name": null, "developer_privacy_policy_url": "https://stevehinanpresents.com/privacy_policy.pdf", "developer_terms_of_service_url": null, "publisher_name": "Steve Hinan", "support_website_url": "https://stevehinanpresents.com/support.html", "website_url": "https://stevehinanpresents.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "1436351953220286"}, {"id": "939033889924114"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ARCADE", "MUSIC", "ACTION"], "h