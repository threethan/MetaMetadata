cdn.com&oh=00_AYAV4jvsRKmcrwmH2wom_9E26nxwEZvqvOQKpH-qSkn6iw&oe=671A45E5"}, {"file_name": "pdpscreenshot2_2560x1440.png", "id": "189575319607362", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/38984462_189575322940695_2245710134253276400_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XJKLZ5gVh1YQ7kNvgHStmYD&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCyfOUe521LVg4Jtfqa2soR1yyVhsJyZyuoRQ8dhstFuQ&oe=671A359F"}, {"file_name": "pdpscreenshot5_2560x1440.png", "id": "428753815051356", "uri": "https://scontent-xsp1-2.oculuscdn.com/v/t64.5771-25/39001711_428753818384689_1522422253164281646_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=tbdERFUKqSgQ7kNvgFAeZVi&_nc_ht=scontent-xsp1-2.oculuscdn.com&oh=00_AYCjAEbdDPlz_ErYum9hyRnlncK2P_t2JCOHU4PDKcerlw&oe=671A2A57"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "storecoverart_2560x1440.png", "id": "442888356916842", "uri": "https://scontent-xsp1-1.oculuscdn.com/v/t64.5771-25/39031334_442888360250175_8830731171757784778_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7kncgz86RS0Q7kNvgHZmnMq&_nc_ht=scontent-xsp1-1.oculuscdn.com&oh=00_AYCp67E7mWbBSuv3GIfTeQ4XgXH2Ud571DcfKpwZrfRNSA&oe=671A2994"}, "display_name": "METAL MULTIBALL", "keywords": [], "long_description": "Enter the arena in Metal Multiball, a powerful twist on an arcade classic celebrating the head banging, heart pounding excitement of live metal music. \n\nIn this fast-paced pinball-inspired game, it\u2019s up to you to get the band thrashing by activating their riffs in time. \n\nEasy to learn, hard to put down, and playable seated or standing, Metal Multiball takes the simple mechanic of the classic pinball machine to a full VR experience. \n\nCan you sharpen your reflexes and take on the world leaderboard? \n\n\u201cIt\u2019s Guitar Hero-meets-pinball-meets-pong in first-person 3D. I loved it.\u201d - john.falco.16 \n\nFor soundtrack sheet music, developer feedback and press kit, please visit: https://stevehinanpresents.com/", 