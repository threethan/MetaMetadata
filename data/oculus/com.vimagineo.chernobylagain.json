id=6e7a0a&_nc_ohc=1LDm9G1e5uYQ7kNvgEYThI_&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAZnnEjZ02BMCaqzsJdmzfYztnPeJ630rqOBlwy3U7UXQ&oe=6771228E"}, {"file_name": "HUB2_v1.png", "id": "996873442181549", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974650_996873445514882_2154121447832373372_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=97xD6mFDEQMQ7kNvgEtawTP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAvPk2-FP_u5b0XXA8AlQpzuTs7FiFnl3VPeCfNZSunpg&oe=677145A7"}, {"file_name": "CR_v4.png", "id": "470834692256587", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031588_470834695589920_6708869786565533216_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mzxPOw3ofBgQ7kNvgFwkDBl&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3UMCRftsYzdC0__wGqhq0Si3Rn2ut2gwnI6G4HQyxiQ&oe=677119F0"}, {"file_name": "DUGA_v5.png", "id": "1466821260708095", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/57572943_1466821267374761_6415709384416036575_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MEvDcyEtuZcQ7kNvgEv1y2S&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDq8y-AUFAJTAIQOPhOfD7aVuXqReSZPUMLv9RkPSV3AA&oe=67711E16"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ChernobylAgain_KeyArt.png", "id": "3647629912233771", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031656_3647629918900437_8164619944999043534_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NR6nl3j0Z4cQ7kNvgHBOGm0&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA0fepfubzQLunqULIt2qyVIhwHumeoQ1bSlHFO1ovx1g&oe=67711D13"}, "display_name": "Chernobyl Again", "keywords": [], "long_description": "Chernobyl Again is an adventure game created for Virtual Reality headsets taking place in the 3D-scanned Chernobyl Exclusion Zone for a more immersive and engaging experience. You\u2019ll get the chance to explore the Zone, feel its dark atmosphere, and follow the plot full of unexpected twists via different kind of puzzles, you\u2019ll get to solve while traveling through space and time. Your main goal will be to stop the Chernobyl Nuclear Power Plant explosion, and the consequences we know it brought not only to our timeline but also to alternative futures that became available to us thanks to your time traveling discovery.", "short_description": "Living without parents isn\u2019t easy. You know it best. To the world you are Olena Ponomarenko \u2013 a successful Ukrainian scientist responsible for discovering time traveling. But deep inside you are an adult woman that desperately wants to once again meet her parents, just to tell them how much she loves them. This was the driving force behind all your scientific experiments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chernobylagain.com/ChernobylAgain_PrivacyPolicy_en.pdf", "developer_terms_of_service_url": null, "publisher_name": "Vimagineo Sp z o.o.", "support_website_url": null, "website_url": "https://vimagineo.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "459781504968480"}, {"id": "2691890164460465"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7177225272377657"}}]}, "scheduled_offers": {"count": 5, "nodes": [{"status": "PUBLISHED", "id": "1184681803026431"}, {"status": "PUBLISHED", "id": "466140412544565"}, {"status": "PUBLISHED", "id": "465889589621262"}, {"status": "PUBLISHED", "id": "1543178829914038"}, {"status": "PUBLI