Dr_Zq&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoVBruPvx2QUQ5lPpNlUadh&oh=00_AYAU-8R1ihqrI6hDud4bv3g_BZyPsyxmJYZd2bi5-V6kxw&oe=66F558A7"}, {"file_name": "CR_v4.png", "id": "470834692256587", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031588_470834695589920_6708869786565533216_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=XcAexRkewFoQ7kNvgGph3en&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoVBruPvx2QUQ5lPpNlUadh&oh=00_AYBq1KwzUe-yP61OVfdQj4od54jpm_TsM2q7V9egJ1xACA&oe=66F56530"}, {"file_name": "DUGA_v5.png", "id": "1466821260708095", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57572943_1466821267374761_6415709384416036575_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uuFf09lZFhcQ7kNvgF7Up8t&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoVBruPvx2QUQ5lPpNlUadh&oh=00_AYCUhC51iD5IAUvduXqW0I_DYbXfJQauWoI-9uwxfIq1TQ&oe=66F53116"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ChernobylAgain_KeyArt.png", "id": "3647629912233771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_3647629918900437_8164619944999043534_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xzEYrCvK3kIQ7kNvgGFXn9D&_nc_ht=scontent.oculuscdn.com&_nc_gid=AoVBruPvx2QUQ5lPpNlUadh&oh=00_AYAwiFqzHqfjEkkLfv0mqDlRcScohYvjNfXbLNmV2Qae9g&oe=66F53013"}, "display_name": "Chernobyl Again", "keywords": [], "long_description": "Chernobyl Again is an adventure game created for Virtual Reality headsets taking place in the 3D-scanned Chernobyl Exclusion Zone for a more immersive and engaging experience. You\u2019ll get the chance to explore the Zone, feel its dark atmosphere, and follow the plot full of unexpected twists via different kind of puzzles, you\u2019ll get to solve while traveling through space and time. Your main goal will be to stop the Chernobyl Nuclear Power Plant explosion, and the consequences we know it brought not only to our timeline but also to alternative futures that became available to us thanks to your time traveling discovery.", "short_description": "Living without parents isn\u2019t easy. You know it best. To the world you are Olena Ponomarenko \u2013 a successful Ukrainian scientist responsible for discovering time traveling. But deep inside you are an adult woman that desperately wants to once again meet her parents, just to tell them how much she loves them. This was the driving force behind all your scientific experiments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chernobylagain.com/ChernobylAgain_PrivacyPolicy_en.pdf", "developer_terms_of_service_url": null, "publisher_name": "Vimagineo Sp z o.o.", "support_website_url": null, "website_url": "https://vimagineo.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7177225272377657"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PUBLISHED", "id": "465889589621262"}, {"status": "PUBLISHED", "id": "1543178829914038"}, {"status": "PUBLISHED", "id": "1096958862034550"}]}, "baseline_offer": {"id": "465889589621262"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1726160400, "status": "PUBLISHED", "id": "465889589621262"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "7576359029130944", "version": "0.489900"}, "id": "829065182435975", "channel_name": "LIVE"}]}, "is_for_