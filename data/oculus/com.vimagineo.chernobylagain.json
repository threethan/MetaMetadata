7kNvgGL0Fh-&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8yCkCyGj6Rtf986b6Vyrp1&oh=00_AYAiS76xzg9omQtvVREk1E89VrSqMfZ1V-5EgaDPnwNnYQ&oe=66F289F0"}, {"file_name": "Pump_v2 (1).png", "id": "1603107346902568", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031378_1603107350235901_5182994270841475141_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=0CMB_Rss3vIQ7kNvgGCQOxo&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8yCkCyGj6Rtf986b6Vyrp1&oh=00_AYBdLgjQyCwWmkWMtNhPd_PEivh8mNdBClQrFlocPlNsZg&oe=66F2983A"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "ChernobylAgain_KeyArt.png", "id": "3647629912233771", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031656_3647629918900437_8164619944999043534_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_qDEEk3i4OwQ7kNvgEAUfW6&_nc_ht=scontent.oculuscdn.com&_nc_gid=A8yCkCyGj6Rtf986b6Vyrp1&oh=00_AYAd4atWXeoKgcyul9HSmwtXA95r8IEUL07O5oFJtvE24A&oe=66F28D13"}, "display_name": "Chernobyl Again", "keywords": [], "long_description": "Chernobyl Again is an adventure game created for Virtual Reality headsets taking place in the 3D-scanned Chernobyl Exclusion Zone for a more immersive and engaging experience. You\u2019ll get the chance to explore the Zone, feel its dark atmosphere, and follow the plot full of unexpected twists via different kind of puzzles, you\u2019ll get to solve while traveling through space and time. Your main goal will be to stop the Chernobyl Nuclear Power Plant explosion, and the consequences we know it brought not only to our timeline but also to alternative futures that became available to us thanks to your time traveling discovery.", "short_description": "Living without parents isn\u2019t easy. You know it best. To the world you are Olena Ponomarenko \u2013 a successful Ukrainian scientist responsible for discovering time traveling. But deep inside you are an adult woman that desperately wants to once again meet her parents, just to tell them how much she loves them. This was the driving force 