", "adventure", "spy", "radiation", "timetravel"], "long_description": "Chernobyl Again is an adventure game created for Virtual Reality headsets taking place in the 3D-scanned Chernobyl Exclusion Zone for a more immersive and engaging experience. You\u2019ll get the chance to explore the Zone, feel its dark atmosphere, and follow the plot full of unexpected twists via different kind of puzzles, you\u2019ll get to solve while traveling through space and time. Your main goal will be to stop the Chernobyl Nuclear Power Plant explosion, and the consequences we know it brought not only to our timeline but also to alternative futures that became available to us thanks to your time traveling discovery.", "short_description": "Living without parents isn\u2019t easy. You know it best. To the world you are Olena Ponomarenko \u2013 a successful Ukrainian scientist responsible for discovering time traveling. But deep inside you are an adult woman that desperately wants to once again meet her parents, just to tell them how much she loves them. This was the driving force behind all your scientific experiments."}]}, "developer_name": null, "developer_privacy_policy_url": "https://chernobylagain.com/ChernobylAgain_PrivacyPolicy_en.pdf", "developer_terms_of_service_url": null, "publisher_name": "Vimagineo Sp z o.o.", "support_website_url": "https://linktr.ee/chernobylagainvr", "website_url": "https://chernobylagain.com/", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}, {"id": "377978390272490"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "zh_CN", "fr", "de", "it", "ja", 