9470729033"}, {"status": "PUBLISHED", "id": "971226863390042"}, {"status": "PUBLISHED", "id": "993803007418411"}]}, "baseline_offer": {"id": "993803007418411"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1577250000, "status": "PUBLISHED", "id": "1502073169942798"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "2804547742932726", "version": "1.0.6"}, "id": "1800480756875650", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1172102179510632", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "2804547742932726"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1800480756875650"}]}, "change_log": "Update V1.0.6 - Patch Notes\n\nHi everyone,\nCityAvenger has released an important update: The input method adds an oculus 3dof controller. However, the 3dof handle has fewer keys, so downloading tools are not supported. We will improve the operation of the 3dof handle in subsequent updates.\n\nImportant Update: Support Oculus controller\n\n-Bullet Time: Rotating the handle can make the game screen enter the cool bullet time, the sense of the movie blockbuster.\n-Character Jumping: Tap the touchpad to jump high, and the battle on the roof is completely open!\n-Grenade Throwing: Raise the handle and press the trigger. The grenade can knock down a bunch of enemies.\n-New tutorial: animation guide, operation is no longer lost!\n\nChesstar", "created_date": 1585214227, "id": "2804547742932726", "version": "1.0.6", "version_code": 7, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsse