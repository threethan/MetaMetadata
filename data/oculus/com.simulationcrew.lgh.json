s": [], "long_description": "Ga in een realistisch virtueel rollenspel op huisbezoek bij Noreen, een cli\u00ebnt die moeite heeft met een lastige brief die ze heeft ontvangen. Begeleid haar bij haar hulpvraag, werk aan het opbouwen van een vertrouwensband en leer tekenen van laaggeletterdheid herkennen en bespreekbaar te maken. Is dit niet direct gelukt? Geen zorgen; na ieder gesprek ontvang je feedback en tips die je kunt toepassen in de volgende ronde.\n\nDeze unieke gespreksimulatie maakt gebruik van vrije spraak, waardoor het initiatief in het gesprek bij jou ligt. Door de realistische omgeving en je virtuele gesprekspartner, word je helemaal ondergedompeld in de situatie. Met de ingebouwde feedback en intelligente begeleiding krijg je jouw gespreksvaardigheden op een hoger niveau.", "short_description": "Oefen met het herkennen en bespreekbaar maken van laaggeletterdheid in Virtual Reality."}]}, "developer_name": null, "developer_privacy_policy_url": "https://cdn.jutten.com/docs/Privacyverklaring_The_Simulation_Crew_1.1.pdf", "developer_terms_of_service_url": null, "publisher_name": "The Simulation Crew BV", "support_website_url": "https://thesimulationcrew.nl/contact/", "website_url": "https://thesimulationcrew.nl/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "27362927396627898"}], "external_subscription_type": "REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["nl"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7107855689335535"}, "review_messages": ["", ""]}]}, "cover_square_image": {"uri": "https://scontent