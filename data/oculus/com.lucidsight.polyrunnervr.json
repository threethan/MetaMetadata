: "https://scontent.oculuscdn.com/v/t64.5771-25/12138787_952368068204629_924394922_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=czZECx-ZhoYQ7kNvgH9QXnW&_nc_ht=scontent.oculuscdn.com&oh=00_AYDVtfoXGGs8U7ZlUfAK-VZjDIgd4t5f4M8xVrC3QDwcZA&oe=66EEC2B2"}, {"file_name": "migrated_image.png", "id": "1072022266488003", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449013_228821660840807_1983909034_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xZ6Ytu0ZCdoQ7kNvgFa-NaI&_nc_ht=scontent.oculuscdn.com&oh=00_AYCUw5mFfY93JzyLope8ZcjYHInSSK_Rq9IMRxi0t_neeg&oe=66EE9161"}, {"file_name": "migrated_image.png", "id": "139484677469269", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12138834_1704839416462802_1846039149_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=D1DpfHGSfawQ7kNvgH6BZtg&_nc_ht=scontent.oculuscdn.com&oh=00_AYD1-E6AQJD8LzKyZtojo7ZADfu66FKXS0RB2eVZkhqUbQ&oe=66EEB3DA"}, {"file_name": "migrated_image.png", "id": "199826677981130", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449015_571657549679681_739445879_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mrIT-7VtZxoQ7kNvgHY7ke3&_nc_ht=scontent.oculuscdn.com&oh=00_AYDMVBFf-wYv4EeCK5WnkxwceGwZxVhSNL45ERYtUoKu_A&oe=66EEB695"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PolyRunner VR", "keywords": ["platformer", "poly", "racer", "runner", "ship", "side scroller", "space"], "long_description": "**1.3.0 UPDATE: Gameplay Re-balance and New Levels!***\n\nPolyRunner VR is an addictive, high-quality experience that tests your skills against an other-worldly, ever-changing landscape rather than testing your ability to maintain control of your stomach. This engaging virtual world offers more interesting, challenging terrain the further you progress. All the while, you can collect bonus points for your precision by navigating through checkpoints and utilizing boosts to give you an extra edge. The intuitive controls make it easy for anyone to compete in this spaceship runner, but mastering flight skills is a feat that will earn you a place among the top guns and make you worthy of a personal theme song that would inspire jealousy in any maverick pilot. Will you accept the challenge? \n\nFeatures: \n- A spaceflight runner designed to put your skills to the test \n- Intriguing, immersive landscapes that change as you progress \n- An incredibly comfortable VR experiene", "short_description": "Try your hand at the VR spaceflight challenge reviewers have dubbed \u201cnot a hurl fest!\u201d Enter a world full of immersive alien landscapes through which you must navigate at high speeds, using lightning-fast reflexes to score points and earn your rep as the ultimate starfighter pilot. How long can you survive?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/7759324", "developer_terms_of_service_url": "http://lucidsight.com/tos.html", "publisher_name": "Lucid Sight, Inc.", "support_website_url": null, "website_url": "http://www.lucidsight.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "RACING"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "955720835131376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/12449015_1530458947259833_1043309972_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zm1Q7zMDbRkQ7kNvgEAyj5n&_nc_ht=scontent.oculuscdn.com&oh=00_AYAPa97d8IQ1yzT4wvmgeBsNNw9ZKF3dFLmMEoNr_Og4nA&oe=66EEA07F"}, "is_concept": false, "is_test": false