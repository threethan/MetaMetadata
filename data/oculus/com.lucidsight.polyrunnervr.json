2Z&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYARvGvLxqAlhQfznSyA-ePNmGcFcrJWfrUOPDdK0lCDmQ&oe=676AA7CF"}, {"file_name": "migrated_image.png", "id": "1168274726844524", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138787_952368068204629_924394922_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UmNw-_xexRAQ7kNvgE1UjYS&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCoIIY3UoU2cfWeJ8YeaAULD-9YkLVHN8uTA0k8Ok67Lw&oe=676AAFB2"}, {"file_name": "migrated_image.png", "id": "1072022266488003", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12449013_228821660840807_1983909034_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pmcri5gSRdQQ7kNvgHuyeBp&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAn7jlq-2QfC0jQLrW6lA4zt1bidykhCrf1stS2dhGTSA&oe=676AB6A1"}, {"file_name": "migrated_image.png", "id": "139484677469269", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/12138834_1704839416462802_1846039149_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=GL3gezvUi68Q7kNvgE56n8I&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCZORJ7aTmDhwPslDqkwCjB1QO0FLRYbb-QJFjq0U263g&oe=676AA0DA"}, {"file_name": "migrated_image.png", "id": "199826677981130", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/12449015_571657549679681_739445879_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TOSY-bQDz2MQ7kNvgEbuBxv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAdcb7Ds_YYENTWmAeBIq3-OVYORLUUyNmYXWjuKW5XPA&oe=676AA395"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "PolyRunner VR", "keywords": ["platformer", "poly", "racer", "runner", "ship", "side scroller", "space"], "long_description": "**1.3.0 UPDATE: Gameplay Re-balance and New Levels!***\n\nPolyRunner VR is an addictive, high-quality experience that tests your skills against an other-worldly, ever-changing landscape rather than testing your ability to maintain control of your stomach. This engaging virtual world offers more interesting, challenging terrain the further you progress. All the while, you can collect bonus points for your precision by navigating through checkpoints and utilizing boosts to give you an extra edge. The intuitive controls make it easy for anyone to compete in this spaceship runner, but mastering flight skills is a feat that will earn you a place among the top guns and make you worthy of a personal theme song that would inspire jealousy in any maverick pilot. Will you accept the challenge? \n\nFeatures: \n- A spaceflight runner designed to put your skills to the test \n- Intriguing, immersive landscapes that change as you progress \n- An incredibly comfortable VR experiene", "short_description": "Try your hand at the VR spaceflight challenge reviewers have dubbed \u201cnot a hurl fest!\u201d Enter a world full of immersive alien landscapes through which you must navigate at high speeds, using lightning-fast reflexes to score points and earn your rep as the ultimate starfighter pilot. How long can you survive?"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.iubenda.com/privacy-policy/7759324", "developer_terms_of_service_url": "http://lucidsight.com/tos.html", "publisher_name": "Lucid Sight, Inc.", "support_website_url": null, "website_url": "http://www.lucidsight.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "RACING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["GAMEPAD", "TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "955720835131376"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.co