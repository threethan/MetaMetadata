imos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pQIldYR_ziUQ7kNvgGAE0fJ&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYA-Mym7rMQZUfoidWA-c2z3wLyvEnw7E4c7rZeNPsYFLQ&oe=67879CBA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3NTRb3xaVZMQ7kNvgGVVQlM&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYD0WzjkQR70V8WZHXIfQodK6DByN6kqXHwIv_16iBjNpw&oe=67879B82"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4pyK0AlAeV4Q7kNvgF4dh3d&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYBL_vPj4GEFTA08eisWp9a-aDQUupYm-JrqA2ZCmW96-Q&oe=6787A7E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jIrfr45zDoQQ7kNvgFsz48U&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYCOpVGRbiiUIAeS79cytHsjmCKK8zX3IBEAOCprxP3BSg&oe=67879D13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwPFk5p4Dw4Q7kNvgFmlIsK&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=0