5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yidAgTM1_7sQ7kNvgGjQuCv&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBZon7E09YRAQ9zATtS1on8Wm9mBCWAVJPzIYmmFDcrng&oe=675993FC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=b7CebdybEQUQ7kNvgG-6C33&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAGs958E4BZNIsUBq7LQ6CuEFSCirRxLxuepKzkBuBBvg&oe=675966EF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SbdxfglA420Q7kNvgEJWewa&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYC4SO3s7oXvnpos3JrLJPnMc6AgvyVCuogA-v6mVLsM5Q&oe=675985AE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5AxXAl7i3ecQ7kNvgHJLB1e&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAyrjnoQr5P5ZbJBdRCIO-e1ccmT4L6t6xM6dxpdTDLDw&oe=6759783A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mmR6wvizvyIQ7kNvgEzT89Q&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCEokfisvjErD8BxC5jGAnxotwLLfu9aEYMIbpd3_Tjsw&oe=67597702"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7x_nodT3SrcQ7kNvgG8KPuj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYB1ukpAj7lQEnHGvxTW7nErSZ6XJ8KvufW2n7rBT_BKfg&oe=67598362"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y46IzoZxFQYQ7kNvgGBpMCJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAVHXBMuNn55STeUVC9CD17ePxlEdOHIIbaQHKVbukOHA&oe=67597893"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y0dYsuavDj0Q7kNvgGzAHcw&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=0