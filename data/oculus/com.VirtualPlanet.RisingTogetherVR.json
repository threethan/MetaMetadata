5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Rc4WIg2PuicQ7kNvgGgio9U&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBw1A568Sa2SJxV4jqblhIZdZYBJ9ixMJTEZ3P55TLudA&oe=678666FC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZeDaIphhpBgQ7kNvgGgbwVs&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYA_oaibyW1D9kX25dH6g8J1FIFq2O7t88MtjcjDEI_Ndw&oe=678639EF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qaNJ6svVtgsQ7kNvgGfgkhq&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBcRW3in8apHjSftN-gA4E72RtJCUbaLX-Nn4gRYgnNEw&oe=678658AE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pQIldYR_ziUQ7kNvgG8hy2i&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBTLZyOP2ZAOWnX3xlWBsIM0JgcdQpa8XyVtCh0xaZXlw&oe=67864B3A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=3NTRb3xaVZMQ7kNvgFu66qk&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDj8EwfA4dVHt3K1awLOsejFkDH_mtwhk80eFgv5ti2EQ&oe=67864A02"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4pyK0AlAeV4Q7kNvgGFyYZJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCor28k8zqgeZJpPxx4MK-tkStJts0R8no-igAH5hboPg&oe=67865662"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=jIrfr45zDoQQ7kNvgERZ5jT&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBejtrnhHf9vu8s1he3ScsIoWawuQE2bhkTdi0qB33quQ&oe=67864B93"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwPFk5p4Dw4Q7kNvgH2IqCE&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=0