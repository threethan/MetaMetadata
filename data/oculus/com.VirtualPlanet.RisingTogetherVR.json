5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=_fs9hkIU_PcQ7kNvgH9RNGN&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBFXpInFngfIJy8Z4lq0pYfgeHzF5jD0adSSvRtDFIUjA&oe=675D887C"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YRdYaKxAaoUQ7kNvgEZBMvc&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBa2-QHvfz27w0G8JfNUsH8kAxDWwboY7OfFJZjKhd_-A&oe=675D5B6F"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4K_sR204i4cQ7kNvgFUWAUb&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBd37VdzfoD5_P-srO9ZZ0CD9-P3pRvuPoFetv0BPqasw&oe=675D7A2E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=acEftlIKEaIQ7kNvgE7oX9U&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCwqE_hacZ41Zet8V8SaZwjhQwprQfdVs4IuZcKY_3GZw&oe=675D6CBA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=FAClWUxUgLsQ7kNvgGXvSlm&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBmRdAf6x968HKnR8q9sE-cRZM7D2b9NuWU9WXjjQD7nw&oe=675D6B82"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mgh9AzDdZJ0Q7kNvgFrXdTV&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYB2h5zLf2MLPLHZ9GUUuAvEJ44D1z4YcpDyfNuNzj6s3w&oe=675D77E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=m_uAuXx6vUUQ7kNvgEmEEnN&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDHReq7Nr-mHPj62mu9mazibSDd7qz-idI6EtfwvuDxhQ&oe=675D6D13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=mCYTn_l-8HcQ7kNvgHFuINK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=0