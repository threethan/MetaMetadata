v/t64.5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZE-TwdyTPwQ7kNvgHmnOBF&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYBmA3TFfVONiSOOj-RMC6MKfmliWLroWSkIGl_PGlgR_g&oe=677E7DFC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-sin2-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PwHmFH0Jg1oQ7kNvgFktXEp&_nc_zt=3&_nc_ht=scontent-sin2-1.oculuscdn.com&oh=00_AYAGlDvFhffRcbuvPggp9K7OTvI01RB9sE6Dujb7n1GtaA&oe=677E50EF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Sv7-1whf64Q7kNvgGFYzVD&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscdn.com&oh=00_AYBkL7_AN7Bqg0LLNZPJxmsV68PlysNJ2v3c-tsXdj8VBg&oe=677E6FAE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sin6-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BJIZBn4km_QQ7kNvgEgDare&_nc_zt=3&_nc_ht=scontent-sin6-1.oculuscdn.com&oh=00_AYDsjh5LGfZpKMaLYa-C_44_fUs66rJMha01dzy5qohB6g&oe=677E623A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=yc-Zdpok9gIQ7kNvgHYFZZ4&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYCyJRTB5KA2NFzrTKpIzJFaJtWzrbmyvPYAUrQP-MwkOg&oe=677E6102"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sin6-4.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=51PS6GVkwDsQ7kNvgH_cpfG&_nc_zt=3&_nc_ht=scontent-sin6-4.oculuscdn.com&oh=00_AYC_xFhygUXe07eRyxbRizZq2fxdPj0s3c-U9hV3B0u1PQ&oe=677E6D62"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sin11-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lL-Sg2oSMbsQ7kNvgEUps44&_nc_zt=3&_nc_ht=scontent-sin11-1.oculuscdn.com&oh=00_AYACkDnDJYyCK7fj4wWNxuOOxe5kSfy03oBXEijFJs1paw&oe=677E6293"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sin6-3.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pcTHxzVl5UcQ7kNvgGq6inK&_nc_zt=3&_nc_ht=scontent-sin6-3.oculuscd