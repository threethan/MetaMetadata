imos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WPxv_REEWhQQ7kNvgFLWh8o&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBbpiQbWsog40QdRhaDwssZzHrNNxcGWbnWx5eEWEMy3Q&oe=676D3EBA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=s__AgRHE2j8Q7kNvgF1YAx8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC3EABBgcHZb-bRxBkJyi9gTE4E4_c1tpGHb8qp2ljOqQ&oe=676D3D82"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HMPprzR03zwQ7kNvgFTZ2PP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCdUM6fUrkvxaACWPa-JBEKFMIPHt4_kcYHycyi49lRvg&oe=676D49E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JT3-OXD9L88Q7kNvgGlyZql&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDNtVigBnXMqyvVQ9aeOod1IyqDOgweQ3Aid9D0n06Czg&oe=676D3F13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Y-CTjmgAlnoQ7kNvgHxZi9L&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=0