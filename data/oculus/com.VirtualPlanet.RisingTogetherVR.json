imos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Nqt85rnoImgQ7kNvgFVhdrX&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYApYNC8ArCl5CzY4TpvCSjrVhDilMCFi2GO6OSKF7Wj3g&oe=67430EBA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ru83Rxs_xlgQ7kNvgEHoO6A&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYASF2zx1flMa5UbeJ-GZZ8aUDDIQ_Ilt3m_Zw0CqonVXQ&oe=67430D82"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Be9dnfPeOyQQ7kNvgGCKbMQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCRzP5BvWnTYk1plz-a_FpsDEKGQie6MQSjfY9h0XkWbQ&oe=674319E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xnjtlfEsLUIQ7kNvgHlPByK&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAU42HSgH5tSqYtgyIWKEvy5TcwhNIJvP8NZAEo2KCwSw&oe=67430F13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=fMSqxjtsGyoQ7kNvgEsOTVU&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=0