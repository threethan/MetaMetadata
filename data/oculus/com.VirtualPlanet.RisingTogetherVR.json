5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Xd6b9uk8ejgQ7kNvgHOg9PX&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBofj7HeIlFiAn5apIyMNWFIXrSlGAEW3Syal9d2JRKMA&oe=6777E67C"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=273RLJysCyEQ7kNvgFWPMUK&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBsmmor7eJy-CRCFw7mLpW93yWkSJydppxBuDa9sACbew&oe=6777B96F"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=03xSF_pjmAEQ7kNvgHy-pqV&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYA10Ue7knwYktuz_UyLFe8adGvqhHO0kT6tHNiyfZ4eaw&oe=6777D82E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=uh6uHmbuBkwQ7kNvgEI4rjC&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYClJpAYNxrMh5LwH8rlaR9mPVPntfe1-AGTZAmB--HojA&oe=6777CABA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HwAPlgGcpQYQ7kNvgGCFt-1&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYCQdnbyKZ_DlXJ6bpsC2b6HQuBmGBQwOtRMUoqrai_nEg&oe=6777C982"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sPZ9yDGGM84Q7kNvgGrlOCz&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYBWUNLKTaCmilNlLpugQcSL_h5z5XnGAMn6RByFbkqumw&oe=6777D5E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=iEmMzez6Qe4Q7kNvgEpKZsq&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=00_AYAFLhmY4TPdfDwb1gbV06iPNDLOAJs8K6WyShhbcjIGCA&oe=6777CB13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-sea1-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4t7rM8sHbrcQ7kNvgEHwEdg&_nc_zt=3&_nc_ht=scontent-sea1-1.oculuscdn.com&oh=0