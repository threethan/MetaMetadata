5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=32njVn5SQ5EQ7kNvgFPxUGy&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDHK6xiBOFbtjrzoRU5sw4-kFGlckux2JJXPRgYSI3AJg&oe=674C64FC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ze5C7Iv2PkQQ7kNvgEGKI10&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClnEpgzwIonP7KrG4xAsFudVx1CmEOQNGRj6WajphuQw&oe=674C37EF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qRTo3YDElDYQ7kNvgF50rL5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBJrKtu8yaBvVQIZ2EsmCFgP8YjftVpBPK2YpyK1JFblw&oe=674C56AE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ejk8EGPRyFYQ7kNvgE99Per&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBm6tGuh5Z-zWWSdYdjdrmTxJfVJDNKT3B1MfON_K2okg&oe=674C493A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=t7nvuv8AtzgQ7kNvgFvD2qC&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDMIRmSWwQxzq3aEwTJKplBjVO1QJhyvrCajxLLsiy-UA&oe=674C4802"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1ZXNhnUkkboQ7kNvgFBxkeb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCLuj_VqJgIR2-dTF7kIh3bjud1iSubu3JmZERmMU31FA&oe=674C5462"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p7pekgqOb7kQ7kNvgFOHRz9&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCodsoffjr8-RgCydWeZhz270mPDT3wFfsfR-3d4X-AbQ&oe=674C4993"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=g0TPvx6HcL8Q7kNvgE9XOPI&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=0