40", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=E_OaEJsg_sYQ7kNvgEegHG3&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYDmXyBjUbfEMFf_Gybsz6goXlPFxmEFGBRpFvMF088S4A&oe=66E43E7C"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JHBhbLF_FU8Q7kNvgHRVVmW&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYAAhOOQirLYL18t3EQVOHKngrbFcv-_kp3uaxUwhRMkdw&oe=66E4116F"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=hjTSF-qV5JMQ7kNvgGEERyC&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYDayiji-Hc2LffZ8YFDAAxvlBfshflSoaBhcXxTXBMUNA&oe=66E4302E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ATj1mgFTt3oQ7kNvgGwhqrF&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYCb8gym1UVPBz6oZL2UzLsc12XTkH9Gey2GKePO4xLLww&oe=66E422BA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=za-cZI8apN8Q7kNvgEUTRGy&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYDSvtJdSYWM_SwdGrs0wjN5ljD_dhI5y5G19i24y1hRxg&oe=66E42182"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xO4pRXbGpBIQ7kNvgHoAJqQ&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYCfuK8VoKO6UsnLew1XNDGyU3gWR1AVCTTtzF2Zy0CZQQ&oe=66E42DE2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=dOcNlfWbMa0Q7kNvgEZGIkf&_nc_ht=scontent.oculuscdn.com&_nc_gid=AbBSndB647t-FKXYGKXtqqK&oh=00_AYD5OvF0h68_VuqAx62anroqQOaTskkTp1w2WwE_b3SY7w&oe=66E42313"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_