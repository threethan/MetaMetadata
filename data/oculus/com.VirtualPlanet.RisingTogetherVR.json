imos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DOAp-e-5CdMQ7kNvgGyfWPN&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBMEw5Kb27C1qnO48qwp4cDuhOi7A2cNGELnov2y6_TmA&oe=673099BA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6TPLibnzYOIQ7kNvgHDXiT1&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCHv4A5fMWy8hmb4T-pZIga5Q9K6-XepGVJrBO3tXYhHw&oe=67309882"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NkX6Z3MtApsQ7kNvgGMzm_A&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBOKYkd7n4rOgaNC8JNQXqIxWVsCJ9khvwZxSpMVQrcQw&oe=6730A4E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=5__C3-DgY3MQ7kNvgF22QBE&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBt65ijxXT1dgIMpx5NmNTnnhxcQzUGb2UihJoG5OYX2Q&oe=67309A13"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=SLEyxhhXIVoQ7kNvgGVHRqK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=0