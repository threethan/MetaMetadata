5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VZE-TwdyTPwQ7kNvgGz1pOM&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBynWWASZe0nzJfET6q6uA9f7-VmHLRBCXlJUgHANh3Fw&oe=677BDAFC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PwHmFH0Jg1oQ7kNvgED7SR9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC7iDcbXInRwKCOqyUAGWx9VNESjFkHf88wp5I8Yw5TIA&oe=677BADEF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=qiDyIks1Ub4Q7kNvgFZraLY&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDQ2uHyPcVDmfKguXhN4ES7zaN-slQI2mbOsk6_6jtntQ&oe=677BCCAE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=P7G-9DaOU7QQ7kNvgHlqfGp&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDGyvnPjT1cV6PxQSbhUof6fiD5zkCPwD2sifpjmf60BA&oe=677BBF3A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VwHMLFidp9MQ7kNvgFs-edX&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDQFl83nwpYNpzqIKc0m-QAh8IkEcAEcna05-Ng0sZoYg&oe=677BBE02"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=e6tbbcRG9cQQ7kNvgFGplIq&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDlnv-_tyP2Vm4q8R8yLPWU2oBnSHHQA9-tLnyYqzKYVA&oe=677BCA62"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=brnEcMUkgToQ7kNvgHqrT-m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYBgiHB64qBgNfxb1Qt66y-YgrxYbMV2FKOrdmdDv6LM-A&oe=677BBF93"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=As-Qt1U6XlcQ7kNvgGhxWHG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=0