5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ksamwMOxNnAQ7kNvgGJ2JaU&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBEzNngr5UUQ-Itaj1N2zHKlCpyFi21Ta4g5yVnpe0R_w&oe=6751AAFC"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-fra5-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rbgh_ecNPLoQ7kNvgFvUQvu&_nc_zt=3&_nc_ht=scontent-fra5-1.oculuscdn.com&oh=00_AYBFmNgHBkafPIvjUKZtaTwKkJuXqYYunapwDFmOd1pyzg&oe=67517DEF"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cwMbB6jIRU4Q7kNvgHOXMeE&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYCJk3BA5B0UG3o6yFiQ4TXA-VRF0AI9Un0lI65pZ0vEyQ&oe=67519CAE"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=zxa2Yw9RX5QQ7kNvgFuIn24&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=00_AYBydo9WvHndvBfutxoWeqiISaIQrVcLWHRY7ctidfK2ow&oe=67518F3A"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ewcbvpsjrBwQ7kNvgG5vdpS&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYC12IwMvea2jY5wraGuJPzYfwoAeyu4BHdHdOlw6KKRpA&oe=67518E02"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-fra3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HZxAUsZQl-EQ7kNvgGCcQ4L&_nc_zt=3&_nc_ht=scontent-fra3-1.oculuscdn.com&oh=00_AYDWaAIYMWeOwdh_v2fpIfn6H_aXNsyTOxHiyWjvcZ3P7A&oe=67519A62"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-fra5-2.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=c4V2suU6lhUQ7kNvgEeNp8r&_nc_zt=3&_nc_ht=scontent-fra5-2.oculuscdn.com&oh=00_AYD77DUCwrumptZG1kya-ADOoyypLo-dz6O1EqJ9NAqI_Q&oe=67518F93"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-fra3-2.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=50JW9vB_f_MQ7kNvgG8e6X5&_nc_zt=3&_nc_ht=scontent-fra3-2.oculuscdn.com&oh=0