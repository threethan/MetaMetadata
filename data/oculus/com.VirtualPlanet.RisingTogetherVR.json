5771-25/39001675_782529333825373_7704828399990427977_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=TxCKoT71ES4Q7kNvgGKzmad&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBhZCXl5J8rPPsZw80_b7U2BH8oHsJZBb7jr0whFAePUw&oe=6720E37C"}, {"file_name": "Screenshots_4.png", "id": "749311890732491", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75234372_749311894065824_382352523439772154_n.png?_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=l7hZJak1xycQ7kNvgEjmkEL&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBLoxjJHFJbHA-Xh6gmRkOg7ZJkYlAk9nC-oE7q-nSQAQ&oe=6720B66F"}, {"file_name": "Screenshots_5.png", "id": "446673594529769", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974577_446673597863102_7902058877799282215_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=vwd9TaHlL8QQ7kNvgEfrwQy&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYClXtEu0HPifgj0sp7FHvMfMP4OeJntNPIlmT3gTl1E9w&oe=6720D52E"}], "video_trailer": null, "video_trailer_thumbnail": null, "display_name": "Creciendo Juntos: Historias de Superaci\u00f3n", "keywords": [], "long_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad.", "short_description": "En esta experiencia, comprender\u00e1 los retos a los que se enfrentan las personas de comunidades vulnerables con escasos recursos econ\u00f3micos que se enfrentan a una crisis tras otra, sin recuperarse nunca del todo antes de que se presente la siguiente. \nExperimente de primera mano los retos clim\u00e1ticos y las estrategias de resiliencia a trav\u00e9s de los ojos de Emma y Gabriel, dos amigos \u00edntimos que viven en distintas partes de la ciudad."}, {"images": {"nodes": [{"file_name": "Icon.png", "id": "1155147425841579", "image_type": "APP_IMG_ICON", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974456_1155147429174912_2962100820539575176_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=InxKoYp3tMgQ7kNvgFbcVWW&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYAxLFHy1glINQN53z8dOXZRUPgP-po9CPkcMTDBB5lBdQ&oe=6720C7BA"}, {"file_name": "CoverImageSafeAreaTemplateLandscape.png", "id": "808231067864832", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031624_808231071198165_6546105332968198643_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=k4KoUaRIzMwQ7kNvgFyp2s8&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDEGEesdgRx2o6h9z0Fthu5Wg53njdr8JsBoU5p7B1l4Q&oe=6720C682"}, {"file_name": "CoverImageSafeAreaTemplateHero.png", "id": "736703691976042", "image_type": "APP_IMG_HERO", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75207241_736703701976041_406472473292592243_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ug7G97y3yDUQ7kNvgEu2DXb&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYAsdbokH33YNe-E0RPlAb41UJ9dhozUQg3sREwFRlZ-kA&oe=6720D2E2"}, {"file_name": "CoverImageSafeAreaTemplatePortrait.png", "id": "475483578148166", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75236137_475483581481499_83115808611481710_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Z9uMJn4xl2UQ7kNvgHp01G4&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBL4ougJPEYfIvihRiHIj24S_jd7Df8ctBXdEAh4DbrVg&oe=6720C813"}, {"file_name": "VRLandscape.png", "id": "458873799834510", "image_type": "APP_IMG_SMALL_LANDSCAPE", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75411993_458873803167843_2581683882877717865_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UcsTTePv_joQ7kNvgEYJPtE&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=0