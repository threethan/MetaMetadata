", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031453_1041083970058897_8001433061460558749_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=sfCq5-xA2d0Q7kNvgFqOOpY&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDbQk33W_lq4ZhK2ATLHz03TM-CpvRsQZA73O-jUagcjQ&oe=67274954"}, {"file_name": "Screengrabs_5.png", "id": "470269494344623", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39031384_470269501011289_7582579877800940198_n.png?_nc_cat=100&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ICT-q0Y5JjUQ7kNvgHGuuOa&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBcoMATINSkSbpBaB-llQwV1RbM1Zt006mj8MUYc2zM-g&oe=672763EB"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "occulus_coverart_placeholder.png", "id": "547061729749417", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75375087_547061736416083_6937420105488662687_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=W3bDK4Ea254Q7kNvgFrsbgk&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBhXmpNl6MXmfDMmc-8X4gsqdvmz3pImxvMmE-G-18Q_w&oe=67275B26"}, "display_name": "Curatours", "keywords": [], "long_description": "Museum of Plastic 2121 is the first museum tour available on Curatours!\n\nBuilt 100 years from now in an imagined future where things have worked out well for both the planet and humanity. Visitors can uncover the story of plastic - its history, science, industry, and impact on our environment. They will learn the importance of establishing a circular economy and find out how activism and individual action happening now will lead to positive change in the future. \n\nEvery Thursday in November 2021 we will be opening a new wing of the Museum of Plastic. \n\nCuratours is a social virtual tour platform for culture and heritage. Visit incredible places filled with art, artefacts, stories and friends. Visitors can access tours of museums around the world from desktop, phones or VR headsets. In VR it's an incredibly immersive experience and on other devices it feels like a cross between a video call and playing a multiplayer game.", "short_description": "Museum of Plastic 2121 is the first museum tour available on Curatours! Built 100 years from now in an imagined future where things have worked out well for both the planet and humanity. Visitors can uncover the story of plastic - its history, science, industry, and impact on our environment. They will learn the importance of establishing a circular economy and find out how activism and individual action happening now will lead to positive change in the future. \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.coopinnovations.co.uk/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": "https://cura.tours/support/", "website_url": "https://cura.tours/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "314530610625542"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/57572941_4514988158519614_513828567661581694_n.png?stp=dst-png_s360x360&_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ritFrPAZrcAQ7kNvgGTvn5f&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYDmS4sLa1_H03JjebFhaoi1DUvpgZO2Cr2jZYXIpZix9w&oe=67274838"}, "is_concep