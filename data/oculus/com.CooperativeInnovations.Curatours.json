71-25/75348045_3058377077821824_606644335952339901_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HYOrm8-f7SEQ7kNvgE9GnPK&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD8b4nTTJYCIEjLAZXFK3TVvjuPOAcoauB_u0ppotWwAw&oe=6756BE91"}, {"file_name": "Screengrabs_2.png", "id": "861756404772390", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/57572923_861756408105723_8470923836315507856_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8brQ8THxaJYQ7kNvgFIq-wU&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAJWNc6KplYIGlu52D57U7RrjJm4AK3filpB5Ur7mqifA&oe=6756CDA4"}, {"file_name": "Screengrabs_3.png", "id": "341601274328513", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/39036632_341601277661846_5428982906936699612_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Gtzih_YngcYQ7kNvgHoT29m&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCZsjbsp5XzVnzq39IdfQvbi9IPFwzAjZZbgDBHowzONA&oe=6756BE2F"}, {"file_name": "Screengrabs_4.png", "id": "507102677251409", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75395590_507102680584742_7420227356861752672_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=v-qxEASmyWQQ7kNvgGplvzt&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYCNyIx9fU0DVlSxk2s9pMO-mqjFm4hocSOVLta8JxLR2w&oe=6756F562"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "occulus_coverart_placeholder.png", "id": "547061729749417", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75375087_547061736416083_6937420105488662687_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=pn0LGUlk8jcQ7kNvgGdTDa4&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYBNQuIiZGqBg2MwcVcRhJIfnMyHbK-XQCLsk87BUchg6g&oe=6756D126"}, "display_name": "Curatours", "keywords": [], "long_description": "Visitors can access tours of museums around the world from their desktops, phones or VR headsets. In VR it's an incredibly immersive experience and on other devices it's a bit like a cross between a Zoom Call and playing a game. \n\nYou can choose from three types of tour:\n \nSelf-guided tours can happen at anytime, just login and go exploring!\n \nPre-recorded tours are similar to a self-guided tour only at points a guide will appear to tell you something about that place or the artefact you\u2019re near. It\u2019s a bit like a 3D audio guide.\n \nLive-guided tours put you in a museum or gallery with an expert so you can talk to them and ask questions. To get a live-guided tour you will need to book on to one of the timeslots available. ", "short_description": "Visit art exhibitions and museums with friends and family. Everyone can explore and experience the tours using a either a PC, tablet, smartphone or virtual reality headset."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.coopinnovations.co.uk/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": null, "website_url": "https://cura.tours/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "438375174647419"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "899004787695333"}]}, "baseline_offer": {"id": "899004787695333"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636362000, "status": "PUBLISHED", "