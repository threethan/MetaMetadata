E"}, {"file_name": "CuratoursHero.png", "id": "562152335151429", "image_type": "APP_IMG_HERO", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/38974504_562152338484762_830536931451838944_n.png?_nc_cat=101&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=X76ZUbJj14kQ7kNvgFsSrNk&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBDPsYH5z3HgcUX4at5dCKU77SIVw-Ab_qTVxzcXkqFrQ&oe=67123F37"}, {"file_name": "CuratoursPortrait.png", "id": "454914215471041", "image_type": "APP_IMG_COVER_PORTRAIT", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/75422395_454914218804374_7293411826951448827_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=PYO8Nxc1OcgQ7kNvgH_Vkkr&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYAv4VOWX8zhdoFMwwe2DCgSrnA_dvM0-l1P6Qq3gAtIHA&oe=67126579"}, {"file_name": "logo-trans.png", "id": "237433071719456", "image_type": "APP_IMG_LOGO_TRANSPARENT", "uri": "https://scontent-lhr6-1.oculuscdn.com/v/t64.5771-25/38974883_237433075052789_4423484037734055115_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=DlvG68bnW5wQ7kNvgHabMaj&_nc_ht=scontent-lhr6-1.oculuscdn.com&oh=00_AYApbIqbxuu6fZin-dVYkvju96jrysiLDu7LADLzuXZ1Ow&oe=67125F38"}]}, "id": "564328565009525", "locale": "en_US", "screenshots": [{"file_name": "Screengrabs_5.png", "id": "380192943730477", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/86631741_380192947063810_2218913260223384092_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gekxMZSr_yMQ7kNvgGtdpEk&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDeUBwV6VtA1wVgvh7zj9Cb80QWREuBFi-nzhg2hF7Ndg&oe=6712501B"}, {"file_name": "screengrab_1.png", "id": "3058377071155158", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75348045_3058377077821824_606644335952339901_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bqMvz0ZKa5kQ7kNvgF6KySU&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYDRqzUK_lAhLsPyrPrYMxxajoMnXikptY1PQULZ-idlnQ&oe=67123091"}, {"file_name": "Screengrabs_2.png", "id": "861756404772390", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/57572923_861756408105723_8470923836315507856_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rnqwcgAUr4gQ7kNvgHaDRrk&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYCiteizL3mEx3dqpNPLkI8oigjJDx1BiMYHX0oNlTBt6Q&oe=67123FA4"}, {"file_name": "Screengrabs_3.png", "id": "341601274328513", "uri": "https://scontent-lhr8-2.oculuscdn.com/v/t64.5771-25/39036632_341601277661846_5428982906936699612_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=p8HdlpB1tfAQ7kNvgFsAKJx&_nc_ht=scontent-lhr8-2.oculuscdn.com&oh=00_AYBwaYB_2wfP-dEPWEiXp1avycKkFbsKsfL-aF65f9l9OQ&oe=6712302F"}, {"file_name": "Screengrabs_4.png", "id": "507102677251409", "uri": "https://scontent-lhr8-1.oculuscdn.com/v/t64.5771-25/75395590_507102680584742_7420227356861752672_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=WPhDl3jHfNwQ7kNvgHHdcYi&_nc_ht=scontent-lhr8-1.oculuscdn.com&oh=00_AYBjEzx9eijaiAGsH5qy74K7s8QADtfhabrJa2Ot39_Fjw&oe=67122F22"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "occulus_coverart_placeholder.png", "id": "547061729749417", "uri": "https://scontent-lhr6-2.oculuscdn.com/v/t64.5771-25/75375087_547061736416083_6937420105488662687_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VpJY2WZhvAQQ7kNvgHypB_5&_nc_ht=scontent-lhr6-2.oculuscdn.com&oh=00_AYDjZviz7WzLUGz5kpP-DbyLqD0qQB2tS_Zwo3iZA3NpfA&oe=67124326"}, "display_name": "Curatours", "keywords": [], "long_description": "Visitors can access tours of museums around the world from their desktops, phones or VR headsets. In VR it's an incredibly immersive experience and on other devices it's a bit like a cross between a Zoom Call and playing a game. \n\nYou can choose from three types of tour:\n \nSelf-guided tours can happen at anytime, just login and go exploring!\n \nPre-recorded tours are similar to a self-guided tour only at points a guide will appear to tell you something about that place or the artefact you\u2019re near. It\u2019s a bit like a 3D audio guide.\n \nLive-guided tours put you in a museum or gallery with an expert so you can talk to them and ask questions. To get a live-guided tour you will need to book on to one of the timeslots available. ", "short_description": "Visit art exhibitions and museums with friends and family. Everyone can explore and experience the tours using a either a PC, tablet, smartphone or virtual reality headset."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.coopinnovations.co.uk/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": null, "website_url": "https://cura.tours/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "438375174647419"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "899004787695333"}]}, "baseline_offer": {"id": "899004787695333"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636362000, "status": "PUBLISHED", "id": "899004787695333"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "6100210936715035", "version": "1.1.7390"}, "id": "521612405568387", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application":