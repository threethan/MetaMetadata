 game. \n\nYou can choose from three types of tour:\n \nSelf-guided tours can happen at anytime, just login and go exploring!\n \nPre-recorded tours are similar to a self-guided tour only at points a guide will appear to tell you something about that place or the artefact you\u2019re near. It\u2019s a bit like a 3D audio guide.\n \nLive-guided tours put you in a museum or gallery with an expert so you can talk to them and ask questions. To get a live-guided tour you will need to book on to one of the timeslots available. ", "short_description": "Visit art exhibitions and museums with friends and family. Everyone can explore and experience the tours using a either a PC, tablet, smartphone or virtual reality headset."}]}, "developer_name": null, "developer_privacy_policy_url": "https://www.coopinnovations.co.uk/privacy/", "developer_terms_of_service_url": null, "publisher_name": "Cooperative Innovations", "support_website_url": null, "website_url": "https://cura.tours/", "category": "APPS", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "362692211442873", "context_category": "APPS"}, "context_topics": [{"id": "726368587961803"}], "external_subscription_type": "REQUIRED_FOR_SOME_CONTENT", "genres": ["DOCUMENTARY_HISTORY", "EDUCATIONAL", "ART_CREATIVITY"], "has_in_app_ads": false, "internet_connection": "REQUIRED_FOR_DOWNLOAD", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER", "MULTI_USER"], "id": "438375174647419"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "899004787695333"}]}, "baseline_offer": {"id": "899004787695333"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1636362000, "status": "PUBLISHED", "