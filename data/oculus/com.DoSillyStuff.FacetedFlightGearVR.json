inate the leaderboards and show the world just how skilled you are.\n\nIt's time to fly!", "short_description": ""}]}, "developer_name": null, "developer_privacy_policy_url": null, "developer_terms_of_service_url": null, "publisher_name": "The Department of Silly Stuff, LLC", "support_website_url": null, "website_url": "http://www.facetedflight.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": null, "genres": ["ARCADE", "RACING"], "has_in_app_ads": false, "internet_connection": null, "play_area": null, "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": [], "supported_input_devices": ["TOUCHPAD"], "supported_player_modes": [], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "1291854894651010"}}]}, "scheduled_offers": {"count": 8, "nodes": [{"status": "PUBLISHED", "id": "152511135512961"}, {"status": "PUBLISHED", "id": "1173859989352037"}, {"status": "PUBLISHED", "id": "1706711366228416"}, {"status": "PUBLISHED", "id": "1735504226480708"}, {"status": "PUBLISHED", "id": "170482547022756"}, {"status": "PUBLISHED", "id": "274147754040440"}, {"status": "PUBLISHED", "id": "233664330405632"}, {"status": "PUBLISHED", "id": "1650693774959566"}]}, "baseline_offer": {"id": "274147754040440"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1513274400, "status": "PUBLISHED", "id": "152511135512961"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "811296868993462", "version": "1.20"}, "id": "899863153395899", "channel_name": "LIVE"}]}, "is_for_oculus_keys_only": false, "primary_binaries": {"nodes": [{"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "1219562808069896", "is_concept": false, "la