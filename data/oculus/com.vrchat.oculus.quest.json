27_966687911214713_6864761240170562917_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=QPcu4FG-9_4Q7kNvgE2h3Ft&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiC6eLnNg2D1GNc8lKGXFq0&oh=00_AYC7rx8_1Vz5t9GJZcoggED-W_nbZsz9QicFHnwZZAm7hw&oe=66F53D09"}, {"file_name": "PlayStore_Shoot_PuttPutt_FINAL.png", "id": "657201409796047", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39001665_657201413129380_848256794196336036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1WKq9kG2CvkQ7kNvgHllTyi&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiC6eLnNg2D1GNc8lKGXFq0&oh=00_AYAQ5nYSa6tZduu90WskV0donJRtgLRJOUL7OKbZPpS-CQ&oe=66F54C18"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_300DPI_VRC_Landscape_FingerTracking.png", "id": "1136410263649539", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/75195911_1136410266982872_7400914850211442315_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=bmB-NacMHgoQ7kNvgE1H2GL&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiC6eLnNg2D1GNc8lKGXFq0&oh=00_AYBgv1yUYlqeZlJNWrHEEFA5lOZew8aqK-3g0xdsO9y7-w&oe=66F55D15"}, "display_name": "VRChat", "keywords": ["social", "roleplaying", "adventure", "casual", "Funny"], "long_description": "Imagine a space filled with limitless possibilities. \n\nSpend your afternoon dogfighting in fighter jets, before winding down in a treehouse that exists floating in a nebula. Make a new best friend while exploring a haunted mansion, right before playing a hand of cards with a robot, alien, and eight-foot tall wolf.\n\nIn VRChat, there are hundreds of thousands of worlds, millions of avatars \u2013 all created by the users. No matter what you\u2019re into, there\u2019s a space in VRChat for you. And if there isn\u2019t, we\u2019ll give you the tools to make your dream a reality.\n\nVRChat was built to take advantage of VR headsets in many unique ways. That means avatars that flow with your movement, and systems that work alongside various hardware platforms to provide full-body tracking, finger tracking, and much, much more.\n\nThere\u2019s something magical around every corner. Come take a look, and see what you find.", "short_description": "Make Friends and Explore an Endless Stream of Community Made Worlds and Avatars"}]}, "developer_name": "VRChat Inc.", "developer_privacy_policy_url": "https://vrchat.com/privacy", "developer_terms_of_service_url": "https://vrchat.com/legal", "publisher_name": "VRChat Inc.", "support_website_url": "https://help.vrchat.com/", "website_url": "https://vrchat.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EXPLORATION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr_BE", "fr_CA", "fr", "zh_CN", "zh_HK", "zh_TW", "de", "de_CH", "it", "ja", "pl", "pt_BR", "ru", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "205601085811637"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38982486_676255960502704_678825458453538366_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=V8pkIF3t1PgQ7kNvgF2nD6b&_nc_ht=scontent.oculuscdn.com&_nc_gid=AiC6eLnNg2D1GNc8lKGXFq0&oh=00_AYAGA_bqSyCxJ08ln9jrX4kfRPlHG_rbDgxkwzW8FPyqAA&oe=66F55FB2"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRChat", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "274332603592553