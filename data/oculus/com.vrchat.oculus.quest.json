.", "short_description": "Make Friends and Explore an Endless Stream of Community Made Worlds and Avatars"}]}, "developer_name": "VRChat Inc.", "developer_privacy_policy_url": "https://vrchat.com/privacy", "developer_terms_of_service_url": "https://vrchat.com/legal", "publisher_name": "VRChat Inc.", "support_website_url": "https://help.vrchat.com/", "website_url": "https://vrchat.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_FEW", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1573854509480616"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["ART_CREATIVITY", "EXPLORATION", "SOCIAL"], "has_in_app_ads": false, "internet_connection": "REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "fr_BE", "fr_CA", "fr", "zh_CN", "zh_HK", "zh_TW", "de", "de_CH", "it", "ja", "pl", "pt_BR", "ru", "es_AR", "es_CL", "es_CO", "es_MX", "es_PE", "es_PR", "es", "es_VE"], "supported_input_devices": ["OCULUS_TOUCH", "HAND_TRACKING", "GAMEPAD"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["MULTI_USER"], "id": "205601085811637"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982486_676255960502704_678825458453538366_n.png?stp=dst-png_s360x360&_nc_cat=1&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Zi9ND8rKMO0Q7kNvgE1Gw5x&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBdXTvALya7YFsA1RkLBm21N0uHQ0gzVuHEpvno2_HSJg&oe=6718F832"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "VRChat", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "2743326035925534"}, "context_topics": [{"topic_name": "Social", "id": "1573854509480616"}], "release_date": 1558458300, "lastRevision": {"n