_ohc=I_Gk_1qv_fgQ7kNvgHs3zB1&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYA9HgHQ09nksjVYLyGAtddA_5REdB3hDbWCAIljGVxLCQ&oe=673B1C89"}, {"file_name": "PlayStore_Shoot_PuttPutt_FINAL.png", "id": "657201409796047", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/39001665_657201413129380_848256794196336036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ESnR8jygMKwQ7kNvgE341Y3&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBUThlA7vbGb3Ekd6mo1Elyr4NHa8c5QmIbYtGOplMG5A&oe=673B2B98"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_300DPI_VRC_Landscape_FingerTracking.png", "id": "1136410263649539", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75195911_1136410266982872_7400914850211442315_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=G3CiMYZaPpAQ7kNvgEA8Olh&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBd2fBfa7CeNV7iFhqE1l-lT_nCGxAcxJvplLDfSIe2Hw&oe=673B3C95"}, "display_name": "VRChat", "keywords": ["social", "roleplaying", "adventure", "casual", "Funny"], "long_description": "Imagine a space filled with limitless possibilities. \n\nSpend your afternoon dogfighting in fighter jets, before winding down in a treehouse that exists floating in a nebula. Make a new best friend while exploring a haunted mansion, right before playing a hand of cards with a robot, alien, and eight-foot tall wolf.\n\nIn VRChat, there are hundreds of thousands of worlds, millions of avatars \u2013 all created by the users. No matter what you\u2019re into, there\u2019s a space in VRChat for you. And if there isn\u2019t, we\u2019ll give you the tools to make your dream a reality.\n\nVRChat was built to take advantage of VR headsets in many unique ways. That means avatars that flow with your movement, and systems that work alongside various hardware platforms to provide full-body tracking, finger tracking, and much, much more.\n\nThere\u2019s something magical around every corner. Come take a look, and see what you find."