_ohc=1rttZDN_TvcQ7kNvgEncKHK&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYC2GoTEAcPIBmYRBj8uyojuSjUnnJop2BCZePpEHy98IQ&oe=67406289"}, {"file_name": "PlayStore_Shoot_PuttPutt_FINAL.png", "id": "657201409796047", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39001665_657201413129380_848256794196336036_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=YPF0wY1JRS4Q7kNvgHP0pCx&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD0E5YZW8-8zHjTbur1cITgk1SHj5k04K38zWMW7xe21w&oe=67407198"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "CoverImage_300DPI_VRC_Landscape_FingerTracking.png", "id": "1136410263649539", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/75195911_1136410266982872_7400914850211442315_n.png?_nc_cat=103&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=gI33X-DuXV4Q7kNvgEksFjJ&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYCAvpGHa38AXRtwbH2rlr8PQIOc4-6915eY5oo7BpJxvw&oe=67408295"}, "display_name": "VRChat", "keywords": ["social", "roleplaying", "adventure", "casual", "Funny"], "long_description": "Imagine a space filled with limitless possibilities. \n\nSpend your afternoon dogfighting in fighter jets, before winding down in a treehouse that exists floating in a nebula. Make a new best friend while exploring a haunted mansion, right before playing a hand of cards with a robot, alien, and eight-foot tall wolf.\n\nIn VRChat, there are hundreds of thousands of worlds, millions of avatars \u2013 all created by the users. No matter what you\u2019re into, there\u2019s a space in VRChat for you. And if there isn\u2019t, we\u2019ll give you the tools to make your dream a reality.\n\nVRChat was built to take advantage of VR headsets in many unique ways. That means avatars that flow with your movement, and systems that work alongside various hardware platforms to provide full-body tracking, finger tracking, and much, much more.\n\nThere\u2019s something magical around every corner. Come take a look, and see what you find."