}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1314154942779374"}]}, "change_log": "-Fixed issue where certain symbols were not included for korean and japanese fonts\n-Fixed issue where main menu UI could overlap buttons in certain languages.", "created_date": 1728461839, "id": "8514208535335146", "version": "1.0.1.1351", "version_code": 1351, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6146292702126753", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8514208535335146"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728374178, "id": "8505438432878823", "version": "1.0.1.1350", "version_code": 1350, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6146292702126753", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8514208535335146"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1728312933, "id": "8498385486917451", "version": "1.0.1.1349", "version_code": 1349, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6146292702126753", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8514208535335146"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": [{"channel_name": "LIVE", "id": "1314154942779374"}]}, "change_log": "Features\n-Added hands for Molly when in first person\n\nGameplay\n-Added tutorial instruction for exiting first person in pipe puzzle\n-Added auto exit first person on pipe puzzle completion\n-Added so that lightbulbs dance if diamond mine is complete\n-Added shimmer effect to cult buttons\n-Added cog visual variants to Twilight Acres\n-Tweaked quest text for readability in storage room\n-Tweaked ladder starting position in storage room\n\nBugs\n-Tweaked uv to prevent light spilling in the ending door lightbeam\n-Tweaked ladder snapping threshold in storage room\n-Tweaked mipmap bias in character shader for shaper resolution of texture\n-Tweaked popup point position in machine room 5 for Willpower Plant.\n-Fixed dodo face getting stuck on angry during conversion with Mr.Mole\n-Fixed issue where menu page would not reset when returning to title screen\n-Fixed banter setup in the queens tent. The queen will no longer respond to your interactions once she has left.\n-Fixed issue where player could interrupt machine room cutscene by interacting with other objects in the room\n-Fixed SFX setup in machine room\n-Fixed Twilight Acres interaction button remaining even if interaction was finished.\n-Fixed issue where hand poses on the mirrors in mirror mire would be incorrect.\n-Fixed issue where player could lock themselves if trying to leave stove top room with Dodo and Molly simultaneously\n-Fixed issue where Cheshire Cat smoke VFX would play twice consecutively \n-Fixed null ref issue when using elevator but not reloading scene\n", "created_date": 1726666172, "id": "8320791694676832", "version": "1.0.1.1347", "version_code": 1347, "release_status": "RELEASED", "status": "APPROVED", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}, {"__typename": "AndroidBinary", "__isAppBinary": "AndroidBinary", "binary_application": {"__typename": "Application", "id": "6146292702126753", "is_concept": false, "latest_released_binary": {"__typename": "AndroidBinary", "id": "8514208535335146"}, "release_status": "RELEASED"}, "binary_release_channels": {"nodes": []}, "change_log": null, "created_date": 1725539442, "id": "8222081737881162", "version": "1.0.1.1346", "version_code": 1346, "release_status": "PENDING", "status": "DRAFT", "binary_test_results": {"nodes": []}, "obb_binary": null, "asset_files": {"count": 0}, "debug_symbols": {"count": 0}, "__isAppBinaryWithFileAsset": "AndroidBinary"}]}}, "viewer": {"user": null}}}