ence, woven into a sci-fi tapestry set in a distant galaxy, brimming with formidable adversaries", "short_description": "Embark on an intergalactic journey, controlling your ship to hurl balls to shatter cubes, and combat enemy droids en route to vanquishing Krugg! Rebeloid is revolutionizing the classic block breaker gaming experience by taking you to space with the power of VR technology. You have been warned, this is going to be a very bumpy ride! \n"}]}, "developer_name": null, "developer_privacy_policy_url": "https://rebeloidvr.com/privacy.html", "developer_terms_of_service_url": null, "publisher_name": "Beren Studio", "support_website_url": "https://rebeloidvr.com/", "website_url": "https://rebeloidvr.com/", "category": null, "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "1592192974313489"}, {"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "25874234422163909"}}]}, "scheduled_offers": {"count": 3, "nodes": [{"status": "PENDING", "id": "1095952841938311"}, {"status": "PUBLISHED", "id": "775740544742982"}, {"status": "PUBLISHED", "id": "432426205908092"}]}, "baseline_offer": {"id": "775740544742982"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 0, "status": "PENDING", "id": "1095952841938311"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "25946590751594942", "version": "1.4"}, "id": 