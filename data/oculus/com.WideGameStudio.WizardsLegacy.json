=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCuz-J2ZenNewBDwiTq_NzQUbaHsGij0mYBmQlGP4Qz-A&oe=676AA1C3"}, {"file_name": "Untitled-6.png", "id": "838588491102212", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031309_838588494435545_3221430962329902390_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=euCJVS64S64Q7kNvgGGLhOP&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDeuAbvmIlrwQbbTIiHqqVKcPVnvcYnHTkd5Uj3GGPVUA&oe=676AA392"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SMALL.CAPSULE.VARIANT.png", "id": "1942826292828817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974439_1942826296162150_5288366189613001907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=xzSlHYJITjUQ7kNvgFjHH2n&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYC2Xa8Cb1IsteO_AUjNWvUB6fnPh1Qwz0bdrogaDafilg&oe=676AAB69"}, "display_name": "Wizard's Legacy", "keywords": ["wizard", "magic", "roguelike", "melee", "combat"], "long_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be.\n\n{3648923568693208}\nA desperate father, bound by a dark pact, transforms into a wizard trapped within a cursed labyrinth. Each victory grants power, but death returns him to the start. Explore the labyrinth's ever-changing depths, where every battle unveils its grim history. Can you master magic, overcome enemies, and save your child?\n\n{362183290313011}\n\n{459743683357113}\nDive deeper, shaping the world with every decision. Explore branching paths, unearth secrets, and face escalating challenges. Collect potions and power-ups scattered throughout to enhance your magic and forge your destiny as a powerful wizard.\n\n{828863472676196}\nUnleash your inner wizard! Draw symbols to control fireballs, ice walls, and lightning. Feel the power surge as you master arcane combat.\n\n{1407283433268429}\n\n{1453454962100883}\nChoose from a variety of playable characters, each with unique spells and abilities. Experiment with different playstyles \u2013 fiery mage, cunning illusionist, or something else entirely?\n\n{1136617717392676}\nThe labyrinth teems with cunning foes, each demanding a unique strategy. Test your skills against a diverse array of enemies, adapting tactics to exploit weaknesses and emerge victorious.\n\n{788110426812574}\n\n{1584321828806767}\nImmerse yourself in stunning visuals. Explore dynamic dungeons, lush forests, and ominous landscapes, each meticulously detailed for an unforgettable VR experience.\n\n\n{1415112652482029}\n\n", "short_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wizardslegacy.widegamestudio.com/privacy.html", "developer_terms_of_service_url": "https://wizardslegacy.widegamestudio.com/terms.html", "publisher_name": "Wide Game Studio", "support_website_url": null, "website_url": "https://wizardslegacy.widegamestudio.com/index.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE