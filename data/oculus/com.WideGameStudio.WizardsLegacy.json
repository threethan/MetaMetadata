aEvTtXO24kgJxeNwsuQLbGyiAvw&oe=672762BC"}, {"file_name": "Untitled-7.png", "id": "379966851375388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982555_379966854708721_6237733781365760945_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M0cZW51L5KMQ7kNvgG81_lJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCQbAPICJzdjhuBYD8ktjOPMNER7OWBddZGmW3w2xTdNw&oe=67275457"}, {"file_name": "Untitled-3.png", "id": "1457878311765107", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75647714_1457878321765106_873955209399552846_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=rWd1scmST8UQ7kNvgF_e4YN&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBn2SVplq6s6ICjsHa_DoRDSZiB31G7tKfmgtqEP_e48Q&oe=67274786"}, {"file_name": "Untitled-2.png", "id": "853176473329833", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196224_853176476663166_2779387245026015972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1RQ64T3V178Q7kNvgE_uugQ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDeJwXH6hfcg4i2kB4y0mex8UCkf1dBwi0L72qrCO5SLQ&oe=67276543"}, {"file_name": "Untitled-6.png", "id": "838588491102212", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031309_838588494435545_3221430962329902390_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=7Rqkc744l8AQ7kNvgE1tH9z&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCeCYcqpd_ruSfp248ciaIxG3XNflLAyXgxxcbwZKlHbA&oe=67276712"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "WIZARD.S.LEGACY.COVER.24.BIT (1).png", "id": "794564832812199", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/65228545_794564836145532_348548685399172447_n.png?_nc_cat=107&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lNi1i70bHCoQ7kNvgG0UB45&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD1SiJ8-oG84j9t6-506KWsKwJ8h9igR17gnlLLZVKEew&oe=672757A2"}, "display_name": "Wizard's Legacy", "keywords": [], "long_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be.\n\n{3648923568693208}\nA desperate father, bound by a dark pact, transforms into a wizard trapped within a cursed labyrinth. Each victory grants power, but death returns him to the start. Explore the labyrinth's ever-changing depths, where every battle unveils its grim history. Can you master magic, overcome enemies, and save your child?\n\n{362183290313011}\n\n{459743683357113}\nDive deeper, shaping the world with every decision. Explore branching paths, unearth secrets, and face escalating challenges. Collect potions and power-ups scattered throughout to enhance your magic and forge your destiny as a powerful wizard.\n\n{828863472676196}\nUnleash your inner wizard! Draw symbols to control fireballs, ice walls, and lightning. Feel the power surge as you master arcane combat.\n\n{1407283433268429}\n\n{1453454962100883}\nChoose from a variety of playable characters, each with unique spells and abilities. Experiment with different playstyles \u2013 fiery mage, cunning illusionist, or something else entirely?\n\n{1136617717392676}\nThe labyrinth teems with cunning foes, each demanding a unique strategy. Test your skills against a diverse array of enemies, adapting tactics to exploit weaknesses and emerge victorious.\n\n{788110426812574}\n\n{1584321828806767}\nImmerse yourself in stunning visuals. Explore dynamic dungeons, lush forests, and ominous landscapes, each meticulously detailed for an unforgettable VR experience.\n\n\n{1415112652482029}\n\n", "short_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be."}]}, "developer_name": null, "developer_privacy_policy_url": 