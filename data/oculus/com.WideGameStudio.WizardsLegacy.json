ABC8"}, {"file_name": "COVER ART (1).png", "id": "238021306041044", "image_type": "APP_IMG_COVER_LANDSCAPE", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/75254869_238021309374377_3088549895855860287_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ffzhTOJRFpQQ7kNvgHTVoKN&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYCQjh5eZMJOZ2Bex-IOFvfqer8tAYzGdlwjk4TrScKtbQ&oe=6766A5B6"}]}, "id": "532695239119928", "locale": "en_US", "screenshots": [{"file_name": "Untitled-1.png", "id": "519462800645328", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974652_519462803978661_5861237216833818903_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=NKi-zqmjZ2EQ7kNvgFYnQaZ&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYB8OrrbiWMwsZkNRVv7NM3OH2FVlGoQ4CkCfMgQ-anT_A&oe=6766AABC"}, {"file_name": "Untitled-7.png", "id": "379966851375388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982555_379966854708721_6237733781365760945_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=ZSl8mskNFyoQ7kNvgHDhdR5&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCFqkzdD2ZwgUg1XXbbvkRZYNnqFfwRXUic9cpympuq9g&oe=67669C57"}, {"file_name": "Untitled-3.png", "id": "1457878311765107", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75647714_1457878321765106_873955209399552846_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=4phCUNa911oQ7kNvgGtXyCj&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYA1SZemx1JtXQERan11pzDbjeo0AHFHkgOOYjy2A0KgAA&oe=67668F86"}, {"file_name": "Untitled-2.png", "id": "853176473329833", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196224_853176476663166_2779387245026015972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=41Vt-qXGQQwQ7kNvgEtAaUd&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBCslzwJMXhzpmrZYjO26jMI5XgVYZxG7dW_3utRJKvHg&oe=6766AD43"}, {"file_name": "Untitled-6.png", "id": "838588491102212", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031309_838588494435545_3221430962329902390_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=M2ITGI0pT-0Q7kNvgG9ssqJ&_nc_zt=3&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYDZBT0CJsN-iBWKT3cgvO-UGvMLzMjtHSmKLrfkXDhNNQ&oe=6766AF12"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SMALL.CAPSULE.VARIANT.png", "id": "1942826292828817", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974439_1942826296162150_5288366189613001907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=MV1V1pSbalwQ7kNvgFLSw5g&_nc_zt=3&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD9wS3Rj7gSwLvYw8KuEYqHUpbBMNYbcP7tLapiBBxRbA&oe=6766B6E9"}, "display_name": "Wizard's Legacy", "keywords": ["wizard", "magic", "roguelike", "melee", "combat"], "long_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be.\n\n{3648923568693208}\nA desperate father, bound by a dark pact, transforms into a wizard trapped within a cursed labyrinth. Each victory grants power, but death returns him to the start. Explore the labyrinth's ever-changing depths, where every battle unveils its grim history. Can you master magic, overcome enemies, and save your child?\n\n{362183290313011}\n\n{459743683357113}\nDive deeper, shaping the world with every decision. Explore branching paths, unearth secrets, and face escalating challenges. Collect potions and power-ups scattered throughout to enhance your magic and forge your destiny as a powerful wizard.\n\n{828863472676196}\nUnleash your inner wizard! Draw symbols to control fireballs, ice walls, and lightning. Feel the power surge as you master arcane combat.\n\n{1407283433268429}\n\n{1453454962100883}\nChoose from a variety of playable characters, each with unique spells and abilities. Experiment with different playstyles \u2013 fiery mage, cunning illusionist, or something else entirely?\n\n{1136617717392676}\nThe labyrinth teems with cunning foes, each demanding a unique strategy. Test your skills against a diverse array of enemies, adapting tactics to exploit weaknesses and emerge victorious.\n\n{788110426812574}\n\n{1584321828806767}\nImmerse yourself in stunning visuals. Explore dynamic dungeons, lush forests, and ominous landscapes, each meticulously detailed for an unforgettable VR experience.\n\n\n{1415112652482029}\n\n", "short_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wizardslegacy.widegamestudio.com/privacy.html", "developer_terms_of_service_url": "https://wizardslegacy.widegamestudio.com/terms.html", "publisher_name": "Wide Game Studio", "support_website_url": null, "website_url": "https://wizardslegacy.widegamestudio.com/index.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7979045852208466"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86655528_414792768082741_2904469078414870906_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6