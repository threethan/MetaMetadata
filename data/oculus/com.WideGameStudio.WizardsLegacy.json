luscdn.com/v/t64.5771-25/75254869_238021309374377_3088549895855860287_n.png?_nc_cat=111&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=UHLbOGEHpiEQ7kNvgFh0XDq&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYD-VI0oLL8fKVwDNJG42W9Ji8sEJdTF5Eybe1hmlF5c7g&oe=670E5136"}]}, "id": "532695239119928", "locale": "en_US", "screenshots": [{"file_name": "Untitled-1.png", "id": "519462800645328", "uri": "https://scontent-iad3-2.oculuscdn.com/v/t64.5771-25/38974652_519462803978661_5861237216833818903_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=39DqT7mbOnoQ7kNvgHbDIUo&_nc_ht=scontent-iad3-2.oculuscdn.com&oh=00_AYBwXXvCioOTAbRasgrh3BjpwCf6BgWQxXvaYVgfyl497w&oe=670E563C"}, {"file_name": "Untitled-7.png", "id": "379966851375388", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38982555_379966854708721_6237733781365760945_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=LI8iSxvaIRMQ7kNvgGd1oD-&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBWbmxosQLDZ1H2YrB3Tho9YBfe6_NxoXbmKxneTO7C3Q&oe=670E47D7"}, {"file_name": "Untitled-3.png", "id": "1457878311765107", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75647714_1457878321765106_873955209399552846_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=EgYq3jrWluAQ7kNvgHrHQDN&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCBOyPIByphftKB8U34g-LR-aaIFPsS5Z-QNUUr6hKcyQ&oe=670E3B06"}, {"file_name": "Untitled-2.png", "id": "853176473329833", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/75196224_853176476663166_2779387245026015972_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=HKDGNMh8VboQ7kNvgHgfO5y&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBZyCKO01Vm1RspTR0QrkTCD16RWtFW-2hzfOXqqsBh6g&oe=670E58C3"}, {"file_name": "Untitled-6.png", "id": "838588491102212", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/39031309_838588494435545_3221430962329902390_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=BZqf73DVOsQQ7kNvgGlKJuj&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYD7x7FhkS9DSNJt5VK1NqdTpT8CEjRkWhDUJ7RGbMhTCg&oe=670E5A92"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "SMALL.CAPSULE.VARIANT.png", "id": "1942826292828817", "uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/38974439_1942826296162150_5288366189613001907_n.png?_nc_cat=109&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=8cneQQUoUVUQ7kNvgGbNsIQ&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYCqNdwUYAxe409PQG1HR0VUnALrKSs0-GDhxjaYYrkw8Q&oe=670E6269"}, "display_name": "Wizard's Legacy", "keywords": ["wizard", "magic", "roguelike", "melee", "combat"], "long_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be.\n\n{3648923568693208}\nA desperate father, bound by a dark pact, transforms into a wizard trapped within a cursed labyrinth. Each victory grants power, but death returns him to the start. Explore the labyrinth's ever-changing depths, where every battle unveils its grim history. Can you master magic, overcome enemies, and save your child?\n\n{362183290313011}\n\n{459743683357113}\nDive deeper, shaping the world with every decision. Explore branching paths, unearth secrets, and face escalating challenges. Collect potions and power-ups scattered throughout to enhance your magic and forge your destiny as a powerful wizard.\n\n{828863472676196}\nUnleash your inner wizard! Draw symbols to control fireballs, ice walls, and lightning. Feel the power surge as you master arcane combat.\n\n{1407283433268429}\n\n{1453454962100883}\nChoose from a variety of playable characters, each with unique spells and abilities. Experiment with different playstyles \u2013 fiery mage, cunning illusionist, or something else entirely?\n\n{1136617717392676}\nThe labyrinth teems with cunning foes, each demanding a unique strategy. Test your skills against a diverse array of enemies, adapting tactics to exploit weaknesses and emerge victorious.\n\n{788110426812574}\n\n{1584321828806767}\nImmerse yourself in stunning visuals. Explore dynamic dungeons, lush forests, and ominous landscapes, each meticulously detailed for an unforgettable VR experience.\n\n\n{1415112652482029}\n\n", "short_description": "Wizard\u2019s Legacy blends VR immersion with roguelite replayability, offering action, adventure, and fantasy. Play as a powerful wizard, explore dynamic dungeons, face formidable foes, and uncover ancient secrets. Become the wizard you were meant to be."}]}, "developer_name": null, "developer_privacy_policy_url": "https://wizardslegacy.widegamestudio.com/privacy.html", "developer_terms_of_service_url": "https://wizardslegacy.widegamestudio.com/terms.html", "publisher_name": "Wide Game Studio", "support_website_url": null, "website_url": "https://wizardslegacy.widegamestudio.com/index.html", "category": null, "comfort_rating": "COMFORTABLE_FOR_SOME", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "2691890164460465"}, {"id": "459781504968480"}], "external_subscription_type": "NOT_REQUIRED", "genres": [], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING", "ROOM_SCALE"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "7979045852208466"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-iad3-1.oculuscdn.com/v/t64.5771-25/86655528_414792768082741_2904469078414870906_n.png?stp=dst-png_s360x360&_nc_cat=102&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=Ro3iXLLLQQMQ7kNvgFaP3Nz&_nc_ht=scontent-iad3-1.oculuscdn.com&oh=00_AYBGneHVXxJWsiF3qIumnw_5ttaftBdqQ4aJLy6kjJjLMg&oe=670E6299"}, "is_concept": false, "is_test": fals