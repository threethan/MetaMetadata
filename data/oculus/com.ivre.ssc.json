e": "shuttle-image-3.png", "id": "360564375114367", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38974670_360564378447700_4924651884064022442_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=JWpOR9g5_1cQ7kNvgEuHbT5&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYD2urKvD2cLeJfEpzBhXGNejiT00XE4Y5mvITb8W-9L5w&oe=677BD16C"}, {"file_name": "migrated_image.png", "id": "923746698083840", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/75210397_2540519289364681_7415879670748413952_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=q-slR8GS9DAQ7kNvgFY8zja&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYAGc5D908YV5aAY22QQDik9871sunJBhzspHipAaxLqpA&oe=677BAA86"}, {"file_name": "shuttle-image-1.png", "id": "368222790852487", "uri": "https://scontent-ams4-1.oculuscdn.com/v/t64.5771-25/38974792_368222794185820_4714922044610919664_n.png?_nc_cat=110&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=VTVWKVQCXl4Q7kNvgGPV7M9&_nc_zt=3&_nc_ht=scontent-ams4-1.oculuscdn.com&oh=00_AYDPA94Ze_mUaEE_M8-7Py4azLw8OwyIGTW_OZpd8M7OUA&oe=677BD63C"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "shuttle-image-2.png", "id": "347030936441470", "uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/38982442_347030939774803_7088371903635342664_n.png?_nc_cat=108&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=6dOFXs0UQ44Q7kNvgGZFEgQ&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDjBgUx_hJ1mLiXKwZOOZ4C9UpjYfOxWMtYntzumNmYJw&oe=677BABF0"}, "display_name": "Shuttle Commander", "keywords": ["Flight", "Simulator", "Sim", "Space", "Shuttle"], "long_description": "Shuttle Commander is an accurate physics-based flight simulator where you take to the controls of the space shuttle and land it at various real-world landing sites such as Kennedy Space Centre, White Sands Air Force Base and Edwards Air Force Base. Players can also experience the launch of the Hubble Space Telescope from the cockpit of Discovery in a real time launch experience using original NASA cockpit audio and mission data. Finally, you can view some of the amazing imagery from the Hubble Space Telescope which has been collecting data over the past 30 years from 568 kilometres above us.", "short_description": "Shuttle Commander is an accurate physics-based flight simulator where you take to the controls of the space shuttle and land it at various real-world landing sites such as Kennedy Space Centre, White Sands Air Force Base and Edwards Air Force Base."}]}, "developer_name": "Immersive VR Education", "developer_privacy_policy_url": "https://engagevr.io/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Immersive VR Education", "support_website_url": null, "website_url": "https://engagevr.io/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["FLYING", "SIMULATION", "SPACE_UNIVERSE"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "274968878165869"}, "review_messages": [""]}]}, "cover_square_image": {"uri": "https://scontent-ams2-1.oculuscdn.com/v/t64.5771-25/39031436_2347691125525654_94108427082714690_n.png?stp=dst-png_s360x360&_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=1UA_HTwC0UMQ7kNvgGk1jXG&_nc_zt=3&_nc_ht=scontent-ams2-1.oculuscdn.com&oh=00_AYDc6eWan9xTocu0sicyUwWlAK8qgWCUfSexADnWbw2Jpg&oe=677BB923"}, "is_concept": false, "is_test": false, "is_trial_offer_valid": false, "display_name": "Shuttle Commander", "platform": "ANDROID_6DOF", "context_category": {"context_category": "GAMES", "id": "