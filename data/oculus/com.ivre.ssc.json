ginal NASA cockpit audio and mission data. Finally, you can view some of the amazing imagery from the Hubble Space Telescope which has been collecting data over the past 30 years from 568 kilometres above us.", "short_description": "Shuttle Commander Quest is an accurate physics-based flight simulator where you take to the controls of the space shuttle and land it at various real-world landing sites such as Kennedy Space Centre, White Sands Air Force Base and Edwards Air Force Base."}]}, "developer_name": "Immersive VR Education", "developer_privacy_policy_url": "http://www.immersivevreducation.com/", "developer_terms_of_service_url": null, "publisher_name": "Immersive VR Education", "support_website_url": null, "website_url": "http://www.immersivevreducation.com/", "category": "GAMES", "comfort_rating": "COMFORTABLE_FOR_MOST", "comfort_tags": [], "context_category": {"id": "2743326035925534", "context_category": "GAMES"}, "context_topics": [{"id": "331529188132278"}], "external_subscription_type": "NOT_REQUIRED", "genres": ["SPACE_UNIVERSE", "SIMULATION", "FLYING"], "has_in_app_ads": null, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "en_US"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "395847652314427"}}]}, "scheduled_offers": {"count": 1, "nodes": [{"status": "PUBLISHED", "id": "2492160164411542"}]}, "baseline_offer": {"id": "2492160164411542"}, "is_approved": true, "firstOffer": {"nodes": [{"start_time": 1600966800, "status": "PUBLISHED", "id": "2492160164411542"}]}, "liveChannel": {"nodes": [{"latest_supported_binary": {"__typename": "AndroidBinary", "binary_test_results": {"nodes": []}, "id": "3435069303199115", "version": "0.64"}, "id": "453841828676333", "channel_name": "LIVE"}]}, "is_for_o