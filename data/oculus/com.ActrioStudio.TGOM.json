K_E&oh=00_AYCNoN0fEiYbzixWDRJfPG3RLHM2OnUDtIpMDkQKNBBw6A&oe=66D98198"}, {"file_name": "Screenshot_3.png", "id": "389076903331488", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036686_389076906664821_2660622704348240302_n.png?_nc_cat=105&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=eB2Hu6XWa9YQ7kNvgFM5nfr&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am2kLRukNPVb1ghkhWvPK_E&oh=00_AYB9wxN8wcBEO1zls1JVd7CTGAs-V2xlxjk1XcPw9T95Jg&oe=66D9B1A2"}, {"file_name": "Screenshot_6.png", "id": "1103746716896357", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/39036641_1103746720229690_4764254891439105056_n.png?_nc_cat=104&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=cXObVVZPC5IQ7kNvgEIiaUy&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am2kLRukNPVb1ghkhWvPK_E&oh=00_AYB7d0GtzNRC94d88sX_GiohJFEyoRz12mMuyBryLV8YSw&oe=66D9997E"}, {"file_name": "Screenshot_2.png", "id": "2219903311518583", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/38974837_2219903314851916_6282926995332431501_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=lFj8UcfYT1AQ7kNvgGCZwTR&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am2kLRukNPVb1ghkhWvPK_E&oh=00_AYDYZB_4hFhI2S7nI_iiLgV570lCc_TZfORmmJyWfN9Vzg&oe=66D9A0E7"}], "video_trailer": null, "video_trailer_thumbnail": {"file_name": "COVER_Landscape.png", "id": "1201511510643854", "uri": "https://scontent.oculuscdn.com/v/t64.5771-25/57568668_1201511513977187_8294533139069675396_n.png?_nc_cat=106&ccb=1-7&_nc_sid=6e7a0a&_nc_ohc=skgTlp49bs4Q7kNvgE0kVkc&_nc_ht=scontent.oculuscdn.com&_nc_gid=Am2kLRukNPVb1ghkhWvPK_E&oh=00_AYBKmuzyGE769moG0_1iHyAvoHONzPkOqgsgWmxzeJuh7g&oe=66D99994"}, "display_name": "The Great Ocean ", "keywords": [], "long_description": "In the game you explore in a high-tech ROV submarine the earth\u2019s oceans from the best diving spots in the Galapagos or in Cozumel in Mexico to the Icebergs in the Arctic and the Deep Sea and many other fascinating places around our planet's huge underwater world. In each of the levels you solve quests with your ROV's upgradeable tools based on real sunken submarines, WW2 battleship wrecks, Deep Sea creatures or Caribbean coral reefs. You will also encounter all of the giants and living wonders of the oceans from sharks, to dolphins, sea turtles and of course the blue whale and learn more about this unique, beautiful and threatened world. With your mission success you contribute to protect and save the oceans. Many hours of gameplay with a personal story, great interaction and challenging quests with a global leaderboard engage players on the exploration of the oceans and to go where no one has gone before.", "short_description": "Dive into an adventure of the earth\u2019s oceans. Explore in your high-tech submarine fascinating spots like the Galapagos or the Deep Sea and use your upgradeable tools to solve quests when you discover sunken WW2 battleships or deep sea creatures. Swim with majestic whales, sharks and sea turtles."}]}, "developer_name": null, "developer_privacy_policy_url": "https://actrio-studio.de/privacy-policy/", "developer_terms_of_service_url": null, "publisher_name": "Actrio Studio UG", "support_website_url": null, "website_url": "https://www.actrio-studio.com/", "category": "GAMES", "comfort_rating": "NOT_RATED", "comfort_tags": [], "context_category": null, "context_topics": [], "external_subscription_type": "NOT_REQUIRED", "genres": ["EDUCATIONAL", "EXPLORATION", "SIMULATION"], "has_in_app_ads": false, "internet_connection": "NOT_REQUIRED", "play_area": "NO_MOVEMENT", "recommended_graphics": null, "recommended_memory_gb": null, "recommended_processor": null, "supported_in_app_languages": ["en", "de"], "supported_input_devices": ["OCULUS_TOUCH"], "supported_player_modes": ["SITTING", "STANDING"], "supported_tracking_modes": [], "user_interaction_modes": ["SINGLE_USER"], "id": "767983510992950"}}]}, "scheduled_offers": {"count": 6, "nodes": [{"status": "PENDING", "id": "409337895486603"}, {"status": "PUBLISHED", "id": "610610321006262"}, {"status": "PENDING", "id": "1260908531416319"}, {"s